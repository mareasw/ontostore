@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_agent_development_triggering_examples a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "triggering-examples" ;
    skos:broader "Reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/agent-development" ;
    oc:contentHash "2a5ea013c97fc9f2c1ed55f96c6d5da2c2378695f7714bfb2c2e61bfbc9d228f" ;
    oc:differentia "that teaches best practices for writing effective `<example>` blocks in agent descriptions for reliable triggering in Claude Code plugins" ;
    oc:extends oc:skill_anthropics_claude_code_agent_development ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "agent-name or triggering scenario" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_58da0fd3,
        oc:kn_aef4e3ff,
        oc:kn_b0d37b06,
        oc:kn_b759e090,
        oc:kn_dc384d75 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:AgentDescriptionDrafted ;
    oc:resolvesIntent "debug agent triggering issues",
        "improve agent triggering reliability",
        "learn example block format for agents",
        "write triggering examples for agents" ;
    oc:yieldsState oc:AgentExamplesComplete .

oc:kn_58da0fd3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining how many examples to include in an agent description" ;
    oc:directiveContent "Include 2-4 examples per agent description. Minimum 2 (explicit request + one variation), recommended 3-4, maximum 6." ;
    oc:hasRationale "Too few examples reduces triggering reliability; too many makes the description excessively long and may confuse the model." ;
    oc:severityLevel "HIGH" .

oc:kn_aef4e3ff a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing multiple examples for the same agent" ;
    oc:directiveContent "Vary user message phrasing across examples to cover synonyms and alternative expressions of the same intent (e.g., 'Review my code', 'Can you check this implementation?', 'Look over my changes')." ;
    oc:hasRationale "Users express the same intent in many different ways; varied phrasings teach the model to recognize the underlying intent regardless of surface wording." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b0d37b06 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any agent triggering example" ;
    oc:directiveContent "Every example block must include four components: Context (what led to the interaction), user message (exact phrasing), assistant response before triggering, and commentary explaining why the agent should trigger." ;
    oc:hasRationale "Complete example blocks give Claude sufficient signal to understand both WHEN and WHY to trigger the agent, improving reliability." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b759e090 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing a comprehensive set of triggering examples" ;
    oc:directiveContent "Cover four triggering types in examples: explicit request (direct ask), proactive triggering (after relevant work), implicit request (user implies need), and tool usage pattern (based on prior tool usage)." ;
    oc:hasRationale "Diverse example types ensure the agent triggers correctly across the full range of realistic interaction patterns, not just direct requests." ;
    oc:severityLevel "HIGH" .

oc:kn_dc384d75 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any example block" ;
    oc:directiveContent "Never omit context or commentary from example blocks. Never show the agent's output instead of the triggering invocation. Never use vague context like 'User needs help'." ;
    oc:hasRationale "Missing context removes the situational signal; missing commentary removes the reasoning signal; showing output instead of triggering teaches the wrong behavior; vague context provides no discriminative value." ;
    oc:severityLevel "HIGH" .

