    oc:resolvesIntent "create agent instructions",
        "design agent system prompt",
        "improve agent prompt quality",
        "structure agent prompt",
        "write agent system prompt" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_1a13d418 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting to design a new agent system prompt" ;
    oc:directiveContent "Choose the agent pattern based on its primary function: Analysis (examine and report findings), Generation (create artifacts), Validation (check against criteria), or Orchestration (coordinate multi-step workflows)." ;
    oc:hasRationale "Using the right pattern ensures the prompt structure matches the agent's operational needs." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2574ec2b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining system prompt length" ;
    oc:directiveContent "System prompts should be 500-5,000 words. Minimum viable: ~500 words (role, 3 responsibilities, 5-step process, output format). Standard: 1,000-2,000 words. Avoid exceeding 10,000 words due to diminishing returns." ;
    oc:hasRationale "Too short leaves the agent without guidance; too long causes diminishing returns and can dilute critical instructions." ;
    oc:severityLevel "HIGH" .

oc:kn_661a8206 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When refining an agent system prompt after initial testing" ;
    oc:directiveContent "After testing an agent, iterate on its system prompt by: (1) identifying where it struggled, (2) adding missing guidance, (3) clarifying ambiguous instructions, (4) adding process steps for edge cases, (5) re-testing." ;
    oc:hasRationale "System prompts are rarely perfect on first draft; iterative refinement based on observed failures is the most effective improvement method." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6cc14ecb a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When testing a completed system prompt" ;
    oc:directiveContent "Before finalizing a system prompt, verify it enables the agent to handle: typical task execution, documented edge cases, error scenarios, unclear requirements, large/complex inputs, and empty/missing inputs." ;
    oc:hasRationale "These six test categories cover the full spectrum of operational scenarios an agent will encounter." ;
    oc:severityLevel "HIGH" .

oc:kn_7bebbae7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the output format section" ;
    oc:directiveContent "Never leave the output format undefined with instructions like 'provide a report'. Always specify exact structure with section headers, expected content per section, and formatting requirements." ;
    oc:hasRationale "Undefined output formats lead to inconsistent, unpredictable agent responses that are hard to parse or use downstream." ;
    oc:severityLevel "HIGH" .

oc:kn_8413fdf7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any instruction in a system prompt" ;
    oc:directiveContent "Use second person ('You are responsible for...') when addressing the agent. Be specific about what to check, where to look, and how to report. Give concrete steps with tool names." ;
    oc:hasRationale "Second person creates direct accountability. Specificity eliminates ambiguity that causes agent errors." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b6dd9a7c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing core responsibilities section" ;
    oc:directiveContent "Never use vague responsibilities like 'help the user' or 'provide assistance'. Instead, write specific, actionable responsibilities like 'Analyze TypeScript code for type safety issues' and 'Identify missing type annotations and improper any usage'." ;
    oc:hasRationale "Vague instructions give the agent no clear behavioral boundary, leading to inconsistent or off-topic outputs." ;
    oc:severityLevel "HIGH" .

oc:kn_f9e34063 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any agent system prompt" ;
    oc:directiveContent "Every agent system prompt must include: role description, core responsibilities, step-by-step process, quality standards, output format, and edge case handling." ;
    oc:hasRationale "These six sections provide the minimum scaffolding for an agent to operate autonomously and consistently." ;
    oc:severityLevel "CRITICAL" .

