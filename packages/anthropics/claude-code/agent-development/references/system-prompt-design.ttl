@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_agent_development_system_prompt_design a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "system-prompt-design" ;
    skos:broader "Prompt engineering guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/agent-development" ;
    oc:contentHash "eaac53eaaf8326ac04428987280fb5041920b7571477ad41742517c5aac683fc" ;
    oc:differentia "that provides structured patterns and best practices for writing effective agent system prompts across four archetypes (analysis, generation, validation, orchestration) with quality standards and testing methodology" ;
    oc:extends oc:skill_anthropics_claude_code_agent_development ;
    oc:handlesFailure oc:InvalidPromptStructure,
        oc:MissingRequiredSections ;
    oc:hasArgumentHint "agent-type (analysis|generation|validation|orchestration)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_10906a2d,
        oc:kn_401df093,
        oc:kn_663a224e,
        oc:kn_75a113f2,
        oc:kn_99c7d667,
        oc:kn_9d20586d,
        oc:kn_c544798e ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:AgentRoleDefined ;
    oc:resolvesIntent "choose the right system prompt pattern for an agent type",
        "design agent system prompts",
        "test and iterate on agent system prompts",
        "write effective system prompts for agents" ;
    oc:yieldsState oc:SystemPromptAuthored .

oc:kn_10906a2d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a system prompt template for a new agent" ;
    oc:directiveContent "Match the system prompt pattern to the agent archetype: Analysis agents prioritize findings with severity and file:line references; Generation agents follow gather-context-then-create flow; Validation agents produce pass/fail with violation details; Orchestration agents manage phased execution with monitoring." ;
    oc:hasRationale "Each archetype has fundamentally different operational patterns, and using the wrong template leads to missing critical sections that the agent needs for that type of work." ;
    oc:severityLevel "MEDIUM" .

oc:kn_401df093 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any instruction within a system prompt" ;
    oc:directiveContent "Use second person ('You are...') when addressing the agent, be specific rather than vague in instructions, and provide concrete actionable steps with tool names." ;
    oc:hasRationale "Second person creates clear agency, specificity eliminates ambiguity, and concrete steps prevent the agent from guessing at implementation details." ;
    oc:severityLevel "HIGH" .

oc:kn_663a224e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any agent system prompt" ;
    oc:directiveContent "Every agent system prompt must include five core sections: specific role description, core responsibilities, detailed process steps, quality standards, and defined output format." ;
    oc:hasRationale "These five sections provide the minimal scaffolding needed for an agent to operate autonomously and produce consistent, high-quality output." ;
    oc:severityLevel "CRITICAL" .

oc:kn_75a113f2 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When finalizing any agent system prompt" ;
    oc:directiveContent "Always include edge case handling in system prompts: define what to do when no issues are found, when there are too many issues, when input is unclear, and when dependencies are missing." ;
    oc:hasRationale "Edge cases are where agents most frequently fail or produce undesired behavior; pre-defining handling prevents hallucination and poor decision-making under ambiguity." ;
    oc:severityLevel "HIGH" .

oc:kn_99c7d667 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any section of an agent system prompt" ;
    oc:directiveContent "Never write vague responsibilities like 'help the user' or 'provide assistance', missing process steps like 'analyze the code and provide feedback', or undefined output formats like 'provide a report'." ;
    oc:hasRationale "Vague instructions cause agents to produce inconsistent, low-quality outputs because they lack concrete guidance on what to do, how to do it, and what the result should look like." ;
    oc:severityLevel "HIGH" .

oc:kn_9d20586d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining system prompt length" ;
    oc:directiveContent "System prompts should be at minimum 500 words, ideally 1,000-2,000 words for standard agents, and should not exceed 10,000 words due to diminishing returns." ;
    oc:hasRationale "Below 500 words lacks sufficient guidance for autonomous operation; above 10,000 words wastes context window capacity with negligible quality improvement." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c544798e a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "After writing or modifying a system prompt" ;
    oc:directiveContent "Test system prompts by verifying the agent can handle typical tasks, edge cases, error scenarios, unclear requirements, large inputs, and empty inputs based on the prompt alone; iterate by adding missing guidance where the agent struggled." ;
    oc:hasRationale "System prompts are specifications that must be validated against real execution; iteration based on observed failures is the most reliable path to quality." ;
    oc:severityLevel "MEDIUM" .

