oc:kn_0a408394 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing code review or analysis agents" ;
    oc:directiveContent "For code review agents, assume the user wants to review recently written code, not the whole codebase, unless explicitly stated otherwise. Include proactive triggering examples showing agent use after code is written." ;
    oc:hasRationale "Defaulting to recent changes is more practical and avoids overwhelming the agent with entire codebase context" .

oc:kn_0bdc2342 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When debugging agent triggering issues" ;
    oc:directiveContent "Common triggering failures: missing <example> blocks, no 'Use this agent when...' prefix, examples showing agent responding directly instead of using Agent tool, or examples missing context/commentary." ;
    oc:hasRationale "These are the most common reasons agents fail to trigger reliably in production" .

oc:kn_0feab70b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any new agent" ;
    oc:directiveContent "1. Take user request for agent functionality → 2. Feed to Claude with the agent-creation system prompt → 3. Get JSON output (identifier, whenToUse, systemPrompt) → 4. Convert to agent markdown file with frontmatter (name, description, model:inherit, color, tools) → 5. Validate with validate-agent.sh → 6. Test triggering conditions → 7. Add to plugin's agents/ directory" ;
    oc:stepOrder 1 .

oc:kn_399f63ae a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any agent system prompt" ;
    oc:directiveContent "System prompts must be specific rather than generic, use second person ('You are...', 'You will...'), include concrete steps, define output format, and cover edge cases. Balance comprehensiveness with clarity — every instruction should add value." ;
    oc:hasRationale "Vague instructions lead to unpredictable agent behavior; specificity enables autonomous, reliable operation" .

oc:kn_81157af6 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "After creating or modifying an agent file" ;
    oc:directiveContent "./scripts/validate-agent.sh agents/your-agent.md" .

oc:kn_824aace8 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating agent configurations" ;
    oc:directiveContent """{
  "identifier": "lowercase-hyphenated-name",
  "whenToUse": "Use this agent when... Examples:\\n<example>\\nContext: [situation]\\nuser: \\"[message]\\"\\nassistant: \\"[response]\\"\\n<commentary>[reasoning]</commentary>\\nassistant: \\"I'll use the [agent-name] agent to [action]\\"\\n</example>",
  "systemPrompt": "You are [role]...\\n**Your Core Responsibilities:**\\n1. [responsibility]\\n**Process:**\\n1. [step]\\n**Output Format:**\\n[format]"
}""" ;
    oc:templateVariables "agent-name",
        "format",
        "identifier",
        "responsibility",
        "role",
        "step",
        "systemPrompt",
        "whenToUse" .

oc:kn_950f74a1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing system prompts" ;
    oc:directiveContent "System prompt length guidelines: minimum ~500 words (role + 3 responsibilities + 5-step process + output format), standard 1,000-2,000 words, comprehensive 2,000-5,000 words. Avoid >10,000 words due to diminishing returns." ;
    oc:hasRationale "Too short = under-specified agent; too long = wasted tokens with no added capability" .

oc:kn_c8da1798 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing agent descriptions/whenToUse fields" ;
    oc:directiveContent "Agent description must start with 'Use this agent when...' and include 2-4 <example> blocks with Context, user message, assistant response, and <commentary> explaining WHY the agent triggers." ;
    oc:hasRationale "Structured examples with commentary are the primary mechanism for reliable agent triggering — they teach the system when to invoke the agent" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ca8c4b4a a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting JSON output to agent markdown file" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
name: [identifier]
description: [whenToUse with examples]
model: inherit
color: [blue|cyan|green|yellow|magenta|red]
tools: ["Read", "Write", "Grep"]  # Optional
---

[systemPrompt content]""" .

oc:kn_e3330e78 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating agent identifiers" ;
    oc:directiveContent "Never use generic terms like 'helper' or 'assistant' as agent identifiers. Identifiers must use lowercase letters, numbers, and hyphens only, be 2-4 words, and clearly indicate the agent's primary function." ;
    oc:hasRationale "Generic names make agents indistinguishable and fail to convey purpose for triggering" ;
    oc:severityLevel "HIGH" .

oc:kn_e56cd4fe a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating agents for a specific project" ;
    oc:directiveContent "Include project-specific context from CLAUDE.md files when creating agents — align with project patterns, follow coding standards, and respect established practices." ;
    oc:hasRationale "Agents that respect project conventions integrate better and produce more relevant output" .

