oc:kn_1735a0f8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When iterating on generated agents" ;
    oc:directiveContent "Start with AI-assisted generation then refine manually — focus manual edits on better examples, more specific prompts, clearer process steps, and better output format definitions" ;
    oc:hasRationale "Combines the speed and comprehensiveness of AI generation with the precision of manual refinement for optimal results" .

oc:kn_4a1c8043 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting agent requirement descriptions" ;
    oc:directiveContent "Include triggering preferences, project context (tech stack, conventions), and output format expectations in the agent description for best results" ;
    oc:hasRationale "Rich context produces agents with better examples, more specific prompts, and clearer triggering conditions" .

oc:kn_7e6b8667 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When generating any new agent" ;
    oc:directiveContent "1. Describe agent need (task, trigger, proactive/reactive, responsibilities) 2. Send generation prompt to Claude with agent-creation-system-prompt loaded 3. Claude returns JSON with identifier, whenToUse, systemPrompt 4. Convert JSON to agents/[identifier].md with frontmatter (name, description, model, color, tools) and systemPrompt body 5. Validate and iterate" ;
    oc:hasRationale "Provides a repeatable, structured workflow that ensures consistency across all generated agents" ;
    oc:stepOrder 1 .

oc:kn_848412af a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When converting generated JSON to an agent .md file" ;
    oc:directiveContent """---
name: {identifier}
description: {whenToUse}
model: inherit
color: {blue|cyan|green|yellow|magenta|red}
tools: [{"Read", "Write", "Grep", "Glob", ...}]
---
{systemPrompt}""" ;
    oc:templateVariables "color",
        "identifier",
        "systemPrompt",
        "tools",
        "whenToUse" .

oc:kn_9f91afcb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sending the generation request to Claude" ;
    oc:directiveContent "The generation prompt must include 'Return ONLY the JSON object, no other text' to ensure parseable output" ;
    oc:hasRationale "Without this constraint, Claude may include explanatory text that breaks automated parsing" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b42f5eac a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing agent requirement descriptions" ;
    oc:directiveContent "Never use vague descriptions like 'I need an agent that helps with code' — always specify task scope, triggering preferences, project context, and output expectations" ;
    oc:hasRationale "Vague inputs produce generic, low-quality agents that lack specificity and usefulness" ;
    oc:severityLevel "HIGH" .

oc:kn_bffdb7c8 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "After generating any agent file" ;
    oc:directiveContent "Validate generated agent structure with ./scripts/validate-agent.sh agents/your-agent.md and test triggering with scenarios from examples" ;
    oc:hasRationale "Catches structural issues and ensures the agent triggers correctly before deployment" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cffd1ea4 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When Claude returns generated agent configuration" ;
    oc:directiveContent "{\"identifier\": \"agent-name\", \"whenToUse\": \"Use this agent when... Examples: <example>...</example>\", \"systemPrompt\": \"You are... **Your Core Responsibilities:**...\"}" ;
    oc:templateVariables "identifier",
        "systemPrompt",
        "whenToUse" .

