@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_agent_development_agent_creation_prompt a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "agent-creation-prompt" ;
    skos:broader "generation guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/agent-development" ;
    oc:contentHash "fddc24d6f7c67722e5c007087d19606cf116a89f3360519c2ae8f52989f40a4d" ;
    oc:dependsOnSkill oc:skill_agent_development ;
    oc:differentia "that instructs users how to interact with the agent-creation system prompt to produce structured agent configurations via AI-assisted generation" ;
    oc:extends oc:skill_anthropics_claude_code_agent_development ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "agent description or requirements text" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_50cc1884,
        oc:kn_56ec0a82,
        oc:kn_5df7c66f,
        oc:kn_94f502e2,
        oc:kn_a98db256 ;
    oc:isUserInvocable true ;
    oc:nature "template" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "convert agent descriptions to markdown files",
        "create agent files from descriptions",
        "generate agent configurations",
        "learn agent creation workflow" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_50cc1884 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "After converting JSON to agent file" ;
    oc:directiveContent "Validate generated agents using the validation script and test with scenarios from the examples before deploying." ;
    oc:hasRationale "Generated agents may have imperfect triggering examples or missing edge cases; validation catches structural issues before use." ;
    oc:severityLevel "MEDIUM" .

oc:kn_56ec0a82 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When generating any new agent" ;
    oc:directiveContent "Follow the 4-step workflow: (1) describe your agent need, (2) send the generation prompt to Claude with the agent-creation-system-prompt loaded, (3) receive JSON output with identifier/whenToUse/systemPrompt, (4) convert JSON to a markdown agent file under agents/ directory." ;
    oc:hasRationale "This structured workflow ensures complete, consistent agent configurations that follow proven patterns." ;
    oc:severityLevel "HIGH" .

oc:kn_5df7c66f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When the generated agent needs improvement" ;
    oc:directiveContent "Start with AI-assisted generation then refine manually for best results — edit examples, system prompt specificity, process steps, and output format." ;
    oc:hasRationale "Generation provides a strong foundation quickly; manual refinement adds project-specific precision that AI may miss." ;
    oc:severityLevel "LOW" .

oc:kn_94f502e2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting generated JSON to the agent markdown file" ;
    oc:directiveContent "The agent file must have frontmatter with name, description, model, color, and optional tools, followed by the systemPrompt body." ;
    oc:hasRationale "Consistent file structure ensures the agent system can correctly parse and activate the agent." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a98db256 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the agent description for generation" ;
    oc:directiveContent "Be specific in agent requests — include triggering preferences, project context, and output expectations rather than vague descriptions." ;
    oc:hasRationale "Specific requests yield agents with precise triggering conditions, relevant domain knowledge, and well-defined output formats." ;
    oc:severityLevel "MEDIUM" .

