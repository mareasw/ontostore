@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_agent_development_complete_agent_examples a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "complete-agent-examples" ;
    skos:broader "Template collection" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/agent-development" ;
    oc:contentHash "36fde2ac46665ba98804ec0fb6e94022795cba063e932d670c9463deedd30e72" ;
    oc:differentia "provides four production-ready agent configurations (code reviewer, test generator, docs generator, security analyzer) with complete frontmatter and system prompts, along with customization guidance for adapting them to new domains" ;
    oc:extends oc:skill_anthropics_claude_code_agent_development ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "Bash",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "agent type or use case (code-review, test-generator, docs-generator, security-analyzer)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_5645c52e,
        oc:kn_96427abe ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DirectoryWritable ;
    oc:resolvesIntent "copy production-ready agent templates",
        "create code review agent",
        "create documentation generation agent",
        "create security analysis agent",
        "create test generation agent",
        "customize agent templates for specific domains",
        "learn agent structure from working examples" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_5645c52e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any new agent from these templates" ;
    oc:directiveContent "Each agent template follows a consistent structure: YAML frontmatter (name, description with examples, model, color, tools) followed by a system prompt with Core Responsibilities, Process steps, Quality Standards, Output Format, and Edge Cases." ;
    oc:hasRationale "Consistent structure ensures agents are maintainable, predictable, and follow proven patterns from production use" ;
    oc:severityLevel "HIGH" .

oc:kn_96427abe a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring the tools field in agent frontmatter" ;
    oc:directiveContent "Match tool access to agent purpose: read-only agents get [Read, Grep, Glob], generator agents get [Read, Write, Grep], executor agents get [Read, Write, Bash, Grep], and full-access agents omit the tools field entirely." ;
    oc:hasRationale "Principle of least privilege — agents should only have the tools they genuinely need to prevent unintended side effects" .

