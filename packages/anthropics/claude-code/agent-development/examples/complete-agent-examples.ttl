Context: {situation}
user: "{user message}"
assistant: "{response}"
<commentary>{reasoning}</commentary>
</example>
model: inherit
color: {semantic-color}
tools: ["{tool-list}"]
---
{Agent instructions}""" .

oc:kn_49866f87 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When designing agent output templates" ;
    oc:directiveContent "Every agent must define an explicit output format section with section headers, severity-based categorization, file:line references, and actionable recommendations. Include edge case handling for empty results, overload, and missing context." ;
    oc:hasRationale "Structured output ensures consistent, parseable results and prevents vague or unactionable feedback" ;
    oc:severityLevel "HIGH" .

oc:kn_a7edb0b4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring agent tool access" ;
    oc:directiveContent "Do not give read-only agents Write or Bash tools. Restrict tool access to the minimum needed: read-only agents get Read/Grep/Glob, generator agents get Read/Write/Grep, executor agents get Read/Write/Bash/Grep." ;
    oc:hasRationale "Over-provisioned tools increase the blast radius of agent errors and can cause unintended side effects" ;
    oc:severityLevel "HIGH" .

