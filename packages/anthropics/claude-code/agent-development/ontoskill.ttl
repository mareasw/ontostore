@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_agent_development a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "agent-development" ;
    skos:broader "Agent development framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/agent-development" ;
    oc:contentHash "38ceb4a757c39a5a674e273b7520f6b02011c35a4f1d163d7dd701ddce9ac915" ;
    oc:differentia "that provides structure, validation, and best practices for creating autonomous agent configurations in Claude Code plugins with YAML frontmatter, triggering conditions, and system prompts" ;
    oc:handlesFailure oc:InvalidInput,
        oc:ValidationError ;
    oc:hasAllowedTool "Bash",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "agent description or requirements" ;
    oc:hasCategory "development" ;
    oc:hasDescription "This skill should be used when the user asks to \"create an agent\", \"add an agent\", \"write a subagent\", \"agent frontmatter\", \"when to use description\", \"agent examples\", \"agent tools\", \"agent colors\", \"autonomous agent\", or needs guidance on agent structure, system prompts, triggering conditions, or agent development best practices for Claude Code plugins." ;
    oc:hasName "agent-development" ;
    oc:impartsKnowledge oc:kn_0b272053,
        oc:kn_1773fb63,
        oc:kn_2f640b81,
        oc:kn_37a938d7,
        oc:kn_6230e51c,
        oc:kn_68d550c5,
        oc:kn_6dd79bc2,
        oc:kn_72ada212 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "add an agent to plugin",
        "create an agent",
        "define agent triggering conditions",
        "design agent system prompts",
        "learn agent development best practices",
        "validate agent configuration",
        "write a subagent" ;
    oc:yieldsState oc:AgentCreated,
        oc:AgentValidated .

oc:kn_0b272053 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When creating a new agent from scratch" ;
    oc:directiveContent "Use AI-assisted generation first (feed requirements to Claude with the agent-creation-system-prompt), then manually refine the output for domain-specific patterns, custom tool combinations, and precise triggering conditions." ;
    oc:hasRationale "AI-assisted generation produces comprehensive, consistent agents quickly. Manual refinement adds domain expertise that generic generation misses." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1773fb63 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When choosing an agent name identifier" ;
    oc:directiveContent "Agent identifiers must be 3-50 characters, lowercase letters/numbers/hyphens only, must start and end with alphanumeric, and must avoid generic names like 'helper' or 'assistant'." ;
    oc:hasRationale "Identifiers are used for namespacing, invocation, and auto-discovery. Invalid identifiers break plugin loading." ;
    oc:severityLevel "HIGH" .

oc:kn_2f640b81 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing agent system prompts" ;
    oc:directiveContent "Never write system prompts in first person ('I am...', 'I will...') or use vague/generic instructions without concrete process steps, output format definitions, or quality standards." ;
    oc:hasRationale "First-person prompts confuse the agent's identity boundary. Vague instructions lead to inconsistent, low-quality autonomous behavior." ;
    oc:severityLevel "HIGH" .

oc:kn_37a938d7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring any agent system prompt" ;
    oc:directiveContent "System prompts should follow the standard structure: role description → core responsibilities → step-by-step process → quality standards → output format → edge cases. Use second person throughout." ;
    oc:hasRationale "Consistent structure ensures agents have all necessary guidance for autonomous operation, reducing ambiguity and improving reliability." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6230e51c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring agent tool access in frontmatter" ;
    oc:directiveContent "Limit agent tools to the minimum needed for the task (principle of least privilege). Read-only analysis: [Read, Grep, Glob]. Code generation: [Read, Write, Grep]. Testing: [Read, Bash, Grep]. Omit the tools field only when full access is truly needed." ;
    oc:hasRationale "Minimizing tool access reduces the blast radius of agent errors and prevents unintended side effects during autonomous operation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_68d550c5 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing any agent file" ;
    oc:directiveContent "Before deploying an agent, validate it with scripts/validate-agent.sh to check frontmatter structure, required fields, name format, description quality, example blocks, system prompt length and voice." ;
    oc:hasRationale "Automated validation catches structural errors that would cause silent failures at runtime." ;
    oc:severityLevel "HIGH" .

oc:kn_6dd79bc2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any agent description field" ;
    oc:directiveContent "The description field is the most critical part of an agent — it must include 'Use this agent when...' triggering conditions and 2-4 concrete <example> blocks with Context, user message, assistant response, and <commentary> explaining why the agent triggers." ;
    oc:hasRationale "The description field controls when Claude decides to invoke the agent autonomously. Poor descriptions cause missed triggers or false positives." ;
    oc:severityLevel "CRITICAL" .

oc:kn_72ada212 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring agent files" ;
    oc:directiveContent "System prompts must be under 10,000 characters (recommended 500-3,000). Descriptions must be 10-5,000 characters with examples. Agents are for autonomous multi-step work; commands are for user-initiated actions." ;
    oc:hasRationale "Oversized prompts degrade performance and increase cost. Confusing agents with commands leads to incorrect architecture decisions." ;
    oc:severityLevel "MEDIUM" .

