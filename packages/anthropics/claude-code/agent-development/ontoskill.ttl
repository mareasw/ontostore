oc:kn_06acf3f7 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When designing output format for analysis/review agents" ;
    oc:directiveContent """## Code Review Summary
[2-3 sentence overview]

## Critical Issues (Must Fix)
- `src/file.ts:42` - [Issue] - [Why critical] - [How to fix]

## Major Issues (Should Fix)
- `src/file.ts:15` - [Issue] - [Impact] - [Recommendation]

## Minor Issues (Consider Fixing)
- `src/file.ts:88` - [Issue] - [Suggestion]

## Positive Observations
- [Good practice]

## Overall Assessment
[Verdict and recommendations]""" ;
    oc:templateVariables "file_path",
        "issue",
        "line_number",
        "recommendation" .

oc:kn_09114606 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any agent file" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
name: {identifier}
description: Use this agent when {triggering_conditions}. Examples:

<example>
Context: {situation}
user: "{user_message}"
assistant: "{assistant_response}"
<commentary>
{why_trigger}
</commentary>
</example>

model: inherit
color: {blue|cyan|green|yellow|magenta|red}
tools: ["Read", "Grep", "Glob"]
---

You are {role} specializing in {domain}.

**Your Core Responsibilities:**
1. {responsibility_1}
2. {responsibility_2}

**Process:**
1. {step_1}
2. {step_2}

**Output Format:**
{output_template}""" ;
    oc:templateVariables "assistant_response",
        "domain",
        "identifier",
        "output_template",
        "responsibility_1",
        "responsibility_2",
        "role",
        "situation",
        "step_1",
        "step_2",
        "triggering_conditions",
        "user_message",
        "why_trigger" .

oc:kn_20dff583 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to create an agent vs a command" ;
    oc:directiveContent "Agents are for autonomous work; commands are for user-initiated actions. Always distinguish between the two when deciding what to create." ;
    oc:hasRationale "Misclassifying agents vs commands leads to incorrect triggering behavior and poor user experience" ;
    oc:severityLevel "HIGH" .

oc:kn_239972d2 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before deploying or testing an agent" ;
    oc:directiveContent "Validate agent files with scripts/validate-agent.sh before testing. Check: frontmatter structure, required fields, name format, description length, example blocks, system prompt length, second-person voice." ;
    oc:hasRationale "Structural validation catches common errors before they cause runtime failures" ;
    oc:severityLevel "MEDIUM" .

oc:kn_68089c9c a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating an agent file after creation" ;
    oc:directiveContent "./scripts/validate-agent.sh agents/{agent-name}.md" ;
    oc:hasRationale "Catches structural errors in frontmatter, description, and system prompt before runtime testing" .

oc:kn_7d272c3d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing agent system prompts" ;
    oc:directiveContent "System prompts must be written in second person ('You are...', 'You will...'), kept under 10,000 characters, and include: responsibilities, process steps, quality standards, output format, and edge cases." ;
    oc:hasRationale "First-person or vague prompts lead to inconsistent agent behavior and unclear operational boundaries" ;
    oc:severityLevel "HIGH" .

oc:kn_8b7b13a7 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Agent files must be placed in the agents/ directory of a Claude Code plugin. The plugin directory structure must already exist." .

oc:kn_9aea5c9f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing agent descriptions and colors" ;
    oc:directiveContent "Include 2-4 triggering examples covering: explicit request, proactive triggering, and edge case. Use consistent color coding: blue/cyan for analysis, green for generation, yellow for validation, red for security, magenta for creative." ;
    oc:hasRationale "Diverse examples ensure reliable triggering across user phrasing variations; consistent colors aid visual identification" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9f5483e0 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When using AI-assisted agent generation, Claude returns this JSON structure" ;
    oc:directiveContent """{
  "identifier": "{agent-name}",
  "whenToUse": "Use this agent when... <example>...</example>",
  "systemPrompt": "You are..."
}""" ;
    oc:templateVariables "agent-name",
        "systemPrompt",
        "whenToUse" .

oc:kn_d2f878c9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing agent identifiers" ;
    oc:directiveContent "Never use generic agent names like 'helper', 'assistant', 'agent', or 'tool'. Names must be 3-50 characters, lowercase with hyphens, starting and ending with alphanumeric." ;
    oc:hasRationale "Generic names cause naming collisions and make agents unidentifiable in multi-agent plugin environments" ;
    oc:severityLevel "HIGH" .

oc:kn_e79734a3 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a new agent" ;
    oc:directiveContent "1. Define agent purpose and triggering conditions. 2. Choose creation method (AI-assisted or manual). 3. Create agents/agent-name.md file. 4. Write frontmatter (name, description with examples, model, color, tools). 5. Write system prompt (role, responsibilities, process, quality standards, output format, edge cases). 6. Validate with scripts/validate-agent.sh. 7. Test triggering with real scenarios. 8. Document agent in plugin README." ;
    oc:hasRationale "This step-by-step workflow ensures complete, well-structured, and validated agents" ;
    oc:stepOrder 1 .

oc:kn_ec05e4c0 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When debugging agent triggering issues" ;
    oc:directiveContent "If an agent doesn't trigger: add more examples with varied phrasing, ensure context matches actual scenarios, verify commentary explains triggering logic. If agent triggers too often: make examples more specific and add negative examples." ;
    oc:hasRationale "Triggering problems are the most common agent failure mode and are resolved through example refinement" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f2524cac a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing agent frontmatter description" ;
    oc:directiveContent "The description field is the most critical field — it must include triggering conditions starting with 'Use this agent when...' and 2-4 <example> blocks with Context, user, assistant, and <commentary> elements." ;
    oc:hasRationale "Without proper triggering examples, Claude cannot reliably determine when to activate the agent" ;
    oc:severityLevel "CRITICAL" .

oc:kn_fce25cc2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring agent tool access" ;
    oc:directiveContent "Limit agent tools to minimum needed (principle of least privilege). Use ['Read', 'Grep', 'Glob'] for read-only analysis, ['Read', 'Write', 'Grep'] for generation, ['Read', 'Bash', 'Grep'] for testing." ;
    oc:hasRationale "Over-privileged agents can cause unintended side effects and security risks" ;
    oc:severityLevel "MEDIUM" .

