@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_skill_development_skill_creator_original a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "skill-creator-original" ;
    skos:broader "Skill creation guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/skill-development" ;
    oc:contentHash "8c0ce23bb87be91f5b0853c2e9815617c3858b63acdddfe5da47d2c2d3a60816" ;
    oc:differentia "provides a structured 6-step process for creating, editing, packaging, and iterating on modular skills that extend Claude's capabilities with specialized workflows, tool integrations, domain expertise, and bundled resources" ;
    oc:extends oc:skill_anthropics_claude_code_skill_development ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "skill-name and optional output-path" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_085ebe8b,
        oc:kn_6101ea42,
        oc:kn_7f082a00,
        oc:kn_958db548,
        oc:kn_e11da82e,
        oc:kn_e481b925,
        oc:kn_fefe294f ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create a new skill",
        "iterate on skill design",
        "package a skill for distribution",
        "plan skill contents and resources",
        "understand skill anatomy and structure",
        "update an existing skill" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_085ebe8b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing skill content across files" ;
    oc:directiveContent "Never duplicate information between SKILL.md and references/ files. Information should live in exactly one location. Prefer references/ for detailed content unless it is truly core to the skill." ;
    oc:hasRationale "Duplication causes context waste and risks inconsistency when content is updated in one location but not the other." ;
    oc:severityLevel "HIGH" .

oc:kn_6101ea42 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or editing any skill's content structure" ;
    oc:directiveContent "Use progressive disclosure: keep SKILL.md under 5,000 words (ideally 1,500-2,000), move detailed content to references/ files that are loaded only as needed." ;
    oc:hasRationale "Progressive disclosure prevents context window bloat by loading only essential instructions when the skill triggers, and deferring detailed references until Claude determines they are needed." ;
    oc:severityLevel "HIGH" .

oc:kn_7f082a00 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing or editing SKILL.md YAML frontmatter" ;
    oc:directiveContent "Write the frontmatter description in third-person with specific trigger phrases (e.g. 'This skill should be used when the user asks to \"create X\", \"configure Y\"'). Include exact phrases users would say." ;
    oc:hasRationale "The description field determines when Claude activates the skill. Specific trigger phrases ensure correct routing; third-person format is required by convention." ;
    oc:severityLevel "HIGH" .

oc:kn_958db548 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running scripts/package_skill.py" ;
    oc:directiveContent "Before packaging a skill, validate that: YAML frontmatter has required name and description fields, description uses third-person with trigger phrases, directory structure is correct, and all referenced files exist." ;
    oc:hasRationale "The packaging script validates automatically and will reject skills that don't meet requirements. Pre-validation saves iteration cycles." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e11da82e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning skill contents in Step 2" ;
    oc:directiveContent "To identify what resources a skill needs, analyze concrete usage examples: consider how to execute each from scratch, then identify which scripts, references, or assets would eliminate repeated work." ;
    oc:hasRationale "Concrete examples ground skill design in real usage patterns, ensuring resources are practical and necessary rather than speculative." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e481b925 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing skill body content" ;
    oc:directiveContent "Write the entire SKILL.md body using imperative/infinitive form (verb-first instructions), not second person. Use objective instructional language (e.g., 'To accomplish X, do Y' not 'You should do Y')." ;
    oc:hasRationale "Imperative form maintains consistency and clarity for AI consumption across all skills." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fefe294f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When creating any new skill from scratch" ;
    oc:directiveContent "When creating a skill, follow the 6-step process in order: (1) Understand with concrete examples, (2) Plan reusable contents, (3) Initialize with init_skill.py, (4) Edit the skill, (5) Package, (6) Iterate. Skip steps only with clear justification." ;
    oc:hasRationale "This ordered process ensures skills are well-understood before implementation, properly structured, validated, and continuously improved." ;
    oc:severityLevel "MEDIUM" .

