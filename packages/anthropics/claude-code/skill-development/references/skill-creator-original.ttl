@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_claude_code_skill_development_skill_creator_original a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "skill-creator-original" ;
    skos:broader "Skill authoring guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/skill-development" ;
    oc:contentHash "8c0ce23bb87be91f5b0853c2e9815617c3858b63acdddfe5da47d2c2d3a60816" ;
    oc:dependsOnSkill oc:skill_ontoskills_skill_development ;
    oc:differentia "provides a structured process for creating, editing, and packaging Claude Code skills with SKILL.md frontmatter, bundled resources, and progressive disclosure principles" ;
    oc:extends oc:skill_claude_code_skill_development ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "skill-name or skill description" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_0b20161e,
        oc:req_79a2a1a8 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "This skill provides guidance for creating effective skills." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "To create a skill, follow the \"Skill Creation Process\" in order, skipping steps only if there is a clear reason why they are not applicable." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "When editing the (newly-generated or existing) skill, remember that the skill is being created for another instance of Claude to use. Focus on including information that would be beneficial and non-obvious to Claude. Consider what procedural knowledge, domain-specific details, or reusable assets would help another Claude instance execute these tasks more effectively." ] ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 2 ;
                                            oc:textContent "Also, delete any example files and directories not needed for the skill. The initialization script creates example files in `scripts/`, `references/`, and `assets/` to demonstrate structure, but most skills won't need all of them." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "To begin implementation, start with the reusable resources identified above: `scripts/`, `references/`, and `assets/` files. Note that this step may require user input. For example, when implementing a `brand-guidelines` skill, the user may need to provide brand assets or templates to store in `assets/`, or documentation to store in `references/`." ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 1 ;
                                    oc:sectionTitle "Start with Reusable Skill Contents" ],
                                [ a oc:Section ;
                                    oc:hasContent _:ref_3de4999e90ae1d65,
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**Writing Style:** Write the entire skill using **imperative/infinitive form** (verb-first instructions), not second person. Use objective, instructional language (e.g., \"To accomplish X, do Y\" rather than \"You should do X\" or \"If you need to do X\"). This maintains consistency and clarity for AI consumption." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 2 ;
                                            oc:textContent "To complete SKILL.md, answer the following questions:" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 2 ;
                                    oc:sectionTitle "Update SKILL.md" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Step 4: Edit the Skill" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Example: When building a `pdf-editor` skill to handle queries like \"Help me rotate this PDF,\" the analysis shows:" ],
                                _:ref_5f1b9360a5140cc7,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "To turn concrete examples into an effective skill, analyze each example by:" ],
                                _:ref_73497529e00dfe63,
                                _:ref_8174fb8f1d077afb,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 7 ;
                                    oc:textContent "Example: When building a `big-query` skill to handle queries like \"How many users have logged in today?\" the analysis shows:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 9 ;
                                    oc:textContent "To establish the skill's contents, analyze each concrete example to create a list of the reusable resources to include: scripts, references, and assets." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "Example: When designing a `frontend-webapp-builder` skill for queries like \"Build me a todo app\" or \"Build me a dashboard to track my steps,\" the analysis shows:" ],
                                _:ref_eff086c9972c3647 ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Step 2: Planning the Reusable Skill Contents" ],
                        [ a oc:Section ;
                            oc:hasContent _:ref_1e12661d105dfc26,
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """scripts/package_skill.py <path/to/skill-folder>
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 179-181" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "The packaging script will:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """scripts/package_skill.py <path/to/skill-folder> ./dist
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 4 ;
                                    oc:sourceLocation "lines 185-187" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Optional output directory specification:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Once the skill is ready, it should be packaged into a distributable zip file that gets shared with the user. The packaging process automatically validates the skill first to ensure it meets all requirements:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 7 ;
                                    oc:textContent "If validation fails, the script will report the errors and exit without creating a package. Fix any validation errors and run the packaging command again." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Step 5: Packaging a Skill" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "Conclude this step when there is a clear sense of the functionality the skill should support." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "To create an effective skill, clearly understand concrete examples of how the skill will be used. This understanding can come from either direct user examples or generated examples that are validated with user feedback." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Skip this step only when the skill's usage patterns are already clearly understood. It remains valuable even when working with an existing skill." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "To avoid overwhelming users, avoid asking too many questions in a single message. Start with the most important questions and follow up as needed for better effectiveness." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "For example, when building an image-editor skill, relevant questions include:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "\"What would a user say that should trigger this skill?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "\"Can you give some examples of how this skill would be used?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "\"I can imagine users asking for things like 'Remove the red-eye from this image' or 'Rotate this image'. Are there other ways you imagine this skill being used?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "\"What functionality should the image-editor skill support? Editing, rotating, anything else?\"" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Step 1: Understanding the Skill with Concrete Examples" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "When creating a new skill from scratch, always run the `init_skill.py` script. The script conveniently generates a new template skill directory that automatically includes everything a skill requires, making the skill creation process much more efficient and reliable." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 7 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Generates a SKILL.md template with proper frontmatter and TODO placeholders" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Creates the skill directory at the specified path" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Adds example files in each directory that can be customized or deleted" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Creates example resource directories: `scripts/`, `references/`, and `assets/`" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 8 ;
                                    oc:textContent "After initialization, customize or remove the generated SKILL.md and example files as needed." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "Usage:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "The script:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "Skip this step only if the skill being developed already exists, and iteration or packaging is needed. In this case, continue to the next step." ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """scripts/init_skill.py <skill-name> --path <output-directory>
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 5 ;
                                    oc:sourceLocation "lines 142-144" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "At this point, it is time to actually create the skill." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Step 3: Initializing the Skill" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "After testing the skill, users may request improvements. Often this happens right after using the skill, with fresh context of how the skill performed." ],
                                _:ref_9f07b808647d1f22,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Iteration workflow:**" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "Step 6: Iterate" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Skill Creation Process" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """Skills are modular, self-contained packages that extend Claude's capabilities by providing
specialized knowledge, workflows, and tools. Think of them as "onboarding guides" for specific
domains or tasks—they transform Claude from a general-purpose agent into a specialized agent
equipped with procedural knowledge that no model can fully possess.""" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Skills use a three-level loading system to manage context efficiently:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "*Unlimited because scripts can be executed without reading into context window." ],
                                _:ref_fbdfb03ef39c1718 ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Progressive Disclosure Design Principle" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Every skill consists of a required SKILL.md file and optional bundled resources:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """skill-name/
├── SKILL.md (required)
│   ├── YAML frontmatter metadata (required)
│   │   ├── name: (required)
│   │   └── description: (required)
│   └── Markdown instructions (required)
└── Bundled Resources (optional)
    ├── scripts/          - Executable code (Python/Bash/etc.)
    ├── references/       - Documentation intended to be loaded into context as needed
    └── assets/           - Files used in output (templates, icons, fonts, etc.)
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 29-40" ] ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**Metadata Quality:** The `name` and `description` in YAML frontmatter determine when Claude will use the skill. Be specific about what the skill does and when to use it. Use the third-person (e.g. \"This skill should be used when...\" instead of \"Use this skill when...\")." ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 1 ;
                                    oc:sectionTitle "SKILL.md (required)" ],
                                [ a oc:Section ;
                                    oc:hasSubsection [ a oc:Section ;
                                            oc:hasContent [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 2 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "**When to include**: For documentation that Claude should reference while working" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "**Use cases**: Database schemas, API documentation, domain knowledge, company policies, detailed workflow guides" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 6 ;
                                                            oc:itemText "**Avoid duplication**: Information should live in either SKILL.md or references files, not both. Prefer references files for detailed information unless it's truly core to the skill—this keeps SKILL.md lean while making information discoverable without hogging the context window. Keep only essential procedural instructions and workflow guidance in SKILL.md; move detailed reference material, schemas, and examples to references files." ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 5 ;
                                                            oc:itemText "**Best practice**: If files are large (>10k words), include grep search patterns in SKILL.md" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "**Examples**: `references/finance.md` for financial schemas, `references/mnda.md` for company NDA template, `references/policies.md` for company policies, `references/api_docs.md` for API specifications" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 4 ;
                                                            oc:itemText "**Benefits**: Keeps SKILL.md lean, loaded only when Claude determines it's needed" ] ],
                                                [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 1 ;
                                                    oc:textContent "Documentation and reference material intended to be loaded as needed into context to inform Claude's process and thinking." ] ;
                                            oc:sectionLevel 5 ;
                                            oc:sectionOrder 2 ;
                                            oc:sectionTitle "References (`references/`)" ],
                                        [ a oc:Section ;
                                            oc:hasContent [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 1 ;
                                                    oc:textContent "Executable code (Python/Bash/etc.) for tasks that require deterministic reliability or are repeatedly rewritten." ],
                                                [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 2 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "**Example**: `scripts/rotate_pdf.py` for PDF rotation tasks" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "**When to include**: When the same code is being rewritten repeatedly or deterministic reliability is needed" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 4 ;
                                                            oc:itemText "**Note**: Scripts may still need to be read by Claude for patching or environment-specific adjustments" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "**Benefits**: Token efficient, deterministic, may be executed without loading into context" ] ] ;
                                            oc:sectionLevel 5 ;
                                            oc:sectionOrder 1 ;
                                            oc:sectionTitle "Scripts (`scripts/`)" ],
                                        [ a oc:Section ;
                                            oc:hasContent [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 1 ;
                                                    oc:textContent "Files not intended to be loaded into context, but rather used within the output Claude produces." ],
                                                [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 2 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "**When to include**: When the skill needs files that will be used in the final output" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "**Examples**: `assets/logo.png` for brand assets, `assets/slides.pptx` for PowerPoint templates, `assets/frontend-template/` for HTML/React boilerplate, `assets/font.ttf` for typography" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "**Use cases**: Templates, images, icons, boilerplate code, fonts, sample documents that get copied or modified" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 4 ;
                                                            oc:itemText "**Benefits**: Separates output resources from documentation, enables Claude to use files without loading them into context" ] ] ;
                                            oc:sectionLevel 5 ;
                                            oc:sectionOrder 3 ;
                                            oc:sectionTitle "Assets (`assets/`)" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 2 ;
                                    oc:sectionTitle "Bundled Resources (optional)" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Anatomy of a Skill" ],
                        [ a oc:Section ;
                            oc:hasContent _:ref_9cb6ab395ad24008 ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "What Skills Provide" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "About Skills" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Skill Creator" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: skill-creator
description: Guide for creating effective skills. This skill should be used when users want to create a new skill (or update an existing skill) that extends Claude's capabilities with specialized knowledge, workflows, or tool integrations.
license: Complete terms in LICENSE.txt
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow _:ref_1e12661d105dfc26,
        _:ref_3de4999e90ae1d65,
        _:ref_5f1b9360a5140cc7,
        _:ref_73497529e00dfe63,
        _:ref_8174fb8f1d077afb,
        _:ref_9cb6ab395ad24008,
        _:ref_9f07b808647d1f22,
        _:ref_eff086c9972c3647,
        _:ref_fbdfb03ef39c1718 ;
    oc:impartsKnowledge oc:kn_343bbf00,
        oc:kn_3942042e,
        oc:kn_58defe8a,
        oc:kn_629e075d,
        oc:kn_ad38004a,
        oc:kn_bd447c9c,
        oc:kn_be650e0b,
        oc:kn_e7682a9c ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create a new skill",
        "design skill structure with scripts/references/assets",
        "package a skill for distribution",
        "update an existing skill" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_343bbf00 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any skill" ;
    oc:directiveContent "Use progressive disclosure: metadata (~100 words) always in context, SKILL.md body (<5k words) when triggered, bundled resources loaded as needed." ;
    oc:hasRationale "Manages context window efficiently, keeping essential info always available while loading details on demand." ;
    oc:severityLevel "HIGH" .

oc:kn_3942042e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to create a script" ;
    oc:directiveContent "Include scripts when the same code is being rewritten repeatedly or deterministic reliability is needed. Scripts are token-efficient and may be executed without loading into context." ;
    oc:hasRationale "Scripts provide deterministic behavior and token savings compared to inline code generation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_58defe8a a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding what to include in a skill" ;
    oc:directiveContent "Skills are being created for another instance of Claude to use. Focus on including information that is beneficial and non-obvious to Claude — procedural knowledge, domain-specific details, and reusable assets." ;
    oc:hasRationale "General knowledge Claude already has should not be duplicated; skills should add specialized, non-obvious value." ;
    oc:severityLevel "HIGH" .

oc:kn_629e075d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any new skill from scratch" ;
    oc:directiveContent "1. Understand the skill with concrete examples — gather/validate usage patterns. 2. Plan reusable contents — identify scripts, references, assets needed. 3. Initialize skill — run scripts/init_skill.py. 4. Edit the skill — implement resources then update SKILL.md. 5. Package — run scripts/package_skill.py. 6. Iterate — test on real tasks and refine." ;
    oc:stepOrder 1 .

oc:kn_ad38004a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing skill content" ;
    oc:directiveContent "Do not duplicate information between SKILL.md and reference files. Prefer references for detailed material; keep only essential procedural instructions in SKILL.md." ;
    oc:hasRationale "Duplication wastes context tokens and creates maintenance burden. Lean SKILL.md ensures efficient loading." ;
    oc:severityLevel "HIGH" .

oc:kn_bd447c9c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When including large reference files" ;
    oc:directiveContent "For reference files larger than ~10k words, include grep search patterns in SKILL.md so Claude can find relevant sections without loading the entire file." ;
    oc:hasRationale "Large files consume context; grep patterns enable targeted loading of relevant sections." ;
    oc:severityLevel "MEDIUM" .

oc:kn_be650e0b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing SKILL.md content" ;
    oc:directiveContent "Write SKILL.md using imperative/infinitive form (verb-first instructions), not second person. Use objective, instructional language." ;
    oc:hasRationale "Maintains consistency and clarity for AI consumption across all skills." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e7682a9c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing YAML frontmatter" ;
    oc:directiveContent "The name and description in YAML frontmatter determine when Claude will use the skill. Use third-person voice (e.g., 'This skill should be used when...'). Be specific about what the skill does and when to use it." ;
