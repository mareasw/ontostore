oc:kn_2fc3f5be a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When finalizing SKILL.md" ;
    oc:directiveContent "Reference all supporting files (references/, examples/, scripts/) explicitly in SKILL.md so Claude knows they exist and can discover them." ;
    oc:hasRationale "Claude cannot load resources it doesn't know about. Explicit references enable progressive disclosure." ;
    oc:severityLevel "HIGH" .

oc:kn_62467fca a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing or editing SKILL.md" ;
    oc:directiveContent "Keep SKILL.md lean at 1,500-2,000 words. Move detailed patterns, advanced techniques, migration guides, and API references to references/ files." ;
    oc:hasRationale "Bloating SKILL.md wastes context tokens every time the skill triggers, degrading performance on unrelated tasks." ;
    oc:severityLevel "HIGH" .

oc:kn_63403d90 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any skill structure" ;
    oc:directiveContent "Use three-level progressive disclosure: (1) metadata always in context (~100 words), (2) SKILL.md body loaded when skill triggers (<5k words), (3) bundled resources loaded as needed by Claude." ;
    oc:hasRationale "Minimizes context window consumption while making detailed information discoverable on demand." ;
    oc:severityLevel "HIGH" .

oc:kn_6c62c4c8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any skill body content" ;
    oc:directiveContent "Write all skill body content in imperative/infinitive form (verb-first), never second person. Use 'To accomplish X, do Y' not 'You should do X'." ;
    oc:hasRationale "Imperative form provides consistent, unambiguous instructions optimized for AI consumption." ;
    oc:severityLevel "HIGH" .

oc:kn_95822a9f a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "During skill iteration after real-world usage" ;
    oc:directiveContent "When skill fails to trigger correctly, strengthen trigger phrases in description, move long sections to references/, add missing examples, and clarify ambiguous instructions." ;
    oc:hasRationale "Most skill quality issues stem from weak triggering, context bloat, or missing procedural clarity." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c5d5d8f7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before considering a skill complete" ;
    oc:directiveContent "Before finalizing a skill, validate: SKILL.md has frontmatter with name+description, description uses third person with trigger phrases, body uses imperative form, word count is 1,500-2,000, all referenced files exist." ;
    oc:hasRationale "The validation checklist catches the most common skill quality issues before distribution." ;
    oc:severityLevel "HIGH" .

oc:kn_e31d8ee5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing skill frontmatter YAML" ;
    oc:directiveContent "Frontmatter description must use third-person format ('This skill should be used when...') and include specific trigger phrases users would say." ;
    oc:hasRationale "The description determines when Claude auto-triggers the skill. Vague descriptions cause missed triggers or false positives." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f77b369a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing skill content" ;
    oc:directiveContent "Never duplicate information between SKILL.md and references/ files. Information should live in exactly one place, preferring references/ for detailed content." ;
    oc:hasRationale "Duplication causes maintenance burden and risks inconsistency when one copy is updated without the other." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f8d638cc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning skill contents from concrete examples" ;
    oc:directiveContent "Include scripts/ when the same code is repeatedly rewritten; include references/ when Claude needs domain documentation; include assets/ when output needs template files." ;
    oc:hasRationale "Matching resource type to use case maximizes token efficiency and deterministic reliability." ;
    oc:severityLevel "MEDIUM" .

