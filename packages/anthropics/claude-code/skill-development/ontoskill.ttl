@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_skill_development a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "skill-development" ;
    skos:broader "Meta-skill framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/skill-development" ;
    oc:contentHash "4a8eacffacbe831a5f8c10cfb1c82a15d255997be29b14ea729e094e066ba474" ;
    oc:differentia "that guides the creation, structure, and progressive disclosure design of Claude Code plugin skills" ;
    oc:extends oc:skill_skill_creator ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "skill-name or description of skill to create" ;
    oc:hasCategory "development" ;
    oc:hasDescription "This skill should be used when the user wants to \"create a skill\", \"add a skill to plugin\", \"write a new skill\", \"improve skill description\", \"organize skill content\", or needs guidance on skill structure, progressive disclosure, or skill development best practices for Claude Code plugins." ;
    oc:hasName "skill-development" ;
    oc:impartsKnowledge oc:kn_221eacf1,
        oc:kn_2784f972,
        oc:kn_2f3e0e81,
        oc:kn_6971fda4,
        oc:kn_d1c3182a,
        oc:kn_e339249d,
        oc:kn_e3c0e1ff ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "add a skill to a plugin",
        "create a new skill for a Claude Code plugin",
        "improve skill description and trigger phrases",
        "organize skill content with progressive disclosure",
        "validate and test a plugin skill",
        "write or improve a skill's SKILL.md" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_221eacf1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing skill content" ;
    oc:directiveContent "Never put everything in SKILL.md. Avoid duplicating information between SKILL.md and references/. Never leave resources unreferenced in SKILL.md." ;
    oc:hasRationale "Bloating SKILL.md wastes context tokens on every skill trigger. Unreferenced resources are invisible to Claude and effectively don't exist." ;
    oc:severityLevel "HIGH" .

oc:kn_2784f972 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before marking any skill as complete or ready for distribution" ;
    oc:directiveContent "Before finalizing a skill, validate: SKILL.md has frontmatter with name and description, description uses third-person with specific trigger phrases, body uses imperative form, SKILL.md is under ~2,000 words, all referenced files exist, and examples are complete." ;
    oc:hasRationale "Skipping validation leads to skills that fail to trigger, waste context, or provide broken references to Claude." ;
    oc:severityLevel "HIGH" .

oc:kn_2f3e0e81 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any skill body content" ;
    oc:directiveContent "Write the entire SKILL.md body in imperative/infinitive form (verb-first instructions), never second person. Use objective, instructional language ('To accomplish X, do Y' not 'You should do X')." ;
    oc:hasRationale "Imperative form maintains consistency and clarity for AI consumption across all skills in the ecosystem." ;
    oc:severityLevel "HIGH" .

oc:kn_6971fda4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring or editing any SKILL.md" ;
    oc:directiveContent "Use progressive disclosure: keep SKILL.md lean (1,500-2,000 words ideal, <5k max) and move detailed content to references/, working code to examples/, and utility scripts to scripts/." ;
    oc:hasRationale "Skills use a three-level loading system (metadata always loaded, SKILL.md on trigger, references on demand) to manage context window efficiently." ;
    oc:severityLevel "HIGH" .

oc:kn_d1c3182a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When creating any new skill from scratch" ;
    oc:directiveContent "Follow the 6-step skill creation process in order: (1) understand use cases with concrete examples, (2) plan reusable resources (scripts/references/assets), (3) create directory structure, (4) edit skill starting with resources then SKILL.md, (5) validate and test, (6) iterate based on usage." ;
    oc:hasRationale "This ordered process ensures skills are grounded in real usage patterns and properly structured before being validated." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e339249d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or improving any plugin skill" ;
    oc:directiveContent "Study existing well-crafted skills (hook-development, agent-development, plugin-settings) as templates for trigger descriptions, word count targets, and progressive disclosure patterns." ;
    oc:hasRationale "These reference skills demonstrate proven best practices for each aspect of skill design and have been refined through real usage." ;
    oc:severityLevel "LOW" .

oc:kn_e3c0e1ff a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or editing YAML frontmatter description" ;
    oc:directiveContent "Frontmatter description must use third-person format ('This skill should be used when...') and include specific trigger phrases that users would actually say." ;
    oc:hasRationale "The description determines when Claude auto-triggers the skill; vague or second-person descriptions lead to missed triggers or incorrect loading." ;
    oc:severityLevel "CRITICAL" .

