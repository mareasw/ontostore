oc:skill_anthropics_claude_code_plugin_structure_readme a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "readme" ;
    skos:broader "Architectural reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/plugin-structure" ;
    oc:contentHash "c7cb4931d6d71198cba6b552e4733b41940be56a65552a2ff7c5656750b95184" ;
    oc:differentia "that defines Claude Code plugin directory structure, manifest configuration, component organization, and auto-discovery mechanisms using progressive disclosure" ;
    oc:extends oc:skill_anthropics_claude_code_plugin_structure ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "Glob",
        "Read",
        "Write" ;
    oc:hasArgumentHint "plugin-name or structure question" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_766d5e3f,
        oc:kn_909afe9f,
        oc:kn_98a3682f,
        oc:kn_ba27e980,
        oc:kn_cee700b5 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DirectoryWritable,
        oc:EnvironmentReady ;
    oc:resolvesIntent "configure auto-discovery",
        "create a plugin",
        "learn plugin architecture best practices",
        "organize plugin components",
        "scaffold a plugin",
        "set up plugin.json",
        "understand plugin structure" ;
    oc:yieldsState oc:PluginStructured .

oc:kn_766d5e3f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring any new plugin or adding components to an existing one" ;
    oc:directiveContent "Organize plugin components (commands, agents, skills, hooks, scripts) into dedicated subdirectories following auto-discovery conventions so Claude Code can find them without explicit configuration." ;
    oc:hasRationale "Auto-discovery mechanisms rely on conventional directory names and file placements; non-standard organization requires manual configuration and increases maintenance burden." ;
    oc:severityLevel "HIGH" .

oc:kn_909afe9f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring or updating plugin documentation and skill content" ;
    oc:directiveContent "Keep SKILL.md lean (~1600 words) focused on core concepts; move detailed references (~6000 words) and examples (~8000 words) into separate files loaded only when needed." ;
    oc:hasRationale "Progressive disclosure reduces initial context window consumption while keeping deep documentation available on demand, optimizing token usage during skill activation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_98a3682f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When users request plugin creation without specifying complexity level" ;
    oc:directiveContent "Use the three-tier example progression (minimal → standard → advanced) as templates when scaffolding new plugins, matching the pattern to the plugin's intended scope." ;
    oc:hasRationale "Starting with the minimal pattern avoids premature complexity; the standard and advanced patterns provide proven structures for scaling when needed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ba27e980 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating or validating a plugin.json manifest file" ;
    oc:directiveContent "The plugin.json manifest must include required fields (name, version, description) and should follow the minimal-to-complete spectrum based on plugin complexity." ;
    oc:hasRationale "Missing required fields prevent plugin activation; overly complex manifests for simple plugins create unnecessary maintenance overhead." ;
    oc:severityLevel "HIGH" .

oc:kn_cee700b5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any file path in plugin.json, skill files, command definitions, or hook configurations" ;
    oc:directiveContent "Use ${CLAUDE_PLUGIN_ROOT} for all internal path references within a plugin to ensure portability across different installation environments." ;
    oc:hasRationale "Hardcoded absolute paths break when the plugin is installed in a different location; the variable resolves dynamically to the plugin's actual root directory." ;
    oc:severityLevel "CRITICAL" .

