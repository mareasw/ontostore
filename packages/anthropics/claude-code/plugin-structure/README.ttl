oc:kn_0b47ecf1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying custom command, agent, hook, or MCP server paths in plugin.json" ;
    oc:directiveContent "Paths in manifest component fields must be relative (start with ./), cannot use ../  for parent navigation, cannot use absolute paths, and must use forward slashes even on Windows." ;
    oc:hasRationale "Claude Code validates these path rules on load and will reject the plugin if violated." ;
    oc:severityLevel "HIGH" .

oc:kn_1344744f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When configuring commands, agents, or other component paths in the manifest" ;
    oc:directiveContent "Custom paths in plugin.json supplement default directories — they do NOT replace them. Components in both default directories and custom paths will all be loaded." ;
    oc:hasRationale "Understanding merge behavior prevents accidentally loading duplicate components or expecting defaults to be overridden." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4a6e2d3b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing hook commands, MCP server args, script references, or resource paths" ;
    oc:directiveContent "Always use ${CLAUDE_PLUGIN_ROOT} for intra-plugin path references. Never use hardcoded absolute paths, relative paths from working directory, or home directory shortcuts." ;
    oc:hasRationale "Plugins install in different locations depending on OS, installation method, and user preferences. Portable paths ensure the plugin works everywhere." ;
    oc:severityLevel "HIGH" .

oc:kn_526b3025 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing plugin directory structure" ;
    oc:directiveContent "All component directories (commands, agents, skills, hooks) MUST be at plugin root level, NOT nested inside .claude-plugin/." ;
    oc:hasRationale "The .claude-plugin/ directory is reserved exclusively for the manifest; components elsewhere will not be auto-discovered." ;
    oc:severityLevel "CRITICAL" .

oc:kn_67ad3d5c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or validating any plugin" ;
    oc:directiveContent "The plugin.json manifest MUST be located at .claude-plugin/plugin.json — no other location is recognized." ;
    oc:hasRationale "Claude Code uses this exact path to discover and load plugin configuration." ;
    oc:severityLevel "CRITICAL" .

oc:kn_874d0819 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding on plugin organization pattern" ;
    oc:directiveContent "For plugins: start simple with flat structure, reorganize into categorized/hierarchical layouts only when you have 15+ commands or clear functional categories." ;
    oc:hasRationale "Premature categorization adds complexity without benefit; restructure when the pain of a flat layout becomes clear." ;
    oc:severityLevel "LOW" .

oc:kn_8fdb4872 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming any plugin component file or directory" ;
    oc:directiveContent "Use kebab-case for all directory and file names (commands: code-review.md, agents: test-generator.md, skills: error-handling/)." ;
    oc:hasRationale "Consistent naming conventions prevent discovery failures and improve maintainability." ;
    oc:severityLevel "MEDIUM" .

oc:kn_98e72c4f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When referencing any file path within a plugin" ;
    oc:directiveContent "Never use hardcoded absolute paths (e.g., /Users/name/...), working-directory-relative paths (e.g., ./scripts/... in commands), or home directory shortcuts (~/plugins/...) in any plugin file." ;
    oc:hasRationale "These break portability across different installation locations and operating systems." ;
    oc:severityLevel "HIGH" .

oc:kn_efe46a6c a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When troubleshooting plugin component discovery failures" ;
    oc:directiveContent "If a component is not loading: verify file is in correct directory with correct extension, check YAML frontmatter syntax, ensure skills use SKILL.md (not README.md), confirm plugin is enabled, and restart Claude Code to reload configuration." ;
    oc:hasRationale "Most loading failures stem from misplaced files, wrong file names, or syntax errors in frontmatter." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f3385433 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before publishing or distributing any plugin" ;
    oc:directiveContent "Before considering a plugin complete, verify: manifest is valid JSON with correct name format, all referenced paths exist, YAML frontmatter is syntactically correct in commands/agents/skills, and ${CLAUDE_PLUGIN_ROOT} is used consistently." ;
    oc:hasRationale "Common validation failures include invalid name format (spaces, underscores), missing ./ prefix in paths, and incorrect YAML syntax." ;
    oc:severityLevel "HIGH" .

