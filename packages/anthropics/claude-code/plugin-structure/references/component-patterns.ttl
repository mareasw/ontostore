oc:kn_2a6aaa5f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing any plugin component type" ;
    oc:directiveContent "Group components by one consistent axis: flat (by name), categorized (by function), hierarchical (by function+sub-function), role-based (by agent role), capability-based (by technology), or workflow-based (by lifecycle stage)." ;
    oc:hasRationale "Mixed organizational axes create confusion and make components hard to discover" ;
    oc:severityLevel "HIGH" .

oc:kn_5c5da40d a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When designing plugin layout for performance" ;
    oc:directiveContent "Avoid deep directory nesting and minimize custom manifest paths. Large configurations and deep nesting increase component discovery time during Claude Code initialization." ;
    oc:hasRationale "Component registration happens at Claude Code startup; slow discovery delays availability" ;
    oc:severityLevel "LOW" .

oc:kn_a063f6e8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using event-based hook organization" ;
    oc:directiveContent "Claude Code does NOT support file references like ${file:./x.json} in hooks.json. Use a build script to combine separate hook files into a single hooks.json." ;
    oc:hasRationale "The hooks configuration must be a single resolved JSON object" ;
    oc:severityLevel "HIGH" .

oc:kn_b0be9d5d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using hierarchical command organization" ;
    oc:directiveContent "Claude Code does NOT support nested command discovery automatically. For hierarchical command structures, explicitly list each subdirectory path in the manifest commands array." ;
    oc:hasRationale "Only explicitly declared paths are scanned for command definitions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d345d2dc a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Component activation phase when components are invoked" ;
    oc:directiveContent "Commands: slash → lookup → execute. Agents: task → evaluate capabilities → select. Skills: context match → load. Hooks: event → call matching. MCP Servers: tool call → forward." ;
    oc:stepOrder 2 .

oc:kn_d7f00b74 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Component lifecycle discovery phase during Claude Code startup" ;
    oc:directiveContent "1. Scan enabled plugins (read plugin.json) → 2. Discover components (default + custom paths) → 3. Parse definitions (YAML frontmatter) → 4. Register components → 5. Initialize (start MCP servers, register hooks)" ;
    oc:stepOrder 1 .

oc:kn_e1bf394a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing plugin directory structure" ;
    oc:directiveContent "Start with flat structure for 5-15 components, reorganize to categorized at 15+, and hierarchical at 20+ commands. Refactor early before complexity becomes unmanageable." ;
    oc:hasRationale "Over-engineering early structure wastes effort; under-organizing at scale creates maintenance burden" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fe02072c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When multiple components share logic" ;
    oc:directiveContent "Use a shared lib/ directory for cross-component utilities. Reference scripts via ${CLAUDE_PLUGIN_ROOT}/lib/ to ensure portable paths." ;
    oc:hasRationale "Centralized shared code reduces duplication and ensures consistent behavior across components" .

