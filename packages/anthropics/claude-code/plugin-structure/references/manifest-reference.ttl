@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_plugin_structure_manifest_reference a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "manifest-reference" ;
    skos:broader "Reference specification" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/plugin-structure" ;
    oc:contentHash "d0ff8ffece4754df92c543266b8d0b689fb85473f51fbb57e215f2d235ee9782" ;
    oc:differentia "that documents all fields, validation rules, path resolution, and best practices for the plugin.json manifest file used by Claude Code plugins" ;
    oc:extends oc:skill_anthropics_claude_code_plugin_structure ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "optional field name to look up (e.g. \"name\", \"version\", \"hooks\")" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_0db6580a,
        oc:req_77436396,
        oc:req_ed04db6b ;
    oc:impartsKnowledge oc:kn_575dc091,
        oc:kn_5a1146cd,
        oc:kn_641bfbf6,
        oc:kn_9246b272,
        oc:kn_9a336d5f,
        oc:kn_d2c6b2d5,
        oc:kn_e52e12a9 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:FileExists ;
    oc:resolvesIntent "configure plugin metadata and component paths",
        "debug manifest validation errors",
        "understand plugin manifest fields",
        "validate plugin.json configuration" ;
    oc:yieldsState oc:ManifestValidated .

oc:kn_575dc091 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing plugin file structure and deciding whether to customize paths" ;
    oc:directiveContent "Use default directory locations (./commands/, ./agents/, ./skills/, ./hooks/hooks.json, ./.mcp.json) whenever possible. Custom paths in the manifest supplement defaults rather than replace them — all discovered components from all locations are loaded and merged." ;
    oc:hasRationale "Default discovery reduces configuration burden and follows convention-over-configuration. The merge behavior means components accumulate from all sources, but name conflicts cause errors." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5a1146cd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between inline vs. external configuration for hooks and mcpServers" ;
    oc:directiveContent "Avoid using inline hook or MCP server configurations when they exceed ~50 lines (hooks) or ~20 lines (mcpServers). Move large configurations to external JSON files instead." ;
    oc:hasRationale "Inline configuration bloats the manifest and makes maintenance harder. External files enable modular configuration and are easier to validate independently." ;
    oc:severityLevel "MEDIUM" .

oc:kn_641bfbf6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or validating any Claude Code plugin" ;
    oc:directiveContent "The manifest file MUST be located at .claude-plugin/plugin.json in the plugin root directory. Claude Code will not recognize plugins without this file in the correct location." ;
    oc:hasRationale "Claude Code uses a fixed discovery path to locate plugin manifests; any other location will cause the plugin to be silently ignored." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9246b272 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When using both default directories and custom paths in the manifest" ;
    oc:directiveContent "Components from manifest-specified paths and default directories are merged — all discovered components register. Name conflicts between any sources cause load errors." ;
    oc:hasRationale "Understanding the merge behavior prevents unexpected naming collisions that would prevent the entire plugin from loading." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9a336d5f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before publishing or sharing a Claude Code plugin" ;
    oc:directiveContent "Before distributing a plugin, validate: (1) name field is present and valid kebab-case, (2) version follows MAJOR.MINOR.PATCH semver, (3) all paths are relative with ./ prefix, (4) all referenced paths exist, (5) no name conflicts across components." ;
    oc:hasRationale "Claude Code validates the manifest on load and will reject plugins with syntax errors, invalid fields, missing paths, or circular dependencies." ;
    oc:severityLevel "HIGH" .

oc:kn_d2c6b2d5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any path field in plugin.json" ;
    oc:directiveContent "All component paths in manifest fields (commands, agents, hooks, mcpServers) must be relative, start with './', use forward slashes only, and never use '../' for parent directory navigation." ;
    oc:hasRationale "Relative path constraints ensure plugin portability and prevent security issues from absolute or traversal paths. Missing './' prefix is a common validation error." ;
    oc:severityLevel "HIGH" .

oc:kn_e52e12a9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting the 'name' field in plugin.json" ;
    oc:directiveContent "The plugin name field must match the regex /^[a-z][a-z0-9]*(-[a-z0-9]+)*$/ — kebab-case only, starting with a letter, ending with a letter or number, no spaces or special characters." ;
    oc:hasRationale "Name format enforcement prevents ambiguity in command namespacing, conflict detection, and filesystem compatibility across platforms." ;
    oc:severityLevel "HIGH" .

oc:req_0db6580a a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Semantic versioning conventions" .

oc:req_77436396 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Claude Code plugin directory layout" .

oc:req_ed04db6b a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "JSON syntax and structure" .

