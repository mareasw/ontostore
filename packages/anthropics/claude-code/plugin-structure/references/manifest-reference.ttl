oc:kn_2316b7d4 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using custom paths alongside default directories" ;
    oc:directiveContent "Name conflicts between components discovered from default directories and custom paths cause load errors — all component names must be unique across all scanned locations." ;
    oc:hasRationale "The merge behavior registers all discovered components with no overwriting, so duplicate names are fatal." ;
    oc:severityLevel "HIGH" .

oc:kn_425dbf7e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any path in plugin.json" ;
    oc:directiveContent "Do not use absolute paths, backslashes, missing `./` prefixes, or `../` traversal in any component path field." ;
    oc:hasRationale "These will fail validation and prevent the plugin from loading." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4bc15ca6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying commands, agents, hooks, or mcpServers paths" ;
    oc:directiveContent "All component paths must be relative, start with `./`, use forward slashes only, and cannot use `../` for parent directory navigation." ;
    oc:hasRationale "Ensures portable, sandboxed path resolution regardless of host OS or installation directory." ;
    oc:severityLevel "HIGH" .

oc:kn_745d19a7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting the plugin name field" ;
    oc:directiveContent "The `name` field is required and must match the regex `/^[a-z][a-z0-9]*(-[a-z0-9]+)*$/` — lowercase kebab-case, starting with a letter, ending with a letter or number." ;
    oc:hasRationale "Ensures unique, conflict-free identification and valid command namespacing across installed plugins." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9a2a093e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or validating a plugin manifest" ;
    oc:directiveContent "The manifest MUST be located at `.claude-plugin/plugin.json` — Claude Code will not recognize plugins without this file in the correct location." ;
    oc:hasRationale "Claude Code uses this fixed path to discover and load plugins; any other location will be ignored." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b01ff07c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When setting or bumping the version field" ;
    oc:directiveContent "Use semantic versioning (MAJOR.MINOR.PATCH) for the version field. MAJOR for breaking changes, MINOR for backward-compatible additions, PATCH for bug fixes." ;
    oc:hasRationale "Allows consumers and tooling to understand compatibility and change significance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b2d9c4d2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting a new plugin" ;
    oc:directiveContent "The minimal valid manifest is `{\"name\": \"my-plugin\"}` — rely on default directory discovery (commands/, agents/, skills/, hooks/hooks.json, .mcp.json) rather than explicit configuration." ;
    oc:hasRationale "Convention over configuration reduces boilerplate and onboarding friction." .

oc:kn_b9461a19 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring hooks or mcpServers fields" ;
    oc:directiveContent "Use inline hook/MCP configuration for simple plugins (<50 lines for hooks, <20 lines for MCP), and external JSON files for complex multi-server or multi-hook setups." ;
    oc:hasRationale "Keeps the manifest readable for small plugins while allowing separation of concerns for large ones." ;
    oc:severityLevel "LOW" .

oc:kn_d200ffe4 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before distributing or installing a plugin" ;
    oc:directiveContent "Before publishing, verify: valid JSON syntax, name field present and kebab-case, version is semver if present, all paths are relative with `./` prefix, referenced paths actually exist." ;
    oc:hasRationale "Claude Code validates the manifest on load and will reject plugins with any of these errors." ;
    oc:severityLevel "HIGH" .

