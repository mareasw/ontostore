                                    oc:contentOrder 7 ;
                                    oc:textContent "**Usage**: Hooks execute automatically in response to Claude Code events" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """{
  "PreToolUse": [{
    "matcher": "Write|Edit",
    "hooks": [{
