    oc:appliesToContext "When building production-grade or distribution-ready plugins" ;
    oc:directiveContent "A standard plugin should include all four component types — commands, agents, skills, and hooks — organized in separate root-level directories with auto-discovery." ;
    oc:hasRationale "Full component coverage enables cohesive workflows where commands trigger actions, agents provide specialized expertise, skills supply contextual knowledge, and hooks enforce standards automatically." ;
    oc:severityLevel "MEDIUM" .

oc:kn_41b87dd3 a oc:Heuristic,
