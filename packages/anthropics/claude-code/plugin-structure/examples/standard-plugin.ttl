    oc:hasRationale "Complete metadata enables discovery, attribution, versioning, and proper package management in plugin marketplaces." ;
    oc:severityLevel "HIGH" .

oc:kn_86e479ad a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When scaffolding a new standard plugin from scratch" ;
    oc:directiveContent "1. Create .claude-plugin/plugin.json with complete metadata 2. Create commands/ with .md files (YAML frontmatter: name, description) 3. Create agents/ with .md files (frontmatter: description, capabilities) 4. Create skills/ subdirs each with SKILL.md (frontmatter: name, description, version) 5. Create hooks/hooks.json with PreToolUse/Stop handlers 6. Create scripts/ for shared utilities referenced via ${CLAUDE_PLUGIN_ROOT}" ;
    oc:stepOrder 1 .

oc:kn_91d9f0a2 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When configuring hooks for automated quality enforcement" ;
    oc:directiveContent "Use PreToolUse hooks with prompt type to enforce coding standards before code modifications, and Stop hooks with command type to validate changes before task completion." ;
    oc:hasRationale "PreToolUse catches issues proactively during editing; Stop hooks provide a final quality gate before the session considers work complete." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9c2f1dea a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Hook scripts that run linters (eslint, pylint) require those tools to be installed in the project." .

oc:kn_a4dc22b1 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring hooks for code quality enforcement" ;
    oc:codeLanguage "json" ;
    oc:directiveContent """{
  "PreToolUse": [{
    "matcher": "Write|Edit",
    "hooks": [{
      "type": "prompt",
      "prompt": "Verify coding standards...",
      "timeout": 30
    }]
  }],
  "Stop": [{
    "matcher": ".*",
    "hooks": [{
      "type": "command",
      "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate.sh",
      "timeout": 45
    }]
  }]
}""" .

oc:kn_b4433cdb a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing hook scripts that provide feedback to Claude Code" ;
    oc:directiveContent "Hook scripts must output JSON with a systemMessage key (e.g., echo '{\"systemMessage\": \"Code quality checks passed.\"}') and exit with code 0 for success, non-zero for failure." ;
    oc:hasRationale "Claude Code parses hook output as JSON to display system messages and uses exit codes to determine whether to block the action." ;
    oc:severityLevel "HIGH" .

oc:kn_b8fb82a3 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing hook scripts for Stop or PreToolUse events" ;
    oc:directiveContent "Hook validation scripts should be idempotent — running multiple times should produce the same result without side effects." ;
    oc:hasRationale "Hooks may fire multiple times during a session; non-idempotent scripts could cause cumulative side effects or false failures." .

oc:kn_c8497791 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing a validate-commit hook script for code quality" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """#!/bin/bash
set -e
CHANGED_FILES=$(git diff --name-only --cached | grep -E '\\.(js|ts|py)$' || true)
for file in $CHANGED_FILES; do
  case "$file" in
    *.js|*.ts) npx eslint "$file" --quiet ;;
    *.py) python -m pylint "$file" --errors-only ;;
  esac
done
echo '{"systemMessage": "Code quality checks passed."}'""" .

