    oc:contentHash "b8cfba84bd4dbdc83365cebcde5dcc6391252372300df0c1ea7890441582d784" ;
    oc:differentia "demonstrates a well-structured Claude Code plugin with commands, agents, skills, hooks, and scripts working cohesively" ;
