oc:kn_2efaa8fa a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing any plugin directory structure" ;
    oc:directiveContent "All component directories (commands, agents, skills, hooks) MUST be at plugin root level, NOT nested inside .claude-plugin/. Only plugin.json goes in .claude-plugin/." ;
    oc:hasRationale "Claude Code's auto-discovery scans root-level directories. Placing components inside .claude-plugin/ breaks auto-discovery." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3ca7b418 a oc:DesignPrinciple,
