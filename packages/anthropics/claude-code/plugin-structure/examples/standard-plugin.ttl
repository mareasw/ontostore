    oc:appliesToContext "When organizing plugin directory structure" ;
    oc:directiveContent "Do not place component directories (commands/, agents/, skills/, hooks/) inside the .claude-plugin/ directory. They must be at the plugin root level for auto-discovery to work." ;
    oc:hasRationale "Claude Code only scans root-level directories for auto-discovery. Nested components inside .claude-plugin/ will not be found." ;
