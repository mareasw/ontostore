    dcterms:identifier "minimal-plugin" ;
    skos:broader "plugin template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/plugin-structure" ;
    oc:contentHash "c4f14fe56b153be3c532b7947bb10b453fc92e280dca5a7da752d2b1b5d17448" ;
    oc:differentia "that provides a minimal scaffold with a single command and no external dependencies for Claude Code plugin development" ;
