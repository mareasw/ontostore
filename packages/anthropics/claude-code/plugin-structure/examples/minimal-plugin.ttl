oc:kn_0516562b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding plugin complexity" ;
    oc:directiveContent "Use the minimal plugin pattern for quick prototypes, single-purpose utilities, learning plugin development, or internal team tools with one specific function." ;
    oc:hasRationale "Over-engineering a plugin with unnecessary structure slows development for simple use cases." ;
    oc:severityLevel "LOW" .

oc:kn_606d2916 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing plugin.json" ;
    oc:directiveContent "The plugin.json manifest must contain at minimum the 'name' field. No other fields are required for a functional plugin." ;
    oc:hasRationale "The name field is the only required property; omitting it will cause plugin discovery to fail." ;
    oc:severityLevel "CRITICAL" .

oc:kn_95948740 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When growing beyond a minimal plugin" ;
    oc:directiveContent "To extend a minimal plugin: 1) Add more .md files in commands/ for additional commands 2) Update plugin.json with version, description, author 3) Create agents/ directory for agent definitions 4) Create hooks/hooks.json for event handling" ;
    oc:hasRationale "Provides a clear upgrade path from minimal to full-featured plugin." ;
    oc:stepOrder 1 .

oc:kn_a0d96b09 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing command files" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent "Command markdown files use YAML frontmatter with 'name' and 'description' fields, followed by implementation instructions in the body." ;
    oc:hasRationale "The frontmatter provides metadata for auto-discovery; the body provides the command's logic." .

oc:kn_bf7bbe33 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating the simplest possible plugin" ;
    oc:directiveContent "A minimal plugin requires only a .claude-plugin/plugin.json with a name field and a commands/ directory with at least one .md file." ;
    oc:hasRationale "Establishes the absolute minimum viable structure — everything else (version, description, hooks, agents) is optional extension." ;
    oc:severityLevel "LOW" .

