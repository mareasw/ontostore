oc:skill_anthropics_claude_code_plugin_structure_advanced_plugin a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "advanced-plugin" ;
    skos:broader "reference pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/plugin-structure" ;
    oc:contentHash "3d24f5856048a94cb99fe2b8207d99f2f5d69325771b361d63ec73024290759c" ;
    oc:differentia "demonstrates enterprise-grade Claude Code plugin architecture with MCP integration, multi-level organization, shared libraries, security hooks, and environment-specific configuration" ;
    oc:extends oc:skill_anthropics_claude_code_plugin_structure ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_6cc3405f,
        oc:kn_80d1b903,
        oc:kn_880048d2,
        oc:kn_bde0d571,
        oc:kn_f1db4c1b ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "design enterprise plugin architecture",
        "implement security automation hooks in plugin",
        "integrate MCP servers into plugin",
        "organize plugin with shared libraries and environment configs",
        "structure complex multi-component plugin" ;
    oc:yieldsState oc:PluginArchitectureDesigned .

oc:kn_6cc3405f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring plugins with 15+ commands or 5+ agents" ;
    oc:directiveContent "Organize commands by functional category (ci, monitoring, admin) and agents by role (orchestration, specialized) in hierarchical subdirectories. Specify these as custom paths in plugin.json commands and agents arrays since Claude Code does not auto-discover nested subdirectories." ;
    oc:hasRationale "Hierarchical organization prevents flat-directory chaos at scale and enables team ownership boundaries by functional area" ;
    oc:severityLevel "HIGH" .

oc:kn_80d1b903 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When integrating external tools via MCP in plugins with multiple servers" ;
    oc:directiveContent "Define MCP servers in a dedicated .mcp.json file at plugin root using ${CLAUDE_PLUGIN_ROOT} for server entry points and ${ENV_VAR} for configuration. Pass environment variables with sensible defaults (e.g., ${K8S_NAMESPACE:-default})." ;
    oc:hasRationale "Centralized MCP configuration with portable paths ensures servers start correctly regardless of plugin installation location, while environment variable defaults prevent startup failures in common configurations" ;
    oc:severityLevel "HIGH" .

oc:kn_880048d2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When multiple plugin components share common logic" ;
    oc:directiveContent "Extract reusable code into a shared lib/ directory with layers: core/ (logging, config, auth), integrations/ (external services like Slack, Datadog, PagerDuty), and utils/ (retry, validation). Reference from commands, agents, and skills via ${CLAUDE_PLUGIN_ROOT}/lib/ paths." ;
    oc:hasRationale "Shared libraries eliminate code duplication, ensure consistent behavior across components, and centralize maintenance of integration patterns" ;
    oc:severityLevel "MEDIUM" .

oc:kn_bde0d571 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When designing security automation for production-grade plugins" ;
    oc:directiveContent "Implement layered security hooks: PreToolUse secret scanning on Write|Edit operations, Bash command safety evaluation via prompt hooks, SessionStart permission validation, and Stop-phase config auditing. Each hook should have appropriate timeouts (15-45 seconds)." ;
    oc:hasRationale "Layered security catches different threat classes at different lifecycle points — secret leaks during writes, destructive commands at execution time, permission issues at session start, and configuration drift at completion" ;
    oc:severityLevel "CRITICAL" .

oc:kn_f1db4c1b a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When plugin behavior must vary across deployment environments" ;
    oc:directiveContent "Separate environment-specific configuration into config/environments/ with per-environment JSON files (production.json, staging.json, development.json) and reusable templates in config/templates/. Components load the appropriate config based on active environment." ;
    oc:hasRationale "Environment-specific configuration prevents accidental production actions during development and enables safe promotion through environments without code changes" ;
    oc:severityLevel "MEDIUM" .

