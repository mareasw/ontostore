oc:kn_10d44292 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing command scope and complexity" ;
    oc:directiveContent "Commands should have single responsibility. For complex multi-step workflows, create separate commands for each step and a meta-command that orchestrates them, or use state files (.local.md) for cross-invocation state." ;
    oc:hasRationale "Single-responsibility commands are easier to test, maintain, and compose. State files enable complex workflows without monolithic commands." ;
    oc:severityLevel "MEDIUM" .

oc:kn_28773239 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any command file" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
description: Brief description under 60 chars
argument-hint: [arg1] [arg2]
allowed-tools: Read, Bash(git:*)
---

Command prompt with $1 $2 $ARGUMENTS
File ref: @path/to/file
Bash exec: !`git status`
Plugin ref: ${CLAUDE_PLUGIN_ROOT}/scripts/run.sh""" .

oc:kn_34cdc2f9 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before creating any command" ;
    oc:directiveContent "Commands require .md file extension and valid Markdown format. Commands with bash execution need Bash in allowed-tools. Plugin commands require files within plugin-name/commands/ directory." .

oc:kn_37749372 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding where to place a command file" ;
    oc:directiveContent "Commands support three locations: project (.claude/commands/), personal (~/.claude/commands/), and plugin (plugin-name/commands/). Each has different scope and labeling in /help." ;
    oc:hasRationale "Location determines availability scope and how the command is labeled in the /help listing." ;
    oc:severityLevel "HIGH" .

oc:kn_4951eaa3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring command frontmatter" ;
    oc:directiveContent "YAML frontmatter fields are: description (string), allowed-tools (string or array), model (sonnet|opus|haiku), argument-hint (string), disable-model-invocation (boolean). All are optional." ;
    oc:hasRationale "These are the only supported frontmatter fields. Invalid fields or values will cause command failures." ;
    oc:severityLevel "HIGH" .

oc:kn_56ebb6a2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing plugin commands that reference plugin-internal files" ;
    oc:directiveContent "Never use relative paths like ./scripts/analyze.js in plugin commands. Always use ${CLAUDE_PLUGIN_ROOT}/scripts/analyze.js for portable, cross-installation file references." ;
    oc:hasRationale "Relative paths resolve against the current working directory, not the plugin root. ${CLAUDE_PLUGIN_ROOT} resolves to the absolute path of the plugin directory regardless of where Claude is invoked." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5aae0e78 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any slash command prompt body" ;
    oc:directiveContent "Commands are written for agent consumption, not human consumption. Write commands as directives TO Claude about what to do, not as messages TO the user about what will happen." ;
    oc:hasRationale "Command content becomes Claude's instructions at invocation time. User-facing descriptions belong in the frontmatter 'description' field, not the command body." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7139f256 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating commands with dynamic arguments" ;
    oc:directiveContent "Always include argument-hint when a command accepts arguments. Use $ARGUMENTS for all args as string, $1/$2/$3 for positional args. Document expected format in comments." ;
    oc:hasRationale "argument-hint enables autocomplete and discoverability. Missing argument documentation leads to user confusion and incorrect invocations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a4cf4cbb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming and describing commands" ;
    oc:directiveContent "Follow the verb-noun naming pattern (e.g., review-pr, fix-issue, deploy-app) and keep descriptions under 60 characters for clean /help display." ;
    oc:hasRationale "Consistent naming improves discoverability in /help output and makes command purpose immediately clear to users." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b1d94601 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When developing any new slash command" ;
    oc:directiveContent "1. Design: Define purpose, required arguments, needed tools. 2. Create file: Choose location (project/personal/plugin), create .md file. 3. Add frontmatter: Start minimal (description), add fields as needed. 4. Test: Invoke with /command-name, verify arguments, check bash execution, test file references. 5. Refine: Improve prompt clarity, handle edge cases, add comments." ;
    oc:stepOrder 1 .

oc:kn_bd72f7c6 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating plugin commands that reference plugin resources" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
description: Analyze using plugin script
allowed-tools: Bash(node:*), Read
---

Run: !`node ${CLAUDE_PLUGIN_ROOT}/scripts/analyze.js $1`
Config: @${CLAUDE_PLUGIN_ROOT}/config/$1.json
Template: @${CLAUDE_PLUGIN_ROOT}/templates/report.md

Review results and report findings.""" .

oc:kn_c41c4263 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When documenting complex commands for maintainability" ;
    oc:directiveContent """<!--
COMMAND: command-name
VERSION: x.y.z

PURPOSE: What this command does
USAGE: /command-name [args]
ARGUMENTS: arg1 - description
EXAMPLES: /command-name example-value
REQUIREMENTS: List of prerequisites
CHANGELOG: Version history
-->""" ;
    oc:templateVariables "ARGUMENTS",
        "CHANGELOG",
        "EXAMPLES",
        "PURPOSE",
        "REQUIREMENTS",
        "USAGE",
        "VERSION",
        "command-name" .

oc:kn_cf7bb752 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting allowed-tools in frontmatter" ;
    oc:directiveContent "Use allowed-tools with the most restrictive scope that works: prefer Bash(git:*) over Bash(*), and Read,Grep over *." ;
    oc:hasRationale "Principle of least privilege. Restrictive tool access prevents accidental destructive operations and documents command intent." ;
    oc:severityLevel "HIGH" .

oc:kn_da73dde0 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When building commands that accept user input" ;
    oc:directiveContent "Validate inputs early in the command body using bash checks (!`echo \"$1\" | grep -E \"^pattern$\" || echo \"INVALID\"`) and provide helpful error messages with corrective actions when validation fails." ;
    oc:hasRationale "Early validation with actionable error messages prevents confusing downstream failures and improves user experience." ;
    oc:severityLevel "MEDIUM" .

