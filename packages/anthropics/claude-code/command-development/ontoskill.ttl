oc:skill_anthropics_claude_code_command_development a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "command-development" ;
    skos:broader "Development skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/command-development" ;
    oc:contentHash "fe05e3ac7cd872273d399157bf684b46750cd5c1b565e550bb10d5f516166e72" ;
    oc:dependsOnSkill oc:skill_plugin_structure ;
    oc:differentia "that guides creation of Claude Code slash commands using Markdown files with YAML frontmatter, dynamic arguments, file references, bash execution, and plugin integration patterns" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "[command-name] [command-purpose] [options]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "This skill should be used when the user asks to \"create a slash command\", \"add a command\", \"write a custom command\", \"define command arguments\", \"use command frontmatter\", \"organize commands\", \"create command with file references\", \"interactive command\", \"use AskUserQuestion in command\", or needs guidance on slash command structure, YAML frontmatter fields, dynamic arguments, bash execution in commands, user interaction patterns, or command development best practices for Claude Code." ;
    oc:hasName "command-development" ;
    oc:impartsKnowledge oc:kn_40754607,
        oc:kn_430d6ae5,
        oc:kn_74851d44,
        oc:kn_ab1e7888,
        oc:kn_acdcac5e,
        oc:kn_d7e5e89d,
        oc:kn_d9aae1ee,
        oc:kn_ed029e07 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build plugin commands with CLAUDE_PLUGIN_ROOT",
        "create interactive commands with AskUserQuestion",
        "create slash commands",
        "define command arguments and frontmatter",
        "integrate commands with agents, skills, and hooks",
        "organize commands with namespacing",
        "test and document commands for distribution",
        "validate command inputs and handle errors" ;
    oc:yieldsState oc:CommandCreated,
        oc:CommandValidated .

oc:kn_40754607 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing and naming any slash command" ;
    oc:directiveContent "Follow single responsibility: each command should have one clear purpose, use the verb-noun naming pattern (e.g., review-pr, fix-issue), and always provide an argument-hint when accepting arguments." ;
    oc:hasRationale "Single-purpose commands are composable, testable, and discoverable. Consistent naming and documented arguments improve usability in /help output and team adoption." ;
    oc:severityLevel "HIGH" .

oc:kn_430d6ae5 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before deploying or distributing any slash command" ;
    oc:directiveContent "Before testing a command: verify the .md file is in the correct directory (.claude/commands/ or plugin commands/), validate YAML frontmatter has exactly 2 '---' markers, confirm allowed-tools covers any bash execution or file references, and test in Claude Code with /help to confirm discovery." ;
    oc:hasRationale "Common command failures stem from wrong file locations, malformed YAML, missing tool permissions, or files not being discovered. Pre-flight checks catch these before users encounter them." ;
    oc:severityLevel "MEDIUM" .

oc:kn_74851d44 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or iterating on command YAML frontmatter" ;
    oc:directiveContent "Start minimal with frontmatter (just description), then add allowed-tools, model, and argument-hint incrementally as needed. Use the most restrictive allowed-tools that works (e.g., Bash(git:*) not Bash(*))." ;
    oc:hasRationale "Minimal frontmatter reduces complexity and maintenance burden. Restrictive tool scopes prevent accidental side effects and improve security posture." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ab1e7888 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing commands that accept user arguments or reference files" ;
    oc:directiveContent "Always validate command inputs early: check required arguments, verify file existence, validate argument formats with grep/test, and provide helpful error messages with corrective suggestions." ;
    oc:hasRationale "Early validation prevents cascading errors, provides actionable feedback, and creates a professional user experience especially important for distributed/marketplace commands." ;
    oc:severityLevel "HIGH" .

oc:kn_acdcac5e a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building multi-command workflows or deployment pipelines" ;
    oc:directiveContent "For multi-step workflows, use .local.md state files with YAML frontmatter to persist state between command invocations, enabling checkpoint recovery and sequential command chaining." ;
    oc:hasRationale "Persistent state files allow commands to communicate across invocations, support resume-after-failure, and provide a clean separation of workflow stages." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d7e5e89d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between interactive questioning and positional arguments in commands" ;
    oc:directiveContent "Use AskUserQuestion for complex multi-choice decisions requiring context (2-4 options with trade-off descriptions), and use simple $arguments for known values like file paths or numbers." ;
    oc:hasRationale "AskUserQuestion excels at complex decisions where users need to see options with explanations. Simple arguments are faster and more scriptable for straightforward inputs." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d9aae1ee a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating commands bundled in Claude Code plugins" ;
    oc:directiveContent "Plugin commands MUST use ${CLAUDE_PLUGIN_ROOT} for all internal file references instead of relative or hardcoded paths, and must be placed in the plugin's commands/ directory for auto-discovery." ;
    oc:hasRationale "CLAUDE_PLUGIN_ROOT resolves to the plugin's absolute path at runtime, ensuring portable operation across different installations. Hardcoded paths break portability." ;
    oc:severityLevel "HIGH" .

oc:kn_ed029e07 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any slash command prompt body" ;
    oc:directiveContent "Never write command content as messages to the user; commands are instructions FOR Claude (agent consumption), not human-facing descriptions of what will happen." ;
    oc:hasRationale "Commands become Claude's instructions when invoked. Writing user-facing prose instead of agent directives produces vague, ineffective commands that don't tell Claude what to do." ;
    oc:severityLevel "CRITICAL" .

