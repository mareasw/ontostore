oc:kn_091c582f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building deployment or validation commands that run across multiple environments" ;
    oc:directiveContent "Use environment-aware conditional logic in commands — full checks for production, basic checks for development — with appropriate pass/fail thresholds per environment." ;
    oc:hasRationale "Different environments have different risk tolerances; production needs comprehensive validation while dev should stay fast" .

oc:kn_1422f4c3 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When a command depends on specific plugin resources being present" ;
    oc:directiveContent "Before executing plugin scripts, verify resource existence: !`test -f ${CLAUDE_PLUGIN_ROOT}/path/file && echo \"YES\" || echo \"NO\"`" ;
    oc:hasRationale "Missing resources cause cryptic script errors; pre-flight checks provide clear diagnostics" .

oc:kn_28c03583 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When commands accept user arguments like environment names or file paths" ;
    oc:directiveContent "Always validate user inputs before using them in script execution. Use grep -E pattern matching to verify arguments match expected values." ;
    oc:hasRationale "Unvalidated inputs can cause script failures, path traversal, or deployment to wrong environments" .

oc:kn_42888c49 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When referencing any plugin resource in a command" ;
    oc:directiveContent "Never use relative paths like ./scripts/analyze.js in plugin commands. Always use ${CLAUDE_PLUGIN_ROOT} for portable paths that work across installations." ;
    oc:hasRationale "Relative paths break when the plugin is installed in different locations or invoked from different working directories" ;
    oc:severityLevel "CRITICAL" .

oc:kn_589d2010 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any plugin command that needs script execution, config loading, or template referencing" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """!`node ${CLAUDE_PLUGIN_ROOT}/scripts/script-name.js $1` for Node.js scripts
!`bash ${CLAUDE_PLUGIN_ROOT}/scripts/script-name.sh $1` for shell scripts
@${CLAUDE_PLUGIN_ROOT}/config/config-name.json for config loading
@${CLAUDE_PLUGIN_ROOT}/templates/template-name.md for template usage""" .

oc:kn_750ac471 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When referencing any plugin file in a command" ;
    oc:directiveContent "Never hardcode absolute plugin paths like /home/user/.claude/plugins/my-plugin/config.json. Always use ${CLAUDE_PLUGIN_ROOT} variable." ;
    oc:hasRationale "Hardcoded paths break on different machines and user installations" ;
    oc:severityLevel "HIGH" .

oc:kn_8404802a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing multi-component plugin commands" ;
    oc:directiveContent "Structure complex commands as phased workflows: automated analysis first, then agent/skill delegation, then template-based reporting, then prioritized recommendations." ;
    oc:hasRationale "Phased workflows separate concerns, produce clearer output, and allow each phase to fail independently" .

oc:kn_93d48bca a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing command frontmatter" ;
    oc:directiveContent "Commands that execute scripts must declare allowed-tools in frontmatter. Bash(*) for shell scripts, Bash(node:*) for Node.js scripts, Read for file references." ;
    oc:hasRationale "Without proper tool permissions, script execution will fail at runtime" ;
    oc:severityLevel "CRITICAL" .

oc:kn_de56ba8c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any new plugin command" ;
    oc:directiveContent "1. Define frontmatter (description, argument-hint, allowed-tools, model) → 2. Reference target files with @$1 → 3. Execute plugin scripts with !`...` → 4. Load templates with @${CLAUDE_PLUGIN_ROOT}/templates/ → 5. Instruct Claude to analyze output and report findings" ;
    oc:stepOrder 1 .

