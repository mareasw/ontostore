@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_command_development_plugin_commands a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "plugin-commands" ;
    skos:broader "Example catalog" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/command-development" ;
    oc:contentHash "7d71d7b516020a6c171171399b40dd2cad02b842c9faa78b90e0983906c9ee94" ;
    oc:differentia "that demonstrates plugin-specific Claude Code slash command patterns including script execution, template loading, configuration-driven workflows, agent/skill integration, input validation, and environment-aware logic" ;
    oc:extends oc:skill_anthropics_claude_code_command_development ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "[command-type] [use-case]" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_138ee894,
        oc:kn_2b00af3c,
        oc:kn_a70acb68,
        oc:kn_adecfbe5,
        oc:kn_f58d6ac4 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build multi-script plugin workflows",
        "create environment-aware commands",
        "create plugin commands",
        "create validated input commands",
        "design commands with CLAUDE_PLUGIN_ROOT",
        "integrate plugin agents and skills into commands",
        "write plugin-specific slash commands" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_138ee894 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding !` bash execution blocks to any command" ;
    oc:directiveContent "Never use Bash execution in commands without declaring allowed-tools in frontmatter — the command will fail at runtime without proper permissions." ;
    oc:hasRationale "Claude Code enforces tool restrictions; missing allowed-tools declarations cause silent or confusing failures" ;
    oc:severityLevel "HIGH" .

oc:kn_2b00af3c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any plugin command that references plugin files" ;
    oc:directiveContent "Never use relative paths like ./scripts/analyze.js in plugin commands — always use ${CLAUDE_PLUGIN_ROOT} for portable, cross-installation compatibility." ;
    oc:hasRationale "Relative paths break when the working directory changes or the plugin is installed in a different location" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a70acb68 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When commands accept arguments like environment names, file paths, or version numbers" ;
    oc:directiveContent "Always validate user inputs early in the command using grep/test patterns before executing destructive or resource-intensive operations." ;
    oc:hasRationale "Early validation prevents wasted execution time and provides clear, actionable error messages instead of cryptic failures" ;
    oc:severityLevel "HIGH" .

oc:kn_adecfbe5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building multi-component plugin commands that combine scripts, agents, skills, and templates" ;
    oc:directiveContent "For complex workflows, decompose into numbered phases: script execution → agent delegation → skill invocation → template-based reporting → prioritized recommendations." ;
    oc:hasRationale "Phased decomposition makes commands maintainable, debuggable, and allows partial execution if an early phase fails" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f58d6ac4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any command prompt body" ;
    oc:directiveContent "Write commands as instructions FOR Claude (imperative directives), not as descriptions TO the user about what will happen." ;
    oc:hasRationale "Commands are agent-consumed prompts — instructive directives produce correct agent behavior while descriptive text does not guide action" ;
    oc:severityLevel "CRITICAL" .

