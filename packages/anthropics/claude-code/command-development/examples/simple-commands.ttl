oc:skill_anthropics_claude_code_command_development_simple_commands a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "simple-commands" ;
    skos:broader "Example collection" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/command-development" ;
    oc:contentHash "f2533ed834305166603bcb4dd870d695af4a33b9a49d330937a4c70ed964767c" ;
    oc:differentia "Provides 10 ready-to-use slash command templates covering code review, security review, testing, documentation generation, git status, deployment, file comparison, quick fixes, research, and code explanation, along with 7 key structural patterns for building basic Claude Code commands" ;
    oc:extends oc:skill_anthropics_claude_code_command_development ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Grep",
        "Read",
        "Write" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_0eeb3eb0,
        oc:kn_7b281a42,
        oc:kn_9b821eb7,
        oc:kn_b65d18d3,
        oc:kn_eba04079 ;
    oc:isUserInvocable true ;
    oc:nature "Reference" ;
    oc:requiresState oc:DirectoryWritable ;
    oc:resolvesIntent "create simple slash command",
        "find command template examples",
        "learn basic command patterns",
        "write code review command",
        "write deployment command",
        "write documentation generator command",
        "write explain code command",
        "write file comparison command",
        "write git status command",
        "write quick fix command",
        "write research command",
        "write security review command",
        "write test command" ;
    oc:yieldsState oc:CommandFilesCreated .

oc:kn_0eeb3eb0 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating or naming any new slash command" ;
    oc:directiveContent "Use the verb-noun naming pattern for command files (e.g., review.md, test-file.md, deploy.md) and always include argument-hint in frontmatter when a command accepts arguments." ;
    oc:hasRationale "Descriptive names make commands discoverable in /help. argument-hint documents the interface for users and improves autocomplete." ;
    oc:severityLevel "HIGH" .

oc:kn_7b281a42 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scaffolding a new slash command" ;
    oc:directiveContent "Start with minimal frontmatter (just description) and add allowed-tools, model, and argument-hint incrementally as needed. Never use allowed-tools: * unless absolutely necessary." ;
    oc:hasRationale "Minimal frontmatter reduces complexity and potential misconfiguration. Overly broad tool permissions violate the principle of least privilege." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9b821eb7 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing the structure and frontmatter of a new command" ;
    oc:directiveContent "Follow the 7 key patterns to match command purpose: read-only analysis (Read, Grep), git operations (Bash(git:*)), single argument ($1), multiple arguments ($1 $2), fast execution (model: haiku), file comparison (@$1 with @$2), and context gathering (bash + file refs combined)." ;
    oc:hasRationale "These patterns cover the vast majority of command use cases and provide proven structural templates that avoid common pitfalls." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b65d18d3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing the model field in command frontmatter" ;
    oc:directiveContent "Match model selection to task complexity: use 'haiku' for simple repetitive tasks (quick-fix), 'sonnet' for standard workflows (review, research), and 'opus' for complex analysis requiring deep reasoning." ;
    oc:hasRationale "Right-sizing the model optimizes cost and latency. Haiku is faster and cheaper for simple tasks; opus provides deeper analysis for complex ones." ;
    oc:severityLevel "MEDIUM" .

oc:kn_eba04079 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any slash command prompt content" ;
    oc:directiveContent "Commands must be written as instructions FOR Claude (agent consumption), not messages TO users. Write directives telling Claude what to do, not describing what will happen." ;
    oc:hasRationale "Command content becomes Claude's instructions on invocation. Writing for human consumption yields a passive description rather than actionable directives, causing Claude to narrate instead of act." ;
    oc:severityLevel "CRITICAL" .

