        "integrate commands with plugin components (agents, skills, hooks)",
        "organize commands in plugins and projects",
        "validate and test custom commands" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_562a00d1 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating or updating command files" ;
    oc:directiveContent "Always include a description in frontmatter and use argument-hint to document expected arguments for discoverability via /help." ;
    oc:hasRationale "Clear descriptions and argument hints make commands self-documenting and discoverable." ;
    oc:severityLevel "HIGH" .

oc:kn_64f70eaf a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When developing a new slash command from scratch" ;
    oc:directiveContent "1. Define purpose, scope, required arguments, and needed tools. 2. Choose location (.claude/commands/, ~/.claude/commands/, or plugin/commands/) and create .md file. 3. Add minimal frontmatter (description), then add fields as needed. 4. Test via /command-name invocation. 5. Refine prompt, handle edge cases, add comments." ;
    oc:stepOrder 1 .

oc:kn_b35d9646 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring command frontmatter" ;
    oc:directiveContent "Use the most restrictive allowed-tools setting possible — never grant more tool access than the command needs." ;
    oc:hasRationale "Minimal tool access reduces the blast radius of unexpected command behavior." ;
    oc:severityLevel "CRITICAL" .

oc:kn_cddc2939 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any new slash command" ;
    oc:directiveContent "Each command should have a single, clear purpose — avoid combining unrelated concerns in one command file." ;
    oc:hasRationale "Single-responsibility commands are easier to discover, test, and maintain." ;
    oc:severityLevel "HIGH" .

oc:kn_df020f4d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any slash command file" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
description: Brief description
argument-hint: [arg1] [arg2]
allowed-tools: Read, Bash(git:*)
---

Command prompt with $1, $2, $ARGUMENTS, @file-ref, !`bash cmd`""" ;
    oc:hasRationale "This is the canonical command file format combining all available features." .

