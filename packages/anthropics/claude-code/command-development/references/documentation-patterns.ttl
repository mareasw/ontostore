@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_command_development_documentation_patterns a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "documentation-patterns" ;
    skos:broader "documentation pattern library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/command-development" ;
    oc:contentHash "70c6c9b0a9b2d46a925ada6c45808a73498a457e1d641c82cc05de8a29a33b05" ;
    oc:differentia "provides templates, best practices, and structural patterns for creating self-documenting, maintainable slash commands with embedded help text, error messages, examples, and changelogs" ;
    oc:extends oc:skill_anthropics_claude_code_command_development ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "null" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_2bb17882,
        oc:kn_97383ce1,
        oc:kn_9af9c651,
        oc:kn_b15b3f0d,
        oc:kn_d9d7dbd9,
        oc:kn_f5a52723 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:CommandCreated ;
    oc:resolvesIntent "create well-documented commands",
        "design command help text",
        "maintain command changelogs",
        "structure command documentation",
        "write command error messages" ;
    oc:yieldsState oc:CommandDocumented .

oc:kn_2bb17882 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before releasing or distributing any command" ;
    oc:directiveContent "Never release a command without completing the documentation checklist: clear description in frontmatter, argument-hint, usage examples, helpful error messages, requirements, changelog, and verified examples." ;
    oc:hasRationale "Undocumented commands create technical debt immediately; early users who can't figure out a command will abandon it and form negative impressions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_97383ce1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring any slash command" ;
    oc:directiveContent "Embed documentation directly inside the command file using HTML comment sections (PURPOSE, USAGE, ARGUMENTS, EXAMPLES, REQUIREMENTS, RELATED COMMANDS, TROUBLESHOOTING, CHANGELOG) so it is co-located with the implementation and always accessible." ;
    oc:hasRationale "Co-located documentation stays synchronized with code better than separate files, and is immediately available to users and maintainers without context switching." ;
    oc:severityLevel "HIGH" .

oc:kn_9af9c651 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing command documentation and help text" ;
    oc:directiveContent "Show examples before explanations: lead with concrete usage examples and expected outputs, then follow with conceptual descriptions." ;
    oc:hasRationale "Users learn faster from concrete examples than abstract descriptions; example-first documentation reduces cognitive load and time to first success." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b15b3f0d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing error handling in commands" ;
    oc:directiveContent "Error messages must include: what happened, why it matters, common causes, and actionable recovery steps with specific commands the user can run." ;
    oc:hasRationale "Helpful error messages transform failures into learning moments and reduce support burden; uninformative errors force users to guess at solutions." ;
    oc:severityLevel "HIGH" .

oc:kn_d9d7dbd9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing command frontmatter" ;
    oc:directiveContent "The frontmatter description must be under 60 characters and the argument-hint must document all accepted arguments including optional ones with their defaults." ;
    oc:hasRationale "Short descriptions ensure they display cleanly in command listings; complete argument hints prevent invocation errors and reduce trial-and-error usage." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f5a52723 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When organizing documentation across a command's lifecycle" ;
    oc:directiveContent "Use progressive disclosure for command documentation: frontmatter description (always visible), inline comments for implementation context, README for installation/configuration, separate docs for tutorials and API reference." ;
    oc:hasRationale "Progressive disclosure ensures users see the most relevant information first without being overwhelmed, while deeper details remain discoverable when needed." ;
    oc:severityLevel "MEDIUM" .

