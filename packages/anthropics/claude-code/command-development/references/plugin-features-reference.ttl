                            oc:hasContent [ a oc:Template ;
                                    oc:blockType "template" ;
                                    oc:contentOrder 2 ;
                                    oc:templateContent """---
description: Build and validate output
allowed-tools: Bash(*)
---

Build: !`bash ${CLAUDE_PLUGIN_ROOT}/scripts/build.sh`

Validate output:
- Exit code: !`echo $?`
- Output exists: !`test -d dist && echo "✓" || echo "✗"`
- File count: !`find dist -type f | wc -l`

Report build status and any validation failures.
""" ;
                                    oc:templateVariables "CLAUDE_PLUGIN_ROOT" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
