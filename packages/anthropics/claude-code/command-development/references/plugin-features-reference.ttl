oc:skill_anthropics_claude_code_command_development_plugin_features_reference a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "plugin-features-reference" ;
    skos:broader "documentation reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/command-development" ;
    oc:contentHash "57e11ae6a4bbc1a4a295d1f036202970911d6029d64f4ab058b63a4c5a899072" ;
    oc:dependsOnSkill oc:skill_command_development ;
    oc:differentia "covers plugin-specific command features including CLAUDE_PLUGIN_ROOT, auto-discovery, namespacing, multi-component integration, and validation patterns" ;
    oc:extends oc:skill_anthropics_claude_code_command_development ;
    oc:hasArgumentHint "none (reference document)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_0cd647c9,
        oc:kn_3f4015e1,
        oc:kn_567f121f,
        oc:kn_d37e82a9,
        oc:kn_fd1816ec ;
    oc:isUserInvocable false ;
    oc:nature "reference" ;
    oc:resolvesIntent "discover and namespace plugin commands",
        "integrate commands with plugin agents skills and hooks",
        "reference plugin-specific command features",
        "use CLAUDE_PLUGIN_ROOT for portable paths",
        "validate inputs and handle errors in plugin commands" .

oc:kn_0cd647c9 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any plugin command that references files within the plugin directory" ;
    oc:directiveContent "Always use ${CLAUDE_PLUGIN_ROOT} for all plugin-internal paths — scripts, templates, configuration, and resources — never use relative paths like ./" ;
    oc:hasRationale "Relative paths resolve against the current working directory, not the plugin directory, causing file-not-found errors across different installations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_3f4015e1 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building comprehensive plugin commands that need multiple capabilities" ;
    oc:directiveContent "Delegate complex multi-step workflows to plugin scripts for execution, agents for deep analysis, skills for domain knowledge, and use templates for standardized output" ;
    oc:hasRationale "Separation of concerns between scripts (execution), agents (reasoning), skills (knowledge), and templates (formatting) produces maintainable and extensible plugin architectures" ;
    oc:severityLevel "MEDIUM" .

oc:kn_567f121f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any plugin command begins its primary operation" ;
    oc:directiveContent "Validate all inputs early — check required arguments, verify file existence, validate argument formats — before executing the main command logic" ;
    oc:hasRationale "Early validation prevents confusing downstream errors and provides clear, actionable error messages to the user" ;
    oc:severityLevel "HIGH" .

oc:kn_d37e82a9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming plugin commands" ;
    oc:directiveContent "Avoid generic command names like /test, /run, or /do-stuff that conflict with common names or lack descriptive purpose" ;
    oc:hasRationale "Generic names create conflicts with other plugins and built-in commands, and fail to communicate the command's purpose to users" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fd1816ec a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing plugin command structure and naming" ;
    oc:directiveContent "Organize plugin commands in subdirectories for logical grouping when the plugin has 5 or more commands, using the subdirectory name as a namespace" ;
    oc:hasRationale "Namespacing prevents command name collisions and improves discoverability in /help output with clear grouping" ;
    oc:severityLevel "MEDIUM" .

