oc:kn_1278d2a1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing command composition patterns" ;
    oc:directiveContent "Each command should have single responsibility — do one thing well. Compose commands together for complex workflows rather than building monolithic commands." ;
    oc:hasRationale "Single-responsibility commands are easier to test, debug, and reuse across different workflow combinations" ;
    oc:severityLevel "HIGH" .

oc:kn_4665e0fb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building state-carrying workflows" ;
    oc:directiveContent "Never rely on implicit state between command invocations. Always explicitly read state files and validate state before proceeding." ;
    oc:hasRationale "Implicit state assumptions break when commands are run out of order, skipped, or resumed after interruption" ;
    oc:severityLevel "CRITICAL" .

oc:kn_51ae61a9 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining argument-hint commands with optional parameters" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent "Use ${1:-default} syntax for optional arguments with defaults in command templates. Validate inputs against allowed values before proceeding." .

oc:kn_64abc7ce a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building workflows that modify shared resources" ;
    oc:directiveContent "Implement workflow locking via lock files (e.g., .claude/deployment.lock) to prevent concurrent execution of the same workflow. Check for locks at startup and provide abort option." ;
    oc:hasRationale "Concurrent workflow execution can cause race conditions, data corruption, and inconsistent deployments" ;
    oc:severityLevel "HIGH" .

oc:kn_69948016 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a multi-step workflow fails or is interrupted" ;
    oc:directiveContent "Use checkpoint logging (e.g., writing step names to a checkpoint log file) to enable resuming interrupted workflows from the last successful step rather than restarting from scratch." ;
    oc:hasRationale "Checkpoint recovery saves time and avoids repeating expensive or risky operations that already succeeded" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6b6f41d3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing workflow state to .local.md files" ;
    oc:directiveContent "State files must be written atomically (complete content) and must include a timestamp field. Never partially write state files." ;
    oc:hasRationale "Partial or corrupt state files cause workflow recovery failures and make debugging impossible" ;
    oc:severityLevel "HIGH" .

oc:kn_8979d817 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a deployment or destructive operation fails mid-execution" ;
    oc:directiveContent "On deployment failure, automatically rollback to the previously saved version. Always capture the previous state before making changes to enable rollback." ;
    oc:hasRationale "Automatic rollback prevents leaving systems in a broken intermediate state" ;
    oc:severityLevel "HIGH" .

oc:kn_8ecdd069 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When managing state across command invocations" ;
    oc:directiveContent "Use .local.md files in the .claude/ directory for persistent workflow state. Include YAML frontmatter with structured state fields (workflow, stage, timestamp, environment, branch, commit)." ;
    oc:hasRationale ".local.md files are gitignored by convention and provide a human-readable, structured state format" ;
    oc:severityLevel "HIGH" .

oc:kn_9c9f383b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building any multi-step workflow command" ;
    oc:directiveContent "1. Check for lock/state files → 2. Validate environment and preconditions → 3. Execute steps with checkpoints → 4. Update state after each step → 5. Clean up state and lock files on completion" ;
    oc:stepOrder 1 .

oc:kn_f721ba3c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing interactive multi-step workflows" ;
    oc:directiveContent "Provide numbered decision points with clear options (e.g., 1. Approve / 2. Request changes / 3. Leave comments) at critical junctures to keep users in control of workflow progression." ;
    oc:hasRationale "User control points prevent unintended destructive actions and ensure human judgment is applied at critical decisions" ;
    oc:severityLevel "MEDIUM" .

