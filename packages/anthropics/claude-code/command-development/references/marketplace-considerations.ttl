oc:skill_anthropics_claude_code_command_development_marketplace_considerations a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "marketplace-considerations" ;
    skos:broader "distribution design guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/command-development" ;
    oc:contentHash "ab30835431d06a8e65cd629ba0e73b3f1de5b043126c6fef7ea70163400e90f4" ;
    oc:differentia "provides marketplace readiness criteria for commands including cross-platform compatibility, graceful degradation, user onboarding, namespace management, and quality standards for unknown end-users" ;
    oc:extends oc:skill_anthropics_claude_code_command_development ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_31f6a442,
        oc:kn_3a998ff1,
        oc:kn_3d290764,
        oc:kn_4db53e5c,
        oc:kn_5d63126c,
        oc:kn_a758d47f,
        oc:kn_ae8bbc03,
        oc:kn_cc7cbdfa ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "create user-friendly onboarding for commands",
        "design commands for cross-platform compatibility",
        "ensure quality standards for public commands",
        "handle errors gracefully in distributed commands",
        "prepare command for marketplace distribution" .

oc:kn_31f6a442 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When a command will be used by unknown users who have no prior context" ;
    oc:directiveContent "Provide a first-run onboarding experience that explains purpose, quick-start usage, and examples. Use progressive disclosure to surface tips after successful execution." ;
    oc:hasRationale "Unknown users need orientation before they can derive value; progressive disclosure avoids overwhelming them while teaching advanced features." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3a998ff1 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before publishing any command to a marketplace" ;
    oc:directiveContent "Before release, verify the command works on macOS, Linux, and Windows (WSL), all arguments are tested, error cases handled, no hardcoded paths, and dependencies are documented." ;
    oc:hasRationale "The pre-release checklist catches platform-specific breakage and UX gaps that the author's own environment cannot surface." ;
    oc:severityLevel "HIGH" .

oc:kn_3d290764 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When designing commands that modify state or perform one-time setup operations" ;
    oc:directiveContent "Implement idempotent operations using completion markers so that repeated execution is safe and informative, showing when an operation was already completed rather than re-executing." ;
    oc:hasRationale "Idempotency prevents duplicate side effects and gives users confidence to retry without fear of corruption." ;
    oc:severityLevel "HIGH" .

oc:kn_4db53e5c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a command supports optional integrations (e.g., GitHub CLI, Docker) that enhance but are not required for core functionality" ;
    oc:directiveContent "Implement graceful degradation: detect available features at runtime and offer reduced functionality with a helpful message rather than failing outright when optional tools are absent." ;
    oc:hasRationale "Users may not have every optional tool installed; feature detection with degraded mode keeps the command usable while guiding installation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5d63126c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a command performs multi-step modifications to files or environment state" ;
    oc:directiveContent "All operations must be atomic: either fully succeed or fully roll back with no partial state. Use temporary workspaces and validate before applying changes." ;
    oc:hasRationale "Partial failures leave the environment in an inconsistent state that is difficult to diagnose and recover from." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a758d47f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming and describing a command for marketplace distribution" ;
    oc:directiveContent "Never use vague descriptions like 'Do the thing' or overly generic names like '/deploy' that will collide with other plugins. Use descriptive, namespaced names with clear purpose statements." ;
    oc:hasRationale "Generic names cause collision with other plugins and poor discoverability; vague descriptions prevent users from understanding what the command does." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ae8bbc03 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any command intended for distribution beyond personal use" ;
    oc:directiveContent "Commands must detect and adapt to the host platform (macOS, Linux, Windows/WSL) using platform detection rather than assuming specific tools are available." ;
    oc:hasRationale "Unknown users run commands on diverse platforms; hardcoded platform-specific tools like pbcopy break silently on Linux or Windows." ;
    oc:severityLevel "HIGH" .

oc:kn_cc7cbdfa a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before executing any command that relies on external tools (git, jq, node, gh, docker, etc.)" ;
    oc:directiveContent "Check for all required dependencies at startup and provide clear installation instructions when tools are missing. Document optional dependencies separately with feature-gated behavior." ;
    oc:hasRationale "Missing dependencies cause cryptic errors; upfront checks with install URLs give users a clear remediation path." ;
    oc:severityLevel "HIGH" .

