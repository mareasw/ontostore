@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_command_development_interactive_commands a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "interactive-commands" ;
    skos:broader "command pattern guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/command-development" ;
    oc:contentHash "09ab1f18bfa3ff5f7088e45d5810ac20eb25ffc97fc9e8bb79416d40e0b4516b" ;
    oc:differentia "uses AskUserQuestion tool to create interactive commands that gather user feedback and guide multi-stage decisions within Claude Code slash commands" ;
    oc:extends oc:skill_anthropics_claude_code_command_development ;
    oc:hasAllowedTool "AskUserQuestion",
        "Bash",
        "Read",
        "Write" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_30bcec01,
        oc:kn_8a5c9df0,
        oc:kn_9ed0a841,
        oc:kn_a3d45ef0,
        oc:kn_af1a6490,
        oc:kn_ebb8e497,
        oc:kn_f967a166 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "build conditional question flows in commands",
        "create interactive commands with user prompts",
        "design multi-stage interactive workflows",
        "gather user configuration through AskUserQuestion" .

oc:kn_30bcec01 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing AskUserQuestion option labels and descriptions" ;
    oc:directiveContent "Option labels should be 1-5 specific descriptive words; descriptions should explain what the option means, mention key trade-offs or benefits, and help the user make an informed decision." ;
    oc:hasRationale "Well-crafted options reduce back-and-forth and help users make correct choices on the first interaction." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8a5c9df0 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building multi-stage interactive workflows" ;
    oc:directiveContent "Design interactive flows as staged conversations: gather core settings first, then conditionally ask follow-up questions based on earlier answers, and always confirm before executing." ;
    oc:hasRationale "Progressive disclosure reduces cognitive load and ensures the user only sees questions relevant to their chosen path." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9ed0a841 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing an interactive command" ;
    oc:directiveContent "Always verify that AskUserQuestion is listed in the command's allowed-tools frontmatter, and handle cases where answers are empty or invalid by showing alternative approaches." ;
    oc:hasRationale "Without AskUserQuestion in allowed-tools the tool call will fail silently; empty answer handling prevents silent failures mid-workflow." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a3d45ef0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring AskUserQuestion parameters" ;
    oc:directiveContent "Limit options to 2-4 per question, headers to max 12 characters, 1-4 questions per AskUserQuestion call, and descriptions to 1-2 sentences." ;
    oc:hasRationale "These limits keep the interactive UI readable and prevent decision overload for the user." ;
    oc:severityLevel "MEDIUM" .

oc:kn_af1a6490 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any command that needs user input" ;
    oc:directiveContent "Use AskUserQuestion for complex choices (multi-select, trade-offs, preference gathering) and command arguments for simple values (file paths, numbers, names, scriptable inputs)." ;
    oc:hasRationale "Matching the interaction mechanism to the complexity of the decision prevents both user frustration from over-prompting and confusion from under-specified arguments." ;
    oc:severityLevel "HIGH" .

oc:kn_ebb8e497 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On validation failure in interactive commands" ;
    oc:directiveContent "When validation of user answers fails, present the errors clearly and offer Fix/Override/Cancel choices via AskUserQuestion to let the user decide how to proceed." ;
    oc:hasRationale "Giving the user agency in error recovery prevents dead ends and allows informed overrides when appropriate." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f967a166 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring multiSelect on AskUserQuestion options" ;
    oc:directiveContent "Never use multiSelect: true for mutually exclusive choices (e.g., selecting a database engine or authentication method). Only use multiSelect when any combination of options is valid." ;
    oc:hasRationale "Allowing multiple selections on mutually exclusive options leads to invalid or contradictory configurations." ;
    oc:severityLevel "HIGH" .

