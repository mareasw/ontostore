oc:kn_02707fee a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing hooks within the same event (e.g., multiple PreToolUse hooks)" ;
    oc:directiveContent "Never assume hook execution order — all matching hooks run in parallel and cannot see each other's output." ;
    oc:hasRationale "Parallel execution means hooks must be designed for independence; shared state between hooks in the same event group will fail unpredictably." ;
    oc:severityLevel "HIGH" .

oc:kn_0c5baf00 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing command hooks that reference plugin files" ;
    oc:directiveContent "Always use ${CLAUDE_PLUGIN_ROOT} for file references in hook commands to ensure portability across environments." ;
    oc:hasRationale "Hardcoded paths break when the plugin is installed in different locations; CLAUDE_PLUGIN_ROOT resolves to the correct plugin directory at runtime." ;
    oc:severityLevel "HIGH" .

oc:kn_0e65b7d7 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When returning results from command hooks" ;
    oc:directiveContent "Use exit code 0 for success (stdout shown in transcript), exit code 2 for blocking errors (stderr fed back to Claude), other codes for non-blocking errors." ;
    oc:hasRationale "Exit codes control how Claude processes hook output; wrong codes cause hooks to silently fail or block unexpectedly." .

oc:kn_18701c50 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before deploying hooks to a Claude Code session" ;
    oc:directiveContent "Validate hooks.json with scripts/validate-hook-schema.sh, lint scripts with hook-linter.sh, and test with test-hook.sh before deploying hooks." ;
    oc:hasRationale "Invalid hook configuration can break the entire plugin load; testing prevents production failures." .

oc:kn_1d164257 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When modifying hook configuration or scripts during a session" ;
    oc:directiveContent "Hooks are loaded at session start and cannot be hot-swapped. Editing hooks.json or hook scripts requires restarting Claude Code." ;
    oc:hasRationale "Hook configuration is loaded once at session initialization; changes mid-session will not take effect without restart." ;
    oc:severityLevel "CRITICAL" .

oc:kn_644f4e56 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing hook type for a new hook" ;
    oc:directiveContent "Use prompt-based hooks for complex/context-aware logic; use command hooks for deterministic, fast checks (<50ms) and external tool integrations." ;
    oc:hasRationale "Prompt hooks leverage LLM reasoning for edge cases but are slower (~30s). Command hooks are deterministic and fast but brittle for nuanced validation." .

oc:kn_8d83d0d7 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When configuring hook timeout values" ;
    oc:directiveContent "Default timeouts are 60s for command hooks and 30s for prompt hooks. Set explicit timeouts to avoid blocking workflows." ;
    oc:hasRationale "Long-running hooks block the agent's event loop; appropriate timeouts prevent workflow stalls." .

oc:kn_96761ea7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating hooks that should only run conditionally" ;
    oc:directiveContent "For temporarily active hooks, use flag files ($CLAUDE_PROJECT_DIR/.enable-xxx) or configuration-driven activation to make hooks opt-in." ;
    oc:hasRationale "Flag-file patterns allow enabling/disabling hooks without code changes, supporting feature flags and debugging workflows." .

oc:kn_ad7c85ae a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating hook configuration files" ;
    oc:directiveContent "Plugin hooks.json must use wrapper format {\"description\": \"...\", \"hooks\": {...}}; settings format uses direct {\"PreToolUse\": [...], ...} without wrapper." ;
    oc:hasRationale "Mixing the two formats causes configuration loading failures." .

oc:kn_ae97e44d a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When implementing cross-hook state communication" ;
    oc:directiveContent "Hook state sharing via temp files only works across sequential events (e.g., PreToolUse → PostToolUse), never within parallel hooks of the same event." ;
    oc:hasRationale "Parallel hooks within the same event group execute simultaneously and cannot reliably share temp-file state." .

oc:kn_b236a667 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring prompt-type hooks" ;
    oc:directiveContent "Prompt-based hooks are only supported on Stop, SubagentStop, UserPromptSubmit, and PreToolUse events." ;
    oc:hasRationale "Other events (PostToolUse, SessionStart, SessionEnd, PreCompact, Notification) only support command-type hooks." ;
    oc:severityLevel "HIGH" .

oc:kn_ebf80c4b a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When writing command hook bash scripts" ;
    oc:directiveContent "Always validate hook input in command hooks: quote all bash variables, use set -euo pipefail, and check for path traversal/injection patterns." ;
    oc:hasRationale "Hook scripts receive user-controlled JSON via stdin; unquoted variables and missing validation enable command injection attacks." ;
    oc:severityLevel "CRITICAL" .

