                _:ref_9399310d422bfc64 ;
            oc:workflowId "hook-migration" ;
            oc:workflowName "Command Hook to Prompt Hook Migration" ],
        _:ref_c13a58e67b27321a ;
    oc:impartsKnowledge oc:kn_5fcc89ae,
        oc:kn_a5a4fcf7,
        oc:kn_c101b26f,
        oc:kn_d7011d5e,
        oc:kn_e4c03bd9,
        oc:kn_e7b26131,
        oc:kn_eea34a94,
        oc:kn_ff48ce47 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "combine command and prompt hooks in hybrid approach",
        "migrate command hooks to prompt hooks",
        "refactor hook configuration for maintainability",
        "upgrade bash hook scripts to LLM-based validation" .

oc:kn_5fcc89ae a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring prompt hook timeouts" ;
    oc:directiveContent "Set appropriate timeout for prompt hooks: usually 15-30 seconds. Command hooks used in hybrid setups should use shorter timeouts (e.g., 5s)." ;
    oc:hasRationale "Prompt hooks require LLM inference time; too-short timeouts cause false approvals, too-long timeouts degrade user experience." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a5a4fcf7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between command and prompt hook types" ;
    oc:directiveContent "Prompt-based hooks offer natural language reasoning, better edge case handling, no bash scripting requirement, and more flexible validation compared to command hooks." ;
    oc:hasRationale "Prompt hooks leverage LLM understanding of intent rather than literal string matching, catching variations and patterns that hard-coded scripts miss." ;
    oc:severityLevel "HIGH" .

oc:kn_c101b26f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building hybrid hooks with both command and prompt stages" ;
    oc:codeLanguage "json" ;
    oc:directiveContent """{
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/quick-check.sh",
          "timeout": 5
        },
        {
          "type": "prompt",
          "prompt": "Deep analysis of bash command: $TOOL_INPUT",
          "timeout": 15
        }
      ]
    }
  ]
}""" .

oc:kn_d7011d5e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating from command to prompt hooks" ;
    oc:directiveContent "Do not migrate all hooks at once. Hard-coded bash patterns (exact string matching, simple regex) miss variations, edge cases, and lack context awareness." ;
    oc:hasRationale "Batch migration risks introducing regressions; incremental migration allows testing each hook's prompt equivalent against edge cases the old hook missed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e4c03bd9 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When multi-stage validation is needed" ;
    oc:directiveContent "Use hybrid approach: command hook for fast deterministic checks first, then prompt hook for deep reasoning. Both run in sequence under the same matcher." ;
    oc:hasRationale "Combining both types gets the speed of deterministic checks with the nuanced understanding of LLM reasoning, failing fast on obvious issues." ;
    oc:severityLevel "HIGH" .

oc:kn_e7b26131 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When writing hook validation logic" ;
    oc:directiveContent "Prompt hook response must return 'approve' or 'deny' with explanation. Command hooks exit 0 to approve, exit 2 with stderr message to deny." ;
    oc:hasRationale "The hook system uses exit codes (command) or approve/deny strings (prompt) to gate tool execution." .

oc:kn_eea34a94 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When migrating any command hook to prompt hook" ;
    oc:directiveContent "1. Identify validation logic in command hook. 2. Convert hard-coded patterns to natural language criteria. 3. Test with edge cases the old hook missed. 4. Verify LLM understands the intent. 5. Set appropriate timeout (15-30s). 6. Document the new hook in README. 7. Remove or archive old script files." ;
    oc:stepOrder 1 .

oc:kn_ff48ce47 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating whether a command hook should be migrated" ;
    oc:directiveContent "Keep command hooks for: (1) deterministic performance checks (mathematical/file size), (2) external tool integration (security scanners), (3) very fast checks under 50ms with simple logic." ;
    oc:hasRationale "Command hooks are faster and deterministic where logic is simple; prompt hooks add latency (15-30s timeout) and non-determinism unnecessary for trivial checks." ;
    oc:severityLevel "HIGH" .

