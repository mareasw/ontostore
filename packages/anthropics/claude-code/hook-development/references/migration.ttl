@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_hook_development_migration a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "migration" ;
    skos:broader "Migration guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/hook-development" ;
    oc:contentHash "7f8e7a795829837f46a0c058c26c8f5c4aa8be5c9fb5316b828229d1802ded77" ;
    oc:dependsOnSkill oc:skill_hook_development ;
    oc:differentia "that transforms basic command-based hooks into advanced prompt-based hooks for better maintainability, flexibility, and context-awareness in Claude Code plugins" ;
    oc:extends oc:skill_anthropics_claude_code_hook_development ;
    oc:handlesFailure oc:PromptHookTimeout,
        oc:ValidationLogicLost ;
    oc:hasArgumentHint "hook-type or plugin-path to migrate" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_2c5d53c5,
        oc:kn_3fbdd682,
        oc:kn_57ca9fea,
        oc:kn_9d161aa2,
        oc:kn_d1614be8,
        oc:kn_dc958927,
        oc:kn_e83ee636 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CommandHooksExist ;
    oc:resolvesIntent "convert bash hook scripts to prompt-based hooks",
        "determine when to keep command hooks vs migrate to prompt hooks",
        "migrate command hooks to prompt hooks",
        "refactor hook validation from scripting to natural language",
        "upgrade plugin hooks to advanced format" ;
    oc:yieldsState oc:PromptHooksConfigured,
        oc:ScriptsArchived .

oc:kn_2c5d53c5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a hook needs both fast deterministic validation and nuanced contextual reasoning" ;
    oc:directiveContent "Use the hybrid approach when beneficial: combine a fast command hook for deterministic checks with a prompt hook for complex reasoning in the same matcher." ;
    oc:hasRationale "The hybrid approach gets the best of both worlds—fast fail on obvious issues via command hooks, plus intelligent analysis via prompt hooks. Both run in parallel." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3fbdd682 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring migrated prompt hooks" ;
    oc:directiveContent "Set appropriate timeouts for prompt hooks, usually 15-30 seconds. Command hooks default to 60s but prompt hooks should be tighter." ;
    oc:hasRationale "Prompt hooks that take too long degrade the user experience since they run before/after every matched tool call" ;
    oc:severityLevel "MEDIUM" .

oc:kn_57ca9fea a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any hook migration" ;
    oc:directiveContent "Before migrating, identify all validation logic in the existing command hook, list edge cases the old hook missed, and verify the LLM understands the intent of the new prompt." ;
    oc:hasRationale "Incomplete migration of validation logic creates security gaps. Testing edge cases ensures the prompt hook is at least as comprehensive as the command hook it replaces." ;
    oc:severityLevel "HIGH" .

oc:kn_9d161aa2 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "After completing a hook migration" ;
    oc:directiveContent "Archive old script files in a scripts/archive/ directory rather than deleting them, so the original validation logic can be referenced if the prompt hook needs debugging." ;
    oc:hasRationale "Scripts contain explicit validation logic that may be needed for debugging prompt hook false positives/negatives or as reference if reverting" ;
    oc:severityLevel "LOW" .

oc:kn_d1614be8 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When translating bash validation logic into prompt hook prompts" ;
    oc:directiveContent "Convert hard-coded bash patterns (string contains, regex matches, multiple conditions) into natural language criteria lists. Pattern: 'Check: 1) criterion1 2) criterion2 3) criterion3. Deny if any fail.'" ;
    oc:hasRationale "Natural language criteria lists let the LLM understand intent rather than matching literal strings, catching variations and edge cases the original script missed" ;
    oc:severityLevel "MEDIUM" .

oc:kn_dc958927 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning a hook migration project" ;
    oc:directiveContent "Migrate hooks one at a time rather than all at once. Start with the simplest hook to build confidence, then progressively migrate more complex ones." ;
    oc:hasRationale "Incremental migration reduces risk and allows validation that prompt hooks catch what command hooks caught before moving on" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e83ee636 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to migrate a specific command hook" ;
    oc:directiveContent "Do not blindly migrate all command hooks to prompt hooks. Keep command hooks for deterministic performance checks, external tool integrations, and very fast checks (<50ms)." ;
    oc:hasRationale "Command hooks are superior for purely mathematical/deterministic validations and have zero latency overhead. Prompt hooks introduce LLM inference latency (typically 5-30s) which is inappropriate for trivial checks." ;
    oc:severityLevel "HIGH" .

