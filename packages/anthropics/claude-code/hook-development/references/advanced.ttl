        oc:KnownIssue ;
    oc:appliesToContext "When sharing state between hooks" ;
    oc:directiveContent "Hook state sharing via temporary files only works for sequential hook events, not parallel hooks in the same event. Use the $$ PID variable to avoid file collisions between sessions." ;
    oc:hasRationale "Parallel hooks accessing the same temp file will race. Sequential events (PreToolUse → PostToolUse) guarantee ordering." ;
    oc:severityLevel "HIGH" .

oc:kn_98511f4b a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When optimizing hook execution latency" ;
    oc:directiveContent "Design hooks to be independent so they can run in parallel, and use caching (e.g., md5-based cache keys with TTL) for repeated validations on the same input." ;
    oc:hasRationale "Parallel independent hooks reduce total latency. Caching avoids redundant computation for repeated operations on unchanged inputs." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a947dc2b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing validation hooks that need both speed and intelligence" ;
    oc:directiveContent "Combine command hooks (fast deterministic checks) with prompt hooks (intelligent analysis) for layered validation — command hooks quickly approve safe operations while prompt hooks handle complex cases." ;
    oc:hasRationale "Command hooks have lower latency and cost; prompt hooks provide deeper reasoning. Layering them optimizes both performance and accuracy." ;
    oc:severityLevel "HIGH" .

oc:kn_bae61b39 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When writing hook scripts that process tool inputs" ;
    oc:directiveContent "Always validate inputs before processing — check that file paths exist, jq extractions produce values, and external services are reachable before acting on them. Use exit 0 with continue:true for non-critical failures." ;
    oc:hasRationale "Uncaught exceptions from missing files or null jq results will crash hooks and may block the entire workflow unexpectedly." ;
    oc:severityLevel "HIGH" .

oc:kn_bfeca745 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When hooks need to adapt to different deployment contexts" ;
    oc:directiveContent "Use environment variables (CI, USER) and project config files (.claude-hooks-config.json) to conditionally execute hooks, enabling different behavior across environments." ;
    oc:hasRationale "Conditional execution prevents unnecessary validation in trusted environments while maintaining strict checks in production/CI." ;
    oc:severityLevel "MEDIUM" .

oc:kn_dd4d4408 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When hooks interact with sensitive operations or external systems" ;
    oc:directiveContent "Implement rate limiting and secret detection in hooks to prevent abuse and data leaks. Track command frequency per minute and block patterns matching api_key, password, secret, or token literals." ;
    oc:hasRationale "Rate limiting prevents runaway or malicious tool usage. Secret detection prevents accidental exposure of credentials in tool inputs." ;
    oc:severityLevel "HIGH" .

oc:kn_f20e03ad a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing multiple hooks for the same event/matcher" ;
    oc:directiveContent "Never assume hooks run in a specific order within the same event — hooks within a single matcher run in parallel, so state sharing only works across sequential events (e.g., PreToolUse → PostToolUse)." ;
    oc:hasRationale "Parallel execution means Hook 1's state may not be available when Hook 2 runs if they share the same event." ;
    oc:severityLevel "CRITICAL" .

