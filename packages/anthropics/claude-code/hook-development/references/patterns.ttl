oc:kn_27866d7c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using Pattern 9 (temporarily active hooks) with flag files" ;
    oc:directiveContent "Must restart Claude Code after creating or removing flag files for hooks to recognize changes." ;
    oc:hasRationale "Hook configurations are loaded at startup; runtime flag file changes are not hot-reloaded." ;
    oc:severityLevel "HIGH" .

oc:kn_32733267 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building hooks that need per-project or per-team customization" ;
    oc:directiveContent "Use JSON configuration files (.claude/*.local.json) with sensible defaults to make hook behavior user-configurable and team-specific." ;
    oc:hasRationale "Configuration-driven hooks decouple validation rules from hook code, enabling non-developer customization." ;
    oc:severityLevel "MEDIUM" .

oc:kn_587ec6cb a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing bash command hooks that validate tool inputs" ;
    oc:directiveContent "Command hooks receive JSON input on stdin; use 'jq' to extract fields like .tool_input.file_path. Output denial as JSON to stderr with exit code 2." ;
    oc:hasRationale "Consistent input/output handling ensures hooks integrate correctly with Claude Code's hook protocol." ;
    oc:severityLevel "HIGH" .

oc:kn_5ce34f36 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When implementing security validation hooks (Pattern 1)" ;
    oc:directiveContent "PreToolUse prompt hooks on Write|Edit should verify: not in /etc or system directories, not .env or credentials, no '..' path traversal." ;
    oc:hasRationale "These checks prevent the agent from writing to sensitive system files or leaking credentials." ;
    oc:severityLevel "CRITICAL" .

oc:kn_775f8fb3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating performance-intensive or project-specific validation hooks" ;
    oc:directiveContent "Use flag files ($CLAUDE_PROJECT_DIR/.enable-*) to gate expensive or optional hooks, allowing opt-in activation without code changes." ;
    oc:hasRationale "Flag files let teams toggle hooks per-project without modifying hook configuration, and provide a clean on/off mechanism." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c02cf55e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing comprehensive hook coverage" ;
    oc:directiveContent "Combine multiple hook patterns across PreToolUse, PostToolUse, Stop, and SessionStart events for layered protection and automation." ;
    oc:hasRationale "Single hooks provide narrow protection; multi-layered hooks catch issues at different stages of the agent lifecycle." ;
    oc:severityLevel "MEDIUM" .

_:ref_291a13f9adbd65dd a oc:WorkflowStep ;
    dcterms:description "Identify which lifecycle event the hook targets: PreToolUse (before tool runs), PostToolUse (after tool runs), Stop (before session ends), SessionStart (at session start), Notification (on notifications)" ;
    oc:expectedOutcome "Lifecycle event determined" ;
    oc:stepId "identify-lifecycle" .

_:ref_5f82542cffbe50d8 a oc:WorkflowStep ;
    dcterms:description "Define matcher: specific tool name (e.g., 'Bash'), pipe-separated list ('Write|Edit'), regex pattern ('mcp__.*__delete.*'), or '*' for all tools" ;
    oc:expectedOutcome "Matcher configured to target the right tools" ;
    oc:stepDependsOn _:ref_bc381c68e837ca50 ;
    oc:stepId "select-matcher" .

_:ref_9b24f6bdf41f66e9 a oc:WorkflowStep ;
    dcterms:description "Implement the hook using the appropriate pattern template from the 10 common patterns" ;
    oc:expectedOutcome "Hook configuration written with correct JSON structure" ;
    oc:stepDependsOn _:ref_5f82542cffbe50d8 ;
    oc:stepId "implement-pattern" .

_:ref_bc381c68e837ca50 a oc:WorkflowStep ;
    dcterms:description "Choose hook type: 'prompt' for LLM-based validation/approval, 'command' for script-based actions" ;
    oc:expectedOutcome "Hook type selected based on whether LLM judgment or script execution is needed" ;
    oc:stepDependsOn _:ref_291a13f9adbd65dd ;
    oc:stepId "choose-hook-type" .

