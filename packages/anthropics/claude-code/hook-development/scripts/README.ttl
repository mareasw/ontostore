@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_hook_development_readme a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "readme" ;
    skos:broader "Development utility suite" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/hook-development" ;
    oc:contentHash "08a28b12ffa9fcb16f257ea685c70a920f4f835978b9ffbbac055137c6f6aca0" ;
    oc:dependsOnSkill oc:skill_hook_development ;
    oc:differentia "Validates, tests, and lints Claude Code hook implementations before deployment through three complementary shell scripts" ;
    oc:extends oc:skill_anthropics_claude_code_hook_development ;
    oc:handlesFailure oc:InvalidInput,
        oc:SchemaValidationFailed,
        oc:TimeoutExceeded ;
    oc:hasAllowedTool "Bash" ;
    oc:hasArgumentHint "<path-to-hooks.json-or-hook-script>" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_30d05e51,
        oc:kn_940a7c1d,
        oc:kn_b5abc0b7,
        oc:kn_eead233c,
        oc:kn_f50f4751 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:ToolInstalled ;
    oc:resolvesIntent "debug hook development issues",
        "lint hook scripts for best practices",
        "test hook scripts with sample input",
        "validate hook configuration schema" ;
    oc:yieldsState oc:HooksLinted,
        oc:HooksTested,
        oc:HooksValidated .

oc:kn_30d05e51 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When developing new hooks from scratch" ;
    oc:directiveContent "Follow the typical workflow: lint → create test input → test hook → add to hooks.json → validate config → test in claude --debug" ;
    oc:hasRationale "This sequential workflow catches issues at each stage before they compound in production" ;
    oc:severityLevel "HIGH" .

oc:kn_940a7c1d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing command-based hook scripts" ;
    oc:directiveContent "Never deploy hooks without testing — unquoted variables, missing set -euo pipefail, and hardcoded paths introduce injection vulnerabilities and portability failures" ;
    oc:hasRationale "The linter catches these issues, but skipping linting means security and reliability problems ship to users" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b5abc0b7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before deploying any hook changes to Claude Code" ;
    oc:directiveContent "Always lint hook scripts, test them with sample input, and validate hooks.json before deploying to avoid breaking user workflows" ;
    oc:hasRationale "Faulty hooks can silently break Claude Code workflows, block tool usage, or introduce security vulnerabilities" ;
    oc:severityLevel "CRITICAL" .

oc:kn_eead233c a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When a configured hook doesn't fire during Claude Code sessions" ;
    oc:directiveContent "Hooks that don't execute usually lack a shebang, aren't executable, or have incorrect paths in hooks.json" ;
    oc:hasRationale "These are the three most common root causes for silent hook failures" ;
    oc:severityLevel "HIGH" .

oc:kn_f50f4751 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting timeout values in hooks.json" ;
    oc:directiveContent "Hooks should complete within their configured timeout (default 60s for command, 30s for prompt); timeouts over 600s are flagged as warnings" ;
    oc:hasRationale "Long-running hooks block the Claude Code event loop and degrade user experience" ;
    oc:severityLevel "MEDIUM" .

