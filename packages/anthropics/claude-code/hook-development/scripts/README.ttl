oc:kn_0ec5c0a1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing hook scripts and hooks.json configuration" ;
    oc:directiveContent "Never use hardcoded paths in hooks; always use ${CLAUDE_PLUGIN_ROOT} and quote all variables" ;
    oc:hasRationale "Hardcoded paths break portability; unquoted variables enable injection vulnerabilities" ;
    oc:severityLevel "HIGH" .

oc:kn_25890245 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before testing or deploying any hook script" ;
    oc:directiveContent "Verify script has shebang (#!/bin/bash), is executable (chmod +x), and path in hooks.json uses ${CLAUDE_PLUGIN_ROOT}" ;
    oc:hasRationale "Missing shebang, permissions, or incorrect paths are the most common reasons hooks don't execute" .

oc:kn_38557170 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When developing a new hook from scratch" ;
    oc:directiveContent "1. Write hook script 2. Lint with hook-linter.sh 3. Create test input with test-hook.sh --create-sample 4. Test hook with test-hook.sh -v 5. Add to hooks.json 6. Validate with validate-hook-schema.sh 7. Test in Claude Code with --debug" ;
    oc:hasRationale "Following this order catches issues early—lint before test, test before config, validate before deploy" ;
    oc:stepOrder 1 .

oc:kn_4a455ac2 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When linting one or more hook scripts for best practices" ;
    oc:directiveContent "./hook-linter.sh <hook-script.sh> [hook-script2.sh ...]" .

oc:kn_8c0767d6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When testing hooks that aren't behaving as expected" ;
    oc:directiveContent "Use verbose mode (-v) to debug hook behavior, and create different test inputs for safe operations, dangerous operations, and edge cases" ;
    oc:hasRationale "Verbose mode reveals execution details; diverse test inputs surface edge-case failures before production" .

oc:kn_a93cdc61 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, before any hook deployment" ;
    oc:directiveContent "Always test hooks before deploying to avoid breaking user workflows" ;
    oc:hasRationale "A broken hook can block or corrupt Claude Code operations for end users" ;
    oc:severityLevel "CRITICAL" .

oc:kn_aa735d0b a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When a hook doesn't seem to execute or produces unexpected behavior" ;
    oc:directiveContent "Hooks may fail silently if exit codes are wrong (should be 0 or 2), errors go to stdout instead of stderr, or JSON output is malformed" ;
    oc:hasRationale "Claude Code interprets exit codes 0 and 2 specifically; other codes or missing stderr output hide failures" .

oc:kn_ac183890 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating test input and running hook tests" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """./test-hook.sh --create-sample PreToolUse > test-input.json
./test-hook.sh -v -t 30 my-hook.sh test-input.json""" .

oc:kn_dfaad5a3 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating a hooks.json configuration file" ;
    oc:directiveContent "./validate-hook-schema.sh path/to/hooks.json" .

oc:kn_f8556c0a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any hook script" ;
    oc:directiveContent "Hook scripts must include: shebang, set -euo pipefail, stdin input reading, proper error handling to stderr, variable quoting, and input validation" ;
    oc:hasRationale "These practices ensure scripts are robust, secure against injection, and fail predictably" ;
    oc:severityLevel "HIGH" .

