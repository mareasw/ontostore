@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_claude_code_frontend_design a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "frontend-design" ;
    skos:broader "Frontend code generator" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/claude-code/frontend-design" ;
    oc:contentHash "e02cb16b9749174327314036821ed5faabd248e34501c045ac0243a62fb9f091" ;
    oc:differentia "that produces distinctive, production-grade interfaces with bold aesthetic vision, deliberately avoiding generic AI-generated design patterns" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "description of component, page, or interface to build" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Create distinctive, production-grade frontend interfaces with high design quality. Use this skill when the user asks to build web components, pages, or applications. Generates creative, polished code that avoids generic AI aesthetics." ;
    oc:hasName "frontend-design" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "This skill guides creation of distinctive, production-grade frontend interfaces that avoid generic \"AI slop\" aesthetics. Implement real working code with exceptional attention to aesthetic details and creative choices." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "The user provides frontend requirements: a component, page, application, or interface to build. They may include context about the purpose, audience, or technical constraints." ],
                [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: frontend-design
description: Create distinctive, production-grade frontend interfaces with high design quality. Use this skill when the user asks to build web components, pages, or applications. Generates creative, polished code that avoids generic AI aesthetics.
license: Complete terms in LICENSE.txt
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Before coding, understand the context and commit to a BOLD aesthetic direction:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Differentiation**: What makes this UNFORGETTABLE? What's the one thing someone will remember?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Purpose**: What problem does this interface solve? Who uses it?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Constraints**: Technical requirements (framework, performance, accessibility)." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Tone**: Pick an extreme: brutally minimal, maximalist chaos, retro-futuristic, organic/natural, luxury/refined, playful/toy-like, editorial/magazine, brutalist/raw, art deco/geometric, soft/pastel, industrial/utilitarian, etc. There are so many flavors to choose from. Use these for inspiration but design one that is true to the aesthetic direction." ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**CRITICAL**: Choose a clear conceptual direction and execute it with precision. Bold maximalism and refined minimalism both work - the key is intentionality, not intensity." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "Then implement working code (HTML/CSS/JS, React, Vue, etc.) that is:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 5 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Cohesive with a clear aesthetic point-of-view" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Visually striking and memorable" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Production-grade and functional" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Meticulously refined in every detail" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Design Thinking" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "Interpret creatively and make unexpected choices that feel genuinely designed for the context. No design should be the same. Vary between light and dark themes, different fonts, different aesthetics. NEVER converge on common choices (Space Grotesk, for example) across generations." ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "**Backgrounds & Visual Details**: Create atmosphere and depth rather than defaulting to solid colors. Add contextual effects and textures that match the overall aesthetic. Apply creative forms like gradient meshes, noise textures, geometric patterns, layered transparencies, dramatic shadows, decorative borders, custom cursors, and grain overlays." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Color & Theme**: Commit to a cohesive aesthetic. Use CSS variables for consistency. Dominant colors with sharp accents outperform timid, evenly-distributed palettes." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Typography**: Choose fonts that are beautiful, unique, and interesting. Avoid generic fonts like Arial and Inter; opt instead for distinctive choices that elevate the frontend's aesthetics; unexpected, characterful font choices. Pair a distinctive display font with a refined body font." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Motion**: Use animations for effects and micro-interactions. Prioritize CSS-only solutions for HTML. Use Motion library for React when available. Focus on high-impact moments: one well-orchestrated page load with staggered reveals (animation-delay) creates more delight than scattered micro-interactions. Use scroll-triggering and hover states that surprise." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Spatial Composition**: Unexpected layouts. Asymmetry. Overlap. Diagonal flow. Grid-breaking elements. Generous negative space OR controlled density." ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent "Remember: Claude is capable of extraordinary creative work. Don't hold back, show what can truly be created when thinking outside the box and committing fully to a distinctive vision." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 5 ;
                    oc:textContent "**IMPORTANT**: Match implementation complexity to the aesthetic vision. Maximalist designs need elaborate code with extensive animations and effects. Minimalist or refined designs need restraint, precision, and careful attention to spacing, typography, and subtle details. Elegance comes from executing the vision well." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "NEVER use generic AI-generated aesthetics like overused font families (Inter, Roboto, Arial, system fonts), cliched color schemes (particularly purple gradients on white backgrounds), predictable layouts and component patterns, and cookie-cutter design that lacks context-specific character." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Focus on:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Frontend Aesthetics Guidelines" ] ;
    oc:impartsKnowledge oc:kn_1ec471b0,
        oc:kn_3b09655e,
        oc:kn_593303b5,
        oc:kn_5db99907,
        oc:kn_993a573e,
        oc:kn_ce59fc5f,
        oc:kn_f51de0e1 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build production-grade UI",
        "build web components",
        "create frontend interfaces",
        "design web pages",
        "generate creative frontend code" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_1ec471b0 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing animations and theming" ;
    oc:codeLanguage "css" ;
    oc:directiveContent "Prioritize CSS-only animation solutions for HTML projects. Use the Motion library for React when available. Leverage animation-delay for staggered reveals. Use CSS custom properties (variables) for consistent theming." .

oc:kn_3b09655e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any frontend interface" ;
    oc:directiveContent "Never use generic AI aesthetics: overused fonts (Inter, Roboto, Arial, system fonts), clichéd purple gradient-on-white color schemes, predictable layouts, or cookie-cutter design lacking context-specific character. Never converge on common choices like Space Grotesk across generations." ;
    oc:hasRationale "Generic AI aesthetics produce forgettable, indistinguishable interfaces that fail to serve the specific context and purpose" ;
    oc:severityLevel "CRITICAL" .

oc:kn_593303b5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before writing any frontend code" ;
    oc:directiveContent "Before coding, analyze Purpose (problem + audience), Tone (pick an extreme aesthetic direction), Constraints (framework, performance, accessibility), and Differentiation (what makes this unforgettable). Choose a clear conceptual direction and execute with precision — intentionality matters more than intensity." ;
    oc:hasRationale "Deliberate aesthetic direction prevents generic output and ensures the design serves its specific context" ;
    oc:severityLevel "HIGH" .

oc:kn_5db99907 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating multiple frontend designs in a session" ;
    oc:directiveContent "No two designs should be the same. Vary between light and dark themes, different fonts, different aesthetics. Never converge on common choices across generations." ;
    oc:hasRationale "Convergence on repeated patterns defeats the purpose of distinctive design and produces predictable, boring output" ;
    oc:severityLevel "MEDIUM" .

oc:kn_993a573e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making design implementation choices" ;
    oc:directiveContent "For typography: pair a distinctive display font with a refined body font. For color: use CSS variables for consistency; dominant colors with sharp accents outperform evenly-distributed palettes. For motion: one well-orchestrated page load with staggered reveals (animation-delay) creates more delight than scattered micro-interactions. For spatial composition: prefer asymmetry, overlap, diagonal flow, and grid-breaking elements." ;
    oc:hasRationale "These heuristics consistently produce visually striking results that feel intentionally designed rather than assembled" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ce59fc5f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing the chosen aesthetic direction" ;
    oc:directiveContent "Match implementation complexity to the aesthetic vision: maximalist designs need elaborate code with extensive animations and effects; minimalist designs need restraint, precision, and careful attention to spacing, typography, and subtle details." ;
    oc:hasRationale "Mismatched implementation effort undermines the design vision — maximalism under-implemented looks sparse, minimalism over-implemented looks cluttered" ;
    oc:severityLevel "HIGH" .

oc:kn_f51de0e1 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building any frontend interface" ;
    oc:directiveContent "1. Understand context (purpose, audience, constraints) 2. Choose a BOLD aesthetic direction (tone, differentiation) 3. Select typography (distinctive display + refined body font) 4. Define color palette with CSS variables (dominant colors + sharp accents) 5. Plan spatial composition (unexpected layout, asymmetry) 6. Design motion/animation strategy (CSS-first, high-impact moments) 7. Add atmospheric details (textures, patterns, gradients, overlays) 8. Implement production-grade working code" ;
    oc:stepOrder 1 .

