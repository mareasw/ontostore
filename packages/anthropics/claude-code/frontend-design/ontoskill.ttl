@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_frontend_design a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "frontend-design" ;
    skos:broader "Frontend code generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/frontend-design" ;
    oc:contentHash "e02cb16b9749174327314036821ed5faabd248e34501c045ac0243a62fb9f091" ;
    oc:differentia "that produces distinctive, production-grade interfaces with bold aesthetic direction, rejecting generic AI-generated design patterns in favor of intentional, memorable visual choices" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Write" ;
    oc:hasArgumentHint "Frontend requirements: component, page, or application description with optional context about purpose, audience, and technical constraints" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Create distinctive, production-grade frontend interfaces with high design quality. Use this skill when the user asks to build web components, pages, or applications. Generates creative, polished code that avoids generic AI aesthetics." ;
    oc:hasName "frontend-design" ;
    oc:impartsKnowledge oc:kn_6d7665c9,
        oc:kn_8531f3ef,
        oc:kn_defd396f,
        oc:kn_efa5725f,
        oc:kn_fc1f975a ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:resolvesIntent "build web application",
        "build web component",
        "create frontend interface",
        "create visually distinctive UI",
        "design web page",
        "generate production-grade frontend code" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_6d7665c9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating multiple frontend designs or when a design could default to a common pattern" ;
    oc:directiveContent "Vary designs across generations — never converge on common choices like Space Grotesk or repeated aesthetic directions. Alternate between light and dark themes, different fonts, different aesthetics to ensure each output is unique." ;
    oc:hasRationale "AI models tend to converge on safe, repeated choices. Deliberate variation ensures each design is distinctive and contextually appropriate rather than a template variation." ;
    oc:severityLevel "HIGH" .

oc:kn_8531f3ef a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing the chosen aesthetic direction" ;
    oc:directiveContent "Match implementation complexity to the aesthetic vision. Maximalist designs need elaborate code with extensive animations and effects. Minimalist designs need restraint, precision, and careful attention to spacing, typography, and subtle details." ;
    oc:hasRationale "Misalignment between vision and implementation produces uncanny results — a maximalist concept with sparse code feels unfinished, while a minimalist concept with heavy code feels overwrought." .

oc:kn_defd396f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any frontend code" ;
    oc:directiveContent "Never use generic AI aesthetics: avoid overused fonts (Inter, Roboto, Arial, system fonts), cliched color schemes (purple gradients on white), predictable layouts, and cookie-cutter designs lacking context-specific character." ;
    oc:hasRationale "Generic AI aesthetics produce forgettable, homogenous interfaces that fail to serve the specific context and purpose of the design." ;
    oc:severityLevel "CRITICAL" .

oc:kn_efa5725f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "At the start of every frontend design task, before writing any code" ;
    oc:directiveContent "Before coding, analyze purpose, tone, constraints, and differentiation. Commit to a BOLD aesthetic direction (e.g., brutalist, editorial, retro-futuristic, luxury) and execute it with precision and intentionality." ;
    oc:hasRationale "Intentional aesthetic direction prevents the default convergence toward generic, safe designs. Bold maximalism and refined minimalism both work — the key is intentionality, not intensity." .

oc:kn_fc1f975a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing and implementing visual details" ;
    oc:directiveContent "Focus on five aesthetic pillars: distinctive typography (unique font pairings), cohesive color with CSS variables, purposeful motion (CSS-only for HTML, Motion library for React), spatial composition with unexpected layouts, and atmospheric backgrounds with textures and depth." ;
    oc:hasRationale "These five pillars cover the dimensions that most impact perceived design quality. Mastery of each elevates interfaces from functional to memorable." .

