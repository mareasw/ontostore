@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_claude_code_claude_opus_4_5_migration a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "claude-opus-4-5-migration" ;
    skos:broader "Migration guide" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/claude-code/claude-opus-4-5-migration" ;
    oc:contentHash "afb3140e206502f96a154570d5ff801a910e712c29fb82afab3592186e52eefc" ;
    oc:differentia "migrates Claude model strings and prompts from Sonnet 4.0/4.5 and Opus 4.1 to Opus 4.5 across Anthropic API, AWS Bedrock, Google Vertex AI, and Azure AI Foundry platforms" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "codebase path or directory to migrate" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Migrate prompts and code from Claude Sonnet 4.0, Sonnet 4.5, or Opus 4.1 to Opus 4.5. Use when the user wants to update their codebase, prompts, or API calls to use Opus 4.5. Handles model string updates and prompt adjustments for known Opus 4.5 behavioral differences. Does NOT migrate Haiku 4.5." ;
    oc:hasName "claude-opus-4-5-migration" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "One-shot migration from Sonnet 4.0, Sonnet 4.5, or Opus 4.1 to Opus 4.5." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "See `references/effort.md` for configuring the effort parameter (only if user requests it)." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "See `references/prompt-snippets.md` for the full text of each snippet to add." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Reference" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_d6d9ec6cfdd33e92 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Migration Workflow" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "If the prompt already uses XML tags, add new content within appropriate existing tags or create consistent new ones" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Use XML tags (e.g., `<code_guidelines>`, `<tool_usage>`) to organize additions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Match the style and structure of the existing prompt" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Place snippets in logical locations (e.g., coding guidelines near other coding instructions)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Integration guidelines**: When adding snippets, don't just append them to prompts. Integrate them thoughtfully:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Opus 4.5 has known behavioral differences from previous models. **Only apply these fixes if the user explicitly requests them or reports a specific issue.** By default, just update model strings." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "Only apply to tool-triggering instructions. Leave other uses of emphasis alone." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Apply if**: User reports tools being called too frequently or unnecessarily." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Opus 4.5 is more responsive to system prompts. Aggressive language that prevented undertriggering on previous models may now cause overtriggering." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Find and soften**:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "`NEVER skip...` → `Don't skip...`" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "`You MUST...` → `You should...`" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "`REQUIRED` → remove or soften" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`CRITICAL:` → remove or soften" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "`ALWAYS do X` → `Do X`" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "1. Tool Overtriggering" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Apply if**: User reports unwanted files, excessive abstraction, or unrequested features. Add the snippet from `references/prompt-snippets.md`." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Opus 4.5 tends to create extra files, add unnecessary abstractions, or build unrequested flexibility." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "2. Over-Engineering Prevention" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Apply if**: User reports the model proposing fixes without inspecting relevant code. Add the snippet from `references/prompt-snippets.md`." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Opus 4.5 can be overly conservative about exploring code, proposing solutions without reading files." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "3. Code Exploration" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**Apply if**: User requests improved frontend design quality or reports generic-looking outputs." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "Add the frontend aesthetics snippet from `references/prompt-snippets.md`." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "4. Frontend Design" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Apply if**: User reports issues related to \"thinking\" while extended thinking is not enabled (no `thinking` parameter in request)." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "When extended thinking is not enabled (the default), Opus 4.5 is particularly sensitive to the word \"think\" and its variants. Extended thinking is enabled only if the API request contains a `thinking` parameter." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Replace \"think\" with alternatives like \"consider,\" \"believe,\" or \"evaluate.\"" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "5. Thinking Sensitivity" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Prompt Adjustments" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Identify which platform the codebase uses, then replace model strings accordingly." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """# Note: 1M context beta (context-1m-2025-08-07) not yet supported with Opus 4.5
""" ;
                                    oc:codeLanguage "python" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 27-29" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Remove the `context-1m-2025-08-07` beta header if present—it is not yet supported with Opus 4.5. Leave a comment noting this:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Unsupported Beta Headers" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Target Model Strings (Opus 4.5)" ;
                                    oc:tableMarkdown """| Platform | Opus 4.5 Model String |
|----------|----------------------|
| Anthropic API (1P) | `claude-opus-4-5-20251101` |
| AWS Bedrock | `anthropic.claude-opus-4-5-20251101-v1:0` |
| Google Vertex AI | `claude-opus-4-5@20251101` |
| Azure AI Foundry | `claude-opus-4-5-20251101` |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Target Model Strings (Opus 4.5)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "### Source Model Strings to Replace" ;
                                    oc:tableMarkdown """| Source Model | Anthropic API (1P) | AWS Bedrock | Google Vertex AI |
|--------------|-------------------|-------------|------------------|
| Sonnet 4.0 | `claude-sonnet-4-20250514` | `anthropic.claude-sonnet-4-20250514-v1:0` | `claude-sonnet-4@20250514` |
| Sonnet 4.5 | `claude-sonnet-4-5-20250929` | `anthropic.claude-sonnet-4-5-20250929-v1:0` | `claude-sonnet-4-5@20250929` |
| Opus 4.1 | `claude-opus-4-1-20250422` | `anthropic.claude-opus-4-1-20250422-v1:0` | `claude-opus-4-1@20250422` |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Do NOT migrate**: Any Haiku models (e.g., `claude-haiku-4-5-20251001`)." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Source Model Strings to Replace" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Model String Updates" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Opus 4.5 Migration Guide" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: claude-opus-4-5-migration
description: Migrate prompts and code from Claude Sonnet 4.0, Sonnet 4.5, or Opus 4.1 to Opus 4.5. Use when the user wants to update their codebase, prompts, or API calls to use Opus 4.5. Handles model string updates and prompt adjustments for known Opus 4.5 behavioral differences. Does NOT migrate Haiku 4.5.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "One-shot migration from Sonnet 4.0/4.5 or Opus 4.1 to Opus 4.5" ;
            oc:hasStep _:ref_21ceb492e520aa67,
                _:ref_584a232088918e8c,
                _:ref_7018e240ad5e6dc7,
                [ a oc:WorkflowStep ;
                    dcterms:description "Tell the user: 'If you encounter any issues with Opus 4.5, let me know and I can help adjust your prompts.'" ;
                    oc:expectedOutcome "User knows they can get help with behavioral adjustments" ;
                    oc:stepDependsOn _:ref_7018e240ad5e6dc7 ;
                    oc:stepId "offer-support" ],
                _:ref_9a4d3d5d1f45c7c5,
                _:ref_eb324a302b1b03bc ;
            oc:workflowId "opus-4-5-migration" ;
            oc:workflowName "Opus 4.5 Migration" ],
        _:ref_d6d9ec6cfdd33e92 ;
    oc:impartsKnowledge oc:kn_00cacb7d,
        oc:kn_3d0def50,
        oc:kn_4154d27e,
        oc:kn_445adfd1,
        oc:kn_59dc7ce8,
        oc:kn_8b5c5f10,
        oc:kn_c3705875 ;
    oc:isUserInvocable true ;
    oc:nature "Procedure" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "fix opus 4.5 behavioral issues",
        "migrate prompts to opus 4.5",
        "migrate to opus 4.5",
        "update claude model strings",
        "upgrade from sonnet to opus" ;
    oc:yieldsState oc:MigrationComplete .

oc:kn_00cacb7d a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When user reports tools being called too frequently" ;
    oc:directiveContent "Opus 4.5 is more responsive to system prompts — aggressive language like 'CRITICAL:', 'You MUST', 'ALWAYS', 'NEVER', 'REQUIRED' that prevented undertriggering on previous models may now cause tool overtriggering." ;
    oc:hasRationale "Opus 4.5 has a different sensitivity profile than Sonnet/Opus predecessors" .

oc:kn_3d0def50 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When user reports unwanted files, excessive abstraction, or unrequested features" ;
    oc:directiveContent "Opus 4.5 tends to create extra files, add unnecessary abstractions, or build unrequested flexibility — apply the over-engineering prevention snippet if user reports this." ;
    oc:hasRationale "Opus 4.5's increased capability can lead to over-engineering if not constrained" .

oc:kn_4154d27e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When searching for model strings to replace" ;
    oc:directiveContent "Do NOT migrate any Haiku models (e.g., claude-haiku-4-5-20251001). This skill only handles Sonnet 4.0, Sonnet 4.5, and Opus 4.1 migrations." ;
    oc:hasRationale "Haiku models serve a different use case (speed/cost) and should not be blindly upgraded to Opus 4.5" ;
    oc:severityLevel "HIGH" .

oc:kn_445adfd1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to modify system prompts beyond model string updates" ;
    oc:directiveContent "Only apply prompt adjustments (tool overtriggering, over-engineering, code exploration, frontend design, thinking sensitivity) if the user explicitly requests them or reports a specific issue. By default, just update model strings." ;
    oc:hasRationale "Premature prompt modification may introduce unnecessary changes and break working configurations" .

oc:kn_59dc7ce8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying any prompt adjustment snippet from references/prompt-snippets.md" ;
    oc:directiveContent "When adding prompt snippets, integrate them thoughtfully into existing prompt structure using XML tags, matching existing style, and placing them in logical locations — don't just append them." ;
    oc:hasRationale "Carelessly appended snippets break prompt coherence and may cause unexpected model behavior" .

oc:kn_8b5c5f10 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When user reports issues related to thinking behavior without extended thinking enabled" ;
    oc:directiveContent "When extended thinking is not enabled (no 'thinking' parameter in the API request), Opus 4.5 is particularly sensitive to the word 'think' and its variants — replace with 'consider', 'evaluate', or 'believe'." ;
    oc:hasRationale "The word 'think' can trigger unintended extended-thinking-like behavior when the feature is not explicitly enabled" .

oc:kn_c3705875 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating API calls that contain beta headers" ;
    oc:directiveContent "Remove the context-1m-2025-08-07 beta header if present — it is not yet supported with Opus 4.5. Leave a comment noting its removal." ;
    oc:hasRationale "Using unsupported beta headers with Opus 4.5 will cause API errors" ;
    oc:severityLevel "HIGH" .

_:ref_076373d37ed03835 a oc:WorkflowStep ;
    dcterms:description "Tell the user: \"If you encounter any issues with Opus 4.5, let me know and I can help adjust your prompts.\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_369eb4115b803304 a oc:WorkflowStep ;
    dcterms:description "Search codebase for model strings and API calls" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_6f897b07a8a1d890 a oc:WorkflowStep ;
    dcterms:description "Update model strings to Opus 4.5 (see platform-specific strings below)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_abf44ce396201eee a oc:WorkflowStep ;
    dcterms:description "Add effort parameter set to `\"high\"` (see `references/effort.md`)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_aca5ec572a60e949 a oc:WorkflowStep ;
    dcterms:description "Summarize all changes made" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_b6e266b6e8e38c43 a oc:WorkflowStep ;
    dcterms:description "Remove unsupported beta headers" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_21ceb492e520aa67 a oc:WorkflowStep ;
    dcterms:description "Add effort parameter set to 'high' with beta flag effort-2025-11-24 to API calls" ;
    oc:expectedOutcome "Effort parameter configured for optimal Opus 4.5 performance" ;
    oc:stepDependsOn _:ref_9a4d3d5d1f45c7c5 ;
    oc:stepId "add-effort-parameter" .

_:ref_584a232088918e8c a oc:WorkflowStep ;
    dcterms:description "Remove unsupported beta headers (context-1m-2025-08-07) and leave a comment noting removal" ;
    oc:expectedOutcome "Unsupported headers removed with explanatory comments" ;
    oc:stepDependsOn _:ref_eb324a302b1b03bc ;
    oc:stepId "remove-unsupported-headers" .

_:ref_7018e240ad5e6dc7 a oc:WorkflowStep ;
    dcterms:description "Summarize all changes made during migration" ;
    oc:expectedOutcome "User receives a clear summary of all modifications" ;
    oc:stepDependsOn _:ref_21ceb492e520aa67,
        _:ref_584a232088918e8c,
        _:ref_9a4d3d5d1f45c7c5 ;
    oc:stepId "summarize-changes" .

_:ref_d6d9ec6cfdd33e92 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_076373d37ed03835,
        _:ref_369eb4115b803304,
        _:ref_6f897b07a8a1d890,
        _:ref_abf44ce396201eee,
        _:ref_aca5ec572a60e949,
        _:ref_b6e266b6e8e38c43 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_9a4d3d5d1f45c7c5 a oc:WorkflowStep ;
    dcterms:description "Update model strings to Opus 4.5 using platform-specific target strings from the model string tables" ;
    oc:expectedOutcome "All model strings replaced with correct Opus 4.5 equivalents" ;
    oc:stepDependsOn _:ref_eb324a302b1b03bc ;
    oc:stepId "update-model-strings" .

_:ref_eb324a302b1b03bc a oc:WorkflowStep ;
    dcterms:description "Search codebase for model strings and API calls referencing Sonnet 4.0, Sonnet 4.5, or Opus 4.1" ;
    oc:expectedOutcome "All files containing model strings are identified" ;
    oc:stepId "search-codebase" .

