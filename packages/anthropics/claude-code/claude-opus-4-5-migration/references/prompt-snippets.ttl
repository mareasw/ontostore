@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_claude_opus_4_5_migration_prompt_snippets a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "prompt-snippets" ;
    skos:broader "Migration aid" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/claude-opus-4-5-migration" ;
    oc:contentHash "a6995d7c3588bb55da02eac0aaf438d6f75a0f8203c16c0f621fea384e2ffa51" ;
    oc:dependsOnSkill oc:skill_claude_opus_4_5_migration ;
    oc:differentia "that provides targeted prompt adjustments to address Opus 4.5-specific behavioral issues like overtriggering, over-engineering, and design quality" ;
    oc:extends oc:skill_anthropics_claude_code_claude_opus_4_5_migration ;
    oc:handlesFailure oc:InvalidSnippetRequest,
        oc:UnrelatedIssueReported ;
    oc:hasArgumentHint "specific issue reported (e.g., \"overtriggering\", \"over-engineering\", \"code exploration\", \"frontend design\", \"thinking sensitivity\")" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_36ce03fc,
        oc:kn_44720ad1,
        oc:kn_855ae2c8,
        oc:kn_ed51c43f,
        oc:kn_f6a498fa ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:OpusMigrationInProgress ;
    oc:resolvesIntent "apply targeted prompt snippets for opus 4.5 migration",
        "enhance opus 4.5 frontend design quality",
        "fix opus 4.5 thinking sensitivity when extended thinking is disabled",
        "fix opus 4.5 tool overtriggering",
        "improve opus 4.5 code exploration rigor",
        "prevent opus 4.5 over-engineering" ;
    oc:yieldsState oc:PromptSnippetsApplied .

oc:kn_36ce03fc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user reports issues related to 'thinking' while extended thinking is not enabled" ;
    oc:directiveContent "When extended thinking is not enabled (no thinking parameter in API request), replace 'think' and variants with alternatives like 'consider', 'evaluate', 'believe', or 'reasoning' to avoid unintended model behavior." ;
    oc:hasRationale "Opus 4.5 is particularly sensitive to the word 'think' and its variants when extended thinking is disabled, potentially causing degraded output quality." ;
    oc:severityLevel "HIGH" .

oc:kn_44720ad1 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing prompt snippet integration during Opus 4.5 migration" ;
    oc:directiveContent "After migration, list all model string updates and prompt modifications made so the user can review the full scope of changes." ;
    oc:hasRationale "Providing a summary of all changes ensures transparency and allows the user to verify no unintended modifications were introduced." ;
    oc:severityLevel "MEDIUM" .

oc:kn_855ae2c8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user reports tools being called too frequently or unnecessarily during Opus 4.5 migration" ;
    oc:directiveContent "Replace aggressive trigger language (CRITICAL, MUST, ALWAYS, NEVER, REQUIRED) with normal phrasing (use when, should, don't) to prevent Opus 4.5 tool overtriggering." ;
    oc:hasRationale "Opus 4.5 is more responsive to instruction strength than prior models; aggressive language designed to overcome undertriggering on older models now causes overtriggering." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ed51c43f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When integrating any prompt snippet into the migrated prompt" ;
    oc:directiveContent "Do not append snippets blindly to prompts. Weave them into the existing prompt structure using XML tags that match or complement the existing structure, and place them logically near related content." ;
    oc:hasRationale "Blindly appended snippets can conflict with existing instructions or be ignored due to poor structural placement." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f6a498fa a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, before applying any prompt snippet during Opus 4.5 migration" ;
    oc:directiveContent "Only apply these prompt snippets if the user explicitly requests them or reports a specific issue. By default, the migration should only update model strings." ;
    oc:hasRationale "Applying snippets unconditionally introduces unnecessary prompt changes and may alter behavior that was working correctly." ;
    oc:severityLevel "HIGH" .

