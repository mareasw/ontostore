            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "**Add effort set to `\"high\"` during migration.** This is the default configuration for best performance with Opus 4.5." ] ;
