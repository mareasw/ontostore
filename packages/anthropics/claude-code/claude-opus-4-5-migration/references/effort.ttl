oc:skill_anthropics_claude_code_claude_opus_4_5_migration_effort a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "effort" ;
    skos:broader "configuration parameter" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/claude-opus-4-5-migration" ;
    oc:contentHash "1d10254a2089682bedc2dcc68243221f9b67f852fdf8e8992fa3eb1f731763ca" ;
    oc:differentia "that controls how eagerly Claude spends tokens across thinking, text responses, and function calls during API interactions" ;
    oc:extends oc:skill_anthropics_claude_code_claude_opus_4_5_migration ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "effort level: high | medium | low" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_3136c4b0,
        oc:kn_628da317,
        oc:kn_85efe0c5,
        oc:kn_9e3d2b6f,
        oc:kn_e86a6d16 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "configure effort parameter for Opus 4.5 migration",
        "optimize token usage vs performance tradeoff",
        "set effort level in API calls" ;
    oc:yieldsState oc:EffortConfigured .

oc:kn_3136c4b0 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When reasoning about the impact of effort changes on API costs" ;
    oc:directiveContent "Effort affects ALL tokens: thinking tokens, text response tokens, and function call tokens. It is not limited to a single token category." ;
    oc:hasRationale "Understanding that effort is a holistic parameter prevents miscalculations when estimating token usage and costs." ;
    oc:severityLevel "MEDIUM" .

oc:kn_628da317 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating to Opus 4.5" ;
    oc:directiveContent "Set effort to 'high' as the default for Opus 4.5 migration to ensure best performance and deep reasoning." ;
    oc:hasRationale "High effort is the recommended default for migration scenarios to avoid regressions in reasoning quality." ;
    oc:severityLevel "HIGH" .

oc:kn_85efe0c5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing for cost and latency" ;
    oc:directiveContent "Use 'low' effort only for simple, high-volume queries where token savings matter more than depth of reasoning." ;
    oc:hasRationale "Low effort provides significant token savings but at the cost of reduced reasoning depth, making it unsuitable for complex tasks." ;
    oc:severityLevel "LOW" .

oc:kn_9e3d2b6f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing effort configuration in any SDK or raw API call" ;
    oc:directiveContent "The effort parameter requires the beta flag 'effort-2025-11-24' in API calls. Without this flag, the parameter will be ignored or cause an error." ;
    oc:hasRationale "Effort is a beta feature and the beta flag is mandatory for activation." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e86a6d16 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring Opus 4.5 API calls" ;
    oc:directiveContent "First determine the effort level, then set thinking budget. Effort and thinking budget are independent parameters." ;
    oc:hasRationale "Effort controls overall token eagerness while thinking budget caps reasoning tokens. Setting them in the wrong order can lead to suboptimal configurations." ;
    oc:severityLevel "MEDIUM" .

