                            oc:blockType "code_block" ;
                            oc:codeContent """{
  "model": "claude-opus-4-5-20251101",
  "max_tokens": 1024,
  "anthropic-beta": "effort-2025-11-24",
  "output_config": {
    "effort": "high"
  },
  "messages": [...]
}
""" ;
                            oc:codeLanguage "json" ;
