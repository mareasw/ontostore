oc:kn_4a5056e6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring both effort and thinking parameters" ;
    oc:directiveContent "Effort is independent of thinking budget. They are orthogonal controls: effort controls token eagerness, thinking budget caps extended thinking tokens." ;
    oc:hasRationale "Developers may mistakenly assume effort subsumes or replaces thinking budget — they serve different purposes and compose freely." .

oc:kn_8ca9e8fc a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using the effort parameter" ;
    oc:directiveContent "Requires API call with model `claude-opus-4-5-20251101` and beta flag `effort-2025-11-24`." .

oc:kn_8d015d30 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing effort in any API call (Python, TypeScript, or raw HTTP)" ;
    oc:directiveContent "The effort parameter requires the beta flag `effort-2025-11-24` in API calls. Without it, the parameter is ignored." ;
    oc:hasRationale "Effort is a beta feature and will not activate without the correct beta header." ;
    oc:severityLevel "CRITICAL" .

oc:kn_96c2a633 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating prompts or code to Claude Opus 4.5" ;
    oc:directiveContent "Set effort to \"high\" as the default during Opus 4.5 migration for best performance with deep reasoning." ;
    oc:hasRationale "High effort ensures the model spends tokens eagerly for thorough, high-quality responses during migration." ;
    oc:severityLevel "HIGH" ;
    oc:stepOrder 1 .

oc:kn_a8d13a07 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning API call configuration" ;
    oc:directiveContent "First determine effort level, then set thinking budget. Recommended combos: high effort + high thinking for best performance; medium effort for cost/latency balance; low effort for simple high-volume queries." ;
    oc:hasRationale "Ordering configuration decisions prevents conflicting settings and aligns effort with use case." .

_:ref_00977a2fa1a55fb0 a oc:WorkflowStep ;
    dcterms:description "Best performance: high effort + high thinking budget" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

