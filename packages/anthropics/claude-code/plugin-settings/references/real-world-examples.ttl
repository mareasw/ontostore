    oc:appliesToContext "When writing to or reading from plugin settings files" ;
    oc:directiveContent "Never use hardcoded absolute paths or non-atomic sed -i for settings files. Always use relative paths (.claude/plugin.local.md) and temp-file-plus-mv." ;
    oc:hasRationale "Absolute paths break portability; sed -i can corrupt on interruption" ;
    oc:severityLevel "HIGH" .

oc:kn_4ac631f1 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing any hook that reads plugin settings" ;
    oc:directiveContent "1. Check file exists (quick exit if not) → 2. Parse frontmatter with sed → 3. Check enabled flag → 4. Extract needed fields → 5. Perform action → 6. Update state atomically if needed" ;
    oc:hasRationale "Consistent structure across all plugins reduces bugs and improves maintainability" ;
    oc:stepOrder 1 .

oc:kn_5a40f7a3 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When initializing a new plugin settings file from a script" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "Create settings file with cat > \"$FILE\" <<EOF\\n---\\nkey: $VALUE\\n---\\n\\nBody content\\nEOF" ;
    oc:hasRationale "Heredoc with variable interpolation generates complete frontmatter+body files in one atomic write" ;
    oc:severityLevel "MEDIUM" .

oc:kn_689a2f4a a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parsing YAML frontmatter from .claude/*.local.md in bash" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "Parse frontmatter with: FRONTMATTER=$(sed -n '/^---$/,/^---$/{ /^---$/d; p; }' \"$FILE\"). Strip YAML quotes with: sed 's/^\"\\(.*\\)\"$/\\1/'. Extract body with: awk '/^---$/{i++; next} i>=2'." ;
    oc:hasRationale "YAML allows both quoted and unquoted values; this normalizes them" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6b66fa6c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When designing any plugin settings schema" ;
    oc:directiveContent "Include an `enabled: true` frontmatter field in every settings file and check it before acting." ;
    oc:hasRationale "Allows temporary deactivation without deleting the file or losing configuration" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b5b4d917 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any hook or script reads a .claude/*.local.md file" ;
    oc:directiveContent "Always check if the settings file exists before parsing: if [[ ! -f \"$STATE_FILE\" ]]; then exit 0; fi. This is the quick-exit pattern." ;
    oc:hasRationale "Avoids errors when plugin isn't configured and keeps hook overhead near zero" ;
    oc:severityLevel "CRITICAL" ;
    oc:stepOrder 1 .

