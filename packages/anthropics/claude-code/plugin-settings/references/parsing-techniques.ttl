oc:kn_03347108 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Atomically updating a field in a settings file" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """TEMP_FILE="${FILE}.tmp.$$"
sed "s/^field_name: .*/field_name: $NEW_VALUE/" "$FILE" > "$TEMP_FILE"
mv "$TEMP_FILE" "$FILE\"""" .

oc:kn_1ab559f7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before parsing any settings file" ;
    oc:directiveContent "Verify settings file exists (-f) and is readable (-r) before attempting to parse; count --- markers to validate frontmatter structure (must be >= 2)" ;
    oc:hasRationale "Missing or malformed files cause silent parsing failures that are hard to debug downstream" .

oc:kn_2609df5d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Extracting markdown body content after frontmatter" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "BODY=$(awk '/^---$/{i++; next} i>=2' \"$FILE\")" .

oc:kn_475e8787 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When parsing string fields from frontmatter" ;
    oc:directiveContent "YAML frontmatter allows both quoted and unquoted string values — always strip surrounding quotes (double and single) after extraction" ;
    oc:hasRationale "Inconsistent quoting causes subtle bugs when comparing values or constructing JSON" ;
    oc:severityLevel "HIGH" .

oc:kn_9aafa53c a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Extracting a single string field from frontmatter with a default value" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """FRONTMATTER=$(sed -n '/^---$/,/^---$/{ /^---$/d; p; }' "$FILE")
VALUE=$(echo "$FRONTMATTER" | grep '^field:' | sed 's/field: *//' | sed 's/^"\\(.*\\)"$/\\1/')
VALUE=${VALUE:-default_value}""" .

oc:kn_a0e1f8c5 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When loading plugin settings at startup" ;
    oc:directiveContent "1. Check if settings file exists → 2. Extract frontmatter with sed range → 3. Parse fields with grep+sed (strip quotes) → 4. Apply defaults for missing values → 5. Validate values → 6. Use config in logic" ;
    oc:hasRationale "This order ensures graceful degradation: defaults work when no file exists, and validation catches corruption before it affects behavior" ;
    oc:stepOrder 1 .

oc:kn_bdfb7d21 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading more than one field from a settings file" ;
    oc:directiveContent "Parse frontmatter once and cache it, then extract multiple fields from the cached string rather than re-reading the file for each field" ;
    oc:hasRationale "File I/O is expensive; caching the frontmatter string avoids redundant disk reads and sed invocations" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c37dc22c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a parsing approach for frontmatter fields" ;
    oc:directiveContent "Use sed/grep for simple field extraction; use yq for complex YAML structures (nested objects, lists, multi-line values)" ;
    oc:hasRationale "sed/grep have zero dependencies and handle 80% of cases; yq handles edge cases but requires installation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e25fae96 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating any .claude/*.local.md settings file" ;
    oc:directiveContent "Always use temp file + atomic mv to update settings files, never write directly to the file in place" ;
    oc:hasRationale "Direct writes can corrupt the file if the process is interrupted mid-write; atomic mv is an all-or-nothing operation" ;
    oc:severityLevel "CRITICAL" .

oc:kn_f9eea7c5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building JSON output from parsed settings values" ;
    oc:directiveContent "Use jq -n --arg for constructing JSON with user-provided content; never interpolate shell variables directly into JSON strings" ;
    oc:hasRationale "Direct interpolation breaks on special characters (quotes, backslashes, newlines) and creates injection vulnerabilities" ;
    oc:severityLevel "CRITICAL" .

