                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """# Update several fields at once
TEMP_FILE="${FILE}.tmp.$$"

sed -e "s/^iteration: .*/iteration: $NEXT_ITERATION/" \\
    -e "s/^pr_number: .*/pr_number: $PR_NUMBER/" \\
    -e "s/^status: .*/status: $NEW_STATUS/" \\
    "$FILE" > "$TEMP_FILE"

mv "$TEMP_FILE" "$FILE"
""" ;
