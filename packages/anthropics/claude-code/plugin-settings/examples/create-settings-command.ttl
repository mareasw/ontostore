    oc:impartsKnowledge oc:kn_0f02523b,
        oc:kn_2d714c90,
        oc:kn_ba0752b4,
        oc:kn_e0a94e1a,
        oc:kn_e14fc463 ;
    oc:isUserInvocable true ;
    oc:nature "Command" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "configure plugin preferences",
        "create plugin settings",
        "set up plugin validation mode" ;
    oc:yieldsState oc:SettingsFileCreated .

oc:kn_0f02523b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating plugin settings file" ;
    oc:directiveContent "1. Use AskUserQuestion to gather enabled (Yes/No) and validation mode (Strict/Standard/Lenient) preferences. 2. Parse answers — answers[\"0\"] = enabled, answers[\"1\"] = mode. 3. Validate inputs. 4. Use Write tool to create .claude/my-plugin.local.md with frontmatter (enabled, validation_mode, max_file_size, notify_on_errors) and summary body. 5. Inform user of location, config summary, how to edit manually, restart requirement, and that file is gitignored." ;
    oc:hasRationale "Structured wizard ensures consistent, valid configuration files are created every time." ;
    oc:stepOrder 1 .

oc:kn_2d714c90 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After successfully writing .claude/my-plugin.local.md" ;
    oc:directiveContent "After creating the settings file, inform the user: file location, current configuration summary, how to edit manually, reminder to restart Claude Code, and that the file is gitignored." ;
    oc:hasRationale "User must restart Claude Code for settings to take effect; awareness of manual editing and gitignore status prevents confusion." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ba0752b4 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When writing the settings file" ;
    oc:directiveContent """---
enabled: <true|false>
validation_mode: <strict|standard|lenient>
max_file_size: 1000000
notify_on_errors: true
---

# Plugin Configuration

Your plugin is configured with <mode> validation mode.

To modify settings, edit this file and restart Claude Code.""" ;
    oc:templateVariables "enabled",
        "max_file_size",
        "notify_on_errors",
        "validation_mode" .

oc:kn_e0a94e1a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing the output file path" ;
    oc:directiveContent "The settings file must be written to .claude/my-plugin.local.md — this path is gitignored and local to the project." ;
    oc:hasRationale "Using .local.md suffix ensures the file is excluded from version control, keeping user-specific preferences private." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e14fc463 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before writing .claude/my-plugin.local.md" ;
    oc:directiveContent "Always validate user input before writing the settings file: check mode is valid, validate numeric fields are numbers, ensure paths don't have traversal attempts, and sanitize any free-text fields." ;
    oc:hasRationale "Input validation prevents malformed config files and security vulnerabilities like path traversal." ;
    oc:severityLevel "HIGH" .

oc:req_883dcb03 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Write" .

oc:req_debc444e a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "AskUserQuestion" .

