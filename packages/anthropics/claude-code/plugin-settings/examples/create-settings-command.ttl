@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_plugin_settings_create_settings_command a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "create-settings-command" ;
    skos:broader "configuration command" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/plugin-settings" ;
    oc:contentHash "abf0a36bb3f6425041046f2da1ebfac5505c5b37656fdd4772cfc4d8bd2fa655" ;
    oc:differentia "creates a plugin settings file with user preferences via interactive prompts" ;
    oc:extends oc:skill_anthropics_claude_code_plugin_settings ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasAllowedTool "AskUserQuestion",
        "Write" ;
    oc:hasArgumentHint "none (interactive prompts)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_413b071a,
        oc:kn_aa62fe86,
        oc:kn_be64a0c5,
        oc:kn_c0951a3c ;
    oc:isUserInvocable true ;
    oc:nature "command" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "configure plugin preferences",
        "create plugin settings",
        "set up plugin settings file" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_413b071a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before writing the settings file in Step 3" ;
    oc:directiveContent "Always validate user input before writing the settings file: check mode is valid (strict/standard/lenient), validate numeric fields are numbers, ensure paths don't have traversal attempts, and sanitize free-text fields." ;
    oc:hasRationale "Prevents malformed configuration files and security vulnerabilities such as path traversal attacks" ;
    oc:severityLevel "CRITICAL" .

oc:kn_aa62fe86 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When executing Step 3 (Write tool)" ;
    oc:directiveContent "Creates a file at .claude/my-plugin.local.md that persists plugin configuration on disk. This file is gitignored and will not be committed to version control." ;
    oc:hasRationale "Users must understand the file is local-only and won't be shared with collaborators via git" ;
    oc:severityLevel "MEDIUM" .

oc:kn_be64a0c5 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After successful file creation in Step 4" ;
    oc:directiveContent "After creating the settings file, inform the user of the file location, current configuration summary, how to edit manually, and remind them to restart Claude Code for changes to take effect." ;
    oc:hasRationale "Users need clear feedback about what was created and the requirement to restart for settings to activate" ;
    oc:severityLevel "HIGH" .

oc:kn_c0951a3c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When gathering user preferences in Step 1" ;
    oc:directiveContent "Use interactive AskUserQuestion prompts with structured options rather than free-text input for boolean and enum-style settings." ;
    oc:hasRationale "Structured options reduce input errors and make the configuration process more intuitive" ;
    oc:severityLevel "MEDIUM" .

