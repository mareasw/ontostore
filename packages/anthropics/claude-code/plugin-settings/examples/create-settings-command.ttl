    oc:contentHash "abf0a36bb3f6425041046f2da1ebfac5505c5b37656fdd4772cfc4d8bd2fa655" ;
    oc:differentia "that interactively gathers user preferences and writes them to a local settings file for a Claude Code plugin" ;
