oc:kn_08e3a1ca a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "At the start of any hook that reads plugin settings" ;
    oc:directiveContent "Check if settings file exists before reading it: if [[ ! -f \".claude/my-plugin.local.md\" ]]; then exit 0; fi" ;
    oc:hasRationale "Graceful degradation - unconfigured plugins should silently skip rather than error" .

oc:kn_1df02b75 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any plugin settings file schema" ;
    oc:directiveContent "Use frontmatter for machine-parseable key-value settings and markdown body for human-readable documentation and instructions" ;
    oc:hasRationale "Separation of concerns keeps configuration parseable by hooks while remaining self-documenting for humans" .

oc:kn_28caec73 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any plugin settings file - use YAML frontmatter between --- delimiters" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
enabled: true
key: value
---
# Title
Content body""" ;
    oc:hasRationale "Frontmatter provides machine-readable settings that hooks can parse, while markdown body provides human-readable documentation" .

oc:kn_4ebe3ac0 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "After editing any .claude/*.local.md file" ;
    oc:directiveContent "Changes to settings files require Claude Code restart - hooks cannot be hot-swapped" ;
    oc:hasRationale "Hooks read settings at startup; in-process hooks retain stale configuration until restart" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8033f457 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading plugin settings from hook scripts" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """FRONTMATTER=$(sed -n '/^---$/,/^---$/{ /^---$/d; p; }' ".claude/my-plugin.local.md")
ENABLED=$(echo "$FRONTMATTER" | grep '^enabled:' | sed 's/enabled: *//')""" ;
    oc:hasRationale "Bash-based YAML parsing extracts frontmatter values without requiring external dependencies" .

oc:kn_a05cd273 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any plugin settings file" ;
    oc:directiveContent "Always add .claude/*.local.md and .claude/*.local.json to .gitignore - settings files are user-local and must not be committed" ;
    oc:hasRationale "Local settings contain user-specific configurations that should not leak into the shared repository" ;
    oc:severityLevel "HIGH" .

