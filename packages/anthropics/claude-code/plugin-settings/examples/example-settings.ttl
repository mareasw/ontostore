@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_code_plugin_settings_example_settings a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "example-settings" ;
    skos:broader "Configuration templates" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-code/plugin-settings" ;
    oc:contentHash "f07209b6e2fb62d443ae07d01bc1674c6c741c352a04549bfa978e1f34b9769e" ;
    oc:differentia "provides example YAML frontmatter patterns for plugin settings, agent state files, and feature flags in .claude/*.local.md files" ;
    oc:extends oc:skill_anthropics_claude_code_plugin_settings ;
    oc:handlesFailure oc:FileNotFound,
        oc:PermissionDenied ;
    oc:hasArgumentHint "template-type (basic|advanced|agent-state|feature-flag)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_0e994ca6,
        oc:kn_21abdf97,
        oc:kn_91dffa83,
        oc:kn_db360782,
        oc:kn_fc2e6c12 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:DirectoryWritable ;
    oc:resolvesIntent "configure plugin settings",
        "create local settings file",
        "define feature flags for plugins",
        "set up agent state configuration" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0e994ca6 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When initializing a plugin for a project" ;
    oc:directiveContent "Always add '.claude/*.local.md' and '.claude/*.local.json' to the project .gitignore." ;
    oc:hasRationale "Prevents accidental commits of user-local configuration files." ;
    oc:severityLevel "HIGH" .

oc:kn_21abdf97 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or reading any plugin settings file" ;
    oc:directiveContent "Plugin settings use YAML frontmatter in .claude/*.local.md files with an 'enabled' key as the primary toggle." ;
    oc:hasRationale "Consistent frontmatter format allows hooks to reliably parse settings with sed/grep without requiring a YAML parser." ;
    oc:severityLevel "HIGH" .

oc:kn_91dffa83 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "After editing any .claude/*.local.md settings file" ;
    oc:directiveContent "Settings changes require a Claude Code restart to take effect — hooks cannot be hot-swapped." ;
    oc:hasRationale "Hooks read settings at startup; modifying files mid-session has no effect until restart, which can confuse users." ;
    oc:severityLevel "CRITICAL" .

oc:kn_db360782 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up or distributing plugin configurations" ;
    oc:directiveContent "Never commit .claude/*.local.md or .claude/*.local.json files to version control." ;
    oc:hasRationale "Local settings are user-specific and machine-specific; committing them leaks local paths, preferences, and potentially secrets." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fc2e6c12 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a hook checks for plugin configuration that may not exist" ;
    oc:directiveContent "If a hook finds no settings file, it should exit cleanly (exit 0) rather than error." ;
    oc:hasRationale "Settings files are optional; plugins should gracefully degrade when not configured rather than blocking workflows." .

