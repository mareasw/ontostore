oc:kn_2609df5d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting markdown body after frontmatter" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "BODY=$(awk '/^---$/{i++; next} i>=2' \"$FILE\")" .

oc:kn_2c6c1656 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When reading multiple settings fields" ;
    oc:directiveContent "Parse frontmatter once and cache it, then extract multiple fields from the cached value — don't re-read the file for each field." ;
    oc:hasRationale "Reduces file I/O and subprocess overhead in hook scripts" ;
    oc:severityLevel "LOW" .

oc:kn_31d3bd2d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After editing any .local.md settings file" ;
    oc:directiveContent "Settings changes require Claude Code restart — hooks cannot be hot-swapped within a session" ;
    oc:hasRationale "Hooks are loaded at session start; changes mid-session won't take effect" ;
    oc:severityLevel "HIGH" .

oc:kn_3c107b95 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any plugin settings file" ;
    oc:directiveContent "Settings files MUST use .claude/plugin-name.local.md naming and be added to .gitignore as .claude/*.local.md" ;
    oc:hasRationale "The .local.md suffix prevents accidental git commits of user-specific configuration" ;
    oc:severityLevel "CRITICAL" .

oc:kn_42589761 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing plugin configuration" ;
    oc:directiveContent "Store per-project plugin settings in .claude/plugin-name.local.md using YAML frontmatter for structured config and markdown body for prompts or context." ;
    oc:hasRationale "Provides human-readable, gitignored, per-project settings accessible from hooks, commands, and agents" ;
    oc:severityLevel "HIGH" .

oc:kn_4579ddae a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Quick-exit pattern for hooks checking settings" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """if [[ ! -f "$STATE_FILE" ]]; then
  exit 0  # Not configured
fi""" .

oc:kn_46149e9f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "In hook scripts reading settings" ;
    oc:directiveContent "Always use the quick-exit pattern: check if settings file exists first, then check enabled field, before any heavy processing." ;
    oc:hasRationale "Avoids errors and unnecessary I/O when plugin is not configured or disabled" ;
    oc:severityLevel "MEDIUM" .

oc:kn_63717663 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating settings file structure" ;
    oc:directiveContent "bash scripts/validate-settings.sh .claude/plugin-name.local.md" .

oc:kn_85ab7e24 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When creating settings from user input" ;
    oc:directiveContent "Sanitize user input when writing to settings files — escape quotes and validate file paths for traversal attacks." ;
    oc:hasRationale "Unsanitized input in YAML frontmatter or paths can lead to injection or unauthorized file access" ;
    oc:severityLevel "HIGH" .

oc:kn_a6f5babd a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When adding settings to a plugin" ;
    oc:directiveContent "1. Design settings schema (fields, types, defaults) 2. Create template file in plugin docs 3. Add .gitignore entry for .claude/*.local.md 4. Implement parsing in hooks/commands 5. Use quick-exit pattern 6. Document settings in plugin README 7. Remind users restart is required" ;
    oc:stepOrder 1 .

oc:kn_acac6701 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting frontmatter fields from command line" ;
    oc:directiveContent "bash scripts/parse-frontmatter.sh .claude/plugin-name.local.md [field-name]" .

oc:kn_b0815248 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating any settings file programmatically" ;
    oc:directiveContent "Never use non-atomic file updates (e.g., sed -i). Always use temp file + mv for settings file writes." ;
    oc:hasRationale "Non-atomic writes can corrupt the file if the process is interrupted mid-write" ;
    oc:severityLevel "HIGH" .

oc:kn_cb8f204e a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Project must have a .claude/ directory in the project root for settings files" .

oc:kn_dacaab72 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parsing YAML frontmatter from .local.md files" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """FRONTMATTER=$(sed -n '/^---$/,/^---$/{ /^---$/d; p; }' "$FILE")
VALUE=$(echo "$FRONTMATTER" | grep '^field:' | sed 's/field: *//' | sed 's/^"\\(.*\\)"$/\\1/')""" .

oc:kn_dc08cd86 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Template for creating .claude/plugin-name.local.md files" ;
    oc:directiveContent """---
enabled: {boolean}
{setting_key}: {setting_value}
---

# {Plugin Name} Configuration

{description_or_instructions}""" ;
    oc:templateVariables "Plugin Name",
        "boolean",
        "description_or_instructions",
        "setting_key",
        "setting_value" .

oc:kn_eda4549c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading plugin settings in hooks or commands" ;
    oc:directiveContent "Provide sensible defaults when settings file doesn't exist — never assume the file will always be present." ;
    oc:hasRationale "Plugins should degrade gracefully when not configured rather than failing" ;
    oc:severityLevel "MEDIUM" .

