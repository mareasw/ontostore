    oc:differentia "documents the four MCP server transport types (stdio, SSE, HTTP, WebSocket) with configuration, lifecycle, and selection criteria for Claude Code plugins" ;
    oc:extends oc:skill_claude_code_mcp_integration ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Complete reference for all MCP server types supported in Claude Code plugins." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 8 ;
                            oc:tableCaption "## Comparison Matrix" ;
                            oc:tableMarkdown """| Feature | stdio | SSE | HTTP | WebSocket |
|---------|-------|-----|------|-----------|
| **Transport** | Process | HTTP/SSE | HTTP | WebSocket |
| **Direction** | Bidirectional | Server→Client | Request/Response | Bidirectional |
| **State** | Stateful | Stateful | Stateless | Stateful |
| **Auth** | Env vars | OAuth/Headers | Headers | Headers |
| **Use Case** | Local tools | Cloud services | REST APIs | Real-time |
| **Latency** | Lowest | Medium | Medium | Low |
| **Setup** | Easy | Medium | Easy | Medium |
| **Reconnect** | Process respawn | Automatic | N/A | Automatic |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 32 ;
