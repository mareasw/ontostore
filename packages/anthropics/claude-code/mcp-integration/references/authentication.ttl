oc:kn_11d22834 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building an MCP plugin with authentication" ;
    oc:directiveContent "1. Prefer OAuth when service supports it → 2. Use env vars for tokens (${VAR_NAME}) → 3. Document all required vars in README → 4. Provide setup instructions with examples → 5. Never commit credentials → 6. Use HTTPS/WSS only → 7. Test authentication thoroughly" ;
    oc:stepOrder 1 .

oc:kn_470dd808 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any MCP server with token-based auth" ;
    oc:directiveContent "Never hardcode tokens directly in MCP configuration JSON. Always use environment variable substitution syntax like ${API_TOKEN}." ;
    oc:hasRationale "Hardcoded tokens get committed to git, leaked in logs, and cannot be rotated without code changes" ;
    oc:severityLevel "CRITICAL" .

oc:kn_796a887d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when handling credentials" ;
    oc:directiveContent "Do not commit .env files to git. Do not share tokens in documentation. Do not log tokens or sensitive headers." ;
    oc:hasRationale "Credential leakage through version control, docs, or logs is the most common vector for unauthorized access" ;
    oc:severityLevel "CRITICAL" .

oc:kn_8fbd66ed a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When configuring any MCP server URL" ;
    oc:directiveContent "Use HTTPS/WSS for all MCP server connections. Never use plain HTTP. Tokens stored by Claude Code OAuth are encrypted at rest and inaccessible to plugins." ;
    oc:hasRationale "Plain HTTP exposes tokens in transit and makes the entire authentication mechanism worthless" ;
    oc:severityLevel "CRITICAL" .

oc:kn_baa6b503 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building MCP plugin configurations" ;
    oc:directiveContent "Always document required environment variables, token permissions, and setup steps in the plugin README with copy-paste examples." ;
    oc:hasRationale "Users need clear setup instructions to configure authentication without trial-and-error" .

oc:kn_d40510e7 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When troubleshooting authentication failures" ;
    oc:directiveContent "401 errors may stem from expired tokens, incorrect header format (missing 'Bearer' prefix), or unset environment variables. 403 errors indicate valid tokens lacking required permissions." ;
    oc:hasRationale "Distinguishing between 401 and 403 narrows debugging from 'auth is broken' to a specific root cause" ;
    oc:severityLevel "HIGH" .

oc:kn_f9aef259 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing an authentication method for a new MCP server" ;
    oc:directiveContent "Prefer OAuth for cloud services (automatic handling), bearer tokens for API services, environment variables for stdio servers, and dynamic headers for complex auth flows." ;
    oc:hasRationale "Each method maps to the server type's natural authentication mechanism, minimizing user friction and maximizing security" .

