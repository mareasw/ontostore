oc:kn_4e8b5c39 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When referencing MCP tools in commands or agents" ;
    oc:directiveContent "MCP tool names follow the format mcp__plugin_<plugin-name>_<server-name>__<tool-name>. Tool names are case-sensitive and must match exactly when pre-allowed in command frontmatter." ;
    oc:hasRationale "Incorrect tool names cause silent failures where tools appear unavailable" ;
    oc:severityLevel "HIGH" .

oc:kn_58f16b52 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "After modifying .mcp.json or plugin.json MCP configuration" ;
    oc:directiveContent "MCP servers require Claude Code restart to pick up configuration changes. Tools discovered and registered only at startup." ;
    oc:hasRationale "Configuration is parsed at plugin load time, not dynamically" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6088470a a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When optimizing MCP tool call performance" ;
    oc:directiveContent "MCP servers connect on-demand (lazy loading), not at startup. First tool use triggers the connection. Batch queries with filters instead of making many individual calls." ;
    oc:hasRationale "Batching reduces round-trips and rate limit hits; lazy loading avoids unnecessary connections" ;
    oc:severityLevel "LOW" .

oc:kn_70c3018e a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When MCP tools are not available or connection fails" ;
    oc:directiveContent "When MCP server connection fails: check URL correctness, verify server is running (stdio), check network connectivity, review auth configuration, and use claude --debug for connection logs. Restart Claude Code after config changes." ;
    oc:hasRationale "Most MCP issues stem from configuration errors, auth problems, or stale connections that restart resolves" ;
    oc:severityLevel "MEDIUM" .

oc:kn_710a2f74 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When designing commands vs agents that use MCP tools" ;
    oc:directiveContent "Agents can use MCP tools autonomously without pre-allowing. Commands require explicit allowed-tools. This means agents have broader tool access by design." ;
    oc:hasRationale "Agent autonomy requires flexible tool access, but commands need strict permission scoping for safety" ;
    oc:severityLevel "MEDIUM" .

oc:kn_82f71989 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When configuring SSE, HTTP, or WebSocket MCP servers" ;
    oc:directiveContent "Always use HTTPS/WSS for network MCP server connections. Never use plain HTTP or WS." ;
    oc:hasRationale "Unencrypted connections expose authentication tokens and data to interception" ;
    oc:severityLevel "HIGH" .

oc:kn_a05ef833 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring allowed-tools in command frontmatter" ;
    oc:directiveContent "Pre-allow specific MCP tools in command frontmatter rather than using wildcards. Use wildcards only when a command truly needs all tools from a server." ;
    oc:hasRationale "Specific tool permissions reduce the attack surface and prevent unintended tool access" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c4130068 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any MCP server configuration (.mcp.json or plugin.json)" ;
    oc:directiveContent "Never hardcode tokens, credentials, or absolute paths in MCP configuration files. Always use ${VAR} environment variable syntax for tokens and ${CLAUDE_PLUGIN_ROOT} for file paths." ;
    oc:hasRationale "Hardcoded credentials leak via git commits and absolute paths break portability across environments" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d3522415 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting MCP server type" ;
    oc:directiveContent "Choose stdio for local/custom servers, SSE for hosted cloud services with OAuth, HTTP for REST APIs with token auth, WebSocket for real-time bidirectional communication." ;
    oc:hasRationale "Each transport type is optimized for specific communication patterns and auth mechanisms" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ddab9471 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing MCP configuration method for a plugin" ;
    oc:directiveContent "Use .mcp.json as a dedicated configuration file (recommended) for clarity and separation of concerns. Use inline mcpServers in plugin.json only for simple single-server plugins." ;
    oc:hasRationale "Separate .mcp.json is easier to maintain, especially with multiple servers" ;
    oc:severityLevel "MEDIUM" .

