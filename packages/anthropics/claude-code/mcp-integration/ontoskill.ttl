oc:skill_claude_code_mcp_integration a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "mcp-integration" ;
    skos:broader "Integration guide" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/claude-code/mcp-integration" ;
    oc:contentHash "31043c6c231724469bb19a373d3cf04e1145f79eadd08c3dada5c0d7bd342809" ;
    oc:dependsOnSkill oc:skill_ontoskills_build_mcp_server,
        oc:skill_ontoskills_plugin_structure ;
    oc:differentia "that configures Model Context Protocol servers into Claude Code plugins for external tool and service access" ;
    oc:handlesFailure oc:AuthenticationFailed,
        oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "MCP server configuration or integration request" ;
    oc:hasCategory "development" ;
    oc:hasDescription "This skill should be used when the user asks to \"add MCP server\", \"integrate MCP\", \"configure MCP in plugin\", \"use .mcp.json\", \"set up Model Context Protocol\", \"connect external service\", mentions \"${CLAUDE_PLUGIN_ROOT} with MCP\", or discusses MCP server types (SSE, stdio, HTTP, WebSocket). Provides comprehensive guidance for integrating Model Context Protocol servers into Claude Code plugins for external tool and service integration." ;
    oc:hasName "mcp-integration" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: MCP Integration
description: This skill should be used when the user asks to "add MCP server", "integrate MCP", "configure MCP in plugin", "use .mcp.json", "set up Model Context Protocol", "connect external service", mentions "${CLAUDE_PLUGIN_ROOT} with MCP", or discusses MCP server types (SSE, stdio, HTTP, WebSocket). Provides comprehensive guidance for integrating Model Context Protocol servers into Claude Code plugins for external tool and service integration.
version: 0.1.0
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "When MCP servers provide tools, they're automatically prefixed:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Example:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Format:** `mcp__plugin_<plugin-name>_<server-name>__<tool-name>`" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Tool: `create_task`" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Full name:** `mcp__plugin_asana_asana__asana_create_task`" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Plugin: `asana`" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Server: `asana`" ] ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "**Best practice:** Pre-allow specific tools, not wildcards, for security." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Pre-allow specific MCP tools in command frontmatter:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """---
allowed-tools: [
  "mcp__plugin_asana_asana__asana_create_task",
  "mcp__plugin_asana_asana__asana_search_tasks"
]
---
""" ;
                                    oc:codeLanguage "markdown" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 206-213" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Wildcard (use sparingly):**" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """---
allowed-tools: ["mcp__plugin_asana_asana__*"]
---
""" ;
                                    oc:codeLanguage "markdown" ;
                                    oc:contentOrder 4 ;
                                    oc:sourceLocation "lines 216-220" ] ;
