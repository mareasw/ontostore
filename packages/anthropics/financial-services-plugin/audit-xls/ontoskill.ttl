@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_financial_services_plugin_audit_xls a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "audit-xls" ;
    skos:broader "Spreadsheet auditor" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/audit-xls" ;
    oc:contentHash "12cc3668bc0257fa49f722b2e75c4f9c75053a6baf79e068f68cae644445af81" ;
    oc:dependsOnSkill oc:skill_ontoskills_xlsx_manipulation ;
    oc:differentia "Performs formula-level and financial-model integrity checks scoped to selection, sheet, or full model" ;
    oc:handlesFailure oc:CorruptedFile,
        oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "scope (selection/sheet/model) and spreadsheet file" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Audit a spreadsheet for formula accuracy, errors, and common mistakes. Scopes to a selected range, a single sheet, or the entire model (including financial-model integrity checks like BS balance, cash tie-out, and logic sanity). Triggers on \"audit this sheet\", \"check my formulas\", \"find formula errors\", \"QA this spreadsheet\", \"sanity check this\", \"debug model\", \"model check\", \"model won't balance\", \"something's off in my model\", \"model review\"." ;
    oc:hasName "audit-xls" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: audit-xls
description: Audit a spreadsheet for formula accuracy, errors, and common mistakes. Scopes to a selected range, a single sheet, or the entire model (including financial-model integrity checks like BS balance, cash tie-out, and logic sanity). Triggers on "audit this sheet", "check my formulas", "find formula errors", "QA this spreadsheet", "sanity check this", "debug model", "model check", "model won't balance", "something's off in my model", "model review".
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Audit formulas and data for accuracy and mistakes. Scope determines depth — from quick formula checks on a selection up to full financial-model integrity audits." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Hardcoded overrides are the #1 source of silent bugs** — search aggressively" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Sign convention errors** (positive vs negative for cash outflows) are extremely common" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "If the model uses VBA macros, note any macro-driven calculations that can't be audited from formulas alone" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**BS balance first** — if it doesn't balance, everything downstream is suspect" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Notes" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "If scope is **model**, identify the model type (DCF / LBO / 3-statement / merger / comps / custom) and run the appropriate integrity checks below." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "### 3a. Structural review" ;
                                    oc:tableMarkdown """| Check | What to look for |
|---|---|
| Input/formula separation | Are inputs clearly separated from calculations? |
| Color convention | Blue=input, black=formula, green=link — or whatever the model uses, applied consistently? |
| Tab flow | Logical order (Assumptions → IS → BS → CF → Valuation)? |
| Date headers | Consistent across all tabs? |
| Units | Consistent (thousands vs millions vs actuals)? |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "3a. Structural review" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "If unintentional: trace the loop and flag how to break it" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Interest → debt balance → cash → interest is a common intentional circ in LBO/3-stmt models" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "If intentional: verify iteration toggle exists and works" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "3e. Circular references" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "If BS doesn't balance, **quantify the gap per period and trace where it breaks** — nothing else matters until this is fixed." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "### 3b. Balance Sheet" ;
                                    oc:tableMarkdown """| Check | Test |
|---|---|
| BS balances | Total Assets = Total Liabilities + Equity (every period) |
| RE rollforward | Prior RE + Net Income − Dividends = Current RE |
| Goodwill/intangibles | Flow from acquisition assumptions (if M&A) |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "3b. Balance Sheet" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "### 3d. Income Statement" ;
                                    oc:tableMarkdown """| Check | Test |
|---|---|
| Revenue build | Ties to segment/product detail |
| Tax | Tax expense = Pre-tax income × tax rate (allow for deferred tax adj) |
| Share count | Ties to dilution schedule (options, converts, buybacks) |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "3d. Income Statement" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Debt paydown doesn't match cash sweep mechanics" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "PIK interest not accruing to principal" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Fees/expenses not deducted from Day 1 equity" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Exit multiple applied to wrong EBITDA (LTM vs NTM)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Management rollover not reflected in returns" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 7 ;
                                    oc:textContent "**3-statement:**" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 8 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Depreciation doesn't match PP&E schedule" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Debt maturity schedule doesn't match principal payments" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Working capital changes have wrong sign" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Dividends exceed net income without explanation" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "**Merger:**" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 6 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Accretion/dilution uses wrong share count (pre- vs post-deal)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Transaction fees not in sources & uses" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Synergies not phased in" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Purchase price allocation doesn't balance" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Foregone interest on cash not included" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**DCF:**" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Terminal value not discounted back" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "WACC uses book values instead of market values" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Tax shield double-counted" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "FCF includes interest expense (should be unlevered)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Discount rate applied to wrong period (mid-year vs end-of-year)" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**LBO:**" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 7 ;
                            oc:sectionTitle "3g. Model-type-specific bugs" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 6 ;
                                    oc:tableCaption "### 3f. Logic & reasonableness" ;
                                    oc:tableMarkdown """| Check | Flag if |
|---|---|
| Growth rates | >100% revenue growth without explanation |
| Margins | Outside industry norms |
| Terminal value dominance | TV > ~75% of DCF EV (yellow flag) |
| Hockey-stick | Projections ramp unrealistically in out-years |
| Compounding | EBITDA compounds to absurd $ by Year 10 |
| Edge cases | Model breaks at 0% or negative growth, negative EBITDA, leverage goes negative |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "3f. Logic & reasonableness" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "### 3c. Cash Flow Statement" ;
                                    oc:tableMarkdown """| Check | Test |
|---|---|
| Cash tie-out | CF Ending Cash = BS Cash (every period) |
| CF sums | CFO + CFI + CFF = Δ Cash |
| D&A match | D&A on CF = D&A on IS |
| CapEx match | CapEx on CF matches PP&E rollforward on BS |
| WC changes | Signs match BS movements (ΔAR, ΔAP, ΔInventory) |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "3c. Cash Flow Statement" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Step 3: Model-integrity checks (MODEL scope only)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 9 ;
                            oc:tableCaption "Run these regardless of scope" ;
                            oc:tableMarkdown """| Check | What to look for |
|---|---|
| Formula errors | `#REF!`, `#VALUE!`, `#N/A`, `#DIV/0!`, `#NAME?` |
| Hardcodes inside formulas | `=A1*1.05` — the `1.05` should be a cell reference |
| Inconsistent formulas | A formula that breaks the pattern of its neighbors in a row/column |
| Off-by-one ranges | `SUM`/`AVERAGE` that misses the first or last row |
| Pasted-over formulas | Cell that looks like a formula but is actually a hardcoded value |
| Circular references | Intentional or accidental |
| Broken cross-sheet links | References to cells that moved or were deleted |
| Unit/scale mismatches | Thousands mixed with millions, % stored as whole numbers |
| Hidden rows/tabs | Could contain overrides or stale calculations |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Run these regardless of scope:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Step 2: Formula-level checks (ALL scopes)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "The **model** scope is the deepest — use it for DCF, LBO, 3-statement, merger, comps, or any integrated financial model before sending to a client or IC." ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent """What scope do you want me to audit?
- **selection** — just the currently selected range
- **sheet** — the current active sheet only
- **model** — the whole workbook, including financial-model integrity checks (BS balance, cash tie-out, roll-forwards, logic sanity)""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "If the user already gave a scope, use it. Otherwise **ask them**:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Step 1: Determine scope" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Output a findings table:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Severity:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent "**Don't change anything without asking** — report first, fix on request." ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 6 ;
                            oc:quoteContent "Model type: [DCF/LBO/3-stmt/...] — Overall: [Clean / Minor Issues / Major Issues] — [N] critical, [N] warnings, [N] info" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Info** — style/best-practice (color coding, layout, naming)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Critical** — wrong output (BS doesn't balance, formula broken, cash doesn't tie)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Warning** — risky (hardcodes, inconsistent formulas, edge-case failures)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "For **model** scope, prepend a summary line:" ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 0 ;
                            oc:tableCaption "Output a findings table" ;
                            oc:tableMarkdown """| # | Sheet | Cell/Range | Severity | Category | Issue | Suggested Fix |
|---|---|---|---|---|---|---|
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Step 4: Report" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Audit Spreadsheet" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Deep balance sheet integrity checks that must pass before other model checks are meaningful." ;
            oc:hasStep _:ref_3370a79a9d1cff8d,
                _:ref_35b36313fa7dd695,
                [ a oc:WorkflowStep ;
                    dcterms:description "Verify D&A on CF = D&A on IS, CapEx matches PP&E rollforward, tax rate ties, share count ties to dilution schedule." ;
                    oc:expectedOutcome "Cross-statement consistency confirmed" ;
                    oc:stepDependsOn _:ref_3370a79a9d1cff8d ;
                    oc:stepId "is-cross-checks" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Test Retained Earnings rollforward: Prior RE + Net Income − Dividends = Current RE." ;
                    oc:expectedOutcome "RE rollforward verified" ;
                    oc:stepDependsOn _:ref_35b36313fa7dd695 ;
                    oc:stepId "re-rollforward" ] ;
            oc:workflowId "model-bs-validation" ;
            oc:workflowName "Balance Sheet Validation Sub-Workflow" ],
        [ a oc:Workflow ;
            dcterms:description "Systematic audit of a spreadsheet progressing from scope determination through formula checks, model integrity, and reporting." ;
            oc:hasStep _:ref_2f266e73eb7e01d3,
                [ a oc:WorkflowStep ;
                    dcterms:description "Output findings table with columns: #, Sheet, Cell/Range, Severity, Category, Issue, Suggested Fix. For model scope, prepend summary line with model type, overall status, and issue counts." ;
                    oc:expectedOutcome "Structured findings report delivered to user without making any changes" ;
                    oc:stepDependsOn _:ref_7db830ea0fb3d44b,
                        _:ref_fa7472e339d28f60 ;
                    oc:stepId "report-findings" ],
                _:ref_7db830ea0fb3d44b,
                _:ref_fa7472e339d28f60 ;
            oc:workflowId "audit-spreadsheet" ;
            oc:workflowName "Spreadsheet Audit Workflow" ],
        [ a oc:Workflow ;
            dcterms:description "Lightweight audit for when user only needs formula-level checks on a range or single sheet." ;
            oc:hasStep _:ref_040c987cd347e77d,
                [ a oc:WorkflowStep ;
                    dcterms:description "Output findings table with severity classifications (Critical/Warning/Info)." ;
                    oc:expectedOutcome "Findings report delivered" ;
                    oc:stepDependsOn _:ref_040c987cd347e77d ;
                    oc:stepId "report-findings" ] ;
            oc:workflowId "audit-selection-sheet" ;
            oc:workflowName "Quick Audit (Selection/Sheet Scope)" ],
        [ a oc:Workflow ;
            dcterms:description "Run targeted bug patterns based on identified model type (DCF, LBO, Merger, 3-statement)." ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Apply model-type-specific bug patterns (e.g., DCF: terminal value discounted, WACC market values; LBO: PIK accrual, exit multiple EBITDA basis; Merger: accretion/dilution share count; 3-stmt: WC sign convention)." ;
                    oc:expectedOutcome "All type-specific issues flagged" ;
                    oc:stepDependsOn _:ref_d4f49f82697c9959 ;
                    oc:stepId "run-type-checks" ],
                _:ref_d4f49f82697c9959 ;
            oc:workflowId "model-type-specific-audit" ;
            oc:workflowName "Model-Type-Specific Bug Check" ] ;
    oc:impartsKnowledge oc:kn_0a570bee,
        oc:kn_3ebd2998,
        oc:kn_4a9edf33,
        oc:kn_62acd33a,
        oc:kn_8eb614dd,
        oc:kn_99365447,
        oc:kn_b87a0356,
        oc:kn_c66910ec ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:FileExists ;
    oc:resolvesIntent "QA financial model integrity",
        "audit spreadsheet formulas",
        "check formula errors in Excel",
        "debug model balance issues",
        "find hardcoded values in spreadsheets",
        "review DCF LBO merger model",
        "validate 3-statement model" ;
    oc:yieldsState oc:SpreadsheetAudited .

oc:kn_0a570bee a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When auditing workbooks containing macros" ;
    oc:directiveContent "If the model uses VBA macros, note any macro-driven calculations that cannot be audited from formulas alone — these represent blind spots." ;
    oc:hasRationale "VBA can override formula logic invisibly, creating unauditable calculation paths." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3ebd2998 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When auditing at model scope" ;
    oc:directiveContent "BS balance is the first priority — if Total Assets ≠ Total Liabilities + Equity in any period, quantify the gap per period and trace the break before proceeding further." ;
    oc:hasRationale "A broken balance sheet makes all downstream calculations (cash flow, valuations) unreliable." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4a9edf33 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When circular references are detected in model scope" ;
    oc:directiveContent "Circular references in LBO/3-statement models (interest → debt → cash → interest) may be intentional. Verify iteration toggle exists for intentional circs; trace and break unintentional ones." ;
    oc:hasRationale "Misidentifying an intentional circular reference can waste time; missing an unintentional one corrupts results." ;
    oc:severityLevel "MEDIUM" .

oc:kn_62acd33a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "At the start of every audit" ;
    oc:directiveContent "Before starting, determine audit scope: selection (selected range), sheet (active sheet), or model (full workbook with integrity checks). Ask the user if not specified." ;
    oc:hasRationale "Scope determines depth of analysis and which check sets apply." .

oc:kn_8eb614dd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When checking cash flow statement and working capital" ;
    oc:directiveContent "Sign convention errors (positive vs negative for cash outflows) are extremely common in financial models — always verify sign consistency across WC changes, CF line items, and debt movements." ;
    oc:hasRationale "Inconsistent sign conventions produce models that appear balanced but contain offsetting errors." ;
    oc:severityLevel "HIGH" .

oc:kn_99365447 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reporting audit results" ;
    oc:directiveContent "Never change anything without asking — report findings first, fix only on explicit user request." ;
    oc:hasRationale "An audit is a read-only diagnostic. Unauthorized modifications could corrupt production models." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b87a0356 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When auditing DCF models" ;
    oc:directiveContent "Terminal value > ~75% of DCF EV is a yellow flag — it means most of the valuation relies on assumptions far in the future rather than near-term cash flows." ;
    oc:hasRationale "High terminal value concentration undermines the reliability of the valuation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c66910ec a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running formula-level checks at any scope" ;
    oc:directiveContent "Hardcoded numbers inside formulas (e.g., =A1*1.05) are the #1 source of silent bugs. Search aggressively for them." ;
    oc:hasRationale "Hardcoded values bypass the model's input framework and are invisible to change tracking." ;
    oc:severityLevel "HIGH" .

_:ref_040c987cd347e77d a oc:WorkflowStep ;
    dcterms:description "Run the 9 formula-level checks on the selected range or active sheet." ;
    oc:expectedOutcome "Formula issues identified and catalogued" ;
    oc:stepId "run-formula-checks" .

_:ref_2f266e73eb7e01d3 a oc:WorkflowStep ;
    dcterms:description "Determine audit scope (selection, sheet, or model) by asking user or using provided scope." ;
    oc:expectedOutcome "Scope is confirmed as selection, sheet, or model" ;
    oc:stepId "determine-scope" .

_:ref_3370a79a9d1cff8d a oc:WorkflowStep ;
    dcterms:description "Verify CF Ending Cash = BS Cash for every period, and CFO + CFI + CFF = ΔCash." ;
    oc:expectedOutcome "Cash flow ties out to balance sheet" ;
    oc:stepDependsOn _:ref_35b36313fa7dd695 ;
    oc:stepId "cash-tie-out" .

