oc:kn_2d787876 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing scenario switching" ;
    oc:directiveContent "Use consolidation columns with INDEX formulas to pull from scenario blocks based on a case selector cell (1=Bear, 2=Base, 3=Bull). Do NOT scatter nested IF formulas throughout projection rows." ;
    oc:hasRationale "Centralized INDEX logic is cleaner, easier to audit, and prevents formula errors from scattered IF statements" ;
    oc:severityLevel "MEDIUM" .

oc:kn_479acfe1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building sensitivity tables" ;
    oc:directiveContent "Sensitivity tables must use an ODD number of rows and columns (standard 5×5). The center cell must equal the model's actual implied share price (base case sanity check). Highlight center cell with #BDD7EE fill + bold font." ;
    oc:hasRationale "Odd dimensions guarantee a true center cell; center cell matching the model output proves the table is correctly constructed" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6003613e a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When writing any hardcoded value" ;
    oc:directiveContent "Cell comments must be added AS EACH hardcoded value is created — never deferred to end. Format: 'Source: [System/Document], [Date], [Reference], [URL if applicable]'. Every blue input must have a comment." ;
    oc:hasRationale "Deferred comments get forgotten; missing source documentation fails audit readiness and xlsx skill requirements" ;
    oc:severityLevel "MEDIUM" .

oc:kn_60d90a6b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building sensitivity tables" ;
    oc:directiveContent "Never use Excel's Data Table feature for sensitivity analysis. Instead, build simple 2D grids with regular formulas in each cell, populated programmatically via openpyxl loops. All 75 cells (3 tables × 25 cells) must contain full DCF recalculation formulas." ;
    oc:hasRationale "Data Table feature requires manual intervention and cannot be automated via openpyxl; linear approximations produce inaccurate results" ;
    oc:severityLevel "CRITICAL" .

oc:kn_897e7c43 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any cell in the DCF model" ;
    oc:directiveContent "Every projection, margin, discount factor, PV, and sensitivity cell MUST be a live Excel formula — never a value computed in Python and written as a number. Only raw historical inputs, assumption drivers, and current market data may be hardcoded." ;
    oc:hasRationale "The model must flex when the user changes an assumption — hardcoded computed values break this fundamental requirement" ;
    oc:severityLevel "CRITICAL" .

oc:kn_91bea621 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When building section headers in Office JS environment" ;
    oc:directiveContent "When using Office JS merged cells, do NOT call .merge() then set .values on the merged range — it throws InvalidArgument. Instead, write the value to the top-left cell alone, then merge and format the full range." ;
    oc:hasRationale "Office JS reports the range's original dimensions after merge, causing array size mismatch" ;
    oc:severityLevel "HIGH" .

oc:kn_a5610de3 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "Before delivering the completed DCF model" ;
    oc:directiveContent "Run `python recalc.py model.xlsx 30` before delivery. Fix ALL errors until status is 'success'. Then spot-check: one FCF formula references correct assumption rows, case selector updates consolidation column, revenue formulas reference consolidation column." ;
    oc:hasRationale "Zero formula errors is a hard requirement; spot-checking catches logical errors that pass recalculation" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a6cf3a6a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When constructing the Excel model layout" ;
    oc:directiveContent "Define ALL section row positions BEFORE writing any formulas. Write ALL headers and labels first, then section dividers, THEN formulas using locked row positions. Test formulas immediately after creation." ;
    oc:hasRationale "Inserting headers after writing formulas shifts row references causing #REF! errors throughout the model" ;
    oc:severityLevel "HIGH" .

oc:kn_a866f226 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building operating expense projections" ;
    oc:directiveContent "Operating expenses (S&M, R&D, G&A) must be modeled as percentages of REVENUE, not gross profit. Model operating leverage by having percentages decline as revenue scales." ;
    oc:hasRationale "Businesses scale OpEx with revenue, not gross profit; using GP produces unrealistic margin progression" ;
    oc:severityLevel "HIGH" .

oc:kn_be2cff70 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Throughout the DCF build process" ;
    oc:directiveContent "Verify step-by-step with the user: confirm raw inputs → confirm revenue projections → confirm FCF schedule → confirm WACC → confirm equity bridge → then build sensitivity tables. Catch errors at each stage before proceeding." ;
    oc:hasRationale "A wrong assumption discovered late means rebuilding everything downstream; incremental validation prevents costly rework" ;
    oc:severityLevel "HIGH" .

oc:kn_c5db4646 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "After data retrieval, before model construction" ;
    oc:directiveContent "Before building: verify net debt vs net cash, confirm diluted shares outstanding (check for recent buybacks/issuances), validate historical margins consistent with business model, cross-check revenue growth with industry benchmarks, verify tax rate is reasonable (21-28%)." ;
    oc:hasRationale "Garbage in, garbage out — invalid inputs produce unreliable valuations regardless of model quality" ;
    oc:severityLevel "HIGH" .

oc:kn_f5cb1172 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating terminal value" ;
    oc:directiveContent "Terminal growth rate must always be less than WACC, otherwise the perpetuity growth method produces infinite value which is mathematically invalid. Terminal value should represent 50-70% of Enterprise Value." ;
    oc:hasRationale "Terminal growth >= WACC creates mathematically undefined infinite value; >75% EV reliance on terminal assumptions signals model fragility" ;
    oc:severityLevel "CRITICAL" .

oc:payload_e3e85596488cdd9e a oc:ExecutionPayload ;
    oc:code "python scripts/validate_dcf.py <excel_file> [output.json]" ;
    oc:executor "python" ;
    oc:timeout 60 .

