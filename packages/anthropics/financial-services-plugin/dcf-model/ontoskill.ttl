        oc:kn_53ed4a08,
        oc:kn_59ed86d7,
        oc:kn_59f331cf,
        oc:kn_9dae7928,
        oc:kn_b336d4bd,
        oc:kn_cdc18a78,
        oc:kn_dd795082 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "build equity valuation model with terminal value",
        "calculate intrinsic value with growth projections",
        "create DCF model with sensitivity analysis",
        "generate professional Excel DCF model",
        "perform WACC-based company valuation",
        "value a company using DCF methodology" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_24bc253b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing Bear/Base/Bull scenario switching" ;
    oc:directiveContent "Do not use nested IF formulas scattered throughout for scenario selection. Instead, use a consolidation column with INDEX formulas that pulls from the appropriate scenario block based on a case selector cell." ;
    oc:hasRationale "A consolidation column centralizes scenario logic, making the model easier to audit and reducing formula errors compared to scattered IF statements in every projection row." ;
    oc:severityLevel "HIGH" .

oc:kn_2b41d405 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before delivering the DCF model to the user" ;
    oc:directiveContent "Run recalc.py and validate_dcf.py on the model before delivery. Fix all errors until both scripts return success status with zero formula errors." ;
    oc:hasRationale "Delivering a model with formula errors (#REF!, #DIV/0!, #VALUE!) is unprofessional and may produce incorrect valuations." ;
    oc:severityLevel "CRITICAL" .

oc:kn_2f70ea68 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing sensitivity analysis tables" ;
    oc:directiveContent "Use odd-dimension grids (5×5 or 7×7) for sensitivity tables so the center cell exactly equals the base case. Highlight the center cell with medium-blue fill (#BDD7EE) and bold font as a visual anchor and sanity check." ;
    oc:hasRationale "The center cell serves as a built-in validation: if its output doesn't match the model's actual implied share price, the table is built incorrectly." ;
    oc:severityLevel "MEDIUM" .

oc:kn_53ed4a08 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When modeling operating expenses in the income statement projection" ;
    oc:directiveContent "Do not base operating expenses on gross profit. All OpEx percentages (S&M, R&D, G&A) must be based on revenue, not gross profit." ;
    oc:hasRationale "Operating expenses scale with revenue, not gross profit. Basing OpEx on gross profit produces unrealistic margin progression and does not reflect how businesses actually operate." ;
    oc:severityLevel "HIGH" .

oc:kn_59ed86d7 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After building the complete model and running recalc" ;
    oc:directiveContent "Spot-check that FCF formulas reference correct assumption rows, case selector updates the consolidation column, revenue formulas use consolidation column (not nested IFs), and OpEx is based on revenue." ;
    oc:hasRationale "These are the top 5 errors in DCF models; spot-checking catches them before delivery." ;
    oc:severityLevel "HIGH" .

oc:kn_59f331cf a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During the entire DCF model building process" ;
    oc:directiveContent "Verify step-by-step with the user at each checkpoint: after data retrieval, after revenue projections, after FCF build, after WACC, and after terminal value + PV. Do not build end-to-end without intermediate confirmation." ;
    oc:hasRationale "Catching errors at each stage prevents costly rebuilds. A wrong margin assumption discovered after sensitivity tables means rebuilding everything downstream." ;
    oc:severityLevel "HIGH" .

oc:kn_9dae7928 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating terminal value using the perpetuity growth method" ;
    oc:directiveContent "Terminal growth rate must be less than WACC, and terminal value should represent 50-70% of Enterprise Value. Terminal growth should not exceed the risk-free rate or long-term GDP growth." ;
    oc:hasRationale "Terminal growth >= WACC creates mathematically infinite value. Terminal value >80% of EV indicates over-reliance on terminal assumptions; <40% suggests overly conservative assumptions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b336d4bd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building sensitivity analysis tables (WACC vs Terminal Growth, Revenue Growth vs EBIT Margin, Beta vs Risk-Free Rate)" ;
    oc:directiveContent "Never use linear approximations or shortcuts in sensitivity tables. Every cell in every sensitivity table must contain a full DCF recalculation formula. Do not leave placeholder text or require manual user steps." ;
    oc:hasRationale "Linear approximations produce inaccurate results because DCF relationships are non-linear. Placeholders or empty cells produce incomplete, non-client-ready deliverables." ;
    oc:severityLevel "CRITICAL" .

oc:kn_cdc18a78 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any cell in the DCF model spreadsheet" ;
    oc:directiveContent "Every projection, margin, discount factor, PV, and sensitivity cell MUST be a live Excel formula — never a hardcoded computed value. Only raw historical inputs, assumption drivers, and current market data may be hardcoded." ;
    oc:hasRationale "Formulas ensure the model recalculates dynamically when users change assumptions, which is essential for scenario analysis and sensitivity testing." ;
    oc:severityLevel "CRITICAL" .

oc:kn_dd795082 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When laying out the Excel model structure" ;
    oc:directiveContent "Define ALL section row positions BEFORE writing any formulas. Write all headers and labels first, then section dividers, then formulas using locked row positions." ;
    oc:hasRationale "Inserting rows after formulas are written shifts all references, causing #REF! errors. Planning the layout first ensures formula stability." ;
    oc:severityLevel "HIGH" .

oc:payload_e3e85596488cdd9e a oc:ExecutionPayload ;
    oc:code "python scripts/validate_dcf.py {model_path}" ;
    oc:executor "python" ;
    oc:timeout 60 .

