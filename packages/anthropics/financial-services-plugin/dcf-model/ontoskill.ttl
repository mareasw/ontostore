                            oc:sectionTitle "Sheet Architecture" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 39 ;
                    oc:sectionTitle "Excel Model Structure" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent _:ref_b0082adda0ee631c ;
