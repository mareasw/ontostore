                                    oc:contentOrder 1 ;
                                    oc:textContent "**Mid-Year Convention:**" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """For each projection year:
PV of FCF = Unlevered FCF × Discount Factor

Example (Year 1):
FCF = $1,000
WACC = 10%
Period = 0.5
Discount Factor = 1 / (1.10)^0.5 = 0.9535
PV = $1,000 × 0.9535 = $954
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 4 ;
                                    oc:sourceLocation "lines 256-266" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 6 ;
