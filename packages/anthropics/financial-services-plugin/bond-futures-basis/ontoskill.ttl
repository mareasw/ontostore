oc:skill_financial_services_plugin_bond_futures_basis a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "bond-futures-basis" ;
    skos:broader "Financial analysis methodology" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/bond-futures-basis" ;
    oc:contentHash "db01887af17867593b72fe610a3ae4fcdd6c6fea2eb22430a87705f4cc71fc6a" ;
    oc:dependsOnSkill oc:skill_ontoskills_fixed_income_portfolio ;
    oc:differentia "that combines bond futures pricing, CTD identification, and yield curve context to assess basis trading opportunities and delivery option value" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasAllowedTool "bond_future_price",
        "bond_price",
        "credit_curve",
        "interest_rate_curve",
        "tscc_historical_pricing_summaries" ;
    oc:hasArgumentHint "contract RIC (e.g., FGBLc1 for Bund future, TYc1 for 10Y Treasury note future)" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Analyze the bond futures basis by pricing futures, identifying the cheapest-to-deliver, and comparing with yield curves to assess delivery option value and basis trading opportunities. Use when analyzing bond futures, computing the basis, identifying CTD bonds, calculating implied repo rates, or evaluating basis trades." ;
    oc:hasName "bond-futures-basis" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: bond-futures-basis
description: Analyze the bond futures basis by pricing futures, identifying the cheapest-to-deliver, and comparing with yield curves to assess delivery option value and basis trading opportunities. Use when analyzing bond futures, computing the basis, identifying CTD bonds, calculating implied repo rates, or evaluating basis trades.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "You are an expert in bond futures and basis trading. Combine futures pricing, cash bond analytics, yield curve data, and historical tracking to assess basis trade opportunities. Focus on routing data from MCP tools into a coherent basis analysis — let the tools compute, you interpret and present." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "### Future Summary" ;
                                    oc:tableMarkdown """| Field | Value |
|-------|-------|
| Contract | ... |
| Fair Price | ... |
| CTD Bond | ... |
| Conversion Factor | ... |
| Contract DV01 | ... |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Future Summary" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 2 ;
                                    oc:tableCaption "### Historical Basis Context" ;
                                    oc:tableMarkdown """| Metric | Current | 3M Avg | 6M Avg | Percentile |
|--------|---------|--------|--------|------------|
| Net Basis | ... | ... | ... | ...th |
| Implied Repo | ... | ... | ... | ...th |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "Lead with the basis trade assessment (long/short/neutral) and implied repo comparison. Follow with detailed analytics tables." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Historical Basis Context" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 6 ;
                                    oc:tableCaption "### Basis Calculation" ;
                                    oc:tableMarkdown """| Metric | Value |
|--------|-------|
| Gross Basis | ... ticks |
| Carry | ... ticks |
| Net Basis | ... ticks |
| Implied Repo | ...% |
| Market Repo (approx) | ...% |
| Assessment | Rich / Fair / Cheap |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Basis Calculation" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### CTD Bond Analytics" ;
                                    oc:tableMarkdown """| Field | Value |
|-------|-------|
| Clean Price | ... |
| YTM | ... |
| Duration | ... |
| DV01 | ... |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "CTD Bond Analytics" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Output Format" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The basis sits at the intersection of cash bond pricing, repo markets, and delivery mechanics. Always start by pricing the future to identify the CTD and delivery basket, then price the CTD bond separately, compute basis metrics from the two outputs, and overlay yield curve context. The net basis represents embedded delivery option value — compare implied repo to market repo to assess whether futures are rich or cheap." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Principles" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**`credit_curve`** — Credit spread curves. Use for sovereign credit context when relevant." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**`interest_rate_curve`** — Government yield curves. Two-phase: list available curves, then calculate. Use short end as repo rate proxy." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**`bond_future_price`** — Price bond futures. Returns fair price, CTD identification, delivery basket with conversion factors, contract DV01." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**`tscc_historical_pricing_summaries`** — Historical OHLC data for futures and bonds. Use to track basis evolution over time." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**`bond_price`** — Price individual cash bonds. Returns clean/dirty price, yield, duration, DV01, convexity." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Available MCP Tools" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_f940472944945341 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Tool Chaining Workflow" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Bond Futures Basis Analysis" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Complete bond futures basis analysis from futures pricing through trade assessment" ;
            oc:hasStep _:ref_52d88d7740cc6b78,
                _:ref_5a820ff82fe02380,
                _:ref_8c5a8b3dbff7f16e,
                _:ref_a34b5daac1aa4502,
                [ a oc:WorkflowStep ;
                    dcterms:description "Optionally call credit_curve for relevant sovereign to check for credit-driven basis distortions" ;
                    oc:expectedOutcome "Sovereign credit overlay assessed if applicable" ;
                    oc:stepDependsOn _:ref_8c5a8b3dbff7f16e ;
                    oc:stepId "credit-context-optional" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Lead with basis trade assessment (long/short/neutral) and implied repo comparison, followed by detailed analytics tables" ;
                    oc:expectedOutcome "Complete basis analysis report with trade recommendation and supporting data" ;
                    oc:stepDependsOn _:ref_52d88d7740cc6b78,
                        _:ref_8c5a8b3dbff7f16e,
                        _:ref_eb9e9f7fb1a7abd9 ;
                    oc:stepId "present-assessment" ],
                _:ref_eb9e9f7fb1a7abd9 ;
            oc:workflowId "bond-futures-basis-analysis" ;
            oc:workflowName "Bond Futures Basis Analysis Workflow" ],
        _:ref_f940472944945341 ;
    oc:impartsKnowledge oc:kn_4a91efb8,
        oc:kn_69616327,
        oc:kn_edf51d7b,
        oc:kn_f1ef708f,
        oc:kn_ff314fb8 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "analyze bond futures basis",
        "assess delivery option value",
        "calculate implied repo rates",
        "compare futures pricing to cash bond analytics",
        "compute gross and net basis metrics",
        "evaluate basis trade opportunities",
        "identify cheapest-to-deliver bonds" ;
    oc:yieldsState oc:BasisAnalysisComplete .

oc:kn_4a91efb8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting basis analysis results" ;
    oc:directiveContent "Lead with the basis trade assessment (long/short/neutral) and implied repo comparison, then follow with detailed analytics tables." ;
    oc:hasRationale "Decision-makers need the actionable conclusion first — the detailed tables support but should not precede the assessment." .

oc:kn_69616327 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating basis trade opportunities" ;
    oc:directiveContent "The net basis represents embedded delivery option value. Compare implied repo to market repo to assess whether futures are rich or cheap — this comparison is the core assessment." ;
    oc:hasRationale "Without the implied repo vs market repo comparison, the basis analysis lacks its primary signal for trading direction." ;
    oc:severityLevel "HIGH" .

oc:kn_edf51d7b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing any bond futures basis analysis" ;
    oc:directiveContent "1. Call bond_future_price with contract RIC → extract CTD, conversion factors, delivery basket, DV01. 2. Call bond_price for the CTD → extract clean/dirty price, yield, duration, DV01. 3. Compute gross basis, carry, net basis (BNOC), implied repo rate from both outputs. 4. Call interest_rate_curve (list then calculate) for repo proxy comparison. 5. Call tscc_historical_pricing_summaries for future and CTD (3M daily) → assess trend, volatility, percentile. 6. Optionally call credit_curve for sovereign credit context." ;
    oc:hasRationale "Sequential tool chaining is required because each step depends on outputs from prior steps — CTD from futures pricing feeds into bond pricing, both feed into basis computation." ;
    oc:stepOrder 1 .

oc:kn_f1ef708f a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When comparing implied repo to market repo" ;
    oc:directiveContent "Uses short-end government yield curve rate as a proxy for market repo rate. This approximation may deviate from actual repo rates in stressed markets." ;
    oc:hasRationale "The interest rate curve's short end is a proxy, not the actual repo rate — in dislocated markets this proxy may be unreliable." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ff314fb8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning any basis analysis" ;
    oc:directiveContent "Always start by pricing the future to identify the CTD and delivery basket, then price the CTD bond separately, compute basis metrics, and overlay yield curve context. Let the MCP tools compute — you interpret and present." ;
    oc:hasRationale "The basis sits at the intersection of cash bond pricing, repo markets, and delivery mechanics — the correct sequencing ensures coherent analysis." .

_:ref_0d3fb69752d1dd30 a oc:WorkflowStep ;
    dcterms:description "**Price the Future:** Call `bond_future_price` with the contract RIC. Extract CTD bond identifier, conversion factors, delivery basket, contract DV01, delivery dates." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_102de5d1d0450120 a oc:WorkflowStep ;
    dcterms:description "**Price the CTD Bond:** Call `bond_price` for the CTD identified in step 1. Extract clean/dirty price, yield, duration, DV01." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_22859cbc5a6e321b a oc:WorkflowStep ;
    dcterms:description "**Yield Curve Context:** Call `interest_rate_curve` — list then calculate for the future's currency. Use short-end rate as repo proxy for the implied repo comparison." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_52d6ea83c75e6515 a oc:WorkflowStep ;
    dcterms:description "**Sovereign Credit (optional):** Call `credit_curve` for the relevant sovereign to check for credit-driven basis distortions." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_c2c1e0b7223b0868 a oc:WorkflowStep ;
    dcterms:description "**Historical Context:** Call `tscc_historical_pricing_summaries` for both the future and CTD bond (3M daily). Assess basis trend, volatility, and current percentile." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_d629ef0cfec8f7e9 a oc:WorkflowStep ;
    dcterms:description "**Compute Basis Metrics:** From the two outputs, compute gross basis, carry, net basis (BNOC), and implied repo rate. Compare implied repo to market short-term rate." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_52d88d7740cc6b78 a oc:WorkflowStep ;
    dcterms:description "Call interest_rate_curve (list then calculate) for the future's currency. Use short-end rate as repo proxy for implied repo comparison" ;
    oc:expectedOutcome "Market repo proxy rate obtained from short-end yield curve for comparison" ;
    oc:stepDependsOn _:ref_8c5a8b3dbff7f16e ;
    oc:stepId "yield-curve-context" .

_:ref_eb9e9f7fb1a7abd9 a oc:WorkflowStep ;
    dcterms:description "Call tscc_historical_pricing_summaries for both future and CTD bond (3M daily). Assess basis trend, volatility, and current percentile" ;
    oc:expectedOutcome "Historical basis trend, volatility profile, and percentile ranking established" ;
    oc:stepDependsOn _:ref_5a820ff82fe02380,
        _:ref_a34b5daac1aa4502 ;
    oc:stepId "historical-context" .

_:ref_f940472944945341 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_0d3fb69752d1dd30,
        _:ref_102de5d1d0450120,
