    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_5a820ff82fe02380 a oc:WorkflowStep ;
    dcterms:description "Call bond_price for the CTD bond identified in step 1 to get clean/dirty price, yield, duration, DV01, convexity" ;
    oc:expectedOutcome "CTD bond clean/dirty price, yield, duration, and DV01 extracted" ;
    oc:stepDependsOn _:ref_a34b5daac1aa4502 ;
    oc:stepId "price-ctd-bond" .

_:ref_8c5a8b3dbff7f16e a oc:WorkflowStep ;
    dcterms:description "Compute gross basis, carry, net basis (BNOC), and implied repo rate from futures and bond pricing outputs" ;
    oc:expectedOutcome "Gross basis, carry, net basis, and implied repo rate calculated" ;
    oc:stepDependsOn _:ref_5a820ff82fe02380,
