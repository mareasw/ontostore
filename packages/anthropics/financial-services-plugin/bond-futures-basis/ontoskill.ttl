    oc:stepId "compute-basis-metrics" .

_:ref_a34b5daac1aa4502 a oc:WorkflowStep ;
    dcterms:description "Call bond_future_price with contract RIC to get fair price, CTD identification, delivery basket, conversion factors, and contract DV01" ;
    oc:expectedOutcome "CTD bond identifier, conversion factor, delivery basket, and contract DV01 extracted" ;
    oc:stepId "price-future" .

