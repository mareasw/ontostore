@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_financial_services_plugin_fx_carry_trade a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "fx-carry-trade" ;
    skos:broader "FX analysis tool" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/fx-carry-trade" ;
    oc:contentHash "0eac23e8d4b485a95b4960b03e777a96dc58b4f1351f8ac4586dfd94355c6b68" ;
    oc:differentia "that evaluates carry trade opportunities by combining spot rates, forward curves, volatility surfaces, and historical data into risk-adjusted carry-to-vol assessments" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasAllowedTool "fx_forward_curve",
        "fx_forward_price",
        "fx_spot_price",
        "fx_vol_surface",
        "interest_rate_curve",
        "tscc_historical_pricing_summaries" ;
    oc:hasArgumentHint "currency-pair (e.g. AUDJPY, USDTRY)" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Evaluate FX carry trade opportunities by combining spot rates, forward points, interest rate differentials, volatility surface analysis, and historical price trends. Use when analyzing carry trades, comparing FX forward curves, assessing carry-to-vol ratios, or evaluating currency pair opportunities." ;
    oc:hasName "fx-carry-trade" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: fx-carry-trade
description: Evaluate FX carry trade opportunities by combining spot rates, forward points, interest rate differentials, volatility surface analysis, and historical price trends. Use when analyzing carry trades, comparing FX forward curves, assessing carry-to-vol ratios, or evaluating currency pair opportunities.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "You are an expert FX strategist specializing in carry trade analysis. Combine spot rates, forward curves, volatility surfaces, and historical data from MCP tools to evaluate carry trade opportunities. Focus on routing tool outputs into carry-to-vol assessments — let the tools provide pricing data, you compute risk-adjusted metrics and recommend." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**`fx_spot_price`** — Current spot rate for a currency pair. Returns mid/bid/ask. Starting point for all carry analysis." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**`fx_forward_price`** — Forward rate at a specific tenor. Returns forward points and outright rate. Use to compute carry at the target tenor." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**`tscc_historical_pricing_summaries`** — Historical spot price data. Use to compute realized vol and assess spot trend direction." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**`fx_vol_surface`** — Implied volatility surface by delta and expiry. Returns ATM vol, risk reversals, butterflies. Use for carry-to-vol ratio and skew assessment." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**`fx_forward_curve`** — Full forward curve across all standard tenors. Two-phase: list then calculate. Use to map the carry term structure." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**`interest_rate_curve`** — Yield curves by currency. Use to understand the rate differential driving the carry." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Available MCP Tools" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "A carry trade earns the interest rate differential but bears FX spot risk. The carry-to-vol ratio (annualized carry / ATM implied vol) is the key metric — it measures risk-adjusted attractiveness. Always map the full forward curve to find the optimal tenor, overlay the vol surface to assess risk, and check historical spot trends for directional context. Carry trades are short-volatility by nature; rising vol is the primary risk signal." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Principles" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_3193898604895704 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Tool Chaining Workflow" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "### Vol Surface Summary" ;
                                    oc:tableMarkdown """| Tenor | ATM Vol | 25d Put | 25d Call | RR | BF |
|-------|---------|---------|----------|-----|-----|
| 1M | ... | ... | ... | ... | ... |
| 3M | ... | ... | ... | ... | ... |
| 6M | ... | ... | ... | ... | ... |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Vol Surface Summary" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "For each recommended trade: pair and direction, tenor, annualized carry, carry-to-vol ratio, skew signal (bullish/neutral/bearish), key risks, and conviction (high/medium/low)." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Carry Trade Recommendation" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "### Carry Profile" ;
                                    oc:tableMarkdown """| Metric | 1M | 3M | 6M | 1Y |
|--------|-----|-----|-----|-----|
| Forward Points (pips) | ... | ... | ... | ... |
| Annualized Carry (%) | ... | ... | ... | ... |
| ATM Implied Vol (%) | ... | ... | ... | ... |
| Carry-to-Vol Ratio | ... | ... | ... | ... |
| 25d Risk Reversal | ... | ... | ... | ... |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Carry Profile" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Output Format" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "FX Carry Trade Analysis" ] ;
    oc:hasWorkflow _:ref_3193898604895704,
        [ a oc:Workflow ;
            dcterms:description "Sequential tool-chaining workflow to evaluate an FX carry trade opportunity from spot pricing through to a risk-adjusted recommendation." ;
            oc:hasStep _:ref_45650b6a365a91b2,
                _:ref_4b7835fd53109a8a,
                _:ref_8a9bd25f86028dea,
                _:ref_b96aad2947ddf56d,
                [ a oc:WorkflowStep ;
                    dcterms:description "Combine all data into a carry profile with carry-to-vol ratio, vol surface signals, and historical context. Recommend entry with position sizing guidance." ;
                    oc:expectedOutcome "Complete carry trade recommendation with conviction level" ;
                    oc:stepDependsOn _:ref_45650b6a365a91b2,
                        _:ref_b96aad2947ddf56d ;
                    oc:stepId "synthesize" ],
                _:ref_f06c50e5455f331a ;
            oc:workflowId "fx-carry-analysis" ;
            oc:workflowName "FX Carry Trade Analysis Workflow" ] ;
    oc:impartsKnowledge oc:kn_30b50c7c,
        oc:kn_340022da,
        oc:kn_54e4bfb9,
        oc:kn_612b4ca7,
        oc:kn_8a5d162e ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "analyze carry-to-vol ratios",
        "assess currency pair carry trades",
        "compare FX forward curves",
        "compute risk-adjusted carry metrics",
        "evaluate FX carry trade opportunities" ;
    oc:yieldsState oc:CarryTradeProfiled .

oc:kn_30b50c7c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing carry trade recommendations" ;
    oc:directiveContent "Carry trades are short-volatility by nature — rising implied volatility is the primary risk signal and should always be assessed via the vol surface." ;
    oc:hasRationale "Carry trades profit from stable or declining vol; a rising vol environment erodes carry returns and can trigger sharp unwinds." ;
    oc:severityLevel "HIGH" .

oc:kn_340022da a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When forming carry trade recommendations" ;
    oc:directiveContent "Never recommend a carry trade based solely on interest rate differential without overlaying vol surface analysis and historical spot trends." ;
    oc:hasRationale "High carry pairs often have high vol; without risk-adjusting, the recommendation may ignore the exact risk that makes the trade unattractive." ;
    oc:severityLevel "HIGH" .

oc:kn_54e4bfb9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing carry term structure" ;
    oc:directiveContent "Always map the full forward curve across tenors to find the optimal sweet-spot tenor with the best risk-adjusted carry, rather than defaulting to a single tenor." ;
    oc:hasRationale "Carry profiles vary across tenors — the 1M carry may be unattractive while 6M offers the best risk-adjusted return." .

oc:kn_612b4ca7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating any FX carry trade" ;
    oc:directiveContent "The carry-to-vol ratio (annualized carry / ATM implied vol) is the key risk-adjusted metric for evaluating carry trades — it measures attractiveness relative to volatility risk." ;
    oc:hasRationale "Carry trades earn the interest rate differential but bear FX spot risk; normalizing by implied vol provides a comparable risk-adjusted measure across pairs and tenors." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8a5d162e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When starting carry analysis on a currency pair" ;
    oc:directiveContent "Note the bid-ask spread from the spot rate quote as a liquidity indicator before proceeding with the carry analysis." ;
    oc:hasRationale "Wide bid-ask spreads indicate illiquidity, which increases transaction costs and may invalidate the carry trade economics." .

_:ref_21ef2097e3be82d5 a oc:WorkflowStep ;
    dcterms:description "**Price the Forward:** Call `fx_forward_price` at the target tenor. Compute annualized carry from forward points." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_3780816d4fafbdc7 a oc:WorkflowStep ;
    dcterms:description "**Map Carry Curve:** Call `fx_forward_curve` (list then calculate). Compute annualized carry at each tenor. Identify the sweet-spot tenor with best risk-adjusted carry." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_3f1f22d4354ad769 a oc:WorkflowStep ;
    dcterms:description "**Synthesize:** Combine into a carry profile with carry-to-vol ratio, vol surface signals, and historical context. Recommend entry with position sizing guidance." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_a5a0d2ed6449c32e a oc:WorkflowStep ;
    dcterms:description "**Assess Vol Risk:** Call `fx_vol_surface`. Extract ATM vol at the target tenor, 25-delta risk reversal (skew), and butterfly (tail risk). Compute carry-to-vol ratio." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_cba77c46705c1ff7 a oc:WorkflowStep ;
    dcterms:description "**Get Spot Rate:** Call `fx_spot_price` for the currency pair. Note bid-ask spread as a liquidity indicator." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_df689a659b98dcc1 a oc:WorkflowStep ;
    dcterms:description "**Historical Context:** Call `tscc_historical_pricing_summaries` for 1Y daily data. Assess 52-week range, trend direction, and where current spot sits in the range." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_3193898604895704 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_21ef2097e3be82d5,
        _:ref_3780816d4fafbdc7,
        _:ref_3f1f22d4354ad769,
        _:ref_a5a0d2ed6449c32e,
        _:ref_cba77c46705c1ff7,
        _:ref_df689a659b98dcc1 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_45650b6a365a91b2 a oc:WorkflowStep ;
    dcterms:description "Call tscc_historical_pricing_summaries for 1Y daily data. Assess 52-week range, trend direction, and spot positioning within the range." ;
    oc:expectedOutcome "Historical trend and range context established" ;
    oc:stepDependsOn _:ref_4b7835fd53109a8a ;
    oc:stepId "historical-context" .

_:ref_8a9bd25f86028dea a oc:WorkflowStep ;
    dcterms:description "Call fx_forward_curve (list then calculate) to map carry across all tenors. Identify the sweet-spot tenor with best risk-adjusted carry." ;
    oc:expectedOutcome "Carry term structure with optimal tenor identified" ;
    oc:stepDependsOn _:ref_f06c50e5455f331a ;
    oc:stepId "map-carry-curve" .

_:ref_b96aad2947ddf56d a oc:WorkflowStep ;
    dcterms:description "Call fx_vol_surface to extract ATM vol, 25-delta risk reversal, and butterfly at target tenor. Compute carry-to-vol ratio." ;
    oc:expectedOutcome "Vol surface metrics and carry-to-vol ratio computed" ;
    oc:stepDependsOn _:ref_8a9bd25f86028dea ;
    oc:stepId "assess-vol" .

_:ref_f06c50e5455f331a a oc:WorkflowStep ;
    dcterms:description "Call fx_forward_price at the target tenor. Compute annualized carry from forward points." ;
    oc:expectedOutcome "Forward rate and annualized carry computed" ;
    oc:stepDependsOn _:ref_4b7835fd53109a8a ;
    oc:stepId "price-forward" .

_:ref_4b7835fd53109a8a a oc:WorkflowStep ;
    dcterms:description "Call fx_spot_price for the currency pair to get current mid/bid/ask rates. Note bid-ask spread as a liquidity indicator." ;
    oc:expectedOutcome "Spot rate with bid-ask spread obtained" ;
    oc:stepId "get-spot" .

