oc:skill_financial_services_plugin_swap_curve_strategy a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "swap-curve-strategy" ;
    skos:broader "Financial analysis framework" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/swap-curve-strategy" ;
    oc:contentHash "d603b0a973c480cba1544adaac2b48e57d87e9a12af99a399d3dfaaeeba13a7c" ;
    oc:differentia "that prices interest rate swaps across tenors, overlays government and inflation curves, and identifies curve trade opportunities with DV01-neutral sizing" ;
    oc:handlesFailure oc:DataUnavailable,
        oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasAllowedTool "inflation_curve",
        "interest_rate_curve",
        "ir_swap",
        "qa_macroeconomic",
        "tscc_historical_pricing_summaries" ;
    oc:hasArgumentHint "currency or swap curve to analyze (e.g., USD, EUR, GBP)" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Analyze the interest rate swap curve by pricing swaps at multiple tenors, overlaying government and inflation curves, and identifying curve trade opportunities. Use when analyzing swap curves, computing swap spreads, decomposing real rates, identifying steepener/flattener/butterfly trades, or comparing swap rates across currencies." ;
    oc:hasName "swap-curve-strategy" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: swap-curve-strategy
description: Analyze the interest rate swap curve by pricing swaps at multiple tenors, overlaying government and inflation curves, and identifying curve trade opportunities. Use when analyzing swap curves, computing swap spreads, decomposing real rates, identifying steepener/flattener/butterfly trades, or comparing swap rates across currencies.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "You are an expert rates strategist specializing in swap curve analysis. Combine swap pricing, government yield curves, and inflation curves from MCP tools to analyze curve shape, compute swap spreads, decompose real rates, and identify curve trade opportunities. Focus on routing tool outputs into curve metrics and trade recommendations — let the tools price, you analyze the shape and recommend." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent _:ref_4877038466fd7862 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Tool Chaining Workflow" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**`ir_swap`** — Swap pricing. Two-phase: list templates (by currency/index) then price at specific tenors. Returns par swap rate, DV01, NPV." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**`qa_macroeconomic`** — Macro data. Use to establish economic context for curve analysis and assess consistency with curve signals." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**`interest_rate_curve`** — Government yield curves. Two-phase: list then calculate. Use for swap spread computation and curve shape context." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**`inflation_curve`** — Inflation breakeven curves. Two-phase: search then calculate. Use for real rate decomposition." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**`tscc_historical_pricing_summaries`** — Historical pricing data. Use for historical curve slope context and trend analysis." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Available MCP Tools" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "For each trade: structure (e.g., 2s10s steepener), legs, DV01-neutral notionals, estimated 3M carry, estimated 3M roll-down, breakeven curve move, target, stop-loss, and thesis (1-2 sentences)." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Curve Trade Recommendation" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Curve Metrics" ;
                                    oc:tableMarkdown """| Metric | Current |
|--------|---------|
| 2s10s slope (bp) | ... |
| 5s30s slope (bp) | ... |
| 2s5s10s butterfly (bp) | ... |
| Curve shape | Normal / Flat / Inverted / Humped |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Curve Metrics" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "### Real Rate Decomposition" ;
                                    oc:tableMarkdown """| Tenor | Nominal Swap | Inflation BE | Real Rate | Signal |
|-------|-------------|-------------|-----------|--------|
| 2Y | ...% | ...% | ...% | Accommodative/Restrictive |
| 5Y | ...% | ...% | ...% | Accommodative/Restrictive |
| 10Y | ...% | ...% | ...% | Accommodative/Restrictive |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Real Rate Decomposition" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Swap Curve Table" ;
                                    oc:tableMarkdown """| Tenor | Swap Rate (%) | Govt Yield (%) | Swap Spread (bp) | DV01 | Inflation BE (%) | Real Rate (%) |
|-------|-------------|----------------|-------------------|------|-------------------|---------------|
| 2Y | ... | ... | ... | ... | ... | ... |
| 5Y | ... | ... | ... | ... | ... | ... |
| 10Y | ... | ... | ... | ... | ... | ... |
| 30Y | ... | ... | ... | ... | ... | ... |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Swap Curve Table" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Output Format" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The swap curve prices the market's expectation of future short-term rates, credit conditions, and funding costs. Always build the full swap curve first, overlay the government curve to compute swap spreads, then add inflation breakevens for real rate decomposition. Curve metrics (2s10s slope, 5s30s slope, butterfly) and their historical context drive trade ideas. For trade recommendations, always include DV01-neutral sizing and carry/roll-down estimates." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Principles" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Swap Curve Strategy Analysis" ] ;
    oc:hasWorkflow _:ref_4877038466fd7862,
        [ a oc:Workflow ;
            dcterms:description "Complete swap curve analysis from pricing through trade recommendations" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Combine all data into swap curve table, swap spreads, real rate decomposition, curve metrics, and DV01-neutral trade recommendations with carry/roll-down estimates." ;
                    oc:expectedOutcome "Complete analysis output with trade recommendations" ;
                    oc:stepDependsOn _:ref_790281f1df82afd9 ;
                    oc:stepId "synthesize" ],
                _:ref_0cc274ba27c962db,
                _:ref_33eabdb094d67d42,
                _:ref_6206c02abbebd3c4,
                _:ref_621e7d431b467c67,
                _:ref_790281f1df82afd9 ;
            oc:workflowId "swap-curve-analysis" ;
            oc:workflowName "Swap Curve Strategy Analysis" ] ;
    oc:impartsKnowledge oc:kn_235e88f4,
        oc:kn_3138ef72,
        oc:kn_3310072b,
        oc:kn_4ada85e9,
        oc:kn_4b4baa62,
        oc:kn_4e9600a1,
        oc:kn_5f80f328,
        oc:kn_97ea3d9e,
        oc:kn_c84deebf ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "analyze swap curves",
        "compare swap rates across currencies",
        "compute swap spreads",
        "decompose real rates from nominal and inflation curves",
        "identify steepener flattener butterfly trades",
        "price interest rate swaps at multiple tenors" ;
    oc:yieldsState oc:CurveTradesIdentified,
        oc:SwapCurveBuilt,
        oc:SwapSpreadsComputed .

oc:kn_235e88f4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning any swap curve analysis" ;
    oc:directiveContent "Always build the full swap curve first, overlay the government curve to compute swap spreads, then add inflation breakevens for real rate decomposition. Curve metrics and historical context drive trade ideas." ;
    oc:hasRationale "Layered analysis from swap pricing → government overlay → inflation decomposition ensures systematic coverage of all curve dimensions." ;
    oc:severityLevel "HIGH" .

oc:kn_3138ef72 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When calling ir_swap, interest_rate_curve, or inflation_curve tools" ;
    oc:directiveContent "Use two-phase tool calls for MCP tools: first list/search to discover available templates, then price/calculate at specific tenors." ;
    oc:hasRationale "Two-phase discovery-then-pricing avoids errors from unknown indices or unavailable tenors and ensures correct parameter usage." ;
    oc:severityLevel "HIGH" .

oc:kn_3310072b a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """### Swap Curve Table
| Tenor | Swap Rate (%) | Govt Yield (%) | Swap Spread (bp) | DV01 | Inflation BE (%) | Real Rate (%) |
### Curve Metrics
| Metric | Current |
| 2s10s slope, 5s30s slope, 2s5s10s butterfly, Curve shape |
### Real Rate Decomposition
| Tenor | Nominal Swap | Inflation BE | Real Rate | Signal (Accommodative/Restrictive) |
### Curve Trade Recommendation
Structure, legs, DV01-neutral notionals, 3M carry, 3M roll-down, breakeven curve move, target, stop-loss, thesis.""" ;
    oc:templateVariables "2s10s slope",
        "2s5s10s butterfly",
        "5s30s slope",
        "Breakeven",
        "Carry",
        "Curve shape",
        "DV01",
        "Govt Yield",
        "Inflation BE",
        "Legs",
        "Notionals",
        "Real Rate",
        "Roll-down",
        "Signal",
        "Stop-loss",
        "Structure",
        "Swap Rate",
        "Swap Spread",
        "Target",
        "Tenor",
        "Thesis" .

oc:kn_4ada85e9 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing curve metrics and decompositions from raw pricing data" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """swap_spread = swap_rate - government_yield  # at each tenor
real_rate = nominal_swap_rate - inflation_breakeven  # at each tenor
slope_2s10s = swap_rate_10y - swap_rate_2y
butterfly_2s5s10s = swap_rate_2y - 2*swap_rate_5y + swap_rate_10y""" .

oc:kn_4b4baa62 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "Do not attempt to price swaps yourself — let the MCP tools handle pricing. Focus on analyzing curve shape and recommending trades." ;
    oc:hasRationale "Manual swap pricing is error-prone and inconsistent with market conventions; MCP tools provide accurate, real-time pricing." ;
    oc:severityLevel "HIGH" .

oc:kn_4e9600a1 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before execution" ;
    oc:directiveContent "Requires access to MCP tools: ir_swap, interest_rate_curve, inflation_curve, tscc_historical_pricing_summaries, and qa_macroeconomic." ;
    oc:hasRationale "All analysis depends on real-time pricing and curve data from these external tools." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5f80f328 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When recommending any curve trade" ;
    oc:directiveContent "For all trade recommendations, always include DV01-neutral sizing and carry/roll-down estimates." ;
    oc:hasRationale "DV01-neutral sizing ensures risk-equivalent positions across legs; carry/roll-down estimates quantify the cost of holding the trade over time." ;
    oc:severityLevel "CRITICAL" .

oc:kn_97ea3d9e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing swap spreads and real rate decomposition" ;
    oc:directiveContent "Compute swap spread as swap rate minus government yield at each tenor. Compute real rate as nominal swap rate minus inflation breakeven at each tenor." ;
    oc:hasRationale "These are the standard market conventions for decomposing the swap curve into credit/funding and inflation components." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c84deebf a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing full swap curve analysis" ;
    oc:directiveContent "1. Discover swap templates via ir_swap list mode for target currency. 2. Build swap curve via ir_swap price mode at standard tenors (2Y, 5Y, 7Y, 10Y, 20Y, 30Y). 3. Overlay government curve via interest_rate_curve for same currency. 4. Decompose inflation via inflation_curve (search then calculate). 5. Compute curve metrics: 2s10s slope, 5s30s slope, 2s5s10s butterfly, classify shape. 6. Synthesize into swap curve table, swap spreads, real rates, curve metrics, and DV01-neutral trade recommendations." ;
    oc:stepOrder 1 .

_:ref_0a600e57c8273326 a oc:WorkflowStep ;
    dcterms:description "**Overlay Government Curve:** Call `interest_rate_curve` (list then calculate) for the same currency. Compute swap spread = swap rate minus government yield at each tenor." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_40d408c1b19d4ad4 a oc:WorkflowStep ;
    dcterms:description "**Compute Curve Metrics:** From the swap curve: 2s10s slope, 5s30s slope, 2s5s10s butterfly. Note curve shape classification." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_77fec3e7781c7dd7 a oc:WorkflowStep ;
    dcterms:description "**Synthesize:** Combine into a complete analysis with swap curve table, swap spreads, real rate decomposition, curve metrics, and trade recommendations with DV01-neutral sizing." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_9ca1b73354726b22 a oc:WorkflowStep ;
    dcterms:description "**Inflation Decomposition:** Call `inflation_curve` (search then calculate). Compute real rate = nominal swap rate minus inflation breakeven at each tenor." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_9fce47285d3a9aca a oc:WorkflowStep ;
    dcterms:description "**Build Swap Curve:** Call `ir_swap` in price mode for standard tenors (2Y, 5Y, 7Y, 10Y, 20Y, 30Y). Extract par swap rate and DV01 at each point." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_ebbfa2fb7e552c10 a oc:WorkflowStep ;
    dcterms:description "**Discover Swap Templates:** Call `ir_swap` in list mode for the target currency. Identify available indices and tenors." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_0cc274ba27c962db a oc:WorkflowStep ;
    dcterms:description "Call inflation_curve (search then calculate). Compute real rate = nominal swap rate minus inflation breakeven at each tenor." ;
    oc:stepDependsOn _:ref_621e7d431b467c67 ;
    oc:stepId "inflation-decomposition" .

_:ref_33eabdb094d67d42 a oc:WorkflowStep ;
    dcterms:description "Call interest_rate_curve (list then calculate) for same currency. Compute swap spread = swap rate minus government yield at each tenor." ;
    oc:expectedOutcome "Government yield curve and swap spreads at each tenor" ;
    oc:stepDependsOn _:ref_621e7d431b467c67 ;
    oc:stepId "overlay-govt-curve" .

_:ref_4877038466fd7862 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_0a600e57c8273326,
        _:ref_40d408c1b19d4ad4,
        _:ref_77fec3e7781c7dd7,
        _:ref_9ca1b73354726b22,
        _:ref_9fce47285d3a9aca,
