    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_6206c02abbebd3c4 a oc:WorkflowStep ;
    dcterms:description "Discover available swap templates for target currency via ir_swap list mode" ;
    oc:expectedOutcome "List of available indices and tenors for the currency" ;
    oc:stepId "discover-templates" .

_:ref_790281f1df82afd9 a oc:WorkflowStep ;
    dcterms:description "Compute curve metrics: 2s10s slope, 5s30s slope, 2s5s10s butterfly. Classify curve shape as Normal/Flat/Inverted/Humped." ;
    oc:expectedOutcome "Curve slope metrics and shape classification" ;
    oc:stepDependsOn _:ref_0cc274ba27c962db,
        _:ref_33eabdb094d67d42,
        _:ref_621e7d431b467c67 ;
    oc:stepId "compute-metrics" .

_:ref_621e7d431b467c67 a oc:WorkflowStep ;
    dcterms:description "Price swaps at standard tenors (2Y, 5Y, 7Y, 10Y, 20Y, 30Y) via ir_swap price mode. Extract par swap rate and DV01 at each point." ;
    oc:expectedOutcome "Complete swap curve with rates and DV01s at all standard tenors" ;
    oc:stepDependsOn _:ref_6206c02abbebd3c4 ;
    oc:stepId "build-swap-curve" .

