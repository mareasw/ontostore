                    oc:sectionTitle "Phase 7: Generate the HTML Report" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Single-Company Earnings Preview" ],
        [ a oc:Section ;
