                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 4 ;
                                                            oc:itemText "Example: `\"Barclays upgraded WMT to Overweight with $210 price target on Jan 15, 2026.\" — <a href=\"https://www.investing.com/news/barclays-upgrades-wmt\" target=\"_blank\">Investing.com, Jan 15 2026</a>. Query: search(\"WMT analyst ratings price target upgrades downgrades\")`" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "Write the key finding or excerpt from the search result." ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "**MANDATORY: Include the source URL** returned by the Kensho `search` tool as a clickable `<a href=\"[URL]\" target=\"_blank\">` hyperlink. This is the most important part — readers must be able to click through to the original source." ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "Format: `\"[finding/excerpt]\" — <a href=\"[URL]\" target=\"_blank\">[Source Title or Publication]</a>. Query: search(\"[query used]\")`" ] ] ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Source & Derivation**: This is the critical column. **Every row must have a specific, detailed source — not just a label.** Follow these rules strictly:" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Value**: The exact figure as displayed in the report (e.g., \"$152.3B\", \"24.5%\", \"28.1x\"). For non-numeric facts, leave blank or write \"N/A\"." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Ref #**: Sequential ID matching the hyperlink anchors in the report body (`ref-1`, `ref-2`, etc.). Each row has an `id=\"ref-N\"` attribute so hyperlinks scroll to it." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Fact**: Human-readable label (e.g., \"Q3 FY2026 Revenue\", \"LTM P/E — WMT\", \"Management flagged tariff headwinds\", \"Barclays upgraded to Overweight\")" ] ],
                                [ a oc:BlockQuote ;
                                    oc:blockType "blockquote" ;
                                    oc:contentOrder 3 ;
                                    oc:quoteContent "**\"Analysis is AI-generated — please confirm all outputs\"**" ],
