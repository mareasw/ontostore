                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "The specific metrics that will determine if this is a good or bad quarter beyond the EPS number" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "For each: what the metric is, what consensus/management expects, why it matters" ] ] ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Key Metrics Beyond Headline EPS** (bulleted list, 3-5 items):" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 9 ;
                            oc:sectionTitle "Report Structure (4-5 pages total)" ] ;
                    oc:sectionLevel 2 ;
