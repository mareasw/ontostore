_:ref_3bcc67e4f3f234a0 a oc:WorkflowStep ;
    dcterms:description "**Calculate derived metrics** from the raw data now in context:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem _:ref_0f17060bf64c1512,
                _:ref_136b2b4534615708,
                _:ref_342d7b22c025fbf4,
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "Gross margin % = gross_profit / revenue (per quarter)" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 7 ;
                    oc:itemText "NTM P/E per company = latest price / NTM EPS, where **NTM EPS = sum of the next 4 quarterly consensus mean EPS estimates** from `consensus-eps.csv`. Add all 4 quarters' consensus_mean_eps values for each ticker. If fewer than 4 forward quarters are available for a peer, mark NTM P/E as \"n/a\". Note in the appendix which 4 quarters were summed." ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "Operating margin % = operating_income / revenue (per quarter)" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 5 ;
                    oc:itemText "Segment y/y growth % = match segment by name to year-ago Q; if missing, note \"y/y not available\"" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 6 ;
                    oc:itemText "LTM P/E per company = latest price / sum of most recent 4 quarterly EPS (check which 4 quarters are available per ticker using `peer-eps.csv`)" ] ] ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

