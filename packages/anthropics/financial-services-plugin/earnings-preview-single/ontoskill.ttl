                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "Example: `LTM P/E = <a href='#ref-20'>Price $172.35</a> / (<a href='#ref-8'>Q1 EPS $1.47</a> + <a href='#ref-9'>Q2 EPS $1.84</a> + <a href='#ref-10'>Q3 EPS $1.53</a> + <a href='#ref-11'>Q4 EPS $1.80</a>) = $172.35 / $6.64 = 25.9x`" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
