    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet,
        oc:EnvironmentReady,
        oc:NetworkAvailable ;
    oc:resolvesIntent "analyze upcoming company earnings",
        "create equity research preview",
        "generate earnings preview report",
        "preview quarterly earnings for a stock" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_06476633 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Phases 2-5 (data collection)" ;
    oc:directiveContent "Never compute derived metrics (margins, growth rates, P/E, returns) during data collection phases. Write raw data only to intermediate files. Calculations happen only in Phase 6 (Verification)." ;
    oc:hasRationale "Separating raw data collection from calculation enables independent verification and prevents propagation of errors through the pipeline." ;
    oc:severityLevel "HIGH" .

oc:kn_18cae34c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing or displaying P/E ratios" ;
    oc:directiveContent "All valuation ratios must be explicitly labeled as LTM or NTM. Never use 'trailing' or 'forward'. NTM EPS = sum of next 4 quarterly consensus mean EPS estimates, NOT a single annual figure." ;
    oc:hasRationale "Ambiguous ratio labels cause reader confusion. Precise LTM/NTM nomenclature is standard in institutional equity research." ;
    oc:severityLevel "HIGH" .

oc:kn_2731970d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Report writing (Phase 7)" ;
    oc:directiveContent "Target 4-5 printed pages. Use tight, punchy bullet points. Every sentence must earn its place. If you can say it in fewer words, do so. Take an opinionated view backed by data." ;
    oc:hasRationale "Concise reports are more valuable to time-constrained portfolio managers. Verbosity obscures the investment thesis." ;
    oc:severityLevel "MEDIUM" .

oc:kn_324c4a19 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Creating charts in Phase 7" ;
    oc:directiveContent "Use the pre-built Chart.js helper functions from report-template.md (createRevEpsChart, createMarginChart, createRevGrowthChart, createAnnotatedPriceChart, createCompPerfChart, createPEChart). Each chart call must be in its own <script> tag wrapped in try-catch." ;
    oc:hasRationale "Pre-built helpers are debugged and tested. Custom inline Chart.js code risks bugs that break chart rendering." ;
    oc:severityLevel "MEDIUM" .

oc:kn_48a1f0c2 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Immediately before report generation (Phase 7)" ;
    oc:directiveContent "Before Phase 7, verify all 11 intermediate files exist and are non-empty by reading each one individually. If any file is missing, STOP and report which file failed." ;
    oc:hasRationale "Missing intermediate data files will produce a report with fabricated or compressed-data errors." ;
    oc:severityLevel "CRITICAL" .

oc:kn_70f36941 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Throughout all research phases (Phases 1-6) and before report generation (Phase 7)" ;
    oc:directiveContent "All raw data from MCP tool calls MUST be written to files in /tmp/earnings-preview/ immediately after each tool call returns — before moving to the next call. Before generating the HTML report (Phase 7), ALL intermediate files must be read back into context." ;
    oc:hasRationale "Protects data from context window compression. Earlier conversation turns may be summarized and WILL contain errors if relied upon." ;
    oc:severityLevel "CRITICAL" .

oc:kn_822a0b66 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Multiple executions of the skill" ;
    oc:directiveContent "The report generation pipeline is NOT idempotent — re-running will overwrite intermediate files and regenerate the report with potentially different data if market data has changed between runs." ;
    oc:hasRationale "Each run fetches live market data, so outputs reflect the point-in-time snapshot of when the skill was executed." .

oc:kn_87da24a0 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Phase 6 (Verification) and all calculations" ;
    oc:directiveContent "For multi-step calculations (implied quarterly figures from guidance, LTM P/E, y/y growth rates), write out each step explicitly and verify intermediate results before using them in the next step. If A+B+C=X, verify X is arithmetically correct." ;
    oc:hasRationale "Multi-step calculations are the highest risk for errors in equity research. Explicit step-by-step verification catches arithmetic mistakes." ;
    oc:severityLevel "HIGH" .

oc:kn_a525d276 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "All report body text in Phase 7" ;
    oc:directiveContent "Every claim in the report — numeric AND non-numeric — MUST be wrapped in an <a href=\"#ref-N\" class=\"data-ref\"> hyperlink pointing to the corresponding entry in the Appendix. Every number must be a clickable link." ;
    oc:hasRationale "Enforces full data provenance and traceability, which is the core integrity mechanism of the report." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b0c4e26f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "All data collection phases (Phases 1-5)" ;
    oc:directiveContent "The ONLY permitted data sources are Kensho Grounding MCP (search) and S&P Global MCP (kfinance). Never use WebSearch, WebFetch, brave_search, google_search, or any generic web search tool — even if Kensho is slow or returns no results." ;
    oc:hasRationale "Ensures data provenance is fully traceable and prevents hallucinated or unverified data from entering the report." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b2732358 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When labeling any quarter reference in the report" ;
    oc:directiveContent "NEVER infer the fiscal quarter from the calendar report date. Always use the fiscal quarter and fiscal year exactly as stated in the earnings call name returned by get_next_earnings_from_identifiers or get_earnings_from_identifiers." ;
    oc:hasRationale "Many companies have non-standard fiscal years (e.g., Walmart FY ends Jan 31). Mislabeling fiscal quarters is a critical factual error." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c6955c98 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When quoting management in <blockquote> tags" ;
    oc:directiveContent "Never paraphrase, rearrange, combine sentences, or 'clean up' management quotes in blockquote tags. Every blockquote must be a verbatim, word-for-word copy-paste excerpt from the transcript." ;
    oc:hasRationale "Paraphrased quotes misrepresent management statements and undermine the report's credibility." ;
    oc:severityLevel "HIGH" .

oc:kn_cd750253 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "Final review before output" ;
    oc:directiveContent "Before finalizing the report, scan every number in the report body and verify: (1) each is wrapped in <a href=\"#ref-N\"> tag, (2) each has a corresponding appendix row, (3) each appendix formula has hyperlinked components, (4) each Kensho-sourced claim has a source URL." ;
    oc:hasRationale "Completeness of the hyperlink/appendix system is the report's primary integrity mechanism." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ddd006bc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Stock return calculations in Phase 6" ;
    oc:directiveContent "When computing comparative stock returns, ALL tickers MUST use the exact same start and end dates. Find the first trading date that appears in ALL tickers' data and use that as the common base date." ;
    oc:hasRationale "Different base dates for different tickers produce misleading comparisons that distort relative performance." ;
    oc:severityLevel "HIGH" .

