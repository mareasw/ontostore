                    oc:sectionTitle "Phase 5: Financial Data Collection" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "**Charts must use real data**: Every chart populated with actual MCP data. Never fabricate." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**CONCISE**: Target 4-5 printed pages. Every sentence must carry weight. Use bullets, not paragraphs, wherever possible. If a section feels long, cut it." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Take a view**: This is an earnings preview, not a summary. State what you expect, what matters, and why. Be opinionated but back it with data." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Management quotes without headers**: Weave 3-4 key management quotes from the most recent call directly into the narrative as blockquotes. Do not create a \"Key Management Quotes\" section heading — let them flow naturally as supporting evidence." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Professional tone**: Sell-side equity research style — analytical, direct, data-driven." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Be specific with numbers**: \"$52.4B revenue, up 5.2% y/y\" not \"strong revenue growth.\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**NO EMOJIS**: Do not use any emojis anywhere in the report. This is a professional research document." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 8 ;
                                    oc:itemText "**Competitor context**: Frame valuation relative to peers. A 25x P/E means nothing without knowing peers trade at 20x or 35x." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 9 ;
                                    oc:itemText "**Hyperlinked claims**: Every factual claim — numeric or qualitative — must be an `<a class=\"data-ref\">` tag linking to its appendix entry. Numbers: `<a href=\"#ref-1\" class=\"data-ref\">$152.3B</a>`. Qualitative: `<a href=\"#ref-25\" class=\"data-ref\">management flagged tariff headwinds as the primary margin risk</a>`. No fact should appear without a traceable source in the appendix." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 11 ;
                    oc:sectionTitle "Writing Guidelines" ],
