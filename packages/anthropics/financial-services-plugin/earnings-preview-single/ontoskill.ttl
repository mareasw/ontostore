                                                [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 5 ;
                                                    oc:textContent "**For transcript-sourced claims (quotes, management commentary, guidance):**" ],
                                                [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 6 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 4 ;
                                                            oc:itemText "Example: `\"We expect comp sales growth of 3-4% in Q4\" — CEO John Furner. Source: Q3 FY2026 Earnings Call Transcript (key_dev_id: 12345678)`" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
