@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_pitch_deck a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "pitch-deck" ;
    skos:broader "Document populator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/pitch-deck" ;
    oc:contentHash "2447bff4d8b50d9d5b75ff25d1fa8c0cc5a30c88e99da9e76ee3efa0a99a67d8" ;
    oc:dependsOnSkill oc:skill_pptx_manipulation,
        oc:skill_xlsx_manipulation ;
    oc:differentia "fills investment banking pitch deck PowerPoint templates with source data using programmatic XML and python-pptx editing with validation loops" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "PowerPoint template file (.pptx) and source data files (Excel, CSV, PDF)" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Populates investment banking pitch deck templates with data from source files. Use when: user provides a PowerPoint template to fill in, user has source data (Excel/CSV) to populate into slides, user mentions populating or filling a pitch deck template, or user needs to transfer data into existing slide layouts. Not for creating presentations from scratch." ;
    oc:hasName "pitch-deck" ;
    oc:impartsKnowledge oc:kn_4527f7ee,
        oc:kn_5e523037,
        oc:kn_6149909e,
        oc:kn_694c01af,
        oc:kn_752ce21d,
        oc:kn_7bbc1bb4,
        oc:kn_a51a68e0,
        oc:kn_c2d004f4,
        oc:kn_e9de694c ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:FileExists,
        oc:ToolInstalled ;
    oc:resolvesIntent "create investment banking presentations from templates",
        "fill PowerPoint template from source files",
        "fix formatting issues in pitch deck slides",
        "populate pitch deck template with data",
        "transfer Excel/CSV data into slide layouts" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_4527f7ee a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During Phase 4 validation iterations when issues persist" ;
    oc:directiveContent "Limit the validate-fix loop to 3 cycles maximum. After 3 cycles, document remaining unresolved issues with slide numbers and descriptions, then deliver the file with an explicit disclaimer listing what requires manual review." ;
    oc:hasRationale "Some issues (font rendering, complex shape alignment) fundamentally require manual intervention in PowerPoint — indefinite cycling wastes effort and cannot resolve rendering-engine limitations" ;
    oc:severityLevel "MEDIUM" .

oc:kn_5e523037 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "During Phase 5 final verification before delivery" ;
    oc:directiveContent "A successfully populated pitch deck passes the final quality checklist: all figures match sources, no [bracket] placeholders remain, tables are actual objects, text is readable against backgrounds, formatting is consistent, no placeholder boxes retained, and logo is positioned correctly." ;
    oc:hasRationale "The checklist ensures systematic verification across data accuracy, content mapping, formatting, and template compliance — preventing common omissions" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6149909e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any template population work" ;
    oc:directiveContent "Create a backup copy of the original template to [filename]_backup.pptx before any modifications. Direct XML editing or unexpected errors can corrupt files irreversibly." ;
    oc:hasRationale "PowerPoint files have complex interdependencies (relationship files, content types) and direct XML editing can corrupt the entire file if mistakes are made" ;
    oc:severityLevel "HIGH" .

oc:kn_694c01af a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When programmatically editing PowerPoint files" ;
    oc:directiveContent "Use python-pptx for creating new tables, adding text boxes, inserting images, and most shape creation. Use direct XML editing ONLY for modifying properties that python-pptx doesn't expose — never for creating tables from scratch due to relationship management risks." ;
    oc:hasRationale "Direct XML table creation is error-prone due to interdependencies and relationship file management; python-pptx handles these automatically and safely" ;
    oc:severityLevel "HIGH" .

oc:kn_752ce21d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any table in a PowerPoint slide" ;
    oc:directiveContent "Never create tables using pipe characters (|), tabs, or spaces as column separators. All tabular data must be actual PowerPoint table objects created via python-pptx or proper OOXML table elements." ;
    oc:hasRationale "Text-based 'tables' cannot align properly, cannot be formatted consistently, cannot be edited by recipients, and signal amateur work" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7bbc1bb4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying formatting and populating content across all slides" ;
    oc:directiveContent "Boxes at the same hierarchy level must use identical font sizes, and the same data appearing on multiple slides must use identical figures, formatting, and terminology. If a metric is updated on one slide, update all occurrences." ;
    oc:hasRationale "Cross-slide inconsistencies (different figures for the same metric, mismatched font sizes on parallel elements) undermine credibility in client-facing investment banking materials" ;
    oc:severityLevel "HIGH" .

oc:kn_a51a68e0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating any template that contains colored instruction/guidance boxes" ;
    oc:directiveContent "Never populate data into placeholder instruction boxes while keeping their colored formatting. Instruction boxes tell you WHAT content to create, not HOW to format it. Delete instruction boxes entirely and create new content with production formatting (dark text on light background)." ;
    oc:hasRationale "Retaining placeholder formatting results in unprofessional output with light text on bright colored backgrounds — a common failure mode where the agent confuses input scaffolding for output styling" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c2d004f4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "At the very beginning of every pitch deck population task" ;
    oc:directiveContent "Read all four reference files (formatting-standards.md, slide-templates.md, xml-reference.md, calculation-standards.md) at task start before beginning any work. They contain critical patterns and anti-patterns that affect approach." ;
    oc:hasRationale "Waiting until issues arise leads to rework — the reference files contain preventative knowledge about formatting, XML patterns, content mapping, and calculation verification" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e9de694c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating output slides using LibreOffice PDF/image conversion" ;
    oc:directiveContent "LibreOffice does not render PowerPoint files accurately — it mangles fonts, gradients, shape positions, text wrapping, and some table formatting. Always include a disclaimer recommending Microsoft PowerPoint review before distribution." ;
    oc:hasRationale "A slide that passes visual validation in LibreOffice may still have font substitution, subtle alignment shifts, or gradient problems in Microsoft PowerPoint" ;
    oc:severityLevel "HIGH" .

