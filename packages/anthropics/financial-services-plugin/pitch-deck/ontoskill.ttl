                            oc:contentOrder 4 ;
                            oc:textContent "**Header Row:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Column Alignment:**" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Text columns: Left-aligned (header and content)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
