oc:skill_financial_services_plugin_equity_research a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "equity-research" ;
    skos:broader "Research analysis workflow" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/equity-research" ;
    oc:contentHash "6d104ffb67dedebe64e4d5e02d1b5fe87b54fe4ee58dd8ed1f9075806162aab7" ;
    oc:differentia "Chains MCP-based financial data tools (IBES consensus, fundamentals, pricing, macro) into structured equity research snapshots with investment thesis" ;
    oc:handlesFailure oc:DataUnavailable,
        oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasAllowedTool "qa_company_fundamentals",
        "qa_historical_equity_price",
        "qa_ibes_consensus",
        "qa_macroeconomic",
        "tscc_historical_pricing_summaries" ;
    oc:hasArgumentHint "ticker or company name" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Generate comprehensive equity research snapshots combining analyst consensus estimates, company fundamentals, historical prices, and macroeconomic context. Use when researching stocks, comparing estimates to actuals, analyzing company financials, assessing equity valuations, or building investment cases." ;
    oc:hasName "equity-research" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "You are an expert equity research analyst. Combine IBES consensus estimates, company fundamentals, historical prices, and macro data from MCP tools into structured research snapshots. Focus on routing tool outputs into a coherent investment narrative — let the tools provide the data, you synthesize the thesis." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Every piece of data must connect to an investment thesis. Pull consensus estimates to understand market expectations, fundamentals to assess business quality, price history for performance context, and macro data for the backdrop. The key question is always: where might consensus be wrong? Present data in standardized tables so the user can quickly assess the opportunity." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Principles" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**`qa_ibes_consensus`** — IBES analyst consensus estimates and actuals. Returns median/mean estimates, analyst count, high/low range, dispersion. Supports EPS, Revenue, EBITDA, DPS." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**`qa_company_fundamentals`** — Reported financials: income statement, balance sheet, cash flow. Historical fiscal year data for ratio analysis." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**`qa_macroeconomic`** — Macro indicators (GDP, CPI, unemployment, PMI). Use to establish the economic backdrop for the company's sector." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**`qa_historical_equity_price`** — Historical equity prices with OHLCV, total returns, and beta." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**`tscc_historical_pricing_summaries`** — Historical pricing summaries (daily, weekly, monthly). Alternative/supplement for price history." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Available MCP Tools" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_7373d2cea980058d ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Tool Chaining Workflow" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "### Consensus Estimates" ;
                                    oc:tableMarkdown """| Metric | FY1 | FY2 | # Analysts | Dispersion |
|--------|-----|-----|------------|------------|
| EPS | ... | ... | ... | ...% |
| Revenue (M) | ... | ... | ... | ...% |
| EBITDA (M) | ... | ... | ... | ...% |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Consensus Estimates" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Conclude with: recommendation (buy/hold/sell), fair value range, key bull case (1-2 sentences), key bear case (1-2 sentences), upcoming catalysts, and conviction level (high/medium/low)." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Investment Thesis" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "### Valuation Summary" ;
                                    oc:tableMarkdown """| Metric | Current | Context |
|--------|---------|---------|
| Forward P/E | ... | vs sector/history |
| EV/EBITDA | ... | vs sector/history |
| Dividend Yield | ... | ... |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Valuation Summary" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "### Financials Summary" ;
                                    oc:tableMarkdown """| Metric | FY-2 | FY-1 | FY0 (LTM) | Trend |
|--------|------|------|-----------|-------|
| Revenue (M) | ... | ... | ... | ... |
| Gross Margin | ... | ... | ... | ... |
| Operating Margin | ... | ... | ... | ... |
| ROE | ... | ... | ... | ... |
| Net Debt/EBITDA | ... | ... | ... | ... |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Financials Summary" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Output Format" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Equity Research Analysis" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: equity-research
description: Generate comprehensive equity research snapshots combining analyst consensus estimates, company fundamentals, historical prices, and macroeconomic context. Use when researching stocks, comparing estimates to actuals, analyzing company financials, assessing equity valuations, or building investment cases.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Sequential tool-chaining workflow to produce a comprehensive equity research note from consensus, fundamentals, pricing, and macro data" ;
            oc:hasStep _:ref_0e0e5ab7b76a4b9c,
                _:ref_1e5b9ef26bc7bef3,
                _:ref_23edd95027a236a6,
                [ a oc:WorkflowStep ;
                    dcterms:description "Combine all data into research note with consensus tables, financials summary, valuation metrics, and investment thesis (recommendation, fair value range, bull/bear cases, catalysts, conviction level)." ;
                    oc:expectedOutcome "Complete equity research snapshot with structured tables and investment thesis" ;
                    oc:stepDependsOn _:ref_0e0e5ab7b76a4b9c,
                        _:ref_1e5b9ef26bc7bef3,
                        _:ref_23edd95027a236a6,
                        _:ref_4c073c76477e0276,
                        _:ref_ff689237ed73af9c ;
                    oc:stepId "synthesize" ],
                _:ref_4c073c76477e0276,
                _:ref_ff689237ed73af9c ;
            oc:workflowId "equity-research-snapshot" ;
            oc:workflowName "Equity Research Snapshot" ],
        _:ref_7373d2cea980058d ;
    oc:impartsKnowledge oc:kn_3f07b396,
        oc:kn_9846f161,
        oc:kn_9a1e6e33,
        oc:kn_ba50470a,
        oc:kn_c0c341af,
        oc:kn_fc4b0025 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "analyze equity valuation",
        "assess company financials",
        "build investment case",
        "compare analyst estimates to actuals",
        "generate equity research snapshot",
        "research a stock" ;
    oc:yieldsState oc:DocumentCreated,
        oc:ResearchCompleted .

oc:kn_3f07b396 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When formatting research output" ;
    oc:directiveContent "Present all data in standardized tables (Consensus Estimates, Financials Summary, Valuation Summary) so the user can quickly assess the opportunity." ;
    oc:hasRationale "Standardized tabular format enables rapid comparison across companies and time periods" .

oc:kn_9846f161 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Always when running equity research workflow" ;
    oc:directiveContent "Chain tools in sequence: consensus → fundamentals → price history → recent pricing → macro → synthesize. Let tools provide data, you synthesize the thesis." ;
    oc:hasRationale "Structured tool chaining ensures comprehensive coverage and prevents gaps in the research snapshot" .

oc:kn_9a1e6e33 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing any equity research output" ;
    oc:directiveContent "Every piece of data must connect to an investment thesis. The key question is always: where might consensus be wrong?" ;
    oc:hasRationale "Data without thesis is noise; the value of equity research lies in identifying where market expectations diverge from reality" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ba50470a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling qa_ibes_consensus" ;
    oc:directiveContent "Pull FY1 and FY2 consensus estimates noting analyst count and dispersion. High dispersion signals uncertainty and potential opportunity." ;
    oc:hasRationale "Analyst count validates consensus reliability; dispersion identifies where expectations are most contested" .

oc:kn_c0c341af a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On tool call failure or empty results" ;
    oc:directiveContent "If a tool call fails or returns no data, note the gap explicitly and proceed with available data rather than halting the entire workflow." ;
    oc:hasRationale "Partial research with documented gaps is more useful than no output at all" .

oc:kn_fc4b0025 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building valuation metrics" ;
    oc:directiveContent "Always compute forward P/E from current price divided by consensus EPS, not trailing P/E alone. Include 52-week range position and beta for context." ;
    oc:hasRationale "Forward valuation based on consensus is more relevant for investment decisions than backward-looking metrics" .

_:ref_014591efb5fe281e a oc:WorkflowStep ;
    dcterms:description "**Synthesize:** Combine into a research note with consensus tables, financials summary, valuation metrics (forward P/E from price / consensus EPS), and macro backdrop." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_1a2fe9fbdb5ce1e1 a oc:WorkflowStep ;
    dcterms:description "**Macro Context:** Call `qa_macroeconomic` for GDP, CPI, and policy rate in the company's primary market. Summarize whether macro is tailwind or headwind." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_4a07d335f01fa25b a oc:WorkflowStep ;
    dcterms:description "**Consensus Snapshot:** Call `qa_ibes_consensus` for FY1 and FY2 estimates (EPS, Revenue, EBITDA, DPS). Note analyst count and dispersion." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_9b08b1ba20646362 a oc:WorkflowStep ;
    dcterms:description "**Recent Price Detail:** Call `tscc_historical_pricing_summaries` for 3M daily data. Assess volume trends and recent momentum." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_e39a6496595396c7 a oc:WorkflowStep ;
    dcterms:description "**Price Performance:** Call `qa_historical_equity_price` for 1Y history. Compute YTD return, 1Y return, 52-week range position, beta." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_f36f1607551f6b35 a oc:WorkflowStep ;
    dcterms:description "**Historical Fundamentals:** Call `qa_company_fundamentals` for the last 3-5 fiscal years. Extract revenue growth, margins, leverage, returns (ROE, ROIC)." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_0e0e5ab7b76a4b9c a oc:WorkflowStep ;
    dcterms:description "Call qa_macroeconomic for GDP, CPI, and policy rate in company's primary market. Summarize tailwind or headwind." ;
    oc:expectedOutcome "Macro backdrop summarized with directional assessment for the sector" ;
    oc:stepId "macro-context" .

_:ref_1e5b9ef26bc7bef3 a oc:WorkflowStep ;
    dcterms:description "Call tscc_historical_pricing_summaries for 3M daily data. Assess volume trends and recent momentum." ;
    oc:expectedOutcome "Recent volume trends and momentum indicators assessed" ;
    oc:stepId "recent-pricing" .

_:ref_23edd95027a236a6 a oc:WorkflowStep ;
    dcterms:description "Call qa_ibes_consensus for FY1 and FY2 estimates (EPS, Revenue, EBITDA, DPS). Note analyst count and dispersion." ;
    oc:expectedOutcome "Consensus estimates table populated with median/mean estimates, analyst count, and dispersion" ;
    oc:stepId "consensus" .

_:ref_4c073c76477e0276 a oc:WorkflowStep ;
    dcterms:description "Call qa_company_fundamentals for last 3-5 fiscal years. Extract revenue growth, margins, leverage, returns (ROE, ROIC)." ;
    oc:expectedOutcome "Historical financial metrics extracted for trend and ratio analysis" ;
    oc:stepId "fundamentals" .

