oc:skill_financial_services_plugin_lbo_model a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "lbo-model" ;
    skos:broader "Financial model builder" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/lbo-model" ;
    oc:contentHash "64237e33e7301cb89823e92659789aaf3e5c50e07115abc4ef38a29b065e331a" ;
    oc:dependsOnSkill oc:skill_ontoskills_xlsx_manipulation ;
    oc:differentia "Completes LBO model templates in Excel with formulas, formatting, and validation for private equity transactions" ;
    oc:handlesFailure oc:CircularReference,
        oc:FileNotFound,
        oc:FormulaError,
        oc:InvalidInput ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Read",
        "Write" ;
    oc:hasArgumentHint "template file (xlsx) or deal assumptions" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "This skill should be used when completing LBO (Leveraged Buyout) model templates in Excel for private equity transactions, deal materials, or investment committee presentations. The skill fills in formulas, validates calculations, and ensures professional formatting standards that adapt to any template structure." ;
    oc:hasName "lbo-model" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent _:ref_0e044da8d252a9fa,
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "**This skill uses templates for LBO models. Always check for an attached template file first.**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**IMPORTANT**: When a file like `LBO_Model.xlsx` is attached, you MUST use it as your template - do not build from scratch. Even if the template seems complex or has more features than needed, copy it and adapt it to the user's requirements. Never decide to \"build from scratch\" when a template is provided." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Before starting any LBO model:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "TEMPLATE REQUIREMENT" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "For each cell that needs a formula, follow this hierarchy:" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
