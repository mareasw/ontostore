            oc:workflowName "Generate Sales/BD Tear Sheet" ] ;
    oc:impartsKnowledge oc:kn_210263ad,
        oc:kn_59557aad,
        oc:kn_87e0b6a0,
        oc:kn_8958cc18,
        oc:kn_97b5bc5e,
        oc:kn_9ea3472b,
        oc:kn_a9750cb5,
        oc:kn_e859df1b ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "create conversation starters for client meetings",
        "generate a sales briefing document",
        "prepare for a sales meeting",
        "research a prospect company for business development" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_210263ad a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building the query plan for data collection" ;
    oc:directiveContent "Execute three sequential queries: (1) Company profile + financials → write to company-profile.txt and financials.csv, (2) Strategy + earnings → write to earnings.txt, (3) Relationships + news → write to relationships.txt. Forward guidance and EPS data come from earnings.txt, not company-profile.txt." ;
    oc:hasRationale "Three queries is usually sufficient; for private companies, queries 2 and 3 may be sparse but still deliver qualitative value." ;
    oc:severityLevel "HIGH" .

oc:kn_59557aad a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "During final review of Conversation Starters" ;
    oc:directiveContent "Before finalizing each conversation starter, verify it contains at least one specific number, date, product name, or initiative name drawn from the tear sheet. A question that could apply to any company in the sector fails validation." ;
    oc:hasRationale "This validation ensures starters are genuinely tailored and demonstrate preparation." ;
    oc:severityLevel "CRITICAL" .

oc:kn_87e0b6a0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the Company Overview section (Section 2)" ;
    oc:directiveContent "Do NOT paste the CIQ company summary verbatim. Rewrite in plain language: say 'sells' not 'monetizes', say 'yearly revenue' not 'top-line CAGR'." ;
    oc:hasRationale "CIQ summaries read like SEC filings and will lose a non-finance audience." ;
    oc:severityLevel "HIGH" .

oc:kn_8958cc18 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing Conversation Starters (Section 7)" ;
    oc:directiveContent "Every conversation starter must reference a specific strategic priority from Section 3 and contain at least one specific number, date, product name, or initiative name from the tear sheet. Tag each starter with a suggested persona (CTO, CFO, etc.)." ;
    oc:hasRationale "Generic questions are useless; specificity demonstrates preparation and creates genuine engagement opportunities." ;
    oc:severityLevel "CRITICAL" .

oc:kn_97b5bc5e a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the target company is private or has limited public data" ;
    oc:directiveContent "For private companies: omit ticker, market cap, EPS. Financial Snapshot may have only revenue and employees. If earnings call data is unavailable, replace Strategic Priorities with 'Recent Developments' from news/announcements. If relationship data is unavailable, note 'Relationship data not available' and move on." ;
    oc:hasRationale "Private companies have sparse data; two data points showing scale and growth are enough for a sales meeting." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9ea3472b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the entire Sales/BD tear sheet" ;
    oc:directiveContent "This tear sheet should read like a briefing memo, not a data terminal. Prioritize readability over compression. Use warm, accessible language — a non-finance person should understand every sentence." ;
    oc:hasRationale "Sales reps are the audience; they need actionable context fast, not financial jargon." ;
    oc:severityLevel "HIGH" .

oc:kn_a9750cb5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Strategic Priorities & Management Commentary" ;
    oc:directiveContent "Strategic Priorities (Section 3) is NOT an earnings recap. Extract 3-5 strategic themes with thematic labels and supporting data points, not bullet-point earnings results." ;
    oc:hasRationale "Equity research tear sheets already cover earnings recaps; sales reps need actionable strategic themes to align their pitch." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e859df1b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating the Financial Snapshot table (Section 4)" ;
    oc:directiveContent "Financial Snapshot must be three rows maximum: Revenue, Gross Margin %, Employees. No EBITDA, no EV multiples, no balance sheet, no net income. Gross margin is the single profitability metric — it's intuitive for a sales audience." ;
    oc:hasRationale "Sales reps need to know scale, direction, and health — not institutional-grade financials." ;
    oc:severityLevel "HIGH" .

_:ref_0c8307a695b0875a a oc:WorkflowStep ;
    dcterms:description "Write Company Overview (Section 2) in 3-5 plain-language prose sentences. Rewrite CIQ summary — no investor jargon." ;
    oc:expectedOutcome "Readable narrative explaining what the company does, who its customers are, how it makes money, where it operates, and what makes it distinctive." ;
    oc:stepDependsOn _:ref_4d27b8cf327ea031 ;
    oc:stepId "compose-overview" .

_:ref_11acce62a4c2f501 a oc:WorkflowStep ;
    dcterms:description "Synthesize 2-3 conversation starters (Section 7) referencing specific strategic priorities from Section 3, tagged with persona. Validate each has specific data points." ;
    oc:expectedOutcome "Tailored, specific talking points that demonstrate preparation and create engagement windows." ;
    oc:stepDependsOn _:ref_5a2e25adef88a51e ;
    oc:stepId "compose-starters" .

_:ref_351a8fbba8478c00 a oc:WorkflowStep ;
    dcterms:description "Build Key Relationships & Ecosystem (Section 5): four labeled lists (Customers, Vendors/Technology, Partners, Competitors) with 3-5 names each and parenthetical descriptors." ;
    oc:expectedOutcome "Structured view of the prospect's ecosystem with actionable relationship context." ;
