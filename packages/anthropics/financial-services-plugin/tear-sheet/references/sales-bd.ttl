@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_tear_sheet_sales_bd a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "sales-bd" ;
    skos:broader "tear sheet generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/tear-sheet" ;
    oc:contentHash "8e54ebdb8b78ff269c216b3581ed328834a695cfd7e57fec48e8801e6be2d003" ;
    oc:differentia "produces narrative-driven briefing memos for sales and business development meetings, synthesizing company profile, strategic priorities, financials, relationships, and conversation starters" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_tear_sheet ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasArgumentHint "company name or ticker (optionally: target persona, product/service being sold)" ;
    oc:hasCategory "document" ;
    oc:impartsKnowledge oc:kn_2db34465,
        oc:kn_6b06ea2e,
        oc:kn_7927bf51,
        oc:kn_9b9dcea7,
        oc:kn_a169e092,
        oc:kn_a2744f2b,
        oc:kn_a8e3e6aa,
        oc:kn_c9aa6b07 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "brief sales team on prospect",
        "create conversation starters for client meeting",
        "generate sales briefing document",
        "prepare for sales meeting",
        "research prospect company for BD outreach" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_2db34465 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the Company Overview section" ;
    oc:directiveContent "Write in plain language prose, not investor jargon — say 'sells' not 'monetizes', 'yearly revenue' not 'top-line CAGR'. The audience is sales reps, not finance professionals." ;
    oc:hasRationale "Sales reps need to understand the prospect's business instantly; finance jargon creates a comprehension barrier that defeats the document's purpose" ;
    oc:severityLevel "HIGH" .

oc:kn_6b06ea2e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the Financial Snapshot table" ;
    oc:directiveContent "Limit the Financial Snapshot to exactly 3 rows: Revenue, Gross Margin %, and Employees. Use gross margin as the single profitability metric — not EBITDA, not net income." ;
    oc:hasRationale "A sales audience needs scale, direction, and one health signal. Gross margin is intuitive ('how much they keep after direct costs') and signals business health without requiring finance literacy" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7927bf51 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting the final sales/BD tear sheet document" ;
    oc:directiveContent "This is the warmest, most readable tear sheet type. Use 9pt body text, 1.15x line spacing. Company Overview and Strategic Priorities should take 40-50% of the page. Whitespace is a feature, not waste." ;
    oc:hasRationale "The document should feel like a briefing memo, not a data terminal. Readability directly impacts whether the sales rep absorbs and uses the information" ;
    oc:severityLevel "LOW" .

oc:kn_9b9dcea7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating Recent News & Developments" ;
    oc:directiveContent "Lead the Recent News section with the latest earnings report, then cover M&A, product launches, leadership changes. Always include upcoming catalysts under a 'Coming Up:' label — these are the best reasons for sales outreach." ;
    oc:hasRationale "Earnings reports set context for the entire meeting, and upcoming catalysts create natural engagement windows ('I noticed your Investor Day coming up in Q2...')" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a169e092 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating Conversation Starters" ;
    oc:directiveContent "Every conversation starter must reference a specific strategic priority from Section 3 and include at least one specific number, date, product name, or initiative name drawn from the tear sheet. Tag each with a suggested persona (CTO, CFO, etc.)." ;
    oc:hasRationale "Generic questions that could apply to any company are useless. Specificity demonstrates preparation and creates genuine engagement opportunities" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a2744f2b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the Company Overview for any sales/BD tear sheet" ;
    oc:directiveContent "Never paste the CIQ company summary directly into the Company Overview section. Always rewrite in 3-5 sentences of plain language." ;
    oc:hasRationale "CIQ summaries read like SEC filings and will lose a non-finance audience, undermining the briefing's effectiveness" ;
    oc:severityLevel "HIGH" .

oc:kn_a8e3e6aa a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When starting any sales/BD tear sheet research" ;
    oc:directiveContent "Execute exactly 3 queries in order: (1) company profile + financials, (2) strategy + earnings, (3) relationships + news. Write results to /tmp/tear-sheet/ immediately after each query. For private companies, sparse results on queries 2-3 are acceptable." ;
    oc:hasRationale "Three queries provide sufficient coverage for both public and private companies. Immediate writes prevent data loss and enable section-by-section assembly" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c9aa6b07 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the Key Relationships & Ecosystem section" ;
    oc:directiveContent "Every entry in Key Relationships must include a one-line parenthetical descriptor explaining what the relationship means, not just who the entity is." ;
    oc:hasRationale "A name alone doesn't help a rep — knowing that AWS is their 'primary cloud infrastructure' vendor reveals displacement or integration opportunities" ;
    oc:severityLevel "MEDIUM" .

