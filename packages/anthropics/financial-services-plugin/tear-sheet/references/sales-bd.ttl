                _:ref_a529fb8d5507adb9,
                [ a oc:WorkflowStep ;
                    dcterms:description "Apply formatting: 9pt body text, 1.15x line spacing, Company Overview + Strategic Priorities ~40-50% of page, relationships in two-column layout, conversation starters in indented block-style bullets." ;
                    oc:expectedOutcome "Polished 1-2 page briefing memo with warm, readable formatting." ;
                    oc:stepDependsOn _:ref_0c8307a695b0875a,
