                        _:ref_40268bd56dec7d89,
                        _:ref_81db7547b2d648e8,
                        _:ref_9b7abeeb08102d56 ;
                    oc:stepId "assemble-document" ],
                _:ref_81db7547b2d648e8,
                _:ref_9b7abeeb08102d56 ;
            oc:workflowId "corp-dev-tear-sheet" ;
            oc:workflowName "Corporate Development Tear Sheet Generation" ] ;
    oc:impartsKnowledge oc:kn_0d84aced,
        oc:kn_100e6809,
        oc:kn_1f4fed66,
        oc:kn_305154be,
        oc:kn_3a928bd4,
        oc:kn_51a0badd,
        oc:kn_8d412500,
        oc:kn_8d55ae8a,
