@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_financial_services_plugin_tear_sheet_corp_dev a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "corp-dev" ;
    skos:broader "Tear sheet" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/tear-sheet" ;
    oc:contentHash "be6033c08f0b90346ab64cc46336294aa644223621135a5aa8da03095be2afc0" ;
    oc:differentia "Generates corporate development target evaluation profiles focused on strategic fit, integration analysis, and acquisition assessment rather than investment narrative" ;
    oc:extends oc:skill_financial_services_plugin_tear_sheet ;
    oc:handlesFailure oc:DataNotFound,
        oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasArgumentHint "company name (required), optional: acquirer name, specific comps" ;
    oc:hasCategory "finance" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Default page length:** 1-2 pages. Corp Dev teams are comfortable with denser profiles and won't penalize a second page if the content is substantive." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "A target evaluation profile for an internal Corp Dev team assessing a potential acquisition. Unlike the IB/M&A profile (which tells a strategic *story* for a pitch), this is an analytical document focused on strategic fit: how the target's products, customers, technology, and operations overlap with or complement the acquirer's. The Corp Dev audience already knows their own company — they need to understand the target through the lens of \"should we buy this, and what would integration look like?\"" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Purpose" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent """**Query 5 — Valuation + peers:**
If user provided specific comps:
"[Comp company] enterprise value EV/Revenue EV/EBITDA revenue growth EBITDA margin"
Otherwise:
Use the competitors tool to identify 3-5 public peers, then pull EV/Revenue (NTM), EV/EBITDA (NTM), revenue growth %, and EBITDA margin % for each.
Also: "[Company] enterprise value market capitalization valuation multiples"
→ Valuation Context
→ **Immediately write** company multiples to `/tmp/tear-sheet/valuation.csv`
→ **Immediately write** peer data to `/tmp/tear-sheet/peer-comps.csv`""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**Query 2 — Financials:**
"[Company] annual income statement revenue gross profit EBITDA operating income net income capex free cash flow R&D expense total debt cash and equivalents last 4 fiscal years"
→ Financial Summary (pull 4 years; display 3; use the earliest year only for YoY growth computation. R&D is especially important for Corp Dev — they want to understand the target's investment in IP)
→ **Immediately write** raw values to `/tmp/tear-sheet/financials.csv`""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**Query 1 — Target profile:**
"[Company] business description products services technology platform headquarters founded employees sector industry"
→ Header, Business & Product Overview
→ **Immediately write** to `/tmp/tear-sheet/company-profile.txt`""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent """**Query 3 — Segments + customers:**
"[Company] revenue by segment business unit last 2 fiscal years key customers end markets customer concentration"
→ Revenue Mix (need 2 years for YoY growth), Customer Analysis
→ **Immediately write** segment data to `/tmp/tear-sheet/segments.csv` (skip if no segment data returned)""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent """**Query 4 — Relationships + competitive landscape:**
"[Company] key customers suppliers partners competitors business relationships technology vendors"
→ Strategic Fit Analysis, Ecosystem Map
→ **Immediately write** to `/tmp/tear-sheet/relationships.txt`""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent """**Query 6 — Ownership (data permitting):**
"[Company] ownership structure investors institutional ownership insider ownership"
→ Ownership snapshot (no intermediate file — included in company-profile.txt if available)""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Start with these queries. Break apart and follow up if results are incomplete." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Query Plan" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Financial Summary should include R&D and FCF conversion prominently." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:hasChild [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Bump text to 9.5pt (size: 19) — slightly larger than standard body text. This section should look like the most important content on the page." ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "Do not apply left-border accents — they render inconsistently in docx-js." ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Use the standard indented block-style bullets from the global style config (360 DXA left indent)." ] ] ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Strategic Fit Analysis is the centerpiece.** Give it distinctive formatting:" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Tone: analytical and evaluative, not promotional. This isn't a pitch — it's an assessment." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "For private targets, the profile leans heavily on qualitative sections (Business Overview, Strategic Fit, Relationships) — this is expected and still highly valuable." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Two-page discipline:** Before rendering, mentally estimate page count. The combination of Strategic Fit (3 long bullets) + Integration Considerations (4 bullets) alone can consume a full page — if so, compress Strategic Fit bullets first." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Valuation Context with peer comps is required for public companies — do not cut before Ownership Snapshot." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Formatting Notes" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_05c6cb728c758902,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Never cut: Business & Product Overview (2), Financial Summary (5 core table), Integration Considerations (8)." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Target: 2 pages.** Corp Dev profiles can fill both pages with substantive content, but must not spill to a third unless the user explicitly requests a longer format. If content exceeds 2 pages, cut in this order (cut each completely before moving to the next):" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Page Budget & Cut Order" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Listed in priority order. See \"Page Budget & Cut Order\" below for explicit cut guidance." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 5 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "**Capital Structure** (compact sub-table below the financial summary)" ;
                                    oc:tableMarkdown """| Metric | Value |
|---|---|
| Total Debt | $XXM |
| Cash & Equivalents | $XXM |
| Net Debt | $XXM |
| Net Debt / EBITDA | X.Xx |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Capital Structure** (compact sub-table below the financial summary):" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "R&D intensity signals how much of the target's value is in IP vs. services. FCF conversion signals integration complexity — high-capex businesses are harder to integrate. If R&D expense isn't separately reported, note \"Not separately disclosed\" in the row rather than \"N/A\" — this itself is informative (suggests R&D may be embedded in COGS or SG&A)." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 10 ;
                                    oc:tableCaption "Similar to IB/M&A but with added emphasis on R&D and capital efficiency." ;
                                    oc:tableMarkdown """| Metric ($M) | FY20XX | FY20XX | FY20XX |
|---|---|---|---|
| Revenue | | | |
| Revenue Growth % | | | |
| Gross Margin % | | | |
| EBITDA | | | |
| EBITDA Margin % | | | |
| R&D Expense | | | |
| R&D as % of Revenue | | | |
| Capex | | | |
| Free Cash Flow | | | |
| FCF Conversion (FCF/EBITDA) | | | |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "Frame for acquisition context: below the table, include one sentence interpreting leverage (e.g., \"Net debt of $X represents Y.Yx EBITDA leverage, which is manageable for an investment-grade acquirer but would compound leverage in an LBO scenario.\"). Pull from the balance sheet data already retrieved." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Similar to IB/M&A but with added emphasis on R&D and capital efficiency." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "5. Financial Summary (3-Year)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "This section requires synthesis — combine relationship data with the business overview to draw connections. If the user has told you who the acquirer is, tailor to that acquirer. If not, write it generically but still analytically." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**This is the signature section of the Corp Dev tear sheet.** It is required — do not skip or compress it. It uses the Business Relationships data from S&P Capital IQ to map overlaps and complements." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "**Competitive Displacement:** Is the target a competitor, or does acquiring them remove a competitor from the market? Name the target's key competitors and explain how the competitive landscape would change post-acquisition." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Customer Overlap:** Do the target's customers also buy from the acquirer (or the acquirer's industry)? Shared customers = easier cross-sell, but also risk of channel conflict. Name shared relationships and explain the implications." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 7 ;
                                    oc:textContent "**Length discipline:** The 2-3 sentence target per bucket above is a hard constraint, not a suggestion. Each bullet should front-load the insight, then support with one specific data point. The actual outputs frequently balloon to 5-7 sentences per bullet — this is the primary driver of page 3 spillover. If you find yourself writing more than 3 sentences, move the excess detail to Integration Considerations." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "Organize as three buckets. **Each bucket must be 2-3 sentences of analytical reasoning, not a list of company names.** Listing \"Customers: Microsoft, JPMorgan, Google\" without context is useless. Instead, explain *what the overlap or complement means* for an acquisition." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Technology / Product Complement:** Does the target fill a gap in the acquirer's portfolio? What does their tech stack look like? Who are their technology vendors? If they're already using the acquirer's technology, explain why that's a strong integration signal." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "4. Strategic Fit Analysis" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Similar to IB/M&A but adds a \"Strategic Relevance\" tagline." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 7 ;
                                    oc:tableCaption "Similar to IB/M&A but adds a \"Strategic Relevance\" tagline." ;
                                    oc:tableMarkdown """| Field | Notes |
|---|---|
| Company name | Large, bold |
| Ticker & Exchange | If public; omit for private |
| HQ Location | |
| Founded / Employees | |
| Enterprise Value | Market cap for public; latest valuation for private |
| Ownership | Public / PE-backed / Founder-led / etc. |
| **Strategic Relevance** | One sentence: why this target is attractive to an acquirer (synthesized from data) |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "The \"Strategic Relevance\" line is unique to Corp Dev. Write from a neutral analytical perspective, not from the target's marketing language. Frame what an acquirer *gets* — not what the target *is*. Good: \"Dominant position in commodity price benchmarks with regulatory moat and 70%+ gross margins — a capital-light, high-barrier data asset.\" Bad: \"The world's leading provider of financial data and analytics.\" The former tells a corp dev team why this is attractive; the latter is a press release." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "1. Company Header" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "If the tools return ownership data, include a compact block: founder/family control %, PE sponsor details, institutional concentration. Ownership structure directly impacts deal complexity and is relevant for integration considerations." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Do not include a Management Team table.** No S&P Global tool returns executive data — see Data Integrity Rule 10. Management names from training data will be stale." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 7 ;
                            oc:sectionTitle "7. Ownership Snapshot (data permitting — omit if tools return nothing)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 8 ;
                                    oc:textContent """**b) Precedent transactions (data permitting):**
If the M&A tools return recent transactions involving the company's peers or within the same sub-sector, display them:""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 12 ;
                                    oc:textContent "For private companies, skip trading multiples. Precedent transactions (data permitting) are still useful." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 11 ;
                                    oc:textContent "If precedent transaction data is not available from the tools, note \"Precedent transaction data not available from data source\" rather than omitting silently. Do not fabricate precedent multiples." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Peer context is essential, not optional.** If the user provided comps, show each in its own column. If no comps were provided, use the competitors tool to identify 3-5 public peers, then pull EV/Revenue (NTM), EV/EBITDA (NTM), revenue growth %, and EBITDA margin % for each." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**This section is required for public companies.** Corp Dev teams need market context to frame a potential bid. If the tools return valuation multiples, this section must appear. Do not cut it for space — cut Ownership Snapshot (Section 7) first." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 9 ;
                                    oc:rowCount 0 ;
                                    oc:tableCaption "If the M&A tools return recent transactions involving the company's peers or within the same sub-sector, display them" ;
                                    oc:tableMarkdown """| Date | Target | Acquirer | EV ($M) | EV/Rev | EV/EBITDA |
|---|---|---|---|---|---|
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "Not a formal valuation — Corp Dev teams do their own DCFs. This provides market context." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 5 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "**Peer context is essential, not optional.** If the user provided comps, show each in its own column. If no comps were provided, use the competitors tool to identify 3-5 public peers, then pull EV/Revenue (NTM), EV/EBITDA (NTM), revenue growth %, and EBITDA margin % for each." ;
                                    oc:tableMarkdown """| Metric | [Company] | [Peer 1] | [Peer 2] | [Peer 3] | Peer Median |
|---|---|---|---|---|---|
| EV/Revenue (NTM) | | | | | |
| EV/EBITDA (NTM) | | | | | |
| Revenue Growth % | | | | | |
| EBITDA Margin % | | | | | |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**a) Trading multiples** (if public):" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 10 ;
                                    oc:textContent "Frame as context: \"Recent transactions in [sub-sector] have valued targets at X–Yx revenue.\"" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 7 ;
                                    oc:textContent "If peer multiples are unavailable from the tools, show the company's own multiples and list selected peer names below the table for the reader's reference." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "A company's multiples in isolation tell a corp dev team nothing — they need relative context to assess whether the target is cheap or rich vs. the peer set. This is the minimum viable valuation context for a target profile." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "6. Valuation Context" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**a) Revenue by Segment** (if available):" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "Customer concentration is the single most important signal here — if the tools return any data on top customers or revenue concentration, highlight it prominently. If data is sparse, write what you can infer from the business description and relationships. Keep this to 2-3 sentences — it's context for the segment table, not a standalone analysis." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 5 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Geographic mix" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Customer concentration: are the top 5 customers >30% of revenue? (Critical for acquisition risk)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Contract structure: subscription vs. transactional vs. license (if known)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Customer type: enterprise vs. SMB vs. consumer" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent """**b) Customer Analysis:**
Below the segment table (or in place of it if segments aren't available), write a qualitative paragraph covering:""" ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 3 ;
                                    oc:rowCount 0 ;
                                    oc:tableCaption "**a) Revenue by Segment** (if available)" ;
                                    oc:tableMarkdown """| Segment | Revenue ($M) | % of Total | YoY Growth |
|---|---|---|---|
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Two sub-sections:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "3. Revenue Mix & Customer Profile" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Current strategic direction" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Customer segments — who buys this and why" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Technology or platform architecture (at a high level)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Key differentiators and competitive moat" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Core products/services and what problem they solve" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Write with an acquirer's lens. The reader is thinking: \"How would this fit with what we already have?\" The description should make it easy to spot overlaps and complements." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**Do not paste the CIQ company summary.** Rewrite in 4-6 sentences (one paragraph, not two) with a product and technology focus — this audience evaluates acquisitions, not investments:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "2. Business & Product Overview" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**Required section — do not cut.** This is the analytical capstone of the Corp Dev tear sheet. Synthesized observations drawn from everything above. 3-4 substantive bullets:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Label clearly as analytical observations, not facts from the data source." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Key risks:** Customer concentration, key-person dependency, technology debt indicators" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Open questions:** What would a corp dev team need to diligence before making a bid? Focus on concrete, actionable diligence items — not open-ended strategic questions. Good examples: regulatory approval timeline and jurisdictions, change-of-control provisions in key contracts, key-person retention risk (especially founders/CTOs), customer contract transferability, IP ownership structure, outstanding litigation. Bad examples: \"How defensible is X?\" or \"What is the long-term market opportunity?\" — these are analyst questions, not diligence items." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Synergy signals:** Shared customers, complementary products, overlapping technology vendors" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Integration complexity:** Geography (multi-country = harder), employee count, number of products" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 8 ;
                            oc:sectionTitle "8. Integration Considerations" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Sections" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Corporate Development Tear Sheet" ] ;
    oc:hasWorkflow _:ref_05c6cb728c758902,
        [ a oc:Workflow ;
            dcterms:description "Sequential query and assembly workflow for generating a Corp Dev target evaluation profile" ;
            oc:hasStep _:ref_247898491c7f2c1d,
                _:ref_248131e917ad78d1,
                _:ref_320c5e80dbc9b43b,
                _:ref_40268bd56dec7d89,
                [ a oc:WorkflowStep ;
                    dcterms:description "Assemble all sections in priority order: Company Header, Business & Product Overview, Revenue Mix & Customer Profile, Strategic Fit Analysis, Financial Summary, Valuation Context, Ownership Snapshot, Integration Considerations. Apply 2-page budget and cut order." ;
                    oc:expectedOutcome "Complete 1-2 page Corp Dev tear sheet generated" ;
                    oc:stepDependsOn _:ref_247898491c7f2c1d,
                        _:ref_248131e917ad78d1,
