        oc:kn_e65b05ca ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "analyze target company for M&A due diligence",
        "assess strategic fit for acquisition",
        "create corporate development target profile",
        "evaluate acquisition target",
        "generate corp dev tear sheet" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0d84aced a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assembling the tear sheet sections" ;
    oc:directiveContent "Never include a Management Team table. S&P Global tools do not return executive data and management names from training data will be stale." ;
    oc:hasRationale "Stale management data undermines credibility of the entire profile" ;
    oc:severityLevel "HIGH" .

oc:kn_100e6809 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building Valuation Context for public targets" ;
    oc:directiveContent "Valuation Context with peer comps is required for public companies — do not cut before Ownership Snapshot. If no user-provided comps, use the competitors tool to identify 3-5 public peers and pull EV/Revenue (NTM), EV/EBITDA (NTM), revenue growth %, and EBITDA margin % for each." ;
    oc:hasRationale "A company's multiples in isolation tell a corp dev team nothing — they need relative context to assess cheap vs. rich" ;
    oc:severityLevel "HIGH" .

oc:kn_1f4fed66 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building Valuation Context section" ;
    oc:directiveContent "Do not fabricate precedent transaction multiples. If data is unavailable, note 'Precedent transaction data not available from data source' rather than omitting silently." ;
    oc:hasRationale "Silent omissions create false impressions; explicit data gaps maintain trust" ;
    oc:severityLevel "CRITICAL" .

oc:kn_305154be a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing the Company Header section" ;
    oc:directiveContent "Strategic Relevance tagline must be written from a neutral analytical perspective framing what an acquirer *gets*, not what the target *is*. Example good: 'Dominant position in commodity price benchmarks with regulatory moat and 70%+ gross margins.' Example bad: 'The world's leading provider of financial data and analytics.'" ;
    oc:hasRationale "Corp Dev teams need acquisition rationale, not marketing language" ;
    oc:severityLevel "HIGH" .

oc:kn_3a928bd4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the Business & Product Overview section" ;
    oc:directiveContent "Never paste the CIQ company summary directly into the Business & Product Overview. Always rewrite in 4-6 sentences with a product and technology focus through an acquirer's lens." ;
    oc:hasRationale "Raw CIQ summaries are marketing-oriented; Corp Dev readers evaluate acquisitions, not investments" ;
    oc:severityLevel "CRITICAL" .

oc:kn_51a0badd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing customer data in Revenue Mix section" ;
    oc:directiveContent "Customer concentration >30% in top 5 customers is a critical acquisition risk signal. If any data on top customers or revenue concentration is returned, highlight it prominently." ;
    oc:hasRationale "High customer concentration directly impacts acquisition risk and valuation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8d412500 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When populating the Financial Summary table" ;
    oc:directiveContent "If R&D expense isn't separately reported, note 'Not separately disclosed' rather than 'N/A'. R&D intensity signals how much of the target's value is in IP vs. services." ;
    oc:hasRationale "The distinction between 'not disclosed' and 'N/A' is informative — suggests R&D may be embedded in COGS or SG&A" ;
    oc:severityLevel "LOW" .

oc:kn_8d55ae8a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Strategic Fit Analysis section" ;
    oc:directiveContent "Strategic Fit Analysis bullets must be exactly 2-3 sentences each — this is a hard constraint, not a suggestion. If content exceeds 3 sentences, move excess to Integration Considerations." ;
    oc:hasRationale "Exceeding 2-3 sentences per bucket is the primary driver of page 3 spillover" ;
    oc:severityLevel "HIGH" .

oc:kn_a12ebec3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finalizing the tear sheet" ;
    oc:directiveContent "Target length is 1-2 pages maximum. Never spill to a third page unless explicitly requested. Follow the explicit cut order: (1) Ownership Snapshot, (2) Customer Analysis prose, (3) Valuation Context prose, (4) Precedent Transactions, (5) Capital Structure prose, (6) Strategic Fit bullets." ;
    oc:hasRationale "Corp Dev teams value conciseness; page 3 spillover indicates insufficient editorial discipline" ;
    oc:severityLevel "HIGH" .

oc:kn_e65b05ca a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting the final document" ;
    oc:directiveContent "Strategic Fit Analysis is the centerpiece section. Format it with 9.5pt text (size: 19), use standard indented block-style bullets (360 DXA left indent), but do not apply left-border accents as they render inconsistently in docx-js." ;
    oc:hasRationale "Visual emphasis signals to the reader that this is the most important analytical content" ;
    oc:severityLevel "MEDIUM" .

_:ref_03422d4e9101d8a6 a oc:WorkflowStep ;
    dcterms:description "Capital Structure prose — keep table, cut interpretive paragraph below it" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_19cef2e8b1c4050e a oc:WorkflowStep ;
    dcterms:description "Ownership Snapshot (section 7) — omit entirely" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_5664dff70a89c5fd a oc:WorkflowStep ;
    dcterms:description "Customer Analysis prose under Revenue Mix (section 3) — reduce to 2 sentences max" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_74c03f63407bd785 a oc:WorkflowStep ;
    dcterms:description "Valuation Context prose (section 6) — keep peer comp table, cut interpretive paragraph below it" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_95c44078f9630f75 a oc:WorkflowStep ;
    dcterms:description "Strategic Fit Analysis (section 4) — compress each bullet to 2-3 sentences max (do not remove the section)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_b361b3bf8712d047 a oc:WorkflowStep ;
    dcterms:description "Precedent Transactions (section 6b) — keep the \"not available\" note, remove if space-critical" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_05c6cb728c758902 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_03422d4e9101d8a6,
        _:ref_19cef2e8b1c4050e,
        _:ref_5664dff70a89c5fd,
        _:ref_74c03f63407bd785,
        _:ref_95c44078f9630f75,
        _:ref_b361b3bf8712d047 ;
    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_247898491c7f2c1d a oc:WorkflowStep ;
    dcterms:description "Query or derive peer valuation multiples (EV/Revenue NTM, EV/EBITDA NTM, revenue growth, EBITDA margin). Write company multiples to /tmp/tear-sheet/valuation.csv and peer data to /tmp/tear-sheet/peer-comps.csv" ;
    oc:expectedOutcome "Valuation context with peer comparison data retrieved" ;
    oc:stepId "query-valuation" .

_:ref_248131e917ad78d1 a oc:WorkflowStep ;
    dcterms:description "Query key customers, suppliers, partners, competitors, business relationships, technology vendors. Write to /tmp/tear-sheet/relationships.txt" ;
    oc:expectedOutcome "Relationship and competitive landscape data retrieved for Strategic Fit Analysis" ;
    oc:stepId "query-relationships" .

_:ref_320c5e80dbc9b43b a oc:WorkflowStep ;
    dcterms:description "Query annual income statement data (revenue, gross profit, EBITDA, operating income, net income, capex, FCF, R&D, debt, cash) for last 4 fiscal years. Write raw values to /tmp/tear-sheet/financials.csv" ;
    oc:expectedOutcome "4 years of financial data retrieved (display 3, earliest for YoY growth)" ;
    oc:stepId "query-financials" .

_:ref_40268bd56dec7d89 a oc:WorkflowStep ;
    dcterms:description "Query ownership structure, investors, institutional and insider ownership. No intermediate file — include in company-profile.txt if available" ;
    oc:expectedOutcome "Ownership structure data retrieved (may be sparse for private companies)" ;
    oc:stepId "query-ownership" .

_:ref_81db7547b2d648e8 a oc:WorkflowStep ;
    dcterms:description "Query target company business description, products, services, technology, platform, HQ, founded, employees, sector/industry. Write results to /tmp/tear-sheet/company-profile.txt" ;
    oc:expectedOutcome "Company profile data retrieved and cached" ;
    oc:stepId "query-target-profile" .

_:ref_9b7abeeb08102d56 a oc:WorkflowStep ;
    dcterms:description "Query revenue by segment/business unit for last 2 fiscal years plus key customers, end markets, customer concentration. Write segment data to /tmp/tear-sheet/segments.csv" ;
    oc:expectedOutcome "Segment revenue mix and customer data retrieved" ;
    oc:stepId "query-segments-customers" .

