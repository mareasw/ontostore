_:ref_39639d7811799236 a oc:WorkflowStep ;
    dcterms:description "Query revenue by segment (2 years for YoY growth) and full income statement (4 years). Write financials to /tmp/tear-sheet/financials.csv and segment data to /tmp/tear-sheet/segments.csv." ;
    oc:expectedOutcome "Segment breakdown and financial time series captured" ;
    oc:stepDependsOn _:ref_c1536772af4c7a1b ;
    oc:stepId "q2-segments" .

_:ref_80fa9a14a2c5c6bd a oc:WorkflowStep ;
    dcterms:description "Query valuation multiples for the company and 3-5 peer comparables (user-specified or competitor tool). Write company multiples to /tmp/tear-sheet/valuation.csv and peer data to /tmp/tear-sheet/peer-comps.csv." ;
    oc:expectedOutcome "Trading comps with NTM multiples for company and peers captured" ;
    oc:stepDependsOn _:ref_c1536772af4c7a1b ;
    oc:stepId "q3-valuation" .

_:ref_d4884990d5bf808a a oc:WorkflowStep ;
    dcterms:description "Assemble all sections in priority order (Header → Overview → Segments → Financials → Comps → M&A → Relationships → Ownership). Apply 2-page budget and cut order if needed." ;
    oc:expectedOutcome "Complete tear sheet document within 2-page limit" ;
    oc:stepDependsOn _:ref_2b41f25938906678,
