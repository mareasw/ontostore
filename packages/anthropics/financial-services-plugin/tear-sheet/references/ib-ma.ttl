_:ref_dfbfeabd21c75c8e a oc:WorkflowStep ;
    dcterms:description "Query comparable sector M&A transactions using specific industry from Q1 results. Append precedent transactions to /tmp/tear-sheet/ma-activity.csv with type=precedent." ;
    oc:expectedOutcome "Precedent transaction multiples for valuation benchmarking captured" ;
    oc:stepDependsOn _:ref_c01119dae50c6d21,
