@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_tear_sheet_ib_ma a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ib-ma" ;
    skos:broader "company profile" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/tear-sheet" ;
    oc:contentHash "a500e736295105dfb5888c71dd19b61bec55bda15c703c40057949cac79deefa" ;
    oc:differentia "framed for investment banking and M&A transaction context with emphasis on strategic positioning, segment detail, comparable transactions, and deal multiples" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_tear_sheet ;
    oc:handlesFailure oc:DataUnavailable,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "company name, optionally with comparable companies list" ;
    oc:hasCategory "finance" ;
    oc:impartsKnowledge oc:kn_376755ec,
        oc:kn_3d8e04ee,
        oc:kn_69bc45fa,
        oc:kn_72a317f4,
        oc:kn_7fa40b5b,
        oc:kn_be0d4e32,
        oc:kn_fa491b4b,
        oc:kn_fa71c49c ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "analyze company for acquisition context",
        "build pitchbook company profile",
        "create IB/M&A tear sheet",
        "generate company profile for M&A transaction",
        "prepare investment banking company profile" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_376755ec a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When data tools return no segment breakdown for the company" ;
    oc:directiveContent "If segment data is unavailable, replace the segment table with 2-3 sentences of qualitative revenue mix description. Never show a blank table." ;
    oc:hasRationale "A blank table looks broken in a pitchbook. A qualitative description still conveys useful information about revenue composition." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3d8e04ee a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating the M&A Activity table (Section 6)" ;
    oc:directiveContent "If a deal value is returned by M&A tools, it must appear in the output. Never downgrade a known deal value to 'Undisclosed'. Use 'Undisclosed' only when tools genuinely return no value." ;
    oc:hasRationale "This is a data integrity violation — bankers scan for numbers and rely on accuracy of disclosed values. Downgrading known values erodes trust." ;
    oc:severityLevel "CRITICAL" .

oc:kn_69bc45fa a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating the Financial Summary table (Section 4)" ;
    oc:directiveContent "Pull 4 years of financials but display only 3 fiscal years plus LTM if available. Use the earliest year solely for YoY growth computation on the first displayed year." ;
    oc:hasRationale "Bankers work off LTM for valuation cross-checks — a fiscal-year-only view can be 6+ months stale. The extra hidden year enables accurate YoY growth without cluttering the table." ;
    oc:severityLevel "MEDIUM" .

oc:kn_72a317f4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the Trading Comps table (Section 5)" ;
    oc:directiveContent "Forward (NTM) multiples are mandatory when available. The trading comps table must include NTM multiples if the tools return them — bankers price deals on forward earnings, not trailing." ;
    oc:hasRationale "Showing only trailing multiples when forward data exists is a significant analytical gap in any banking deliverable." ;
    oc:severityLevel "HIGH" .

oc:kn_7fa40b5b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "During the 6-query data gathering phase" ;
    oc:directiveContent "Write each query result to /tmp/tear-sheet/ immediately upon retrieval. Do not batch writes — persist data as it arrives to enable recovery if later queries fail." ;
    oc:hasRationale "Progressive persistence ensures partial progress is preserved and reduces data loss risk from interrupted execution." ;
    oc:severityLevel "MEDIUM" .

oc:kn_be0d4e32 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assembling the tear sheet sections" ;
    oc:directiveContent "Do not include a Management Team table. No S&P Global tool returns executive data, and management names from training data will be stale." ;
    oc:hasRationale "Stale or hallucinated executive names undermine credibility. If the data source cannot reliably provide this, omit it entirely." ;
    oc:severityLevel "HIGH" .

oc:kn_fa491b4b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the profile risks exceeding the 2-page target" ;
    oc:directiveContent "When content exceeds 2 pages, cut sections in strict order: (1) Ownership Snapshot, (2) Comparable Sector Transactions, (3) compress Business Relationships, (4) merge Capital Structure, (5) reduce Trading Comps to 3 peers. Never cut Business Overview, Segment Breakdown, core Financial Summary, or company's own M&A transactions." ;
    oc:hasRationale "IB profiles can use both pages fully but must not spill to a third. The cut order preserves the most strategically valuable content for M&A context." ;
    oc:severityLevel "HIGH" .

oc:kn_fa71c49c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the Business Overview section (Section 2)" ;
    oc:directiveContent "Never paste the company description directly from data tools into the Business Overview. Rewrite in pitchbook prose — characterize the revenue model, name the customer base, identify competitive moats, and frame growth vectors." ;
    oc:hasRationale "Bankers expect synthesized, strategically framed narrative — not raw data dumps. A CIQ summary reads as unprofessional in a pitchbook." ;
    oc:severityLevel "HIGH" .

