_:ref_bf98a4ae77541a70 a oc:WorkflowStep ;
    dcterms:description "Business Relationships (section 7) — compress to top 3 competitors + top 2 each of suppliers/partners/customers, drop descriptors to parenthetical only" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_2b41f25938906678 a oc:WorkflowStep ;
    dcterms:description "Query key customers, suppliers, partners, business relationships, and ownership data. Write to /tmp/tear-sheet/relationships.txt." ;
    oc:expectedOutcome "Strategic relationship and ownership data captured" ;
    oc:stepDependsOn _:ref_c1536772af4c7a1b ;
    oc:stepId "q6-relationships" .

