oc:skill_financial_services_plugin_tear_sheet_ib_ma a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ib-ma" ;
    skos:broader "tear sheet" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/tear-sheet" ;
    oc:contentHash "a500e736295105dfb5888c71dd19b61bec55bda15c703c40057949cac79deefa" ;
    oc:differentia "generates investment banking M&A company profiles with strategic positioning, segment detail, financial summaries, trading comps, and transaction multiples for deal context" ;
    oc:extends oc:skill_financial_services_plugin_tear_sheet ;
    oc:handlesFailure oc:DataNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "Glob",
        "Read",
        "Write",
        "web-search" ;
    oc:hasArgumentHint "company name (and optional comparable companies)" ;
    oc:hasCategory "finance" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent """**Query 4 — M&A activity:**
"[Company] acquisitions divestitures completed transactions last 5 years deal value"
→ Company's own deals
→ **Immediately write** to `/tmp/tear-sheet/ma-activity.csv`""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent """**Query 5 — Comparable transactions (data permitting):**
Use the specific industry from Query 1 results (e.g., "cloud observability software M&A transactions" not "technology M&A"). If the user specified comps, also try: "[comp company] acquisition deal multiples."
→ Comparable Transactions
→ **Append** comparable transactions to `/tmp/tear-sheet/ma-activity.csv` (add `type=precedent` to distinguish from company's own deals)""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Start with these queries. Break apart and follow up if results are incomplete." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent """**Query 3 — Valuation + comps:**
If the user provided specific comparable companies, query each:
"[Comp company] enterprise value EV/Revenue EV/EBITDA revenue growth EBITDA margin"
Otherwise:
Use the competitors tool to identify 3-5 public peers, then pull EV/Revenue (NTM), EV/EBITDA (NTM), revenue growth %, and EBITDA margin % for each.
Also: "[Company] enterprise value market capitalization EV/Revenue EV/EBITDA valuation multiples"
→ Header (EV/market cap), Trading Comps
→ **Immediately write** company multiples to `/tmp/tear-sheet/valuation.csv`
→ **Immediately write** peer data to `/tmp/tear-sheet/peer-comps.csv`""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**Query 1 — Profile + identification:**
"[Company] business description headquarters founded employees sector industry ownership structure major shareholders"
→ Header, Business Overview
→ **Immediately write** to `/tmp/tear-sheet/company-profile.txt`""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent """**Query 6 — Relationships + ownership:**
"[Company] key customers suppliers partners business relationships institutional ownership insider ownership"
→ Business Relationships, Ownership (data permitting)
→ **Immediately write** to `/tmp/tear-sheet/relationships.txt`""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**Query 2 — Segments + financials:**
"[Company] revenue by segment business unit last 2 fiscal years AND annual income statement revenue gross profit EBITDA operating income net income capex free cash flow total debt cash and equivalents last 4 fiscal years"
→ Segment Breakdown (need 2 years to compute YoY growth), Financial Summary (pull 4 years; display 3; use the earliest year only for YoY growth computation)
→ **Immediately write** raw financials to `/tmp/tear-sheet/financials.csv`
→ **Immediately write** segment data to `/tmp/tear-sheet/segments.csv` (skip if no segment data returned)""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Query Plan" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Default page length:** 1-2 pages. IB company profiles routinely spill to a second page, especially when segment and M&A data is rich." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "A company profile for transaction context — potential target, acquirer, or pitchbook inclusion. Emphasis on strategic positioning, segment detail, business relationships, and M&A activity. Valuation framed in transaction multiples, not investment thesis." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Purpose" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "For private companies, the header, business overview, financials, and relationships form the core; other sections may be sparse." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**M&A Activity is the signature section:** Use Accent color (#2E75B6) fill with white bold text for M&A table headers — this is the only table that uses a different header color from the standard #D6E4F0. It should catch the eye on a scan." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Business Relationships: give breathing room when space permits.** 6pt between each relationship group, full descriptors on each entry. But if hitting page 3, compress per the cut order above — this section is high-value but also the most compressible." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Business Overview and Segment Breakdown get the most visual weight." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Two-page discipline:** Before rendering, mentally estimate page count. If Business Relationships + M&A Activity together will exceed one full page, start cutting per the cut order." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 14 ;
                    oc:sectionTitle "Formatting Notes" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Never cut: Business Overview (2), Revenue & Segment Breakdown (3), Financial Summary (4 core), M&A Activity company transactions (6a)." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Target: 2 pages maximum.** IB profiles can use both pages fully, but must not spill to a third. If content exceeds 2 pages, cut in this order (cut each completely before moving to the next):" ],
                        _:ref_30b16d2f5790e344 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 13 ;
                    oc:sectionTitle "Page Budget & Cut Order" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Listed in priority order. See \"Page Budget & Cut Order\" below for explicit cut guidance." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Key-value block with transaction-relevant identifiers." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "For private companies: note \"Private Company\" prominently; skip ticker, exchange." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 8 ;
                                    oc:tableCaption "Key-value block with transaction-relevant identifiers." ;
                                    oc:tableMarkdown """| Field | Notes |
|---|---|
| Company name | Large, bold |
| Ticker & Exchange | If public; omit for private |
| HQ Location | City, State/Country |
| Founded | Year |
| Employees | Approximate headcount |
| Market Cap / Valuation | Market cap if public; latest known valuation if private |
| Enterprise Value | |
| Ownership | Public / PE-backed (name sponsor) / Family / Other |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "1. Company Header" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Forward multiples are mandatory when available.** The table must include NTM multiples if the tools return them. Showing only trailing multiples when forward data exists is a significant gap — bankers price deals on forward earnings." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Company multiples **and operating metrics** — bankers use these together, not multiples in isolation." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "For private companies, skip this section." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "If only the company's own multiples are available after attempting peer queries, show those and list selected peer names below the table." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Peer columns are expected.** If the user provided comps, each gets its own column. If not, use the competitors tool to identify 3-5 public peers, pull their multiples and operating metrics, and include them. A company-only trading comps table without peer context is incomplete for any banking use case." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 4 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "**Peer columns are expected.** If the user provided comps, each gets its own column. If not, use the competitors tool to identify 3-5 public peers, pull their multiples and operating metrics, and include them. A company-only trading comps table without peer context is incomplete for any banking use case." ;
                                    oc:tableMarkdown """| Metric | [Company] | [Comp 1] | [Comp 2] | [Comp 3] | Peer Median |
|---|---|---|---|---|---|
| EV/Revenue (NTM) | | | | | |
| EV/EBITDA (NTM) | | | | | |
| Revenue Growth % | | | | | |
| EBITDA Margin % | | | | | |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 9 ;
                            oc:sectionTitle "5. Trading Comps" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 8 ;
                                    oc:rowCount 0 ;
                                    oc:tableCaption "Use the specific industry identified earlier (e.g., \"cloud infrastructure software M&A\" not \"technology M&A\"). If the user specified comps, also look for transactions involving those specific companies." ;
                                    oc:tableMarkdown """| Date | Target | Acquirer | EV ($M) | EV/Rev | EV/EBITDA |
|---|---|---|---|---|---|
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**The table must include a dedicated Deal Value column.** Do not merge deal values into a Notes or Rationale column — bankers scan for numbers, and a dedicated column enables that." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 7 ;
                                    oc:textContent """**b) Comparable Sector Transactions (data permitting):**
Use the specific industry identified earlier (e.g., "cloud infrastructure software M&A" not "technology M&A"). If the user specified comps, also look for transactions involving those specific companies.""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Two parts. **Deal values are expected in this section** — bankers notice when they're missing." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Hard rule: If the M&A tools return a transaction value, it must appear in the output.** Never downgrade a known deal value to \"Undisclosed\" — this is a data integrity violation. Use \"Undisclosed\" only when the tools genuinely return no value for a transaction." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "If none found: \"No disclosed transactions in the last 5 years.\"" ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 5 ;
                                    oc:rowCount 1 ;
                                    oc:tableCaption "**The table must include a dedicated Deal Value column.** Do not merge deal values into a Notes or Rationale column — bankers scan for numbers, and a dedicated column enables that." ;
                                    oc:tableMarkdown """| Date | Target / Divested | Deal Value ($M) | Type | Rationale |
|---|---|---|---|---|
| | | | Acquisition / Divestiture | |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 9 ;
                                    oc:textContent "If not available from the tools: \"Comparable transaction data not available from data source.\" Do not fabricate precedent multiples." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**a) Company's Own Transactions:**" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 10 ;
                            oc:sectionTitle "6. M&A Activity" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "In M&A context, margins and FCF conversion matter as much as absolute scale — a buyer is evaluating efficiency and cash generation potential." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 5 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "**Capital Structure** (compact sub-table below the financial summary)" ;
                                    oc:tableMarkdown """| Metric | Value |
|---|---|
| Total Debt | $XXM |
| Cash & Equivalents | $XXM |
| Net Debt | $XXM |
| Net Debt / EBITDA | X.Xx |
| S&P Credit Rating | XX (if available) |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "Pull from the balance sheet data already retrieved. This is standard in any banker's company profile — total debt, leverage ratio, and credit rating tell a buyer what the financing picture looks like. If credit rating is unavailable, omit that row." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 11 ;
                                    oc:tableCaption "Actual fiscal years as column headers. **If LTM (last twelve months) data is available, add an LTM column to the right of the most recent fiscal year.** Label it \"LTM [quarter end date]\" (e.g., \"LTM Q3 2025\"). Bankers work off LTM for valuation cross-checks — a fiscal-year-only view can be 6+ months stale." ;
                                    oc:tableMarkdown """| Metric ($M) | FY20XX | FY20XX | FY20XX | LTM [date] |
|---|---|---|---|---|
| Revenue | | | | |
| Revenue Growth % | | | | |
| Gross Profit | | | | |
| Gross Margin % | | | | |
| EBITDA | | | | |
| EBITDA Margin % | | | | |
| Operating Income | | | | |
| Net Income | | | | |
| Capex | | | | |
| Free Cash Flow | | | | |
| FCF Margin % | | | | |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Actual fiscal years as column headers. **If LTM (last twelve months) data is available, add an LTM column to the right of the most recent fiscal year.** Label it \"LTM [quarter end date]\" (e.g., \"LTM Q3 2025\"). Bankers work off LTM for valuation cross-checks — a fiscal-year-only view can be 6+ months stale." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Capital Structure** (compact sub-table below the financial summary):" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 8 ;
                            oc:sectionTitle "4. Financial Summary (3-Year + LTM)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "The tone should be confident and specific. A banker reading this paragraph should immediately understand the company's strategic positioning." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Characterize the revenue model (recurring vs. transactional, subscription vs. license)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Frame growth vectors that would matter to a buyer or seller" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Identify competitive moats by name (\"proprietary dataset of X\", \"only provider with Y\")" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Name the customer base at scale (\"serves 80% of Fortune 500 banks\")" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**This is a pitchbook paragraph, not a CIQ summary.** Do not paste the company description from the data tools. Rewrite in 4-6 sentences using pitchbook prose:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "2. Business Overview" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "For each entry, include the relationship type and a parenthetical descriptor explaining the nature of the relationship (e.g., \"AWS — cloud infrastructure (primary hosting provider)\", \"JPMorgan — customer (enterprise analytics platform)\"). A name alone without context isn't useful. Give this section breathing room — it's strategically valuable and most competing tear sheets lack it." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent """**Customers:** Top 3-5 named clients
**Suppliers:** Key vendors and technology providers
**Partners:** Strategic alliances, distribution, JVs
**Competitors:** Key competitive names""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Leverages S&P Capital IQ relationship data. Group by type:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 11 ;
                            oc:sectionTitle "7. Key Business Relationships" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**If segment data isn't available:** Replace the table with 2-3 sentences describing the revenue mix qualitatively (e.g., \"Revenue is primarily derived from subscription licenses (~70%) and professional services (~30%).\"). A blank table looks broken — a qualitative description still conveys useful information." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "Revenue by business unit or product line." ;
                                    oc:tableMarkdown """| Segment | Revenue ($M) | % of Total | YoY Growth |
|---|---|---|---|
| [Segment A] | | | |
| [Segment B] | | | |
| **Total** | | **100%** | |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Revenue by business unit or product line." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 7 ;
                            oc:sectionTitle "3. Revenue & Segment Breakdown" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "For PE-backed companies, name the sponsor, acquisition year, and ownership stake. Ownership structure directly affects deal complexity — a widely held public company, a founder-controlled company, and a PE-backed company each require fundamentally different deal approaches." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "If ownership data is not returned by the tools, omit this section entirely rather than showing placeholders." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "**Do not include a Management Team table.** No S&P Global tool returns executive data — see Data Integrity Rule 10. Management names from training data will be stale." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "If the tools return institutional ownership, insider ownership percentage, or top holders, include a compact block:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent """Top institutional holders (if available): list top 3-5 by ownership %.
Insider ownership: aggregate percentage.""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 12 ;
                            oc:sectionTitle "8. Ownership Snapshot (data permitting — omit if tools return nothing)" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Sections" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Investment Banking / M&A Tear Sheet" ] ;
    oc:hasWorkflow _:ref_30b16d2f5790e344,
        [ a oc:Workflow ;
            dcterms:description "Generate a complete investment banking M&A tear sheet through sequential data queries, progressive file saves, and structured output assembly." ;
