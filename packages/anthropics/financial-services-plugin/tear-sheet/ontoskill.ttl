    oc:workflowId "procedure_4" ;
    oc:workflowName "Ordered Procedure" .

_:ref_91227f633fcdd137 a oc:WorkflowStep ;
    dcterms:description "Compute YoY revenue growth, YoY segment growth, YoY EPS growth" ;
    oc:expectedOutcome "Growth rate calculations complete" ;
    oc:stepDependsOn _:ref_04c86808f09ac765 ;
    oc:stepId "compute-growth" .

_:ref_a38a10b387163dc1 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_0bae7273b5f12ff6,
        _:ref_a35434cb736f4dff,
