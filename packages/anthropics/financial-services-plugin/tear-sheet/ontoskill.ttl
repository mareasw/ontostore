    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_2ba928f7572d3f03 a oc:WorkflowStep ;
    dcterms:description "Read each intermediate file and print verification summary. Warn on missing files but continue. Confirm files (not conversation context) are the source of truth." ;
    oc:expectedOutcome "Verification report printed; all available data confirmed on disk" ;
    oc:stepDependsOn _:ref_3371f0a7709ace67 ;
    oc:stepId "verify-data" .

_:ref_30ce1d51e9ee8bd3 a oc:WorkflowStep ;
    dcterms:description "Create /tmp/tear-sheet/ directory, then execute the query plan: pull company profile, historical financials (4 years), segments, valuation, consensus, earnings, relationships, M&A activity, and peer comps via S&P Global MCP tools. Write each result to intermediate files immediately." ;
    oc:expectedOutcome "All intermediate files populated with raw data from MCP tools" ;
    oc:stepDependsOn _:ref_448cb2e61143fb35 ;
    oc:stepId "pull-data" .

_:ref_3371f0a7709ace67 a oc:WorkflowStep ;
    dcterms:description "Read all intermediate files back, compute derived metrics (margins, growth rates, efficiency ratios, capital structure, segment mix) in a single pass. Validate all arithmetic. Write results to /tmp/tear-sheet/calculations.csv." ;
    oc:expectedOutcome "calculations.csv populated with validated derived metrics" ;
    oc:stepDependsOn _:ref_30ce1d51e9ee8bd3 ;
    oc:stepId "calculate-derived" .

_:ref_40ab4187e564be02 a oc:WorkflowStep ;
    dcterms:description "Compute FCF Conversion, R&D as % of Revenue, Capex as % of Revenue, Net Debt, Net Debt/EBITDA, segment mix percentages" ;
    oc:expectedOutcome "All efficiency and capital structure metrics computed" ;
    oc:stepDependsOn _:ref_04c86808f09ac765 ;
    oc:stepId "compute-efficiency" .

_:ref_448cb2e61143fb35 a oc:WorkflowStep ;
    dcterms:description "Read the audience-specific reference file (equity-research.md, ib-ma.md, corp-dev.md, or sales-bd.md) to get sections, query plan, formatting, and page budget." ;
    oc:expectedOutcome "Audience template loaded with section definitions and query plan" ;
    oc:stepDependsOn _:ref_dc89a0d0129ee48c ;
    oc:stepId "read-reference" .

_:ref_4a7285ac3d78a5c4 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 4 ;
    oc:hasStep _:ref_09a76eb945cfd1d4,
