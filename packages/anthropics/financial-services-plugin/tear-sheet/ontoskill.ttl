    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_b9680bb912b81260 a oc:WorkflowStep ;
    dcterms:description "Validate all calculations: margins match components, growth rates correct, segments sum to total, percentages sum to ~100%, EV cross-checks hold. Flag failures as N/A." ;
    oc:expectedOutcome "All metrics validated; calculations.csv written" ;
    oc:stepDependsOn _:ref_40ab4187e564be02,
        _:ref_91227f633fcdd137,
        _:ref_d9143f159c17202f ;
    oc:stepId "validate-arithmetic" .

_:ref_d9143f159c17202f a oc:WorkflowStep ;
    dcterms:description "Compute Gross Margin %, EBITDA Margin %, FCF Margin %, Operating Margin % from raw components" ;
    oc:expectedOutcome "Margin calculations complete" ;
    oc:stepDependsOn _:ref_04c86808f09ac765 ;
    oc:stepId "compute-margins" .

_:ref_dc89a0d0129ee48c a oc:WorkflowStep ;
    dcterms:description "Identify company (name/ticker), audience type (ER/IB/CD/Sales), optional comparable companies, and page length preference. Ask for audience if not specified." ;
    oc:expectedOutcome "All required inputs gathered; audience type confirmed" ;
    oc:stepId "identify-inputs" .

_:ref_04c86808f09ac765 a oc:WorkflowStep ;
    dcterms:description "Read all intermediate files from /tmp/tear-sheet/ back into context" ;
    oc:expectedOutcome "All raw data loaded for computation" ;
    oc:stepId "read-intermediates" .

