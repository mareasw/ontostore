                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Opening balances equal prior period closing balances" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Roll-forward logic is complete (Beginning + Additions - Deductions = Ending)" ],
                                        [ a oc:BulletItem ;
