                                    oc:contentOrder 2 ;
                                    oc:textContent "**Identify Input vs. Formula Cells**" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Use Excel's Trace Precedents/Dependents (Formulas → Trace Precedents) to understand cell relationships" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Look for visual cues (font color, cell shading) that distinguish input cells from formula cells" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Common conventions: Blue font = inputs, Black font = formulas, Green font = links to other sheets" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Check for named ranges that may control key inputs (Formulas → Name Manager)" ] ],
