                                            oc:itemOrder 6 ;
                                            oc:itemText "All balance sheet items have appropriate signs (assets positive, most liabilities positive)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Debt balances tie to debt schedule (if applicable)" ] ],
                                [ a oc:Paragraph ;
