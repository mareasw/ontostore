@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_3_statement_model a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "3-statement-model" ;
    skos:broader "Financial model template engine" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/3-statement-model" ;
    oc:contentHash "df3f7af86d57b476dcd6208e666251cabacd1362896dade8ec126a7d0d67026d" ;
    oc:dependsOnSkill oc:skill_xlsx_manipulation ;
    oc:differentia "Populates integrated 3-statement (IS/BS/CF) Excel model templates with formula-driven projections, supporting schedules, scenario analysis, and comprehensive validation checks" ;
    oc:handlesFailure oc:BalanceSheetImbalance,
        oc:CashTieOutFailure,
        oc:CircularReferenceDetected,
        oc:FormulaIntegrityError ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "Excel template file path or description of model to complete" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Complete, populate and fill out 3-statement financial model templates (Income Statement, Balance Sheet, Cash Flow Statement) . Use when asked to fill out model templates, complete existing model frameworks, populate financial models with data, complete a partially filled IS/BS/CF framework, or link integrated financial statements within an existing template structure. Triggers include requests to fill in, complete, or populate a 3-statement model template" ;
    oc:hasName "3-statement-model" ;
    oc:impartsKnowledge oc:kn_1a8e158a,
        oc:kn_56bfba2c,
        oc:kn_88043cc7,
        oc:kn_8b3c2a65,
        oc:kn_9a597c36,
        oc:kn_c43113dd,
        oc:kn_d7e034bd,
        oc:kn_fc212e0b ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:FileExists,
        oc:TemplateStructureMapped ;
    oc:resolvesIntent "build integrated financial model with linkages",
        "complete 3-statement model",
        "fill out income statement balance sheet cash flow",
        "populate financial model template",
        "run scenario analysis on financial model",
        "validate financial model integrity" ;
    oc:yieldsState oc:BalancedStatements,
        oc:ModelCompleted,
        oc:ValidationPassed .

oc:kn_1a8e158a a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When building debt schedules with interest-on-average-debt calculations" ;
    oc:directiveContent "Interest expense creates circularity: Interest → Net Income → Cash → Debt Balance → Interest. Enable iterative calculation (max 100 iterations, max change 0.001) and add a circuit breaker toggle in Assumptions." ;
    oc:hasRationale "Unresolved circular references prevent Excel from computing and cause #REF! errors cascading through the model." ;
    oc:severityLevel "HIGH" .

oc:kn_56bfba2c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After completing each statement and during final review" ;
    oc:directiveContent "The three core linkages must ALWAYS hold: (1) Assets = Liabilities + Equity, (2) CF Ending Cash = BS Cash, (3) IS Net Income = CF starting Net Income. Validate these after every statement completion." ;
    oc:hasRationale "These are the fundamental accounting identities; violation means the model is structurally broken and unreliable." ;
    oc:severityLevel "CRITICAL" .

oc:kn_88043cc7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting any cell in the model" ;
    oc:directiveContent "Use the minimal Blue/Grey palette: dark blue headers (#1F4E79), light blue column headers (#D9E1F2), medium blue checks (#BDD7EE), grey inputs (#F2F2F2), and font colors to signal cell type (blue=input, black=formula, green=cross-tab link). Follow template's own scheme if it differs." ;
    oc:hasRationale "Consistent color coding enables instant visual scanning of model structure and quick identification of input vs formula cells." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8b3c2a65 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When model validation checks fail" ;
    oc:directiveContent "When the Master Check shows errors: (1) find red-highlighted sections, (2) identify failing check category, (3) navigate to source tab, (4) trace precedents to find root cause, (5) fix and re-verify. For BS imbalance, check RE roll-forward and WC sign conventions first." ;
    oc:hasRationale "Systematic debugging from the check dashboard avoids blind searching and resolves the most common failure patterns quickly." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9a597c36 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before entering any data into a template" ;
    oc:directiveContent "Before populating any template, identify all tabs, map input vs formula cells (blue font = inputs, black = formulas, green = cross-tab links), understand tab dependencies, and confirm units and sign conventions." ;
    oc:hasRationale "Template structures vary widely; blind data entry risks overwriting formulas, mismatching units, or breaking cross-tab linkages." ;
    oc:severityLevel "HIGH" .

oc:kn_c43113dd a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building any 3-statement model" ;
    oc:directiveContent "Verify step-by-step with the user after each statement: (1) after mapping template, (2) after historicals, (3) after IS projections, (4) after BS with balance check, (5) after CF with cash tie-out. Do NOT populate end-to-end and present complete." ;
    oc:hasRationale "Breaking work into validation checkpoints catches errors early before they cascade across linked statements, saving significant rework." ;
    oc:severityLevel "HIGH" .

oc:kn_d7e034bd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating any projection cell in the model" ;
    oc:directiveContent "Never write pre-computed values (hardcodes) into projection cells — every projection, roll-forward, linkage, and subtotal MUST be an Excel formula referencing assumptions. The ONLY hardcoded cells are historical actuals and assumption drivers." ;
    oc:hasRationale "Hardcoded values break scenario toggling and silently corrupt every downstream integrity check when assumptions change." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fc212e0b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the NOL schedule" ;
    oc:directiveContent "NOL utilization is capped at 80% of EBT (post-2017 federal limit). NOL balance cannot go negative. NOL is generated only when EBT < 0. Beginning NOL for a new business = 0." ;
    oc:hasRationale "Post-2017 tax reform limits NOL utilization; violating these rules produces incorrect tax calculations and DTA values." ;
    oc:severityLevel "HIGH" .

