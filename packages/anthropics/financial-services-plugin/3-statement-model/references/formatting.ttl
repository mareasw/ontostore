@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_3_statement_model_formatting a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "formatting" ;
    skos:broader "formatting standards reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/3-statement-model" ;
    oc:contentHash "7e1c5ca7dd566f6821a6094efcbe48913d984766d7278178111ec4c67aca8778" ;
    oc:differentia "defines cell-level visual formatting rules for 3-statement financial models including color coding, borders, conditional formatting for checks, credit metric thresholds, and margin reasonability flags" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_3_statement_model ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "model-tab or element-type (e.g. income-statement, balance-sheet, credit-metrics, checks)" ;
    oc:hasCategory "finance" ;
    oc:impartsKnowledge oc:kn_01c073bb,
        oc:kn_30fdd11b,
        oc:kn_6f0ee431,
        oc:kn_a91de1d2,
        oc:kn_afef8245,
        oc:kn_e3e21f42,
        oc:kn_e6e3520a ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:DocumentCreated ;
    oc:resolvesIntent "apply professional formatting to financial model cells",
        "color-code inputs formulas and links in spreadsheet models",
        "configure conditional formatting for balance sheet checks and credit metrics",
        "format total and subtotal rows with bold and border conventions",
        "set margin reasonability flags in income statement models" ;
    oc:yieldsState oc:DocumentFormatted .

oc:kn_01c073bb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting numerical values throughout the model" ;
    oc:directiveContent "Negative values must use parentheses notation, not minus signs. Currency uses no decimals for large figures and 2 decimals for per-share amounts. Percentages use 1 decimal place." ;
    oc:hasRationale "Parentheses for negatives and consistent decimal conventions are standard financial modeling practice that ensures readability and professional presentation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_30fdd11b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting any cell in the financial model" ;
    oc:directiveContent "Use font color to signal cell type: blue = hardcoded inputs, black = formulas, green = cross-tab links. Use fill color to signal location context (headers, data, checks)." ;
    oc:hasRationale "Consistent color signaling lets users and auditors instantly distinguish editable inputs from computed values and linked references, reducing error risk." ;
    oc:severityLevel "HIGH" .

oc:kn_6f0ee431 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing the BS balance check row below Total Liabilities and Equity" ;
    oc:directiveContent "Balance Sheet check rows must display non-zero values in red font using conditional formatting. When balanced (value = 0), display in black/standard formatting." ;
    oc:hasRationale "Red-on-error formatting provides immediate visual feedback when the balance sheet is out of balance, which is the single most critical integrity check in a 3-statement model." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a91de1d2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing margin calculations on the Income Statement" ;
    oc:directiveContent "Do not ignore margin reasonability flags: Gross Margin < 0% is an ERROR (review COGS), Gross Margin > 80% is a WARNING (verify data), Net Margin > Gross Margin is an ERROR (formula issue)." ;
    oc:hasRationale "These flags catch the most common data entry and formula errors in financial models — inverted relationships and extreme values that indicate something is fundamentally wrong." ;
    oc:severityLevel "HIGH" .

oc:kn_afef8245 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying borders to financial model sheets" ;
    oc:directiveContent "Use thin vertical borders to separate historical from projected columns, single bottom borders for subtotals, thick bottom borders after section totals, and double bottom borders for grand totals." ;
    oc:hasRationale "Border hierarchy creates visual structure that mirrors the accounting hierarchy of the model, making period boundaries and aggregation levels immediately apparent." ;
    oc:severityLevel "LOW" .

oc:kn_e3e21f42 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When formatting credit metrics on the Balance Sheet tab" ;
    oc:directiveContent "Apply Green/Yellow/Red threshold coloring to credit metrics: Total Debt/EBITDA (< 2.5x green, 2.5-4.0x yellow, > 4.0x red), Interest Coverage (> 4.0x green, 2.5-4.0x yellow, < 2.5x red), Current Ratio (> 1.5x green, 1.0-1.5x yellow, < 1.0x red)." ;
    oc:hasRationale "Standardized threshold coloring enables instant assessment of credit health and covenant compliance without reading individual numbers." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e6e3520a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting total or subtotal rows on any financial statement tab" ;
    oc:directiveContent "Apply bold formatting to all total and subtotal rows including Gross Revenue, Gross Profit, EBITDA, EBIT, Net Profit, Total Assets, Total Liabilities and Equity, Net Cash from Operations, and Closing Cash Balance." ;
    oc:hasRationale "Bold totals provide immediate visual distinction between aggregated summary figures and individual line items, enabling faster model navigation and review." ;
    oc:severityLevel "MEDIUM" .

