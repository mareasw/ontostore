@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_financial_services_plugin_3_statement_model_formatting a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "formatting" ;
    skos:broader "Formatting standards reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/3-statement-model" ;
    oc:contentHash "7e1c5ca7dd566f6821a6094efcbe48913d984766d7278178111ec4c67aca8778" ;
    oc:dependsOnSkill oc:skill_ontoskills_3_statement_model ;
    oc:differentia "that defines color-coding, number formatting, conditional formatting, and visual styling rules for 3-statement financial models" ;
    oc:extends oc:skill_financial_services_plugin_3_statement_model ;
    oc:handlesFailure oc:FormattingInconsistent ;
    oc:hasCategory "finance" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Table ;
                    oc:blockType "table" ;
                    oc:contentOrder 1 ;
                    oc:rowCount 9 ;
                    oc:tableCaption "# Formatting Standards Reference" ;
                    oc:tableMarkdown """| Element | Format |
|---------|--------|
| Hard-coded inputs | Blue font |
| Formulas | Black font |
| Links to other sheets | Green font |
| Check cells | Red if error, green if balanced |
| Negative values | Parentheses, not minus signs |
| Currency | No decimals for large figures, 2 decimals for per-share |
| Percentages | 1 decimal place |
| Headers | Bold, bottom border |
| Units row | Include units row below headers ($ millions, %, etc.) |
""" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Net Margin < 0% → FLAG: Net losses (may be acceptable in growth phase)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Gross Margin < 0% → ERROR: Review COGS" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "Net Margin > Gross Margin → ERROR: Formula issue" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Gross Margin > 80% → WARNING: Verify revenue/COGS" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "EBITDA Margin < 0% → FLAG: Operating losses" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "EBITDA Margin > 50% → WARNING: Unusually high" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Margin Reasonability Flags" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 4 ;
                            oc:tableCaption "## Margin Row Formatting" ;
                            oc:tableMarkdown """| Element | Format |
|---------|--------|
| Margin % rows | Indent, italics, 1 decimal place |
| Positive trend | No special formatting (or subtle green) |
| Negative trend | Flag for review (subtle yellow) |
| Below peer average | Consider highlighting for discussion |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Margin Row Formatting" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Cell contains fail indicator → Red fill" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Difference cells = 0 → Light green fill" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Difference cells ≠ 0 → Light red fill" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Cell contains warning → Yellow fill" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Cell contains pass indicator → Green fill" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Conditional Formatting for Checks Tab" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 6 ;
                            oc:tableCaption "## Credit Metric Threshold Colors" ;
                            oc:tableMarkdown """| Metric | Green | Yellow | Red |
|--------|-------|--------|-----|
| Total Debt / EBITDA | < 2.5x | 2.5x-4.0x | > 4.0x |
| Net Debt / EBITDA | < 2.0x | 2.0x-3.5x | > 3.5x |
| Interest Coverage | > 4.0x | 2.5x-4.0x | < 2.5x |
| Debt / Total Cap | < 40% | 40%-60% | > 60% |
| Current Ratio | > 1.5x | 1.0x-1.5x | < 1.0x |
| Quick Ratio | > 1.0x | 0.75x-1.0x | < 0.75x |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Credit Metric Threshold Colors" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 5 ;
                            oc:tableCaption "## Credit Metric Formatting" ;
                            oc:tableMarkdown """| Element | Format |
|---------|--------|
| Leverage multiples | 1 decimal with "x" suffix (e.g., 2.5x) |
| Percentages | 1 decimal with "%" suffix |
| Net Debt negative | Parentheses, indicates net cash position |
| Section header | Bold, "CREDIT METRICS" |
| Separator line | Thin border above credit metrics section |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Credit Metric Formatting" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Thin vertical border between historical and projected columns" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Double bottom border for grand totals" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Thick bottom border after section totals (e.g., Total Assets)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Single bottom border for subtotals" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Visual Separation Guidelines" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "All total and subtotal rows must use **bold font formatting** for their numerical values to clearly distinguish aggregated figures from individual line items." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 8 ;
                                    oc:tableCaption "### Balance Sheet Tab" ;
                                    oc:tableMarkdown """| Row | Formatting |
|-----|------------|
| Total Current Assets | Bold |
| Total Non-Current Assets | Bold |
| Total Other Assets | Bold |
| Total Assets | Bold |
| Total Current Liabilities | Bold |
| Total Non-Current Liabilities | Bold |
| Total Equity | Bold |
| Total Liabilities and Equity | Bold |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Balance Sheet Tab" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Note:** This list is non-exhaustive. Apply bold formatting to any row that represents a total, subtotal, or summary calculation across the model." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 6 ;
                                    oc:tableCaption "### Cash Flow Statement Tab" ;
                                    oc:tableMarkdown """| Row | Formatting |
|-----|------------|
| Cash Generated from Operations Before Working Capital Changes | Bold |
| Total Working Capital Changes | Bold |
| Net Cash Generated from Operations | Bold |
| Net Cash Flow from Investing Activities | Bold |
| Net Cash Flow from Financing Activities | Bold |
| Closing Cash Balance | Bold |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Cash Flow Statement Tab" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 8 ;
                                    oc:tableCaption "### Income Statement (P&L) Tab" ;
                                    oc:tableMarkdown """| Row | Formatting |
|-----|------------|
| Gross Revenue | Bold |
| Total Cost of Revenue | Bold |
| Gross Profit | Bold |
| Total SG&A | Bold |
| EBITDA | Bold |
| EBIT | Bold |
| EBT | Bold |
| Net Profit After Tax | Bold |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Income Statement (P&L) Tab" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Total and Subtotal Row Formatting" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 2 ;
                            oc:tableCaption "The Balance Sheet check row (below Total Liabilities and Equity) uses conditional number formatting that displays non-zero values in red. When the balance sheet balances correctly (check = 0), the values display in black or standard formatting." ;
                            oc:tableMarkdown """| Check Value | Font Color |
|-------------|------------|
| = 0 (balanced) | Black (standard) |
| ≠ 0 (error) | Red |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Implementation:** Apply custom number format `[Red][<>0]0.00;[Red][<>0](0.00);0.00` or use Excel conditional formatting with the rule \"Cell Value ≠ 0\" → Red font." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The Balance Sheet check row (below Total Liabilities and Equity) uses conditional number formatting that displays non-zero values in red. When the balance sheet balances correctly (check = 0), the values display in black or standard formatting." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Balance Sheet Check Row Formatting" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Formatting Standards Reference" ] ;
    oc:impartsKnowledge oc:kn_016c119f,
        oc:kn_37fb494f,
        oc:kn_7cc854e9,
        oc:kn_83ec4e3f,
        oc:kn_95234341,
        oc:kn_a016c8cd,
        oc:kn_c288a2a6,
        oc:kn_c5298f40,
        oc:kn_f821e714 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:ModelPopulated ;
    oc:resolvesIntent "apply consistent formatting to financial models",
        "apply credit metric threshold colors",
        "format check rows and conditional indicators",
        "format income statement balance sheet and cash flow statement",
        "validate margin reasonability with flags" ;
    oc:yieldsState oc:ModelFormatted .

oc:kn_016c119f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating any cell in the financial model" ;
    oc:directiveContent "Hard-coded inputs must use blue font, formulas black font, and links to other sheets green font. This color-coding is mandatory for all cells in the model." ;
    oc:hasRationale "Color-coding distinguishes input types, enabling auditors and reviewers to immediately identify assumptions vs calculations vs references" ;
    oc:severityLevel "CRITICAL" .

oc:kn_37fb494f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting total or subtotal rows across all three statements" ;
    oc:directiveContent "All total and subtotal rows (Gross Revenue, Total Assets, Net Cash from Operations, etc.) must use bold font for numerical values. Apply bold to any row representing a total, subtotal, or summary calculation." ;
    oc:hasRationale "Bold formatting visually distinguishes aggregated figures from individual line items, improving readability and scanning speed" ;
    oc:severityLevel "HIGH" .

oc:kn_7cc854e9 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When reviewing margin calculations for accuracy" ;
    oc:directiveContent "Margin reasonability flags: Gross Margin <0% is ERROR (review COGS), >80% is WARNING (verify). EBITDA Margin <0% is FLAG (operating losses), >50% is WARNING. Net Margin <0% is FLAG, Net Margin > Gross Margin is ERROR (formula issue)." ;
    oc:hasRationale "These flags catch common modeling errors like formula corruption, sign errors, and unrealistic assumptions before they propagate" ;
    oc:severityLevel "HIGH" .

oc:kn_83ec4e3f a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When implementing the model validation checks tab" ;
    oc:directiveContent "Checks tab conditional formatting: pass indicator → green fill, fail → red fill, warning → yellow fill. Difference cells = 0 → light green, ≠ 0 → light red." ;
    oc:hasRationale "Color-coded check results enable rapid identification and triage of model errors" ;
    oc:severityLevel "MEDIUM" .

oc:kn_95234341 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting credit metric cells in the model" ;
    oc:directiveContent "Credit metrics use threshold color coding: Total Debt/EBITDA <2.5x green, 2.5-4.0x yellow, >4.0x red. Net Debt/EBITDA <2.0x green, 2.0-3.5x yellow, >3.5x red. Interest Coverage >4.0x green, 2.5-4.0x yellow, <2.5x red." ;
    oc:hasRationale "Threshold coloring provides instant visual risk assessment for leverage and coverage metrics" ;
    oc:severityLevel "HIGH" .

oc:kn_a016c8cd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting any numerical value in the model" ;
    oc:directiveContent "Negative values must use parentheses notation (e.g., (100)) not minus signs. Currency uses no decimals for large figures, 2 decimals for per-share. Percentages use 1 decimal place." ;
    oc:hasRationale "Parentheses notation is the financial industry standard and prevents ambiguity in printed reports" ;
    oc:severityLevel "HIGH" .

oc:kn_c288a2a6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing the balance sheet balancing check row" ;
    oc:directiveContent "Do not leave balance sheet check values unformatted. The check row must display non-zero values in red and zero (balanced) values in black/standard formatting. Use custom number format [Red][<>0]0.00;[Red][<>0](0.00);0.00 or conditional formatting." ;
    oc:hasRationale "Unformatted check rows hide errors — red highlighting immediately draws attention to imbalances" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c5298f40 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying borders and visual separation to the model" ;
    oc:directiveContent "Use thin vertical border between historical and projected columns. Thick bottom border after section totals (e.g., Total Assets). Single bottom border for subtotals. Double bottom border for grand totals." ;
    oc:hasRationale "Visual separation helps readers distinguish time periods and hierarchy of aggregation at a glance" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f821e714 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When formatting margin rows and credit metric displays" ;
    oc:directiveContent "Margin % rows use indent, italics, and 1 decimal place. Leverage multiples display with 1 decimal and 'x' suffix (e.g., 2.5x). Percentages use 1 decimal with '%' suffix. Net Debt negative values use parentheses indicating net cash position." ;
    oc:hasRationale "Consistent formatting conventions make the model immediately interpretable by any financial professional" ;
    oc:severityLevel "MEDIUM" .

