oc:kn_068a104c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When D&A line item is missing or aggregated on the income statement" ;
    oc:directiveContent "When D&A is embedded in COGS/SG&A and not broken out on the Income Statement, pull D&A from the Cash Flow Statement instead." ;
    oc:hasRationale "D&A is needed separately for EBITDA, FCF, and PP&E roll-forward schedules; the CF statement always reports it as a separate add-back." ;
    oc:severityLevel "MEDIUM" .

oc:kn_08b47b74 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before extracting any financial data from a filing" ;
    oc:directiveContent "Identify the reporting currency from the cover page, statement headers (e.g., 'in thousands of U.S. dollars'), or Note 1 before extracting any data. Set model currency to match filing and document in Assumptions tab." ;
    oc:hasRationale "Mismatched currency causes compounding errors throughout the model and makes period-over-period comparisons invalid." ;
    oc:severityLevel "CRITICAL" .

oc:kn_42cec634 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building schedules beyond the three primary statements" ;
    oc:directiveContent "Extract supporting detail from Notes to Financial Statements: Debt note for maturity schedule/rates/covenants, PP&E note for gross/accumulated depreciation/useful lives, Revenue note for segment/geographic splits, Leases note for operating vs. finance obligations." ;
    oc:hasRationale "Notes contain the granular detail needed for debt schedules, PP&E roll-forwards, revenue segment analysis, and lease obligation modeling." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5ede560b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "After extracting all three financial statements from a filing" ;
    oc:directiveContent "Verify IS Net Income = CF starting Net Income and BS Cash = CF Ending Cash for each year of historical data." ;
    oc:hasRationale "These cross-statement checks confirm data integrity and prevent propagation of extraction errors through the linked model." ;
    oc:severityLevel "HIGH" .

oc:kn_7cdc1bbb a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When encountering restated financials or non-calendar fiscal years" ;
    oc:directiveContent "For restated figures, use the restated numbers and note the restatement in the Assumptions tab. For fiscal years that differ from calendar years, label with fiscal year end (e.g., FYE Jan 2025)." ;
    oc:hasRationale "Restatements supersede original filings and using outdated figures creates inconsistencies. Fiscal year labeling prevents period confusion." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d0851edd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating historical data in any financial model from SEC filings" ;
    oc:directiveContent "Extract 3 years of historical data minimum. 10-K provides 3 years of IS/CF but only 2 years of BS; retrieve the 3rd year BS from the prior year's 10-K." ;
    oc:hasRationale "Three years of data is the minimum required for meaningful trend analysis and projection base periods in 3-statement models." ;
    oc:severityLevel "HIGH" .

_:ref_2dbfbd3c85c1891a a oc:WorkflowStep ;
    dcterms:description "Use SEC EDGAR: `https://www.sec.gov/cgi-bin/browse-edgar?action=getcompany&CIK=[TICKER]&type=10-K`" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_e6a482dd6d883869 a oc:WorkflowStep ;
    dcterms:description "For quarterly data, use `type=10-Q`" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_1476b139e6612f61 a oc:WorkflowStep ;
    dcterms:description "Confirm 3 years of historical Income Statement data extracted" ;
    oc:expectedOutcome "3 complete years of IS data present" ;
    oc:stepId "check-is-years" .

_:ref_5fde909307ab699a a oc:WorkflowStep ;
    dcterms:description "Confirm 3 years of historical Balance Sheet data extracted" ;
    oc:expectedOutcome "3 complete years of BS data present" ;
    oc:stepId "check-bs-years" .

_:ref_88dbd0f30a77b35a a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_2dbfbd3c85c1891a,
        _:ref_e6a482dd6d883869 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_9ebdec84eb69b6f1 a oc:WorkflowStep ;
    dcterms:description "Locate the filing on SEC EDGAR using the company ticker and filing type (10-K or 10-Q)" ;
    oc:expectedOutcome "Filing URL obtained and document accessible" ;
    oc:stepId "locate-filing" .

_:ref_00966fb4d033fdb4 a oc:WorkflowStep ;
    dcterms:description "Extract 3 years of Cash Flow Statement data from Consolidated Statements of Cash Flows" ;
    oc:expectedOutcome "Net Income, D&A, working capital changes, CapEx, debt activity, dividends populated for 3 years" ;
    oc:stepDependsOn _:ref_ea2a18cfd4f23d8b ;
    oc:stepId "extract-cash-flow" .

_:ref_2d6c74707f3a448f a oc:WorkflowStep ;
    dcterms:description "Extract 3 years of Income Statement data from Consolidated Statements of Operations, mapping line items to model fields" ;
    oc:expectedOutcome "Revenue, COGS, SG&A, D&A, Interest, Taxes, Net Income populated for 3 years" ;
    oc:stepDependsOn _:ref_ea2a18cfd4f23d8b ;
    oc:stepId "extract-income-statement" .

_:ref_5dd84912ac00235c a oc:WorkflowStep ;
    dcterms:description "Confirm 3 years of historical Cash Flow Statement data extracted" ;
    oc:expectedOutcome "3 complete years of CF data present" ;
    oc:stepId "check-cf-years" .

_:ref_77b0d61a2b4aea14 a oc:WorkflowStep ;
    dcterms:description "Extract 3 years of Balance Sheet data from Consolidated Balance Sheets (may need prior year 10-K for 3rd year)" ;
    oc:expectedOutcome "Cash, AR, Inventory, PP&E, Total Assets, AP, Debt, Equity populated for 3 years" ;
    oc:stepDependsOn _:ref_ea2a18cfd4f23d8b ;
    oc:stepId "extract-balance-sheet" .

_:ref_ea2a18cfd4f23d8b a oc:WorkflowStep ;
    dcterms:description "Identify reporting currency from cover page, statement headers, or Note 1. Set model currency to match." ;
    oc:expectedOutcome "Reporting currency and scale (thousands/millions) confirmed and documented" ;
    oc:stepDependsOn _:ref_9ebdec84eb69b6f1 ;
    oc:stepId "identify-currency" .

