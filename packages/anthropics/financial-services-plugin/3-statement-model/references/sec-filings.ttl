                                            oc:itemOrder 2 ;
                                            oc:itemText "Look at statement headers (e.g., \"in thousands of U.S. dollars\")" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Check the cover page or header for reporting currency" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Review Note 1 (Summary of Significant Accounting Policies)" ] ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 4 ;
                                    oc:rowCount 7 ;
                                    oc:tableCaption "**Common Currency Indicators**" ;
                                    oc:tableMarkdown """| Indicator | Currency |
|-----------|----------|
| $, USD | US Dollar |
| €, EUR | Euro |
| £, GBP | British Pound |
| ¥, JPY | Japanese Yen |
| ¥, CNY, RMB | Chinese Yuan |
| CHF | Swiss Franc |
| CAD, C$ | Canadian Dollar |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Common Currency Indicators**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Before extracting data, identify the reporting currency:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Step 2: Identify Filing Currency" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "### Handling Common Filing Variations" ;
                                    oc:tableMarkdown """| Variation | How to Handle |
|-----------|---------------|
| D&A embedded in COGS/SG&A | Pull D&A from Cash Flow Statement |
| "Other" line items are material | Check notes for breakdown |
| Restatements | Use restated figures, note in assumptions |
| Fiscal year ≠ calendar year | Label with fiscal year end (e.g., FYE Jan 2025) |
| Non-USD reporting currency | Adapt model currency to match filing |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 8 ;
                            oc:sectionTitle "Handling Common Filing Variations" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Extracting Data from SEC Filings (10-K / 10-Q)" ] ;
