@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_financial_services_plugin_3_statement_model_formulas a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "formulas" ;
    skos:broader "Reference document" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/3-statement-model" ;
    oc:contentHash "5761041366248bba14782f72082b9396c7e47291491999ea85be1c9c2875df5e" ;
    oc:differentia "defines all formulas, linkages, and structural checks for a 3-statement financial model (IS, BS, CF) including working capital, D&A, debt, NOL schedules, and balance verification" ;
    oc:extends oc:skill_financial_services_plugin_3_statement_model ;
    oc:hasCategory "finance" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "**IMPORTANT:** Use the formulas outlined in this reference document unless otherwise specified by the user." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """Total Debt            = Current Portion of Debt + Long-Term Debt
Net Debt              = Total Debt - Cash
Total Debt / EBITDA   = Total Debt / EBITDA (from IS)
Net Debt / EBITDA     = Net Debt / EBITDA (from IS)
Interest Coverage     = EBITDA / Interest Expense (from IS)
Net Int Exp % Debt    = Net Interest Expense / Long-Term Debt
Debt / Total Cap      = Total Debt / (Total Debt + Total Equity)
Debt / Equity         = Total Debt / Total Equity
Current Ratio         = Total Current Assets / Total Current Liabilities
Quick Ratio           = (Total Current Assets - Inventory) / Total Current Liabilities
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 49-60" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Credit Metric Formulas" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """Beginning Retained Earnings
+ Net Income (from IS)
+ Stock-Based Compensation (SBC) (from IS)
- Dividends
= Ending Retained Earnings
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 128-134" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 9 ;
                    oc:sectionTitle "Retained Earnings Formula" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 3 ;
                            oc:rowCount 4 ;
                            oc:tableCaption "```" ;
                            oc:tableMarkdown """| Term | Definition |
|------|------------|
| Gross Revenue | Total revenue before any deductions |
| Net Revenue | Gross Revenue - Returns - Allowances - Discounts |
| Cost of Revenue | Direct costs attributable to production of goods/services sold |
| Gross Profit | Net Revenue - Cost of Revenue |
""" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """Net Revenue - Cost of Revenue = Gross Profit
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 24-26" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**IMPORTANT:** Gross Profit must be calculated from Net Revenue, not Gross Revenue." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**Note:** Always use Net Revenue (also called \"Net Sales\" or simply \"Revenue\" on most financial statements) as the starting point for profitability calculations. Gross Revenue overstates the true top-line performance." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Gross Profit Calculation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """Balance Sheet:        Assets = Liabilities + Equity
Net Income:           IS Net Income → CF Operations (starting point)
Cash Flow:            ΔCash = CFO + CFI + CFF
Cash Tie-Out:         Ending Cash (CF) = Cash (BS Asset)
Cash Monthly/Annual:  Closing Cash (Monthly) = Closing Cash (Annual)
Retained Earnings:    Prior RE + Net Income - Dividends = Ending RE
Equity Raise:         ΔCommon Stock/APIC (BS) = Equity Issuance (CFF)
Year 0 Equity:        Equity Raised (Year 0) = Beginning Equity (Year 1)
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 9-18" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Linkages" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """Gross Margin %      = Gross Profit / Net Revenue
EBITDA              = EBIT + D&A  (or = Gross Profit - OpEx)
EBITDA Margin %     = EBITDA / Net Revenue
EBIT Margin %       = EBIT / Net Revenue
Net Income Margin % = Net Income / Net Revenue
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 39-45" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Margin Formulas" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """Beginning Debt Balance
+ New Borrowings
- Repayments
= Ending Debt Balance

Interest Expense = Avg Debt Balance × Interest Rate
  (Use beginning balance to avoid circularity, or iterate if circular refs enabled)
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 116-124" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Debt Schedule Formulas" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """CASH FROM OPERATIONS (CFO)
  Net Income (LINK: IS)
  + D&A (LINK: DA schedule)
  + Stock-Based Compensation (SBC) (LINK: IS or Assumptions)
  - ΔDTA (Deferred Tax Asset) (LINK: NOL schedule; increase in DTA = use of cash)
  - ΔAR (LINK: WC)
  - ΔInventory (LINK: WC)
  + ΔAP (LINK: WC)
  = CFO

CASH FROM INVESTING (CFI)
  - CapEx (LINK: DA schedule)
  = CFI

CASH FROM FINANCING (CFF)
  + Debt Issuance (LINK: Debt)
  - Debt Repayment (LINK: Debt)
  + Equity Issuance (LINK: BS Common Stock/APIC)
  - Dividends (LINK: RE schedule)
  = CFF

Net Change in Cash = CFO + CFI + CFF
Beginning Cash
+ Net Change in Cash
= Ending Cash (LINK TO: BS Cash)
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 211-237" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 12 ;
                    oc:sectionTitle "Cash Flow Statement Structure" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """Accounts Receivable
  Prior AR
  + Revenue (from IS)
  - Cash Collections (plug)
  = Ending AR
  DSO = (AR / Revenue) × 365

Inventory
  Prior Inventory
  + Purchases (plug)
  - COGS (from IS)
  = Ending Inventory
  DIO = (Inventory / COGS) × 365

Accounts Payable
  Prior AP
  + Purchases (from Inventory calc)
  - Cash Payments (plug)
  = Ending AP
  DPO = (AP / COGS) × 365

Net Working Capital = AR + Inventory - AP
ΔWC = Current NWC - Prior NWC
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 74-98" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Working Capital Formulas" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """Net Revenue
  Growth %
(-) Cost of Revenue
  % of Net Revenue
────────────────
Gross Profit (= Net Revenue - Cost of Revenue)
  Gross Margin %

(-) S&M
  % of Net Revenue
(-) G&A
  % of Net Revenue
(-) R&D
  % of Net Revenue
(-) D&A
(-) SBC
  % of Net Revenue
────────────────
EBIT
  EBIT Margin %

EBITDA
  EBITDA Margin %

(-) Interest Expense
────────────────
EBT (Pre-Tax Income)
(-) NOL Utilization (from NOL schedule, reduces taxable income)
────────────────
Taxable Income
(-) Taxes (Taxable Income × Tax Rate)
────────────────
Net Income
  Net Income Margin %
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 241-276" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 13 ;
                    oc:sectionTitle "Income Statement Structure" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """Cost of Revenue (Forecast) = Net Revenue × Cost of Revenue % Assumption
S&M (Forecast)             = Net Revenue × S&M % Assumption
G&A (Forecast)             = Net Revenue × G&A % Assumption
R&D (Forecast)             = Net Revenue × R&D % Assumption
SBC (Forecast)             = Net Revenue × SBC % Assumption
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 64-70" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Forecast Formulas (% of Net Revenue Method)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """Beginning PP&E (Gross)
+ CapEx
= Ending PP&E (Gross)

Beginning Accumulated Depreciation
+ Depreciation Expense
= Ending Accumulated Depreciation

PP&E (Net) = Gross PP&E - Accumulated Depreciation
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 102-112" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "D&A Schedule Formulas" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """NOL CARRYFORWARD SCHEDULE

Beginning NOL Balance (Year 1 / Formation = 0)
+ NOL Generated (if EBT < 0, then ABS(EBT), else 0)
- NOL Utilized (limited by taxable income and utilization cap)
= Ending NOL Balance

STARTING BALANCE RULE

For a new business or first modeled period:
  Beginning NOL Balance = 0
  NOL can only increase through realized losses (EBT < 0)
  NOL cannot be created from thin air or assumed

NOL UTILIZATION CALCULATION

Pre-Tax Income (EBT)
  If EBT > 0:
    NOL Available = Beginning NOL Balance
    Utilization Limit = EBT × 80%  (post-2017 federal limit)
    NOL Utilized = MIN(NOL Available, Utilization Limit)
    Taxable Income = EBT - NOL Utilized
  If EBT ≤ 0:
    NOL Utilized = 0
    Taxable Income = 0
    NOL Generated = ABS(EBT)

TAX CALCULATION WITH NOL

Taxes Payable = MAX(0, Taxable Income × Tax Rate)
  (Taxes cannot be negative; losses create NOL asset instead)

DEFERRED TAX ASSET (DTA) FOR NOL

DTA - NOL Carryforward = Ending NOL Balance × Tax Rate
ΔDTA = Current DTA - Prior DTA
  (Increase in DTA = non-cash benefit on CF)
  (Decrease in DTA = non-cash expense on CF)
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 138-177" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 10 ;
                    oc:sectionTitle "NOL (Net Operating Loss) Schedule Formulas" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """BS Balance Check:       = Assets - Liabilities - Equity  (must = 0)
Cash Tie-Out:           = BS Cash - CF Ending Cash       (must = 0)
RE Roll-Forward:        = Prior RE + NI + SBC - Div - BS RE  (must = 0)
DTA Tie-Out:            = NOL Schedule DTA - BS DTA      (must = 0)
Equity Raise Tie-Out:   = ΔCommon Stock/APIC (BS) - Equity Issuance (CFF)  (must = 0)
Year 0 Equity Tie-Out:  = Equity Raised (Year 0) - Beginning Equity (Year 1)  (must = 0)
Cash Monthly vs Annual: = Closing Cash (Monthly) - Closing Cash (Annual)  (must = 0)
NOL Utilization Cap:    = NOL Utilized ≤ EBT × 80%       (must be TRUE for post-2017)
NOL Non-Negative:       = Ending NOL Balance ≥ 0         (must be TRUE)
NOL Starting Balance:   = Beginning NOL (Year 1) = 0     (must be TRUE for new business)
NOL Accumulation:       = NOL increases only when EBT < 0 (losses generate NOL)
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 280-292" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 14 ;
                    oc:sectionTitle "Check Formulas" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """ASSETS
  Cash (from CF ending cash)
  Accounts Receivable (from WC)
  Inventory (from WC)
  Total Current Assets
  
  PP&E, Net (from DA)
  Deferred Tax Asset - NOL (from NOL schedule)
  Total Non-Current Assets
  Total Assets

LIABILITIES
  Accounts Payable (from WC)
  Current Portion of Debt (from Debt)
  Total Current Liabilities
  
  Long-Term Debt (from Debt)
  Total Liabilities

EQUITY
  Common Stock
  Retained Earnings (from RE schedule)
  Total Equity

CHECK: Assets - Liabilities - Equity = 0
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 181-207" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 11 ;
                    oc:sectionTitle "Balance Sheet Structure" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Formula Reference" ] ;
    oc:impartsKnowledge oc:kn_1c6db8c5,
        oc:kn_37d4295e,
        oc:kn_37f35d75,
        oc:kn_553a2117,
        oc:kn_644e57c0,
        oc:kn_6acf8dbd,
        oc:kn_7b60b279,
        oc:kn_a3404817,
        oc:kn_ae5c0001,
        oc:kn_b5a52fb3,
        oc:kn_c1f82847,
        oc:kn_ee2c53bd ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "build NOL and debt schedules",
        "calculate financial metrics (margins, credit ratios, working capital)",
        "check model balance and tie-outs",
        "populate financial model formulas",
        "verify 3-statement model linkages" .

oc:kn_1c6db8c5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After populating any period in the model" ;
    oc:directiveContent "All balance checks must equal zero: BS Balance (Assets - Liabilities - Equity = 0), Cash Tie-Out (BS Cash - CF Ending Cash = 0), RE Roll-Forward, DTA Tie-Out, Equity Raise Tie-Out, Year 0 Equity Tie-Out, Cash Monthly vs Annual." ;
    oc:hasRationale "Non-zero balance checks indicate broken formula linkages between statements, which invalidate the entire model." ;
    oc:severityLevel "CRITICAL" .

oc:kn_37d4295e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating Gross Profit, margins, or any profitability metric" ;
    oc:directiveContent "Gross Profit must be calculated from Net Revenue (not Gross Revenue). Use Net Revenue as the starting point for all profitability calculations." ;
    oc:hasRationale "Gross Revenue overstates true top-line performance by including returns, allowances, and discounts that will never be realized." ;
    oc:severityLevel "CRITICAL" .

oc:kn_37f35d75 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building the working capital schedule" ;
    oc:directiveContent "Working capital plug calculation order: (1) AR: Prior AR + Revenue - Cash Collections (plug) = Ending AR; (2) Inventory: Prior Inventory + Purchases (plug) - COGS = Ending Inventory; (3) AP: Prior AP + Purchases (from Inventory calc) - Cash Payments (plug) = Ending AP. Calculate DSO, DIO, DPO from results." ;
    oc:stepOrder 1 .

oc:kn_553a2117 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When building or verifying balance sheet structure" ;
    oc:directiveContent """ASSETS: Cash (from CF), AR (from WC), Inventory (from WC), Total Current Assets, PP&E Net (from D&A), DTA-NOL (from NOL), Total Non-Current Assets, Total Assets
LIABILITIES: AP (from WC), Current Portion of Debt (from Debt), Total Current Liabilities, LT Debt (from Debt), Total Liabilities
EQUITY: Common Stock, Retained Earnings (from RE schedule), Total Equity
CHECK: Assets - Liabilities - Equity = 0""" ;
    oc:templateVariables "AP",
        "AR",
        "Cash",
        "Common Stock",
        "Current Portion of Debt",
        "DTA-NOL",
        "Inventory",
        "LT Debt",
        "PP&E Net",
        "Retained Earnings" .

oc:kn_644e57c0 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before delivering or sharing any model output" ;
    oc:directiveContent "Before finalizing any period, verify all check formulas equal zero/TRUE: BS Balance, Cash Tie-Out, RE Roll-Forward, DTA Tie-Out, Equity Raise Tie-Out, Year 0 Equity Tie-Out, Cash Monthly vs Annual, NOL Utilization Cap (≤80% EBT), NOL Non-Negative, NOL Starting Balance (=0 for new business)." ;
    oc:hasRationale "These checks are the quality gate that confirms all statement linkages are correctly wired." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6acf8dbd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When connecting NOL schedule outputs to BS and CF" ;
    oc:directiveContent "The DTA from NOL (Ending NOL Balance × Tax Rate) must flow to both the Balance Sheet (non-current asset) and the Cash Flow Statement (ΔDTA as a non-cash adjustment). An increase in DTA is a use of cash on the CF; a decrease is a source." ;
    oc:hasRationale "The DTA bridges tax accounting (NOL carryforward) with cash reality (non-cash tax benefit/expense)." ;
    oc:severityLevel "HIGH" .

oc:kn_7b60b279 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing NOL schedule calculations" ;
    oc:directiveContent """NOL Utilized = IF(EBT > 0, MIN(Beginning NOL, EBT × 80%), 0)
Taxable Income = MAX(0, EBT - NOL Utilized)
Taxes Payable = Taxable Income × Tax Rate
DTA - NOL = Ending NOL Balance × Tax Rate""" .

oc:kn_a3404817 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — these are the fundamental linkages that make a 3-statement model integrated" ;
    oc:directiveContent "The three statements link through these core flows: IS Net Income → CF Operations starting point; ΔCash = CFO + CFI + CFF; Ending Cash (CF) = Cash (BS Asset); Prior RE + Net Income - Dividends = Ending RE; ΔCommon Stock/APIC (BS) = Equity Issuance (CFF)." ;
    oc:hasRationale "Breaking any of these linkages produces an inconsistent model where statements don't tie out." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ae5c0001 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building NOL carryforward schedules and calculating taxes" ;
    oc:directiveContent "NOL utilization is capped at 80% of EBT for post-2017 federal tax years. NOL starting balance for a new business is 0. NOL cannot be created from thin air—only from realized losses (EBT < 0). Taxes Payable = MAX(0, Taxable Income × Tax Rate)." ;
    oc:hasRationale "Post-2017 TCJA rules limit NOL utilization to 80% of taxable income. NOLs can only arise from actual operating losses." ;
    oc:severityLevel "HIGH" .

oc:kn_b5a52fb3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When initializing NOL schedules" ;
    oc:directiveContent "Never assume an NOL balance exists without a source. For new businesses, Beginning NOL (Year 1) = 0 and NOL can only increase through realized losses." ;
    oc:hasRationale "Fabricating NOL balances artificially reduces tax expense and overstates net income and cash flows." ;
    oc:severityLevel "HIGH" .

oc:kn_c1f82847 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When projecting income statement line items" ;
    oc:directiveContent "Forecast line items using % of Net Revenue method: Cost of Revenue, S&M, G&A, R&D, and SBC are each forecast as Net Revenue × respective % assumption." ;
    oc:stepOrder 2 .

oc:kn_ee2c53bd a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building the debt schedule and calculating interest expense" ;
    oc:directiveContent "Use beginning debt balance (not average) to calculate interest expense to avoid circularity, unless circular reference iteration is explicitly enabled." ;
    oc:hasRationale "Using average debt balance creates a circular reference (interest affects net income, which affects cash, which affects debt paydown, which affects interest)." ;
    oc:severityLevel "HIGH" .

