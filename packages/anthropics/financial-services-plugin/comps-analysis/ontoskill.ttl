oc:skill_financial_services_plugin_comps_analysis a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "comps-analysis" ;
    skos:broader "Financial analysis framework" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/comps-analysis" ;
    oc:contentHash "057787cefb96a8817109239cd24f633124f22cc00c3c598e396cddc6b4fb17b8" ;
    oc:differentia "Builds institutional-grade comparable company analyses with operating metrics, valuation multiples, and statistical benchmarking in Excel/spreadsheet format" ;
    oc:extends oc:skill_ontoskills_xlsx_manipulation ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "target company or sector with peer group" ;
    oc:hasCategory "finance" ;
    oc:hasDescription """Build institutional-grade comparable company analyses with operating metrics, valuation multiples, and statistical benchmarking in Excel/spreadsheet format.

**Perfect for:**
- Public company valuation (M&A, investment analysis)
- Benchmarking performance vs. industry peers
- Pricing IPOs or funding rounds
- Identifying valuation outliers (over/under-valued)
- Supporting investment committee presentations
- Creating sector overview reports

**Not ideal for:**
- Private companies without comparable public peers
- Highly diversified conglomerates
- Distressed/bankrupt companies
- Pre-revenue startups
- Companies with unique business models""" ;
    oc:hasName "comps-analysis" ;
    oc:hasRequirement oc:req_03819ce4,
        oc:req_53c83401,
        oc:req_6662bfdc ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 13 ;
                            oc:textContent "User-provided examples and explicit preferences always take precedence over defaults." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**DO use examples for:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 10 ;
                            oc:textContent "**Adapt based on specifics:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "An example comparable company analysis is provided in `examples/comps_example.xlsx`. When using this or other example files in this skill directory, use them intelligently:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "**DO NOT use examples for:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Reference Material & Contextualization:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 8 ;
                            oc:textContent "**ALWAYS ask yourself first:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 12 ;
                            oc:textContent "**Core principle:** Use template principles (clear structure, statistical rigor, transparent formulas) but vary execution based on context. The goal is institutional-quality analysis, not institutional-looking templates." ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 11 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Decision type**: M&A requires different emphasis than ongoing portfolio monitoring" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Sector-specific needs**: Add relevant metrics early (e.g., cloud ARR, enterprise customers, developer ecosystem for tech)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Industry context**: Big tech mega-caps need different metrics than emerging SaaS startups" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Company familiarity**: Well-known companies may need less background, more focus on delta analysis" ] ],
                        _:ref_ab932f34a5d0fe2c,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "This skill teaches Claude to build institutional-grade comparable company analyses that combine operating metrics, valuation multiples, and statistical benchmarking. The output is a structured Excel/spreadsheet that enables informed investment decisions through peer comparison." ],
