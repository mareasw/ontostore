                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Add: Backlog, Order book trends, Geographic mix" ] ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
