                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 8 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Emphasize: Revenue growth, gross margins, inventory turns" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
