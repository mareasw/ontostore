                                    oc:textContent "**Industrials:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Healthcare:**" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Emphasize: EBITDA margins, growth rates, reimbursement risk" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
