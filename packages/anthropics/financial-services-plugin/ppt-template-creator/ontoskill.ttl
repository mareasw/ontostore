@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_ppt_template_creator a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ppt-template-creator" ;
    skos:broader "Skill factory" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/ppt-template-creator" ;
    oc:contentHash "a5dfeddb6ce6e9a7eef39ac1989144aa28f4f3515358b10e162e0dce5ac2cdce" ;
    oc:dependsOnSkill oc:skill_skill_creator ;
    oc:differentia "that creates self-contained PPT template skills from user-provided PowerPoint templates by extracting layout metadata, placeholder positions, and generating a complete reusable skill package" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "PowerPoint template file (.pptx or .potx)" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Creates self-contained PPT template SKILLS (not presentations) from user-provided PowerPoint templates. Use ONLY when a user wants to create a reusable skill from their template. For creating actual presentations, use the pptx skill instead." ;
    oc:hasName "ppt-template-creator" ;
    oc:impartsKnowledge oc:kn_41ed5eb9,
        oc:kn_585f106b,
        oc:kn_68d0a013,
        oc:kn_718da6d8,
        oc:kn_ffdd962a ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:FileExists ;
    oc:resolvesIntent "analyze PowerPoint template layouts and placeholders",
        "build a branded presentation template skill",
        "create a reusable skill from a PowerPoint template",
        "turn a PPTX template into a skill" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_41ed5eb9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing template layouts in Step 2" ;
    oc:directiveContent "Always extract the OBJECT placeholder's y-position to determine the true content start position, not the subtitle placeholder's end position. Many templates have visual borders or reserved gaps between subtitle and content." ;
    oc:hasRationale "Placing content in the gap between subtitle and OBJECT placeholder causes visual overlap with template decorative elements like borders and lines." ;
    oc:severityLevel "CRITICAL" .

oc:kn_585f106b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the generated SKILL.md in Step 5" ;
    oc:directiveContent "Generated skills must be fully self-contained: the SKILL.md must embed all instructions, placeholder mappings, and layout details with no external references back to this meta-skill." ;
    oc:hasRationale "Self-containment ensures the generated skill works independently without depending on the template creator skill at runtime." ;
    oc:severityLevel "HIGH" .

oc:kn_68d0a013 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating presentation creation code in the output skill" ;
    oc:directiveContent "Always delete all existing slides from the template before adding new ones. Use the rId drop_rel pattern to remove slides cleanly." ;
    oc:hasRationale "Templates often contain example slides that must be removed to avoid them appearing in generated presentations." ;
    oc:severityLevel "HIGH" .

oc:kn_718da6d8 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When writing the placeholder mapping table in Step 5" ;
    oc:directiveContent "Document placeholder positions with exact x, y, width, height coordinates in inches for every layout and placeholder in the generated SKILL.md." ;
    oc:hasRationale "Precise coordinates are essential for placing custom shapes, tables, and charts within safe content boundaries without overlapping template elements." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ffdd962a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing content-filling code in generated SKILL.md" ;
    oc:directiveContent "Never add manual bullet characters in generated skill instructions. Use python-pptx's paragraph.level property for hierarchy instead." ;
    oc:hasRationale "Slide masters handle bullet formatting; manual bullet characters create double-bullets or inconsistent formatting." ;
    oc:severityLevel "HIGH" .

