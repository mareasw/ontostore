oc:skill_financial_services_plugin_bond_relative_value a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "bond-relative-value" ;
    skos:broader "fixed income analysis routine" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/bond-relative-value" ;
    oc:contentHash "099a05d580638011c668e683b0c36a577f6b0a1600048fba8e74ff84b745ebaa" ;
    oc:differentia "decomposes bond spreads into risk-free, credit, and residual components to assess richness or cheapness with scenario stress testing" ;
    oc:handlesFailure oc:DataUnavailable,
        oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasArgumentHint "bond identifier (ISIN, RIC, or CUSIP)" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Perform relative value analysis on bonds by combining pricing, yield curve context, credit spreads, and scenario stress testing. Use when analyzing bond richness/cheapness, computing spread decomposition, comparing bonds, assessing bond value vs curves, or running rate shock scenarios." ;
    oc:hasName "bond-relative-value" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "You are an expert fixed income analyst specializing in relative value. Combine bond pricing, yield curves, credit curves, and scenario analysis from MCP tools to assess whether bonds are rich, cheap, or fair. Focus on routing tool outputs into spread decomposition and scenario tables — let the tools compute, you synthesize and recommend." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Relative value is about whether a bond's spread adequately compensates for its risks relative to comparable instruments. Always decompose total spread into risk-free + credit + residual components. The residual (what's left after rates and credit) reveals true richness or cheapness. Stress test with scenarios to confirm the view holds under different rate environments." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Principles" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**`bond_price`** — Price bonds. Returns clean/dirty price, yield, duration, convexity, DV01, Z-spread. Accepts ISIN, RIC, or CUSIP." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**`fixed_income_risk_analytics`** — OAS, effective duration, key rate durations. Use for callable bonds and deeper risk decomposition." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**`interest_rate_curve`** — Government and swap yield curves. Two-phase: list then calculate. Use to compute G-spreads." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**`credit_curve`** — Credit spread curves by issuer type. Two-phase: search by country/issuerType, then calculate. Use to isolate credit component." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**`yieldbook_scenario`** — Scenario analysis with parallel rate shifts. Returns price change and P&L under each scenario." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**`tscc_historical_pricing_summaries`** — Historical pricing data. Use for historical spread context and Z-score analysis." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Available MCP Tools" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_08e3165210ca03d2 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Tool Chaining Workflow" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "### Scenario P&L" ;
                                    oc:tableMarkdown """| Scenario | Price Change | P&L (per 100 notional) |
|----------|-------------|----------------------|
| -100bp | ... | ... |
| -50bp | ... | ... |
| Base | ... | ... |
| +50bp | ... | ... |
| +100bp | ... | ... |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Scenario P&L" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "State the primary spread metric, its historical context (percentile, comparison to averages), the residual spread signal, and a clear recommendation: rich (avoid/underweight), cheap (buy/overweight), or fair (neutral). Quantify how many bp of spread move would change the recommendation." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Rich/Cheap Summary" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "### Spread Decomposition" ;
                                    oc:tableMarkdown """| Component | Spread (bp) | % of Total |
|-----------|-------------|------------|
| G-spread (total over govt) | ... | 100% |
| Credit curve spread | ... | ...% |
| Residual (liquidity + technicals) | ... | ...% |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Spread Decomposition" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Output Format" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Bond Relative Value Analysis" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: bond-relative-value
description: Perform relative value analysis on bonds by combining pricing, yield curve context, credit spreads, and scenario stress testing. Use when analyzing bond richness/cheapness, computing spread decomposition, comparing bonds, assessing bond value vs curves, or running rate shock scenarios.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow _:ref_08e3165210ca03d2,
        [ a oc:Workflow ;
            dcterms:description "Extended workflow for callable bonds requiring OAS and effective duration" ;
            oc:hasStep _:ref_29a254a10bb379d6,
                [ a oc:WorkflowStep ;
                    dcterms:description "Incorporate OAS and option-adjusted metrics into the final rich/cheap assessment, replacing Z-spread with OAS as the primary metric" ;
                    oc:expectedOutcome "Option-adjusted relative value assessment with complete recommendation" ;
                    oc:stepDependsOn _:ref_29a254a10bb379d6 ;
                    oc:stepId "synthesize-callable" ],
                _:ref_7004a6caf834a2d8 ;
            oc:workflowId "callable-bond-rv" ;
            oc:workflowName "Callable Bond Relative Value Analysis" ],
        [ a oc:Workflow ;
            dcterms:description "Full workflow for decomposing bond spreads and assessing richness/cheapness" ;
            oc:hasStep _:ref_1d2628a41a0c8467,
                _:ref_b5b102ca5381f9b8,
                _:ref_b6c5c4f3b23d1468,
                _:ref_ce250baa9e0a8590,
                _:ref_cf1cba4bc049065f,
                [ a oc:WorkflowStep ;
                    dcterms:description "Combine spread decomposition, scenario results, and historical context into a rich/cheap assessment with quantified recommendation." ;
                    oc:expectedOutcome "Complete relative value assessment with spread decomposition table, scenario P&L table, and actionable recommendation" ;
                    oc:stepDependsOn _:ref_1d2628a41a0c8467,
                        _:ref_b5b102ca5381f9b8,
                        _:ref_b6c5c4f3b23d1468 ;
                    oc:stepId "synthesize" ] ;
            oc:workflowId "bond-rv-analysis" ;
            oc:workflowName "Bond Relative Value Analysis" ] ;
    oc:impartsKnowledge oc:kn_0d9d9322,
        oc:kn_20374bb2,
        oc:kn_2b7d9c92,
        oc:kn_32b38e63,
        oc:kn_397a4505,
        oc:kn_50496c59,
        oc:kn_60b12a95,
        oc:kn_7212994e,
        oc:kn_8034e177,
        oc:kn_8d15af6c ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "analyze bond relative value",
        "assess bond richness or cheapness",
        "compare bonds using spread analysis",
        "decompose bond spreads",
        "run rate shock scenarios on bonds" ;
    oc:yieldsState oc:RelativeValueAssessed .

oc:kn_0d9d9322 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any bond relative value analysis" ;
    oc:directiveContent "Always decompose total spread into risk-free + credit + residual components. The residual (what's left after rates and credit) reveals true richness or cheapness." ;
    oc:hasRationale "Without decomposition, you cannot distinguish whether spread width reflects credit risk, rate risk, or a genuine mispricing opportunity." ;
    oc:severityLevel "CRITICAL" .

oc:kn_20374bb2 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Throughout the analysis workflow" ;
    oc:directiveContent "Let the MCP tools compute; you synthesize and recommend. Route tool outputs into spread decomposition and scenario tables." ;
    oc:hasRationale "The tools provide precise calculations; the analyst's value-add is in interpretation, triangulation of multiple signals, and actionable recommendations." .

oc:kn_2b7d9c92 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting spread metrics for decomposition" ;
    oc:directiveContent "Use G-spread as the primary total spread metric over government curves. Compute residual = G-spread minus credit curve spread to isolate liquidity/technical factors." ;
    oc:hasRationale "G-spread provides a clean comparison to the risk-free government curve; the residual isolates what cannot be explained by rates or credit." ;
    oc:severityLevel "MEDIUM" .

oc:kn_32b38e63 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "After initial spread decomposition" ;
    oc:directiveContent "Stress test with scenarios to confirm the relative value view holds under different rate environments." ;
    oc:hasRationale "A bond that looks cheap in the current rate environment may not remain cheap after a parallel rate shift; scenarios validate the thesis." ;
    oc:severityLevel "HIGH" .

oc:kn_397a4505 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before executing bond relative value analysis" ;
    oc:directiveContent "Requires MCP tools: bond_price, interest_rate_curve, credit_curve, yieldbook_scenario, tscc_historical_pricing_summaries, fixed_income_risk_analytics" .

oc:kn_50496c59 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing a full bond relative value analysis" ;
    oc:directiveContent "1. Call bond_price for target and comparison bonds → extract yield, Z-spread, duration, convexity, DV01. 2. Call interest_rate_curve (list then calculate) for currency → interpolate at maturity → compute G-spread. 3. Call credit_curve for issuer country/type → extract credit spread at maturity → residual = G-spread minus credit spread. 4. Call yieldbook_scenario with shifts (-100bp, -50bp, 0, +50bp, +100bp) → extract price changes and P&L. 5. (Optional) Call tscc_historical_pricing_summaries for historical spread context. 6. Synthesize into rich/cheap assessment with quantified recommendation." ;
    oc:stepOrder 1 .

oc:kn_60b12a95 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling interest_rate_curve or credit_curve MCP tools" ;
    oc:directiveContent "interest_rate_curve and credit_curve both use a two-phase pattern: first list available curves, then calculate specific points. Always call list before calculate." .

oc:kn_7212994e a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When presenting final bond relative value analysis" ;
    oc:directiveContent """### Spread Decomposition
| Component | Spread (bp) | % of Total |
| G-spread (total over govt) | {g_spread} | 100% |
| Credit curve spread | {credit_spread} | {credit_pct}% |
| Residual (liquidity + technicals) | {residual} | {residual_pct}% |

### Scenario P&L
| Scenario | Price Change | P&L (per 100 notional) |
| -100bp | {chg_neg100} | {pnl_neg100} |
| -50bp | {chg_neg50} | {pnl_neg50} |
| Base | {chg_base} | {pnl_base} |
| +50bp | {chg_pos50} | {pnl_pos50} |
| +100bp | {chg_pos100} | {pnl_pos100} |

### Rich/Cheap Summary
State primary spread metric, historical context (percentile, comparison to averages), residual spread signal, and recommendation: rich (avoid/underweight), cheap (buy/overweight), or fair (neutral). Quantify bp of spread move that would change recommendation.""" ;
    oc:templateVariables "chg_base",
        "chg_neg100",
        "chg_neg50",
        "chg_pos100",
        "chg_pos50",
        "credit_pct",
        "credit_spread",
        "g_spread",
        "pnl_base",
        "pnl_neg100",
        "pnl_neg50",
        "pnl_pos100",
        "pnl_pos50",
        "residual",
        "residual_pct" .

oc:kn_8034e177 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When initiating bond relative value analysis" ;
    oc:directiveContent "Bond identifiers must be ISIN, RIC, or CUSIP format. Analysis requires matching currency for risk-free curve and matching issuer country/type for credit curve." ;
    oc:severityLevel "HIGH" .

oc:kn_8d15af6c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When analyzing bonds with embedded options" ;
    oc:directiveContent "For callable bonds, use fixed_income_risk_analytics to get OAS, effective duration, and key rate durations for deeper risk decomposition beyond Z-spread." ;
    oc:hasRationale "Z-spread is misleading for callable bonds because it ignores the option component; OAS strips out optionality." ;
    oc:severityLevel "HIGH" .

_:ref_189d6703e41b518a a oc:WorkflowStep ;
    dcterms:description "**Historical Context (optional):** Call `tscc_historical_pricing_summaries` for the bond to assess where current spread sits vs history." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_1f606867d92c9b4f a oc:WorkflowStep ;
    dcterms:description "**Price the Bond(s):** Call `bond_price` for target and any comparison bonds. Extract yield, Z-spread, duration, convexity, DV01." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_2c50c987c856c64a a oc:WorkflowStep ;
    dcterms:description "**Synthesize:** Combine spread decomposition, scenario results, and historical context into a rich/cheap assessment." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_4b79085bdf540ecc a oc:WorkflowStep ;
    dcterms:description "**Get Credit Curve:** Call `credit_curve` for the issuer's country and type. Extract credit spread at the bond's maturity. Compute residual spread = G-spread minus credit curve spread." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_cb77bfa4872f854f a oc:WorkflowStep ;
    dcterms:description "**Run Scenarios:** Call `yieldbook_scenario` with parallel shifts (-100bp, -50bp, 0, +50bp, +100bp). Extract price changes and P&L per scenario." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_efce5d37d5057c87 a oc:WorkflowStep ;
    dcterms:description "**Get Risk-Free Curve:** Call `interest_rate_curve` (list then calculate) for the bond's currency. Interpolate at bond maturity to compute G-spread." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

