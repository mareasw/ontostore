@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_financial_services_plugin_ib_check_deck a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ib-check-deck" ;
    skos:broader "Quality assurance checker" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/ib-check-deck" ;
    oc:contentHash "2213ef1e8c4ab4f34c9ad466050ea1a16737c1ec7bb320647accad10f6200916" ;
    oc:differentia "that reviews investment banking pitch decks across four dimensions (number consistency, data-narrative alignment, language polish, visual/formatting QC) and produces a severity-categorized findings report" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "Bash",
        "Read",
        "Write" ;
    oc:hasArgumentHint "file path to .pptx presentation or live deck in add-in mode" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Investment banking presentation quality checker. Reviews a pitch deck or client-ready presentation for (1) number consistency across slides, (2) data-narrative alignment, (3) language polish against IB standards, (4) visual and formatting QC. Use whenever the user asks to review, check, QC, proof, or do a final pass on a deck, pitch, or client materials — including requests like \"check my numbers\", \"reconcile figures across slides\", \"is this client-ready\", or \"what am I missing before I send this out\"." ;
    oc:hasName "ib-check-deck" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: ib-check-deck
description: Investment banking presentation quality checker. Reviews a pitch deck or client-ready presentation for (1) number consistency across slides, (2) data-narrative alignment, (3) language polish against IB standards, (4) visual and formatting QC. Use whenever the user asks to review, check, QC, proof, or do a final pass on a deck, pitch, or client materials — including requests like "check my numbers", "reconcile figures across slides", "is this client-ready", or "what am I missing before I send this out".
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Perform comprehensive QC on the presentation across four dimensions. Read every slide, then report findings." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Add-in** — read from the live open deck." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Chat** — read from the uploaded `.pptx` file." ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "This is read-and-report only — no edits — so the workflow is identical in both." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "This skill works in both the PowerPoint add-in and chat. Identify which you're in before starting:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Environment check" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "See `references/ib-terminology.md` for replacement patterns." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "IB decks have a register. Scan for anything that breaks it: casual phrasing (\"pretty good\", \"a lot of\"), contractions, exclamation points, vague quantifiers without numbers, inconsistent terminology for the same concept." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "3. Language polish" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "Visual verification catches overlaps, overflow, and contrast issues that don't show up in text extraction. Don't skip it — a chart with no source citation looks the same as a properly sourced one in the text dump." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Run standard visual verification checks on each slide. You're looking for: missing chart source citations, missing axis labels, typography inconsistencies, number formatting drift (1,000 vs 1K within the same deck), date format drift, footnote and disclaimer gaps." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "4. Visual and formatting QC" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Pull text from every slide, keeping track of which slide each line came from. You'll need slide-level attribution for every finding (\"$500M appears on slides 3 and 8, but slide 15 shows $485M\"). A deck with 30 slides is too much to hold in working memory reliably — write the extracted text to a file so the number-checking script can process it." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "The script expects markdown-ish input with slide markers. Format as:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """## Slide 1
[slide 1 text content]

## Slide 2
[slide 2 text content]
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 3 ;
                                    oc:sourceLocation "lines 27-33" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Read the deck" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "Beyond what the script flags, verify:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """python scripts/extract_numbers.py /tmp/deck_content.md --check
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 39-41" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "It normalizes units ($500M vs $500MM vs $500,000,000 → same number), categorizes values (revenue, EBITDA, multiples, margins), and flags when the same metric category shows conflicting values on different slides. This is the part most likely to catch something a human missed on the fifth read-through." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Run the extraction script on what you collected:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 5 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Unit style is consistent — the deck should pick one of $M or $MM and stick with it" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Time periods are aligned — FY vs LTM vs quarterly, explicitly labeled" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Calculations are correct (totals sum, percentages add up, growth rates match the endpoints)" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "1. Number consistency" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Map claims to the data that's supposed to support them. This is where decks go wrong quietly — someone edits the chart on slide 7 and forgets the narrative on slide 4." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Trend statements (\"declining margins\") → does the chart actually go that direction?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Plausibility — \"#1 in a $100B market\" with $200M revenue is 0.2% share; that's not #1" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Market position claims (\"#1 player\") → revenue and share data support it?" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "2. Data-narrative alignment" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Workflow" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Critical** — number mismatches, factual errors, data contradicting narrative. These block client delivery." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Minor** — font sizes, spacing, date formats. Polish." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Important** — language, missing sources, terminology drift. Should fix." ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Lead with criticals. If there aren't any, say so explicitly — \"no number inconsistencies found\" is a finding, not an absence of one." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use `references/report-format.md` as the structure. Categorize by severity:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Output" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "IB Deck Checker" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Fast check for number mismatches only, without full four-dimension QC" ;
            oc:hasStep _:ref_79b1c9f0603cbffb,
                [ a oc:WorkflowStep ;
                    dcterms:description "Run python scripts/extract_numbers.py /tmp/deck_content.md --check" ;
                    oc:expectedOutcome "JSON output with categorized numbers and flagged inconsistencies" ;
                    oc:stepDependsOn _:ref_79b1c9f0603cbffb ;
                    oc:stepId "run-script" ] ;
            oc:workflowId "quick-number-check" ;
            oc:workflowName "Quick Number Consistency Check" ],
        [ a oc:Workflow ;
            dcterms:description "Full QC pass on an investment banking presentation across four dimensions" ;
            oc:hasStep _:ref_1b5b4512b29d0161,
                _:ref_2a6dbd496905f471,
                _:ref_3ff213beaa155c48,
                [ a oc:WorkflowStep ;
                    dcterms:description "Compile findings using report-format.md template. Categorize by severity (Critical/Important/Minor). Lead with criticals. Explicitly state when a dimension has no issues." ;
                    oc:expectedOutcome "Structured Deck Check Report with all findings categorized by severity" ;
                    oc:stepDependsOn _:ref_2a6dbd496905f471,
                        _:ref_3ff213beaa155c48,
                        _:ref_b59acd6cda177c58,
                        _:ref_e7102d02a71cbd37 ;
                    oc:stepId "generate-report" ],
                _:ref_b59acd6cda177c58,
                _:ref_e7102d02a71cbd37 ;
            oc:workflowId "ib-deck-check" ;
            oc:workflowName "IB Deck Quality Check" ] ;
    oc:impartsKnowledge oc:kn_1db83151,
        oc:kn_3f158e35,
        oc:kn_59d081e2,
        oc:kn_ac397b2b,
        oc:kn_db4857fd,
        oc:kn_f8ae5801,
        oc:kn_fb52af15 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:FileExists ;
    oc:resolvesIntent "check if deck is client-ready",
        "check number consistency across slides",
        "perform final QC pass on client materials",
        "polish IB presentation language",
        "reconcile figures across slides",
        "review pitch deck for errors",
        "verify data-narrative alignment" ;
    oc:yieldsState oc:DocumentReviewed,
        oc:ReportGenerated .

oc:kn_1db83151 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the output report" ;
    oc:directiveContent "Lead the report with criticals. If there are no issues in a dimension, say so explicitly — 'no number inconsistencies found' is a finding, not an absence of one." ;
    oc:hasRationale "Explicit confirmation of clean dimensions gives the user confidence; silence on a dimension is ambiguous" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3f158e35 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "Running this skill multiple times on the same deck produces the same findings — it is purely analytical with no side effects on the source file." ;
    oc:hasRationale "Safe to re-run after partial fixes to verify corrections without risk of corrupting the deck" .

oc:kn_59d081e2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — this is a fundamental design constraint" ;
    oc:directiveContent "This skill is read-and-report only — it never edits the presentation. The workflow is identical in both add-in and chat modes." ;
    oc:hasRationale "Ensures the original deck is never modified during QC, preserving the author's work for manual correction" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ac397b2b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing decks larger than ~10 slides" ;
    oc:directiveContent "Write extracted slide text to a file for the number-checking script rather than holding it all in working memory. Decks with 30+ slides exceed reliable in-context retention." ;
    oc:hasRationale "Avoids losing or conflating numbers across slides due to context window limitations" ;
    oc:severityLevel "HIGH" .

oc:kn_db4857fd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing dimension 4 (Visual and formatting QC)" ;
    oc:directiveContent "Never skip visual verification checks — a chart with no source citation looks the same as a properly sourced one in the text dump." ;
    oc:hasRationale "Text-only extraction misses overlaps, overflow, contrast issues, and missing visual elements that humans catch at a glance" ;
    oc:severityLevel "HIGH" .

oc:kn_f8ae5801 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running extract_numbers.py with --check flag" ;
    oc:directiveContent "The number extraction script normalizes units ($500M vs $500MM vs $500,000,000 to the same value) and categorizes values (revenue, EBITDA, multiples, margins) to detect conflicting values for the same metric category across slides." ;
    oc:hasRationale "Manual cross-referencing across dozens of slides misses unit-format inconsistencies that a normalizer catches automatically" .

oc:kn_fb52af15 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing data-narrative alignment check" ;
    oc:directiveContent "Map narrative claims to their supporting data across slides. Someone edits the chart on slide 7 and forgets the narrative on slide 4 — check trend statements, market position claims, and plausibility of share/revenue ratios." ;
    oc:hasRationale "Cross-slide drift is the most common and hardest-to-catch deck error, often introduced during iterative editing" ;
    oc:severityLevel "HIGH" .

_:ref_2a6dbd496905f471 a oc:WorkflowStep ;
    dcterms:description "Map narrative claims to supporting data: verify trend statements match charts, market position claims match share/revenue data, and plausibility checks (e.g., revenue vs market size ratios)." ;
    oc:expectedOutcome "List of claims contradicted or unsupported by the data presented elsewhere in the deck" ;
    oc:stepDependsOn _:ref_1b5b4512b29d0161 ;
    oc:stepId "data-narrative-alignment" .

_:ref_3ff213beaa155c48 a oc:WorkflowStep ;
    dcterms:description "Run extract_numbers.py --check on extracted content. Then manually verify calculations, unit style consistency ($M vs $MM), and time period alignment (FY vs LTM vs quarterly)." ;
    oc:expectedOutcome "List of number mismatches, calculation errors, unit inconsistencies across slides" ;
    oc:stepDependsOn _:ref_1b5b4512b29d0161 ;
    oc:stepId "number-consistency" .

_:ref_79b1c9f0603cbffb a oc:WorkflowStep ;
    dcterms:description "Extract text from all slides into markdown format with slide markers" ;
    oc:expectedOutcome "Markdown file with slide content" ;
    oc:stepId "extract-slide-text" .

_:ref_b59acd6cda177c58 a oc:WorkflowStep ;
    dcterms:description "Check each slide for missing chart sources, missing axis labels, typography inconsistencies, number format drift (1,000 vs 1K), date format drift, footnote/disclaimer gaps. Verify visually for overlaps, overflow, contrast issues." ;
    oc:expectedOutcome "List of formatting and visual quality issues by slide" ;
    oc:stepDependsOn _:ref_1b5b4512b29d0161 ;
    oc:stepId "visual-formatting-qc" .

_:ref_e7102d02a71cbd37 a oc:WorkflowStep ;
    dcterms:description "Scan for casual phrasing, contractions, exclamation points, vague quantifiers, inconsistent terminology. Reference ib-terminology.md for replacement patterns." ;
    oc:expectedOutcome "List of language issues with suggested IB-standard replacements" ;
    oc:stepDependsOn _:ref_1b5b4512b29d0161 ;
    oc:stepId "language-polish" .

_:ref_1b5b4512b29d0161 a oc:WorkflowStep ;
    dcterms:description "Extract text from every slide with slide-level attribution. Write to markdown file with ## Slide N headers for script processing." ;
    oc:expectedOutcome "Complete markdown file with all slide content and slide markers" ;
    oc:stepId "read-deck" .

