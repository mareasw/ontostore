@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_ib_check_deck_ib_terminology a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ib-terminology" ;
    skos:broader "terminology reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/ib-check-deck" ;
    oc:contentHash "f609b5ca48b09c9d883db5785eb0cdd97f6240d070a9345dea88e8d12171fc7a" ;
    oc:differentia "that maps casual language to investment banking professional standards with replacement patterns and preferred phrasing" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_ib_check_deck ;
    oc:hasArgumentHint "text to review for IB language compliance" ;
    oc:hasCategory "document" ;
    oc:impartsKnowledge oc:kn_205ddfaf,
        oc:kn_97118dd0,
        oc:kn_9a53d6b3,
        oc:kn_e2c74894,
        oc:kn_f78f39a5 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "identify and fix language register violations in IB materials",
        "polish language to IB standards",
        "replace casual phrasing with professional IB terminology" .

oc:kn_205ddfaf a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating narrative claims in IB materials" ;
    oc:directiveContent "Every superlative claim (e.g., 'best-in-class', 'leading', '#1') must be supported by specific data or a cited source." ;
    oc:hasRationale "Unsubstantiated claims in client materials can create legal liability and damage credibility with sophisticated institutional audiences." ;
    oc:severityLevel "CRITICAL" .

oc:kn_97118dd0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing language polish on IB presentations and reports" ;
    oc:directiveContent "Avoid contractions (don't → do not, won't → will not), exclamation points, first-person pronouns ('We think'), and unsupported superlatives ('best-in-class' without data)." ;
    oc:hasRationale "Contractions, first-person, and unsupported claims break the formal register expected in client-facing banking materials and can expose the bank to compliance issues." ;
    oc:severityLevel "HIGH" .

oc:kn_9a53d6b3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or reviewing any investment banking presentation or client-facing material" ;
    oc:directiveContent "Never use casual quantifiers like 'a lot of', 'tons of', 'huge', or 'a bunch of' in IB materials — always replace with precise figures or formal alternatives like 'significant', 'substantial', or 'multiple'." ;
    oc:hasRationale "IB materials demand precision; vague quantifiers undermine credibility and signal lack of rigor to clients and senior bankers." ;
    oc:severityLevel "HIGH" .

oc:kn_e2c74894 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing slide text for language polish during deck QC" ;
    oc:directiveContent "Replace vague descriptors with quantified alternatives: 'pretty good margins' → 'attractive margins of X%', 'cheap valuation' → 'attractive valuation' or 'valuation discount', 'expensive' → 'premium valuation'." ;
    oc:hasRationale "Quantified language is more defensible and professional; it demonstrates analytical rigor and avoids subjective interpretation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f78f39a5 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When drafting or rewriting content in IB pitch decks, CIMs, or client deliverables" ;
    oc:directiveContent "Use IB-standard phrasing patterns for growth narratives ('Demonstrated track record of X% revenue CAGR'), market position ('#X player in [segment]'), and strategic rationale ('Compelling strategic fit driven by...')." ;
    oc:hasRationale "Consistent professional phrasing establishes credibility and aligns with institutional expectations from clients, legal teams, and senior bankers." ;
    oc:severityLevel "MEDIUM" .

