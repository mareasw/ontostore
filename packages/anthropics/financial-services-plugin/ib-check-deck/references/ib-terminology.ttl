@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_financial_services_plugin_ib_check_deck_ib_terminology a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ib-terminology" ;
    skos:broader "Terminology reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/ib-check-deck" ;
    oc:contentHash "f609b5ca48b09c9d883db5785eb0cdd97f6240d070a9345dea88e8d12171fc7a" ;
    oc:differentia "that maps casual/informal language to investment banking standard phrasing and identifies language patterns to avoid in IB materials" ;
    oc:extends oc:skill_financial_services_plugin_ib_check_deck ;
    oc:hasCategory "finance" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 18 ;
                            oc:tableCaption "## Casual to Professional Replacements" ;
                            oc:tableMarkdown """| Casual/Informal | IB Standard |
|-----------------|-------------|
| "a lot of growth" | "significant growth" or "X% growth" |
| "pretty good margins" | "attractive margins" or "margins of X%" |
| "they bought the company" | "the company was acquired" |
| "big deal" | "transformative transaction" |
| "cheap valuation" | "attractive valuation" or "valuation discount" |
| "expensive" | "premium valuation" |
| "make more money" | "enhance profitability" or "drive margin expansion" |
| "getting bigger" | "pursuing growth" or "expanding operations" |
| "cut costs" | "implement cost optimization" or "drive operational efficiencies" |
| "good fit" | "strategic fit" or "compelling strategic rationale" |
| "help with" | "support" or "facilitate" |
| "a bunch of" | "multiple" or "numerous" |
| "kind of" / "sort of" | [remove or be specific] |
| "really" / "very" | [remove or quantify] |
| "tons of" | "substantial" or quantify |
| "huge" | "significant" or quantify |
| "pretty much" | [remove or be precise] |
| "basically" | [remove or clarify] |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Casual to Professional Replacements" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "\"Proven ability to generate organic growth\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\"Consistent margin expansion over [period]\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\"Demonstrated track record of X% revenue CAGR\"" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Growth narratives**:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "**Strategic rationale**:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\"Leading provider of [specific offering]\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "\"Differentiated positioning through [specific attribute]\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\"#X player in [specific segment]\"" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 6 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\"Compelling strategic fit driven by...\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "\"Synergy potential of $Xm from [specific sources]\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\"Attractive value creation opportunity through...\"" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Market position**:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Preferred Phrasing Patterns" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Superlatives without evidence**: \"best-in-class\" requires supporting data" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Contractions**: Don't → Do not, won't → will not" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Exclamation points**: Generally inappropriate for IB materials" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**First-person**: \"We think...\" → \"Management believes...\" or passive voice" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Vague quantifiers**: \"some\", \"many\", \"several\" → specific numbers" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Language Patterns to Avoid" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "IB Terminology Reference" ] ;
    oc:impartsKnowledge oc:kn_33a7c471,
        oc:kn_66d74c68,
        oc:kn_bedf76a9,
        oc:kn_ddafc0e5,
        oc:kn_f86ee047 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "improve deck language quality",
        "professionalize language for IB materials",
        "replace casual phrasing with IB-standard terminology" .

oc:kn_33a7c471 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting or reviewing deck text" ;
    oc:directiveContent "Avoid contractions, exclamation points, first-person pronouns, unevidenced superlatives, and vague quantifiers in IB materials." ;
    oc:hasRationale "These patterns signal informal communication and reduce the perceived rigor and authority of the analysis." ;
    oc:severityLevel "MEDIUM" .

oc:kn_66d74c68 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting growth narratives, market positioning, or strategic rationale sections" ;
    oc:directiveContent "Growth: 'Demonstrated track record of X% revenue CAGR' | Market: '#X player in [specific segment]' | Strategy: 'Compelling strategic fit driven by...' | Value: 'Attractive value creation opportunity through...'" ;
    oc:hasRationale "These phrasing templates are industry-standard and convey precision and authority." .

oc:kn_bedf76a9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When self-editing IB text" ;
    oc:directiveContent "When in doubt, replace vague qualifiers ('really', 'very', 'kind of', 'basically') with specific quantitative data or remove them entirely." ;
    oc:hasRationale "Quantification is the hallmark of professional IB communication; hedging qualifiers add no information and reduce credibility." .

oc:kn_ddafc0e5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Whenever making claims about market position, performance, or scale" ;
    oc:directiveContent "Superlatives like 'best-in-class' must be supported by specific data; vague quantifiers like 'some', 'many', 'several' must be replaced with exact numbers." ;
    oc:hasRationale "IB audiences expect every assertion to be evidence-backed; unsupported claims erode trust." ;
    oc:severityLevel "HIGH" .

oc:kn_f86ee047 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or reviewing any investment banking presentation or document" ;
    oc:directiveContent "Never use casual language ('a lot of', 'pretty good', 'big deal', 'cheap') in IB materials — always substitute IB-standard terminology ('significant', 'attractive margins', 'transformative transaction', 'attractive valuation')." ;
    oc:hasRationale "Casual language undermines credibility with sophisticated clients and stakeholders who expect precise, professional communication." ;
    oc:severityLevel "HIGH" .

