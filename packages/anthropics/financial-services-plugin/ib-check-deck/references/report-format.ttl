@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_financial_services_plugin_ib_check_deck_report_format a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "report-format" ;
    skos:broader "Report template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/ib-check-deck" ;
    oc:contentHash "8f5adbeeb980fbaf2346759c9057a9010a4b0108b377e66aa9f45331673e94b7" ;
    oc:differentia "that structures deck check findings into severity-tiered format with reconciliation checklist for investment banking presentations" ;
    oc:extends oc:skill_financial_services_plugin_ib_check_deck ;
    oc:handlesFailure oc:InvalidInput,
        oc:MissingData ;
    oc:hasCategory "document" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Deck Check Report: [Presentation Name]

## Summary
- Total issues: X
- Critical: X (number mismatches, factual errors)
- Important: X (narrative-data alignment, language)
- Minor: X (formatting)

## Critical Issues

### Number Consistency
1. **[Issue name]** (Slides X, Y)
   - Slide X: [value]
   - Slide Y: [value]
   - Action: [recommendation]

### Data-Narrative Alignment
1. **[Issue name]** (Slides X, Y)
   - Claim: "[quoted text]"
   - Data shows: [contradiction]
   - Action: [recommendation]

## Important Issues

### Language Polish
1. **[Issue type]** (Slide X)
   - Current: "[quoted text]"
   - Suggested: "[replacement]"

## Minor Issues

### Formatting
1. **[Issue type]** (Slide X)
   - [Description and fix]

## Final Checklist
- [ ] Numbers reconciled
- [ ] Narrative matches data
- [ ] Language meets IB standards
- [ ] Charts sourced
- [ ] Formatting consistent
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 5-47" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Report Template" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Critical** (must fix before client delivery):" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Important** (should fix):" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Data contradicting narrative" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Calculation errors" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Factual inaccuracies (names, titles, dates)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Number mismatches across slides" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Casual/informal language" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Missing chart sources" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Terminology inconsistency" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Vague claims without specificity" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 6 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Font/color inconsistencies" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Orphaned text" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Date format variations" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Spacing/alignment issues" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "**Minor** (polish items):" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Issue Severity Classification" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Deck Check Report Format" ] ;
    oc:impartsKnowledge oc:kn_05ad6977,
        oc:kn_331cac58,
        oc:kn_36ad796b,
        oc:kn_80dd36d9,
        oc:kn_ec805fa4 ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:requiresState oc:DeckAnalyzed ;
    oc:resolvesIntent "classify presentation issues by severity",
        "format deck check findings into structured report",
        "generate IB-quality check report with actionable recommendations" ;
    oc:yieldsState oc:ReportGenerated .

oc:kn_05ad6977 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When classifying any deck check finding" ;
    oc:directiveContent "Issue severity must be classified into exactly three tiers: Critical (number mismatches, calculation errors, factual inaccuracies, data contradicting narrative), Important (casual language, vague claims, terminology inconsistency, missing chart sources), Minor (font/color inconsistencies, date format variations, spacing/alignment, orphaned text)" ;
    oc:hasRationale "Three-tier severity ensures reviewers prioritize fixes correctly — Critical blocks client delivery, Important degrades professionalism, Minor is polish" ;
    oc:severityLevel "HIGH" .

oc:kn_331cac58 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating a deck check report" ;
    oc:directiveContent """# Deck Check Report: [Presentation Name]
## Summary (Total/Critical/Important/Minor counts)
## Critical Issues — Number Consistency, Data-Narrative Alignment
## Important Issues — Language Polish
## Minor Issues — Formatting
## Final Checklist (numbers reconciled, narrative matches data, language meets IB standards, charts sourced, formatting consistent)""" ;
    oc:templateVariables "Critical count",
        "Description and fix",
        "Important count",
        "Issue name",
        "Issue type",
        "Minor count",
        "Presentation Name",
        "Slide numbers",
        "Total issues",
        "contradiction",
        "quoted text",
        "recommendation",
        "replacement",
        "value" .

oc:kn_36ad796b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When determining whether an issue is blocking for client delivery" ;
    oc:directiveContent "Critical issues must be fixed before client delivery. They include number mismatches across slides, calculation errors, factual inaccuracies (names, titles, dates), and data contradicting narrative text." ;
    oc:hasRationale "Investment banking presentations with numerical errors destroy credibility and can have legal/financial consequences" ;
    oc:severityLevel "CRITICAL" .

oc:kn_80dd36d9 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting critical issues in the report" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """### Number Consistency
1. **[Issue name]** (Slides X, Y)
   - Slide X: [value]
   - Slide Y: [value]
   - Action: [recommendation]

### Data-Narrative Alignment
1. **[Issue name]** (Slides X, Y)
   - Claim: "[quoted text]"
   - Data shows: [contradiction]
   - Action: [recommendation]""" .

oc:kn_ec805fa4 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing and delivering the deck check report" ;
    oc:directiveContent "Before delivering a deck check report, verify: all numbers are reconciled across slides, narrative matches data, language meets IB standards, all charts have sources, and formatting is consistent." ;
    oc:hasRationale "The final checklist serves as a quality gate ensuring no issue category was missed during the review" .

