@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_ib_check_deck_report_format a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "report-format" ;
    skos:broader "Report template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/ib-check-deck" ;
    oc:contentHash "8f5adbeeb980fbaf2346759c9057a9010a4b0108b377e66aa9f45331673e94b7" ;
    oc:differentia "Defines the structured output format and severity classification system for investment banking deck check reports" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_ib_check_deck ;
    oc:hasCategory "document" ;
    oc:impartsKnowledge oc:kn_10ee4d77,
        oc:kn_b0e4e6a4,
        oc:kn_b15bf5d8,
        oc:kn_c402515f,
        oc:kn_c7c8e4f4 ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:resolvesIntent "classify issue severity in presentation review",
        "format deck check report",
        "generate structured audit report for pitch deck" .

oc:kn_10ee4d77 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finalizing a presentation for external distribution" ;
    oc:directiveContent "Critical issues — number mismatches, calculation errors, factual inaccuracies, and data contradicting narrative — must be fixed before client delivery." ;
    oc:hasRationale "Client-facing materials with factual or numerical errors destroy credibility in investment banking contexts." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b0e4e6a4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When categorizing any finding during a deck check review" ;
    oc:directiveContent "Issues must be classified into exactly three tiers: Critical (number mismatches, factual errors), Important (narrative-data alignment, language), and Minor (formatting polish)." ;
    oc:hasRationale "Three-tier severity provides clear prioritization so the team knows what must be fixed before client delivery versus what is optional polish." ;
    oc:severityLevel "HIGH" .

oc:kn_b15bf5d8 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing the deck check report and before declaring the review finished" ;
    oc:directiveContent "Use the Final Checklist to confirm: numbers reconciled, narrative matches data, language meets IB standards, charts sourced, and formatting consistent." ;
    oc:hasRationale "The checklist acts as a safety net ensuring no category of review was overlooked before the report is delivered." .

oc:kn_c402515f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When documenting any finding in the deck check report" ;
    oc:directiveContent "Every reported issue must include the slide reference(s), the specific discrepancy (current vs. expected), and an actionable recommendation." ;
    oc:hasRationale "Vague reports without slide references and actions are unusable by the team preparing the deck for client delivery." .

oc:kn_c7c8e4f4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing up any issue in the report" ;
    oc:directiveContent "Never deliver a deck check report without quoting the exact text from the slide and showing the specific contradiction or error." ;
    oc:hasRationale "Imprecise references force the reviewer to re-locate the issue, wasting time and introducing ambiguity about what needs fixing." ;
    oc:severityLevel "MEDIUM" .

