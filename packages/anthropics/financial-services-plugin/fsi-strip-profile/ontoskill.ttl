oc:kn_2863a29a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During slide-by-slide creation workflow" ;
    oc:directiveContent "Create ONE slide at a time and get user approval before proceeding. Convert each slide to image for visual review." ;
    oc:hasRationale "Iterative approval prevents wasted effort and ensures each slide meets quality standards before building the next." ;
    oc:severityLevel "CRITICAL" .

oc:kn_2a30d2cf a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any slide" ;
    oc:directiveContent "Use 4:3 aspect ratio (LAYOUT_4x3) for all slides — 10\" wide × 7.5\" tall. This is standard IB pitch book format." ;
    oc:hasRationale "Investment banking standard is 4:3, not widescreen 16:9." ;
    oc:severityLevel "CRITICAL" .

oc:kn_34dd9079 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding financial data to any slide" ;
    oc:directiveContent "Never use plain text prose or HTML tables for financial data — always use native PptxGenJS tables or charts." ;
    oc:hasRationale "Plain text and HTML tables don't render properly in PowerPoint and break the professional formatting required for IB deliverables." ;
    oc:severityLevel "CRITICAL" .

oc:kn_568001bf a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing financial data for slides" ;
    oc:directiveContent "Normalize all amounts to consistent currency and consistent scaling ($mm or $bn throughout, never mixed)." ;
    oc:hasRationale "Mixed scaling causes confusion and undermines the professional quality of the deliverable." ;
    oc:severityLevel "HIGH" .

oc:kn_5ef7de9f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting slide creation" ;
    oc:directiveContent "Research actual company brand colors via web search before creating slides. Do not guess or assume colors." ;
    oc:hasRationale "Using correct brand colors signals attention to detail and professionalism expected in IB materials." ;
    oc:severityLevel "MEDIUM" .

oc:kn_72609906 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding bullet-point content to slides" ;
    oc:directiveContent "Never create multiple separate textboxes for individual bullet points — use ONE textbox per section with all bullets inside." ;
    oc:hasRationale "Separate textboxes cause alignment issues and make spacing unpredictable. A single textbox with paragraph spacing handles layout naturally." ;
    oc:severityLevel "HIGH" .

oc:kn_b50939a8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating any quadrant with content" ;
    oc:directiveContent "Maximize information density — a busy executive should understand the entire company story in 30 seconds. Fill every quadrant to capacity with 6-8 bullets minimum." ;
    oc:hasRationale "Strip profiles are designed for rapid executive consumption; sparse content wastes valuable slide real estate." ;
    oc:severityLevel "HIGH" .

oc:kn_d4f95e09 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When deciding between chart vs table for financial data" ;
    oc:directiveContent "For single-slide profiles use tables for financials (more space-efficient). For multi-slide profiles include 2-3 actual charts. Never use both table and chart in the same quadrant." ;
    oc:hasRationale "Tables are denser for single slides; charts add visual variety across multi-slide decks." ;
    oc:severityLevel "MEDIUM" .

oc:kn_dbb9d8f8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When detecting text overlap or cutoff during visual review" ;
    oc:directiveContent "If text overflows, reduce font size by 1pt and re-render rather than removing content. Fix overlap in order: 1) reduce font size, 2) shorten text, 3) adjust positions." ;
    oc:hasRationale "Content density is the top priority — shrinking text preserves information while fixing layout issues." ;
    oc:severityLevel "HIGH" .

oc:kn_fcddd68a a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "During mandatory visual review of every rendered slide" ;
    oc:directiveContent "Check for these specific visual issues on every page: table rows colliding with text below, chart x-axis labels cut off, bullet wrapping into adjacent content, quadrant content bleeding, title/content overlap, legend overlap, footer collision." ;
    oc:hasRationale "These are the most common layout failures in dense slide creation and must be explicitly checked." ;
    oc:severityLevel "HIGH" .

