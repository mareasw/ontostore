    oc:yieldsState oc:ReportValidated .

oc:kn_0b000317 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any text in the initiation report" ;
    oc:directiveContent "Never use vague prose like 'Strong revenue' — always lead with numbers: 'Revenue grew 15% to $1.2B'. Use 'vs.' not 'versus'. Maintain professional institutional tone with no informal language." ;
    oc:hasRationale "Institutional research writing conventions demand quantitative precision and formal tone." ;
    oc:severityLevel "MEDIUM" .

oc:kn_0c5f8adf a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building or reviewing the Excel financial model" ;
    oc:directiveContent "XLS model must use blue text for hardcoded inputs, black text for formulas, green text for cross-sheet links. All numbers must flow: changing one assumption updates the entire model." ;
    oc:hasRationale "Color-coded cells and linked formulas are industry-standard for auditable financial models." ;
    oc:severityLevel "HIGH" .

oc:kn_35fb7c6a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After both DOCX and XLS files are created" ;
    oc:directiveContent "Cross-check 10-15 key numbers (revenue, EPS, margins, valuation, price target) between the DOCX report and XLS model. Numbers must match EXACTLY." ;
    oc:hasRationale "Inconsistencies between deliverables erode client trust and signal careless work." ;
    oc:severityLevel "HIGH" .

oc:kn_475cd195 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Immediately before delivering the final report" ;
    oc:directiveContent "Before delivery, verify actual counts: pages (30-50), charts (25-35 PNG/JPG), tables (12-20), words (10,000-15,000), XLS tabs (15+), cross-file number match (10+ spot checks), Page 1 header says 'INITIATING COVERAGE'." ;
    oc:hasRationale "A final quantitative check prevents delivery of substandard work." ;
    oc:severityLevel "CRITICAL" .

oc:kn_56525803 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When embedding charts in the DOCX report" ;
    oc:directiveContent "Charts must be actual PNG/JPG image files embedded in the DOCX — NOT text descriptions of charts." ;
    oc:hasRationale "Text-described charts are a major failure mode that makes the report unusable for institutional clients." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9b22af2b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding citations and references throughout the report" ;
    oc:directiveContent "All URLs must be clickable hyperlinks (not plain text). SEC filings link to EDGAR viewer, transcripts link to Seeking Alpha or company IR, subscription data noted as '(subscription required)'. No raw URLs displayed." ;
    oc:hasRationale "Hyperlinked sources are mandatory for professional research reports — they enable verification and demonstrate rigor." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a32e1460 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before delivering any initiation report" ;
    oc:directiveContent "DOCX report must be 30-50 pages, 10,000-15,000 words, with 25-35 actual PNG/JPG charts and 12-20 comprehensive tables. XLS model must have 15+ tabs. Do NOT deliver if any minimum is unmet." ;
    oc:hasRationale "Institutional equity research clients expect comprehensive, data-dense reports. Sub-minimum deliverables damage credibility." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b78c604b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating charts for the report" ;
    oc:directiveContent "Use specific chart formats: Revenue by product = Stacked Area, Revenue by geography = Stacked Bar, DCF sensitivity = 2-way Heat Map with color coding, Valuation football field = Horizontal bar chart." ;
    oc:hasRationale "Standardized chart formats are expected in institutional research and improve readability." ;
    oc:severityLevel "MEDIUM" .

