@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_initiating_coverage_quality_checklist a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "quality-checklist" ;
    skos:broader "Quality control checklist" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/initiating-coverage" ;
    oc:contentHash "1bb73c5420e56b3e01109a883ee22ae5b3bacff40722697f4c3fbb070feff913" ;
    oc:differentia "that validates equity research initiation reports against institutional-grade standards for completeness, formatting, consistency, and content depth before delivery" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_initiating_coverage ;
    oc:handlesFailure oc:CrossFileMismatch,
        oc:MissingDeliverable,
        oc:ReportIncomplete ;
    oc:hasArgumentHint "initiation-report-files (DOCX + XLS deliverables to validate)" ;
    oc:hasCategory "finance" ;
    oc:impartsKnowledge oc:kn_13daf95d,
        oc:kn_4edfee24,
        oc:kn_977aef48,
        oc:kn_b75538a8,
        oc:kn_d303d01f ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DocumentCreated,
        oc:FileExists ;
    oc:resolvesIntent "check report completeness before delivery",
        "ensure institutional-grade formatting and citations",
        "validate initiation report quality",
        "verify cross-file consistency between DOCX and XLS" ;
    oc:yieldsState oc:DeliverablesVerified,
        oc:ReportValidated .

oc:kn_13daf95d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During cross-file consistency verification" ;
    oc:directiveContent "All key financial numbers (revenue, EPS, margins, valuation, price target) must match EXACTLY between the DOCX report and XLS financial model. Spot-check 10-15 key numbers before delivery." ;
    oc:hasRationale "Inconsistencies between the narrative report and the financial model undermine the entire analysis and erode client trust" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4edfee24 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting citations, figures, and tables in the DOCX report" ;
    oc:directiveContent "Every figure needs a caption above ('Figure X - [Company] [Descriptive Title]'), a source line below with specific document name and date, and sequential numbering. All URLs must be clickable hyperlinks, not plain text." ;
    oc:hasRationale "Source attribution and clickable hyperlinks are mandatory for institutional compliance and enable readers to verify data independently" ;
    oc:severityLevel "HIGH" .

oc:kn_977aef48 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before delivering any initiation report" ;
    oc:directiveContent "Never deliver an initiation report with fewer than 30 pages, 25 embedded charts, 12 tables, or 10,000 words. The DOCX and XLS are both mandatory deliverables. Charts must be actual PNG/JPG files, not text descriptions." ;
    oc:hasRationale "Substandard deliverables damage institutional credibility and violate professional equity research standards" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b75538a8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building or reviewing the Excel financial model" ;
    oc:directiveContent "The XLS model must use blue text for hardcoded inputs, black for formulas, green for cross-sheet links. The model must have 15+ tabs and all numbers must flow dynamically from assumptions through projections to valuation." ;
    oc:hasRationale "Color-coding conventions and dynamic linking are industry-standard practices that ensure model auditability and reduce errors" ;
    oc:severityLevel "HIGH" .

oc:kn_d303d01f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When laying out the DOCX report structure and selecting chart types" ;
    oc:directiveContent "Charts and tables must be interspersed throughout the report, not grouped at the end. Every page should have both text AND visuals. Revenue by product must use Stacked Area format, revenue by geography Stacked Bar, DCF sensitivity a 2-way Heat Map, and valuation a horizontal bar football field chart." ;
    oc:hasRationale "Proper visual distribution and standardized chart formats improve readability and match institutional investor expectations" ;
    oc:severityLevel "MEDIUM" .

