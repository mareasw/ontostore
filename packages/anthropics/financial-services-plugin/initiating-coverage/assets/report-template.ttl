    oc:isUserInvocable true ;
    oc:nature "Template" ;
    oc:resolvesIntent "create valuation analysis sections (DCF, comps, football field)",
        "format professional investment research with DOCX",
        "generate chart images for equity research report",
        "layout investment update page with rating box and financial metrics",
        "structure an equity research initiation report" .

oc:kn_0da6ecfa a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "For every chart, graph, or data table in the report" ;
    oc:directiveContent "All charts and tables must use sequential figure numbering (Figure 1, Figure 2, etc.) with descriptive titles and source lines in the format: 'Source: Company data, [Firm Name] estimates.'" ;
    oc:hasRationale "Professional equity research follows strict figure numbering conventions for cross-referencing and compliance." ;
    oc:severityLevel "HIGH" .

oc:kn_5e05449d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the Financial Analysis & Performance section (Pages 21-24)" ;
    oc:directiveContent "Three charts are mandatory in the Financial Analysis section: Revenue by Product/Segment (stacked area), Revenue by Geography (stacked bar), and Revenue Growth Trajectory (line with annotations)." ;
    oc:hasRationale "These three charts are the most critical visualizations institutional investors look for to understand revenue quality and diversification." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7e0fafba a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When laying out any page of the report" ;
    oc:directiveContent "Every page must be information-dense with interspersed text, charts, and tables. Never have orphaned section headers alone, a single chart on its own page, or pages with text-only or charts-only content." ;
    oc:hasRationale "Institutional research reports maximize information density (60-80% page coverage) — white space and orphaned elements signal amateur quality." ;
    oc:severityLevel "HIGH" .

oc:kn_80554954 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the Valuation Analysis section (Pages 32-34)" ;
    oc:directiveContent "The Valuation section must include: DCF sensitivity as a 2-way heatmap table with color coding (WACC vs Terminal Growth Rate), comparable companies table with both individual company data AND statistical summary (median, quartiles), and a horizontal bar football field chart showing all valuation method ranges with current price overlay." ;
    oc:hasRationale "These three formats are institutional standards — the heatmap, dual-part comp table, and football field are expected by professional investors." ;
    oc:severityLevel "HIGH" .

oc:kn_81ab1fdf a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When constructing Page 1 of the report" ;
    oc:directiveContent "Page 1 is an Investment Update (NOT Executive Summary) with: rating box (top-left), analyst credentials, stock price performance chart (Figure 1, top-right), 3-4 ■-bulleted insights with bold topic headers and 3-5 sentence explanations, and a financial/valuation metrics table at bottom." ;
    oc:hasRationale "Page 1 follows the specific institutional format used by professional equity research firms — it is the most critical page." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c46dab65 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing Page 1 bullet points" ;
    oc:directiveContent "Investment thesis bullets on Page 1 must use ■ character, lead with bold topic headers capturing the main point, follow with 3-5 sentences of specific analysis with quantification, and use 'vs.' not 'versus'." ;
    oc:hasRationale "This is the specific format used by institutional equity research firms for their investment update bullet points." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c86c2430 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when producing the final report document" ;
    oc:directiveContent "The report MUST be created using the DOCX skill — never generate markdown content as the final output. Generate 20-30+ chart images as PNG/JPG files using Python (matplotlib/plotly) BEFORE creating the Word document, then embed them inline." ;
    oc:hasRationale "Professional equity research requires proper Word formatting with styles, headers/footers, and embedded chart images — markdown cannot achieve institutional quality." ;
    oc:severityLevel "CRITICAL" .

oc:kn_df2fa21d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting DOCX document creation" ;
    oc:directiveContent "Before creating the DOCX: (1) Generate all 20-30+ chart images as PNG/JPG files using matplotlib/plotly, (2) Verify all financial data is consistent across tables and charts, (3) Ensure figure numbering is sequential throughout the entire report." ;
    oc:hasRationale "Chart images must exist as files before embedding; data consistency and sequential numbering are critical for professional credibility." ;
    oc:severityLevel "HIGH" .

oc:kn_e5fef907 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting financial tables throughout the report" ;
    oc:directiveContent "Use 'A' suffix for actual/historical years and 'E' suffix for estimated/projected years in all financial tables (e.g., 2023A, 2025E)." ;
    oc:hasRationale "Standard equity research convention distinguishes reported results from analyst estimates for compliance and clarity." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fbe43d5b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning report writing order" ;
    oc:directiveContent "Do NOT write the Page 1 Investment Update first. Write it LAST after completing the full analysis, even though it appears on page 1." ;
    oc:hasRationale "The Investment Update synthesizes all analysis — it can only be accurate and comprehensive after the full body of research is complete." ;
    oc:severityLevel "MEDIUM" .

