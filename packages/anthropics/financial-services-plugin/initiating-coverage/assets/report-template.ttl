@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_initiating_coverage_report_template a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "report-template" ;
    skos:broader "Document template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/initiating-coverage" ;
    oc:contentHash "7b9c98e9fde6622e111b6ec046d2933bf8bad4d17ba3b385a59a30f16e8cc9e4" ;
    oc:differentia "that defines the page-by-page structure, layout, and formatting standards for institutional equity research initiation reports, including investment update page format, figure numbering conventions, chart placement requirements, and section-by-section content specifications" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_initiating_coverage ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "N/A - reference template used internally by Task 5 report assembly" ;
    oc:hasCategory "finance" ;
    oc:impartsKnowledge oc:kn_060bed05,
        oc:kn_0a9988d6,
        oc:kn_326e07be,
        oc:kn_4448242b,
        oc:kn_59a5a95d,
        oc:kn_eaf5fb80 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:ChartsGenerated,
        oc:CompanyResearchComplete,
        oc:FinancialModelComplete,
        oc:ValuationAnalysisComplete ;
    oc:resolvesIntent "define chart and table placement in coverage reports",
        "format institutional research report pages",
        "structure equity research initiation report",
        "template investment update page layout" ;
    oc:yieldsState oc:ReportStructureDefined .

oc:kn_060bed05 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When inserting any visual element into the report" ;
    oc:directiveContent "Every chart, graph, and table must have sequential figure numbering (Figure 1, Figure 2, etc.), a descriptive title in the format 'Figure X - [Company] [Specific Metric] [Type]', and a source line at the bottom such as 'Source: Company data, [Firm Name] estimates.'" ;
    oc:hasRationale "Figure numbering and source attribution are non-negotiable standards in institutional research; missing these undermines credibility and violates compliance norms" ;
    oc:severityLevel "HIGH" .

oc:kn_0a9988d6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning and placing all charts in the report" ;
    oc:directiveContent "Reports must contain 20-30+ chart images generated as PNG/JPG files and embedded inline within text sections. Charts must NEVER be grouped on separate pages — they must be interspersed throughout the narrative." ;
    oc:hasRationale "Visual density is a hallmark of institutional research; grouping charts at the end is a common amateur mistake that reduces readability" ;
    oc:severityLevel "HIGH" .

oc:kn_326e07be a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assembling the final report document" ;
    oc:directiveContent "Every page must contain both text AND visual elements (charts or tables). Never have a section header alone on a page, a single chart on its own page, or multiple consecutive pages of pure text. Target 60-80% page coverage with 1 chart per 200-300 words of text." ;
    oc:hasRationale "Professional equity research is extremely information-dense; orphaned sections and sparse pages signal low-quality work to institutional readers" ;
    oc:severityLevel "HIGH" .

oc:kn_4448242b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any financial text or table in the report" ;
    oc:directiveContent "Use 'A' suffix for actual/historical years and 'E' suffix for estimated/projected years in all financial tables. Lead with specific numbers using 'vs.' (not 'versus'). Be concrete and quantify all statements." ;
    oc:hasRationale "Year notation consistency prevents misreading of historical vs. projected data; leading with numbers is the institutional research writing standard" ;
    oc:severityLevel "MEDIUM" .

oc:kn_59a5a95d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating Page 1 of any equity research initiation report" ;
    oc:directiveContent "Page 1 must use the 'Investment Update' institutional format with a rating box (top-left), stock price performance chart (top-right), 3-4 detailed bullets with ■ character and bold topic headers, and a financial/valuation metrics table at the bottom — NOT a traditional executive summary." ;
    oc:hasRationale "Professional equity research firms (JPMorgan, Goldman Sachs, Morgan Stanley) use this specific layout; deviating from it makes the report look amateurish to institutional investors" ;
    oc:severityLevel "CRITICAL" .

oc:kn_eaf5fb80 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When producing the final deliverable document" ;
    oc:directiveContent "Never generate markdown content as the final report. The actual report MUST be created using the DOCX skill with proper styles, headers/footers, page numbers, and actual embedded chart images." ;
    oc:hasRationale "Delivering markdown instead of a professional Word document defeats the purpose of the entire multi-task workflow and is not acceptable for institutional distribution" ;
    oc:severityLevel "CRITICAL" .

