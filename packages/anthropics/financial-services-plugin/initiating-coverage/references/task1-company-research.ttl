@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_initiating_coverage_task1_company_research a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "task1-company-research" ;
    skos:broader "Equity research workflow step" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/initiating-coverage" ;
    oc:contentHash "00ec47ca64c1cfdf6e1b74fa8c693633b5e12e98264667b40f2d7dea90b48227" ;
    oc:differentia "that conducts comprehensive company research including business model analysis, management profiling, competitive intelligence, industry analysis, and risk assessment to produce a 6,000-8,000 word research document as the foundational task of a 5-task initiating coverage pipeline" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_initiating_coverage ;
    oc:handlesFailure oc:CompanyNotFound,
        oc:DocumentTooShort,
        oc:InsufficientDataSources ;
    oc:hasArgumentHint "company-name-or-ticker" ;
    oc:hasCategory "finance" ;
    oc:hasRequirement oc:req_5225b92a,
        oc:req_83a2e81e,
        oc:req_adad5d46,
        oc:req_b8983209,
        oc:req_c8750f1d ;
    oc:impartsKnowledge oc:kn_31ac585b,
        oc:kn_62b9e302,
        oc:kn_69b5aa87,
        oc:kn_739e5194,
        oc:kn_86589ae1,
        oc:kn_890bd27c,
        oc:kn_af56b499,
        oc:kn_f41c0314 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:CompanyIdentified ;
    oc:resolvesIntent "analyze company business model and competitive position",
        "assess company risks for investment analysis",
        "gather and synthesize company intelligence from SEC filings and secondary sources",
        "produce a company research document",
        "profile company management team",
        "research a company for equity coverage initiation" ;
    oc:yieldsState oc:CompanyResearchDocumentCreated .

oc:kn_31ac585b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When conducting competitive intelligence in Step 4" ;
    oc:directiveContent "Competitive analysis must cover 5-10 specific competitors including direct, indirect, and emerging/disruptor competitors. Map each on key dimensions (price, features, scale) and identify switching costs and network effects." ;
    oc:hasRationale "Shallow competitive analysis fails to position the company accurately. Including multiple competitor tiers ensures comprehensive landscape understanding." ;
    oc:severityLevel "MEDIUM" .

oc:kn_62b9e302 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the Risk Assessment section" ;
    oc:directiveContent "Risk assessment must identify 8-12 distinct risks across exactly four categories: company-specific (4-6), industry/market (3-4), financial (2-3), and macroeconomic (2-3). Each risk needs 50-100 words with impact quantification and mitigating factors." ;
    oc:hasRationale "Incomplete risk coverage exposes analysts to blind spots. The four-category framework ensures balanced risk assessment across all dimensions." ;
    oc:severityLevel "HIGH" .

oc:kn_69b5aa87 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the company research document" ;
    oc:directiveContent "Write 6,000-8,000 words with all 9 required sections meeting specific word count targets. Do not abbreviate sections to save time or skip any required sections." ;
    oc:hasRationale "Institutional equity research demands comprehensive coverage. Abbreviated documents lack the analytical depth needed for investment decisions and fall below professional standards." ;
    oc:severityLevel "CRITICAL" .

oc:kn_739e5194 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When completing Task 1 output delivery" ;
    oc:directiveContent "Never deliver extra documents alongside the research document (no completion summaries, executive summaries, or next-steps documents). Deliver ONLY the single .md research file." ;
    oc:hasRationale "Extra deliverables waste context and are not part of the professional workflow. The research document is the sole output." ;
    oc:severityLevel "HIGH" .

oc:kn_86589ae1 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing the research document before delivery" ;
    oc:directiveContent "Verify the research document meets the 6,000-8,000 word target, includes all 9 required sections with minimum word counts, covers 5-10 competitors, profiles 3-4 executives with 300-400 word bios, and identifies 8-12 risks across all 4 categories." ;
    oc:hasRationale "Missing sections or insufficient depth means the document cannot serve as reliable input for downstream Tasks 2, 4, and 5." ;
    oc:severityLevel "HIGH" .

oc:kn_890bd27c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning the data collection phase" ;
    oc:directiveContent "Start research with the company website and SEC filings, then expand to secondary sources (competitor filings, industry reports, news). Always check the 10-K for the company's own list of competitors." ;
    oc:hasRationale "Primary sources provide the most reliable and detailed data. The 10-K competitor list gives an authoritative starting point for competitive intelligence." ;
    oc:severityLevel "MEDIUM" .

oc:kn_af56b499 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When researching and writing the Management Team section" ;
    oc:directiveContent "Management bios must be 300-400 words each for 3-4 key executives (CEO and CFO always required, plus 2 additional C-suite). Each bio must cover current role, prior experience, key accomplishments, and education." ;
    oc:hasRationale "Insufficient management profiling undermines the reader's ability to assess leadership quality and execution capability, a critical factor in investment decisions." ;
    oc:severityLevel "HIGH" .

oc:kn_f41c0314 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning Task 1 execution" ;
    oc:directiveContent "Verify that the company name or ticker symbol is provided before starting. This is the only prerequisite for Task 1." ;
    oc:hasRationale "Task 1 is fully independent with no other task dependencies, but it cannot proceed without knowing which company to research." ;
    oc:severityLevel "CRITICAL" .

oc:req_5225b92a a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Web search for company data and SEC filings" .

oc:req_83a2e81e a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "SEC filing types (10-K, 10-Q, DEF 14A, 8-K)" .

oc:req_adad5d46 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "SEC EDGAR access for public company filings" .

oc:req_b8983209 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Equity research institutional standards (JPMorgan, Goldman Sachs, Morgan Stanley)" .

oc:req_c8750f1d a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Markdown file writing capability" .

