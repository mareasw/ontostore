    oc:requirementValue "pandas" .

oc:req_7922f00a a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "External market data (Yahoo Finance, Bloomberg)" .

oc:req_90e744ab a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Valuation analysis from Task 3" .

oc:req_b5761c69 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "plotly" .

oc:req_c3f5d782 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "seaborn" .

oc:req_fe6b6a53 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "matplotlib" .

