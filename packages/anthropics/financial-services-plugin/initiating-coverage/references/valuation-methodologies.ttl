                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "Weight recent transactions more heavily" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Adjust for differences in transaction rationale" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
