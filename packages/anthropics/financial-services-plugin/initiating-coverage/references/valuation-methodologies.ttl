                                                    oc:itemText "Typical range: 20-40%" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Unaffected Price = Target's stock price 1-2 days before announcement" ] ] ;
