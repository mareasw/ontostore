                                            oc:contentOrder 3 ;
                                            oc:textContent "**Calculate Control Premium:**" ],
                                        [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """Transaction Value = Equity Purchase Price + Assumed Debt - Cash Acquired

EV/Revenue (LTM) = Transaction Value / Target's LTM Revenue
EV/EBITDA (LTM) = Transaction Value / Target's LTM EBITDA
EV/EBIT (LTM) = Transaction Value / Target's LTM EBIT
""" ;
                                            oc:codeLanguage "" ;
                                            oc:contentOrder 2 ;
                                            oc:sourceLocation "lines 300-306" ],
                                        [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """Control Premium = (Offer Price - Unaffected Price) / Unaffected Price
""" ;
                                            oc:codeLanguage "" ;
                                            oc:contentOrder 4 ;
                                            oc:sourceLocation "lines 309-311" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**Same multiples as trading comps, but based on transaction value:**" ],
