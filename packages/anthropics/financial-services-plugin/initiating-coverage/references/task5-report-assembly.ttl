@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_initiating_coverage_task5_report_assembly a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "task5-report-assembly" ;
    skos:broader "Report assembly workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/initiating-coverage" ;
    oc:contentHash "7e2f2ccc6bfb54a4be247cd29a9aa95df20a624bb82243980d4f31412e7172ed" ;
    oc:differentia "integrates all prior task outputs (company research, financial model, valuation analysis, charts) into a comprehensive 30-50 page institutional equity research initiation report in DOCX format" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_initiating_coverage ;
    oc:handlesFailure oc:FileNotFound,
        oc:InsufficientContent,
        oc:MissingPrerequisiteTask ;
    oc:hasAlias "compile report",
        "final report",
        "report assembly",
        "task 5" ;
    oc:hasAllowedTool "DOCX",
        "Read",
        "Write",
        "XLSX" ;
    oc:hasArgumentHint "company name or ticker (requires all Tasks 1-4 outputs to exist)" ;
    oc:hasCategory "finance" ;
    oc:hasRequirement oc:req_18479262,
        oc:req_694611fd,
        oc:req_6b3b0834,
        oc:req_7e77815e,
        oc:req_d1aa4837,
        oc:req_de844365,
        oc:req_f4344f42 ;
    oc:impartsKnowledge oc:kn_25df5e57,
        oc:kn_392e1a69,
        oc:kn_7681420c,
        oc:kn_7819cde4,
        oc:kn_82211dd4,
        oc:kn_9c9c21ca,
        oc:kn_a8fda3de,
        oc:kn_b70ffbf6,
        oc:kn_d084a6eb,
        oc:kn_d41bb88f ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:ChartFilesGenerated,
        oc:CompanyResearchComplete,
        oc:FinancialModelComplete,
        oc:ValuationAnalysisComplete ;
    oc:resolvesIntent "assemble equity research report",
        "compile initiation report from research tasks",
        "create publication-ready equity research DOCX",
        "integrate financial model and valuation into final report",
        "produce institutional-grade equity research document" ;
    oc:yieldsState oc:InitiationReportDelivered,
        oc:ReportAssembled .

oc:kn_25df5e57 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting Task 5 report assembly" ;
    oc:directiveContent "Verify ALL Tasks 1-4 are complete before starting Task 5: Task 1 (6-8K word research document), Task 2 (financial model with 6 tabs), Task 3 (valuation with price target and recommendation), Task 4 (25-35 chart PNG files in zip). If any task is incomplete, stop immediately and inform the user." ;
    oc:hasRationale "Task 5 cannot produce a publication-ready report without all prior work products; attempting to assemble with missing inputs results in placeholder content that fails institutional quality standards" ;
    oc:severityLevel "CRITICAL" .

oc:kn_392e1a69 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the final output file" ;
    oc:directiveContent "Never create the report as markdown. Use the DOCX skill to programmatically create a Word document with professional formatting, proper styles, headers/footers, page numbers, clickable hyperlinks for all URLs, and embedded chart images." ;
    oc:hasRationale "Institutional research reports must be properly formatted DOCX documents with clickable hyperlinks, embedded images, and professional typography — markdown fails all these requirements" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7681420c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Throughout the entire report assembly process" ;
    oc:directiveContent "Never use placeholder phrases like 'this section would include...', 'charts would be inserted here...', or 'see financial model for details...'. Write every section in full, embed all charts, and extract all data into the report." ;
    oc:hasRationale "Placeholders violate the publication-ready standard and produce incomplete deliverables unacceptable for institutional investors making investment decisions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7819cde4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Final quality verification before delivery" ;
    oc:directiveContent "The report must meet all minimum specifications: 30+ pages, 10,000+ words, 25-35 embedded chart images, 12-20 comprehensive tables. All 4 mandatory charts must be present: revenue by product (stacked area), revenue by geography (stacked bar), DCF sensitivity (heatmap), and valuation football field." ;
    oc:hasRationale "These minimums represent institutional research standards; falling below any threshold produces an incomplete deliverable" ;
    oc:severityLevel "CRITICAL" .

oc:kn_82211dd4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing all analytical sections of the report" ;
    oc:directiveContent "Lead all financial writing with specific numbers: 'Revenue grew 150% YoY to $250M' not 'The company saw strong revenue growth'. Use 'vs.' not 'versus'. Format years as 2024A (actual) and 2025E (estimate). Use basis points for small margin changes." ;
    oc:hasRationale "Professional equity research leads with quantification; vague statements undermine credibility and fail to support investment decisions" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9c9c21ca a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assembling the Company 101 section (pages 6-17) and financial analysis sections" ;
    oc:directiveContent "Use Task 1 company research content (6-8K words) almost verbatim — convert markdown to Word format and insert charts inline. Focus original writing effort on quantitative sections: projection assumptions (2,000-3,000 words), scenario analysis (1,500-2,000 words), and valuation methodology." ;
    oc:hasRationale "Task 1 content is already professional analysis; rewriting wastes effort and the value-add is in quantitative interpretation, not rephrasing qualitative research" ;
    oc:severityLevel "HIGH" .

oc:kn_a8fda3de a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When laying out all report pages" ;
    oc:directiveContent "Target 60-80% page density with charts interspersed every 200-300 words of text. Every page must have BOTH text AND visuals. Charts should be placed immediately after the paragraph discussing that topic, never grouped at the end of sections." ;
    oc:hasRationale "Professional equity research is text-dense with illustrating images; sparse pages or grouped charts fail the institutional standard and reduce readability for investors" ;
    oc:severityLevel "HIGH" .

oc:kn_b70ffbf6 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Understanding file I/O for the report assembly" ;
    oc:directiveContent "Task 5 reads from and depends on files created by Tasks 1-4: a .md research document, an .xlsx financial model (with Task 3 valuation tabs added), a .md valuation analysis, and a .zip of chart PNG files. It writes a single .docx output file." ;
    oc:hasRationale "The skill uses Claude's DOCX and XLSX skills to read source files and write the output, requiring all input files to be accessible in the working directory" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d084a6eb a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing the DOCX assembly, before delivering to user" ;
    oc:directiveContent "Run the comprehensive quality checklist before delivery: verify page count (30-50), word count (10,000-15,000), chart count (25-35), table count (12-20), all 4 mandatory charts, Page 1 'INITIATING COVERAGE' header, all URLs as clickable hyperlinks, and cross-check 10-15 numbers against the financial model." ;
    oc:hasRationale "Quality verification catches formatting errors, missing sections, data inconsistencies, and incomplete content before the deliverable reaches the user" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d41bb88f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When executing the complete report assembly workflow" ;
    oc:directiveContent "Assemble the report in 7 phases: (1) organize inputs and verify files, (2) extract tables from Excel via XLSX skill, (3) write quantitative sections, (4) write synthesis sections, (5) integrate Task 1 company content verbatim, (6) assemble DOCX via DOCX skill, (7) run quality checklist. Write Page 1 Investment Summary LAST after all analysis is complete." ;
    oc:hasRationale "This phased approach maximizes efficiency by reusing existing content, ensures the investment summary synthesizes all findings, and produces a logically structured document" ;
    oc:severityLevel "HIGH" .

oc:req_18479262 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "DOCX skill for creating and manipulating Word documents" .

oc:req_694611fd a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "XLSX skill for reading Excel data" .

oc:req_6b3b0834 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Valuation analysis from Task 3 (price target, DCF, comps)" .

oc:req_7e77815e a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Company research document from Task 1 (6-8K words)" .

oc:req_d1aa4837 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Chart files from Task 4 (25-35 PNG/JPG files)" .

oc:req_de844365 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Read tool for reading markdown files" .

oc:req_f4344f42 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Financial model from Task 2 (Excel with 6+ tabs)" .

