@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_initiating_coverage_task3_valuation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "task3-valuation" ;
    skos:broader "Valuation analysis workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/initiating-coverage" ;
    oc:contentHash "07e0f13d90f7ee7160b01717d7975516fdfe8811953c152dd4c8f2e7137219d8" ;
    oc:differentia "Performs comprehensive equity valuation using DCF, comparable companies, and precedent transactions as part of an initiating-coverage equity research report" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_initiating_coverage ;
    oc:handlesFailure oc:FinancialModelMissing,
        oc:InsufficientPeerData,
        oc:InvalidValuationAssumptions ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Read",
        "Write" ;
    oc:hasArgumentHint "company financial model from Task 2" ;
    oc:hasCategory "finance" ;
    oc:hasRequirement oc:req_59fc9a4e,
        oc:req_822b8e37,
        oc:req_9f5c2bf0,
        oc:req_da056915,
        oc:req_ea7e35fc ;
    oc:impartsKnowledge oc:kn_0c45b62e,
        oc:kn_1c235186,
        oc:kn_2458a738,
        oc:kn_359cf06a,
        oc:kn_7644d0b9,
        oc:kn_96cbc0f1,
        oc:kn_a7109acc,
        oc:kn_d843e0ab,
        oc:kn_fa335a9d ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:FinancialModelComplete ;
    oc:resolvesIntent "analyze precedent transactions",
        "build sensitivity analysis tables",
        "calculate WACC and terminal value",
        "create valuation football field",
        "generate price target and investment recommendation",
        "perform DCF valuation analysis",
        "run comparable companies analysis" ;
    oc:yieldsState oc:PriceTargetSet,
        oc:ValuationAnalysisComplete .

oc:kn_0c45b62e a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When presenting comparable companies analysis" ;
    oc:directiveContent "The comparable companies statistical summary (max/75th percentile/median/25th percentile/min) is MANDATORY. Always include all five statistics for every multiple analyzed." ;
    oc:hasRationale "Statistical summary provides context for where the target falls within the peer distribution and prevents cherry-picking of favorable multiples." ;
    oc:severityLevel "HIGH" .

oc:kn_1c235186 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When building DCF sensitivity analysis" ;
    oc:directiveContent "Sensitivity analysis must use 2-way tables: WACC vs. terminal growth rate (±200-300bps for WACC, ±100bps for terminal growth) and Revenue CAGR vs. Terminal EBITDA Margin." ;
    oc:hasRationale "Two-way sensitivity tables show the interaction between key assumptions and identify which variables drive the most valuation change." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2458a738 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating DCF terminal value" ;
    oc:directiveContent "Terminal value must not exceed 60-70% of total enterprise value. If it exceeds 70%, the projection period is likely too short or assumptions are unrealistic." ;
    oc:hasRationale "An excessively high terminal value proportion means the valuation relies more on perpetuity assumptions than observable projected cash flows, reducing reliability." ;
    oc:severityLevel "HIGH" .

oc:kn_359cf06a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating output deliverables" ;
    oc:directiveContent "Add valuation tabs (DCF, sensitivity, comps, precedent transactions, valuation summary) to the existing Task 2 financial model Excel file rather than creating a separate file." ;
    oc:hasRationale "Consolidating all quantitative data in one workbook ensures consistency, reduces errors from linking across files, and matches institutional research practices." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7644d0b9 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When validating completed valuation analysis" ;
    oc:directiveContent "A successful valuation must: use at least 2 methods (DCF + Comps minimum), include comprehensive sensitivity analysis, provide a valuation range with documented assumptions, pass all sanity checks, arrive at a defensible price target, and identify 3-5 key catalysts and 3-5 key risks." ;
    oc:hasRationale "These criteria ensure institutional-quality output that meets equity research standards and can withstand scrutiny from portfolio managers and compliance." ;
    oc:severityLevel "HIGH" .

oc:kn_96cbc0f1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting valuation conclusions" ;
    oc:directiveContent "Never provide a single point estimate for valuation — always present a range (low/base/high) across multiple methodologies." ;
    oc:hasRationale "Single point estimates create false precision and do not communicate the inherent uncertainty in valuation assumptions." ;
    oc:severityLevel "HIGH" .

oc:kn_a7109acc a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When Task 2 prerequisites are not met" ;
    oc:directiveContent "If verification of Task 2 completion fails, stop immediately and inform the user that Task 2 (Financial Modeling) must be completed first. Do not attempt to proceed or create placeholder valuations." ;
    oc:hasRationale "Placeholder valuations based on incomplete data would be misleading and could result in an unreliable investment recommendation." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d843e0ab a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reconciling multiple valuation methods into a single price target" ;
    oc:directiveContent "Typical valuation weighting: DCF 40-60%, Trading Comps 25-40%, Precedent Transactions 10-25%. Weight DCF higher when forecasts are reliable; weight Comps higher when peer data is robust." ;
    oc:hasRationale "Different valuation methods capture different aspects of value; weighting balances forecast-based intrinsic value with market-based relative value." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fa335a9d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning valuation analysis" ;
    oc:directiveContent "Never start Task 3 unless Task 2 (Financial Modeling) is fully complete with projected income statements, cash flows, revenue/EBITDA forecasts, and unlevered FCF inputs." ;
    oc:hasRationale "Starting without a complete financial model will result in incomplete valuations and unreliable price targets." ;
    oc:severityLevel "CRITICAL" .

oc:req_59fc9a4e a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Precedent transactions analysis" .

oc:req_822b8e37 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Financial model output from Task 2" .

oc:req_9f5c2bf0 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Excel/spreadsheet tool for financial modeling" .

oc:req_da056915 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Comparable companies analysis technique" .

oc:req_ea7e35fc a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "DCF methodology and WACC calculation" .

