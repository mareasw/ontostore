@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_earnings_analysis_workflow a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "workflow" ;
    skos:broader "Earnings analysis workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/earnings-analysis" ;
    oc:contentHash "c8922b00e1f7fbbb23afc7601430bbb9c8bf0ac995f478bdd3b368aad6cf0a01" ;
    oc:differentia "Provides detailed step-by-step instructions across 5 phases for producing institutional-grade earnings update reports, from data collection through delivery" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_earnings_analysis ;
    oc:handlesFailure oc:DataMismatch,
        oc:DocumentNotFound,
        oc:StaleDataDetected ;
    oc:hasArgumentHint "company ticker or name" ;
    oc:hasCategory "finance" ;
    oc:impartsKnowledge oc:kn_07624eb2,
        oc:kn_14cfd12f,
        oc:kn_67381323,
        oc:kn_7c546273,
        oc:kn_8250e403,
        oc:kn_8617d50e,
        oc:kn_d605b5d8,
        oc:kn_f372df16 ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:requiresState oc:CompanyIdentified,
        oc:NetworkAvailable ;
    oc:resolvesIntent "analyze quarterly earnings results",
        "assess rating and price target impact from earnings",
        "generate earnings charts and report",
        "produce earnings update report",
        "update financial estimates after earnings" ;
    oc:yieldsState oc:EarningsReportCreated,
        oc:EstimatesUpdated,
        oc:ValuationUpdated .

oc:kn_07624eb2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating price targets after earnings analysis" ;
    oc:directiveContent "If estimates changed significantly (>5%), change the price target. If estimates changed marginally (<5%), maintain the price target. If thesis strengthened or weakened, consider changing the price target even without estimate changes." ;
    oc:hasRationale "Provides clear decision criteria for when price target changes are warranted vs. when maintaining is appropriate, avoiding unnecessary volatility in recommendations" ;
    oc:severityLevel "MEDIUM" .

oc:kn_14cfd12f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When gathering consensus estimates for comparison" ;
    oc:directiveContent "Consensus estimates must be sourced from BEFORE the earnings release date to enable accurate beat/miss analysis. Post-earnings consensus will reflect updated numbers and defeat the purpose." ;
    oc:hasRationale "Beat/miss analysis is only meaningful when compared against pre-announcement expectations; post-earnings consensus has already incorporated the results" ;
    oc:severityLevel "HIGH" .

oc:kn_67381323 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "After gathering earnings materials, before beginning analysis" ;
    oc:directiveContent "Before proceeding with analysis, verify: today's date written down, earnings release found within last 3 months, transcript date matches release date ±1 day, all materials reference the same quarter." ;
    oc:hasRationale "Mixed-quarter materials or stale data silently corrupts the entire analysis, and these checks catch the most common data integrity failures" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7c546273 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Throughout the report creation phase" ;
    oc:directiveContent "Every figure, table, beat/miss analysis, and guidance change must have a specific source citation with document reference and date. All URLs must be clickable hyperlinks, not plain text." ;
    oc:hasRationale "Institutional-grade equity research requires full source attribution for compliance, auditability, and reader trust" ;
    oc:severityLevel "HIGH" .

oc:kn_8250e403 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "Final quality check before delivering the report" ;
    oc:directiveContent "Before delivery, verify: beat/miss clearly quantified, key drivers explained, updated estimates show old vs. new, price target updated or explicitly maintained, numbers match reported results exactly, and report is 8-12 pages." ;
    oc:hasRationale "Catches omissions and errors before the report reaches the user, ensuring institutional quality standards are met" ;
    oc:severityLevel "HIGH" .

oc:kn_8617d50e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any earnings analysis" ;
    oc:directiveContent "Never use earnings data from training data — it is outdated. Always actively search for and retrieve the most recent earnings materials using web search." ;
    oc:hasRationale "Training data cutoff means any earnings figures from training are stale and will produce incorrect analysis, which is the #1 mistake in earnings analysis" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d605b5d8 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When identifying the latest earnings period" ;
    oc:directiveContent "Companies use different fiscal calendars (e.g., Nike's year ends in May, Apple's in September). Search for the company's fiscal year calendar to correctly interpret quarter labels." ;
    oc:hasRationale "Misaligning fiscal quarters with calendar quarters leads to incorrect YoY comparisons and wrong period identification" ;
    oc:severityLevel "HIGH" .

oc:kn_f372df16 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "During Phase 3 chart generation" ;
    oc:directiveContent "The report must contain exactly 8-12 charts covering: quarterly revenue progression, quarterly EPS progression, margin trends, segment/geography breakdown, operating metrics, beat/miss summary, estimate revisions, and valuation." ;
    oc:hasRationale "These 8 core chart types provide comprehensive visual coverage of the earnings story while maintaining the 8-12 page report constraint" ;
    oc:severityLevel "MEDIUM" .

