oc:skill_financial_services_plugin_earnings_analysis_best_practices a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "best-practices" ;
    skos:broader "Quality assurance framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/earnings-analysis" ;
    oc:contentHash "a688e6b53d408fcfc36cb5490e9e2a75b82789f876f14ba22119bf19db655d09" ;
    oc:differentia "ensures earnings update reports meet institutional equity research standards through examples, anti-patterns, and comprehensive checklists" ;
    oc:extends oc:skill_financial_services_plugin_earnings_analysis ;
    oc:hasCategory "finance" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "This document provides examples, tips for success, common mistakes to avoid, and comprehensive quality checklists." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "When delivering the completed report to the user, provide this summary:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """[Company] Q[X] [Year] Earnings Update Complete

Results: [BEAT / INLINE / MISS]
- Revenue: $X.XB ([beat/missed] by $XXM or X%)
- EPS: $X.XX ([beat/missed] by $X.XX)

Key Takeaways:
■ [Takeaway 1]
■ [Takeaway 2]
■ [Takeaway 3]

Updated Estimates:
- FY[Year]E Revenue: $XX.XB (prior: $XX.XB, [+/-]X%)
- FY[Year]E EPS: $X.XX (prior: $X.XX, [+/-]X%)

Rating: [MAINTAINED / RAISED / LOWERED] [RATING]
Price Target: $XXX (prior: $XXX) - [+/-]XX% upside

Deliverables:
✓ 8-12 page earnings update report (DOCX)
✓ 8-12 embedded charts
✓ Updated estimates with old/new comparison
✓ Complete sources section with clickable hyperlinks
✓ [Optional: Updated XLS financial model]

File: [Company]_Q[X]_[Year]_Earnings_Update.docx
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 221-248" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 16 ;
                    oc:sectionTitle "Summary Delivery Format" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent "❌ **Rehashing basics**: Don't spend 3 pages explaining what the company does" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "❌ **Too comprehensive**: Don't write an initiation-length report for quarterly results" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "❌ **Vague language**: \"Strong performance\" without quantification" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "❌ **Not updating estimates**: Must provide updated forward estimates" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "❌ **Too slow**: Publishing 5+ days after earnings loses relevance" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 8 ;
                            oc:textContent "❌ **Missing price target update**: If estimates changed materially, PT should too" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "❌ **Missing beat/miss**: Lead with whether results beat or missed expectations" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 9 ;
                            oc:textContent "❌ **No investment impact**: Must connect results to thesis and rating" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "❌ **Ignoring guidance**: If company guides, analyze it thoroughly" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 10 ;
                            oc:textContent "❌ **Missing citations**: Every number needs a source with clickable hyperlinks" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 11 ;
                            oc:textContent "❌ **Plain text URLs**: All URLs must be formatted as clickable hyperlinks" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Common Mistakes to Avoid" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Run through this quick final check before sending report to user:" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "If all items check out, the report is ready for delivery." ],
                                _:ref_fc3bb0f871d47082 ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 15 ;
                            oc:sectionTitle "5-Minute Final Review:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 14 ;
                    oc:sectionTitle "Pre-Delivery Final Check" ],
