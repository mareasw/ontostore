                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "[ ] ✅ **VERIFIED all data is from LATEST quarter by searching for recent earnings**" ] ] ;
