@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_earnings_analysis_best_practices a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "best-practices" ;
    skos:broader "Quality guideline reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/earnings-analysis" ;
    oc:contentHash "a688e6b53d408fcfc36cb5490e9e2a75b82789f876f14ba22119bf19db655d09" ;
    oc:differentia "provides best practices, examples, anti-patterns, and comprehensive quality control checklists for producing institutional-grade equity research earnings update reports" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_earnings_analysis ;
    oc:hasCategory "finance" ;
    oc:impartsKnowledge oc:kn_005c0d6f,
        oc:kn_0766632c,
        oc:kn_1a8b097b,
        oc:kn_2aced33f,
        oc:kn_4ae2bbd0,
        oc:kn_654bc114,
        oc:kn_99be08fa,
        oc:kn_a6109e1b,
        oc:kn_b2afd981,
        oc:kn_f2c34005 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "avoid common earnings analysis mistakes",
        "ensure proper citations and hyperlinks in reports",
        "follow professional earnings update formatting standards",
        "perform pre-delivery quality check on earnings report",
        "validate earnings report quality" .

oc:kn_005c0d6f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When performing pre-delivery quality control on a completed earnings report" ;
    oc:directiveContent "Before delivering, run the 5-minute final review: verify Page 1 rating/PT, match reported numbers to press release, spot-check 3-4 citations with clickable hyperlinks, confirm old vs new estimates, verify 8-12 charts are embedded and captioned, check length is 8-12 pages, test hyperlinks, and confirm publication within 48 hours." ;
    oc:hasRationale "A systematic final check catches the most common delivery errors — incorrect numbers, missing hyperlinks, wrong length, and stale data." ;
    oc:severityLevel "HIGH" .

oc:kn_0766632c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When citing any figure, table, chart, or data point in the report" ;
    oc:directiveContent "Every number must have a source citation with clickable hyperlinks — no plain text URLs allowed. All URLs must be formatted as clickable hyperlinks with meaningful display text." ;
    oc:hasRationale "Clickable, sourced citations are a professional compliance standard and allow clients to verify data independently. Plain text URLs are unprofessional and error-prone." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1a8b097b a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When gathering data for the earnings update before writing" ;
    oc:directiveContent "Do not rely on knowledge cutoff data — actively search for the latest earnings release and verify all data is from the most recent quarter." ;
    oc:hasRationale "Using stale data from a knowledge cutoff rather than the actual latest earnings release produces inaccurate, outdated reports that damage credibility." ;
    oc:severityLevel "CRITICAL" .

oc:kn_2aced33f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any earnings update headline" ;
    oc:directiveContent "Never write a generic headline lacking company name, takeaway, or view — e.g., avoid 'Company Reports Earnings' or 'Q3 Results Analysis'." ;
    oc:hasRationale "Headlines are the first thing clients read; generic headlines signal low-quality analysis and provide no actionable information." ;
    oc:severityLevel "HIGH" .

oc:kn_4ae2bbd0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring the analytical narrative of the earnings update" ;
    oc:directiveContent "Lead with the beat/miss conclusion, quantify all variances, explain WHY results differed, and show old estimates → new estimates with reasoning." ;
    oc:hasRationale "Clients read earnings updates for the bottom-line assessment first; burying the conclusion wastes their time and signals weak analysis." ;
    oc:severityLevel "MEDIUM" .

oc:kn_654bc114 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating forward estimates and valuation after earnings" ;
    oc:directiveContent "If estimates change more than 5%, the price target should typically be updated as well. If PT is unchanged, explicitly state it is maintained." ;
    oc:hasRationale "Material estimate changes without corresponding PT updates create internal inconsistency that clients and compliance teams will flag." ;
    oc:severityLevel "MEDIUM" .

oc:kn_99be08fa a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "When presenting the finished earnings update to the user" ;
    oc:directiveContent "Deliver the completed report with a structured summary including: beat/miss result with quantified variances, key takeaways, updated estimates with old/new comparison, rating and PT with upside/downside percentage, and a checklist of deliverables." ;
    oc:hasRationale "A standardized delivery summary ensures the client can quickly digest the key findings and verify all expected deliverables are included." ;
    oc:severityLevel "LOW" .

oc:kn_a6109e1b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoping and writing the earnings update report" ;
    oc:directiveContent "Do not write an initiation-length comprehensive report for quarterly results — stay focused on what changed this quarter." ;
    oc:hasRationale "Earnings updates are event-driven and time-sensitive; rehashing company basics wastes pages and delays publication. That content belongs in an initiation report." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b2afd981 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When producing any earnings update report" ;
    oc:directiveContent "Reports must be 8-12 pages, contain 8-12 embedded charts, include 1-3 summary tables, and be published within 24-48 hours of earnings release." ;
    oc:hasRationale "These length and timing constraints define the earnings update format — longer reports become initiation-length; slower publication loses relevance." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f2c34005 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When describing any financial result or metric in the report" ;
    oc:directiveContent "Avoid vague quantification like 'strong performance' — always use specific numbers like '$150M beat on $1.2B revenue'." ;
    oc:hasRationale "Institutional clients need precise figures to make decisions; vague language undermines credibility and utility." ;
    oc:severityLevel "HIGH" .

