@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_earnings_analysis_report_structure a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "report-structure" ;
    skos:broader "Template specification" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/earnings-analysis" ;
    oc:contentHash "60da5bd7cde0d93f197d21618bf801978022c4b24b91f2ed9ba21eb2945dc586" ;
    oc:differentia "that defines the exact page-by-page layout, table formats, chart placement, and citation styling for institutional equity research earnings update DOCX reports" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_earnings_analysis ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "finance" ;
    oc:impartsKnowledge oc:kn_3897d6e2,
        oc:kn_3a01404c,
        oc:kn_5a5c6493,
        oc:kn_87c75e57,
        oc:kn_d3ca3d3b ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:AnalysisCompleted,
        oc:EarningsDataCollected ;
    oc:resolvesIntent "apply citation and hyperlink standards to earnings reports",
        "format financial tables and charts in equity research reports",
        "lay out 8-12 page earnings update with correct section ordering",
        "structure earnings update report pages" ;
    oc:yieldsState oc:ReportStructureDefined .

oc:kn_3897d6e2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when structuring Page 1 of an earnings update report" ;
    oc:directiveContent "Page 1 must lead with rating, price target, beat/miss summary, 3-4 investment impact bullets (using ■ character with bold headers), and an updated financial estimates table showing old vs. new with change column." ;
    oc:hasRationale "Page 1 is the most-read page; institutional readers scan for the verdict first and need immediately actionable information" ;
    oc:severityLevel "CRITICAL" .

oc:kn_3a01404c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When citing any source, filing, or reference document" ;
    oc:directiveContent "Never include plain text URLs in the report. All URLs must be formatted as clickable hyperlinks in Word with meaningful display text (blue, underlined, Ctrl+Click to open)." ;
    oc:hasRationale "Plain text URLs look unprofessional and are not functional in a delivered DOCX; clickable links enable readers to verify sources instantly" ;
    oc:severityLevel "CRITICAL" .

oc:kn_5a5c6493 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning the overall report layout and page allocation" ;
    oc:directiveContent "Structure the report in this exact page sequence: Page 1 summary → Pages 2-3 detailed results → Pages 4-5 metrics & guidance → Pages 6-7 thesis update → Pages 8-10 valuation & estimates → Pages 11-12 appendix (optional). Embed 2-3 charts per 2-page section, totaling 8-12 charts." ;
    oc:hasRationale "This sequence mirrors how portfolio managers consume earnings updates: quick take → detailed drill-down → forward view → valuation proof" ;
    oc:severityLevel "HIGH" .

oc:kn_87c75e57 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Throughout all written content and table labels in the report" ;
    oc:directiveContent "Use 'A' suffix for actual results (e.g., Q3'24A) and 'E' suffix for estimates (e.g., Q4'24E). Lead sentences with numbers rather than qualitative descriptors. Use 'vs.' not 'versus'." ;
    oc:hasRationale "Consistent notation eliminates ambiguity about which figures are reported vs. projected, and number-first writing is the institutional standard" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d3ca3d3b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any table or chart in the report" ;
    oc:directiveContent "All tables must include a source line at the bottom, clear column headers, and shading for header rows. All charts must have 'Figure X - [Title]' caption above and 'Source: [Source]' line below." ;
    oc:hasRationale "Source attribution is a professional standard in equity research and ensures compliance with firm policies" ;
    oc:severityLevel "HIGH" .

