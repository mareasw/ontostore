@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_earnings_analysis a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "earnings-analysis" ;
    skos:broader "Equity research report generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/earnings-analysis" ;
    oc:contentHash "3b6b1548a154b6f7346c89b638cbb14935b3d8420a85dfa13b3ae5ee983495e5" ;
    oc:dependsOnSkill oc:skill_docx_manipulation ;
    oc:differentia "Produces fast-turnaround (24-48 hour) earnings update reports analyzing quarterly results for companies under coverage, with beat/miss analysis, updated estimates, 8-12 charts, and 1-3 summary tables in institutional format" ;
    oc:handlesFailure oc:ConsensusUnavailable,
        oc:EarningsNotFound,
        oc:OutdatedData,
        oc:TranscriptMismatch ;
    oc:hasAllowedTool "Bash",
        "Read",
        "WebFetch",
        "WebSearch",
        "Write" ;
    oc:hasArgumentHint "\"[Company] Q[Quarter] [Year]\" (e.g., \"Nike Q2 FY24\")" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Create professional equity research earnings update reports (8-12 pages, 3,000-5,000 words) analyzing quarterly results for companies already under coverage. Fast-turnaround format focusing on beat/miss analysis, key metrics, updated estimates, and revised thesis. Includes 1-3 summary tables and 8-12 charts. Use when user requests \"earnings update\", \"quarterly update\", \"earnings analysis\", \"Q1/Q2/Q3/Q4 results\", or post-earnings report." ;
    oc:hasName "earnings-analysis" ;
    oc:hasRequirement oc:req_3c1cef86,
        oc:req_5e8b80f1,
        oc:req_80c7da99,
        oc:req_9f304133,
        oc:req_df4e5e01 ;
    oc:impartsKnowledge oc:kn_03162ddb,
        oc:kn_13f3d320,
        oc:kn_46d26b0c,
        oc:kn_929ea640,
        oc:kn_ae6e10cd,
        oc:kn_c8977332,
        oc:kn_e85f7bc9,
        oc:kn_f068b776 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:CompanyIdentified,
        oc:NetworkAvailable,
        oc:QuarterSpecified ;
    oc:resolvesIntent "analyze quarterly results",
        "create beat/miss analysis report",
        "create earnings update report",
        "generate post-earnings analysis",
        "update equity research estimates after earnings" ;
    oc:yieldsState oc:ChartsGenerated,
        oc:EarningsUpdateReportCreated,
        oc:EstimatesUpdated .

oc:kn_03162ddb a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "Phase 5 quality check before delivering to user" ;
    oc:directiveContent "Before delivery, verify: (1) report is 8-12 pages, (2) 8-12 charts embedded and captioned, (3) all numbers match company's press release exactly, (4) all hyperlinks tested and working, (5) consensus estimates are pre-earnings, (6) report published within 48 hours." ;
    oc:hasRationale "A flawed earnings update damages credibility more than a delayed one — the 5-minute final review catches errors that undermine the entire report's value." ;
    oc:severityLevel "HIGH" .

oc:kn_13f3d320 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Phase 1 data collection, mandatory verification step before proceeding" ;
    oc:directiveContent "Before beginning analysis, verify: (1) today's date written down, (2) latest earnings found via web search, (3) release date within 3 months, (4) transcript date matches release date, (5) all materials show the same quarter." ;
    oc:hasRationale "Using the wrong quarter or mismatched materials is the #1 catastrophic error in earnings analysis — this 5-point check prevents wasted work on incorrect data." ;
    oc:severityLevel "CRITICAL" .

oc:kn_46d26b0c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Throughout the report — every piece of data must be traceable to its source" ;
    oc:directiveContent "Every figure, table, beat/miss claim, guidance reference, and statistic must have a specific source citation with document name, date, and clickable hyperlink. No plain text URLs." ;
    oc:hasRationale "Institutional equity research standards require full source attribution for compliance, auditability, and reader trust. Clickable hyperlinks enable instant verification." ;
    oc:severityLevel "CRITICAL" .

oc:kn_929ea640 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any earnings analysis, during Phase 1 data collection" ;
    oc:directiveContent "Never use training data for earnings results — always actively web search for the latest earnings release and verify the release date is within 3 months of today's date." ;
    oc:hasRationale "Training data is inherently outdated; using stale earnings figures produces factually incorrect analysis and destroys credibility with institutional clients." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ae6e10cd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Page 1 of the report and throughout the analysis sections" ;
    oc:directiveContent "Lead every earnings update with a clear beat/miss verdict, quantify variances in dollars and percentages, and explain WHY results differed from expectations before anything else." ;
    oc:hasRationale "Clients reading earnings updates want the bottom line immediately — the beat/miss determination drives stock reaction and investment decisions." ;
    oc:severityLevel "HIGH" .

oc:kn_c8977332 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When identifying the quarter and interpreting earnings release headers" ;
    oc:directiveContent "Company fiscal calendars vary widely (e.g., Nike FY ends May, Apple ends September, Walmart ends January). Always verify the company's fiscal year convention before interpreting quarter labels." ;
    oc:hasRationale "Misinterpreting fiscal vs. calendar quarters leads to wrong YoY comparisons, incorrect estimate matching, and fundamental analytical errors." ;
    oc:severityLevel "HIGH" .

oc:kn_e85f7bc9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Phase 4 report creation and throughout content scoping" ;
    oc:directiveContent "Earnings updates must be 8-12 pages with 3,000-5,000 words, 1-3 summary tables (not comprehensive), and 8-12 charts. Do not write an initiation-length report." ;
    oc:hasRationale "The earnings update format is distinct from initiation reports — it focuses on what's NEW for an audience already familiar with the company, requiring brevity and speed." ;
    oc:severityLevel "HIGH" .

oc:kn_f068b776 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Updated estimates section and price target determination" ;
    oc:directiveContent "Show old estimates vs. new estimates side-by-side with a change column and brief reason for each revision. If estimates change >5%, typically update the price target too." ;
    oc:hasRationale "Transparent estimate tracking shows analytical rigor and lets clients understand the magnitude and direction of conviction changes." ;
    oc:severityLevel "MEDIUM" .

oc:req_3c1cef86 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Equity research institutional standards and formatting conventions" .

oc:req_5e8b80f1 a oc:RequirementAPI ;
    oc:isOptional false ;
    oc:requirementValue "Web search for latest earnings data" .

oc:req_80c7da99 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Financial modeling and DCF valuation methodology" .

oc:req_9f304133 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "XLS manipulation for optional model updates" .

oc:req_df4e5e01 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Python with matplotlib, pandas, seaborn for chart generation" .

