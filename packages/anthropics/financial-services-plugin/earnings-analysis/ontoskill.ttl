_:ref_740b2a92e060888d a oc:WorkflowStep ;
    dcterms:description "Create 8-12 charts: quarterly revenue progression, EPS progression, margin trends, segment breakdown, operating metrics, beat/miss summary, estimate revisions, valuation" ;
    oc:expectedOutcome "8-12 professional charts ready for embedding in the report" ;
    oc:stepDependsOn _:ref_42dbaf8b669c93e2 ;
    oc:stepId "generate-charts" .

_:ref_7817f7827272c207 a oc:WorkflowStep ;
    dcterms:description "Extract reported results vs estimates: revenue, EPS, margins, key business metrics with beat/miss variances quantified" ;
    oc:expectedOutcome "Structured summary of all key metrics with reported vs estimated comparisons" ;
    oc:stepDependsOn _:ref_e3f7e1f915054db6 ;
