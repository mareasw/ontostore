oc:skill_financial_services_plugin_fixed_income_portfolio a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "fixed-income-portfolio" ;
    skos:broader "Portfolio analysis workflow" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/fixed-income-portfolio" ;
    oc:contentHash "4ec33de22605db36729427008dbf1cd270a8a9fbeb3a7cf8842d0398e97077f1" ;
    oc:differentia "aggregates bond pricing, reference data, cashflow projections, and scenario stress testing into comprehensive fixed income portfolio reviews with market-value weighted metrics" ;
    oc:handlesFailure oc:APIKeySet,
        oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasArgumentHint "portfolio holdings (bond identifiers with position sizes)" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Review fixed income portfolios by pricing multiple bonds, retrieving reference data, analyzing cashflows, and running scenario analysis. Use when reviewing bond portfolios, computing portfolio duration and DV01, analyzing cashflow waterfalls, stress testing rate scenarios, or assessing portfolio composition." ;
    oc:hasName "fixed-income-portfolio" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: fixed-income-portfolio
description: Review fixed income portfolios by pricing multiple bonds, retrieving reference data, analyzing cashflows, and running scenario analysis. Use when reviewing bond portfolios, computing portfolio duration and DV01, analyzing cashflow waterfalls, stress testing rate scenarios, or assessing portfolio composition.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "You are an expert fixed income portfolio analyst. Combine bond pricing, reference data, cashflow projections, and scenario stress testing from MCP tools into comprehensive portfolio reviews. Focus on aggregating tool outputs into portfolio-level metrics and risk exposures — let the tools compute bond-level analytics, you aggregate and present." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Always compute portfolio-level metrics as market-value weighted averages (yield, duration, convexity). Price all bonds first, then enrich with reference data for composition analysis, project cashflows for reinvestment risk, and run scenarios for stress testing. Frame everything relative to a benchmark when available." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Principles" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**`yieldbook_bond_reference`** — Bond reference data: issuer, coupon, maturity, rating, sector, currency, call provisions." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**`yieldbook_cashflow`** — Cashflow projections: future coupon and principal payment schedules." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**`bond_price`** — Price bonds. Returns clean/dirty price, yield, duration, convexity, DV01, spread. Accepts comma-separated identifiers for batch pricing." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**`interest_rate_curve`** — Government yield curves. Use for spread-to-curve context and curve environment assessment." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**`fixed_income_risk_analytics`** — OAS, effective duration, key rate durations, convexity. Use for bonds with embedded options." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**`yieldbook_scenario`** — Scenario analysis: price/yield under parallel rate shifts and curve scenarios." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Available MCP Tools" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 2 ;
                                    oc:tableCaption "### Cashflow Waterfall" ;
                                    oc:tableMarkdown """| Period | Coupon Income | Principal | Total Cash |
|--------|--------------|-----------|-----------|
| Q1 | ... | ... | ... |
| Q2 | ... | ... | ... |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Cashflow Waterfall" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Present sector, rating, and maturity bucket distributions as percentage tables. Flag overweights/underweights vs benchmark." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Composition Breakdown" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Scenario P&L" ;
                                    oc:tableMarkdown """| Scenario | Portfolio P&L ($) | Portfolio P&L (%) | Top Contributor | Bottom Contributor |
|----------|-------------------|--------------------|-----------------|--------------------|
| -100bp | ... | ... | ... | ... |
| Base | -- | -- | -- | -- |
| +100bp | ... | ... | ... | ... |
| +200bp | ... | ... | ... | ... |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Scenario P&L" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "### Portfolio Summary" ;
                                    oc:tableMarkdown """| Metric | Portfolio | Benchmark | Active |
|--------|-----------|-----------|--------|
| Market Value | ... | -- | -- |
| Yield (YTW) | ... | ... | +/-... bp |
| Mod. Duration | ... | ... | +/-... |
| DV01 ($) | ... | ... | +/-... |
| Avg Rating | ... | ... | -- |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Portfolio Summary" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Output Format" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_5df41d6669691984 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Tool Chaining Workflow" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Fixed Income Portfolio Analysis" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Complete portfolio review workflow from bond pricing through synthesized report with scenario analysis" ;
            oc:hasStep _:ref_04d4a3115421f824,
                _:ref_288841090e1b8817,
                [ a oc:WorkflowStep ;
                    dcterms:description "Combine all outputs into a portfolio review with summary metrics, composition analysis, cashflow projections, and scenario P&L" ;
                    oc:expectedOutcome "Complete portfolio review report delivered" ;
                    oc:stepDependsOn _:ref_04d4a3115421f824,
                        _:ref_288841090e1b8817,
                        _:ref_6f5aa585dcf3000e,
                        _:ref_7f2e8511a1f924d6,
                        _:ref_b00f8785684dbf00 ;
                    oc:stepId "synthesize-report" ],
                _:ref_6f5aa585dcf3000e,
                _:ref_7f2e8511a1f924d6,
                _:ref_b00f8785684dbf00,
                _:ref_e612d7e7b84df263 ;
            oc:workflowId "fixed-income-portfolio-review" ;
            oc:workflowName "Fixed Income Portfolio Review" ],
        _:ref_5df41d6669691984 ;
    oc:impartsKnowledge oc:kn_035837a9,
        oc:kn_152be758,
        oc:kn_240d36db,
        oc:kn_252db734,
        oc:kn_29a01c80,
        oc:kn_2cdc9e50,
        oc:kn_2d9829a0 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet ;
    oc:resolvesIntent "analyze cashflow waterfall",
        "assess portfolio composition",
        "compute portfolio duration and DV01",
        "review bond portfolio",
        "run fixed income portfolio analysis",
        "stress test rate scenarios" ;
    oc:yieldsState oc:PortfolioPriced,
        oc:ScenarioAnalysisComplete .

oc:kn_035837a9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing any portfolio-level metric" ;
    oc:directiveContent "Always compute portfolio-level metrics as market-value weighted averages (yield, duration, convexity). Price all bonds first, then enrich with reference data, project cashflows, and run scenarios." ;
    oc:hasRationale "Market-value weighting ensures metrics reflect actual portfolio risk exposure; computing prices first establishes the foundation for all downstream analytics." ;
    oc:severityLevel "CRITICAL" .

oc:kn_152be758 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing fixed income portfolios" ;
    oc:directiveContent "Let the MCP tools compute bond-level analytics; your job is to aggregate and present portfolio-level metrics and risk exposures." ;
    oc:hasRationale "Bond-level pricing is computationally complex and tool-optimized; the agent adds value through synthesis and portfolio-level aggregation." .

oc:kn_240d36db a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When portfolio contains callable, putable, or convertible bonds" ;
    oc:directiveContent "Use fixed_income_risk_analytics tool (OAS, effective duration, key rate durations) specifically for bonds with embedded options rather than standard bond_price metrics." ;
    oc:hasRationale "Embedded options distort standard duration/convexity measures; OAS-based analytics properly account for optionality." ;
    oc:severityLevel "HIGH" .

oc:kn_252db734 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running scenario analysis" ;
    oc:directiveContent "Run standard scenario shocks of -200bp, -100bp, -50bp, 0, +50bp, +100bp, +200bp to capture a comprehensive rate sensitivity profile." ;
    oc:hasRationale "A symmetric shock ladder with fine granularity around base case captures both tail risks and near-base sensitivities." .

oc:kn_29a01c80 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When presenting portfolio review results" ;
    oc:directiveContent """### Portfolio Summary
| Metric | Portfolio | Benchmark | Active |
| Market Value | ... | -- | -- |
| Yield (YTW) | ... | ... | +/-... bp |
| Mod. Duration | ... | ... | +/-... |
| DV01 ($) | ... | ... | +/-... |
| Avg Rating | ... | ... | -- |

### Composition Breakdown
Sector, rating, maturity bucket % tables with overweights/underweights vs benchmark.

### Cashflow Waterfall
| Period | Coupon Income | Principal | Total Cash |

### Scenario P&L
| Scenario | Portfolio P&L ($) | Portfolio P&L (%) | Top Contributor | Bottom Contributor |""" ;
    oc:templateVariables "Active",
        "Avg_Rating",
        "Benchmark",
        "Bottom_Contributor",
        "Coupon_Income",
        "DV01",
        "Metric",
        "Mod_Duration",
        "Period",
        "PnL_dollar",
        "PnL_pct",
        "Portfolio",
        "Principal",
        "Scenario",
        "Top_Contributor",
        "Total_Cash",
        "Yield" .

oc:kn_2cdc9e50 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When benchmark data is available for comparison" ;
    oc:directiveContent "Frame everything relative to a benchmark when available. Report active differences in basis points for yield and absolute difference for duration/DV01." ;
    oc:hasRationale "Benchmark-relative framing is the standard institutional approach for fixed income portfolio management and client reporting." ;
    oc:severityLevel "HIGH" .

oc:kn_2d9829a0 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing a full fixed income portfolio review" ;
    oc:directiveContent "1. Price all bonds via bond_price (batch) → 2. Compute MV-weighted portfolio yield/duration/DV01/convexity → 3. Enrich with yieldbook_bond_reference for sector/rating/maturity breakdowns → 4. Project cashflows via yieldbook_cashflow, aggregate into quarterly waterfall → 5. Run yieldbook_scenario with standard shocks (-200bp to +200bp) → 6. Get interest_rate_curve for spread-to-curve context → 7. Synthesize into portfolio review" ;
    oc:stepOrder 1 .

_:ref_0243cc1996a31d24 a oc:WorkflowStep ;
    dcterms:description "**Run Scenarios:** Call `yieldbook_scenario` with standard shocks (-200bp, -100bp, -50bp, 0, +50bp, +100bp, +200bp). Identify top risk contributors." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_04d1ae5f4cf882c8 a oc:WorkflowStep ;
    dcterms:description "**Project Cashflows:** Call `yieldbook_cashflow` for the portfolio. Aggregate into a quarterly cashflow waterfall. Flag concentration periods." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_5d13c82920adbb1d a oc:WorkflowStep ;
    dcterms:description "**Aggregate Portfolio Metrics:** Compute market-value weighted portfolio yield, duration, DV01, convexity." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_8006f690dcc0d818 a oc:WorkflowStep ;
    dcterms:description "**Synthesize:** Combine into a portfolio review with summary metrics, composition analysis, cashflow projections, and scenario P&L." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_7" ;
    oc:stepOrder 7 .

_:ref_9b3760d5bdcd8593 a oc:WorkflowStep ;
    dcterms:description "**Enrich with Reference Data:** Call `yieldbook_bond_reference` for each bond. Build sector, rating, maturity, and currency breakdowns." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_b50012ba5f94b4a9 a oc:WorkflowStep ;
    dcterms:description "**Price All Bonds:** Call `bond_price` for all holdings. Extract yield, duration, DV01, convexity, spread per bond." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_d21e30453bf565f8 a oc:WorkflowStep ;
    dcterms:description "**Curve Context:** Call `interest_rate_curve` for the portfolio's primary currency. Compute spread to curve for each bond." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_04d4a3115421f824 a oc:WorkflowStep ;
    dcterms:description "Call yieldbook_scenario with standard shocks (-200bp to +200bp) and identify top risk contributors" ;
    oc:expectedOutcome "Scenario P&L table with risk contributor identification" ;
    oc:stepDependsOn _:ref_e612d7e7b84df263 ;
    oc:stepId "run-scenarios" .

_:ref_288841090e1b8817 a oc:WorkflowStep ;
    dcterms:description "Call interest_rate_curve for portfolio's primary currency and compute spread to curve for each bond" ;
    oc:expectedOutcome "Spread-to-curve context for all bonds" ;
    oc:stepDependsOn _:ref_e612d7e7b84df263 ;
    oc:stepId "curve-context" .

_:ref_5df41d6669691984 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_0243cc1996a31d24,
        _:ref_04d1ae5f4cf882c8,
        _:ref_5d13c82920adbb1d,
        _:ref_8006f690dcc0d818,
        _:ref_9b3760d5bdcd8593,
        _:ref_b50012ba5f94b4a9,
        _:ref_d21e30453bf565f8 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_6f5aa585dcf3000e a oc:WorkflowStep ;
    dcterms:description "Call yieldbook_cashflow for the portfolio and aggregate into a quarterly cashflow waterfall, flagging concentration periods" ;
    oc:expectedOutcome "Quarterly cashflow waterfall with concentration flags" ;
    oc:stepDependsOn _:ref_e612d7e7b84df263 ;
    oc:stepId "project-cashflows" .

_:ref_7f2e8511a1f924d6 a oc:WorkflowStep ;
    dcterms:description "Compute market-value weighted portfolio yield, duration, DV01, and convexity from individual bond results" ;
    oc:expectedOutcome "Portfolio-level aggregate metrics calculated" ;
    oc:stepDependsOn _:ref_e612d7e7b84df263 ;
    oc:stepId "aggregate-metrics" .

_:ref_b00f8785684dbf00 a oc:WorkflowStep ;
    dcterms:description "Call yieldbook_bond_reference for each bond to build sector, rating, maturity, and currency breakdowns" ;
    oc:expectedOutcome "Composition breakdown tables populated" ;
    oc:stepDependsOn _:ref_e612d7e7b84df263 ;
    oc:stepId "enrich-reference" .

_:ref_e612d7e7b84df263 a oc:WorkflowStep ;
    dcterms:description "Call bond_price for all holdings to extract yield, duration, DV01, convexity, spread per bond" ;
    oc:expectedOutcome "All bonds priced with individual analytics" ;
    oc:stepId "price-bonds" .

