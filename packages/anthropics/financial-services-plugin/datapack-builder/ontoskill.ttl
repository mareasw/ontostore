                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Verify balance sheet balances: Assets = Liabilities + Equity" ] ] ;
                            oc:sectionLevel 3 ;
