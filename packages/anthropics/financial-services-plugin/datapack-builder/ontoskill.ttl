    oc:stepDependsOn _:ref_3b29617ae7c989cd ;
    oc:stepId "build-scenarios" .

_:ref_3b29617ae7c989cd a oc:WorkflowStep ;
    dcterms:description "Build 8-tab Excel workbook using xlsx skill: create tab structure, apply formatting (font colors, number formats, underlines), insert formula-based calculations with tracked row references, apply professional presentation" ;
