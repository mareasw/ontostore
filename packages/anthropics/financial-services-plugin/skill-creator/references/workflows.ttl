oc:skill_anthropics_financial_services_plugin_skill_creator_workflows a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "workflows" ;
    skos:broader "Workflow pattern guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/skill-creator" ;
    oc:contentHash "ef4846877d5dab47511a01a6cf31476ad64f5bc5945635459295794575338980" ;
    oc:dependsOnSkill oc:skill_skill_creator ;
    oc:differentia "provides sequential and conditional workflow templates for structuring multi-step skill operations" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_skill_creator ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_3a7bb708,
        oc:kn_7cec6111,
        oc:kn_af13f501,
        oc:kn_d2cf1050 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "create branching conditional workflows for skills",
        "design multi-step skill workflows",
        "structure sequential task execution" .

oc:kn_3a7bb708 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When designing workflows that modify files or external state" ;
    oc:directiveContent "Structure workflows so that validation/verification steps follow data-modification steps (e.g., validate mapping before filling, verify output after generation)." ;
    oc:hasRationale "Interleaving verification with modification catches errors early before they cascade through later steps." ;
    oc:severityLevel "HIGH" .

oc:kn_7cec6111 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a skill must handle multiple distinct operation types" ;
    oc:directiveContent "Use conditional branching with decision points and clear labels (e.g., 'Creating new content?') to route Claude to the correct sub-workflow." ;
    oc:hasRationale "Explicit branching prevents Claude from conflating creation and editing logic, which leads to incorrect outputs." ;
    oc:severityLevel "MEDIUM" .

oc:kn_af13f501 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing multi-step skills with dependent stages" ;
    oc:directiveContent "For complex tasks, break operations into clear sequential steps and provide an overview of the entire process near the beginning of SKILL.md." ;
    oc:hasRationale "Sequential overviews help Claude maintain context and track progress through long operations, reducing errors from missed steps." ;
    oc:severityLevel "HIGH" .

oc:kn_d2cf1050 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any skill workflow definition" ;
    oc:directiveContent "Each workflow step should reference a concrete action (run a script, edit a file, verify output) rather than abstract goals." ;
    oc:hasRationale "Actionable steps reduce ambiguity and make the workflow reproducible across invocations." ;
    oc:severityLevel "MEDIUM" .

