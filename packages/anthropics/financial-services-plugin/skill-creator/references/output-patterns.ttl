oc:skill_financial_services_plugin_skill_creator_output_patterns a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "output-patterns" ;
    skos:broader "Pattern reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/skill-creator" ;
    oc:contentHash "d6027800b9d8c26589edba85b42901a41ac36d753b4e9cebc7f4cbb03cdcf0a4" ;
    oc:differentia "that provides templates and examples patterns for consistent skill output formatting" ;
    oc:extends oc:skill_financial_services_plugin_skill_creator ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Use these patterns when skills need to produce consistent, high-quality output." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**For flexible guidance (when adaptation is useful):**" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """## Report structure

Here is a sensible default format, but use your best judgment:

# [Analysis Title]

## Executive summary
[Overview]

## Key findings
[Adapt sections based on what you discover]

## Recommendations
[Tailor to the specific context]

Adjust sections as needed for the specific analysis type.
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 5 ;
                            oc:sourceLocation "lines 33-50" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Provide templates for output format. Match the level of strictness to your needs." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """## Report structure

ALWAYS use this exact template structure:

# [Analysis Title]

## Executive summary
[One-paragraph overview of key findings]

## Key findings
- Finding 1 with supporting data
- Finding 2 with supporting data
- Finding 3 with supporting data

## Recommendations
1. Specific actionable recommendation
2. Specific actionable recommendation
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 11-29" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**For strict requirements (like API responses or data formats):**" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Template Pattern" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """
**Example 2:**
Input: Fixed bug where dates displayed incorrectly in reports
Output:
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 5 ;
                            oc:sourceLocation "lines 68-73" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "For skills where output quality depends on seeing examples, provide input/output pairs:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """
Follow this style: type(scope): brief description, then detailed explanation.
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 8 ;
                            oc:sourceLocation "lines 77-80" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent "Use UTC timestamps consistently across report generation" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "fix(reports): correct date formatting in timezone conversion" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "feat(auth): implement JWT-based authentication" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 9 ;
                            oc:textContent "Examples help Claude understand the desired style and level of detail more clearly than descriptions alone." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """## Commit message format

Generate commit messages following these examples:

**Example 1:**
Input: Added user authentication with JWT tokens
Output:
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 56-64" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "Add login endpoint and token validation middleware" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Examples Pattern" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Output Patterns" ] ;
    oc:impartsKnowledge oc:kn_0d311a0b,
        oc:kn_427b5e44,
        oc:kn_aeff68b4,
        oc:kn_f0d2d005,
        oc:kn_f575f2f7 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:SkillDesignInProgress ;
    oc:resolvesIntent "create consistent output templates",
        "provide output examples for skill development",
        "standardize skill output format" ;
    oc:yieldsState oc:OutputPatternDefined .

oc:kn_0d311a0b a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building a new skill's output section" ;
    oc:directiveContent "Use the Template Pattern for structural consistency and the Examples Pattern for stylistic consistency. Combine both when a skill requires precise formatting AND tone/style alignment." ;
    oc:hasRationale "Templates define structure; examples define style. Together they produce consistently high-quality output." ;
    oc:severityLevel "LOW" .

oc:kn_427b5e44 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When output must conform to a fixed schema (API responses, data formats)" ;
    oc:directiveContent "Strict template: # [Title] → ## Executive summary → ## Key findings (bullet list) → ## Recommendations (numbered list). Always use exact structure." ;
    oc:templateVariables "Analysis Title",
        "Executive summary",
        "Key findings",
        "Recommendations" .

oc:kn_aeff68b4 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When output should follow a sensible default but adapt to context" ;
    oc:directiveContent "Flexible template: # [Title] → ## Executive summary → ## Key findings → ## Recommendations. Adjust sections as needed for the specific analysis type." ;
    oc:templateVariables "Analysis Title",
        "Executive summary",
        "Key findings",
        "Recommendations" .

oc:kn_f0d2d005 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When skill output quality depends on nuance or style" ;
    oc:directiveContent "Provide input/output example pairs to demonstrate desired output style and level of detail rather than relying on descriptions alone." ;
    oc:hasRationale "Examples communicate desired style and granularity more effectively than abstract descriptions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f575f2f7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing output templates for a skill" ;
    oc:directiveContent "Match template strictness to the use case: use rigid templates for API responses and data formats, use flexible guidance when adaptation is useful." ;
    oc:hasRationale "Over-specifying flexible content reduces quality; under-specifying structured content causes inconsistency." ;
    oc:severityLevel "MEDIUM" .

