@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_skill_creator_output_patterns a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "output-patterns" ;
    skos:broader "Pattern catalog" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/skill-creator" ;
    oc:contentHash "d6027800b9d8c26589edba85b42901a41ac36d753b4e9cebc7f4cbb03cdcf0a4" ;
    oc:differentia "defines reusable output formatting patterns (template and examples) for consistent skill output generation" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_skill_creator ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_3aca9f4a,
        oc:kn_3c984822,
        oc:kn_4a4b0cc1,
        oc:kn_9603ffe0 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "apply template patterns to skill output",
        "standardize skill output format",
        "use examples to guide output quality" ;
    oc:yieldsState oc:OutputPatternApplied .

oc:kn_3aca9f4a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining report or analysis output templates" ;
    oc:directiveContent "Template patterns must include a clear header hierarchy with a title, executive summary, key findings, and recommendations as the baseline structure." ;
    oc:hasRationale "A consistent baseline structure ensures stakeholders can always navigate outputs predictably, even when sections are adapted." ;
    oc:severityLevel "LOW" .

oc:kn_3c984822 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When using the examples pattern for short-form structured output" ;
    oc:directiveContent "For commit messages and similar structured short-form output, provide at least two examples covering different scenarios (e.g., a feature addition and a bug fix)." ;
    oc:hasRationale "Multiple examples spanning different scenarios demonstrate the pattern's range and reduce misinterpretation." ;
    oc:severityLevel "LOW" .

oc:kn_4a4b0cc1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a skill's output quality depends on nuance, tone, or formatting conventions" ;
    oc:directiveContent "Use input/output example pairs to convey desired style and detail level when descriptions alone are insufficient." ;
    oc:hasRationale "Examples communicate implicit expectations (style, depth, terminology) more effectively than abstract descriptions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9603ffe0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing output templates for any skill" ;
    oc:directiveContent "Match template strictness to the output context: use rigid templates for API responses and data formats, use flexible guidance when adaptation is useful." ;
    oc:hasRationale "Over-specifying flexible content types stifles quality, while under-specifying structured outputs creates inconsistency." ;
    oc:severityLevel "MEDIUM" .

