oc:skill_financial_services_plugin_skill_creator a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "skill-creator" ;
    skos:broader "Skill creation guide" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/skill-creator" ;
    oc:contentHash "3875339e1383a9c345dc2f15c005ef445c94b33db830031cec2238308373f5f6" ;
    oc:differentia "provides a structured process for designing, implementing, packaging, and iterating on modular AI agent skills with progressive disclosure and context efficiency" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "skill-name or skill-description" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Guide for creating effective skills. This skill should be used when users want to create a new skill (or update an existing skill) that extends Claude's capabilities with specialized knowledge, workflows, or tool integrations." ;
    oc:hasName "skill-creator" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: skill-creator
description: Guide for creating effective skills. This skill should be used when users want to create a new skill (or update an existing skill) that extends Claude's capabilities with specialized knowledge, workflows, or tool integrations.
license: Complete terms in LICENSE.txt
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "This skill provides guidance for creating effective skills." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Follow these steps in order, skipping only if there is a clear reason why they are not applicable." ],
                        _:ref_5f34374e82640c7c,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Skill creation involves these steps:" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent _:ref_0edc8d1f43036958,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 7 ;
                                    oc:textContent "Example: When building a `big-query` skill to handle queries like \"How many users have logged in today?\" the analysis shows:" ],
                                _:ref_59adec9debcedfbc,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "Example: When designing a `frontend-webapp-builder` skill for queries like \"Build me a todo app\" or \"Build me a dashboard to track my steps,\" the analysis shows:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 9 ;
                                    oc:textContent "To establish the skill's contents, analyze each concrete example to create a list of the reusable resources to include: scripts, references, and assets." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Example: When building a `pdf-editor` skill to handle queries like \"Help me rotate this PDF,\" the analysis shows:" ],
                                _:ref_bbd6e88fbcc3ff6a,
                                _:ref_bcffdcfd6fd4ea2f,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "To turn concrete examples into an effective skill, analyze each example by:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 18 ;
                            oc:sectionTitle "Step 2: Planning the Reusable Skill Contents" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "When editing the (newly-generated or existing) skill, remember that the skill is being created for another instance of Claude to use. Include information that would be beneficial and non-obvious to Claude. Consider what procedural knowledge, domain-specific details, or reusable assets would help another Claude instance execute these tasks more effectively." ] ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 3 ;
                                            oc:textContent "These files contain established best practices for effective skill design." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "Consult these helpful guides based on your skill's needs:" ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Specific output formats or quality standards**: See references/output-patterns.md for template and example patterns" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Multi-step processes**: See references/workflows.md for sequential workflows and conditional logic" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 21 ;
                                    oc:sectionTitle "Learn Proven Design Patterns" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**Writing Guidelines:** Always use imperative/infinitive form." ] ;
                                    oc:hasSubsection [ a oc:Section ;
                                            oc:hasContent [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 1 ;
                                                    oc:textContent "Write instructions for using the skill and its bundled resources." ] ;
                                            oc:sectionLevel 5 ;
                                            oc:sectionOrder 25 ;
                                            oc:sectionTitle "Body" ],
                                        [ a oc:Section ;
                                            oc:hasContent [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 3 ;
                                                    oc:textContent "Do not include any other fields in YAML frontmatter." ],
                                                [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 2 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:hasChild [ a oc:BulletList ;
                                                                    oc:blockType "bullet_list" ;
                                                                    oc:contentOrder 1 ;
                                                                    oc:hasItem [ a oc:BulletItem ;
                                                                            oc:blockType "bullet_item" ;
                                                                            oc:itemOrder 3 ;
                                                                            oc:itemText "Example description for a `docx` skill: \"Comprehensive document creation, editing, and analysis with support for tracked changes, comments, formatting preservation, and text extraction. Use when Claude needs to work with professional documents (.docx files) for: (1) Creating new documents, (2) Modifying or editing content, (3) Working with tracked changes, (4) Adding comments, or any other document tasks\"" ],
                                                                        [ a oc:BulletItem ;
                                                                            oc:blockType "bullet_item" ;
                                                                            oc:itemOrder 2 ;
                                                                            oc:itemText "Include all \"when to use\" information here - Not in the body. The body is only loaded after triggering, so \"When to Use This Skill\" sections in the body are not helpful to Claude." ],
                                                                        [ a oc:BulletItem ;
                                                                            oc:blockType "bullet_item" ;
                                                                            oc:itemOrder 1 ;
                                                                            oc:itemText "Include both what the Skill does and specific triggers/contexts for when to use it." ] ] ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "`description`: This is the primary triggering mechanism for your skill, and helps Claude understand when to use the skill." ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "`name`: The skill name" ] ],
                                                [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 1 ;
                                                    oc:textContent "Write the YAML frontmatter with `name` and `description`:" ] ;
                                            oc:sectionLevel 5 ;
                                            oc:sectionOrder 24 ;
                                            oc:sectionTitle "Frontmatter" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 23 ;
                                    oc:sectionTitle "Update SKILL.md" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 2 ;
                                            oc:textContent "Added scripts must be tested by actually running them to ensure there are no bugs and that the output matches what is expected. If there are many similar scripts, only a representative sample needs to be tested to ensure confidence that they all work while balancing time to completion." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "To begin implementation, start with the reusable resources identified above: `scripts/`, `references/`, and `assets/` files. Note that this step may require user input. For example, when implementing a `brand-guidelines` skill, the user may need to provide brand assets or templates to store in `assets/`, or documentation to store in `references/`." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 3 ;
                                            oc:textContent "Any example files and directories not needed for the skill should be deleted. The initialization script creates example files in `scripts/`, `references/`, and `assets/` to demonstrate structure, but most skills won't need all of them." ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 22 ;
                                    oc:sectionTitle "Start with Reusable Skill Contents" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 20 ;
                            oc:sectionTitle "Step 4: Edit the Skill" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """scripts/package_skill.py <path/to/skill-folder>
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 324-326" ],
                                _:ref_64d1e68c76932ee2,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 7 ;
                                    oc:textContent "If validation fails, the script will report the errors and exit without creating a package. Fix any validation errors and run the packaging command again." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Once development of the skill is complete, it must be packaged into a distributable .skill file that gets shared with the user. The packaging process automatically validates the skill first to ensure it meets all requirements:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """scripts/package_skill.py <path/to/skill-folder> ./dist
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 4 ;
                                    oc:sourceLocation "lines 330-332" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "The packaging script will:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Optional output directory specification:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 26 ;
                            oc:sectionTitle "Step 5: Packaging a Skill" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "The script:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 8 ;
                                    oc:textContent "After initialization, customize or remove the generated SKILL.md and example files as needed." ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """scripts/init_skill.py <skill-name> --path <output-directory>
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 5 ;
                                    oc:sourceLocation "lines 266-268" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "At this point, it is time to actually create the skill." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 7 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Adds example files in each directory that can be customized or deleted" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Creates example resource directories: `scripts/`, `references/`, and `assets/`" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Generates a SKILL.md template with proper frontmatter and TODO placeholders" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Creates the skill directory at the specified path" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "Skip this step only if the skill being developed already exists, and iteration or packaging is needed. In this case, continue to the next step." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "When creating a new skill from scratch, always run the `init_skill.py` script. The script conveniently generates a new template skill directory that automatically includes everything a skill requires, making the skill creation process much more efficient and reliable." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "Usage:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 19 ;
                            oc:sectionTitle "Step 3: Initializing the Skill" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Skip this step only when the skill's usage patterns are already clearly understood. It remains valuable even when working with an existing skill." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "To create an effective skill, clearly understand concrete examples of how the skill will be used. This understanding can come from either direct user examples or generated examples that are validated with user feedback." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "Conclude this step when there is a clear sense of the functionality the skill should support." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "\"I can imagine users asking for things like 'Remove the red-eye from this image' or 'Rotate this image'. Are there other ways you imagine this skill being used?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "\"Can you give some examples of how this skill would be used?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "\"What functionality should the image-editor skill support? Editing, rotating, anything else?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "\"What would a user say that should trigger this skill?\"" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "To avoid overwhelming users, avoid asking too many questions in a single message. Start with the most important questions and follow up as needed for better effectiveness." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "For example, when building an image-editor skill, relevant questions include:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 17 ;
                            oc:sectionTitle "Step 1: Understanding the Skill with Concrete Examples" ],
                        [ a oc:Section ;
                            oc:hasContent _:ref_1d238bc5d7ec25df,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Iteration workflow:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "After testing the skill, users may request improvements. Often this happens right after using the skill, with fresh context of how the skill performed." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 27 ;
                            oc:sectionTitle "Step 6: Iterate" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 16 ;
                    oc:sectionTitle "Skill Creation Process" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Every skill consists of a required SKILL.md file and optional bundled resources:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """skill-name/
├── SKILL.md (required)
│   ├── YAML frontmatter metadata (required)
│   │   ├── name: (required)
│   │   └── description: (required)
│   └── Markdown instructions (required)
└── Bundled Resources (optional)
    ├── scripts/          - Executable code (Python/Bash/etc.)
    ├── references/       - Documentation intended to be loaded into context as needed
    └── assets/           - Files used in output (templates, icons, fonts, etc.)
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 51-62" ] ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 3 ;
                                            oc:textContent "The skill should only contain the information needed for an AI agent to do the job at hand. It should not contain auxilary context about the process that went into creating it, setup and testing procedures, user-facing documentation, etc. Creating additional documentation files just adds clutter and confusion." ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "CHANGELOG.md" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "etc." ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "INSTALLATION_GUIDE.md" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "README.md" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "QUICK_REFERENCE.md" ] ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "A skill should only contain essential files that directly support its functionality. Do NOT create extraneous documentation or auxiliary files, including:" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 13 ;
                                    oc:sectionTitle "What to Not Include in a Skill" ],
                                [ a oc:Section ;
                                    oc:hasSubsection [ a oc:Section ;
                                            oc:hasContent [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 1 ;
                                                    oc:textContent "Executable code (Python/Bash/etc.) for tasks that require deterministic reliability or are repeatedly rewritten." ],
                                                [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 2 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "**Example**: `scripts/rotate_pdf.py` for PDF rotation tasks" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "**Benefits**: Token efficient, deterministic, may be executed without loading into context" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 4 ;
                                                            oc:itemText "**Note**: Scripts may still need to be read by Claude for patching or environment-specific adjustments" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "**When to include**: When the same code is being rewritten repeatedly or deterministic reliability is needed" ] ] ;
                                            oc:sectionLevel 5 ;
                                            oc:sectionOrder 10 ;
                                            oc:sectionTitle "Scripts (`scripts/`)" ],
                                        [ a oc:Section ;
                                            oc:hasContent [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 2 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "**Use cases**: Templates, images, icons, boilerplate code, fonts, sample documents that get copied or modified" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 4 ;
                                                            oc:itemText "**Benefits**: Separates output resources from documentation, enables Claude to use files without loading them into context" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "**Examples**: `assets/logo.png` for brand assets, `assets/slides.pptx` for PowerPoint templates, `assets/frontend-template/` for HTML/React boilerplate, `assets/font.ttf` for typography" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "**When to include**: When the skill needs files that will be used in the final output" ] ],
                                                [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 1 ;
                                                    oc:textContent "Files not intended to be loaded into context, but rather used within the output Claude produces." ] ;
                                            oc:sectionLevel 5 ;
                                            oc:sectionOrder 12 ;
                                            oc:sectionTitle "Assets (`assets/`)" ],
                                        [ a oc:Section ;
                                            oc:hasContent [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 2 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 6 ;
                                                            oc:itemText "**Avoid duplication**: Information should live in either SKILL.md or references files, not both. Prefer references files for detailed information unless it's truly core to the skill—this keeps SKILL.md lean while making information discoverable without hogging the context window. Keep only essential procedural instructions and workflow guidance in SKILL.md; move detailed reference material, schemas, and examples to references files." ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 5 ;
                                                            oc:itemText "**Best practice**: If files are large (>10k words), include grep search patterns in SKILL.md" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "**When to include**: For documentation that Claude should reference while working" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 4 ;
                                                            oc:itemText "**Benefits**: Keeps SKILL.md lean, loaded only when Claude determines it's needed" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "**Examples**: `references/finance.md` for financial schemas, `references/mnda.md` for company NDA template, `references/policies.md` for company policies, `references/api_docs.md` for API specifications" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "**Use cases**: Database schemas, API documentation, domain knowledge, company policies, detailed workflow guides" ] ],
                                                [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 1 ;
                                                    oc:textContent "Documentation and reference material intended to be loaded as needed into context to inform Claude's process and thinking." ] ;
                                            oc:sectionLevel 5 ;
                                            oc:sectionOrder 11 ;
                                            oc:sectionTitle "References (`references/`)" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 9 ;
                                    oc:sectionTitle "Bundled Resources (optional)" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "Every SKILL.md consists of:" ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Frontmatter** (YAML): Contains `name` and `description` fields. These are the only fields that Claude reads to determine when the skill gets used, thus it is very important to be clear and comprehensive in describing what the skill is, and when it should be used." ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Body** (Markdown): Instructions and guidance for using the skill. Only loaded AFTER the skill triggers (if at all)." ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 8 ;
                                    oc:sectionTitle "SKILL.md (required)" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 7 ;
                            oc:sectionTitle "Anatomy of a Skill" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "The context window is a public good. Skills share the context window with everything else Claude needs: system prompt, conversation history, other Skills' metadata, and the actual user request." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Default assumption: Claude is already very smart.** Only add context Claude doesn't already have. Challenge each piece of information: \"Does Claude really need this explanation?\" and \"Does this paragraph justify its token cost?\"" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Prefer concise examples over verbose explanations." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Concise is Key" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Medium freedom (pseudocode or scripts with parameters)**: Use when a preferred pattern exists, some variation is acceptable, or configuration affects behavior." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Low freedom (specific scripts, few parameters)**: Use when operations are fragile and error-prone, consistency is critical, or a specific sequence must be followed." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**High freedom (text-based instructions)**: Use when multiple approaches are valid, decisions depend on context, or heuristics guide the approach." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "Think of Claude as exploring a path: a narrow bridge with cliffs needs specific guardrails (low freedom), while an open field allows many routes (high freedom)." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Match the level of specificity to the task's fragility and variability:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "Set Appropriate Degrees of Freedom" ],
                        [ a oc:Section ;
                            oc:hasContent _:ref_ae2a17074d67e490,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Skills use a three-level loading system to manage context efficiently:" ] ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 12 ;
                                            oc:textContent "When the user chooses AWS, Claude only reads aws.md." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 6 ;
                                            oc:textContent "**Pattern 2: Domain-specific organization**" ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 18 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Structure longer reference files** - For files longer than 100 lines, include a table of contents at the top so Claude can see the full scope when previewing." ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Avoid deeply nested references** - Keep references one level deep from SKILL.md. All reference files should link directly from SKILL.md." ] ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 14 ;
                                            oc:textContent "Show basic content, link to advanced content:" ],
                                        [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """# PDF Processing

## Quick start

Extract text with pdfplumber:
[code example]

## Advanced features

- **Form filling**: See [FORMS.md](FORMS.md) for complete guide
- **API reference**: See [REFERENCE.md](REFERENCE.md) for all methods
- **Examples**: See [EXAMPLES.md](EXAMPLES.md) for common patterns
""" ;
                                            oc:codeLanguage "markdown" ;
                                            oc:contentOrder 4 ;
                                            oc:sourceLocation "lines 130-143" ],
                                        [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """# DOCX Processing

## Creating documents

Use docx-js for new documents. See [DOCX-JS.md](DOCX-JS.md).

## Editing documents

For simple edits, modify the XML directly.

**For tracked changes**: See [REDLINING.md](REDLINING.md)
**For OOXML details**: See [OOXML.md](OOXML.md)
""" ;
                                            oc:codeLanguage "markdown" ;
                                            oc:contentOrder 15 ;
                                            oc:sourceLocation "lines 180-193" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 3 ;
                                            oc:textContent "**Pattern 1: High-level guide with references**" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "Keep SKILL.md body to the essentials and under 500 lines to minimize context bloat. Split content into separate files when approaching this limit. When splitting out content into other files, it is very important to reference them from SKILL.md and describe clearly when to read them, to ensure the reader of the skill knows they exist and when to use them." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 17 ;
                                            oc:textContent "**Important guidelines:**" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 5 ;
                                            oc:textContent "Claude loads FORMS.md, REFERENCE.md, or EXAMPLES.md only when needed." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 10 ;
                                            oc:textContent "Similarly, for skills supporting multiple frameworks or variants, organize by variant:" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 9 ;
                                            oc:textContent "When a user asks about sales metrics, Claude only reads sales.md." ],
                                        [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """cloud-deploy/
├── SKILL.md (workflow + provider selection)
└── references/
    ├── aws.md (AWS deployment patterns)
    ├── gcp.md (GCP deployment patterns)
    └── azure.md (Azure deployment patterns)
""" ;
                                            oc:codeLanguage "" ;
                                            oc:contentOrder 11 ;
                                            oc:sourceLocation "lines 165-172" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 13 ;
                                            oc:textContent "**Pattern 3: Conditional details**" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 7 ;
                                            oc:textContent "For Skills with multiple domains, organize content by domain to avoid loading irrelevant context:" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 2 ;
                                            oc:textContent "**Key principle:** When a skill supports multiple variations, frameworks, or options, keep only the core workflow and selection guidance in SKILL.md. Move variant-specific details (patterns, examples, configuration) into separate reference files." ],
                                        [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """bigquery-skill/
├── SKILL.md (overview and navigation)
└── reference/
    ├── finance.md (revenue, billing metrics)
    ├── sales.md (opportunities, pipeline)
    ├── product.md (API usage, features)
    └── marketing.md (campaigns, attribution)
""" ;
                                            oc:codeLanguage "" ;
                                            oc:contentOrder 8 ;
                                            oc:sourceLocation "lines 151-159" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 16 ;
                                            oc:textContent "Claude reads REDLINING.md or OOXML.md only when the user needs those features." ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 15 ;
                                    oc:sectionTitle "Progressive Disclosure Patterns" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 14 ;
                            oc:sectionTitle "Progressive Disclosure Design Principle" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Core Principles" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """Skills are modular, self-contained packages that extend Claude's capabilities by providing
specialized knowledge, workflows, and tools. Think of them as "onboarding guides" for specific
domains or tasks—they transform Claude from a general-purpose agent into a specialized agent
equipped with procedural knowledge that no model can fully possess.""" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent _:ref_bfefff65eafaf40b ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "What Skills Provide" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "About Skills" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Skill Creator" ] ;
