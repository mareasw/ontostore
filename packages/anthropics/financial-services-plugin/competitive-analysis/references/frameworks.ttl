oc:skill_anthropics_financial_services_plugin_competitive_analysis_frameworks a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "frameworks" ;
    skos:broader "Reference framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/competitive-analysis" ;
    oc:contentHash "93b3f437c8da7a48e8a77603bd4eb47aba5880e40afdc1d77b8e590bd02c61b7" ;
    oc:differentia "that provides industry-specific axis pairings for 2x2 competitive positioning matrices" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_competitive_analysis ;
    oc:hasCategory "research" ;
    oc:impartsKnowledge oc:kn_6dba69d1,
        oc:kn_912f401e,
        oc:kn_9dea46c8 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:IndustryIdentified ;
    oc:resolvesIntent "find industry-appropriate framework dimensions for competitive analysis",
        "select axis pairs for 2x2 competitive positioning matrix" ;
    oc:yieldsState oc:FrameworkAxesSelected .

oc:kn_6dba69d1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing a 2x2 competitive positioning matrix" ;
    oc:directiveContent "Choose 2x2 matrix axis pairs that are tailored to the specific industry being analyzed rather than using generic dimensions." ;
    oc:hasRationale "Industry-specific axes produce more actionable and relevant competitive insights than generic ones like 'price vs quality'" ;
    oc:severityLevel "MEDIUM" .

oc:kn_912f401e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing financial services competitive landscapes" ;
    oc:directiveContent "For Financial Services competitive analysis, prefer axes like Product complexity × Customer sophistication or Scale × Specialization." ;
    oc:hasRationale "These dimensions capture the key structural differentiators in financial services where product complexity and customer segments drive competitive positioning" .

oc:kn_9dea46c8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when selecting framework dimensions" ;
    oc:directiveContent "Only use axis pairs that are documented for the target industry; do not mix axes across industries without justification." ;
    oc:hasRationale "Cross-industry axis mixing can produce misleading or nonsensical competitive maps that confuse rather than clarify" .

