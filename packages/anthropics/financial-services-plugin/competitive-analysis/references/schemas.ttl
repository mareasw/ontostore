@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_financial_services_plugin_competitive_analysis_schemas a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "schemas" ;
    skos:broader "Schema reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/competitive-analysis" ;
    oc:contentHash "4bc65ebead267d789a0824342d7e59ac7ff133e873f3c32675bf351d472c9e6d" ;
    oc:differentia "defines table and slide layout formats for competitive analysis deliverables" ;
    oc:extends oc:skill_financial_services_plugin_competitive_analysis ;
    oc:hasCategory "finance" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Additional table formats not shown in main SKILL.md." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 1 ;
                            oc:tableCaption "## M&A Transaction Table" ;
                            oc:tableMarkdown """| Acquirer | Target | Date | Deal Value | Multiple | Rationale |
|----------|--------|------|------------|----------|-----------|
| Company A | Company B | MMM YYYY | $X.XB | X.Xx EV/Rev | [Strategic logic] |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "State multiple methodology: \"X.Xx EV/Revenue\" or \"X.Xx EV/EBITDA\"" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "M&A Transaction Table" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """┌─────────────────────────────────────────────────────────────┐
│ [Insight headline, not topic]                               │
├─────────────────────────────────────────────────────────────┤
│                                                             │
│                     [Main Content]                          │
│                                                             │
├─────────────────────────────────────────────────────────────┤
│ Source: [Citation] ([Date])                                 │
└─────────────────────────────────────────────────────────────┘
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 23-33" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Slide Structure" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 3 ;
                            oc:tableCaption "## Scenario Analysis Table" ;
                            oc:tableMarkdown """| Scenario | Probability | Valuation | Key Assumptions |
|----------|-------------|-----------|-----------------|
| Bull | XX% | $XXB | [Specific, quantified] |
| Base | XX% | $XXB | [Specific, quantified] |
| Bear | XX% | $XXB | [Specific, quantified] |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Scenario Analysis Table" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Schemas Reference" ] ;
    oc:impartsKnowledge oc:kn_323bfad8,
        oc:kn_48379d61,
        oc:kn_53f5d851,
        oc:kn_59f470a1,
        oc:kn_9d118dc4 ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:resolvesIntent "create scenario analysis tables",
        "format M&A transaction tables",
        "structure competitive analysis slides" .

oc:kn_323bfad8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing slide titles for competitive analysis presentations" ;
    oc:directiveContent "Use insight headlines instead of topic labels on slides — headlines should convey the key takeaway, not just name the section" ;
    oc:hasRationale "Insight headlines communicate the finding immediately; topic-only headers force the reader to parse the full content to understand the point" .

oc:kn_48379d61 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating M&A transaction tables" ;
    oc:directiveContent "M&A deal multiples must state methodology explicitly: 'X.Xx EV/Revenue' or 'X.Xx EV/EBITDA' — never omit the metric basis" ;
    oc:hasRationale "Omitting the multiple basis makes comparisons meaningless across deals with different profitability profiles" ;
    oc:severityLevel "HIGH" .

oc:kn_53f5d851 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating any slide for competitive analysis deliverable" ;
    oc:directiveContent """Slide layout:
┌─────────────────────────────────────────┐
│ [Insight headline, not topic]            │
├─────────────────────────────────────────┤
│            [Main Content]                │
├─────────────────────────────────────────┤
│ Source: [Citation] ([Date])              │
└─────────────────────────────────────────┘""" ;
    oc:stepOrder 3 ;
    oc:templateVariables "Citation",
        "Date",
        "Insight headline",
        "Main Content" .

oc:kn_59f470a1 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When presenting M&A transaction comparables in competitive analysis" ;
    oc:directiveContent """## M&A Transaction Table
| Acquirer | Target | Date | Deal Value | Multiple | Rationale |
State multiple methodology as 'X.Xx EV/Revenue' or 'X.Xx EV/EBITDA'""" ;
    oc:stepOrder 1 ;
    oc:templateVariables "Acquirer",
        "Date",
        "Deal Value",
        "Multiple",
        "Rationale",
        "Target" .

oc:kn_9d118dc4 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When presenting scenario-based valuation analysis" ;
    oc:directiveContent """## Scenario Analysis Table
| Scenario | Probability | Valuation | Key Assumptions |
Rows: Bull / Base / Bear with probability-weighted valuations and specific quantified assumptions""" ;
    oc:stepOrder 2 ;
    oc:templateVariables "Key Assumptions",
        "Probability",
        "Scenario",
        "Valuation" .

