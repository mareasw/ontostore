oc:skill_anthropics_financial_services_plugin_competitive_analysis_schemas a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "schemas" ;
    skos:broader "Reference specification" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/competitive-analysis" ;
    oc:contentHash "4bc65ebead267d789a0824342d7e59ac7ff133e873f3c32675bf351d472c9e6d" ;
    oc:differentia "Defines standardized table schemas and slide layout templates for competitive analysis deliverables" ;
    oc:extends oc:skill_anthropics_financial_services_plugin_competitive_analysis ;
    oc:hasArgumentHint "table-type (M&A Transaction Table | Scenario Analysis Table | Slide Structure)" ;
    oc:hasCategory "finance" ;
    oc:impartsKnowledge oc:kn_8dcd4ea8,
        oc:kn_a208d39e,
        oc:kn_a9133afc,
        oc:kn_f69573d1 ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:requiresState oc:DataCollected ;
    oc:resolvesIntent "apply slide layout templates for competitive analysis presentations",
        "format M&A transaction tables",
        "structure scenario analysis tables" ;
    oc:yieldsState oc:DocumentFormatted .

oc:kn_8dcd4ea8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finalizing any slide in competitive analysis presentations" ;
    oc:directiveContent "Every slide must include a source citation with date at the bottom, formatted as 'Source: [Citation] ([Date])'." ;
    oc:hasRationale "Source attribution is essential for institutional credibility and enables reviewers to verify data points independently." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a208d39e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building scenario analysis tables for competitive valuation" ;
    oc:directiveContent "Scenario analysis should always include exactly three scenarios (Bull, Base, Bear) with probability-weighted valuations and specific, quantified key assumptions." ;
    oc:hasRationale "The three-scenario structure provides a bounded range of outcomes that decision-makers can triangulate against, while quantified assumptions make the analysis auditable." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a9133afc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating M&A Transaction Table deal data" ;
    oc:directiveContent "M&A transaction multiples must state their methodology explicitly as 'X.Xx EV/Revenue' or 'X.Xx EV/EBITDA' rather than raw numbers alone." ;
    oc:hasRationale "Without methodology labels, readers cannot compare multiples across deals that may use different bases, leading to misleading conclusions." ;
    oc:severityLevel "HIGH" .

oc:kn_f69573d1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing any slide in a competitive analysis deliverable" ;
    oc:directiveContent "Slide headlines must be insight-driven statements, not topic labels — e.g., 'Acquisition premiums have compressed 40% since 2021' rather than 'M&A Market Overview'." ;
    oc:hasRationale "Topic-label headlines force the audience to do the interpretive work; insight headlines immediately communicate the takeaway and make the deck scannable." ;
    oc:severityLevel "HIGH" .

