oc:skill_financial_services_plugin_competitive_analysis a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "competitive-analysis" ;
    skos:broader "Presentation builder" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/competitive-analysis" ;
    oc:contentHash "48477c5cb31e828c06509bed3a4d8ba85958e90618ce246ad1165c84b1691614" ;
    oc:differentia "that generates competitive landscape analysis decks with market positioning, competitor deep-dives, comparative analysis, and strategic synthesis" ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasAllowedTool "ask_user_question" ;
    oc:hasArgumentHint "company or industry to analyze competitively" ;
    oc:hasCategory "research" ;
    oc:hasDescription "Framework for building competitive landscape decks — market positioning, competitor deep-dives, comparative analysis, strategic synthesis. Use when the user asks for a competitive landscape, competitor analysis, peer comparison, market positioning assessment, strategic review, or investment memo deck. Also triggers on \"who are the competitors to X\", \"benchmark X against peers\", \"build a market map\", or any request to systematically evaluate competitive dynamics across an industry." ;
    oc:hasName "competitive-analysis" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: competitive-analysis
description: Framework for building competitive landscape decks — market positioning, competitor deep-dives, comparative analysis, strategic synthesis. Use when the user asks for a competitive landscape, competitor analysis, peer comparison, market positioning assessment, strategic review, or investment memo deck. Also triggers on "who are the competitors to X", "benchmark X against peers", "build a market map", or any request to systematically evaluate competitive dynamics across an industry.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Build a complete competitive analysis deck. This is a two-phase process: gather requirements and get outline approval first, then build." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "If they've uploaded an Excel/CSV with competitor data, confirm which columns map to which metrics before you start pulling numbers. Source-file fidelity matters: use values exactly as given, don't recalculate or re-round." ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Scope** — Single target company with competitors around it? Or multi-company side-by-side with no protagonist?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Investment context** — Do they need bull/base/bear scenarios and signposts? That's Step 9 below; skip it if this is a strategic review rather than an investment thesis." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Audience and depth** — Quick read for someone already in the space, or a full primer? This drives whether you need market sizing, industry economics, and history — or can skip to the comparison." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Competitor set** — Which companies are in scope? If the user names them, use exactly those. If they say \"the usual suspects,\" propose a set and confirm." ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Gather in one round if you can (the tool takes up to 4 questions):" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Competitive analysis means different things to different people. Before any research or slide-building, use `ask_user_question` to pin down what they actually want. Don't guess — a 20-slide peer benchmarking deck and a 5-slide market map are both \"competitive analysis\" and take completely different shapes." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Phase 1 — Scope the analysis" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 5 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Same metric shows the same value on every slide it appears" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Same decimal precision as the source" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Source-file values extracted directly, not recalculated" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Prompt fidelity**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Before finishing:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 10 ;
                            oc:textContent "Run standard visual verification checks on every slide — this catches overlaps, overflow, and low-contrast text that don't show up when you're reading back the XML." ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 7 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "No overlapping elements" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Titles fit without overflow" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "All text within containers, no clipping" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**Data consistency**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 8 ;
                            oc:textContent "**Content**" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Charts where they said chart; tables where they said table" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Every competitor/year/data point they listed is present" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Slide titles match what the user specified, verbatim" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Exact values and formats as specified" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 9 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Charts are real chart objects" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Slide titles state insights, not topics" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Every number has a citation" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "All metrics from the same fiscal period (or flagged)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "**Layout**" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Quality checklist" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "This skill works in both the PowerPoint add-in and chat. Identify which you're in before starting — the mechanics differ, the workflow doesn't:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Add-in** — the deck is open live; build slides directly into it." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Chat** — generate a `.pptx` file (or build into one the user uploaded)." ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Everything below applies in both." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Environment check" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent _:ref_e0aef054a6266a83 ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Source quality, when sources conflict" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "When the user specifies something, that's a requirement, not a suggestion:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Chart vs. table** — not interchangeable. \"Embedded chart\" means a real chart object with data labels on the bars/slices, not a formatted table." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Slide titles and section names** — exact wording. If they say \"Overview and Competitive Scope,\" don't swap in \"FY2024 Competitive Landscape.\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Complete data series** — if they list 7 competitors, include all 7. If they show 2015-2025, include every year." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Exact values and ratios** — \"surpasses DoorDash 4:1, Lyft 8:1\" means those ratios, not \"7.6x Lyft.\"" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Prompt fidelity" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Every number has a citation: \"[Company] [Document] ([Date])\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "All competitor metrics from the same fiscal year; flag exceptions explicitly (\"FY24\" vs \"H1 2024\")" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Convert to USD for international; note the exchange rate and date" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Same metric definitions across competitors" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Missing data shows as \"-\" or \"N/A\" with an \"[E]\" flag for estimates — never blank" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Data comparability" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "**Tables:**" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Ratings show the actual.** \"●●● $160B\" — not just \"●●●.\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Charts are real chart objects** — not text tables dressed up to look like charts." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Signposts are quantified.** \"Margin below 40%\" — not \"margins decline.\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Slide titles are insights, not labels.** \"Scale leaders pulling away from niche players\" — not \"Competitive Analysis.\"" ] ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 5 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "More than 6 series → split into multiple charts or use a table" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Legend inside the chart boundary, not floating over the plot area" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Pie charts show percentages on slices, not just in the legend" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Right-side legend for pies (≤6 slices), bottom legend for line/bar (≤4 series)" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 8 ;
                                    oc:textContent "**Color:** 2-3 colors max. Muted — navy, gray, one accent. Same color meanings throughout." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Typography** — set explicitly, don't rely on defaults:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Charts:**" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 7 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Enough cell padding that text doesn't touch borders" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Right-align numbers, left-align text" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Light gray header row, bold" ] ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "Same element type = same size throughout the deck" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Section headers: 18-20pt bold" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Table text: 14pt" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Body text: 14-16pt (never below 14pt)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Sources/footnotes: 14pt, gray" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Slide titles: 28-32pt bold" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Design" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 6 ;
                                    oc:tableCaption "### What's strict vs. flexible" ;
                                    oc:tableMarkdown """| Always | Case-by-case |
|---|---|
| Exact titles/sections when user specifies | Creative titles when they don't |
| Chart when user says chart; table when they say table | Visualization type when unspecified |
| Every competitor/data point they list | Number of competitors when unspecified |
| Exact values when specified | Rounding when precision unspecified |
| Titles fit without overflow | Number of competitor categories |
| No overlapping elements | Which dimensions to compare |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "What's strict vs. flexible" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Standards — apply throughout" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Do not create slides until the outline is approved.** Propose slide titles and one-line content notes, present them to the user, get a yes. A competitive deck is 10-20 slides of interlocking content — rebuilding because slide 4 was wrong is expensive. The outline is the cheap iteration point." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "When proposing the outline, `ask_user_question` works well for the structural decisions: which positioning visualization (2×2 matrix / radar / tier diagram — Step 5 below), how to group competitors (by business model / segment / posture — Step 4). These are taste calls the user likely has an opinion on." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Phase 2 — Outline, approve, then build" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """| Dimension | Company A | Company B | Company C |
|---|---|---|---|
| Scale | ●●● $160B | ●●○ $45B | ●○○ $8B |
| Growth | ●●○ +26% | ●●● +35% | ●●○ +22% |
| Margins | ●●○ 7.5% | ●○○ 3.2% | ●●● 15% |
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 213-219" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 8 ;
                            oc:sectionTitle "Step 7 — Comparative analysis" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "M&A transactions (multiples, rationale), partnership trends, capital raising patterns, regulatory developments. See `references/schemas.md` for the M&A transaction table format." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 9 ;
                            oc:sectionTitle "Step 8 — Strategic context" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "By posture — direct / adjacent / emerging" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "By segment — enterprise / SMB / consumer" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "By origin — incumbent / disruptor / new entrant" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "By business model — platform / vertical / horizontal" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Group by whichever lens fits (this is a good `ask_user_question` decision if the user hasn't specified):" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Step 4 — Competitor mapping" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "Multi-segment companies add a breakdown:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """| Metric | Value |
|---|---|
| Revenue | $4.96B |
| Growth | +26% YoY |
| Gross Margin | 45% |
| Profitability | $373M Adj. EBITDA |
| Customers | 134K |
| Retention | 92% |
| Market Share | ~15% |
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 139-149" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "*Note corporate costs if applicable" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """| Segment | Revenue | Rev YoY | Rev % | EBITDA | EBITDA YoY | Margin |
|---|---|---|---|---|---|---|
| Seg A | $25.1B | +26% | 57% | $6.5B | +31% | 26% |
| Seg B | $13.8B | +31% | 31% | $2.5B | +64% | 18% |
| Seg C | $5.1B | -2% | 12% | -$74M | -16% | -1% |
| Total | $44.0B | +18% | 100% | $6.5B* | - | 15% |
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 3 ;
                                    oc:sourceLocation "lines 153-160" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Step 3 — Target company profile" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "Before anything else: what 3-5 metrics does this industry actually run on? Use these consistently across every competitor." ;
                                    oc:tableMarkdown """| Industry | Key metrics |
|---|---|
| SaaS | ARR, NRR, CAC payback, LTV/CAC, Rule of 40 |
| Payments | GPV, take rate, attach rate, transaction margin |
| Marketplaces | GMV, take rate, buyer/seller ratio, repeat rate |
| Retail | Same-store sales, inventory turns, sales per sq ft |
| Logistics | Volume, cost per unit, on-time delivery %, capacity utilization |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Industry not listed — pick the metrics investors and operators benchmark on." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Before anything else: what 3-5 metrics does this industry actually run on? Use these consistently across every competitor." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Step 0 — Industry-defining metrics" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """| Scenario | Probability | Key driver |
|---|---|---|
| Bull | 30% | Market share gains, margin expansion |
| Base | 50% | Current trajectory continues |
| Bear | 20% | Competitive pressure, margin compression |
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 6 ;
                                    oc:sourceLocation "lines 243-249" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Current state vs. trajectory" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Structural vulnerabilities (hard to fix)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Durable advantages (hard to replicate) — map to moat categories" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**Moat assessment** — rate each competitor Strong / Moderate / Weak on:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "**For investment contexts** (skip if the Phase 1 scoping said no):" ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
