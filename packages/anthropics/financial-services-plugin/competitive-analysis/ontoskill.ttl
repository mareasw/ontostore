@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_financial_services_plugin_competitive_analysis a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "competitive-analysis" ;
    skos:broader "Deck-building framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/financial-services-plugin/competitive-analysis" ;
    oc:contentHash "48477c5cb31e828c06509bed3a4d8ba85958e90618ce246ad1165c84b1691614" ;
    oc:differentia "that produces competitive landscape presentations through a scoped two-phase process of requirements gathering, outline approval, and structured analysis workflow covering market context, competitor profiling, positioning visualization, comparative analysis, moat assessment, and strategic synthesis" ;
    oc:handlesFailure oc:DataNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "company name or industry to analyze, optional: competitor list, analysis depth, investment context" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Framework for building competitive landscape decks — market positioning, competitor deep-dives, comparative analysis, strategic synthesis. Use when the user asks for a competitive landscape, competitor analysis, peer comparison, market positioning assessment, strategic review, or investment memo deck. Also triggers on \"who are the competitors to X\", \"benchmark X against peers\", \"build a market map\", or any request to systematically evaluate competitive dynamics across an industry." ;
    oc:hasName "competitive-analysis" ;
    oc:impartsKnowledge oc:kn_05bf56c1,
        oc:kn_24bb3fea,
        oc:kn_4c58e8b4,
        oc:kn_bb0e7357,
        oc:kn_bd5417dd,
        oc:kn_c5d477d7,
        oc:kn_e4bf0052,
        oc:kn_f8db5e6d,
        oc:kn_ff8ee444 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "analyze competitors systematically",
        "assess competitive moats and strategic positioning",
        "benchmark company against peers",
        "build competitive landscape deck",
        "compare products and market positioning",
        "create market map",
        "generate investment thesis with bull/base/bear scenarios" ;
    oc:yieldsState oc:CompetitiveAnalysisComplete,
        oc:DocumentCreated .

oc:kn_05bf56c1 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When presenting any data in tables, charts, or profiles" ;
    oc:directiveContent "Ensure data comparability: same fiscal year for all competitors (flag exceptions), same metric definitions, convert to USD with exchange rate noted, show missing data as '-' or 'N/A' with '[E]' for estimates, and cite every number as '[Company] [Document] ([Date])'." ;
    oc:hasRationale "Inconsistent fiscal periods, currencies, or metric definitions make comparisons misleading; explicit citations enable verification." ;
    oc:severityLevel "HIGH" .

oc:kn_24bb3fea a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When extracting and presenting any numerical data" ;
    oc:directiveContent "Use source-file values exactly as given — never recalculate or re-round numbers. When sources conflict, prioritize: 10-Ks/annual reports > earnings calls/investor presentations > sell-side research > industry reports > news." ;
    oc:hasRationale "Source-file fidelity and a clear citation hierarchy ensure data integrity and auditability across the deck." ;
    oc:severityLevel "HIGH" .

oc:kn_4c58e8b4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Step 5 — when creating the positioning visualization slide" ;
    oc:directiveContent "Choose the positioning visualization based on context: 2×2 matrix for two dominant factors, radar/spider for multi-factor comparison, tier diagram for strategic group clustering, value chain map for vertical industries, ecosystem map for platform markets." ;
    oc:hasRationale "Each visualization type reveals different competitive dynamics; using the wrong one obscures the insight rather than illuminating it." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bb0e7357 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "Before delivering the final deck" ;
    oc:directiveContent "Run a quality checklist before finishing: verify prompt fidelity (exact titles, chart/table types, all data points), data consistency (same metric = same value across slides, source precision), layout (no overflow, no overlaps), and content (every number cited, same fiscal period, insight titles, real chart objects)." ;
    oc:hasRationale "A competitive deck's credibility hinges on consistency — a single mismatched number or missing citation can undermine the entire analysis." ;
    oc:severityLevel "HIGH" .

oc:kn_bd5417dd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Throughout the entire deck-building process" ;
    oc:directiveContent "Treat all user specifications as hard requirements, not suggestions: exact slide titles and section names, chart vs. table distinction, complete data series with all listed competitors/years, and exact values and ratios." ;
    oc:hasRationale "Users specify things precisely for a reason — swapping 'Overview and Competitive Scope' for 'FY2024 Competitive Landscape' or using a table when they asked for a chart violates their intent and reduces trust." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c5d477d7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Step 0 — before starting any competitor profiling" ;
    oc:directiveContent "Identify the 3-5 industry-defining metrics before any analysis. Use these consistently across every competitor throughout the deck (e.g., SaaS: ARR, NRR, CAC payback, LTV/CAC, Rule of 40)." ;
    oc:hasRationale "Industry metrics anchor all comparisons; inconsistency across slides undermines the entire analysis and makes cross-competitor comparison meaningless." ;
    oc:severityLevel "HIGH" .

oc:kn_e4bf0052 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Phase 1 scoping before any research or slide creation" ;
    oc:directiveContent "Always scope the analysis before starting research by asking about: scope (single target vs. multi-company), competitor set, audience depth, and investment context. Use ask_user_question with up to 4 questions in one round." ;
    oc:hasRationale "Competitive analysis means different things to different people — a 20-slide peer benchmarking deck and a 5-slide market map are both 'competitive analysis' and take completely different shapes." ;
    oc:severityLevel "HIGH" .

oc:kn_f8db5e6d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before building any slides in Phase 2" ;
    oc:directiveContent "Never create slides until the user has approved the outline. Propose slide titles with one-line content notes first, get explicit approval, then build." ;
    oc:hasRationale "A competitive deck is 10-20 slides of interlocking content — rebuilding because a slide was wrong is expensive. The outline is the cheap iteration point." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ff8ee444 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing every slide in the deck" ;
    oc:directiveContent "Slide titles must be insight statements, not labels (e.g., 'Scale leaders pulling away from niche players' not 'Competitive Analysis'). Use 2-3 muted colors max, real chart objects not formatted tables, and consistent typography (titles 28-32pt bold, body 14-16pt, never below 14pt)." ;
    oc:hasRationale "Insight-driven titles communicate findings immediately; consistent typography and restrained color palettes maintain professional credibility across 10-20 slides." ;
    oc:severityLevel "MEDIUM" .

