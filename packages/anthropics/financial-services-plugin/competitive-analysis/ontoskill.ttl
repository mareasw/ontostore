                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent """Correct: "Embedded payments is $80-100B in 2024, growing 20-25% CAGR (McKinsey 2024)"
Wrong: "The market is large and growing rapidly\"""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Step 1 — Market context" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
