                                    oc:contentOrder 2 ;
                                    oc:textContent "**Metrics:**" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """| Category | Assessment |
|---|---|
| Business | What they do (1 sentence) |
| Strengths | 2-3 bullets |
| Weaknesses | 2-3 bullets |
| Strategy | Current priorities |
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 5 ;
                                    oc:sourceLocation "lines 202-209" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Qualitative:**" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
