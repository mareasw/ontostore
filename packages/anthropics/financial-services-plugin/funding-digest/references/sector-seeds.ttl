    oc:impartsKnowledge oc:kn_1ab2f396,
        oc:kn_4d4a0aa7,
        oc:kn_d5f22b80,
        oc:kn_dd8e4437,
        oc:kn_e9d08bd9,
        oc:kn_f5ceee7c ;
    oc:isUserInvocable false ;
    oc:nature "Reference" ;
    oc:resolvesIntent "bootstrap company list for funding research",
        "find seed companies for a sector",
        "get company universe for sector analysis",
        "look up S&P Global identifier aliases" .

oc:kn_1ab2f396 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user specifies a sector not covered by the seed lists" ;
    oc:directiveContent "For niche sub-sectors not listed in the seed tables, ask the user for 2-3 example companies to use as seeds instead of guessing." ;
    oc:hasRationale "Prevents hallucinating irrelevant companies and ensures the user's domain knowledge guides the universe" ;
    oc:severityLevel "HIGH" .

oc:kn_4d4a0aa7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting seed companies for any sector" ;
    oc:directiveContent "Never use excluded companies as seeds (e.g., Inflection AI, Adept AI, DeepMind as subsidiaries; Convoy as shut down; BeReal as acquired; Lemon8 brand resolving to wrong entity). These will resolve but return zero or misleading funding data." ;
    oc:hasRationale "Acquired/subsidiary companies have no independent funding rounds; shut-down companies have no new activity; Lemon8 resolves to an unrelated Dutch company in S&P Global" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d5f22b80 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using any sector seed list" ;
    oc:directiveContent "Always expand seed lists via get_competitors_from_identifiers and validate with get_info_from_identifiers. Seeds are starting points, not exhaustive lists." ;
    oc:hasRationale "Seed lists are incomplete and skew toward US-based companies; competitor expansion ensures broader coverage" ;
    oc:severityLevel "HIGH" .

oc:kn_dd8e4437 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "Periodic maintenance of seed company lists" ;
    oc:directiveContent "Seed lists should be reviewed quarterly. AI sector seeds change rapidly due to acquisitions and new entrants. Companies may pivot, merge, or shut down between reviews." ;
    oc:hasRationale "Startup ecosystems evolve quickly; stale seeds waste API calls on dead/acquired companies" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e9d08bd9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a seed company name returns empty results" ;
    oc:directiveContent "When a brand name fails to resolve in get_info_from_identifiers, try the S&P Global legal entity alias. If that fails, use the company_id directly. If that also fails, the company may not be indexed yet." ;
    oc:hasRationale "S&P Global indexes legal entity names, not brand names, so aliases are needed for resolution" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f5ceee7c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating seed companies before funding analysis" ;
    oc:directiveContent "Seeds marked as subsidiaries or acquired will still resolve in get_info_from_identifiers (status = 'Operating Subsidiary') but will return zero funding rounds. Skip these for funding queries." ;
    oc:hasRationale "Including subsidiaries in funding queries produces empty results and wastes processing" ;
    oc:severityLevel "HIGH" .

