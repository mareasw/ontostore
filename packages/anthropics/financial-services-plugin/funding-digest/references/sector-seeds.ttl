                                    oc:textContent "Seeds: Figure AI, Agility Robotics, Locus Robotics, Symbotic, Covariant" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 20 ;
                            oc:sectionTitle "Robotics / Automation" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 18 ;
                    oc:sectionTitle "Industrials / Logistics" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 3 ;
                            oc:quoteContent "**Tip:** When a brand name fails, try `get_info_from_identifiers` with the legal name. If that also fails, the company may not be indexed yet. As a last resort, use the `company_id` directly as the identifier." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Some well-known brand names don't match S&P Global's legal entity names. If a brand name returns empty results from `get_info_from_identifiers`, try the alias:" ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 5 ;
                            oc:tableCaption "Some well-known brand names don't match S&P Global's legal entity names. If a brand name returns empty results from `get_info_from_identifiers`, try the alias" ;
                            oc:tableMarkdown """| Brand Name | S&P Global Legal Name | company_id |
|---|---|---|
| Together AI | Together Computer, Inc. | C_1860042219 |
| Character.ai | Character Technologies, Inc. | C_1829047235 |
| Runway ML | Runway AI, Inc. | C_633706980 |
| Adept AI | Adept AI Labs Inc. | C_1780739313 |
| xAI | X.AI LLC | C_1863863313 |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 22 ;
                    oc:sectionTitle "Identifier Alias Reference" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "*Temu (PDD Holdings)* — PDD Holdings is a massive public conglomerate; its funding activity is captured via equity markets, not venture rounds." ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "⚠️ **Excluded (do not use as seeds):**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Seeds: Shopify, Faire, Whatnot, Fanatics" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 16 ;
                            oc:sectionTitle "E-Commerce / Marketplace" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Seeds: Discord, Reddit, Substack" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "*Lemon8* — The brand name \"Lemon8\" resolves in S&P Global to a small Dutch company (Lemon8 B.V.), **not** the ByteDance social media app. ByteDance's apps are subsidiaries and do not have independent funding rounds. Do not use." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "*BeReal* — Acquired by Voodoo (Jun 2024). Now a subsidiary." ] ],
                                [ a oc:Paragraph ;
