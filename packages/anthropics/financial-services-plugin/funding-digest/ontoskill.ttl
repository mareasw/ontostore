                                                    oc:itemOrder 4 ;
                                                    oc:itemText "Never apply color to backgrounds, accent bars, decorative shapes, or section dividers." ] ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 2 ;
                                            oc:textContent "**Color palette — Monochrome Executive:**" ],
