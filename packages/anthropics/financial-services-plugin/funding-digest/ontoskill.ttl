                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Title: 28–32pt, bold, white on near-black header bar" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "Table text: 9–11pt, near-black with gray (`6B6B6B`) for secondary columns" ],
                                                [ a oc:BulletItem ;
