                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Deal links use muted blue (`2B5797`) — this is the only non-monochrome text color besides semantic red/green." ],
                                                [ a oc:BulletItem ;
