                                                    oc:itemOrder 7 ;
                                                    oc:itemText "Link text: `2B5797` (muted blue) — Capital IQ deal links in the table (the only blue on the slide)" ] ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 9 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
