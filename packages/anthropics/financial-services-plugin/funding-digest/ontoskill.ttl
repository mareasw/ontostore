                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "When in doubt, leave it gray." ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Company logos are the only \"full color\" elements on the slide — they appear as-is from the source." ],
                                                [ a oc:BulletItem ;
