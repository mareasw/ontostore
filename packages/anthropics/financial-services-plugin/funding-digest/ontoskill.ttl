""" ;
                                            oc:codeLanguage "bash" ;
                                            oc:contentOrder 2 ;
                                            oc:sourceLocation "lines 223-225" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "The `simple-icons` package bundles high-quality SVG icons for thousands of well-known brands. It works entirely offline — no API keys, no network calls. Install it alongside `sharp` for SVG → PNG conversion:" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 19 ;
                                    oc:sectionTitle "Tier 1: `simple-icons` npm Package (3,300+ Brand SVGs, No Network Required)" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "For companies not found in `simple-icons`, generate a clean initial-based logo as a PNG:" ],
                                        [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """async function generateInitialLogo(companyName, outputPath) {
    const initial = companyName.charAt(0).toUpperCase();
    const svg = `
    <svg width="128" height="128" xmlns="http://www.w3.org/2000/svg">
        <circle cx="64" cy="64" r="64" fill="#BDBDBD"/>
        <text x="64" y="64" font-family="Arial, Helvetica, sans-serif"
              font-size="56" font-weight="bold" fill="#FFFFFF"
              text-anchor="middle" dominant-baseline="central">${initial}</text>
    </svg>`;
    await sharp(Buffer.from(svg)).png().toFile(outputPath);
}
""" ;
