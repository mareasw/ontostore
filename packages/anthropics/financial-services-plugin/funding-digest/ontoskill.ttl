                                            oc:textContent "**General color rules (enforce strictly):**" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 14 ;
                                            oc:textContent """**Table Centering (pptxgenjs):**
Always center the deal table on the slide. Calculate the x position dynamically:""" ],
