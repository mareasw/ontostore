                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 3 ;
                    oc:itemText "Any other status (e.g., closed, inactive) → The company is no longer operating. Historical data may exist but no new activity." ] ] ;
