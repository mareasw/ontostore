                                                    oc:itemOrder 7 ;
                                                    oc:itemText "Footer: 8pt, medium gray" ] ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 8 ;
                                            oc:textContent "**Key Takeaways (middle section):**" ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 7 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "4 key metrics as large-number callouts: Total Raised, # Rounds, Avg Pre-Money Valuation, Largest Round" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Each in a card with `F5F5F5` fill and a thin `D0D0D0` border — no shadow, no color fills" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "If a stat is surprising or extreme (e.g., 3x normal volume, a record deal), a small colored dot or underline may be placed next to that single number — otherwise keep fully monochrome" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "If pre-money valuations are mostly undisclosed, substitute with a different metric (e.g., Median Round Size, # New Unicorns)" ] ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 10 ;
                                            oc:textContent "**Top Deals Table (bottom section):**" ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 18 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Small text in medium gray: \"Deal Flow Digest · [Period] · Sources: S&P Global Capital IQ · Generated [Date]\"" ] ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 12 ;
                                            oc:textContent """**Deal Link Implementation (pptxgenjs):**
In pptxgenjs, hyperlinks are added to table cells using the `options.hyperlink` property on the cell object:""" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**Color philosophy: Minimal, monochrome-first.** The slide should feel like a high-end financial brief — black, white, and gray dominate. Color is used **only** where it carries meaning (e.g., a red indicator for a down round, a green indicator for a standout metric) or where the reader would naturally expect it (company logos). Never use color for purely decorative purposes like background fills, accent bars, or gradient effects." ],
                                        [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """// Table cell with Capital IQ deal link
{
  text: "View →",
  options: {
    hyperlink: {
      url: `https://www.capitaliq.spglobal.com/web/client?#offering/capitalOfferingProfile?id=${transactionId}`
    },
    color: "2B5797",
    fontSize: 9,
    fontFace: "Arial"
  }
}
""" ;
                                            oc:codeLanguage "javascript" ;
                                            oc:contentOrder 13 ;
                                            oc:sourceLocation "lines 402-415" ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 3 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 6 ;
                                                    oc:itemText "Card backgrounds: `F5F5F5` (off-white / very light gray) — stat card fills, alternating table rows" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "Primary text: `1A1A1A` (near-black) — all body text, stat numbers, takeaways" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "Borders & dividers: `D0D0D0` (light gray) — subtle structural lines, card outlines, table borders" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "Secondary text: `6B6B6B` (medium gray) — labels, captions, footer, date stamps" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:hasChild [ a oc:BulletList ;
                                                            oc:blockType "bullet_list" ;
                                                            oc:contentOrder 1 ;
                                                            oc:hasItem [ a oc:BulletItem ;
                                                                    oc:blockType "bullet_item" ;
                                                                    oc:itemOrder 2 ;
                                                                    oc:itemText "Standout positive metrics (new unicorn, outsized round): `2E7D32` (muted green) — same minimal usage: a dot, a small tag, or a single highlighted number" ],
                                                                [ a oc:BulletItem ;
                                                                    oc:blockType "bullet_item" ;
                                                                    oc:itemOrder 3 ;
                                                                    oc:itemText "If no data points warrant a color indicator, **use no color at all**. A fully monochrome slide is perfectly correct." ],
                                                                [ a oc:BulletItem ;
                                                                    oc:blockType "bullet_item" ;
                                                                    oc:itemOrder 1 ;
                                                                    oc:itemText "Down rounds or negative signals: `C0392B` (muted red) — use only as a small dot, tag, or single-word highlight, never as a fill or background" ] ] ;
                                                    oc:itemOrder 8 ;
                                                    oc:itemText "**Semantic color (sparingly):**" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Header bar: `1A1A1A` (near-black) — strong contrast for the title region" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Primary background: `FFFFFF` (white) — clean, open slide background" ],
                                                [ a oc:BulletItem ;
