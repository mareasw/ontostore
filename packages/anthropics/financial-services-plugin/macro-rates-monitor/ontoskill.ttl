oc:skill_financial_services_plugin_macro_rates_monitor a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "macro-rates-monitor" ;
    skos:broader "dashboard generator" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/macro-rates-monitor" ;
    oc:contentHash "4046475a97a8017525f024852d3c9027f9eca822d741e43a210467b2eef4a962" ;
    oc:differentia "combines macro indicators, yield curves, inflation breakevens, and swap rates from MCP tools into a coherent macro-rates regime assessment" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasArgumentHint "country or region (e.g., US, Eurozone, UK)" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Build macroeconomic and rates dashboards combining macro indicators, yield curves, inflation breakevens, and swap rates. Use when monitoring macro conditions, analyzing yield curve shape, decomposing real vs nominal rates, assessing policy rate expectations, or evaluating financial conditions." ;
    oc:hasName "macro-rates-monitor" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: macro-rates-monitor
description: Build macroeconomic and rates dashboards combining macro indicators, yield curves, inflation breakevens, and swap rates. Use when monitoring macro conditions, analyzing yield curve shape, decomposing real vs nominal rates, assessing policy rate expectations, or evaluating financial conditions.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "You are an expert macro strategist and rates analyst. Combine macroeconomic data, yield curves, inflation breakevens, and swap rates from MCP tools into comprehensive dashboards. Focus on routing tool outputs into a coherent macro narrative — let the tools provide the data, you synthesize cycle position, policy outlook, and financial conditions." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Macro analysis synthesizes multiple indicators into a narrative. Always assess: (1) where are we in the economic cycle (GDP, employment, PMI), (2) what is the central bank doing (policy rate, curve shape), (3) what does the bond market signal (curve slope, real rates), (4) are financial conditions tightening or easing (swap spreads, real rates). Start broad, drill down." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Principles" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_7c5a0adfbdffb679 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Tool Chaining Workflow" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "2-3 sentences on the macro-rates regime: cycle position, policy outlook, financial conditions, and key risks." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Overall Assessment" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Present yields at key tenors (3M, 2Y, 5Y, 10Y, 30Y). Highlight 2s10s and 3M-10Y slopes. Note curve shape: normal / flat / inverted / humped." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Yield Curve Snapshot" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Macro Summary" ;
                                    oc:tableMarkdown """| Indicator | Current | Prior | Direction | Signal |
|-----------|---------|-------|-----------|--------|
| GDP Growth | ...% | ...% | ... | Expansion/Contraction |
| Core Inflation (YoY) | ...% | ...% | ... | Above/At/Below target |
| Unemployment | ...% | ...% | ... | Tight/Balanced/Slack |
| PMI Manufacturing | ... | ... | ... | Expansion/Contraction |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Macro Summary" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "### Swap Spread Table" ;
                                    oc:tableMarkdown """| Tenor | Swap Rate | Govt Yield | Swap Spread (bp) | Signal |
|-------|-----------|------------|-------------------|--------|
| 2Y | ... | ... | ... | Normal/Elevated/Stressed |
| 5Y | ... | ... | ... | Normal/Elevated/Stressed |
| 10Y | ... | ... | ... | Normal/Elevated/Stressed |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Swap Spread Table" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 2 ;
                                    oc:tableCaption "### Real Rate Decomposition" ;
                                    oc:tableMarkdown """| Tenor | Nominal | Breakeven | Real Rate | Signal |
|-------|---------|-----------|-----------|--------|
| 5Y | ...% | ...% | ...% | Accommodative/Restrictive |
| 10Y | ...% | ...% | ...% | Accommodative/Restrictive |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Real Rate Decomposition" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Output Format" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**`ir_swap`** — Swap rates by tenor and currency. Two-phase: list templates then price. Use to compute swap spreads." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**`tscc_historical_pricing_summaries`** — Historical pricing data. Use for historical yield context and trend analysis." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**`interest_rate_curve`** — Government yield curves and swap curves. Two-phase: list then calculate. Use for curve shape and slope analysis." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**`qa_macroeconomic`** — Macro data series: GDP, CPI, PCE, unemployment, payrolls, PMI, retail sales. Multiple countries and frequencies. Search by mnemonic pattern or description." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**`inflation_curve`** — Inflation breakeven curves and real yields. Two-phase: search then calculate. Use for real rate decomposition." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Available MCP Tools" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "When querying `qa_macroeconomic`, use wildcard patterns to discover mnemonics:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Prefer seasonally adjusted series. Monthly for most indicators; GDP is quarterly." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Eurozone: \"EZ\\*GDP\\*\", \"EZ\\*HICP\\*\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "US: \"US\\*GDP\\*\", \"US\\*CPI\\*\", \"US\\*PCE\\*\", \"US\\*UNEMP\\*\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "UK: \"UK\\*GDP\\*\", \"UK\\*CPI\\*\"" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Macro Search Patterns" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Macroeconomic and Rates Monitor" ] ;
    oc:hasWorkflow _:ref_7c5a0adfbdffb679,
        [ a oc:Workflow ;
            dcterms:description "Sequential data-gathering and synthesis workflow combining macro indicators, yield curves, inflation breakevens, swap spreads, and historical context into a unified dashboard." ;
            oc:hasStep _:ref_35c0b8c7ebe7f365,
                _:ref_39d35b45a83ccf7a,
                _:ref_5f3746c437a96889,
                [ a oc:WorkflowStep ;
                    dcterms:description "Combine all data into dashboard with cycle position, curve signals, real rate regime, financial conditions, and overall assessment" ;
                    oc:expectedOutcome "Complete macro-rates dashboard with all sections populated" ;
                    oc:stepDependsOn _:ref_35c0b8c7ebe7f365,
                        _:ref_39d35b45a83ccf7a,
                        _:ref_5f3746c437a96889,
                        _:ref_ec176cc3de373e9e,
                        _:ref_f4a5b4d63c924236 ;
                    oc:stepId "synthesize" ],
                _:ref_ec176cc3de373e9e,
                _:ref_f4a5b4d63c924236 ;
            oc:workflowId "macro-rates-dashboard" ;
            oc:workflowName "Build Macro-Rates Dashboard" ] ;
    oc:impartsKnowledge oc:kn_0415794c,
        oc:kn_1de86f9c,
        oc:kn_350e13c5,
        oc:kn_64a949a6,
        oc:kn_774d0e55,
        oc:kn_bf047313,
        oc:kn_bf62019e ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "analyze yield curve shape",
        "assess policy rate expectations",
        "build macro rates dashboard",
        "decompose real vs nominal rates",
        "evaluate financial conditions",
        "monitor macro conditions" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0415794c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When searching for macro data series" ;
    oc:directiveContent "When querying qa_macroeconomic, use wildcard mnemonic patterns (e.g., 'US*GDP*', 'EZ*HICP*'). Prefer seasonally adjusted series. Use monthly frequency for most indicators; GDP is quarterly." ;
    oc:hasRationale "Mnemonic wildcards are required by the tool API; seasonal adjustment and correct frequency ensure data comparability" .

oc:kn_1de86f9c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "always" ;
    oc:directiveContent "Let the MCP tools provide the data; the agent's role is to synthesize tool outputs into a coherent macro narrative covering cycle position, policy outlook, and financial conditions." ;
    oc:hasRationale "Prevents the agent from fabricating or hallucinating data points; all numbers must come from tool calls" .

oc:kn_350e13c5 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating the final dashboard output" ;
    oc:directiveContent """## Macro Summary
| Indicator | Current | Prior | Direction | Signal |
## Yield Curve Snapshot
Tenors: 3M, 2Y, 5Y, 10Y, 30Y. Slopes: 2s10s, 3M-10Y. Shape: normal/flat/inverted/humped.
## Real Rate Decomposition
| Tenor | Nominal | Breakeven | Real Rate | Signal | (Accommodative/Restrictive)
## Swap Spread Table
| Tenor | Swap Rate | Govt Yield | Swap Spread (bp) | Signal | (Normal/Elevated/Stressed)
## Overall Assessment
2-3 sentences: cycle position, policy outlook, financial conditions, key risks.""" ;
    oc:templateVariables "Breakeven",
        "Current",
        "Direction",
        "Govt Yield",
        "Indicator",
        "Nominal",
        "Prior",
        "Real Rate",
        "Signal",
        "Swap Rate",
        "Swap Spread",
        "Tenor" .

oc:kn_64a949a6 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When calling curve and swap tools" ;
    oc:directiveContent "interest_rate_curve, inflation_curve, and ir_swap each require a two-phase call pattern (list/search first, then calculate/price). Skipping the first phase will cause failures." ;
    oc:hasRationale "The tools are designed with a discovery-then-execution pattern; attempting direct calculation without listing first will error" ;
    oc:severityLevel "HIGH" .

oc:kn_774d0e55 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing macro narrative" ;
    oc:directiveContent "Always assess four dimensions: (1) cycle position via GDP/employment/PMI, (2) central bank stance via policy rate/curve shape, (3) bond market signal via curve slope/real rates, (4) financial conditions via swap spreads/real rates. Start broad, drill down." ;
    oc:hasRationale "These four dimensions capture the essential macro-rates feedback loop and prevent myopic single-indicator analysis" .

oc:kn_bf047313 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When querying qa_macroeconomic for specific regions" ;
    oc:directiveContent "US: \"US*GDP*\", \"US*CPI*\", \"US*PCE*\", \"US*UNEMP*\" | Eurozone: \"EZ*GDP*\", \"EZ*HICP*\" | UK: \"UK*GDP*\", \"UK*CPI*\"" ;
    oc:hasRationale "Provides the exact wildcard patterns needed for each major region to discover available mnemonics" .

oc:kn_bf62019e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "always" ;
    oc:directiveContent "1. Pull macro indicators (GDP, CPI/PCE, unemployment, PMI) via qa_macroeconomic. 2. Snapshot yield curve via interest_rate_curve (list → calculate), compute 2s10s and 3M-10Y slopes. 3. Decompose inflation via inflation_curve (search → calculate), compute real rates = nominal − breakeven. 4. Price swaps via ir_swap (list → price) at 2Y/5Y/10Y, compute swap spreads. 5. Get historical context via tscc_historical_pricing_summaries. 6. Synthesize into dashboard with cycle position, curve signals, real rate regime, financial conditions." ;
    oc:hasRationale "Ensures all five data dimensions are covered before synthesis, preventing incomplete analysis" ;
    oc:stepOrder 1 .

_:ref_00bd2b11a18e5aa2 a oc:WorkflowStep ;
    dcterms:description "**Swap Spreads:** Call `ir_swap` (list then price) at 2Y, 5Y, 10Y. Compute swap spread = swap rate minus government yield at each tenor. Assess financial conditions." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_0f28a18bc92b11dd a oc:WorkflowStep ;
    dcterms:description "**Historical Context:** Call `tscc_historical_pricing_summaries` for the benchmark yield (e.g., 10Y). Assess where current yields sit vs recent history." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_220e0eee64da748a a oc:WorkflowStep ;
    dcterms:description "**Yield Curve Snapshot:** Call `interest_rate_curve` (list then calculate) for the government curve. Extract yields at standard tenors. Compute 2s10s and 3M-10Y slopes. Classify curve shape." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_2d57f30958e8c963 a oc:WorkflowStep ;
    dcterms:description "**Synthesize:** Combine into a dashboard: cycle position, curve signals, real rate regime, financial conditions, and overall assessment." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_3ddaf8b55b07098b a oc:WorkflowStep ;
    dcterms:description "**Inflation Decomposition:** Call `inflation_curve` (search then calculate). Compute real rates = nominal minus breakeven at each tenor. Assess whether real rates are accommodative or restrictive." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_f5a250c66e474eb3 a oc:WorkflowStep ;
    dcterms:description "**Pull Macro Indicators:** Call `qa_macroeconomic` for GDP, CPI/PCE, unemployment, and PMI for the target country. Retrieve latest values and recent series." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_35c0b8c7ebe7f365 a oc:WorkflowStep ;
    dcterms:description "Pull macro indicators (GDP, CPI/PCE, unemployment, PMI) via qa_macroeconomic for target country" ;
    oc:expectedOutcome "Current and prior values for key macro indicators with directional signals" ;
    oc:stepId "pull-macro" .

_:ref_39d35b45a83ccf7a a oc:WorkflowStep ;
    dcterms:description "Retrieve historical pricing via tscc_historical_pricing_summaries for benchmark yield" ;
    oc:expectedOutcome "Context on where current yields sit relative to recent history" ;
    oc:stepId "historical-context" .

_:ref_7c5a0adfbdffb679 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_00bd2b11a18e5aa2,
        _:ref_0f28a18bc92b11dd,
        _:ref_220e0eee64da748a,
        _:ref_2d57f30958e8c963,
        _:ref_3ddaf8b55b07098b,
        _:ref_f5a250c66e474eb3 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_ec176cc3de373e9e a oc:WorkflowStep ;
    dcterms:description "Decompose inflation via inflation_curve (search then calculate), compute real rates at each tenor" ;
    oc:expectedOutcome "Real rate decomposition showing accommodative vs restrictive stance" ;
    oc:stepDependsOn _:ref_5f3746c437a96889 ;
    oc:stepId "inflation-decomp" .

_:ref_f4a5b4d63c924236 a oc:WorkflowStep ;
    dcterms:description "Price swaps via ir_swap (list then price) at 2Y, 5Y, 10Y and compute swap spreads" ;
    oc:expectedOutcome "Swap spread table with financial conditions assessment" ;
    oc:stepDependsOn _:ref_5f3746c437a96889 ;
    oc:stepId "swap-spreads" .

_:ref_5f3746c437a96889 a oc:WorkflowStep ;
    dcterms:description "Snapshot government yield curve via interest_rate_curve (list then calculate), compute 2s10s and 3M-10Y slopes, classify shape" ;
    oc:expectedOutcome "Yields at standard tenors with slope metrics and curve shape classification" ;
    oc:stepId "yield-curve" .

