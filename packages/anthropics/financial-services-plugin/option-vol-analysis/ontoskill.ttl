@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_financial_services_plugin_option_vol_analysis a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "option-vol-analysis" ;
    skos:broader "Derivatives analysis skill" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/financial-services-plugin/option-vol-analysis" ;
    oc:contentHash "324dfa767c633d5b45068ef1ec82f2d161a7fc7576b0d71c7b5317617a8119a5" ;
    oc:differentia "combines implied vol surface data, option pricing with Greeks, and historical price data to assess implied vs realized volatility and recommend trading strategies" ;
    oc:handlesFailure oc:DataUnavailable,
        oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Analyze option volatility by combining vol surface data, option pricing with Greeks, and historical price data to assess implied vs realized volatility. Use when pricing options, analyzing volatility surfaces, computing Greeks, assessing vol premiums, or evaluating vol trading strategies." ;
    oc:hasName "option-vol-analysis" ;
    oc:hasRequirement oc:req_22928740,
        oc:req_5aae26a7 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: option-vol-analysis
description: Analyze option volatility by combining vol surface data, option pricing with Greeks, and historical price data to assess implied vs realized volatility. Use when pricing options, analyzing volatility surfaces, computing Greeks, assessing vol premiums, or evaluating vol trading strategies.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "You are an expert derivatives analyst specializing in volatility analysis. Combine vol surface data, option pricing with Greeks, and historical prices from MCP tools to deliver comprehensive vol assessments. Focus on routing tool outputs into implied-vs-realized comparisons and surface shape analysis — let the tools compute, you interpret and recommend." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**`fx_vol_surface`** — Implied vol surface for FX pairs. Input: currency pair (e.g., \"EURUSD\"). Returns vol by delta and expiry. FX surfaces are quoted in delta space." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**`equity_vol_surface`** — Implied vol surface for equities/indices. Input: RIC (e.g., \".SPX@RIC\") or RICROOT (e.g., \"ES@RICROOT\"). Returns vol by strike/delta and expiry." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**`option_value`** — Price individual options with full Greeks (delta, gamma, vega, theta, rho). Use after identifying specific strikes from the vol surface." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**`qa_historical_equity_price`** — Historical equity prices. Alternative source for realized vol computation." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**`tscc_historical_pricing_summaries`** — Historical OHLC data. Use to compute realized vol from price history." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**`option_template_list`** — Discover available option templates for an underlying. Use to find valid expiries and strikes before pricing." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Available MCP Tools" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Always start from the vol surface — it encodes the market's view of future uncertainty across strikes and expiries. Individual option prices are derived from this surface. Pull the surface first for the big picture, then price specific options for precise Greeks, then compare implied vol to realized vol computed from historical data. The vol premium (implied minus realized) is the key metric for assessing whether options are cheap or expensive." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Principles" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_e68233d7abfd58df ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Tool Chaining Workflow" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Vol Surface Summary" ;
                                    oc:tableMarkdown """| Tenor | ATM Vol | 25d RR | 25d BF |
|-------|---------|--------|--------|
| 1M | ... | ... | ... |
| 3M | ... | ... | ... |
| 6M | ... | ... | ... |
| 1Y | ... | ... | ... |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Vol Surface Summary" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 6 ;
                                    oc:tableCaption "### Greeks Table" ;
                                    oc:tableMarkdown """| Greek | Call | Put |
|-------|------|-----|
| Premium | ... | ... |
| Delta | ... | ... |
| Gamma | ... | ... |
| Vega | ... | ... |
| Theta | ... | ... |
| Implied Vol | ... | ... |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Greeks Table" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "State the vol regime (low/normal/elevated/crisis), whether implied is rich or cheap vs realized, surface shape signals (skew direction, term structure shape), and recommended strategies with key Greeks and rationale." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Assessment" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "### Implied vs Realized Comparison" ;
                                    oc:tableMarkdown """| Window | Realized Vol | Implied Vol (matching tenor) | Premium (IV - RV) | Signal |
|--------|-------------|------------------------------|--------------------|---------|
| 20d | ... | 1M ATM | ... | Rich/Cheap |
| 60d | ... | 3M ATM | ... | Rich/Cheap |
| 90d | ... | 6M ATM | ... | Rich/Cheap |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Implied vs Realized Comparison" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Output Format" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Option Volatility Analysis" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Sequential tool-chaining workflow to deliver a comprehensive volatility assessment" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Combine surface shape, Greeks, and implied-vs-realized comparison into a vol assessment with strategy recommendations. State vol regime, rich/cheap signal, surface shape signals, and recommended strategies." ;
                    oc:expectedOutcome "Comprehensive vol assessment with trading recommendations" ;
                    oc:stepDependsOn _:ref_44072bb842e40b3f,
                        _:ref_810de6c42197fa03,
                        _:ref_92b2af9be721cedc ;
                    oc:stepId "synthesis" ],
                _:ref_2a37be134572228f,
                _:ref_3325da475248057a,
                _:ref_44072bb842e40b3f,
                _:ref_810de6c42197fa03,
                _:ref_92b2af9be721cedc ;
            oc:workflowId "vol-analysis" ;
            oc:workflowName "Option Volatility Analysis Workflow" ],
        _:ref_e68233d7abfd58df ;
    oc:impartsKnowledge oc:kn_22060b3e,
        oc:kn_54f9f451,
        oc:kn_7c2f0ac8,
        oc:kn_eb71e539,
        oc:kn_ee95e86e ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "analyze option volatility",
        "analyze volatility surface shape and skew",
        "assess vol premium (implied vs realized)",
        "compute realized volatility from historical prices",
        "evaluate vol trading strategies",
        "price options with Greeks" ;
    oc:yieldsState oc:VolatilityAnalysisComplete .

oc:kn_22060b3e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating option pricing and trading opportunities" ;
    oc:directiveContent "The vol premium (implied minus realized) is the key metric for assessing whether options are cheap or expensive." ;
    oc:hasRationale "Vol premium directly quantifies the market's expectation premium over actual realized movement, indicating potential over- or under-pricing." ;
    oc:severityLevel "HIGH" .

oc:kn_54f9f451 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling vol surface tools" ;
    oc:directiveContent "FX vol surfaces are quoted in delta space, not strike space. Use fx_vol_surface for FX pairs (input: currency pair like 'EURUSD') and equity_vol_surface for equities/indices (input: RIC like '.SPX@RIC' or RICROOT like 'ES@RICROOT')." ;
    oc:hasRationale "Using the wrong surface tool or input format will return errors or incorrect data." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7c2f0ac8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When computing realized volatility for comparison" ;
    oc:directiveContent "Compute realized vol over 20-day, 60-day, and 90-day windows from historical prices, then compare to matching implied vol tenors (1M, 3M, 6M respectively)." ;
    oc:hasRationale "Matching windows to tenors ensures apples-to-apples comparison between implied and realized volatility." ;
    oc:severityLevel "MEDIUM" .

oc:kn_eb71e539 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Always — this is the mandatory analysis sequence" ;
    oc:directiveContent "Follow the tool chain: vol surface snapshot → template discovery → option pricing → historical data → realized vol computation → synthesis." ;
    oc:hasRationale "Each step produces inputs needed by subsequent steps; out-of-order execution will miss dependencies." ;
    oc:severityLevel "HIGH" .

oc:kn_ee95e86e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning any option volatility analysis" ;
    oc:directiveContent "Always start from the vol surface — it encodes the market's view of future uncertainty across strikes and expiries. Pull the surface first for the big picture, then price specific options for precise Greeks, then compare implied vol to realized vol." ;
    oc:hasRationale "Individual option prices are derived from the surface; starting with the surface provides context for interpreting individual option metrics." ;
    oc:severityLevel "HIGH" .

oc:req_22928740 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Options pricing theory, Greeks, implied/realized volatility concepts" .

oc:req_5aae26a7 a oc:RequirementAPI ;
    oc:isOptional false ;
    oc:requirementValue "MCP server providing equity_vol_surface, fx_vol_surface, option_value, option_template_list, tscc_historical_pricing_summaries, qa_historical_equity_price" .

_:ref_18e2867db414d6be a oc:WorkflowStep ;
    dcterms:description "**Synthesize:** Combine surface shape, Greeks, and implied-vs-realized comparison into a vol assessment with strategy recommendations." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_617c6003e83583ca a oc:WorkflowStep ;
    dcterms:description "**Option Pricing:** Call `option_value` for specific options of interest. Extract premium, delta, gamma, vega, theta, implied vol." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_88333bbc43907f18 a oc:WorkflowStep ;
    dcterms:description "**Realized Vol Computation:** From historical prices, compute close-to-close realized vol over 20-day, 60-day, and 90-day windows. Compare to matching implied vol tenors." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_9325b3f4ffdead13 a oc:WorkflowStep ;
    dcterms:description "**Historical Data:** Call `tscc_historical_pricing_summaries` or `qa_historical_equity_price` for 1Y daily history." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_ce97ec45aa7ea628 a oc:WorkflowStep ;
    dcterms:description "**Template Discovery:** Call `option_template_list` to find available option types, expiries, and strikes for the underlying." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_da73d4d890d494bd a oc:WorkflowStep ;
    dcterms:description "**Vol Surface Snapshot:** Call `equity_vol_surface` or `fx_vol_surface` (based on asset type). Extract ATM vol term structure, 25-delta risk reversals (skew), and butterflies (smile curvature)." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_2a37be134572228f a oc:WorkflowStep ;
    dcterms:description "Call tscc_historical_pricing_summaries or qa_historical_equity_price for 1Y daily price history." ;
    oc:expectedOutcome "Historical OHLC data for realized vol computation" ;
    oc:stepId "historical-data" .

_:ref_3325da475248057a a oc:WorkflowStep ;
    dcterms:description "Call option_template_list to find available option types, expiries, and strikes for the underlying." ;
    oc:expectedOutcome "List of valid option templates with available strikes and expiries" ;
    oc:stepId "template-discovery" .

_:ref_44072bb842e40b3f a oc:WorkflowStep ;
    dcterms:description "Compute close-to-close realized vol over 20d, 60d, and 90d windows from historical prices. Compare to matching implied vol tenors." ;
    oc:expectedOutcome "Realized vol figures and implied-vs-realized comparison table" ;
    oc:stepDependsOn _:ref_2a37be134572228f,
        _:ref_810de6c42197fa03 ;
    oc:stepId "realized-vol" .

_:ref_92b2af9be721cedc a oc:WorkflowStep ;
    dcterms:description "Call option_value for specific options of interest. Extract premium, delta, gamma, vega, theta, implied vol." ;
    oc:expectedOutcome "Option prices and full Greeks for selected strikes/expiries" ;
    oc:stepDependsOn _:ref_3325da475248057a,
        _:ref_810de6c42197fa03 ;
    oc:stepId "option-pricing" .

_:ref_e68233d7abfd58df a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_18e2867db414d6be,
        _:ref_617c6003e83583ca,
        _:ref_88333bbc43907f18,
        _:ref_9325b3f4ffdead13,
        _:ref_ce97ec45aa7ea628,
