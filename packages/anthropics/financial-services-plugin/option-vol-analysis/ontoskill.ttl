    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_810de6c42197fa03 a oc:WorkflowStep ;
    dcterms:description "Call equity_vol_surface or fx_vol_surface to get the implied vol surface. Extract ATM vol term structure, 25-delta risk reversals, and butterflies." ;
