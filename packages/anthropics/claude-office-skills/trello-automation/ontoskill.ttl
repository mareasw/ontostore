                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """butler_rules:
  - name: auto_assign_on_move
    trigger:
      type: card_moved_to_list
      list: "Doing"
    action:
      - join_card
      - set_due_date: "+3 days"
      - add_label: "In Progress"
      
  - name: due_date_reminder
    trigger:
      type: due_date_approaching
      days: 1
    action:
      - post_comment: "@card Reminder: Due tomorrow!"
      - move_to_list: "Urgent"
      
  - name: completion_cleanup
    trigger:
      type: card_moved_to_list
      list: "Done"
    action:
      - mark_due_complete
      - remove_all_members
      - add_label: "Completed"
      
  - name: scheduled_archive
    trigger:
      type: schedule
      frequency: weekly
      day: sunday
    action:
      - archive_cards_in_list: "Done"
      - older_than: 7_days
""" ;
                                    oc:codeLanguage "yaml" ;
