    - name: "Bug"
      color: red
    - name: "Feature"
      color: green
    - name: "Tech Debt"
      color: yellow
    - name: "Blocked"
      color: purple
      
  custom_fields:
    - name: "Story Points"
      type: number
    - name: "Priority"
      type: dropdown
      options: ["High", "Medium", "Low"]
