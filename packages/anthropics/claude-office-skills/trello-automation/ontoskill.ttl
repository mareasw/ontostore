                                    oc:blockType "code_block" ;
                                    oc:codeContent """card_buttons:
  - name: "Start Working"
    actions:
      - move_to_list: "Doing"
      - join_card
      - set_due_date: "+3 days"
      - remove_label: "Backlog"
      - add_label: "In Progress"
      
  - name: "Submit for Review"
    actions:
      - move_to_list: "Review"
      - add_checklist:
          name: "Review Checklist"
          items:
            - "Code reviewed"
            - "Tests passing"
            - "Documentation updated"
      - mention: "@reviewer"
      
  - name: "Mark Complete"
    actions:
      - check_all_items
      - move_to_list: "Done"
      - mark_due_complete
      - post_comment: "✅ Completed!"
""" ;
