oc:kn_050dc384 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating Trello cards via API" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const card = await trello.cards.create({
  name: "Task name",
  desc: "Description",
  idList: "list_id",
  idLabels: ["label_id"],
  idMembers: ["member_id"],
  due: "2024-01-20T17:00:00.000Z",
  pos: "top"
});""" .

oc:kn_2f57ba13 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When setting up a new Trello board or standardizing an existing one" ;
    oc:directiveContent "1. Define board lists (5-7 max) → 2. Create labels with consistent color coding → 3. Set up Butler trigger-action rules → 4. Configure card button shortcuts → 5. Add checklist templates for recurring task types → 6. Enable Power-Ups (Calendar, Custom Fields, Slack) → 7. Set WIP limits on active columns → 8. Schedule weekly archive of Done cards" ;
    oc:stepOrder 1 .

oc:kn_6706abb9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring sprint or workflow boards" ;
    oc:directiveContent "Enforce WIP limits on in-progress columns (e.g., max 5 for 'In Progress', max 3 for 'Code Review') to prevent bottlenecks" ;
    oc:hasRationale "Unlimited WIP leads to context switching and stalled cards; limits force team to finish before starting new work" ;
    oc:severityLevel "HIGH" .

oc:kn_696f621c a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any Trello API interaction" ;
    oc:directiveContent "Verify Trello API credentials and board access before creating cards or running automations" ;
    oc:hasRationale "Expired tokens or insufficient permissions will cause silent failures in automated workflows" ;
    oc:severityLevel "HIGH" .

oc:kn_6b2136b8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or configuring any Trello board" ;
    oc:directiveContent "Keep boards to 5-7 lists maximum for clarity and usability" ;
    oc:hasRationale "Too many lists create visual clutter and reduce team adoption; kanban best practices favor narrow column counts" ;
    oc:severityLevel "MEDIUM" .

oc:kn_753c3f39 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing board structure" ;
    oc:directiveContent "Do not create overly granular lists or use Trello as a detailed database — keep cards focused on actionable work items" ;
    oc:hasRationale "Overcomplicated boards reduce team engagement and make automation harder to maintain" ;
    oc:severityLevel "MEDIUM" .

oc:kn_882b0c84 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating board analytics reports" ;
    oc:directiveContent """BOARD ANALYTICS - {Sprint Name}
═══════════════════════════════════════
CARDS:
Total:        {total}
Completed:    {completed} ({pct}%)
In Progress:  {in_progress}
Blocked:      {blocked}

VELOCITY:
This Sprint:  {velocity} cards
Average:      {avg} cards
Trend:        {trend}%

CYCLE TIME:
Average:      {avg_cycle} days
Shortest:     {min_cycle} days
Longest:      {max_cycle} days""" ;
    oc:templateVariables "Sprint Name",
        "avg",
        "avg_cycle",
        "blocked",
        "completed",
        "in_progress",
        "max_cycle",
        "min_cycle",
        "pct",
        "total",
        "trend",
        "velocity" .

oc:kn_89d83b40 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating cards and labels on any board" ;
    oc:directiveContent "Use consistent label color coding across all boards and set realistic due dates on every card" ;
    oc:hasRationale "Inconsistent labels cause confusion; missing due dates prevent Butler automation from triggering reminders" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a77e4cf7 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When setting up board automation for ongoing projects" ;
    oc:directiveContent "Automate repetitive actions with Butler rules: auto-assign on card move, due date reminders, completion cleanup, and scheduled archiving of old Done cards" ;
    oc:hasRationale "Butler rules reduce manual overhead and ensure consistent process enforcement across the team" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b728d4e6 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "Ongoing board maintenance" ;
    oc:directiveContent "Regularly archive completed cards (e.g., weekly on Sunday) to keep boards performant and scannable" ;
    oc:hasRationale "Accumulated Done cards slow board loading and obscure active work; scheduled archiving is a low-effort hygiene practice" ;
    oc:severityLevel "LOW" .

