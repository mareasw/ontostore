oc:skill_claude_office_skills_image_generation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "image-generation" ;
    skos:broader "Prompt engineering framework" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/claude-office-skills/image-generation" ;
    oc:contentHash "6b6933e727a0788ad92524fe84a581ecc81ae817b66b75f4fd305b0c5d7ae5e6" ;
    oc:differentia "that crafts optimized prompts for AI image generation platforms (DALL-E, Midjourney, Stable Diffusion) with platform-specific syntax, style keywords, and structured output templates" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "visual description, target platform, style preferences, aspect ratio" ;
    oc:hasCategory "visualization" ;
    oc:hasDescription "Create effective AI image generation prompts for DALL-E, Midjourney, and Stable Diffusion. Generate prompts for various styles and use cases." ;
    oc:hasName "image-generation" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """# ═══════════════════════════════════════════════════════════════════════════════
# CLAUDE OFFICE SKILL - Image Generation
# ═══════════════════════════════════════════════════════════════════════════════

name: image-generation
description: "Create effective AI image generation prompts for DALL-E, Midjourney, and Stable Diffusion. Generate prompts for various styles and use cases."
version: "1.0.0"
author: claude-office-skills
license: MIT

category: visualization
tags:
  - image
  - ai-art
  - prompts
  - dall-e
  - midjourney
department: Design/Marketing

models:
  recommended:
    - claude-sonnet-4
    - claude-opus-4
  compatible:
    - claude-3-5-sonnet
    - gpt-4
    - gpt-4o

capabilities:
  - prompt_engineering
  - style_specification
  - composition_guidance
  - negative_prompting
  - prompt_optimization

languages:
  - en
  - zh

related_skills:
  - ppt-visual
  - infographic
  - brand-guidelines
""" ] ;
