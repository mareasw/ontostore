oc:kn_00e2b237 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — when setting user expectations" ;
    oc:directiveContent "This skill cannot generate images directly; it only produces text prompts. Results are unpredictable and vary between AI platforms. Some concepts are restricted by platform content policies." ;
    oc:hasRationale "Users must understand the skill is a prompt engineering tool, not an image generator, to avoid misuse." ;
    oc:severityLevel "HIGH" .

oc:kn_122d67f0 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating image generation prompts for users" ;
    oc:directiveContent "1. Gather user vision (subject, purpose, style, mood) 2. Select target platform (DALL-E 3 for clarity, Midjourney for aesthetics, Stable Diffusion for customization) 3. Specify parameters (aspect ratio, quality, style refs, things to avoid) 4. Construct prompt using [Subject]+[Action]+[Environment]+[Style]+[Technical] framework 5. Generate platform-specific variants 6. Provide iteration suggestions" ;
    oc:stepOrder 1 .

oc:kn_35112451 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When refining prompts after initial generation" ;
    oc:directiveContent "Iterate on results and use consistent seeds for variations when possible. Quality modifiers like 'professional', 'detailed', '8k' improve output." ;
    oc:hasRationale "AI image generation is inherently iterative; refining based on results is the standard workflow." ;
    oc:severityLevel "LOW" .

oc:kn_3af46a68 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting prompts for each specific platform" ;
    oc:codeLanguage "prompt" ;
    oc:directiveContent """DALL-E 3: Natural language descriptive prompt
Midjourney: keyword1, keyword2, keyword3 --ar 16:9 --style raw --v 6
Stable Diffusion: (keyword1:1.2), (keyword2:1.1), keyword3, 8k, detailed
Negative: unwanted1, (unwanted2:1.4)""" .

oc:kn_4785abc7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing any image generation prompt" ;
    oc:directiveContent "The basic prompt structure follows: [Subject] + [Action/State] + [Environment] + [Style] + [Technical Parameters]. Be specific (e.g., 'golden retriever' not 'dog'), include lighting, and specify composition." ;
    oc:hasRationale "Structured prompts with specificity produce more predictable and higher quality results." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6740c6af a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adapting prompts across platforms" ;
    oc:directiveContent "Each platform requires a fundamentally different prompt style: DALL-E 3 uses natural language descriptions, Midjourney uses keyword-based prompts with parameters, and Stable Diffusion uses weighted tokens with essential negative prompts." ;
    oc:hasRationale "Using the wrong prompt syntax for a platform produces suboptimal results." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9e21342e a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before generating prompts" ;
    oc:directiveContent "User must have access to at least one AI image generation platform (DALL-E 3, Midjourney, or Stable Diffusion) to use the generated prompts." .

oc:kn_b72b5453 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """# Image Generation Prompts: {Concept}
**Purpose**: {purpose}
**Target Platform**: {platform}
**Aspect Ratio**: {ratio}
## Primary Prompt (platform-specific variants)
## Variations (1-3 alternatives)
## Style Alternatives (with keyword suggestions)
## Tips for This Image
## Iteration Suggestions""" ;
    oc:templateVariables "Concept",
        "platform",
        "purpose",
        "ratio" .

oc:kn_fe78c783 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing prompts for any AI image generation platform" ;
    oc:directiveContent "Do not describe what you don't want in positive prompts — use negative prompts separately instead." ;
    oc:hasRationale "Including negative descriptions in the main prompt can inadvertently introduce unwanted elements due to how AI models interpret keywords." ;
    oc:severityLevel "HIGH" .

