oc:kn_0f721135 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When documents are parsed repeatedly" ;
    oc:directiveContent "Cache parsed document results to avoid reprocessing the same document multiple times." ;
    oc:hasRationale "Document parsing is computationally expensive; caching avoids redundant processing and improves response times." ;
    oc:severityLevel "LOW" .

oc:kn_17489422 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When iterating document elements to extract specific content types" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """for element in doc.iterate_items():
    if element.type == "table":
        table_df = element.export_to_dataframe()
    elif element.type == "picture":
        # Handle figures
        pass""" .

oc:kn_23410116 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running parsing on unchanged documents" ;
    oc:directiveContent "Parsing the same document with the same pipeline options produces deterministic output." ;
    oc:hasRationale "Deterministic parsing enables reliable caching and consistent result comparison across runs." ;
    oc:severityLevel "LOW" .

oc:kn_537d99c4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring advanced pipeline options for PDFs with tables or OCR needs" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from docling.datamodel.pipeline_options import PdfPipelineOptions

pipeline_options = PdfPipelineOptions()
pipeline_options.do_ocr = True
pipeline_options.do_table_structure = True
pipeline_options.table_structure_options.do_cell_matching = True

converter = DocumentConverter(pdf_backend_options=pipeline_options)""" .

oc:kn_61e4cee5 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When parsing any document" ;
    oc:directiveContent "1. Install docling (pip install docling[all]) 2. Create DocumentConverter with appropriate PdfPipelineOptions 3. Call converter.convert(file_path) 4. Access result.document 5. Export via export_to_markdown(), export_to_text(), or export_to_dict()" ;
    oc:stepOrder 1 .

oc:kn_6d2e486f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Basic document parsing — use as the default starting pattern" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from docling.document_converter import DocumentConverter

converter = DocumentConverter()
result = converter.convert("document.pdf")
doc = result.document
markdown = doc.export_to_markdown()""" .

oc:kn_70e997b4 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When encountering encrypted or handwritten documents" ;
    oc:directiveContent "Encrypted PDFs are not supported by docling; handwritten content requires OCR preprocessing." ;
    oc:hasRationale "These are hard limitations of the docling library that cannot be worked around without external preprocessing." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7d18abb4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before parsing documents" ;
    oc:directiveContent "Configure the pipeline options for your document type: enable OCR for scanned documents, enable table structure for tabular data, enable cell matching for precise table extraction." ;
    oc:hasRationale "Using appropriate pipeline options improves accuracy by activating only the needed processing modules for the document type." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9479313a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting tables from complex documents" ;
    oc:directiveContent "Do not assume table extraction is always accurate — complex nested tables and merged cells may need manual review." ;
    oc:hasRationale "docling's table structure detection can misinterpret nested or irregular table layouts, leading to incorrect data extraction." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ea443782 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When reporting parsing results to the user" ;
    oc:directiveContent """## Parsed Document Result
- **Source**: {filename}
- **Format**: {format}
- **Pages**: {page_count}
- **Tables**: {table_count}
- **Figures**: {figure_count}
- **Content**: {markdown_output}""" ;
    oc:templateVariables "figure_count",
        "filename",
        "format",
        "markdown_output",
        "page_count",
        "table_count" .

oc:kn_f4d24b32 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parsing large or complex documents" ;
    oc:directiveContent "Very large documents may require chunking before parsing; GPU is recommended for best performance with docling." ;
    oc:hasRationale "Large documents can exhaust memory and CPU resources without chunking; GPU acceleration significantly improves OCR and layout analysis speed." ;
    oc:severityLevel "HIGH" .

oc:kn_f5184380 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any document parsing" ;
    oc:directiveContent "Python 3.10+ and docling library must be installed (pip install docling or pip install docling[all] for full functionality)" .

