        "tailor resume for specific job application" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_1c2b4e16 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning resume tailoring" ;
    oc:directiveContent "Before tailoring, verify you have: (1) the full job description (not summarized), (2) the complete resume, (3) any additional context like career change or specific concerns, and (4) the target company name." ;
    oc:hasRationale "Incomplete inputs lead to missed keywords and suboptimal tailoring; the full job description contains the exact ATS-scanned keywords." ;
    oc:severityLevel "HIGH" .

oc:kn_4fcd6c11 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining resume length and versioning strategy" ;
    oc:directiveContent "Keep resume to 1 page for 0-5 years experience, 1-2 pages for 5-15 years, 2 pages max for 15+ years or executive roles. Maintain a 'base' resume with everything, then tailor for each application." ;
    oc:hasRationale "Recruiters spend 6-10 seconds on initial scan; appropriate length signals relevance and respect for their time." ;
    oc:severityLevel "MEDIUM" .

oc:kn_57e49333 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — this is a hard ethical and practical constraint" ;
    oc:directiveContent "Never fabricate experience you don't have. This tool cannot verify your background — be truthful. Also cannot guarantee ATS passage or job offers." ;
    oc:hasRationale "Fabricated experience is unethical, can be discovered during background checks, and undermines the entire optimization process." ;
    oc:severityLevel "CRITICAL" .

oc:kn_69236d4c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user is transitioning between careers or industries" ;
    oc:directiveContent "For career changers, reframe existing experience using target-industry terminology rather than inventing new qualifications. Map teaching→instructional design, operations→product management, etc." ;
    oc:hasRationale "Skills transfer across domains but the vocabulary doesn't — reframing demonstrates fitness for the new role without fabrication." ;
    oc:severityLevel "MEDIUM" .

oc:kn_74cfb688 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working with non-English resumes or expecting layout feedback" ;
    oc:directiveContent "The skill assumes English-language resumes with deep industry vocabulary; for other languages it may have less specialized vocabulary. It also cannot see actual document formatting." ;
    oc:hasRationale "Industry-specific keyword databases are primarily English-focused, and visual formatting review requires a different capability." ;
    oc:severityLevel "LOW" .

oc:kn_7b1e1b79 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After completing resume tailoring" ;
    oc:directiveContent "Successful tailoring produces: a requirements match table showing gaps and matches, a list of keywords to add and already present, an optimized full resume, specific per-section changes with explanations, and additional recommendations for cover letter/LinkedIn/interview prep." ;
    oc:hasRationale "Structured output ensures the user can verify each change and understand the reasoning, enabling productive iteration." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a5999dc6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting any resume for online submission" ;
    oc:directiveContent "Never use creative section headers, clever synonyms, or complex formatting (tables, columns, graphics) — ATS systems cannot parse them and your resume will be filtered out." ;
    oc:hasRationale "ATS systems scan for standard headers and exact keyword matches; non-standard terms are invisible to the parser." ;
    oc:severityLevel "HIGH" .

oc:kn_bf6697e2 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When optimizing a resume for ATS compatibility" ;
    oc:directiveContent "Use exact keywords from the job posting, spell out acronyms AND include them, and use standard section headers (Experience, Skills, Education)." ;
    oc:hasRationale "ATS ranks candidates by keyword match percentage against the job description." ;
    oc:severityLevel "HIGH" .

oc:kn_e58f5e39 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or improving any resume bullet point" ;
    oc:directiveContent "[Power Verb] + [What] + [Quantified Result] + [How/Context]" ;
    oc:hasRationale "Quantified achievement bullets are far more impactful and ATS-friendly than vague responsibility descriptions." ;
    oc:severityLevel "MEDIUM" .

oc:req_1fc24383 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "ATS (Applicant Tracking System) filtering mechanics" .

oc:req_6847fa9b a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Industry-specific vocabulary and power verbs for resume writing" .

oc:req_780df9ef a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "office-mcp MCP server with extract_text_from_pdf, extract_text_from_docx, create_docx tools" .

_:ref_417970d6f2450e2d a oc:WorkflowStep ;
    dcterms:description "Reorganize experience, add missing keywords, improve bullet points with quantified achievements using the power verb + result formula" ;
    oc:expectedOutcome "Full tailored resume with per-section change explanations" ;
    oc:stepDependsOn _:ref_8fd201ecd4b66247 ;
    oc:stepId "optimize-resume" .

_:ref_8fd201ecd4b66247 a oc:WorkflowStep ;
    dcterms:description "Map resume experience to job requirements, identify matches (strengths) and gaps" ;
    oc:expectedOutcome "Requirements match table with ✅/⚠️ indicators" ;
    oc:stepDependsOn _:ref_9407fdacfa6a401c ;
    oc:stepId "match-assess" .

_:ref_9407fdacfa6a401c a oc:WorkflowStep ;
    dcterms:description "Extract key requirements, skills, qualifications, and keywords from the job description" ;
    oc:expectedOutcome "Structured list of job requirements and target keywords" ;
    oc:stepDependsOn _:ref_96748092fc7afe6a ;
    oc:stepId "analyze-job" .

_:ref_96748092fc7afe6a a oc:WorkflowStep ;
    dcterms:description "Collect full resume (paste or upload via PDF/DOCX extraction), full job description, and any additional context (career change, internal transfer, specific concerns)" ;
    oc:expectedOutcome "All source materials available for analysis" ;
    oc:stepId "collect-inputs" .

