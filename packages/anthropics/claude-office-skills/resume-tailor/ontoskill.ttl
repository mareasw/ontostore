oc:kn_0223871d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing multiple job applications" ;
    oc:directiveContent "Maintain 2-3 resume versions for different role types. Focus on relevant experience; summarize or omit old/unrelated positions in one line." ;
    oc:hasRationale "A single generic resume underperforms compared to targeted versions; tailoring is more effective than breadth." .

oc:kn_1d7c653b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or improving experience bullet points" ;
    oc:directiveContent "Transform weak bullet points using the formula: [Power Verb] + [What] + [Quantified Result] + [How/Context]. Every achievement should include a number." ;
    oc:hasRationale "Quantified achievements demonstrate impact concretely and are more persuasive to both ATS and human reviewers." .

oc:kn_64790a27 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires the user's complete resume text and the full job description (not summarized). Best results with additional context about career goals or concerns." .

oc:kn_b79790f7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining resume length" ;
    oc:directiveContent "Resume length should be 1 page for 0-5 years experience, 1-2 pages for 5-15 years, 2 pages max for 15+ years or executive roles. Academic CVs can be longer." ;
    oc:hasRationale "Recruiters spend limited time per resume; length expectations vary by seniority level." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bff0cb2b a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """## Resume Analysis
### Job Requirements Match
| Requirement | Your Match | Gap? |
|-------------|-----------|------|
| {key_skill} | {experience} | ✅/⚠️ |

### Keyword Optimization
**Add these keywords:** {add_list}
**Already present:** {present_list}

---
## Tailored Resume
{full_optimized_resume}
---
## Changes Made
### Summary Section
- {change_and_why}
### Experience Section
- {change_and_why}
### Skills Section
- {change_and_why}
---
## Additional Recommendations
1. {cover_letter_suggestion}
2. {linkedin_suggestion}
3. {interview_prep_suggestion}""" ;
    oc:templateVariables "add_list",
        "change_and_why",
        "cover_letter_suggestion",
        "experience",
        "full_optimized_resume",
        "interview_prep_suggestion",
        "key_skill",
        "linkedin_suggestion",
        "present_list" .

oc:kn_c49c5efa a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing resume tailoring workflow" ;
    oc:directiveContent "1. Collect resume text, full job description, and any additional context (career change, concerns) 2. Analyze job requirements and map to candidate experience 3. Identify keyword gaps and strengths 4. Produce tailored resume with quantified bullets, optimized keywords, and standard formatting 5. Explain each change with rationale 6. Provide additional recommendations (cover letter, LinkedIn, interview prep)" ;
    oc:stepOrder 1 .

oc:kn_c8857650 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When optimizing for ATS (Applicant Tracking System) compatibility" ;
    oc:directiveContent "Use exact keywords from the job posting in the resume. Spell out acronyms AND include their abbreviated forms. Use standard section headers (Experience, Education, Skills)." ;
    oc:hasRationale "ATS systems scan for exact keyword matches and rank candidates by match percentage. Creative headers and clever synonyms will be missed." ;
    oc:severityLevel "HIGH" .

oc:kn_cdbfadf4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When tailoring any resume" ;
    oc:directiveContent "Never fabricate experience the candidate does not have. Only reorganize, reframe, and emphasize existing qualifications." ;
    oc:hasRationale "Fabricating experience is unethical, damages credibility, and can lead to termination if discovered post-hire." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e998d140 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When delivering final recommendations" ;
    oc:directiveContent "Cannot verify candidate experience or know internal company culture. Recommend the user research company culture separately and be truthful about qualifications." ;
    oc:hasRationale "The skill operates on text only and cannot validate claims; responsibility for accuracy lies with the candidate." ;
    oc:severityLevel "MEDIUM" .

