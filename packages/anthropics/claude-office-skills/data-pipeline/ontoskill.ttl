oc:kn_705b84d7 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires configured connections to data sources (API keys, database connection strings, OAuth tokens) and write access to destinations." .

oc:kn_95c2adfc a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing transformation code" ;
    oc:directiveContent "Design transforms to be idempotent: re-running with the same input must produce the same output without side effects." ;
    oc:hasRationale "Idempotent transforms enable safe retries and backfill operations without data corruption." ;
    oc:severityLevel "HIGH" .

oc:kn_96a704ec a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When loading data to databases or APIs" ;
    oc:directiveContent "Use batch inserts (1000 rows) for database loads and batch webhooks (100 per call) to optimize throughput. Process large datasets in chunks rather than loading all into memory." ;
    oc:hasRationale "Batched operations reduce network overhead and prevent memory exhaustion on large datasets." .

oc:kn_ba153fed a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scheduling pipeline runs" ;
    oc:directiveContent "Configure retries with exponential backoff (max 3 attempts) and alert only on final failure to balance resilience with noise reduction." ;
    oc:hasRationale "Transient failures are common in API calls and network operations; alerting on every failure creates alert fatigue." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c483b3b4 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a pipeline fails and needs re-execution" ;
    oc:directiveContent "Use append/truncate write modes at destinations and maintain idempotent transforms so pipelines can be safely re-run after failures." ;
    oc:hasRationale "Non-idempotent pipelines risk duplicating data or losing records during recovery, making failures worse." ;
    oc:severityLevel "HIGH" .

oc:kn_e751805a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any data pipeline" ;
    oc:directiveContent "Always follow the Extract → Transform → Load pattern as distinct stages, keeping each stage independently testable and resumable." ;
    oc:hasRationale "Separation of ETL stages enables debugging, retries, and monitoring at each phase independently." ;
    oc:severityLevel "HIGH" .

oc:kn_f7993d41 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When aggregating data by group keys" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const grouped = {};
items.forEach(item => {
  const key = `${item.date}_${item.category}`;
  if (!grouped[key]) grouped[key] = { date: item.date, category: item.category, total: 0, count: 0 };
  grouped[key].total += item.amount;
  grouped[key].count += 1;
});
return Object.values(grouped);""" .

