    prov:wasDerivedFrom "../.agents/skills/anthropics/claude-office-skills/pdf-form-filler" ;
    oc:contentHash "14f3a317fe7ef6bc88b3f4cc8661376dc601fce50aca352ee7546df4f860fb63" ;
    oc:dependsOnSkill oc:skill_ontoskills_office_mcp ;
    oc:differentia "that programmatically fills PDF form fields and extracts form data with validation and batch processing support" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "pdf-file-path" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Fill out PDF forms programmatically and extract form data" ;
    oc:hasName "pdf-form-filler" ;
    oc:hasPackageName "claude-office-skills" ;
    oc:hasRequirement oc:req_bc78c3c8,
        oc:req_c35db97a ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """# ═══════════════════════════════════════════════════════════════════════════════
# CLAUDE OFFICE SKILL - Enhanced Metadata v2.0
# ═══════════════════════════════════════════════════════════════════════════════

# Basic Information
name: PDF Form Filler
description: "Fill out PDF forms programmatically and extract form data"
version: "1.0"
author: claude-office-skills
license: MIT

# Categorization
category: pdf
tags:
  - pdf
  - form
  - fill
  - data-entry
department: All

# AI Model Compatibility
models:
  recommended:
    - claude-sonnet-4
    - claude-opus-4
  compatible:
    - claude-3-5-sonnet
    - gpt-4
    - gpt-4o

# MCP Tools Integration
mcp:
  server: office-mcp
  tools:
    - fill_pdf_form
    - get_pdf_metadata

# Skill Capabilities
capabilities:
  - form_filling
  - data_entry
  - pdf_forms

# Language Support
languages:
  - en
  - zh
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Fill out PDF forms automatically and extract data from completed forms." ] ;
