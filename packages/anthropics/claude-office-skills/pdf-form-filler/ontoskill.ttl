oc:kn_173a1b4e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When batch filling multiple forms" ;
    oc:directiveContent "For batch operations, use a data source file (CSV/spreadsheet) and always preview a sample of the data before running the full batch. Track progress with completion/warning/error counts." ;
    oc:hasRationale "Previewing data catches systematic mapping errors before they propagate across all outputs, and progress tracking enables partial recovery." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4717900c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When preparing to fill any non-trivial form, especially batch operations" ;
    oc:directiveContent "Create a field mapping template (YAML) that maps source data keys to PDF form field names before batch filling. Include field type, required status, and page number in the mapping." ;
    oc:hasRationale "Explicit field mappings prevent mismatches between data source keys and actual PDF field names, which is the most common source of fill errors." ;
    oc:severityLevel "MEDIUM" .

oc:kn_59639839 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When filling forms with calculated fields or signature requirements" ;
    oc:directiveContent "Complex calculations in PDF forms may not auto-update after programmatic filling. Signature fields require manual completion or proper digital certificates." ;
    oc:hasRationale "Programmatic form fillers set field values but may not trigger the embedded JavaScript calculations that recalculate dependent fields." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5de751e3 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before filling any form with user-provided data" ;
    oc:directiveContent "Validate all form data before filling: check email format, phone digit count (10 digits), SSN format (XXX-XX-XXXX), date format (MM/DD/YYYY), ZIP code (5 or 9 digits), and amounts (numeric, positive). Run cross-field validations such as conditional requirements and date ranges." ;
    oc:hasRationale "Pre-fill validation prevents downstream errors and avoids producing forms with incorrect or incomplete data." ;
    oc:severityLevel "HIGH" .

oc:kn_7965776b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When attempting to fill any PDF form" ;
    oc:directiveContent "Cannot execute actual form filling — provides guidance only. Digital signatures require proper certificates, some secured PDFs prevent form filling, and field names must match exactly." ;
    oc:hasRationale "These are hard limitations of the skill that cannot be worked around without additional tooling or certificates." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e918ea0e a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When programmatic form filling fails or is not possible" ;
    oc:directiveContent "For forms that cannot be filled programmatically (secured, flattened, or with unsupported field types), recommend desktop tools like Adobe Acrobat Pro, Foxit PDF Editor, or programming libraries like pdf-lib, PyPDF2, or iText." ;
    oc:hasRationale "Having fallback tool recommendations ensures the user can still complete their task even when automated filling is blocked." ;
    oc:severityLevel "LOW" .

oc:kn_f3af9e62 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering a PDF that appears to have form fields but no interactive fields are detected" ;
    oc:directiveContent "Do not attempt to fill flattened PDF forms — their fields have been converted to static content and cannot be edited." ;
    oc:hasRationale "Flattened forms lose their interactive field structure; attempting to fill them will silently fail or produce unexpected results." ;
    oc:severityLevel "HIGH" .

oc:req_bc78c3c8 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of PDF form field types (text, checkbox, radio, dropdown, signature, combo box)" .

oc:req_c35db97a a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "office-mcp MCP server with fill_pdf_form and get_pdf_metadata tools" .

