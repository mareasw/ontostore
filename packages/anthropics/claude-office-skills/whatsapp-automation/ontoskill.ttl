    oc:requiresState oc:APIKeySet,
        oc:NetworkAvailable ;
    oc:resolvesIntent "automate WhatsApp customer support",
        "build n8n WhatsApp workflows",
        "create WhatsApp chatbot flows",
        "create WhatsApp message templates",
        "manage broadcast messaging campaigns",
        "send order and shipping notifications via WhatsApp",
        "set up WhatsApp Business API integration" ;
    oc:yieldsState oc:MessageSent,
        oc:WorkflowConfigured .

oc:kn_0c21518d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running AI chatbot flows for customer support" ;
    oc:directiveContent "Escalate to human agent when: customer sentiment is very negative, keywords like 'complaint', 'refund', 'angry', 'sue' are detected, or the same question is asked 3+ times." ;
    oc:hasRationale "Automated escalation triggers prevent negative customer experiences and catch issues before they become complaints." ;
    oc:severityLevel "HIGH" .

oc:kn_1b045a09 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing chatbot flows and AI-powered responses" ;
    oc:directiveContent "Keep WhatsApp responses concise with appropriate emoji usage. Always offer human agent handoff when AI cannot resolve." ;
    oc:hasRationale "WhatsApp users expect quick, scannable messages. Lack of human escalation causes frustration and customer churn." ;
    oc:severityLevel "MEDIUM" .

oc:kn_87198527 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When setting up WhatsApp Business API from scratch" ;
    oc:directiveContent "1. Create Meta Business Account at business.facebook.com and verify business. 2. Access WhatsApp Business API through Meta Developer Portal, create app, get Phone Number ID and Access Token. 3. Configure webhook with callback URL and verify token, subscribe to messages. 4. Create message templates in Business Manager and wait for approval (24-48h)." ;
    oc:stepOrder 1 .

oc:kn_bfb46a75 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating broadcast campaigns or marketing messages" ;
    oc:directiveContent "Never send marketing messages without explicit opt-in or without using a Meta-approved message template." ;
    oc:hasRationale "WhatsApp has strict anti-spam policies; violations result in account suspension or permanent bans." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e325f3a8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When setting up broadcast messaging campaigns" ;
    oc:directiveContent "Comply with broadcast messaging rules: require opt-in, support STOP to unsubscribe, enforce frequency limits per contact per day, and respect timezone quiet hours." ;
    oc:hasRationale "Regulatory compliance (GDPR, TCPA) and WhatsApp policy require these safeguards to protect users." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e6a540f4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up any outbound notification or campaign template" ;
    oc:directiveContent "Message templates must be created in Business Manager and approved by Meta before use. Approval takes 24-48 hours." ;
    oc:hasRationale "WhatsApp Business API requires pre-approved templates for outbound messages outside the 24-hour customer service window." ;
    oc:severityLevel "HIGH" .

