                            oc:sectionOrder 2 ;
                            oc:sectionTitle "AI-Powered Responses" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Chatbot Flows" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "WhatsApp Automation" ] ;
    oc:impartsKnowledge oc:kn_0c21518d,
        oc:kn_1b045a09,
        oc:kn_87198527,
        oc:kn_bfb46a75,
        oc:kn_e325f3a8,
        oc:kn_e6a540f4 ;
    oc:isUserInvocable true ;
