        oc:FileDownloaded .

oc:kn_18a1988f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When using fill_docx_template tool" ;
    oc:directiveContent "Template filling uses {{placeholder}} syntax via docxtemplater. Ensure template variables match the double-brace placeholder names in the DOCX template." ;
    oc:hasRationale "Mismatched placeholder names cause silent failures in template filling" .

oc:kn_21d39a04 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before first use of office-mcp tools" ;
    oc:directiveContent "1. Clone repo and cd to mcp-servers/office-mcp 2. Run npm install && npm run build 3. Add server config to claude_desktop_config.json 4. Restart Claude Desktop" ;
    oc:hasRationale "MCP server must be built and registered with Claude Desktop before tools become available" ;
    oc:stepOrder 1 .

oc:kn_4d2fb127 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring the MCP server in Claude Desktop" ;
    oc:codeLanguage "json" ;
    oc:directiveContent """{
  "mcpServers": {
    "office-mcp": {
      "command": "/usr/local/bin/node",
      "args": ["/path/to/claude-office-skills/mcp-servers/office-mcp/dist/index.js"]
    }
  }
}""" ;
    oc:hasRationale "Standard MCP server registration format required for Claude Desktop to discover and connect to the server" .

oc:kn_526c3dad a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Word or HTML to PDF format" ;
    oc:directiveContent "docx_to_pdf and html_to_pdf conversions require an external tool to be installed on the system." ;
    oc:hasRationale "These conversions depend on system-level PDF rendering that is not bundled in the npm package" ;
    oc:severityLevel "HIGH" .

oc:kn_8dddbb69 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using ocr_pdf or ocr_image tools" ;
    oc:directiveContent "OCR supports eng, chi_sim, chi_tra, jpn, kor, fra, deu, spa. Specify the language when processing non-English scanned documents for best results." ;
    oc:hasRationale "Specifying the correct OCR language significantly improves accuracy for non-English text" .

oc:kn_9a8096ff a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which tool to use for a document task" ;
    oc:directiveContent "The server implements 39 tools across 5 categories: PDF (10), Spreadsheet (7), Document (6), Conversion (9), Presentation (7). Use the appropriate tool for each document operation rather than chaining multiple tools." ;
    oc:hasRationale "Direct tool selection is more efficient than multi-step workarounds" .

