oc:kn_3cafea3b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating invoices via QuickBooks API" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const invoice = {
  CustomerRef: { value: "123" },
  Line: [{
    DetailType: "SalesItemLineDetail",
    Amount: 1000,
    SalesItemLineDetail: {
      ItemRef: { value: "1" },
      Qty: 10,
      UnitPrice: 100
    }
  }],
  DueDate: "2024-02-15",
  EmailStatus: "NeedToSend"
};""" .

oc:kn_4015946b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any invoice" ;
    oc:directiveContent "Use sequential, searchable invoice numbers with format INV-{YYYY}{MM}-{####} for consistent tracking and auditability." ;
    oc:hasRationale "Consistent numbering prevents duplicates, enables search, and simplifies reconciliation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4c0a3e2b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating and managing an invoice from start to finish" ;
    oc:directiveContent "1. Collect customer data and line items 2. Apply branded template with tax rates and terms 3. Generate PDF invoice 4. Send via platform (QuickBooks/Xero/Stripe) 5. Set up reminder sequence 6. Track payment status 7. Reconcile received payments weekly" ;
    oc:stepOrder 1 .

oc:kn_6a11e042 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating and sending invoices via Stripe API" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const invoice = await stripe.invoices.create({
  customer: 'cus_xxx',
  collection_method: 'send_invoice',
  days_until_due: 30,
  auto_advance: true
});
await stripe.invoiceItems.create({
  customer: 'cus_xxx',
  invoice: invoice.id,
  price: 'price_xxx',
  quantity: 1
});
await stripe.invoices.sendInvoice(invoice.id);""" .

oc:kn_8646b42b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a project or milestone is completed" ;
    oc:directiveContent "Send invoices immediately upon service delivery rather than batching." ;
    oc:hasRationale "Timely invoicing accelerates cash flow and reduces the risk of forgotten billables." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a2ec3c91 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When configuring payment reminder automation" ;
    oc:directiveContent "Set up a tiered reminder sequence: 3 days before due, 1 day after, 7 days after, 30 days after with escalating tone." ;
    oc:hasRationale "Progressive reminders balance maintaining client relationships with ensuring timely payment." ;
    oc:severityLevel "HIGH" .

oc:kn_adac1616 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reconciling bank feed transactions to invoices" ;
    oc:directiveContent "Fuzzy matching for bank reconciliation (customer_name match) must NOT auto-match; always flag for manual review when confidence is below 1.0." ;
    oc:hasRationale "Fuzzy matches can incorrectly pair payments, causing inaccurate accounting records." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c7b8d87f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating invoice templates" ;
    oc:directiveContent "Always specify payment terms and accepted payment methods on every invoice." ;
    oc:hasRationale "Clear terms reduce payment disputes and set expectations for due dates." ;
    oc:severityLevel "MEDIUM" .

