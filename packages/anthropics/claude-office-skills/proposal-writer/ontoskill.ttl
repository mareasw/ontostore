oc:kn_05dfbeea a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any business proposal" ;
    oc:directiveContent "1. Gather opportunity details (client, project, requirements) 2. Obtain solution and pricing from user 3. Determine proposal type and length 4. Select appropriate template (Sales/Service, Quick Quote, or Partnership) 5. Apply customization preferences (length, style, focus, format) 6. Generate structured proposal 7. Include executive summary, understanding, solution, investment, timeline, credibility, and next steps" ;
    oc:stepOrder 1 .

