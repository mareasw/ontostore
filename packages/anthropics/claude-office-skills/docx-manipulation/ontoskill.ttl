oc:kn_2b267c48 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working with pre-existing templates or documents" ;
    oc:directiveContent "Complex templates may lose some formatting when opened and re-saved with python-docx. Track changes reading is limited. No direct PDF conversion is available." ;
