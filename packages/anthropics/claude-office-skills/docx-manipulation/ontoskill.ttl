  server: office-mcp
  tools:
    - create_docx
    - extract_text_from_docx
    - fill_docx_template
    - merge_docx_files

# Skill Capabilities
capabilities:
  - document_creation
  - editing
  - template_handling

# Language Support
languages:
  - en
  - zh
""" ] ;
            oc:sectionLevel 0 ;
