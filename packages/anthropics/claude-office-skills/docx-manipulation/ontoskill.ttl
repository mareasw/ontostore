    oc:hasRationale "Styles ensure consistency across the document and make global formatting changes easy" ;
    oc:severityLevel "HIGH" .

oc:kn_f3355e0a a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any Word document" ;
    oc:directiveContent "1. Plan document structure and hierarchy before coding. 2. Create Document object (new or from template). 3. Add content sections with headings, paragraphs, tables, images. 4. Apply styles and formatting. 5. Set up headers/footers and page layout. 6. Save document." ;
    oc:stepOrder 1 .

oc:kn_fb758c49 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling a template document with placeholder replacements" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """def fill_template(template_path, replacements):
    doc = Document(template_path)
    for para in doc.paragraphs:
        for key, value in replacements.items():
            if f'{{{key}}}' in para.text:
                para.text = para.text.replace(f'{{{key}}}', value)
    return doc""" .

