oc:kn_00636d70 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any slide layout" ;
    oc:directiveContent "One idea per slide — single key message supported by visuals, never overcrowd." ;
    oc:hasRationale "Cognitive load theory: audiences retain one message per slide; multiple ideas fragment attention." .

oc:kn_08a7236c a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """## Slide Design: {Slide Title}
**Slide Type**: {type} | **Layout Pattern**: {pattern} | **Visual Style**: {style}
### Layout Wireframe
{ASCII wireframe}
### Content Placement
- Primary Content: Position, Text, Font, Color
- Supporting Elements: Description, position
### Visual Elements
- Icons, Images, Shapes with sources
### Color Palette
- Background, Primary Text, Accent, Highlight (hex)
### Typography
- Title, Subtitle, Body, Caption (font, size, style)
### Animation Suggestions
### Implementation Notes""" ;
    oc:templateVariables "ASCII wireframe",
        "Color",
        "Font",
        "Position",
        "Slide Title",
        "Text",
        "hex",
        "pattern",
        "style",
        "type" .

oc:kn_3451d8be a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing slide compositions" ;
    oc:directiveContent "Use contrast to create emphasis: large vs small, dark vs light, color vs neutral, image vs text." ;
    oc:hasRationale "Contrast is the primary tool for directing attention and creating visual interest." .

oc:kn_47e5408a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining scope of deliverables" ;
    oc:directiveContent "Cannot create actual PPTX files, cannot generate images, and complex animations need manual setup in PowerPoint." ;
    oc:hasRationale "This skill provides design specifications and wireframes; actual file creation requires pptx tools or manual implementation." ;
    oc:severityLevel "HIGH" .

oc:kn_60cc0e35 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When placing content on any slide" ;
    oc:directiveContent "Establish visual hierarchy: Title (largest) → Key Point (prominent) → Supporting Details (smaller) → Source/Footer (smallest)." ;
    oc:hasRationale "Visual hierarchy guides the audience's eye through information in order of importance." .

oc:kn_61c7e8d3 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When designing a slide from scratch" ;
    oc:directiveContent "1. Receive slide content, purpose, audience, and design issues. 2. Choose design direction (Minimalist/Corporate/Creative/Data-focused/Storytelling). 3. Output layout wireframe, visual element recommendations, color/font specs, icon suggestions, and implementation tips." ;
    oc:stepOrder 1 .

oc:kn_78d565df a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When positioning visual elements on a slide" ;
    oc:directiveContent "Apply the Rule of Thirds — place key elements at intersection points of a 3×3 grid overlay on the slide." ;
    oc:hasRationale "The Rule of Thirds creates natural focal points that are more aesthetically pleasing than centering everything." .

oc:kn_9462c6bb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing slide visuals" ;
    oc:directiveContent "Use consistent icons (same style throughout), full-bleed images edge-to-edge, dark backgrounds for dim rooms, and leave margins so content doesn't touch edges." ;
    oc:hasRationale "Consistency and proper spacing are what separate professional presentations from amateur ones." .

oc:kn_94da19f5 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a layout for a slide" ;
    oc:directiveContent "Nine slide layout patterns available: Title Slide, Big Statement, Three Columns, Image+Text Split, Data Highlight, Timeline, Comparison, Process Flow, Quote+Image — each with ASCII wireframe template." ;
    oc:hasRationale "Pre-built layout patterns accelerate design and ensure consistent, professional slide compositions." .

oc:kn_df5b7d0a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting text-heavy content into visual slides" ;
    oc:directiveContent "Kill bullet points — replace with visuals, icons, metric cards, or diagrams. One number per slide for data-driven slides." ;
    oc:hasRationale "Bullets are read, not seen. Visuals are processed 60,000x faster than text and improve recall." .

