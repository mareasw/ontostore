    oc:differentia "that creates Non-Disclosure Agreements tailored to business context, jurisdiction, and party configuration" ;
    oc:extends oc:skill_ontoskills_contract_template ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "create_docx",
        "docx_to_pdf",
        "fill_docx_template" ;
    oc:hasArgumentHint "situation description (e.g., 'investor meeting', 'contractor NDA for source code access', 'mutual NDA for partnership')" ;
