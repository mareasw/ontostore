    oc:nature "Work" ;
    oc:resolvesIntent "create non-disclosure agreement",
        "create one-way NDA",
        "draft confidentiality agreement",
        "generate NDA",
        "generate mutual NDA" .

oc:kn_13b86afc a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any NDA" ;
    oc:directiveContent "NDA must adapt confidentiality terms and protective clauses to the applicable jurisdiction" ;
    oc:hasRationale "Legal enforceability varies by jurisdiction; generic clauses may be void in certain regions" ;
    oc:severityLevel "HIGH" .

oc:kn_14b6cb07 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating any NDA" ;
    oc:directiveContent "Gather context from user: (1) purpose/use case, (2) disclosing vs receiving party details, (3) one-way or mutual, (4) jurisdiction, (5) language preference" .

oc:kn_467217e7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the counterparty or jurisdiction requires Chinese language documentation" ;
    oc:directiveContent "Supports English and Chinese language output for NDA generation" ;
    oc:hasRationale "Bilingual support is essential for cross-border business relationships" ;
    oc:severityLevel "MEDIUM" .

oc:kn_994d4ed9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting NDA content" ;
    oc:directiveContent "Include standard protective clauses and customize confidentiality terms based on the specific business context described by the user" ;
    oc:hasRationale "Overly generic NDAs may not cover the specific risks of the engagement context" .

oc:kn_da8abecf a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining NDA structure" ;
    oc:directiveContent "Supports one-way NDAs (unilateral disclosure) and mutual NDAs (bilateral disclosure). Select type based on whether one or both parties share confidential information." ;
    oc:hasRationale "Choosing the wrong NDA type leaves one party unprotected" .

