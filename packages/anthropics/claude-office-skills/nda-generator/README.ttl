oc:skill_claude_office_skills_nda_generator_readme a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "readme" ;
    skos:broader "Legal document generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-office-skills/nda-generator" ;
    oc:contentHash "7bddc371d1b5a8b2db0f19ac8887036f3d2db00ce10603dabeff53f9242b2185" ;
    oc:differentia "that creates customized Non-Disclosure Agreements for business, partnership, and employment contexts with jurisdiction-aware clauses and bilingual support" ;
    oc:extends oc:skill_claude_office_skills_nda_generator ;
    oc:hasArgumentHint "description of the situation requiring an NDA (e.g., meeting with investors, partnership discussion, employment)" ;
    oc:hasCategory "document" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Generate professional Non-Disclosure Agreements for business meetings, partnerships, and employment." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Copy and paste the [SKILL.md](./SKILL.md) content into Claude, then describe your situation.**" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Quick Start" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Adapts for different jurisdictions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Creates one-way or mutual NDAs" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Includes standard protective clauses" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Customizes confidentiality terms" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Supports English and Chinese" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "What It Does" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**You**: I need an NDA for a meeting with potential investors where I'll share our business plan." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Claude**: [Generates appropriate one-way NDA with investor-friendly terms]" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Example" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "NDA Generator Skill" ] ;
