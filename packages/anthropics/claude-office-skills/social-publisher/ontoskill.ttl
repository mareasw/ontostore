    oc:yieldsState oc:ContentPublished .

oc:kn_45372b14 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When running the automated publishing workflow" ;
    oc:directiveContent "Follow the 5-step publishing pipeline: 1) Extract video metadata, 2) Generate AI captions per platform, 3) Publish in parallel, 4) Track results in Airtable, 5) Notify team via Slack." ;
    oc:hasRationale "This pipeline ensures consistent quality, parallel execution for speed, centralized tracking, and team visibility." .

oc:kn_4f1524cb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating captions for multi-platform publishing" ;
    oc:directiveContent "Never use the same caption verbatim across all platforms — each platform has distinct tone, length, and hashtag conventions." ;
    oc:hasRationale "Copy-pasting captions ignores platform culture and algorithm preferences, reducing engagement." ;
    oc:severityLevel "HIGH" .

oc:kn_5515407a a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "Before publishing to any platform" ;
    oc:directiveContent "Platform API rate limits and content policies vary — always validate content against each platform's guidelines before publishing." ;
    oc:hasRationale "Violating platform-specific content policies can result in shadow-banning or account suspension." ;
    oc:severityLevel "HIGH" .

oc:kn_7a983b76 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before publishing video content" ;
    oc:directiveContent "Verify video format matches platform requirements: TikTok requires 9:16 vertical, YouTube needs proper metadata, Instagram Reels need auto-detect cover image." ;
    oc:hasRationale "Incorrect video format or missing metadata causes upload failures or poor display quality." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8db59f82 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Receive content (video/description) and identify target platforms. 2. Generate platform-specific captions with appropriate style, length, and hashtags. 3. Schedule posts at optimal times per platform. 4. Publish in parallel to all platforms. 5. Record results in tracking system. 6. Notify stakeholders." ;
    oc:stepOrder 1 .

oc:kn_9a4626a0 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """# Weekly Social Media Report
## Overview
| Platform | Posts | Reach | Engagement | Followers |
## Top Performing Content
1-3 ranked posts with metrics
## Insights
- Best day/time/content type
## Next Week Recommendations
- Actionable items""" ;
    oc:templateVariables "Engagement",
        "Followers",
        "Platform",
        "Posts",
        "Reach" .

oc:kn_a4f6c0d8 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After executing the publishing workflow" ;
    oc:directiveContent "Successful publishing is confirmed when: all target platforms return post URLs, results are recorded in Airtable tracker, and Slack notification is sent to #content-published." .

oc:kn_ae1cad0d a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires social-media-mcp server with tools: tiktok_upload, instagram_publish, youtube_upload, linkedin_post, twitter_post" .

oc:kn_aff74fe9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scheduling batch content" ;
    oc:directiveContent "Maintain minimum 4-hour gap between posts on the same platform when batch publishing." ;
    oc:hasRationale "Posting too frequently on a single platform triggers spam filters and audience fatigue." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b49c9607 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating platform-specific captions" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """caption_templates:
  tiktok:
    style: casual, trendy
    max: 100 characters
    hashtags: 3-5
  instagram:
    style: engaging, story-driven
    max: 150 characters (first line hook)
    hashtags: 5-10
  youtube:
    title: SEO-optimized (60 chars)
    description: keywords, 2-3 sentences
  linkedin:
    style: professional, thought leadership
    include: CTA
  twitter:
    style: concise, punchy""" .

oc:kn_bf5402f0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adapting content for each platform" ;
    oc:directiveContent "Optimize captions per platform: TikTok (casual/trendy, 100 chars, 3-5 hashtags), Instagram (engaging/story-driven, 150 chars hook, 5-15 hashtags), YouTube (SEO-optimized title 60 chars, keyword description), LinkedIn (professional/thought-leadership with CTA, 3-5 hashtags), Twitter (concise/punchy, 1-2 hashtags)." ;
    oc:hasRationale "Each platform's algorithm and audience expectations reward different caption styles, lengths, and hashtag densities." .

oc:kn_c7e927b6 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "Batch publishing: 1. Sort content by type (educational, entertainment, promotional, community). 2. Assign primary/secondary platforms per video. 3. Generate all captions in parallel. 4. Schedule with optimal times and minimum 4-hour gaps. 5. Queue for manager review 24 hours before first post." ;
    oc:stepOrder 2 .

oc:kn_d6d5aa0d a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """# Multi-Platform Captions: {Topic}

## TikTok
{caption}

## Instagram Reel
{caption}

## YouTube Short
**Title**: {title}
**Description**: {description}

## LinkedIn
{caption}

## Twitter/X
{caption}

---
**Recommended Posting Schedule:**
- TikTok: {day} {time}
- Instagram: {day} {time}
- YouTube: {day} {time}
- LinkedIn: {day} {time}
- Twitter: {day} {time}""" ;
    oc:templateVariables "Topic",
        "caption",
        "day",
        "description",
        "time",
        "title" .

