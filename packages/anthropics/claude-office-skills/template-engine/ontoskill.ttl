oc:kn_1772f124 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When filling any document template" ;
    oc:directiveContent "1. Identify template format (Word/Excel/PPT) 2. Prepare template with Jinja2 placeholders ({{ variable }}, {% for %}, {% if %}) 3. Validate input data against placeholder names 4. Call fill_docx_template MCP tool or run Python script 5. Verify generated document at output path" ;
    oc:stepOrder 1 .

oc:kn_408118da a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any template fill operation" ;
    oc:directiveContent "Verify template file exists, output directory is writable, and all placeholder variables have corresponding data keys before rendering." ;
    oc:hasRationale "Prevents partial or broken document generation that wastes compute and confuses users." ;
    oc:severityLevel "HIGH" .

oc:kn_5ca28901 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — template management lifecycle" ;
    oc:directiveContent "Keep templates version-controlled alongside the code that fills them, treating templates as first-class artifacts in the pipeline." ;
    oc:hasRationale "Templates evolve with business requirements; version control prevents drift between template structure and data binding code." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6541d44f a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When reporting results of template fill or mail merge operations" ;
    oc:directiveContent """Generated document at: {output_path}
Template: {template_path}
Records processed: {count}
Output files:
- {filename_1}
- {filename_2}""" ;
    oc:templateVariables "count",
        "filename_1",
        "filename_2",
        "output_path",
        "template_path" .

oc:kn_a0da452d a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When executing template fill operations" ;
    oc:directiveContent "Each template rendering creates or overwrites a file at the specified output path. Bulk mail merge creates one file per CSV row in the output directory." ;
    oc:hasRationale "Agents must ensure output directories exist and warn users about potential file overwrites before execution." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c6aded50 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating multiple documents from a CSV data source" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import csv
from pathlib import Path

def mail_merge(template_path: str, data_csv: str, output_dir: str):
    Path(output_dir).mkdir(exist_ok=True)
    with open(data_csv) as f:
        reader = csv.DictReader(f)
        for i, row in enumerate(reader):
            output_path = f"{output_dir}/document_{i+1}.docx"
            fill_template(template_path, row, output_path)""" .

oc:kn_cb6ce1be a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When designing any template with placeholders" ;
    oc:directiveContent "Use clear placeholder naming conventions like {{client_name}} to avoid ambiguity and make templates self-documenting." ;
    oc:hasRationale "Clear naming reduces errors during data binding and makes templates maintainable by non-technical users." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cd873ed0 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "pip install python-docx openpyxl python-pptx reportlab jinja2 (docxtpl is required for Word Jinja2 templates)" .

oc:kn_f0c85335 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling Excel templates with simple find-replace placeholders (no Jinja2 engine)" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from openpyxl import load_workbook

def fill_excel_template(template_path: str, data: dict, output_path: str):
    wb = load_workbook(template_path)
    ws = wb.active
    for row in ws.iter_rows():
        for cell in row:
            if cell.value and isinstance(cell.value, str):
                for key, value in data.items():
                    placeholder = "{{" + key + "}}"
                    if placeholder in cell.value:
                        cell.value = cell.value.replace(placeholder, str(value))
    wb.save(output_path)
    return output_path""" .

oc:kn_f4aa0057 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing templates that may receive incomplete data sets" ;
    oc:directiveContent "Handle missing data gracefully using Jinja2 default filters (e.g., {{ name | default('Valued Customer') }}) rather than letting substitution fail silently." ;
    oc:hasRationale "Graceful fallbacks ensure documents are always generated, even with partial data, which is critical in bulk mail merge scenarios." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fc2ebda5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before calling doc.render() or any template fill operation" ;
    oc:directiveContent "Never render a template without validating the input data first — missing or malformed data will produce broken documents or raise Jinja2 errors." ;
    oc:hasRationale "Unchecked data leads to UndefinedError exceptions or documents with raw placeholder text." ;
    oc:severityLevel "HIGH" .

