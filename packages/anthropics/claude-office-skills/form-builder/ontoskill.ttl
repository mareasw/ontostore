    oc:yieldsState oc:DocumentCreated .

oc:kn_0dc5fa2a a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating output documents from form answers" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent "Use attachment blocks with content: containing Mako templates (${ variable }) and mandatory: True for document generation screens" ;
    oc:hasRationale "Attachment blocks produce the final document artifact from collected answers" .

oc:kn_18493b82 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any docassemble interview YAML" ;
    oc:directiveContent "Structure docassemble interviews as metadata block followed by question blocks separated by ---, with mandatory: True on final screens" ;
    oc:hasRationale "Correct YAML block separation and mandatory flags ensure the interview flow executes properly" .

oc:kn_87412eec a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding branching/conditional logic to forms" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent "Use 'if: variable == \"value\"' at block level to conditionally show questions based on prior answers" ;
    oc:hasRationale "Conditional blocks enable adaptive questionnaires that change based on user responses" .

oc:kn_90298c68 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining form fields" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent "Use datatype property on fields: email, integer, currency, date, yesno, checkboxes, file for proper input validation" ;
    oc:hasRationale "Correct datatypes ensure input validation and proper data handling" .

oc:kn_baa51d64 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any docassemble interview" ;
    oc:directiveContent "Always include a metadata block with title and short title at the start of the interview YAML" ;
    oc:hasRationale "Metadata provides the interview's identity and display name in the docassemble platform" ;
    oc:severityLevel "HIGH" .

oc:kn_c6f9ad37 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building complex multi-field forms" ;
    oc:directiveContent "Use objects: to define structured entities (e.g., - client: Individual) and reference properties with dot notation (client.name.first)" ;
    oc:hasRationale "Object-oriented field references keep variable names organized and prevent naming collisions in large forms" .

_:ref_4b9a0909bfbecb1d a oc:WorkflowStep ;
    dcterms:description "I'll create docassemble interview YAML" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
