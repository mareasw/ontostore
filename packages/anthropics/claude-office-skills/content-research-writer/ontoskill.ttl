oc:kn_24995122 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "All content types" ;
    oc:directiveContent "Hook early: the first sentence should grab attention. End strong with a clear takeaway or call to action." ;
    oc:hasRationale "Engagement drops sharply after the first few words; strong openings and closings maximize reader retention and conversion." ;
    oc:severityLevel "HIGH" .

oc:kn_72550379 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any content type" ;
    oc:directiveContent "Prefer specific data over vague claims, use concrete examples to illustrate abstract concepts, and break content up with headers, bullets, and images." ;
    oc:hasRationale "Specificity builds credibility; structural variety improves readability and scanability." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d4a8d073 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting writing style" ;
    oc:directiveContent "Match tone to audience and purpose: Professional (formal/authoritative), Conversational (friendly/relatable), Educational (clear/instructive), Persuasive (action-oriented), or Playful (fun/engaging)." ;
    oc:hasRationale "Tone mismatch undermines content effectiveness; the right tone builds trust and drives the desired reader action." .

oc:kn_e9c64b1e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When researching a topic for content creation" ;
    oc:directiveContent "Before writing, produce a research brief covering key points, statistics, expert quotes, competitor gaps, recommended angle, and target keywords (primary, secondary, long-tail)." ;
    oc:hasRationale "A structured brief ensures comprehensive coverage, identifies differentiation opportunities, and aligns SEO strategy before drafting begins." .

oc:kn_ee44ec58 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "All content generation" ;
    oc:directiveContent "Cannot guarantee SEO rankings, statistics should be verified, cannot access paywalled sources, brand voice requires guidance, visual content descriptions only." ;
    oc:hasRationale "LLMs cannot verify live data, access paywalled research, or produce actual images — outputs need human review for accuracy and brand alignment." ;
    oc:severityLevel "HIGH" .

oc:kn_efce82b3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When including statistics, quotes, or data in content" ;
    oc:directiveContent "Do not present AI-generated statistics or data as verified facts without flagging them for human review." ;
    oc:hasRationale "LLMs may hallucinate or use outdated data; unverified statistics damage credibility and can mislead readers." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ff853643 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating SEO-optimized content" ;
    oc:directiveContent "SEO title must be under 60 characters, meta description 150-160 characters, keyword density 1-2%, primary keyword in first 100 words, subheadings every 300 words." ;
    oc:hasRationale "Search engines truncate titles/descriptions beyond these limits; keyword density and placement directly impact ranking signals." ;
    oc:severityLevel "MEDIUM" .

