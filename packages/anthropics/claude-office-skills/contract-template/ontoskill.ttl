oc:kn_37acfbb6 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing template.tem.md grammar files" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent "Use [{variableName}] for template variables and {{#if condition}}...{{/if}} for conditional blocks in TemplateMark grammar files. Date formatting uses [{dateVar as \"MMMM DD, YYYY\"}]." ;
    oc:hasRationale "TemplateMark syntax enables natural language contracts with embedded variable binding and conditional logic." .

oc:kn_3adc0ac5 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any contract template" ;
    oc:directiveContent "1. Describe contract type and terms 2. Specify variables and logic rules 3. Generate Accord Project template (package.json, grammar, model, logic, sample)" ;
    oc:stepOrder 1 .

oc:kn_64c3e712 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating any Accord Project contract template" ;
    oc:directiveContent "Contract templates must follow the Accord Project structure: package.json for metadata, grammar/template.tem.md for natural language template, model/model.cto for data model, logic/logic.ergo for business logic, and text/sample.md for sample contract." ;
    oc:hasRationale "This standardized structure ensures templates are machine-readable, legally enforceable, and executable." ;
    oc:severityLevel "HIGH" .

oc:kn_7b9a5e43 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing logic.ergo files" ;
    oc:codeLanguage "ergo" ;
    oc:directiveContent "Write business logic in Ergo using 'contract [Name] over [AssetType]' with 'clause' functions that accept request transactions and return response transactions. Use if/then/else for conditional penalty calculations." ;
    oc:hasRationale "Ergo enables deterministic, legally enforceable computation of contract obligations like payment due dates and penalties." .

oc:kn_7fb82da5 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing model.cto data model files" ;
    oc:codeLanguage "cto" ;
    oc:directiveContent "Define data models in Concerto (.cto) with namespace, asset extends Contract for agreements, and transaction types for request/response pairs. Use 'optional' keyword for fields that may be absent." ;
    oc:hasRationale "Concerto models define the typed schema that binds template variables to structured data, enabling type-safe contract execution." .

oc:kn_85681dbf a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing template flexibility" ;
    oc:directiveContent "Use conditional blocks ({{#if}}) for optional contract clauses like late payment penalties, exclusion lists, and remedy types. Provide default fallback text in {{else}} blocks." ;
    oc:hasRationale "Conditional blocks allow a single template to cover multiple contract variations without creating separate templates for each variant." .

oc:kn_bd05b9c4 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating and executing Accord Project templates via CLI" ;
    oc:directiveContent "cicero parse --template ./contract-template --sample ./text/sample.md → cicero trigger --template ./contract-template --sample ./text/sample.md --request ./request.json → cicero draft --template ./contract-template --data ./data.json" ;
    oc:hasRationale "The parse-trigger-draft workflow ensures templates are syntactically valid, logic executes correctly, and new contracts can be drafted from data." .

oc:kn_ec9a2530 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before using Cicero CLI commands for template parsing, triggering, or drafting" ;
    oc:directiveContent "Accord Project Cicero CLI requires Node.js and npm. Install globally with: npm install -g @accordproject/cicero-cli" ;
    oc:hasRationale "Cicero CLI is the primary toolchain for validating and executing Accord Project templates locally." ;
    oc:severityLevel "MEDIUM" .

