        oc:kn_8b8b850c,
        oc:kn_cb56ed7b ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create job description",
        "draft job listing",
        "generate job posting",
        "write inclusive job description" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_1163b899 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After generating a job description" ;
    oc:directiveContent "Cannot guarantee legal compliance — always have HR/legal review the final output. Salary benchmarks may not reflect local markets. Industry-specific requirements need domain expert input." ;
    oc:hasRationale "Legal non-compliance in job postings can create liability; local market data is required for accuracy" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7d99f666 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When drafting job description copy" ;
    oc:directiveContent "Use 'you' instead of 'the ideal candidate'. Use gender-neutral pronouns (they). Remove unnecessary jargon. Be specific about requirements vs nice-to-haves. Include salary range when possible (improves applications by 30%)." ;
    oc:hasRationale "Inclusive, direct language attracts a broader and more diverse applicant pool" ;
    oc:severityLevel "HIGH" .

oc:kn_7fd6638d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining requirements and responsibilities for a given level" ;
    oc:directiveContent "Match job level to experience scope: Entry (0-2 yrs, individual tasks), Mid (2-5 yrs, independent projects), Senior (5-8 yrs, technical leadership), Staff/Lead (8-12 yrs, cross-team impact), Principal/Director (12+ yrs, org-wide)." ;
    oc:hasRationale "Proper level-scoping ensures expectations align with candidate experience and market norms" .

oc:kn_8b8b850c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any job description" ;
    oc:directiveContent "Avoid terms like 'Rockstar', 'Ninja', 'Guru', 'fast-paced environment', and excessive requirements lists. Limit must-haves to 5-7 items." ;
    oc:hasRationale "These terms signal toxic culture, exclude qualified candidates, and reduce applicant diversity" ;
    oc:severityLevel "HIGH" .

oc:kn_cb56ed7b a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating the final job description document" ;
    oc:directiveContent """# [Job Title]
## About [Company]
## About the Role (2-3 sentences)
## What You'll Do (bullet list)
## What We're Looking For (Required + Nice to Have subsections)
## What We Offer (benefits)
## How to Apply""" ;
    oc:hasRationale "Consistent structure ensures completeness and readability for candidates" ;
    oc:templateVariables "Application instructions",
        "Benefits",
        "Company",
        "Job Title",
        "Nice-to-haves",
        "Requirements",
        "Responsibilities",
        "Role description" .

