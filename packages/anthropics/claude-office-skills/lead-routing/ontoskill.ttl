        "title" .

oc:kn_50ef3b33 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Complete lead routing workflow for every inbound lead" ;
    oc:directiveContent "1. Enrich lead with firmographic/demographic data 2. Score lead using AI model 3. Determine tier (A/B/C/D) 4. Apply routing rules in priority order (named account → industry → territory → round-robin) 5. Assign owner in CRM 6. Create follow-up task with SLA deadline 7. Notify assigned rep via Slack 8. Start SLA timer with escalation path" ;
    oc:stepOrder 1 .

oc:kn_537c86aa a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying routing rules to any inbound lead" ;
    oc:directiveContent "Route leads using a priority cascade: named account owner → industry specialist → territory match → round-robin availability." ;
    oc:hasRationale "This priority order ensures relationship continuity and domain expertise take precedence over generic geographic assignment." ;
    oc:severityLevel "HIGH" .

oc:kn_742b92ca a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When configuring or interpreting AI-powered lead scoring" ;
    oc:directiveContent "AI lead scoring produces a 0-100 composite score decomposed into fit_score and intent_score, with tier thresholds: A (80-100), B (60-79), C (40-59), D (0-39)." ;
    oc:hasRationale "Structured tiering enables differentiated SLA treatment and follow-up strategies." ;
    oc:severityLevel "MEDIUM" .

oc:kn_75ab9325 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When a new lead enters the routing pipeline" ;
    oc:directiveContent "Before routing, enrich leads with demographic, firmographic, and behavioral data from providers like Clearbit or ZoomInfo." ;
    oc:hasRationale "Enrichment fills data gaps needed for accurate scoring and territory matching." ;
    oc:severityLevel "HIGH" .

oc:kn_81f56d7d a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating weekly lead routing reports" ;
    oc:directiveContent """# Lead Routing Report - {Week}
## Distribution Summary
| Rep | Assigned | Responded | Avg Response | SLA Met |
## By Tier
| Tier | Count | Avg Score | Converted | Conv Rate |
## Routing Breakdown
- By Territory / Industry / Round Robin percentages
## Issues
## Recommendations""" ;
    oc:templateVariables "Week" .

oc:kn_94699e8f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After lead assignment, while SLA timer is active" ;
    oc:directiveContent "Enforce SLA tiers with escalating alerts: Tier A (1h), Tier B (4h), Tier C (24h), each with 50%/80%/100% elapsed escalation milestones." ;
    oc:hasRationale "Strict SLA enforcement prevents leads from going cold and ensures high-value prospects get immediate attention." ;
    oc:severityLevel "CRITICAL" .

oc:kn_af3ee78d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During round-robin or any automated assignment" ;
    oc:directiveContent "Never assign leads to reps who are out-of-office, at capacity, or off-hours without fallback logic." ;
    oc:hasRationale "Ignoring rep availability leads to missed SLAs and poor lead experience." ;
    oc:severityLevel "HIGH" .

oc:kn_fa47930a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring workload balancing rules" ;
    oc:directiveContent "Per-rep capacity limits: max 50 open leads, max 15 new leads per day, max 60 new leads per week. Team-level overflow queue with manager notification." ;
    oc:hasRationale "Preventing rep overload ensures quality of engagement and prevents burnout." ;
    oc:severityLevel "MEDIUM" .

