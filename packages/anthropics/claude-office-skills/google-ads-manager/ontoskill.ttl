oc:kn_0d864689 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any new campaign" ;
    oc:directiveContent "Never skip negative keywords at campaign setup — without them, budget drains on irrelevant searches like 'free', 'jobs', 'tutorial', 'open source'" ;
    oc:hasRationale "Negative keywords prevent wasted spend on non-converting, low-intent search terms" ;
    oc:severityLevel "HIGH" .

oc:kn_35e118f9 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a new Google Ads campaign" ;
    oc:directiveContent "1. Define campaign structure (Brand/Non-Brand/Competitor/PMax). 2. Set budget, bidding strategy, targeting (locations, languages, audiences). 3. Create ad groups with themed keywords. 4. Write RSAs: 15 headlines pinned by category, 4 descriptions by focus. 5. Add negative keywords at all levels. 6. Configure ad schedule and bid adjustments." ;
    oc:stepOrder 2 .

oc:kn_40d2fab0 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating campaign performance" ;
    oc:directiveContent "Benchmark KPIs: CTR >2%, conversion rate >3%, Quality Score avg >7. Brand campaigns should achieve CPA 5-10x lower than non-brand" ;
    oc:hasRationale "Benchmarks enable rapid identification of underperforming areas needing action" .

oc:kn_58847f58 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining campaign configuration" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """campaign:
  name: "{Product} - Search - Non-Brand"
  type: SEARCH
  budget: {amount: 100, delivery: STANDARD}
  bidding: {strategy: TARGET_CPA, target_cpa: 50}
  targeting: {locations: [US, CA, UK], languages: [en]}
  networks: {search: true, display: false, partners: false}
  negative_keywords: [free, cheap, download, jobs, salary]""" .

oc:kn_71591337 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Responsive Search Ad copy" ;
    oc:directiveContent "RSAs require minimum 3 headlines (max 15, 30 chars each) and minimum 2 descriptions (max 4, 90 chars each). Pin headlines to positions: keyword/benefit at P1, value prop at P2, CTA at P3" ;
    oc:hasRationale "Google requires minimum assets; pinning ensures messaging hierarchy is preserved across ad combinations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_75cd1bfd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a bidding strategy" ;
    oc:directiveContent "Choose bidding strategy based on campaign maturity: Maximize Conversions for new campaigns (no history), Target CPA once 30+ conversions/month achieved, Target ROAS for ecommerce with value tracking" ;
    oc:hasRationale "Smart bidding strategies require conversion history to optimize effectively; wrong strategy wastes budget" .

oc:kn_8267e83e a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating performance reports" ;
