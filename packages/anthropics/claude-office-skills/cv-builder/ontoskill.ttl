oc:kn_140a32a5 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering a CV YAML file to PDF" ;
    oc:directiveContent "pip install rendercv && rendercv render cv.yaml" .

oc:kn_16c6cfaf a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "when selecting a CV theme" ;
    oc:directiveContent "Available themes are limited to: classic, sb2nov, moderncv, engineeringresumes. Use only these values in the design.theme field." ;
    oc:hasRationale "rendercv only ships with these four built-in themes; other values will cause rendering errors" ;
    oc:severityLevel "MEDIUM" .

oc:kn_23936847 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing CV YAML from user-provided information" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """cv:
  name: {name}
  location: {location}
  email: {email}
  sections:
    summary: [...]
    experience:
      - company: {company}
        position: {position}
        start_date: {start}
        end_date: {end}
        highlights: [...]
    education: [...]
    skills: [...]
design:
  theme: {theme}
  font_size: 10pt""" .

oc:kn_7e483767 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "before execution" ;
    oc:directiveContent "rendercv must be installed (pip install rendercv)" .

oc:kn_9016d46e a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-generating or updating a CV" ;
    oc:directiveContent "Running rendercv render on the same YAML always produces the same PDF output. Re-rendering is safe." .

oc:kn_9daad43b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "always" ;
    oc:directiveContent "1. Collect CV information from user (experience, education, skills, contact) 2. Choose theme (classic, sb2nov, moderncv, engineeringresumes) 3. Generate YAML following rendercv schema 4. Run `rendercv render cv.yaml` to produce PDF" ;
    oc:stepOrder 1 .

oc:kn_ed0e377e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing experience section highlights" ;
    oc:directiveContent "Use action-oriented highlights with quantifiable results in experience entries (e.g., 'Increased performance by 40%', 'Led team of 5 engineers')" ;
    oc:hasRationale "Quantified achievements create stronger CVs and are more impactful for recruiters and ATS systems" .

oc:kn_f452a01f a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When locating the generated PDF file" ;
    oc:directiveContent "rendercv_output/{Name}_CV.pdf" ;
    oc:templateVariables "Name" .

