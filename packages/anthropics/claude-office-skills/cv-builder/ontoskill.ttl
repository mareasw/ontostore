      username: sarahchen

  sections:
    summary:
      - "Full-stack developer with 8 years of experience building scalable web applications. Passionate about clean code and user experience."

    experience:
      - company: Startup Inc
        position: Lead Developer
        location: New York, NY
        start_date: 2021-03
        end_date: present
