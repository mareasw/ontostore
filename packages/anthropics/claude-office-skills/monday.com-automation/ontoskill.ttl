                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """// Monday.com GraphQL API Examples

// Create Item
const createItem = `
  mutation {
    create_item (
      board_id: 123456789,
      group_id: "new_group",
      item_name: "New Task",
      column_values: "{\\"status\\":\\"Working on it\\",\\"person\\":\\"12345\\"}"
    ) {
      id
    }
  }
`;

// Update Status
const updateStatus = `
  mutation {
    change_column_value (
      board_id: 123456789,
      item_id: 987654321,
      column_id: "status",
      value: "{\\"label\\":\\"Done\\"}"
    ) {
      id
    }
  }
`;

// Query Items
const queryItems = `
  query {
    boards (ids: 123456789) {
      items_page (limit: 50) {
        items {
          id
          name
          column_values {
            id
            value
          }
        }
      }
    }
  }
`;
""" ;
                                    oc:codeLanguage "javascript" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 394-442" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "API Workflows" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """email_automations:
  - trigger: due_date_approaching
    days_before: 3
    action:
      send_email:
        to: "{{item.person.email}}"
        subject: "Task Due Soon: {{item.name}}"
        body: |
          Hi {{item.person.name}},
          
          Your task "{{item.name}}" is due on {{item.due_date}}.
          
          Please update the status or reach out if you need help.
""" ;
