                            oc:sectionTitle "Dashboard Widgets" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """views:
  main_table:
    type: table
    default: true
    columns: all
    
  kanban:
    type: kanban
    group_by: "Status"
    card_fields:
      - "Assignee"
      - "Due Date"
      - "Priority"
    
  timeline:
    type: timeline
    date_column: "Timeline"
    color_by: "Status"
    
  calendar:
    type: calendar
    date_column: "Due Date"
    color_by: "Priority"
    
  chart:
    type: chart
    chart_type: bar
    x_axis: "Status"
    y_axis: count
    
  workload:
    type: workload
    person_column: "Assignee"
    effort_column: "Estimated Hours"
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 282-317" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "View Types" ] ;
