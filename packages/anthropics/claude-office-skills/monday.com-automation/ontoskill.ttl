                                    oc:blockType "code_block" ;
                                    oc:codeContent """project_board:
  name: "Project Tracker"
  
  groups:
    - "Backlog"
    - "This Sprint"
    - "In Progress"
    - "In Review"
    - "Done"
    
  columns:
    - name: "Task"
