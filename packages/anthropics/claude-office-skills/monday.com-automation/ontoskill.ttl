oc:kn_0ad89a76 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires Monday.com API token and network access to Monday.com GraphQL endpoint" .

oc:kn_1667ea46 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring Monday.com automations" ;
    oc:directiveContent "Avoid creating too many automation recipes on a single board — each additional automation increases complexity and can cause unintended trigger chains." ;
    oc:hasRationale "Excessive automations create hard-to-debug cascading effects and performance degradation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_26d15b26 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating Monday.com items via API" ;
    oc:codeLanguage "graphql" ;
    oc:directiveContent """mutation {
  create_item (
    board_id: BOARD_ID,
    group_id: "GROUP_ID",
    item_name: "ITEM_NAME",
    column_values: "{\\"status\\":\\"Working on it\\",\\"person\\":\\"USER_ID\\"}"
  ) { id }
}""" .

oc:kn_4789e51b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning automation strategy for a new board" ;
    oc:directiveContent "Start with built-in automation recipes before building custom ones — built-in recipes handle common patterns (status change notifications, auto-assign, move on status) reliably." ;
    oc:hasRationale "Built-in recipes are battle-tested and easier to maintain than custom recipes" .

oc:kn_5493a6d1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interacting with Monday.com API directly" ;
    oc:directiveContent "Monday.com uses a GraphQL API — all queries and mutations must follow GraphQL syntax. Column values must be passed as JSON strings within GraphQL mutations." ;
    oc:hasRationale "Incorrect column value formatting is the most common API error" ;
    oc:severityLevel "CRITICAL" .

oc:kn_5b7da2df a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When querying Monday.com board items via API" ;
    oc:codeLanguage "graphql" ;
    oc:directiveContent """query {
  boards (ids: BOARD_ID) {
    items_page (limit: 50) {
      items {
        id
        name
        column_values {
          id
          value
        }
      }
    }
  }
}""" .

oc:kn_72a59119 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """## {Board Name} Configuration
- **Groups**: {workflow_stage_list}
- **Columns**: {column_name}: {type}
- **Automations**: {trigger} → {action}
- **Views**: {view_type} grouped by {field}
- **Integrations**: {platform} — {trigger} → {action}""" ;
    oc:templateVariables "Board Name",
        "action",
        "column_name",
        "field",
        "platform",
        "trigger",
        "type",
        "view_type",
        "workflow_stage_list" .

oc:kn_7d14df79 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When debugging Monday.com automations" ;
    oc:directiveContent "If an automation fails silently, check the automation log in Monday.com and verify trigger conditions match the actual column IDs and labels exactly." ;
    oc:hasRationale "Label mismatches between automation configuration and actual board columns are the most common failure cause" .

oc:kn_951576b9 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When configuring API authentication" ;
    oc:directiveContent "Monday.com API tokens grant access to all boards the token user can see — store tokens securely and use scoped access where possible." ;
    oc:hasRationale "Overly broad API access can expose sensitive board data" ;
    oc:severityLevel "HIGH" .

oc:kn_b6ff63aa a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When designing any Monday.com board structure" ;
    oc:directiveContent "Use groups for workflow stages, standardize columns across boards, and leverage mirror columns to connect related boards." ;
    oc:hasRationale "Consistent board organization enables team adoption, cross-board reporting, and maintainable automations" ;
    oc:severityLevel "HIGH" .

oc:kn_c5fd6bdc a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Define board structure (groups as workflow stages, columns for data capture) → 2. Configure built-in automations for common triggers → 3. Add custom recipes for SLA and rollup logic → 4. Set up views (kanban, timeline, workload) → 5. Create dashboard widgets for executive visibility → 6. Configure integrations (Slack, email) → 7. Test all automations end-to-end → 8. Document board usage for team" ;
    oc:stepOrder 1 .

oc:kn_d1a758e7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When architecting a new Monday.com board" ;
    oc:directiveContent "Design boards around workflow stages using groups, use subitems to break down complex tasks, and use dependencies to show task relationships." ;
    oc:hasRationale "Board design that mirrors actual workflow stages improves team adoption and reduces confusion" .

