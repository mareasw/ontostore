    - name: "Status"
      type: status
    - name: "Assignee"
      type: person
    - name: "Priority"
      type: status
      labels: ["Critical", "High", "Medium", "Low"]
    - name: "Timeline"
      type: timeline
    - name: "Estimated Hours"
      type: numbers
    - name: "Actual Hours"
      type: numbers
    - name: "Tags"
      type: tags
    - name: "Dependencies"
      type: dependency
""" ;
