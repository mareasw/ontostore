oc:kn_00ee6429 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When receiving incoming webhooks" ;
    oc:directiveContent "Never process webhook events synchronously before returning a response — always return 200 immediately and process async" ;
    oc:hasRationale "Slow responses cause the source system to retry, creating duplicate processing and potential timeouts" ;
    oc:severityLevel "CRITICAL" .

oc:kn_353348df a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up webhook logging" ;
    oc:directiveContent "Log everything — request IDs, event types, payload hashes, error messages, stack traces, and retry counts — while masking secrets" ;
    oc:hasRationale "Webhook debugging is notoriously difficult without comprehensive logging since the flow is asynchronous and event-driven" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3cfa201e a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When monitoring webhook health" ;
    oc:directiveContent "A healthy webhook system shows >99% processing rate, p99 processing latency under 300ms, and zero events in the dead letter queue" ;
    oc:hasRationale "These thresholds indicate the system is processing events reliably and within acceptable time bounds" ;
    oc:severityLevel "MEDIUM" .

oc:kn_4a576aeb a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When configuring error handling for webhook processing" ;
    oc:directiveContent "Implement exponential backoff retry with a dead letter queue for failed webhooks after max retries (5 attempts, initial 1s delay, max 60s, 2x multiplier)" ;
    oc:hasRationale "Transient failures are common in distributed systems; dead letter queues prevent silent data loss" ;
    oc:severityLevel "HIGH" .

oc:kn_88e2c034 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When configuring webhook security" ;
    oc:directiveContent "Enforce HTTPS-only, validate payload schemas, check timestamp freshness, use IP allowlisting where possible, and never put sensitive data in URLs" ;
    oc:hasRationale "Webhooks expose an HTTP endpoint that could be abused for injection, replay, or DoS attacks" ;
    oc:severityLevel "HIGH" .

oc:kn_ad65eff5 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building a new webhook integration from scratch" ;
    oc:directiveContent "1. Define webhook endpoint with authentication (HMAC-SHA256 signature verification) 2. Set up event router mapping event types to handlers 3. Implement payload transformations per integration (Stripe, GitHub, Slack) 4. Configure retry strategy with exponential backoff and dead letter queue 5. Add security measures (HTTPS, IP allowlisting, rate limiting) 6. Set up monitoring with metrics dashboard and alerting 7. Test with sample payloads before going live" ;
    oc:hasRationale "Provides a systematic approach to building reliable webhook integrations with all critical safeguards in place" ;
    oc:stepOrder 1 .

oc:kn_bdcf4a2d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When receiving any incoming webhook" ;
    oc:directiveContent "Always verify webhook signatures using HMAC-SHA256 with timing-safe comparison before processing any payload" ;
    oc:hasRationale "Signature verification prevents spoofed webhook payloads from untrusted sources" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ed946cf7 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing webhook handler logic" ;
    oc:directiveContent "Design all webhook handlers to be idempotent — handle duplicate events gracefully by deduplicating on event ID" ;
    oc:hasRationale "Webhook providers guarantee at-least-once delivery, so duplicate events are expected, not exceptional" ;
    oc:severityLevel "HIGH" .

