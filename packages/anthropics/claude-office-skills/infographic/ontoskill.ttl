oc:kn_28920a56 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring infographic content" ;
    oc:directiveContent "Start with a hook (most interesting data point) and focus on one main message per infographic. Don't try to communicate everything at once." ;
    oc:hasRationale "Cognitive load limits mean viewers absorb one clear message far better than multiple competing messages" .

oc:kn_3f459e15 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user has not specified an infographic type" ;
    oc:directiveContent "Select infographic type based on content nature: Statistical for data/surveys, Timeline for chronology, Process for step-by-step, Comparison for side-by-side, List for ranked items." ;
    oc:hasRationale "Matching type to content structure maximizes clarity and viewer comprehension" .

oc:kn_871ef49e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any infographic layout" ;
    oc:directiveContent "Maintain strict visual hierarchy: Title (largest) → Key Statistics → Section Headings → Body Content → Sources (smallest). Never break this ordering." ;
    oc:hasRationale "Visual hierarchy directs the viewer's eye through the information in order of importance, ensuring the key message is absorbed first" ;
    oc:severityLevel "HIGH" .

oc:kn_97e509cd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When laying out infographic sections" ;
    oc:directiveContent "Use generous white space: don't overcrowd, group related items together, and use spacing to guide the eye through the flow." ;
    oc:hasRationale "White space improves readability and creates visual breathing room that prevents information overload" .

oc:kn_a1e9f8b3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining infographic size specifications" ;
    oc:directiveContent "Always specify dimensions based on target platform: social media (e.g., Instagram 1080x1080, Twitter 1200x675), print (A4 at 300 DPI = 2480x3508px), or web (blog 800px wide)." ;
    oc:hasRationale "Platform-specific dimensions prevent distortion, cropping, or readability issues at display time" .

oc:kn_e844584f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting user expectations about deliverables" ;
    oc:directiveContent "This skill cannot create actual graphic files, generate images, or produce final production-ready assets. It only produces design specifications." ;
    oc:hasRationale "The skill is a planning/specification tool, not a rendering engine. Users need to implement specs in Canva, Figma, Piktochart, or similar tools" ;
    oc:severityLevel "CRITICAL" .

