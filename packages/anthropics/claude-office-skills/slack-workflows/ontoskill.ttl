oc:kn_0d934c58 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring multi-step approval flows" ;
    oc:directiveContent "Approval workflows must define escalation timeouts (24h reminder, 48h final escalation) to prevent requests from stalling indefinitely." ;
    oc:hasRationale "Without escalation, approvals become bottlenecks that frustrate requesters and delay operations" ;
    oc:severityLevel "MEDIUM" .

oc:kn_27da2307 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When executing approval or onboarding workflows" ;
    oc:directiveContent "Slack workflows may trigger downstream actions: calendar blocks, Jira ticket creation, accounting system tasks, and CRM updates." ;
    oc:hasRationale "Understanding the full blast radius of a workflow prevents unintended cross-system effects" ;
    oc:severityLevel "MEDIUM" .

oc:kn_2bf0f1e5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring cross-platform sync notifications" ;
    oc:directiveContent "Never send all notifications to a single channel; route by context (wins → #wins, alerts → #engineering-alerts, payments → #revenue-alerts)." ;
    oc:hasRationale "Channel mixing causes information overload and important signals get lost in noise" ;
    oc:severityLevel "HIGH" .

oc:kn_5171604c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any Slack approval or notification workflow" ;
    oc:directiveContent "Structure Slack workflows as trigger → route → action → handle_response sequences, using escalation timeouts for unhandled states." ;
    oc:hasRationale "Consistent sequencing makes workflows predictable, debuggable, and ensures no request goes unhandled" ;
    oc:severityLevel "HIGH" .

oc:kn_7733ae61 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any Slack workflow action" ;
    oc:directiveContent "Verify the Slack MCP server is connected and the target channel exists before posting messages or creating workflows." ;
    oc:hasRationale "Posting to non-existent channels or without proper authentication causes silent failures" .

oc:kn_c9ac429d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When running channel cleanup automation" ;
    oc:directiveContent "Archive stale channels only after 90 days of inactivity, exclude pinned and customer channels, and notify 7 days before archival." ;
    oc:hasRationale "Premature archival disrupts active workflows and loses institutional context" .

oc:kn_e85392eb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building incident response workflows" ;
    oc:directiveContent "Use severity-based routing for incident workflows: critical creates a channel + pages on-call, high notifies alerts channel + creates ticket, medium creates ticket only, low defers to next business day." ;
    oc:hasRationale "Severity-based routing prevents alert fatigue while ensuring critical issues get immediate attention" .

