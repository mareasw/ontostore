    {
      "name": "Format Message",
      "type": "n8n-nodes-base.set",
      "parameters": {
        "values": {
          "message": "🎉 *DEAL CLOSED!*\\n\\n🏢 {{$json.company}}\\n💰 ${{$json.amount}}"
