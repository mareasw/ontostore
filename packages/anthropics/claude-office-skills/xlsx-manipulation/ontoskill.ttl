oc:kn_0280a35d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any xlsx manipulation" ;
    oc:directiveContent "Verify openpyxl is installed (pip install openpyxl) before attempting any spreadsheet operations." ;
    oc:hasRationale "openpyxl is a required external dependency not included in Python's standard library." .

oc:kn_37c6006a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When users request advanced Excel features" ;
    oc:directiveContent "openpyxl cannot execute VBA macros, fully support complex pivot tables, sparklines, or external data connections." ;
    oc:hasRationale "These are limitations of the openpyxl library; alternative tools or approaches must be suggested." ;
    oc:severityLevel "HIGH" .

oc:kn_43ba3670 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating spreadsheets with intricate formatting requirements" ;
    oc:directiveContent "Start with a .xlsx template for complex formatting rather than building all styling programmatically." ;
    oc:hasRationale "Templates save development time and ensure visual consistency with existing documents." .

oc:kn_573a1921 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing large amounts of data to a spreadsheet" ;
    oc:directiveContent "Avoid cell-by-cell operations for large datasets; use batch operations like ws.append() and ws.iter_rows() instead." ;
    oc:hasRationale "Cell-by-cell operations are significantly slower and increase memory overhead for large files." ;
    oc:severityLevel "MEDIUM" .

oc:kn_68b3435e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building spreadsheets with complex formulas" ;
    oc:directiveContent "Use named ranges and defined names for frequently referenced cell ranges to keep formulas readable and maintainable." ;
    oc:hasRationale "Named ranges make formulas self-documenting and easier to update when data ranges change." .

oc:kn_e583bfee a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When calling wb.save() on any workbook" ;
    oc:directiveContent "Saving a workbook writes/overwrites the target .xlsx file on disk. For large files, save periodically to avoid data loss." ;
    oc:hasRationale "Large file operations can fail mid-process; incremental saves prevent total data loss." .

