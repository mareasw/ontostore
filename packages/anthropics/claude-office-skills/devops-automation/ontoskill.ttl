oc:kn_4963dfed a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When provisioning new servers" ;
    oc:directiveContent "1. Validate request (budget approval, security review) → 2. Create infrastructure via Terraform → 3. Configure server via Ansible → 4. Validate (health check, security scan, performance baseline) → 5. Notify team with access details" ;
    oc:stepOrder 1 .

oc:kn_54a31002 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring CI/CD pipelines" ;
    oc:directiveContent "Never deploy to production without staging validation and manual approval gate — automated production deployment without human verification is a critical anti-pattern." ;
    oc:hasRationale "Skipping staging or manual approval gates increases the risk of deploying broken code to production, causing customer-facing outages." ;
    oc:severityLevel "HIGH" .

oc:kn_5e4b956c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When managing incidents" ;
    oc:directiveContent "1. Detect incident → 2. Auto-triage severity → 3. Respond per severity level (critical: page, war room, status page; high: Slack, Jira ticket) → 4. Communicate updates every 30 minutes → 5. Confirm resolution → 6. Schedule postmortem → 7. Close channel after 24h" ;
    oc:stepOrder 2 .

oc:kn_67fb8b29 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining alert severity levels" ;
    oc:directiveContent "Critical alerts must have 5-minute response time with PagerDuty + Slack + SMS escalation; high alerts require 15-minute response time." ;
    oc:hasRationale "Response time SLAs ensure incidents are addressed before they escalate to larger outages." ;
    oc:severityLevel "HIGH" .

oc:kn_993e402d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before deploying monitoring workflows" ;
    oc:directiveContent "Verify monitoring sources (Prometheus, Datadog, CloudWatch, New Relic) are connected and oncall schedules are configured before enabling alert routing." ;
    oc:hasRationale "Alerts without proper routing or oncall schedules lead to missed incidents and extended downtime." .

oc:kn_a8f26177 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building deployment pipelines" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """deployment_pipeline:
  stages:
    build: {trigger: push_to_main, steps: [checkout, install, test, build, push]}
    staging: {trigger: build_success, steps: [deploy, integration_tests, notify_qa]}
    production: {trigger: manual_approval, steps: [backup, deploy, smoke_tests, notify]}
  rollback: {trigger: deployment_failed OR manual, steps: [revert, notify, create_incident]}""" .

oc:kn_bf5da9cc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing deployment pipelines" ;
    oc:directiveContent "Always define rollback procedures alongside deployment stages — production deployments must include a manual_approval gate and a revert path." ;
    oc:hasRationale "Rollback capability is essential for rapid recovery from failed deployments and minimizing downtime." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c0559163 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring alert routing" ;
    oc:directiveContent "Use severity-based routing rules with severity-boosting for critical services (payments, auth) — these should always be escalated one level higher than default." ;
    oc:hasRationale "Critical business services require faster response times and dedicated oncall teams to prevent revenue loss and security incidents." .

oc:kn_d716a0fd a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running infrastructure automation" ;
    oc:directiveContent "Infrastructure provisioning via Terraform and configuration via Ansible should be idempotent — re-running should not create duplicate resources." ;
    oc:hasRationale "Idempotent infrastructure-as-code prevents drift and ensures consistent state across runs." .

oc:kn_d9917677 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "After incident resolution" ;
    oc:directiveContent "Structure postmortems with six mandatory sections: summary, timeline, root cause, impact, resolution, and action items with owners and due dates." ;
    oc:hasRationale "Structured postmortems ensure organizational learning and prevent recurrence of incidents." .

