                    oc:rawYaml """# ═══════════════════════════════════════════════════════════════════════════════
# CLAUDE OFFICE SKILL - Academic Search
# ═══════════════════════════════════════════════════════════════════════════════

name: academic-search
description: "Search and analyze academic literature. Find papers, understand research methodologies, and synthesize academic findings for research projects."
version: "1.0.0"
author: claude-office-skills
license: MIT

category: research
tags:
  - academic
  - papers
  - research
  - literature-review
  - citations
department: Research/Academia

models:
  recommended:
    - claude-sonnet-4
    - claude-opus-4
  compatible:
    - claude-3-5-sonnet
    - gpt-4
    - gpt-4o

mcp:
  server: office-mcp
  tools:
    - create_docx
    - extract_text_from_pdf

capabilities:
  - literature_search
  - paper_analysis
  - methodology_assessment
  - citation_management
  - research_synthesis

languages:
  - en
  - zh

related_skills:
  - deep-research
  - web-search
  - content-writer
