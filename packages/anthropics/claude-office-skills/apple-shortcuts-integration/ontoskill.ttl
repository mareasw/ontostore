                                    oc:blockType "code_block" ;
                                    oc:codeContent """notes:
  create:
    title: "Meeting Notes - {{date}}"
    folder: "Work"
    body: |
      # {{meeting_title}}
      
      ## Attendees
      {{attendees}}
      
