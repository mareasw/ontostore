oc:kn_11d63d3e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running shortcuts with input parameters" ;
    oc:directiveContent "Always validate inputs before passing them to shortcuts — invalid input types or missing required parameters will cause silent failures." ;
    oc:hasRationale "Apple Shortcuts do not always surface clear error messages; input validation prevents confusing downstream failures." ;
    oc:severityLevel "HIGH" .

oc:kn_126e333f a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When executing shortcuts that process user data" ;
    oc:directiveContent "Minimize data exposure when passing content through shortcuts — avoid sending sensitive credentials or personal data through shortcut input parameters." ;
    oc:hasRationale "Shortcuts may log input or share data across apps; minimizing exposure reduces privacy risk." ;
    oc:severityLevel "HIGH" .

oc:kn_774f2659 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When shortcut execution fails or times out" ;
    oc:directiveContent "Implement graceful failure handling for shortcuts — if a shortcut fails, provide the user with the manual steps rather than leaving them with no result." ;
    oc:hasRationale "Users rely on automation; silent failures erode trust. A fallback ensures the user can still complete their task." ;
    oc:severityLevel "MEDIUM" .

oc:kn_79e4e8c2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or naming Apple Shortcuts" ;
    oc:directiveContent "Use clear, descriptive shortcut names to ensure discoverability and maintainability." ;
    oc:hasRationale "Descriptive names prevent confusion when triggering shortcuts programmatically and make workflows self-documenting." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d5d73934 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When deploying cross-device shortcut workflows" ;
    oc:directiveContent "Shortcuts may behave differently on iOS vs macOS — always test automation workflows on all target devices before relying on them." ;
    oc:hasRationale "Apple Shortcuts has platform-specific behaviors (e.g., share sheet availability, file access) that can break workflows silently." ;
    oc:severityLevel "MEDIUM" .

