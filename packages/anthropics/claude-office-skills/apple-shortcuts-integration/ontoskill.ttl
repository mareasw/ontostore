                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """shortcut_daily_log:
  steps:
    - get_current_date
    - prompt_for_input:
        message: "How was your day?"
    - append_to_note:
        title: "Daily Journal"
        content: |
          ## {{date}}
          {{input}}
    - create_reminder:
        title: "Journal entry"
        due: tomorrow 9am
""" ;
