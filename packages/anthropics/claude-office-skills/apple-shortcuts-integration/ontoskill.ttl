                    oc:contentOrder 1 ;
                    oc:rawYaml """name: Apple Shortcuts Integration
description: Create and trigger Apple Shortcuts for iOS/macOS automation and cross-platform workflows
version: 1.0.0
author: Claude Office Skills
category: automation
tags:
  - apple
  - shortcuts
  - ios
  - macos
  - automation
department: operations
models:
  - claude-3-opus
  - claude-3-sonnet
  - gpt-4
mcp:
  server: apple-mcp
  tools:
    - shortcuts_run
    - shortcuts_list
    - reminders_create
    - notes_create
capabilities:
  - Shortcut execution
  - Reminders management
  - Notes creation
  - Calendar integration
input:
  - Shortcut names
  - Input parameters
  - Reminder details
  - Note content
output:
  - Shortcut results
  - Created items
  - Sync status
languages:
  - en
related_skills:
  - home-assistant
  - calendar-automation
  - obsidian-automation
""" ] ;
            oc:sectionLevel 0 ;
