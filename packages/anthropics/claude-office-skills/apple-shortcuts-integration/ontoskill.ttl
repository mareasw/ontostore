                                    oc:blockType "code_block" ;
                                    oc:codeContent """reminders:
  create:
    title: "{{task}}"
    list: "Work"
    due_date: "{{date}}"
    due_time: "09:00"
    priority: high
    notes: "{{details}}"
    
  query:
    list: "Shopping"
    completed: false
    
  complete:
