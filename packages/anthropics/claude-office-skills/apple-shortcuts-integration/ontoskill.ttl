                                    oc:blockType "code_block" ;
                                    oc:codeContent """shortcut_quick_capture:
  trigger: share_sheet
  steps:
    - get_shared_input
    - create_note:
        title: "Captured - {{date}}"
        body: "{{input}}"
    - notify: "Captured successfully"
""" ;
