                                    oc:blockType "code_block" ;
                                    oc:codeContent """calendar:
  create_event:
    title: "{{event_title}}"
    calendar: "Work"
    start: "{{start_time}}"
    end: "{{end_time}}"
    location: "{{location}}"
    notes: "{{notes}}"
