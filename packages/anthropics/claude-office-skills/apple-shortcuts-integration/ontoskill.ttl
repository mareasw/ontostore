                                    oc:blockType "code_block" ;
                                    oc:codeContent """shortcut_execution:
  run:
    name: "Morning Routine"
    input: optional
    
  run_with_input:
    name: "Process Text"
    input: "{{text_to_process}}"
    
  run_with_clipboard:
