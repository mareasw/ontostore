    oc:contentHash "d5369a99336f5e2ddc488ecd8f3e20f3f6b6930b812981d9eff43693e9ec9ce5" ;
    oc:dependsOnSkill oc:skill_ontoskills_lead_routing ;
    oc:differentia "orchestrates lead capture, enrichment, scoring, deal stage progression, multi-CRM synchronization, and automated sequences across HubSpot, Salesforce, and Pipedrive using n8n workflow patterns" ;
    oc:handlesFailure oc:APIRateLimitExceeded,
        oc:CRMAuthenticationFailed,
        oc:DataValidationError,
        oc:DeduplicationConflict ;
    oc:hasArgumentHint "CRM platform (hubspot|salesforce|pipedrive) and workflow type (lead-capture|deal-tracking|sync|sequence|report)" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "CRM workflow automation for HubSpot, Salesforce, Pipedrive - lead management, deal tracking, and multi-CRM synchronization" ;
    oc:hasName "crm-automation" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: crm-automation
description: "CRM workflow automation for HubSpot, Salesforce, Pipedrive - lead management, deal tracking, and multi-CRM synchronization"
version: "1.0.0"
author: claude-office-skills
license: MIT

category: sales
tags:
  - crm
  - hubspot
  - salesforce
  - automation
  - lead-management
department: Sales

models:
  recommended:
    - claude-sonnet-4
    - claude-opus-4
  compatible:
    - gpt-4
    - gpt-4o

mcp:
  server: crm-mcp
  tools:
    - hubspot_create_contact
    - hubspot_update_deal
    - salesforce_query
    - pipedrive_sync
    - enrichment_api

capabilities:
  - lead_capture
  - deal_tracking
  - pipeline_management
  - multi_crm_sync
  - automated_outreach

languages:
  - en
  - zh

related_skills:
  - lead-routing
  - sales-pipeline
  - email-drafter
  - proposal-writer
""" ] ;
