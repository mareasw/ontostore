oc:kn_0d359570 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Ongoing CRM maintenance" ;
    oc:directiveContent "Enforce data hygiene: deduplicate weekly via email_match + company_fuzzy_match, validate emails on creation, enrich missing fields daily, archive stale records after 180 days of inactivity." ;
    oc:hasRationale "Poor data hygiene compounds over time, leading to failed outreach, wasted sequences, and inaccurate reporting" .

oc:kn_47f4adac a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring lead scoring models" ;
    oc:directiveContent "Use rule-based scoring as baseline (MQL=50, SQL=75, Hot=90) and AI scoring for edge cases where demographic/behavioral rules alone are insufficient." ;
    oc:hasRationale "Pure rule-based scoring misses nuanced buying signals; pure AI scoring lacks transparency and consistency for high-volume leads" .

oc:kn_4ed66a87 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Lead capture to CRM workflow" ;
    oc:directiveContent "1. Capture lead from webhook/form → 2. Enrich with Clearbit (append company_size, industry, title, linkedin) → 3. Score (rule-based or AI, threshold 50 for MQL) → 4. Route to team based on score+industry → 5. Create in CRM → 6. Start welcome sequence if score >= 50" ;
    oc:stepOrder 1 .

oc:kn_73551519 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "Always when handling CRM data with PII" ;
    oc:directiveContent "Rotate API keys quarterly, enforce role-based access control, maintain audit logs of all changes, encrypt PII at rest, and track GDPR consent." ;
    oc:hasRationale "CRM data contains sensitive PII subject to GDPR, CCPA, and SOC 2 compliance requirements" .

oc:kn_7b43e307 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating contacts in any CRM" ;
    oc:directiveContent "Never skip lead deduplication before CRM creation. Use email as unique key with a fuzzy match similarity threshold of 0.85 for company name matching." ;
    oc:hasRationale "Duplicate records fragment communication history, inflate pipeline metrics, and cause inconsistent outreach" ;
    oc:severityLevel "HIGH" .

oc:kn_9b408456 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring multi-CRM synchronization" ;
    oc:directiveContent "Multi-CRM sync requires a designated master system per entity type (e.g., HubSpot for contacts, Salesforce for deals) with most_recent_wins conflict resolution." ;
    oc:hasRationale "Without a master system, sync conflicts create data corruption and orphaned records across platforms" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b2c86e7d a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When configuring sync frequencies" ;
    oc:directiveContent "Multi-CRM sync of contacts should be real-time; deal sync should run every 15 minutes; activity aggregation to Google Sheets is batch-oriented." ;
    oc:hasRationale "Over-aggressive sync frequencies consume API rate limits without proportional data freshness benefit" .

oc:kn_c6efce0f a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When monitoring deal pipeline health" ;
    oc:directiveContent "Deals stuck in contract_sent stage for 14+ days require manager escalation alerts and a scheduled re-engagement at 90 days if closed_lost." ;
    oc:hasRationale "Stale deals inflate forecasts and hide pipeline risk; early escalation improves recovery rates" .

oc:kn_dce7d6d6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When routing scored leads to sales teams" ;
    oc:directiveContent "Route leads immediately after scoring: score >= 80 + tech industry → Enterprise Team; score >= 50 → SMB Team; below threshold → Marketing Nurture." ;
    oc:hasRationale "Delayed routing causes response time decay — leads contacted within 5 minutes are 9x more likely to convert" .

_:ref_18768e84dacb3cd9 a oc:WorkflowStep ;
    dcterms:description "Score lead using rule-based or AI model against threshold (MQL=50)" ;
    oc:expectedOutcome "Lead score between 0-100 with classification" ;
    oc:stepDependsOn _:ref_9c193a0823566c2b ;
    oc:stepId "score" .

_:ref_1c960090a5f8236f a oc:WorkflowStep ;
    dcterms:description "Resolve conflicts using most_recent_wins strategy with designated master per entity" ;
    oc:expectedOutcome "Conflict-free canonical records" ;
    oc:stepDependsOn _:ref_c112c4f5eddee402 ;
    oc:stepId "resolve-conflicts" .

_:ref_2c1c8f1472ef9116 a oc:WorkflowStep ;
