oc:kn_0a6fd430 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when using this skill" ;
    oc:directiveContent "Cannot perform actual file operations — this skill provides guidance and plans only, not direct file manipulation." ;
    oc:hasRationale "The skill is advisory; actual operations require MCP tools or external software." ;
    oc:severityLevel "HIGH" .

oc:kn_233de266 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When merging PDFs that have mixed page dimensions (letter, A4, landscape, portrait)" ;
    oc:directiveContent "Merging PDFs with different page sizes may cause layout issues in the output file." ;
    oc:hasRationale "PDF renderers may not automatically normalize page sizes, leading to inconsistent output." ;
    oc:severityLevel "MEDIUM" .

oc:kn_26cbfe02 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering PDFs with owner-level restrictions" ;
    oc:directiveContent "PDFs with DRM or usage restrictions cannot be modified regardless of password access." ;
    oc:hasRationale "DRM restrictions are enforced at the PDF specification level and prevent page extraction or merging." ;
    oc:severityLevel "HIGH" .

oc:kn_8c2af74c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When splitting large PDFs by size target" ;
    oc:directiveContent "When splitting by file size, estimate ~10 splits per 250 MB with a 25 MB target, adjusting based on actual page content density." ;
    oc:hasRationale "Page content varies, so size estimates are approximate and need verification after split." ;
    oc:severityLevel "LOW" .

oc:kn_9ec2a8ba a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing encrypted or password-protected PDFs" ;
    oc:directiveContent "Password-protected PDFs must be unlocked before merge/split operations can proceed." ;
    oc:hasRationale "Encrypted PDFs block read/write operations needed for page manipulation." ;
    oc:severityLevel "HIGH" .

oc:kn_ca802a61 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any merge operation" ;
    oc:directiveContent "Before merging, verify all input files exist, are not password-protected, and list their page counts and sizes to plan the output." ;
    oc:hasRationale "Pre-merge validation prevents partial failures and ensures predictable output." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d931823a a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When processing PDFs over ~100 MB or 500+ pages" ;
    oc:directiveContent "Very large PDF files may require chunked processing to avoid memory issues." ;
    oc:hasRationale "Large files can exceed available memory in a single operation." ;
    oc:severityLevel "MEDIUM" .

