    oc:dependsOnSkill oc:skill_ontoskills_office_mcp ;
    oc:differentia "that produces structured investment memorandums for VC, PE, and public market investment committees with thesis, risk, and returns analysis" ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput ;
    oc:hasArgumentHint "investment-context and due-diligence findings" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Write professional investment memorandums for VC, PE, or public market investments. Structure thesis, risks, and recommendations clearly." ;
    oc:hasName "investment-memo" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """# ═══════════════════════════════════════════════════════════════════════════════
# CLAUDE OFFICE SKILL - Investment Memo
# ═══════════════════════════════════════════════════════════════════════════════

name: investment-memo
description: "Write professional investment memorandums for VC, PE, or public market investments. Structure thesis, risks, and recommendations clearly."
version: "1.0.0"
author: claude-office-skills
license: MIT

category: finance
tags:
  - investment
  - memo
  - venture-capital
  - private-equity
  - analysis
department: Finance/Investment

models:
  recommended:
    - claude-sonnet-4
    - claude-opus-4
  compatible:
    - claude-3-5-sonnet
    - gpt-4
    - gpt-4o

mcp:
  server: office-mcp
  tools:
    - create_docx
    - fill_docx_template
    - docx_to_pdf

capabilities:
  - investment_thesis_writing
  - risk_analysis
  - deal_structuring
  - recommendation_synthesis
  - memo_formatting

languages:
  - en
  - zh

related_skills:
  - dcf-valuation
  - company-research
  - stock-analysis
""" ] ;
