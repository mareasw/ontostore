    oc:appliesToContext "When creating Stripe checkout sessions for subscriptions" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent "const session = await stripe.checkout.sessions.create({ mode: 'subscription', payment_method_types: ['card'], line_items: [{ price: 'price_xxx', quantity: 1 }], success_url: 'https://example.com/success?session_id={CHECKOUT_SESSION_ID}', cancel_url: 'https://example.com/cancel', subscription_data: { trial_period_days: 14, metadata: { plan_tier: 'growth' } } });" .

oc:kn_7ee61ad4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building checkout or payment forms" ;
    oc:directiveContent "Use Stripe Elements for collecting card data — never handle raw card numbers directly." ;
    oc:hasRationale "PCI DSS compliance requires that sensitive card data never touches your servers; Stripe Elements keeps it in Stripe's iframe." ;
    oc:severityLevel "HIGH" .

oc:kn_a9c662e2 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When setting up fraud prevention" ;
    oc:directiveContent "Configure Stripe Radar rules to block highest-risk transactions and review elevated-risk ones, including disposable email and country mismatch checks." ;
    oc:hasRationale "Automated fraud rules catch common attack patterns before they result in chargebacks." ;
    oc:severityLevel "HIGH" .

oc:kn_baaad967 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing any Stripe integration" ;
    oc:directiveContent "1. Use webhooks for payment confirmation 2. Add idempotency keys to prevent duplicates 3. Handle errors gracefully 4. Use Stripe Elements for PCI compliance 5. Test in test mode first 6. Monitor disputes promptly 7. Implement dunning for failed payments 8. Track MRR for revenue recognition" ;
    oc:stepOrder 1 .

oc:kn_c5fc88e6 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before making any changes to payment flows, subscription plans, or webhook handlers" ;
    oc:directiveContent "Always validate in Stripe test mode before deploying to production." ;
    oc:hasRationale "Test mode catches integration bugs without risking real transactions or customer impact." ;
    oc:severityLevel "HIGH" .

oc:kn_fb58ba14 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing subscription management systems" ;
    oc:directiveContent "Structure subscription lifecycle with explicit handlers for create, upgrade, downgrade, cancel, and renewal events, each with automated side effects." ;
    oc:hasRationale "Explicit event-driven handlers ensure no orphaned state (e.g., access not provisioned, billing not prorated)." ;
    oc:severityLevel "MEDIUM" .

