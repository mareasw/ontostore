    oc:directiveContent "const subscription = await stripe.subscriptions.create({ customer: customer.id, items: [{ price: 'price_xxx' }], trial_period_days: 14, payment_behavior: 'default_incomplete', expand: ['latest_invoice.payment_intent'] });" .

oc:kn_34924319 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any Stripe charge or payment intent" ;
    oc:directiveContent "Always use idempotency keys when creating charges or payment intents to prevent duplicate transactions." ;
    oc:hasRationale "Network retries or race conditions can cause duplicate charges without idempotency protection." ;
    oc:severityLevel "CRITICAL" .

oc:kn_38b65d2e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring failed payment recovery" ;
    oc:directiveContent "Implement a progressive dunning sequence: retry at day 0, 3, 7, 14, then cancel at day 30, with escalating communication at each step." ;
    oc:hasRationale "Progressive dunning maximizes recovery while respecting customer experience; most recoveries happen in first 7 days." ;
    oc:severityLevel "MEDIUM" .

oc:kn_43b5ef2f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing Stripe checkout or payment flows" ;
    oc:directiveContent "Never rely on redirect URLs alone to confirm payment success — always use webhook handlers to verify payment state." ;
    oc:hasRationale "Redirects can be bypassed or fail silently; webhooks provide authoritative, asynchronous confirmation from Stripe." ;
    oc:severityLevel "CRITICAL" .

