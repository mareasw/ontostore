oc:kn_009d7c3b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing pipeline stages" ;
    oc:directiveContent "Keep each pipeline stage focused on a single responsibility — one operation per stage." ;
    oc:hasRationale "Single-responsibility stages are easier to debug, test, and reuse across different pipelines." ;
    oc:severityLevel "HIGH" .

oc:kn_2378acc7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating reusable pipelines" ;
    oc:directiveContent "Make pipelines configurable via YAML/JSON declarations rather than hardcoding operations." ;
    oc:hasRationale "Declarative configuration enables non-technical users to modify pipelines and promotes reuse across projects." ;
    oc:severityLevel "MEDIUM" .

oc:kn_289dc39d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing pipeline architecture" ;
    oc:directiveContent "Do not build monolithic stages that perform multiple unrelated operations." ;
    oc:hasRationale "Monolithic stages reduce reusability, make debugging harder, and prevent conditional branching." ;
    oc:severityLevel "HIGH" .

oc:kn_3171431c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any pipeline" ;
    oc:directiveContent "Use intermediate outputs between stages for debugging and error isolation." ;
    oc:hasRationale "Intermediate outputs allow inspection of data at each stage, making it possible to identify which stage introduced errors." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a040f363 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing stage operations" ;
    oc:directiveContent "Pipeline stages should be designed to be idempotent where possible — re-running a stage with the same input should produce the same output." ;
    oc:hasRationale "Idempotent stages enable safe retries and pipeline resumption without side effects." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b6142af6 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On pipeline execution failure" ;
    oc:directiveContent "Implement stage-level error handling so one failing stage doesn't destroy the entire pipeline's intermediate data." ;
    oc:hasRationale "Stage-level isolation allows partial results to be preserved and the pipeline to be resumed from the failure point." ;
    oc:severityLevel "HIGH" .

