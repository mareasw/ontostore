                                    oc:blockType "code_block" ;
                                    oc:codeContent """tweet_config:
  types:
    single:
      max_chars: 280
      media_limit: 4
      
    thread:
      tweets_per_thread: 10  # recommended max
      continuation_style: "numbered"  # or emoji
      
    poll:
      options: 4  # max
      duration_hours: 24
      
  best_practices:
    - Hook in first line
    - Use line breaks
    - Include CTA
    - Optimal hashtags: 1-2
    - Media increases engagement 3x
""" ;
