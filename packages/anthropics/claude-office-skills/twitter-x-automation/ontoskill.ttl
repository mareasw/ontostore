oc:kn_a72f563f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any automation rules" ;
    oc:directiveContent "Never post duplicate content, use automated bulk unfollowing, or skip disclosure for sponsored content. Authentic engagement only." ;
    oc:hasRationale "Twitter actively penalizes inauthentic behavior and can permanently suspend accounts" ;
    oc:severityLevel "HIGH" .

oc:kn_a934c464 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running any automated Twitter workflows" ;
    oc:directiveContent "Twitter API rate limits: 2400 tweets/day, 1000 DMs/day, 400 follows/day. No automated bulk unfollowing or duplicate content posting." ;
    oc:hasRationale "Violating rate limits or automation rules can result in account suspension" ;
    oc:severityLevel "CRITICAL" .

oc:kn_da956580 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing tweet threads or single tweets" ;
    oc:directiveContent "Thread structure: tweet 1 = hook with thread emoji, tweets 2-8 = numbered body points, tweet 9 = TL;DR summary, tweet 10 = CTA with follow/RT ask. Single tweets should have a hook in the first line, line breaks, and a CTA." ;
    oc:hasRationale "Structured threads outperform unstructured ones; hooks drive 3x more thread completion" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e618a1f9 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When running the full Twitter content pipeline" ;
    oc:directiveContent "1. Source content ideas from trends and calendar 2. Create tweet copy with media and hashtags 3. Schedule at optimal posting times 4. Publish as single tweet or thread 5. Engage with replies and retweets 6. Track analytics and iterate" ;
    oc:stepOrder 1 .

oc:kn_e9128a62 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When integrating with Twitter API v2 for posting, threading, or searching" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const tweet = await twitter.v2.tweet({ text: "Hello, Twitter! 🚀" });
const thread = await twitter.v2.tweetThread([
  { text: "Tweet 1 🧵" },
  { text: "Tweet 2" }
]);
const results = await twitter.v2.search({
  query: "#buildinpublic -is:retweet",
  max_results: 100,
  "tweet.fields": ["created_at", "public_metrics"]
});""" .

