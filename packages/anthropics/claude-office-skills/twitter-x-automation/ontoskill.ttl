                                    oc:blockType "code_block" ;
                                    oc:codeContent """thread_template:
  - tweet: 1
    role: hook
    content: |
      {{attention_grabbing_statement}}
      
      A thread 🧵
      
  - tweet: 2-8
    role: body
    content: |
      {{number}}. {{point}}
      
      {{explanation}}
      
  - tweet: 9
    role: summary
    content: |
      TL;DR:
      
      {{key_takeaways}}
      
  - tweet: 10
    role: cta
    content: |
      If you found this helpful:
      
      1. Follow @{{handle}} for more
      2. RT the first tweet
      3. {{specific_cta}}
""" ;
