oc:kn_2c734d70 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or configuring any tweet content" ;
    oc:directiveContent "Single tweets have a 280 character limit and a maximum of 4 media attachments. Threads should be capped at 10 tweets. Polls support up to 4 options." ;
    oc:hasRationale "Exceeding these platform limits causes tweet failures or truncation" ;
    oc:severityLevel "CRITICAL" .

oc:kn_6c6ecd3a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning weekly content strategy" ;
    oc:directiveContent "Weekly content calendar: Monday=inspirational, Tuesday=educational, Wednesday=insights, Thursday=threads, Friday=casual, Weekend=questions/polls." ;
    oc:hasRationale "Thematic consistency builds audience expectations and improves retention" ;
    oc:severityLevel "LOW" .

oc:kn_7f354368 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scheduling and optimizing tweet content" ;
    oc:directiveContent "Use 1-2 hashtags per tweet placed at the end. Media increases engagement 3x. Post during peak hours (weekday 08:00, 12:00, 17:00, 21:00 EST). Maintain a content mix of 60% original, 25% replies, 15% retweets." ;
    oc:hasRationale "These practices maximize engagement based on platform behavior data" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8dd58046 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating analytics and planning content" ;
    oc:directiveContent "Industry average engagement rate is 1.5%. Threads are the most engaging content type (45% of engagement). Best engagement day is Tuesday; worst is Saturday." ;
    oc:hasRationale "Benchmarks help assess whether content strategy is performing above or below expectations" ;
    oc:severityLevel "MEDIUM" .

