oc:skill_claude_office_skills_podcast_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "podcast-automation" ;
    skos:broader "Workflow automation" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/claude-office-skills/podcast-automation" ;
