    oc:dependsOnSkill oc:skill_ontoskills_social_publisher,
        oc:skill_ontoskills_transcription_automation ;
    oc:differentia "Orchestrates the full podcast production pipeline from recording through editing, publishing, and multi-platform distribution with audio processing, RSS feed management, and guest coordination" ;
    oc:handlesFailure oc:AudioProcessingError,
        oc:DistributionFailed,
        oc:RSSValidationError ;
    oc:hasCategory "multimedia" ;
    oc:hasDescription "Automate podcast production workflows including recording, editing, publishing, and distribution" ;
    oc:hasName "podcast-automation" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Comprehensive skill for automating podcast production and distribution." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """show_notes_template:
  format: markdown
  
  structure: |
    # {{episode_title}}
    
    ## Episode {{number}} | Season {{season}}
    
    **Published:** {{publish_date}}
    **Duration:** {{duration}}
    
    ## Summary
    {{summary}}
    
    ## Guest
    {{#if guest}}
    **{{guest.name}}** - {{guest.title}}
    - Website: {{guest.website}}
    - Twitter: {{guest.twitter}}
    - LinkedIn: {{guest.linkedin}}
    {{/if}}
    
    ## Timestamps
    {{#each chapters}}
    - {{this.start}} - {{this.title}}
    {{/each}}
    
    ## Key Takeaways
    {{#each takeaways}}
    - {{this}}
    {{/each}}
    
    ## Resources Mentioned
    {{#each resources}}
    - [{{this.title}}]({{this.url}})
    {{/each}}
    
    ## Subscribe
    - [Apple Podcasts]({{apple_url}})
    - [Spotify]({{spotify_url}})
    - [RSS Feed]({{rss_url}})
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 195-237" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Episode Notes" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Show Notes Template" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """mastering_config:
  loudness:
    target: -16 LUFS
    range: 8 LU
    true_peak: -1 dBTP
    
  eq_settings:
    high_pass: 80Hz
    presence_boost: +2dB @ 3kHz
    air: +1dB @ 12kHz
    
  dynamics:
    compressor:
      ratio: 3:1
      attack: 10ms
      release: 100ms
    limiter:
      ceiling: -1dB
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 170-189" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Mastering Template" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """audio_processing:
  input:
    format: wav
    channels: stereo
    
  processing:
    - step: noise_reduction
      threshold: -30db
      
    - step: normalization
      target_lufs: -16
      
    - step: compression
      ratio: 4:1
      threshold: -20db
      
    - step: eq
      preset: voice_enhance
      
    - step: add_intro
      file: "intro.mp3"
      fade_in: 2s
      
    - step: add_outro
      file: "outro.mp3"
      fade_out: 3s
      
  output:
    format: mp3
    bitrate: 128kbps
    filename: "{{show}}_E{{number}}.mp3"
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 134-166" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Processing Pipeline" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Audio Processing" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """guest_workflow:
  outreach:
    template: |
      Hi {{guest_name}},
      
      I'm the host of {{podcast_name}}, a podcast about {{topic}}.
      
      I'd love to have you on to discuss {{proposed_topic}}.
      
      Our audience is {{audience_description}}.
      
      Would you be interested?
      
  scheduling:
    tool: calendly
    duration: 60_minutes
    buffer: 15_minutes
    
  pre_interview:
    send_days_before: 3
    includes:
      - recording_guide
      - topic_outline
      - tech_requirements
      - consent_form
      
  post_interview:
    - send_thank_you
    - share_publish_date
    - provide_promotional_assets
    - request_share
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 397-429" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Guest Workflow" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Guest Management" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """episode_config:
  metadata:
    title: "{{episode_title}}"
    episode_number: "{{number}}"
    season: "{{season}}"
    description: "{{description}}"
    
  audio:
    file: "episode_{{number}}.mp3"
    format: mp3
    bitrate: 128kbps
    sample_rate: 44100
    
  settings:
    explicit: false
    episode_type: full  # full, trailer, bonus
    
  chapters:
    - start: "00:00:00"
      title: "Introduction"
    - start: "00:02:30"
      title: "Main Topic"
    - start: "00:45:00"
      title: "Q&A"
    - start: "00:55:00"
      title: "Wrap Up"
      
  links:
    - title: "Show Notes"
      url: "{{show_notes_url}}"
    - title: "Guest's Website"
      url: "{{guest_url}}"
""" ;
                                    oc:codeLanguage "yaml" ;
