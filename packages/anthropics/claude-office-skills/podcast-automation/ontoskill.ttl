oc:kn_090f9525 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When regenerating RSS feeds" ;
    oc:directiveContent "RSS feed updates are idempotent — re-running feed generation produces identical output for same input" ;
    oc:hasRationale "Prevents duplicate entries and ensures feed validators don't flag inconsistent state" .

oc:kn_116528cf a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running the audio processing pipeline" ;
    oc:directiveContent "Audio processing pipeline must execute in order: noise reduction → normalization → compression → EQ → add intro/outro" ;
    oc:hasRationale "Order matters — compression before normalization produces different results; EQ should come after dynamics processing" ;
    oc:severityLevel "HIGH" .

oc:kn_21a3969c a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before initiating episode publishing" ;
    oc:directiveContent "Verify audio file exists, metadata is complete, and distribution platform credentials are configured before publishing" ;
    oc:hasRationale "Catching missing files or credentials early prevents partial publishes and feed corruption" .

oc:kn_2f8a1666 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing raw podcast recordings" ;
    oc:directiveContent "Never skip the normalization and noise reduction steps before publishing audio" ;
    oc:hasRationale "Poor audio quality is the #1 reason listeners abandon podcasts" ;
    oc:severityLevel "CRITICAL" .

oc:kn_3ec46219 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When including sponsorships or affiliate links in episodes" ;
    oc:directiveContent "Affiliate disclosures are required for all monetized content placements" ;
    oc:hasRationale "FTC regulations require disclosure of paid endorsements and affiliate relationships" ;
    oc:severityLevel "HIGH" .

oc:kn_4e74bb00 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mastering podcast audio for distribution" ;
    oc:directiveContent "Target loudness of -16 LUFS with true peak at -1 dBTP for podcast audio mastering" ;
    oc:hasRationale "Ensures consistent loudness across platforms and meets Apple/Spotify loudness standards" ;
    oc:severityLevel "HIGH" .

oc:kn_e4fbef3a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When planning episode releases" ;
    oc:directiveContent "Maintain a consistent publishing schedule — same day and time each week" ;
    oc:hasRationale "Algorithm favor and listener habit formation depend on regular publishing cadence" ;
    oc:severityLevel "HIGH" .

oc:kn_e7295e29 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When distributing to video platforms" ;
    oc:directiveContent "Generate 3-5 clips of 60 seconds each from best moments for YouTube video distribution" ;
    oc:hasRationale "Short clips drive discovery and conversion better than full episodes on video platforms" ;
    oc:severityLevel "MEDIUM" .

