oc:kn_07b87ec4 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Converting Markdown to PowerPoint" ;
    oc:directiveContent "1. Verify marp CLI is installed. 2. Write Markdown content with `---\\nmarp: true` frontmatter. 3. Separate slides with `---`. 4. Optionally set theme, size, paginate, header, footer in frontmatter. 5. Run `marp input.md -o output.pptx`." ;
    oc:stepOrder 1 .

oc:kn_629bd4b8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring multi-slide presentations" ;
    oc:directiveContent "Use `---` (horizontal rule) to separate slides, and use the `_class: lead` local directive with `<!-- _class: lead -->` HTML comments for centered title slides." ;
    oc:hasRationale "The lead class provides a centered layout ideal for title and closing slides, creating visual bookends for the presentation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_995582cd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying themes or per-slide customization" ;
    oc:directiveContent "Use built-in themes (default, gaia, uncover) and local directives (prefixed with `_`) to control per-slide styling without affecting the global theme." ;
    oc:hasRationale "Local directives (e.g., `_backgroundColor`, `_paginate`) allow slide-level overrides while maintaining global theme consistency." ;
    oc:severityLevel "LOW" .

oc:kn_9e512276 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user requests advanced PowerPoint features like animations or embedded video" ;
    oc:directiveContent "Complex animations, video embedding, custom fonts (without CSS config), and many PowerPoint-specific features are not supported by Marp conversion." ;
    oc:hasRationale "Marp is a Markdown-to-slides converter, not a full PowerPoint editor; exceeding its capabilities requires direct PPTX manipulation tools." ;
    oc:severityLevel "HIGH" .

oc:kn_ad526c1d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When designing or generating slide content" ;
    oc:directiveContent "Keep slides focused: one idea per slide, maximum 6 bullet points, consistent heading levels, and include visual content for retention." ;
    oc:hasRationale "Following presentation design best practices ensures readable, impactful slides that communicate effectively." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b25a7fb3 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running any Marp conversion" ;
    oc:directiveContent "Verify Marp CLI is installed (`marp --version`) before attempting conversion. Install via `npm install -g @marp-team/marp-cli` or `brew install marp-cli`." ;
    oc:hasRationale "Marp CLI must be available on the system; conversion will fail with a command-not-found error if not installed." ;
    oc:severityLevel "HIGH" .

oc:kn_be45d103 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Marp-compatible Markdown from scratch" ;
    oc:directiveContent "Do not forget to include the `---\\nmarp: true` frontmatter directive at the top of the Markdown file; without it, Marp will not process the file as a presentation." ;
    oc:hasRationale "The marp: true directive activates Marp processing. Omitting it results in plain Markdown rendering with no slide separation." ;
    oc:severityLevel "CRITICAL" .

