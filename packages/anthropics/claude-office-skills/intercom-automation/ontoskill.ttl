oc:kn_3eed31ba a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When relying on keyword-based routing rules" ;
    oc:directiveContent "Bot triage can misclassify complex or ambiguous user intents, leading to incorrect routing." ;
    oc:hasRationale "Keyword matching is brittle; multi-language support and nuanced queries require escalation paths." ;
    oc:severityLevel "MEDIUM" .

oc:kn_56d40756 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up campaign timing and message delays" ;
    oc:directiveContent "Consider user timezone when scheduling messages and campaigns — use time-appropriate delivery windows." ;
    oc:hasRationale "Sending messages at inappropriate times reduces open rates and can annoy users." ;
    oc:severityLevel "MEDIUM" .

oc:kn_61312ced a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring messaging campaigns or automations" ;
    oc:directiveContent "Never over-message users — respect frequency limits to avoid customer fatigue and unsubscribes." ;
    oc:hasRationale "Excessive messaging leads to lower engagement rates, customer frustration, and potential opt-outs." ;
    oc:severityLevel "HIGH" .

oc:kn_8ac88285 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring bot responses and conversation routing" ;
    oc:directiveContent "Know when to escalate from bot to human agent — use intent detection and routing rules to determine when automated responses are insufficient." ;
    oc:hasRationale "Forcing bot responses for complex issues degrades customer experience; timely escalation improves CSAT scores." .

oc:kn_8d055b47 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When setting up Intercom automation end-to-end" ;
    oc:directiveContent "1. Define segments based on user attributes and behavior 2. Create automation rules with triggers, conditions, and actions 3. Configure bot responses with intent patterns and escalation paths 4. Set up conversation routing by topic and priority 5. Build messaging campaigns with timed multi-channel sequences 6. Integrate with CRM/Slack for cross-platform workflows 7. Track metrics and optimize" ;
    oc:stepOrder 1 .

oc:kn_a82a81d5 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before executing any Intercom automation" ;
    oc:directiveContent "Requires access to the helpdesk-mcp server with Intercom tools (intercom_message, intercom_user, intercom_conversation, intercom_articles) configured." .

oc:kn_ca7d7d5f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing any automated message" ;
    oc:directiveContent "Always personalize messages using user attributes like {{first_name}}, {{company_name}}, and custom attributes." ;
    oc:hasRationale "Personalized messages have significantly higher open and engagement rates compared to generic ones." .

oc:kn_e6f0e990 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "After launching any campaign or automation" ;
    oc:directiveContent "A/B test message content and track key metrics (open rate, CTR, tour completion, bot resolution) to continuously optimize." ;
    oc:hasRationale "Data-driven optimization outperforms assumptions about what messaging works best." .

oc:kn_f145ff6e a oc:CodePattern,
