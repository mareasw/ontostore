oc:kn_3286a65f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When transcribing audio with background noise or files over 30 minutes" ;
    oc:directiveContent "Never skip pre-processing (convert, enhance, split) on noisy or long audio files before transcription." ;
    oc:hasRationale "Poor audio quality directly degrades WER; splitting long files avoids memory limits and improves timestamp accuracy." ;
    oc:severityLevel "HIGH" .

oc:kn_4820ae48 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using OpenAI Whisper API for transcription with timestamps" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import openai

with open("meeting.mp3", "rb") as audio_file:
    transcript = openai.Audio.transcribe(
        model="whisper-1",
        file=audio_file,
        response_format="verbose_json",
        timestamp_granularities=["word", "segment"]
    )

for segment in transcript.segments:
    print(f"[{segment.start:.2f}] {segment.text}")""" ;
    oc:hasRationale "OpenAI Whisper provides high-quality transcription with word and segment level granularity." .

oc:kn_49735a3e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any transcription job" ;
    oc:directiveContent "Choose the Whisper model size based on the speed vs accuracy tradeoff: tiny/base for quick drafts, medium for balanced, large for production-quality transcription." ;
    oc:hasRationale "Larger models yield lower Word Error Rate but increase processing time significantly; the 'large' model is recommended for multilingual or critical content." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5e1fca39 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating quality reports for transcription jobs" ;
    oc:directiveContent """TRANSCRIPTION QUALITY REPORT
═══════════════════════════════════════

File: {filename}
Duration: {duration}
Engine: {engine}

METRICS:
Word Error Rate (WER):  {wer}%
Character Error Rate:   {cer}%
Confidence Score:       {confidence}

SPEAKER DIARIZATION:
Speakers Detected: {speaker_count}
Diarization Accuracy: {diarization_accuracy}%

PROCESSING TIME:
Total: {processing_time}
Real-time Factor: {rtf}x

DETECTED ISSUES:
• {issues}""" ;
    oc:hasRationale "Quality metrics enable SLA monitoring and help identify systematic transcription problems." ;
    oc:templateVariables "cer",
        "confidence",
        "diarization_accuracy",
        "duration",
        "engine",
        "filename",
        "issues",
        "processing_time",
        "rtf",
        "speaker_count",
        "wer" .

oc:kn_60fe3f55 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When transcribing meetings, podcasts, or interviews with 2+ speakers" ;
    oc:directiveContent "Always enable speaker diarization for multi-person recordings and word-level timestamps for searchable archives." ;
    oc:hasRationale "Speaker attribution transforms raw text into actionable meeting notes and enables accurate action item assignment." ;
    oc:severityLevel "MEDIUM" .

oc:kn_646937cf a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After every transcription job completes" ;
    oc:directiveContent "After transcription, verify: output file exists and is non-empty, confidence score above threshold (e.g., 0.85), speaker count matches expected, and no unresolved unknown-speaker segments." ;
    oc:hasRationale "Silent failures (empty output, corrupted timestamps) are more common than explicit errors in transcription pipelines." ;
    oc:severityLevel "HIGH" .

