        "title" .

oc:kn_83656fbb a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using AssemblyAI for speaker-diarized transcription" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import assemblyai as aai

transcriber = aai.Transcriber()
config = aai.TranscriptionConfig(
    speaker_labels=True,
    auto_chapters=True,
    entity_detection=True
)
transcript = transcriber.transcribe(url, config=config)
for utterance in transcript.utterances:
    print(f"Speaker {utterance.speaker}: {utterance.text}")""" ;
    oc:hasRationale "AssemblyAI provides built-in speaker diarization and chapter detection that simplifies multi-speaker transcription." .

oc:kn_9b2b2375 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing any transcription pipeline" ;
    oc:directiveContent "1. Receive audio/video input → 2. Pre-process (convert to WAV mono 16kHz, enhance, split if long) → 3. Run STT engine with diarization → 4. Post-process (punctuation, cleanup, formatting) → 5. Generate output formats (TXT/SRT/VTT/JSON) → 6. Quality check (WER, confidence scores) → 7. Distribute to destinations" ;
    oc:hasRationale "This ordered pipeline ensures consistent quality from raw input to distributed output." ;
    oc:stepOrder 1 .

oc:kn_b8a0e8f4 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On transcription quality verification" ;
    oc:directiveContent "When WER exceeds acceptable thresholds (>5%), flag low-confidence segments for human review and check for background noise or overlapping speech at flagged timestamps." ;
    oc:hasRationale "Automated transcription accuracy degrades predictably with noise and overlap; flagging enables targeted human correction." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d5eb8d03 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When processing meeting recordings, medical dictations, or legal proceedings" ;
    oc:directiveContent "Audio and video content may contain sensitive, confidential, or personally identifiable information; handle with privacy controls and avoid storing raw audio longer than necessary." ;
    oc:hasRationale "Transcription pipelines process full speech content which may include PII, trade secrets, or privileged communications." ;
    oc:severityLevel "HIGH" .

oc:kn_e2b15daa a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating SRT subtitle files" ;
    oc:directiveContent "SRT subtitles must respect max 7 seconds per subtitle, 42 chars per line, and max 2 lines per cue." ;
    oc:hasRationale "These are broadcast-standard constraints ensuring readability across all player implementations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e741b5a0 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running any STT engine" ;
    oc:directiveContent "Audio input should be converted to WAV format, mono channel, 16kHz sample rate before transcription for best results." ;
    oc:hasRationale "Most STT engines (Whisper, AssemblyAI) are optimized for 16kHz mono WAV; other formats may introduce resampling artifacts." .

