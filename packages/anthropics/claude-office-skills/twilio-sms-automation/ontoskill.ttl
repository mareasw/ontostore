oc:kn_0f23cc0c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sending bulk or high-volume SMS" ;
    oc:directiveContent "Use Messaging Service SID (MG...) instead of direct phone numbers for high-throughput sending; use batch_size of 100 with 60-second delays between batches for bulk campaigns." ;
    oc:hasRationale "Messaging Services handle intelligent routing, auto-scaling, and compliance; batching prevents rate limit errors." ;
    oc:severityLevel "HIGH" .

oc:kn_1afdf310 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When handling verification check failures" ;
    oc:directiveContent "For 2FA verification failures: allow max 5 attempts with 30-minute lockout; verification codes expire in 10 minutes." ;
    oc:hasRationale "Balancing security (limited attempts, short expiry) with user experience (reasonable retry window)." ;
    oc:severityLevel "MEDIUM" .

oc:kn_200b1023 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Twilio account with Account SID and Auth Token; messaging service SID or purchased phone number; webhook endpoint for incoming messages (for two-way)." .

oc:kn_336aa6d4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before sending messages to new numbers" ;
    oc:directiveContent "Validate phone numbers using the Lookup API before sending to check format, carrier, line type (mobile vs landline), and active status." ;
    oc:hasRationale "Invalid or landline numbers waste message credits and increase failure rates; pre-validation improves delivery rates to 96%+." ;
    oc:severityLevel "MEDIUM" .

oc:kn_42b4cc57 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When verifying 2FA codes" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const check = await twilio.verify.v2
  .services('VA...')
  .verificationChecks
  .create({ to: '+1234567890', code: '123456' });
if (check.status === 'approved') { /* verified */ }""" ;
    oc:hasRationale "Standard Twilio Verify API pattern for checking user-submitted verification codes." .

oc:kn_602a9ff9 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When executing any send operation" ;
    oc:directiveContent "Sending SMS/Voice calls incurs per-message costs (~$0.0275/message US); bulk campaigns can generate significant spend." ;
    oc:hasRationale "Cost awareness prevents unexpected billing; monitor spend per campaign and per-message." ;
    oc:severityLevel "MEDIUM" .

oc:kn_66016bf1 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing 2FA verification" ;
    oc:directiveContent "1. Start verification via Verify API (channel: sms/call) 2. User receives code 3. Check code via verificationChecks.create() 4. If approved → verified; if failed → track attempts, lockout after 5 failures" ;
    oc:stepOrder 2 .

oc:kn_7f7f1e92 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling incoming SMS webhooks" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """app.post('/sms/incoming', (req, res) => {
  const { From, Body } = req.body;
  const twiml = new twilio.twiml.MessagingResponse();
  if (Body.toUpperCase() === 'STATUS') {
    twiml.message('Your order is on the way!');
  }
  res.type('text/xml').send(twiml.toString());
});""" ;
    oc:hasRationale "Express webhook pattern for two-way SMS using TwiML response format." .

oc:kn_8cfd4d80 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sending SMS via Twilio API" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const message = await twilio.messages.create({
  body: 'Message text',
  messagingServiceSid: 'MG...',
  to: '+1234567890',
  statusCallback: 'https://api.example.com/sms/status'
});""" ;
    oc:hasRationale "Using messagingServiceSid with statusCallback is the recommended pattern for production SMS sending." .

oc:kn_8d830a80 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sending any SMS message" ;
    oc:directiveContent "Always obtain opt-in consent before sending SMS messages; include STOP keyword in every message for opt-out." ;
    oc:hasRationale "TCPA/CTIA compliance is legally required; violations result in significant fines and carrier blocking." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ad626ba1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scheduling message delivery" ;
    oc:directiveContent "Respect quiet hours (default 21:00–09:00 recipient timezone); limit to 5 messages per recipient per day; rate limit to 10 messages per second." ;
    oc:hasRationale "Quiet hour violations trigger carrier filtering and compliance flags; rate limiting prevents throttling." ;
    oc:severityLevel "HIGH" .

oc:kn_e8f26b8a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When monitoring message delivery" ;
    oc:directiveContent "Implement retry logic for transient delivery failures; track delivery rates by carrier; set status callback URLs on every message for delivery receipts." ;
    oc:hasRationale "Transient failures are common in SMS delivery; callbacks enable real-time monitoring and automated retry decisions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ec089714 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing SMS sending workflow" ;
    oc:directiveContent "1. Validate recipient number via Lookup API 2. Build message from template with personalized variables 3. Respect quiet hours and rate limits 4. Send via Twilio API with statusCallback 5. Monitor delivery status via callback 6. Handle failures with retry logic" ;
    oc:stepOrder 1 .

oc:kn_f0fd7f34 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating order confirmation SMS" ;
    oc:directiveContent """{{company}}: Your order #{{order_id}} has been confirmed!
Total: ${{total}}
Track: {{tracking_url}}
Reply HELP for assistance.""" ;
    oc:templateVariables "company",
        "order_id",
        "total",
        "tracking_url" .

