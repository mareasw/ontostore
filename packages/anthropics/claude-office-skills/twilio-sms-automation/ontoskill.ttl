    oc:differentia "Integrates with Twilio APIs to automate SMS messaging, voice calls, phone number verification, and two-way conversational workflows" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasAllowedTool "twilio_lookup",
        "twilio_send_sms",
        "twilio_verify",
        "twilio_voice_call" ;
    oc:hasArgumentHint "phone numbers, message content, or workflow configuration" ;
    oc:hasCategory "communication" ;
    oc:hasDescription "Automate SMS communications, two-way messaging, notifications, and voice workflows with Twilio" ;
    oc:hasName "twilio-sms-automation" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: Twilio SMS Automation
description: Automate SMS communications, two-way messaging, notifications, and voice workflows with Twilio
version: 1.0.0
author: Claude Office Skills
category: communication
tags:
  - twilio
  - sms
  - messaging
  - notifications
  - voice
department: operations
models:
  - claude-3-opus
  - claude-3-sonnet
  - gpt-4
mcp:
  server: communication-mcp
  tools:
    - twilio_send_sms
    - twilio_voice_call
    - twilio_lookup
    - twilio_verify
capabilities:
  - SMS sending and receiving
  - Voice call automation
  - Phone number verification
  - Two-factor authentication
input:
  - Phone numbers
  - Message content
  - Call scripts
  - Verification codes
output:
  - Message delivery status
  - Call recordings
  - Verification results
  - Analytics reports
languages:
  - en
  - multi
related_skills:
  - whatsapp-automation
  - slack-workflows
  - email-marketing
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Comprehensive skill for automating SMS, voice, and verification workflows with Twilio." ] ;
            oc:hasSubsection [ a oc:Section ;
