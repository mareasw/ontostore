        oc:req_993a9c59,
        oc:req_c619bc18 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Automate weather-based workflows and notifications." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """morning_weather:
  trigger: daily at 6:30 AM
  actions:
    - get_forecast:
        location: home
        days: 1
    - send_notification:
        channel: slack_dm
        message: |
          🌤️ Good morning! Today's weather:
          High: {{high}}°F | Low: {{low}}°F
          {{conditions}}
          {{#if rain}}☔ Bring an umbrella!{{/if}}
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 112-126" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Morning Briefing" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """event_weather:
  trigger: calendar_event_tomorrow
  condition:
    event_type: outdoor
  actions:
    - get_forecast:
        location: "{{event.location}}"
        date: "{{event.date}}"
    - if:
        precipitation_chance: "> 50%"
      then:
        - notify: organizer
          message: "Consider backup venue - rain likely"
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 129-143" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Event Planning" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Workflow Examples" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """forecast:
  location: "New York, NY"
  days: 7
  
  daily:
    - date: "2024-01-20"
      high: 45°F
      low: 32°F
      conditions: "Snow"
      precipitation_chance: 80%
      
  hourly:
    interval: 3  # hours
    periods: 24
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 72-87" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Forecast" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """alert_rules:
  - name: "Rain Alert"
    condition:
      precipitation_chance: "> 70%"
      within_hours: 6
    action:
      notify: slack
      message: "☔ Rain expected in next 6 hours"
      
  - name: "Freeze Warning"
    condition:
      temperature: "< 32°F"
    action:
      - notify: sms
      - trigger: home_assistant
        action: protect_pipes
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 90-107" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Weather Alerts" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """current_weather:
  location: "San Francisco, CA"
  # or coordinates
  lat: 37.7749
  lon: -122.4194
  
  response:
    temperature: 65°F
    feels_like: 63°F
    humidity: 72%
    wind_speed: 12 mph
    conditions: "Partly Cloudy"
    uv_index: 5
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 55-69" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Current Weather" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Capabilities" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_29d71d7f69ee2ffc ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Best Practices" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Weather Automation" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: Weather Automation
description: Automate weather-based workflows, forecasts, alerts, and location-aware notifications
version: 1.0.0
author: Claude Office Skills
category: utilities
tags:
  - weather
  - forecast
  - alerts
  - location
  - automation
department: operations
models:
  - claude-3-opus
  - claude-3-sonnet
  - gpt-4
mcp:
  server: weather-mcp
  tools:
    - weather_current
    - weather_forecast
    - weather_alerts
    - weather_historical
capabilities:
  - Current conditions
  - Forecast retrieval
  - Weather alerts
  - Historical data
input:
  - Locations
  - Date ranges
  - Alert thresholds
  - Automation triggers
output:
  - Weather data
  - Forecasts
  - Alert notifications
  - Reports
languages:
  - en
related_skills:
  - calendar-automation
  - home-assistant
  - slack-workflows
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow _:ref_29d71d7f69ee2ffc ;
