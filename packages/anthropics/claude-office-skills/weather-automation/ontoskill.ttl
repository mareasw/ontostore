        oc:kn_66738e80,
        oc:kn_94d7e150,
        oc:kn_cf1306fa,
        oc:kn_d80fe706 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:APIKeySet,
