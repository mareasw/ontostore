    oc:resolvesIntent "automate weather-based workflows",
        "get current weather conditions",
        "plan events based on weather conditions",
        "retrieve weather forecasts",
        "set up weather alerts and notifications" ;
    oc:yieldsState oc:AlertsConfigured,
