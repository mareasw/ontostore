oc:kn_5a2e3b92 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When displaying or processing weather data" ;
    oc:directiveContent "Support both metric and imperial units for temperature and wind speed." ;
    oc:hasRationale "Users expect weather data in their preferred unit system; failing to support both limits usability." ;
    oc:severityLevel "MEDIUM" .

oc:kn_66738e80 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When accepting location input from users or automation triggers" ;
    oc:directiveContent "Accept multiple location formats: city names, coordinates (lat/lon), and named aliases like 'home' or 'office'." ;
    oc:hasRationale "Flexible location input improves user experience and enables integration with calendar events and other systems." ;
    oc:severityLevel "MEDIUM" .

oc:kn_94d7e150 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When alert rules include action blocks that notify or trigger external systems" ;
    oc:directiveContent "Weather automation may trigger external actions: Slack notifications, SMS messages, or Home Assistant device actions." ;
    oc:hasRationale "These side effects are irreversible once dispatched and may wake or disturb recipients." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cf1306fa a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring weather alert rules" ;
    oc:directiveContent "Set sensible alert thresholds — avoid alert fatigue from overly sensitive triggers." ;
    oc:hasRationale "Too many false or low-impact alerts cause users to ignore notifications, defeating the purpose of automation." ;
    oc:severityLevel "HIGH" .

oc:kn_d80fe706 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making repeated weather queries for the same location" ;
    oc:directiveContent "Cache frequent weather requests to reduce API calls and improve response times." ;
    oc:hasRationale "Weather APIs often have rate limits and caching avoids unnecessary network calls for data that doesn't change rapidly." ;
    oc:severityLevel "MEDIUM" .

