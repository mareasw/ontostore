oc:kn_0d0952bc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming a new skill directory or skill" ;
    oc:directiveContent "Do not use generic names like 'helper' or 'assistant' — use descriptive kebab-case names that clearly identify the skill's purpose (e.g., expense-report, job-description)." ;
    oc:hasRationale "Descriptive names enable discovery and prevent collision with other skills." ;
    oc:severityLevel "HIGH" .

oc:kn_12a1f3dd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring skill frontmatter" ;
    oc:directiveContent "Every skill must include: name, description, version, author, license, category, tags, MCP tool bindings, and input/output specifications." ;
    oc:hasRationale "Complete metadata ensures discoverability, compatibility checking, and proper tool routing." .

oc:kn_1b11dfb7 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a new skill from this template" ;
    oc:directiveContent "1. Copy the _template folder 2. Rename to kebab-case skill name 3. Edit SKILL.md with skill content 4. Delete README 5. Test by pasting into Claude conversation 6. Submit PR" ;
    oc:stepOrder 1 .

oc:kn_3d7b765c a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When defining the output format section of a new skill" ;
    oc:directiveContent """## [Output Title]

### Section 1
[Content pattern]

### Section 2
[Content pattern]""" ;
    oc:templateVariables "Content pattern",
        "Output Title" .

oc:kn_e9d78acb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing skill content" ;
    oc:directiveContent "Be specific: solve one clear problem, embed domain expertise not just instructions, show real-world examples, and acknowledge limits." ;
    oc:hasRationale "Specific, knowledge-rich skills produce better AI behavior than generic instruction lists." .

oc:kn_faa82caa a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring any new skill" ;
    oc:directiveContent "Skills are scenario-based solution guides: they define WHAT to do and HOW to do it, while MCP tools provide WITH WHAT to accomplish tasks." ;
    oc:hasRationale "Separating the solution guide (skill) from tool execution (MCP) enables portability and reuse across different tool backends." .

oc:kn_fc714e9d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring a new skill's markdown body" ;
    oc:directiveContent "A skill's SKILL.md body should contain these sections: Overview, How to Use Me (steps), Domain Knowledge, Output Format, Examples, Tips, and Limitations." ;
    oc:hasRationale "Consistent section structure enables agents to quickly locate relevant guidance within any skill." .

