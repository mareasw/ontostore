oc:kn_092eec4c a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before submitting or publishing a skill" ;
    oc:directiveContent "Before submitting a skill, test it by pasting SKILL.md content into a new Claude conversation, uploading a sample document, verifying it works, and testing edge cases." ;
    oc:hasRationale "Untested skills may fail silently on edge cases or produce unreliable outputs in production" .

oc:kn_3fa19385 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring skill content in SKILL.md" ;
    oc:directiveContent "Each skill should solve one clear problem, embed domain expertise (not just instructions), show real-world usage examples, and be explicit about its limitations." ;
    oc:hasRationale "Specific, knowledge-rich skills with clear boundaries are more reliable and useful than vague, generic ones" .

oc:kn_8e88fb85 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming a new skill" ;
    oc:directiveContent "Use lowercase with hyphens for skill names (kebab-case), e.g., expense-report, job-description. Be descriptive but concise. Avoid generic names like 'helper' or 'assistant'." ;
    oc:hasRationale "Consistent naming conventions make skills discoverable and maintainable across the organization" .

oc:kn_a442624b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a new skill from this template" ;
    oc:directiveContent "1. Copy the _template folder 2. Rename to skill name (kebab-case) 3. Edit SKILL.md with skill content 4. Delete or replace this README 5. Submit a PR" ;
    oc:hasRationale "Ensures consistent skill structure across the repository" ;
    oc:stepOrder 1 .

