oc:kn_345bdd00 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating daily note templates" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """note_templates:
  daily_note:
    filename: "{{date:YYYY-MM-DD}}"
    folder: "Daily Notes"
    template: |
      # {{date:dddd, MMMM D, YYYY}}
      ## Morning Intentions
      ## Tasks
      ## Notes
      ## Evening Reflection
      ---
      [[{{date:YYYY-MM-DD|-1d}}|← Yesterday]] | [[{{date:YYYY-MM-DD|+1d}}|Tomorrow →]]""" .

oc:kn_378ea50d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any new note" ;
    oc:directiveContent "One idea per note — follow the atomic notes principle to keep notes focused and linkable." ;
    oc:hasRationale "Atomic notes are the foundation of a navigable knowledge graph and enable granular linking." ;
    oc:severityLevel "HIGH" .

oc:kn_6e8f051e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any Obsidian note" ;
    oc:directiveContent "1. Choose appropriate template (daily note, meeting note, zettelkasten, book note) 2. Fill template variables (date, title, attendees, etc.) 3. Write content following atomic notes principle 4. Add wikilinks to related notes 5. Tag appropriately 6. Verify note appears in graph" ;
    oc:stepOrder 1 .

oc:kn_90c56214 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When querying due tasks in Obsidian" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """dataview_examples:
  tasks_due_today:
    query: |
      TASK
      WHERE !completed AND due = date(today)
      SORT due ASC""" .

oc:kn_94c25175 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When reviewing knowledge graph health" ;
    oc:directiveContent "For orphan notes (no incoming links), use graph analysis to suggest connections based on content similarity with a threshold of 0.7." ;
    oc:hasRationale "Orphan notes represent disconnected knowledge that loses value without connections." ;
    oc:severityLevel "LOW" .

oc:kn_a5480537 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When running a research workflow" ;
    oc:directiveContent "1. Create topic note in Research folder 2. Gather sources via search and link to note 3. Generate questions based on sources 4. Create sub-notes for each key concept" ;
    oc:stepOrder 1 .

oc:kn_b74223f4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring smart linking rules" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """auto_linking:
  rules:
    - pattern: "[[Person/{{name}}]]"
      trigger: "@{{name}}"
      create_if_missing: true
    - pattern: "[[Project/{{project}}]]"
      trigger: "#proj/{{project}}\"""" .

oc:kn_b95c8c79 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When configuring linking behavior" ;
    oc:directiveContent "Set auto-linking rules with triggers (@name for persons, #proj/name for projects) and enable backlink suggestions with min_mentions threshold of 2." ;
    oc:hasRationale "Automated linking reduces manual effort and catches connections that would otherwise be missed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cf1468e8 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "notes-mcp MCP server must be installed and configured with obsidian_create_note, obsidian_search, obsidian_link, and obsidian_template tools" .

oc:kn_cfb3275e a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating notes" ;
    oc:directiveContent "Use consistent naming conventions and standardized templates for each note type (daily, meeting, zettelkasten, book notes)." ;
    oc:hasRationale "Consistent structure enables Dataview queries, automated linking, and reliable organization." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d37d9c5d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or editing notes" ;
    oc:directiveContent "Link liberally between related notes and use both tags and wikilinks strategically — tags for categories, links for specific connections." ;
    oc:hasRationale "Rich interconnections make the knowledge graph useful and enable serendipitous discovery." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e05fa2ff a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating zettelkasten-style notes" ;
    oc:directiveContent """---
id: {{date:YYYYMMDDHHmmss}}
tags: 
links: 
---

# {{title}}

## Idea
## Source
## Connections
- Related to: 
## References""" ;
    oc:templateVariables "date",
        "title" .

