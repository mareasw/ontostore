oc:kn_132bea8d a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When designing document storage and offboarding audit processes" ;
    oc:directiveContent "All compliance documents (I-9, W-4, etc.) must be stored in secure HRIS with HR-only access and retention per legal requirements. Document all access revocations and verify no remaining access post-offboarding." ;
    oc:hasRationale "HR documents contain PII subject to GDPR, CCPA, and other privacy regulations; access audit trails are required for compliance" ;
    oc:severityLevel "HIGH" .

oc:kn_39a5b92f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up onboarding document compliance tracking" ;
    oc:directiveContent "I-9 forms must be completed within 3 days of hire start date; W-4 and direct deposit by first payroll; benefits enrollment within 30 days. These are legal compliance deadlines." ;
    oc:hasRationale "Missing compliance deadlines creates legal liability and regulatory risk for the organization" ;
    oc:severityLevel "CRITICAL" .

oc:kn_43f1db1a a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating HR automation workflow documentation" ;
    oc:directiveContent """# {Workflow_Name} Automation
## Trigger
{trigger_description}
## Pre-Start Checklist
### Day -14
- [ ] {task}
### Day -7
- [ ] {task}
### Day -1
- [ ] {task}
## Day 1 Checklist
### Morning
- [ ] {task} ({time})
### Afternoon
- [ ] {task} ({time})
## Notifications
- 50% deadline: Friendly reminder
- 80% deadline: Urgent reminder
- 100% deadline: Escalate to manager
## n8n Workflow
trigger: {trigger}
actions:
  - {action_list}""" ;
    oc:templateVariables "Workflow_Name",
        "action_list",
        "task",
        "time",
        "trigger",
        "trigger_description" .

oc:kn_58a22570 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing employee termination or offboarding" ;
    oc:directiveContent "Never delay access revocation for terminated employees. Email, SSO, VPN, physical access, and company credit cards must be disabled immediately on termination. Tool licenses, shared drives, and code repositories must be revoked within 24 hours." ;
    oc:hasRationale "Delayed access revocation is a major security risk enabling data theft, unauthorized access, and compliance violations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_8a1e14a0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring PTO approval workflows" ;
    oc:directiveContent "Approval routing for time-off should be tiered: direct manager approves requests ≤3 days; both manager and HR approve requests >3 days. Set 48-hour approval deadline with auto-escalation." ;
    oc:hasRationale "Tiered routing balances operational efficiency for short absences with proper oversight for extended leave" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9dc46a5c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating new hire onboarding automation" ;
    oc:directiveContent "1. Trigger on offer_accepted 2. Day -14: send welcome email, collect documents, order equipment 3. Day -7: create accounts (email, Slack, tools), add to HRIS/payroll, schedule orientation, assign buddy 4. Day -1: setup/ship equipment, send first day info 5. Day 1 morning: manager welcome, IT setup, team intros 6. Day 1 afternoon: HR orientation, access verification, buddy lunch 7. Week 1: daily check-ins, tool training, team meetings 8. Month 1: weekly 1-on-1s, project assignment, goal setting, 30-day survey" ;
    oc:stepOrder 1 .

oc:kn_a51b33cc a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing AI-powered resume screening" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """ai_screening:
  prompt: |
    Review this resume for the {job_title} position.
    Job Requirements: {job_requirements}
    Resume: {resume_text}
    Evaluate: 1. Skills match (1-10) 2. Experience match (1-10) 3. Key strengths 4. Potential concerns 5. Recommended: Yes/No/Maybe
  automation:
    - if: score >= 8 → advance_to_screening
    - if: score 5-7 → flag_for_review
    - if: score < 5 → auto_reject + send_rejection""" .

oc:kn_a60d78a8 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating offboarding automation" ;
    oc:directiveContent "1. Trigger on resignation/termination 2. Immediate: acknowledge, notify HR/manager/IT 3. Planning: calculate final pay, schedule exit interview, create transition plan, document knowledge transfer 4. Last week: knowledge transfer sessions, collect equipment, schedule access removal 5. Last day: exit interview, return badge/keys, revoke all access, send farewell (if voluntary) 6. Post-departure: process final paycheck, send COBRA info, archive files, 30-day survey" ;
    oc:stepOrder 2 .

oc:kn_c85ff7ce a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any HR workflow with deadlines (onboarding checklists, review cycles, document collection)" ;
    oc:directiveContent "HR workflows should use tiered escalation for pending tasks: remind at 50% of deadline, urgent reminder at 80%, escalate to manager at 100%." ;
    oc:hasRationale "Progressive escalation prevents tasks from falling through cracks while avoiding excessive notification fatigue" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f97b74ec a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When automating performance review cycles" ;
    oc:directiveContent "Performance review cycles should follow a 5-week quarterly cadence: Week 1 launch + self-assessment, Week 2 peer feedback, Week 3 manager review, Week 4 calibration, Week 5 delivery + goal setting." ;
    oc:hasRationale "Structured cadence ensures consistent evaluation timing and prevents review process delays" ;
    oc:severityLevel "LOW" .

