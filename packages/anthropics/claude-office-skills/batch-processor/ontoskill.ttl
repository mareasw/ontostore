oc:kn_2efad7f1 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When checkpoint file exists from a previous run" ;
    oc:directiveContent "Batch processing with checkpointing is idempotent: re-running skips already-processed files." ;
    oc:hasRationale "Resume-safe design means the same batch command can be reissued safely after interruption." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6ae2cf62 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring ProcessPoolExecutor or similar parallel workers" ;
    oc:directiveContent "Set max_workers to CPU core count for optimal parallel throughput; avoid over-subscription." ;
    oc:hasRationale "Too many workers cause context-switching overhead; too few leaves CPU idle." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a58fcdf8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing the per-file processing function in a batch loop" ;
    oc:directiveContent "Always wrap individual file processing in try/except to isolate failures; never let one file error halt the entire batch." ;
    oc:hasRationale "One corrupt or problematic file should not abort processing of hundreds of valid files." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c68eb352 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When running long batch jobs that may be interrupted" ;
    oc:directiveContent "Use checkpoint files (JSON) to track processed files so interrupted jobs can resume without reprocessing." ;
    oc:hasRationale "Long-running batch jobs on hundreds of files are prone to interruption; checkpointing prevents wasted compute." ;
    oc:severityLevel "HIGH" .

oc:kn_c8e2723d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Parallel file processing with ProcessPoolExecutor" ;
    oc:codeLanguage "python" ;
    oc:directiveContent "futures = {executor.submit(process_file, f): f for f in files}; for future in as_completed(futures): result = future.result()" ;
    oc:hasRationale "Mapping futures to their source files enables error attribution when futures fail." .

oc:kn_d2e8ffcf a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When executing any batch operation with more than a handful of files" ;
    oc:directiveContent "Use tqdm progress bars to provide real-time feedback on batch processing progress and per-file status." ;
    oc:hasRationale "User visibility into progress prevents premature cancellation and aids debugging of stalled jobs." ;
    oc:severityLevel "MEDIUM" .

