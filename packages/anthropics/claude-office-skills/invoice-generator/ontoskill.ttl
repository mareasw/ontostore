@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_claude_office_skills_invoice_generator a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "invoice-generator" ;
    skos:broader "document generator" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/claude-office-skills/invoice-generator" ;
    oc:contentHash "45220449554631901cbab0619566761f1109294b6b9fc0bfa1e5e67750cc8892" ;
    oc:dependsOnSkill oc:skill_ontoskills_office_mcp ;
    oc:differentia "creates professional invoices with tax calculations, multi-currency support, and region-specific compliance guidance for freelancers and small businesses" ;
    oc:extends oc:skill_ontoskills_invoice_template ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "client_info, line_items, currency, tax_rate, payment_terms" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Create professional invoices with proper formatting for freelancers and small businesses. Supports multiple currencies and tax calculations." ;
    oc:hasName "invoice-generator" ;
    oc:hasPackageName "invoice-generator" ;
    oc:hasRequirement oc:req_934e28f0,
        oc:req_c50be04b ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """# ═══════════════════════════════════════════════════════════════════════════════
# CLAUDE OFFICE SKILL - Enhanced Metadata v2.0
# ═══════════════════════════════════════════════════════════════════════════════

# Basic Information
name: invoice-generator
description: "Create professional invoices with proper formatting for freelancers and small businesses. Supports multiple currencies and tax calculations."
version: "1.0.0"
author: claude-office-skills
license: MIT

# Categorization
category: finance
tags:
  - invoice
  - billing
  - generator
  - finance
  - business
department: Finance

# AI Model Compatibility
models:
  recommended:
    - claude-sonnet-4
    - claude-opus-4
  compatible:
    - claude-3-5-sonnet
    - gpt-4
    - gpt-4o

# MCP Tools Integration
mcp:
  server: office-mcp
  tools:
    - create_docx
    - fill_docx_template
    - docx_to_pdf
  optional_tools:
    - create_xlsx

# Skill Capabilities
capabilities:
  - invoice_creation
  - tax_calculation
  - currency_handling
  - professional_formatting

# Input/Output Specification
input:
  required:
    - type: text
      name: client_info
      description: Client name, address, contact
    - type: text
      name: line_items
      description: Products/services with quantities and prices
  optional:
    - type: text
      name: currency
      description: Currency (USD, EUR, CNY, etc.)
    - type: text
      name: tax_rate
      description: Tax rate percentage
    - type: text
      name: payment_terms
      description: Payment terms and due date

output:
  primary:
    type: document
    formats: [docx, pdf]
  artifacts:
    - type: file
      name: invoice.docx
      description: Generated invoice document

# Language Support
languages:
  - en
  - zh

# Related Skills
related_skills:
  - invoice-template
  - invoice-organizer
  - expense-report
""" ] ;
