oc:kn_2b091e20 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating the invoice document" ;
    oc:directiveContent """# INVOICE

**Invoice Number:** {invoice_number}
**Date:** {date}
**Due Date:** {due_date}

---

## From
{sender_name}
{sender_address}
{sender_email}
{sender_tax_id}

## Bill To
{client_name}
{client_address}
{client_email}

---

## Items

| Description | Qty | Rate | Amount |
|-------------|-----|------|--------|
| {item_desc} | {qty} | {rate} | {amount} |

---

| | |
|---|---|
| **Subtotal** | {subtotal} |
| **Tax ({rate}%)** | {tax_amount} |
| **Total Due** | **{total}** |

---

## Payment Details
{bank_or_payment_info}

---

**Payment Terms:** {terms}
**Late Fee:** {late_fee}""" ;
    oc:templateVariables "amount",
        "bank_or_payment_info",
        "client_address",
        "client_email",
        "client_name",
        "date",
        "due_date",
        "invoice_number",
        "item_desc",
        "late_fee",
        "qty",
        "rate",
        "sender_address",
        "sender_email",
        "sender_name",
        "sender_tax_id",
        "subtotal",
        "tax_amount",
        "terms",
        "total" .

oc:kn_350f01d5 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating any invoice" ;
    oc:directiveContent "Always include invoice number, date, due date, sender info, client info, line items with descriptions/quantities/rates/amounts, and total due." ;
    oc:hasRationale "Missing required elements make the invoice unprofessional and may cause payment delays or legal issues." ;
    oc:severityLevel "HIGH" .

oc:kn_359044ee a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finalizing invoice layout" ;
    oc:directiveContent "Include clear payment instructions (bank details, payment link) and payment terms on every invoice to make it easy for clients to pay." ;
    oc:hasRationale "Frictionless payment experience reduces payment delays and improves collection rates." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3b07fa8c a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before generating an invoice" ;
    oc:directiveContent "Requires client info (name, address, contact) and line items (products/services with quantities and prices) as minimum input." .

oc:kn_3e21e5bc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning invoice numbers" ;
    oc:directiveContent "Never reuse invoice numbers. Keep numbers sequential without gaps, as gaps may raise audit questions." ;
    oc:hasRationale "Non-sequential or reused numbers create accounting confusion and may trigger tax authority scrutiny." ;
    oc:severityLevel "HIGH" .

oc:kn_863292c8 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Collect business details (name, address, tax ID) and client details (name, address). 2. Gather line items (description, quantity, rate). 3. Assign or suggest invoice number. 4. Set payment terms and due date. 5. Calculate subtotal, taxes, and total. 6. Generate formatted invoice with all required elements and payment instructions." ;
    oc:stepOrder 1 .

oc:kn_b53efc0c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing line item descriptions" ;
    oc:directiveContent "Use specific line item descriptions (e.g., 'Marketing strategy consulting – Q1 campaign planning') instead of vague terms like 'Consulting'." ;
    oc:hasRationale "Detailed descriptions reduce disputes, clarify scope, and support professional appearance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_df8205f5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When exporting invoices" ;
    oc:directiveContent "Generates text/markdown invoices only, not PDFs directly. Output must be copied to Word/Google Docs or converted separately." ;
    oc:hasRationale "The skill is a text generator; PDF creation requires additional tooling." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e6e3d9a4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating taxes on invoices" ;
    oc:directiveContent "Tax calculations are estimates only — always verify with a qualified accountant. Cannot guarantee compliance with all local regulations." ;
    oc:hasRationale "Tax laws vary by jurisdiction and change frequently; the skill provides guidance but not legal tax advice." ;
    oc:severityLevel "CRITICAL" .

