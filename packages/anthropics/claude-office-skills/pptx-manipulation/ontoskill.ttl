oc:kn_03eec45d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning presentation features that require advanced PowerPoint capabilities" ;
    oc:directiveContent "python-pptx cannot render complex animations, has limited SmartArt support, cannot embed video via API, and master slide editing is complex. Chart types are limited to standard Office charts only." ;
    oc:hasRationale "These are hard limitations of the python-pptx library; attempting them will fail or produce incomplete results" ;
    oc:severityLevel "MEDIUM" .

oc:kn_121b63dc a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding charts to slides with categorical data" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from pptx.chart.data import CategoryChartData
from pptx.enum.chart import XL_CHART_TYPE

chart_data = CategoryChartData()
chart_data.categories = ['Q1', 'Q2', 'Q3', 'Q4']
chart_data.add_series('Sales', (19.2, 21.4, 16.7, 23.8))

chart = slide.shapes.add_chart(
    XL_CHART_TYPE.COLUMN_CLUSTERED,
    Inches(1), Inches(2), Inches(8), Inches(4),
    chart_data
).chart""" .

oc:kn_6c1103cd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, as part of the presentation creation workflow" ;
    oc:directiveContent "Plan slide structure (layout, content types) before writing code. Optimize images by compressing them before adding to slides. Always verify generated presentations by opening them." ;
    oc:hasRationale "Layout-first planning avoids rework; uncompressed images bloat file size; generated PPTX should always be visually verified" ;
    oc:severityLevel "LOW" .

oc:kn_8fe59700 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding slides to a presentation, especially with custom templates" ;
    oc:directiveContent "Slide layout indices may vary by template. The default indices (0=Title, 1=Title+Content, 5=Title Only, 6=Blank) are standard for the default template but not guaranteed for custom templates." ;
    oc:hasRationale "Hard-coded layout indices will produce wrong layouts if the template differs from the default Office template" ;
    oc:severityLevel "HIGH" .

oc:kn_94fd5625 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When reporting the result of presentation creation" ;
    oc:directiveContent """# {presentation_title}

## Slide {n}: {slide_title}
- Layout: {layout_type}
- Content: {content_description}
- Shapes: {shape_count}

Saved to: {output_path}""" ;
    oc:templateVariables "content_description",
        "layout_type",
        "n",
        "output_path",
        "presentation_title",
        "shape_count",
        "slide_title" .

oc:kn_99d22bc8 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating a basic presentation with title slide" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from pptx import Presentation
from pptx.util import Inches, Pt

prs = Presentation()  # new, or Presentation('existing.pptx') to edit
slide = prs.slides.add_slide(prs.slide_layouts[0])  # Title slide
slide.shapes.title.text = "Title"
slide.placeholders[1].text = "Subtitle"
prs.save('output.pptx')""" .

oc:kn_9c3e87bc a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any PPTX manipulation can occur" ;
    oc:directiveContent "python-pptx must be installed: pip install python-pptx" ;
    oc:severityLevel "CRITICAL" .

oc:kn_aa9bc380 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When populating text frames with bullet points or multi-paragraph content" ;
    oc:directiveContent "The first paragraph in a text_frame must be set via tf.text directly. Subsequent paragraphs use tf.add_paragraph(). Setting tf.text overwrites all existing paragraphs." ;
    oc:hasRationale "Misunderstanding text_frame paragraph initialization is a common source of bugs where content gets overwritten or lost" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cfc1bdd0 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding data tables to slides" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """table = slide.shapes.add_table(rows, cols, Inches(1), Inches(2), Inches(8), Inches(2)).table
for i, header in enumerate(headers):
    cell = table.cell(0, i)
    cell.text = header
    cell.text_frame.paragraphs[0].font.bold = True
for row_idx, row_data in enumerate(data, 1):
    for col_idx, value in enumerate(row_data):
        table.cell(row_idx, col_idx).text = value""" .

oc:kn_e10fab77 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a new presentation from user description" ;
    oc:directiveContent "1. User describes desired presentation 2. Determine slide count, layouts, and content types 3. Generate python-pptx code with proper imports 4. Execute and save to specified path 5. Verify output file exists" ;
    oc:stepOrder 1 .

oc:kn_f519192d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any PPTX generation code" ;
    oc:directiveContent "Verify python-pptx is installed (pip install python-pptx) and that the output directory is writable before generating presentations." ;
    oc:hasRationale "Missing dependency or unwritable output path will cause immediate failure with unclear error messages" .

oc:kn_fc7f737a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating presentations that need professional, consistent styling" ;
    oc:directiveContent "Start with a .pptx template file for consistent branding. Reuse slide masters to maintain visual consistency across all slides in a presentation." ;
    oc:hasRationale "Templates encode brand guidelines (colors, fonts, logos) so every slide inherits them automatically, reducing manual formatting errors" .

oc:payload_4cade165fe6a3b4d a oc:ExecutionPayload ;
    oc:code "pip install python-pptx" ;
    oc:executor "shell" ;
    oc:timeout 30 .

