  tools:
    - read_xlsx
    - create_xlsx
    - apply_formula
    - create_chart

capabilities:
  - dcf_modeling
  - wacc_calculation
  - sensitivity_analysis
  - terminal_value_estimation
  - intrinsic_value_calculation

languages:
  - en
  - zh

related_skills:
  - stock-analysis
  - financial-modeling
  - company-research
