oc:kn_0cb09d3a a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When running compliance checks" ;
    oc:directiveContent "Compliance monitoring covers PCI-DSS (log cardholder data access, daily log reviews), HIPAA (audit controls, 6-year retention, tamper protection), and SOC 2 (MFA, password policy, quarterly access reviews)." ;
    oc:hasRationale "Regulatory non-compliance carries financial penalties and increases organizational risk exposure." ;
    oc:severityLevel "HIGH" .

oc:kn_169ba16e a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before executing security monitoring" ;
    oc:directiveContent "Requires a SIEM or security data lake with log aggregation from firewall, endpoint, cloud, network, and application sources" ;
    oc:severityLevel "HIGH" .

oc:kn_2092d69d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When measuring security operations effectiveness" ;
    oc:directiveContent "Key security KPIs to track: MTTD (target <4 hours), MTTR (target <2 hours), True Positive Rate (target >75%), SLA Compliance (>95%), Asset Coverage (>95%), Patch Compliance (>90%)." ;
    oc:hasRationale "Metrics-driven security operations enable continuous improvement and demonstrate value to leadership." ;
    oc:severityLevel "MEDIUM" .

oc:kn_439ac595 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When ransomware is detected" ;
    oc:directiveContent "Ransomware response: immediately isolate endpoint, disable associated AD account, capture memory image for forensics, then notify stakeholders and create incident ticket." ;
    oc:hasRationale "Speed of containment directly correlates with blast radius; evidence must be preserved before eradication." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4c16cb88 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing detection strategies" ;
    oc:directiveContent "Apply defense in depth: use multiple detection layers including rule-based detection, ML anomaly detection, correlation rules, and threat intelligence feeds." ;
    oc:hasRationale "Single detection layers miss attack vectors; layered detection dramatically improves true positive rates." ;
    oc:severityLevel "HIGH" .

oc:kn_5258729a a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running security monitoring workflows" ;
    oc:directiveContent "Security MCP server must be configured with tools: siem_query, alert_create, incident_manage, compliance_check" ;
    oc:severityLevel "HIGH" .

oc:kn_5afd6396 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When configuring correlation rules" ;
    oc:directiveContent "Correlation rules for lateral movement and privilege escalation require precise time-window tuning. Too narrow misses slow attacks; too wide generates false positives." ;
    oc:hasRationale "Attackers increasingly use slow-and-low techniques that evade tight correlation windows." ;
    oc:severityLevel "MEDIUM" .

oc:kn_935d639f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring alert rules and notifications" ;
    oc:directiveContent "Never rely on a single log source or detection method. Avoid alert fatigue by implementing deduplication (1-hour window keyed on rule_id, source.ip, destination.ip) and severity-based routing." ;
    oc:hasRationale "Alert fatigue causes real threats to be missed; deduplication and proper routing ensure critical alerts get attention." ;
    oc:severityLevel "CRITICAL" .

oc:kn_abe8c9ba a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When triaging and responding to security alerts" ;
    oc:directiveContent "Critical severity alerts require 15-minute response time with auto-escalation at 30 minutes. High alerts require 1-hour response. Medium: 4 hours. Low: 24 hours." ;
    oc:hasRationale "SLA compliance ensures threats are contained before damage spreads." ;
    oc:severityLevel "HIGH" .

oc:kn_d8f7c405 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building multi-event correlation rules for lateral movement detection" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """correlation_rules:
  events:
    - type: authentication_success
    - type: process_execution
      within: 5_minutes
    - type: network_connection
      within: 10_minutes""" .

oc:kn_de493997 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When responding to any security incident" ;
    oc:directiveContent "Incident response follows a strict 7-phase workflow: Detection → Triage (validate/classify/prioritize) → Containment (isolate/block/preserve) → Investigation (collect/analyze/correlate) → Eradication (remove/patch/harden) → Recovery (restore/verify/monitor) → Post-Incident (document/review/improve)." ;
    oc:hasRationale "Structured response prevents missed steps and ensures evidence preservation for forensic analysis." ;
    oc:severityLevel "CRITICAL" ;
    oc:stepOrder 1 .

oc:kn_f853760a a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing SIEM detection queries for brute force attacks" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent "event.type == \"authentication\" AND event.outcome == \"failure\" AND COUNT(*) > 5 WITHIN 5 minutes GROUP BY source.ip" .

