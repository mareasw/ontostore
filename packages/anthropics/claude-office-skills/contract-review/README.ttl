oc:kn_2c33f8fc a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When evaluating contract review completeness" ;
    oc:directiveContent "A successful review identifies 15+ common risk patterns, checks for missing contract elements, provides specific negotiation recommendations, and covers applicable jurisdictional concerns" ;
