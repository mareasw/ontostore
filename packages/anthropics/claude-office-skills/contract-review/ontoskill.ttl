oc:kn_0a408084 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scanning contract text for risk patterns" ;
    oc:directiveContent """Look for these keyword patterns in contract text:
High: "unlimited liability", "full indemnification", "all intellectual property", "work product", "at will", "unilateral termination", "waive", "waiver of rights"
Medium: "automatically renew", "evergreen", "penalty", "liquidated damages", "non-compete", "perpetual", "indefinite", "net 90", "upon satisfaction"
Absence checks: missing "force majeure", "personal data", "GDPR", "audit rights", "inspection\"""" .

oc:kn_3a907eb8 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Contract document must be provided in PDF, DOCX, or TXT format. Party role (employee/contractor/buyer/seller) must be specified for actionable analysis." .

oc:kn_532ff475 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing contracts with a specified or implied jurisdiction" ;
    oc:directiveContent "Jurisdiction matters critically: non-competes are void in California, GDPR requires data processing agreements in the EU, China requires written contracts within 30 days and paid non-compete compensation, UK statutory rights cannot be contracted out of." ;
    oc:hasRationale "Contract enforceability varies dramatically by jurisdiction; applying wrong legal assumptions invalidates the entire analysis." ;
    oc:severityLevel "HIGH" .

oc:kn_5806b1cf a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Receive contract file + party role + jurisdiction + concerns 2. Extract text from document 3. Scan for 15 risk patterns categorized as High/Medium/Low 4. Check completeness against standard contract elements (parties, dates, scope, compensation, termination, confidentiality, IP, liability, indemnification, governing law, dispute resolution, signatures) 5. Generate structured report with Risk Summary, Detailed Findings, Completeness Check, and Negotiation Priorities" ;
    oc:stepOrder 1 .

oc:kn_78d136b1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any contract analysis" ;
    oc:directiveContent "Risk identification must cover all 15 known patterns: unlimited liability, broad IP assignment, unilateral termination, one-sided indemnification, broad rights waiver, missing data protection, auto-renewal traps, excessive penalties, broad non-competes, perpetual confidentiality, unfavorable jurisdiction, unfavorable payment terms, uncontrolled scope changes, missing force majeure, and missing audit rights." ;
    oc:hasRationale "Comprehensive pattern coverage ensures no common risk is overlooked during review." ;
    oc:severityLevel "HIGH" .

oc:kn_82424f66 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting contract analysis" ;
    oc:directiveContent "The skill assumes the user provides their party role (employee/contractor/buyer/seller) and jurisdiction for accurate risk assessment. Without these, analysis is generic and less actionable." ;
    oc:hasRationale "Risk interpretation depends entirely on which side of the contract the user is on and which laws apply." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b5baaa68 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """## Contract Analysis Report

**Document**: {contract_name}
**Type**: {contract_type}
**Jurisdiction**: {jurisdiction}
**Your Role**: {party_role}

### Risk Summary
| Severity | Count | Key Issues |
|----------|-------|------------|
| 🔴 High  | {count} | {issues} |
| 🟡 Medium| {count} | {issues} |
| 🟢 Low   | {count} | {issues} |

**Overall Assessment**: [SAFE / REVIEW NEEDED / HIGH RISK]

### Detailed Findings
**{issue_number}. {issue_name}** (Section {section})
> "{exact_quote}"
- **Problem**: {description}
- **Impact**: {impact}
- **Recommendation**: {action}

### Completeness Check
✅ Present: {items}
⚠️ Missing or Unclear: {items}

### Negotiation Priorities
1. **Must Change**: {critical}
2. **Should Change**: {important}
3. **Nice to Have**: {minor}

### Disclaimer""" ;
    oc:templateVariables "action",
        "contract_name",
        "contract_type",
        "count",
        "critical",
        "description",
        "exact_quote",
        "impact",
        "important",
        "issue_name",
        "issue_number",
        "issues",
        "items",
        "jurisdiction",
        "minor",
        "party_role",
        "section" .

oc:kn_c9b7a9fb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the contract analysis report" ;
    oc:directiveContent "Classify every finding into High/Medium/Low severity and structure output as: Risk Summary table → Detailed Findings with exact quotes → Completeness Check → Negotiation Priorities (Must/Should/Nice to Have)." ;
    oc:hasRationale "Tiered severity with specific quotes enables users to quickly assess urgency and take actionable negotiation steps." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d4e367af a oc:KnowledgeNode,
        oc:RequiresHumanClarification ;
    oc:appliesToContext "When reviewing contracts involving significant financial exposure or complex legal structures" ;
    oc:directiveContent "For M&A deals, major commercial contracts, and other high-stakes agreements, escalate to recommend a qualified attorney rather than relying solely on AI analysis." ;
    oc:hasRationale "AI cannot verify counterparty compliance, account for recent legal changes, or handle industry-specific regulatory nuances." ;
    oc:severityLevel "HIGH" .

oc:kn_e5e9dc92 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting any contract analysis results" ;
    oc:directiveContent "Never provide definitive legal advice or guarantee compliance; always include a disclaimer that analysis is informational only and recommend professional legal review for high-stakes contracts." ;
    oc:hasRationale "AI-generated analysis does not constitute legal counsel and could expose users to risk if relied upon exclusively for important decisions." ;
    oc:severityLevel "CRITICAL" .

