@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_claude_office_skills_contract_review a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "contract-review" ;
    skos:broader "Legal analysis framework" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/claude-office-skills/contract-review" ;
    oc:contentHash "a2b0695ecd83236e4a234a485567fc5ed9c9881a18dec692f91f486daf8be36c" ;
    oc:differentia "that identifies contract risks, checks completeness, and provides negotiation recommendations across multiple jurisdictions" ;
    oc:extends oc:skill_ontoskills_office_mcp ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "analyze_document_structure",
        "extract_text_from_docx",
        "extract_text_from_pdf" ;
    oc:hasArgumentHint "contract file (PDF/DOCX/TXT) + party role + jurisdiction" ;
    oc:hasCategory "legal" ;
    oc:hasDescription "Analyze contracts for risks, check completeness, and provide actionable recommendations. Supports employment contracts, NDAs, service agreements, and more." ;
    oc:hasName "contract-review" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """# ═══════════════════════════════════════════════════════════════════════════════
# CLAUDE OFFICE SKILL - Enhanced Metadata v2.0
# ═══════════════════════════════════════════════════════════════════════════════

# Basic Information
name: contract-review
description: "Analyze contracts for risks, check completeness, and provide actionable recommendations. Supports employment contracts, NDAs, service agreements, and more."
version: "1.0.0"
author: claude-office-skills
license: MIT

# Categorization
category: legal
tags:
  - contract
  - review
  - risk-analysis
  - legal
  - compliance
department: Legal

# AI Model Compatibility
models:
  recommended:
    - claude-sonnet-4
    - claude-opus-4
  compatible:
    - claude-3-5-sonnet
    - gpt-4
    - gpt-4o

# MCP Tools Integration
# Skills = Solution Guide (WHAT + HOW)
# MCP = Tool Provider (WITH WHAT)
mcp:
  server: office-mcp
  tools:
    - extract_text_from_pdf
    - extract_text_from_docx
    - analyze_document_structure
  optional_tools:
    - create_docx
    - docx_to_pdf

# Knowledge Base Integration
# Knowledge = Domain expertise as structured data
knowledge:
  base:
    - mcp-servers/office-mcp/knowledge/base/risk_patterns.json
    - mcp-servers/office-mcp/knowledge/base/completeness.json
  jurisdictions:
    - mcp-servers/office-mcp/knowledge/base/jurisdictions/us.json
    - mcp-servers/office-mcp/knowledge/base/jurisdictions/china.json
    - mcp-servers/office-mcp/knowledge/base/jurisdictions/eu.json
  custom:
    # Users can add their own knowledge files here
    # Example: ./knowledge/my_company_rules.json

# Skill Capabilities (for discovery/matching)
capabilities:
  - contract_analysis
  - risk_identification
  - legal_compliance_check
  - negotiation_recommendations

# Input/Output Specification
input:
  required:
    - type: file
      formats: [pdf, docx, txt]
      description: The contract document to review
    - type: text
      name: party_role
      description: Which party you are (employee, contractor, buyer, etc.)
  optional:
    - type: text
      name: jurisdiction
      description: Legal jurisdiction (US, EU, China, UK)
    - type: text
      name: concerns
      description: Specific areas of concern

output:
  primary:
    type: report
    format: markdown
    sections:
      - risk_summary
      - detailed_findings
      - completeness_check
      - negotiation_priorities

# Language Support
languages:
  - en
  - zh

# Related Skills
related_skills:
  - nda-generator
  - offer-letter
  - contract-template
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Statutory Rights**: Cannot contract out of employment rights" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**TUPE**: Employee rights protected in business transfers" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Notice Periods**: Minimum 1 week per year of service (up to 12)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Restrictive Covenants**: Must be reasonable to be enforceable" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 36 ;
                            oc:sectionTitle "United Kingdom" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**GDPR Compliance**: Data processing agreements required" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Language**: May need to be in local language to be enforceable" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Working Time Directive**: Max 48 hrs/week average" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Notice Periods**: Often legally mandated (1-3 months common)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Non-Competes**: Must be compensated in many countries" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 34 ;
                            oc:sectionTitle "European Union" ],
                        [ a oc:Section ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:hasChild [ a oc:BulletList ;
                                                            oc:blockType "bullet_list" ;
                                                            oc:contentOrder 1 ;
                                                            oc:hasItem [ a oc:BulletItem ;
                                                                    oc:blockType "bullet_item" ;
                                                                    oc:itemOrder 2 ;
                                                                    oc:itemText "Exempt: Must meet salary threshold ($684/week) AND duties test" ],
                                                                [ a oc:BulletItem ;
                                                                    oc:blockType "bullet_item" ;
                                                                    oc:itemOrder 1 ;
                                                                    oc:itemText "Non-exempt: Entitled to overtime (1.5x after 40 hrs/week)" ] ] ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Exempt vs Non-Exempt**: Critical classification for overtime eligibility" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "**Non-Competes**: Void in California; FTC proposing nationwide ban" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**At-Will Default**: Most states allow termination without cause (except Montana)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "**Minimum Wage**: Federal $7.25/hr, but many states higher (CA: $16/hr)" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 32 ;
                                    oc:sectionTitle "Employment Contracts" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Table ;
                                            oc:blockType "table" ;
                                            oc:contentOrder 1 ;
                                            oc:rowCount 3 ;
                                            oc:tableCaption "#### State Variations" ;
                                            oc:tableMarkdown """| State | Key Differences |
|-------|-----------------|
| **California** | Daily overtime after 8hrs; non-competes void; strong employee protections |
| **Texas** | Strong at-will; non-competes enforceable if reasonable |
| **New York** | NYC extra protections; salary history ban; paid family leave |
""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 33 ;
                                    oc:sectionTitle "State Variations" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 31 ;
                            oc:sectionTitle "United States" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Social Insurance**: Contributions mandatory (pension, medical, etc.)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Non-Compete**: Must pay compensation (30-50% of salary) during restriction" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Severance**: Required for many termination scenarios" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Labor Contract Law**: Mandatory written contract within 30 days" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Probation Period**: Limited by contract length (max 6 months)" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 35 ;
                            oc:sectionTitle "China" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 30 ;
                    oc:sectionTitle "Jurisdiction-Specific Knowledge" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** No right to verify compliance or check records.
**Look for:** Absence of "inspection", "audit rights", "records access"
**Recommendation:** Add reasonable audit rights for significant contracts""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 25 ;
                                    oc:sectionTitle "15. Missing Audit Rights" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 24 ;
                            oc:sectionTitle "Low Risk (Worth Noting)" ],
                        [ a oc:Section ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** No provision for unforeseeable events (pandemic, disaster).
**Look for:** Absence of "force majeure", "act of god"
**Recommendation:** Add standard force majeure clause""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 23 ;
                                    oc:sectionTitle "14. Missing Force Majeure" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** Disputes resolved in a place far from you or favoring them.
**Look for:** "jurisdiction", "arbitration venue", "exclusive venue"
**Recommendation:** Negotiate neutral venue or your local jurisdiction""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 20 ;
                                    oc:sectionTitle "11. Unfavorable Jurisdiction" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** Restrictions on future work that are too broad.
**Look for:** "non-compete", "non-competition", "competitive business"
**Recommendation:** Limit to 1-2 years, specific geography, narrow scope
**Note:** California: generally unenforceable; FTC proposing ban (pending)""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 18 ;
                                    oc:sectionTitle "9. Broad Non-Compete" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** No process for managing changes to work scope.
**Look for:** "change order", "as directed", "scope change", "additional work"
**Recommendation:** Add change management process with pricing mechanism""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 22 ;
                                    oc:sectionTitle "13. Uncontrolled Scope Changes" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** Contract renews automatically with difficult opt-out.
**Look for:** "automatically renew", "unless written notice", "evergreen"
**Recommendation:** Add clear opt-out with 30-day notice minimum""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 16 ;
                                    oc:sectionTitle "7. Auto-Renewal Trap" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** Penalty for breach exceeds reasonable damages.
**Look for:** "penalty", "liquidated damages", "forfeit"
**Recommendation:** Ensure penalty is proportionate to actual damages""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 17 ;
                                    oc:sectionTitle "8. Excessive Penalty" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** Confidentiality obligations that never expire.
**Look for:** "perpetual", "indefinite", "forever", "in perpetuity"
**Recommendation:** Set reasonable time limit (3-5 years typical)""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 19 ;
                                    oc:sectionTitle "10. Perpetual Confidentiality" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** Long payment cycles or subjective acceptance criteria.
**Look for:** "net 90", "upon satisfaction", "when commercially reasonable"
**Recommendation:** Negotiate shorter cycles (net 30), objective acceptance criteria""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 21 ;
                                    oc:sectionTitle "12. Unfavorable Payment Terms" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 15 ;
                            oc:sectionTitle "Medium Risk (Yellow Flags)" ],
                        [ a oc:Section ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** Only you bear responsibility for problems, not them.
**Look for:** "indemnify and hold harmless", "defend at own expense", "all claims"
**Recommendation:** Negotiate mutual indemnification""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 12 ;
                                    oc:sectionTitle "4. One-Sided Indemnification" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** No provisions for how personal data is handled (GDPR/CCPA risk).
**Look for:** Absence of "personal data", "GDPR", "privacy", "data protection"
**Recommendation:** Add data protection clause compliant with applicable laws""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 14 ;
                                    oc:sectionTitle "6. Missing Data Protection" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** You give up legal rights you're entitled to.
**Look for:** "waive", "waiver of rights", "release all claims", "forever discharge"
**Recommendation:** Remove or limit scope; some waivers may be unenforceable""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 13 ;
                                    oc:sectionTitle "5. Broad Rights Waiver" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** You give away all intellectual property, including work you did before.
**Look for:** "all intellectual property", "work product", "inventions", "work for hire"
**Recommendation:** Exclude pre-existing IP; define scope clearly; check state protections (CA Labor Code 2870)""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 10 ;
                                    oc:sectionTitle "2. Broad IP Assignment" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** You could be responsible for unlimited damages.
**Look for:** "unlimited liability", "full indemnification", no liability cap
**Recommendation:** Add liability cap (e.g., 12 months of fees, or contract value)""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 9 ;
                                    oc:sectionTitle "1. Unlimited Liability" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent """**What it means:** The other party can end the contract anytime, but you can't.
**Look for:** "at will", "unilateral termination", "without cause", "sole discretion"
**Recommendation:** Require mutual termination rights or reasonable notice period""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 11 ;
                                    oc:sectionTitle "3. Unilateral Termination" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 8 ;
                            oc:sectionTitle "High Risk (Red Flags)" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Risk Patterns I Look For" ],
                [ a oc:Section ;
