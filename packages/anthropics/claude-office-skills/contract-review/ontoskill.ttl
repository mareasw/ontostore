                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "My knowledge may not reflect the latest legal changes" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "For high-stakes contracts (M&A, major deals), always use a lawyer" ],
                                [ a oc:BulletItem ;
