oc:kn_90095110 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When working with datasets exceeding 10,000 rows" ;
    oc:directiveContent "For large datasets, aggregate data before chart generation rather than plotting raw records. Use figsize=(12-14, 10) for multi-chart layouts." ;
    oc:hasRationale "Pre-aggregation reduces rendering time and produces cleaner visualizations." ;
    oc:severityLevel "LOW" .

