                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "This skill enables automatic generation of professional data reports. Create dashboards, KPI summaries, and analytical reports with charts, tables, and insights from your data." ] ;
                    oc:sectionLevel 2 ;
