oc:kn_01b201d3 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring a new sync pipeline" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """sync_config:
  source:
    type: {source_type}
    credentials:
      type: secret_manager
      path: "db/source/credentials"
    ssl: required
  target:
    type: {target_type}
    credentials:
      type: secret_manager
      path: "db/target/credentials"
    ssl: required
  sync_settings:
    mode: incremental
    batch_size: 10000
    parallel_tables: 4
    retry_attempts: 3
    checkpoint_interval: 5_minutes""" .

oc:kn_0a9714ba a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring source and target database connections" ;
    oc:directiveContent "Always use secret managers for database credentials. Never hardcode connection strings in configuration files." ;
    oc:hasRationale "Hardcoded credentials in config files create security vulnerabilities and make rotation difficult." ;
    oc:severityLevel "CRITICAL" .

oc:kn_2d9c8175 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When reporting sync status to users" ;
    oc:directiveContent """DATABASE SYNC STATUS
OVERALL STATUS: {status}
SOURCE: {source_type} ({source_db})
TARGET: {target_type} ({target_db})
MODE:   {sync_mode}

TABLES:
| Table | Status | Lag | Records |

THROUGHPUT:
Current:  {current_rate} records/sec
Average:  {avg_rate} records/sec

LAST 24 HOURS:
Records Synced: {total_records}
Errors:         {error_count}
Conflicts:      {conflict_count}""" ;
    oc:templateVariables "avg_rate",
        "conflict_count",
        "current_rate",
        "error_count",
        "source_db",
        "source_type",
        "status",
        "sync_mode",
        "target_db",
        "target_type",
        "total_records" .

oc:kn_475706d5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing sync method" ;
    oc:directiveContent "Use incremental sync with CDC (Change Data Capture) for near real-time replication. Use full sync only for initial setup, schema changes, or disaster recovery." ;
    oc:hasRationale "Incremental sync minimizes data transfer and enables near real-time replication without the downtime and resource cost of full syncs." .

oc:kn_4e749edc a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When sync job fails mid-batch" ;
    oc:directiveContent "Implement checkpoint intervals (e.g., 5 minutes) and retry logic (3 attempts) to resume sync from last successful checkpoint after transient failures." ;
    oc:hasRationale "Without checkpoints, failed syncs must restart from the beginning, wasting time and resources on large datasets." .

oc:kn_5136d889 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring sync monitoring" ;
    oc:directiveContent "Set alerting thresholds on sync lag: warn at >60 seconds, critical at >300 seconds. Monitor conflict count and error rates." ;
    oc:hasRationale "Early detection of replication lag prevents data staleness in downstream systems; unmonitored conflicts compound silently." .

oc:kn_53853250 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing schema evolution across synced databases" ;
    oc:directiveContent "Use schema_sync mode 'evolve' for safe column additions and type expansions. Set 'manual' action for column renames. Keep data when columns are removed." ;
    oc:hasRationale "Schema changes are the most common source of sync failures; evolving safely preserves data while preventing breakage." .

oc:kn_573b1fde a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring bi-directional or multi-source sync" ;
    oc:directiveContent "Define explicit conflict resolution strategies before enabling bi-directional sync: last_write_wins, source_priority, merge, or field-specific custom rules." ;
    oc:hasRationale "Without predefined conflict resolution, simultaneous writes to the same record across databases produce silent data corruption." ;
    oc:severityLevel "HIGH" .

oc:kn_5b5fa601 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Network connectivity between source and target database hosts is required. Database credentials must be stored in a secret manager. SSL certificates must be configured for encrypted connections." .

oc:kn_79fcb6b3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any full sync or migration operation" ;
    oc:directiveContent "Never run a full sync on production without testing against a staging replica first, and always backup before schema migration." ;
    oc:hasRationale "Full syncs are resource-intensive and require downtime; untested migrations can corrupt production data irreversibly." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9057fc6b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When setting up a new database sync pipeline" ;
    oc:directiveContent "1. Configure source and target database connections with secret manager credentials and SSL. 2. Define table mappings with column transformations and filters. 3. Choose sync method (full/incremental/snapshot) and CDC strategy. 4. Configure conflict resolution strategy. 5. Set schema evolution mode. 6. Create _sync_metadata tracking table. 7. Run initial full sync. 8. Switch to incremental sync with monitoring." ;
    oc:stepOrder 1 .

oc:kn_b32333e1 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When schema changes involve column renames or type modifications" ;
    oc:directiveContent "Column renames and type narrowing are inherently dangerous — always set these to 'manual' or 'review' action in schema sync configuration." ;
    oc:hasRationale "Renamed columns break existing mappings; type narrowing can silently truncate or lose data." ;
    oc:severityLevel "HIGH" .

oc:kn_b3d1e18b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating sync tracking infrastructure" ;
    oc:codeLanguage "sql" ;
    oc:directiveContent """CREATE TABLE IF NOT EXISTS _sync_metadata (
  table_name VARCHAR(100) PRIMARY KEY,
  last_sync_at TIMESTAMP,
  last_sync_key VARCHAR(255),
  records_synced BIGINT,
  status VARCHAR(20)
);""" .

oc:kn_cf34a2f9 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up trigger-based CDC on PostgreSQL" ;
    oc:codeLanguage "sql" ;
    oc:directiveContent """CREATE OR REPLACE FUNCTION track_changes()
RETURNS TRIGGER AS $$
BEGIN
  INSERT INTO _change_log (
    table_name, operation, key, changed_at
  ) VALUES (
    TG_TABLE_NAME, TG_OP, NEW.id, NOW()
  );
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;""" .

