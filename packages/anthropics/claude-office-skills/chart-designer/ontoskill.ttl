oc:kn_10fc86c7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting chart type or styling" ;
    oc:directiveContent "Never use pie charts for more than 5 categories; never start y-axis at non-zero for bar charts; never use more than 7 colors in a single chart." ;
    oc:hasRationale "Violating these rules misleads viewers through distorted proportions, false magnitude perception, and visual overload." ;
    oc:severityLevel "HIGH" .

oc:kn_196a9eb6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a chart type for user data" ;
    oc:directiveContent "Use the decision tree: Comparison→Bar/Line, Composition→Pie/Treemap/Stacked Area, Distribution→Histogram/Box/Scatter, Relationship→Scatter/Bubble/Heatmap, Flow→Funnel/Sankey/Gauge." ;
    oc:hasRationale "Matching chart type to the analytical question ensures the visualization communicates the intended insight." ;
    oc:severityLevel "HIGH" .

oc:kn_296450e1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any chart configuration" ;
    oc:directiveContent "Maximize data-ink ratio: remove unnecessary gridlines, minimize chart junk, use color purposefully, label axes with units, and keep appropriate decimal precision." ;
    oc:hasRationale "Following Tufte's data-ink ratio principle ensures charts communicate clearly without visual noise." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2a32c0a3 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating chart design output" ;
    oc:directiveContent "Output must include: Chart Design title, data type description, purpose, recommended chart type, ECharts JSON config, Chart.js config, styling recommendations (color palette + typography), best practices applied, and alternative chart suggestions." ;
    oc:hasRationale "Structured output ensures users get complete, actionable configurations they can immediately use." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2bb188ce a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When designing a chart" ;
    oc:directiveContent "1. Gather data type, story goal, audience, and display context from user. 2. Apply decision tree to recommend chart type(s). 3. Generate ECharts and Chart.js configurations with appropriate styling. 4. Provide color palette, typography, and alternative suggestions." ;
    oc:hasRationale "Following this sequence ensures the chart design addresses the user's actual communication need before jumping to configuration." ;
    oc:stepOrder 1 .

oc:kn_2ec7be80 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating ECharts bar chart configuration" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent "{ xAxis: { type: 'category', data: categories }, yAxis: { type: 'value' }, series: [{ type: 'bar', data: values, itemStyle: { color: '#5470c6' } }] }" .

oc:kn_336b83c9 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When suggesting color schemes" ;
    oc:directiveContent "Always provide the accessible (colorblind-friendly) palette as an option: #0077BB, #33BBEE, #009988, #EE7733, #CC3311, #EE3377, #BBBBBB." ;
    oc:hasRationale "Approximately 8% of men and 0.5% of women have color vision deficiency; accessible palettes ensure inclusivity." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3b2a6ddb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — this is a design/configuration skill, not a rendering tool" ;
    oc:directiveContent "This skill cannot render charts directly, create custom chart types from scratch, or access user data directly. It generates configurations that must be used in external tools." ;
    oc:hasRationale "Users must understand the output is configuration code, not rendered images." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4a901255 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating Chart.js configuration" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent "{ type: 'bar', data: { labels: categories, datasets: [{ label: seriesName, data: values, backgroundColor: 'rgba(54, 162, 235, 0.8)' }] }, options: { responsive: true, plugins: { title: { display: true, text: title } } } }" .

