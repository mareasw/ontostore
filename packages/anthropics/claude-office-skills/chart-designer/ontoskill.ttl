            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Chart Designer Skill" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
