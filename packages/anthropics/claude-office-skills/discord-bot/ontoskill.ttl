oc:kn_3f004ad8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing moderation systems" ;
    oc:directiveContent "Layer moderation with escalation: auto-delete → warn → timeout → ban. Always log all moderation actions to a private mod channel with timestamps." ;
    oc:hasRationale "Graduated responses prevent over-moderation while maintaining community safety; audit logs enable accountability" .

oc:kn_4042efc4 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When sending bulk messages or rapid automated responses" ;
    oc:directiveContent "Rate limiting: Discord enforces per-route rate limits. Implement queue-based message sending and respect 429 responses with Retry-After headers." ;
    oc:hasRationale "Exceeding rate limits causes temporary bot bans and dropped messages, breaking automation workflows" ;
    oc:severityLevel "HIGH" .

oc:kn_b61222b2 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before enabling auto-moderation features" ;
    oc:directiveContent "Before deploying a moderation bot, verify the bot role is hierarchically above all roles it needs to moderate, and that it has BAN_MEMBERS, MODERATE_MEMBERS, and MANAGE_MESSAGES permissions." ;
    oc:hasRationale "Discord's role hierarchy prevents bots from acting on users with equal or higher roles, causing silent permission failures" ;
    oc:severityLevel "CRITICAL" .

oc:kn_be7e9637 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring notification workflows" ;
    oc:directiveContent "Never use @everyone in automated notifications unless absolutely necessary. Always prefer targeted pings or role mentions." ;
    oc:hasRationale "@everyone pings generate notification fatigue and can cause members to leave the server or mute the channel" ;
    oc:severityLevel "HIGH" .

oc:kn_c66785c4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sending any bot message beyond simple responses" ;
    oc:directiveContent "Use Discord embeds (rich embeds) for structured content instead of plain text messages. Include color, fields with inline layout, thumbnails, and footers for polished presentation." ;
    oc:hasRationale "Embeds provide better visual hierarchy, are more readable, and look professional compared to raw text" .

oc:kn_deba295b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any Discord bot" ;
    oc:directiveContent "Three privileged intents must be explicitly enabled: PRESENCE_INTENT, SERVER_MEMBERS_INTENT, and MESSAGE_CONTENT_INTENT. Bots in 100+ servers require verification for these." ;
    oc:hasRationale "Discord requires explicit opt-in for privileged intents; missing them causes silent failures in event handling" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e2c3aa5a a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When setting up a new Discord bot" ;
    oc:directiveContent "1. Create application at discord.com/developers/applications → 2. Add Bot and copy token → 3. Enable PRESENCE_INTENT, SERVER_MEMBERS_INTENT, MESSAGE_CONTENT_INTENT → 4. Generate OAuth2 invite link with bot + applications.commands scopes → 5. Invite bot to server → 6. Register slash commands" ;
    oc:hasRationale "Proper setup order ensures all required intents and permissions are configured before the bot joins the server" ;
    oc:stepOrder 1 .

oc:kn_ed2f4f05 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating welcome embeds for Discord bots" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const welcomeEmbed = {
  title: '👋 Welcome!',
  description: `Hey ${member.user}, welcome to **${guild.name}**!`,
  color: 0x00ff00,
  fields: [
    { name: '📜 Rules', value: 'Check <#rules-channel>', inline: true },
    { name: '🎭 Roles', value: 'Get roles in <#roles>', inline: true }
  ],
  thumbnail: { url: member.user.displayAvatarURL() },
  footer: { text: `Member #${guild.memberCount}` }
};
welcomeChannel.send({ embeds: [welcomeEmbed] });""" .

oc:kn_fb342069 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """# {Bot Name}

## Configuration
```yaml
events:
  - {event_list}
```

## {Feature Name}
```javascript
// {description}
const embed = { title, description, color, fields, thumbnail, footer };
channel.send({ embeds: [embed] });
```

## n8n Workflow
```yaml
trigger: Discord - {event}
actions:
  - Discord - {action_1}
  - Discord - {action_2}
```""" ;
    oc:templateVariables "Bot Name",
        "Feature Name",
        "action_1",
        "action_2",
        "description",
        "event",
        "event_list" .

