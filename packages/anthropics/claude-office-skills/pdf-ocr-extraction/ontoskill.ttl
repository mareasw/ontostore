oc:kn_1f684202 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When processing large or batch documents" ;
    oc:directiveContent "OCR processing time increases with page count. Batch processing large document sets can consume significant compute resources and time." ;
    oc:hasRationale "Users should be warned about processing time for large jobs to set appropriate expectations." ;
    oc:severityLevel "LOW" .

oc:kn_284271e2 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing OCR extraction" ;
    oc:directiveContent "After OCR, verify: word count is reasonable for document length, no large empty sections, tables have correct column counts, and confidence scores are above acceptable thresholds." ;
    oc:hasRationale "Post-extraction validation catches systematic failures (blank pages, corrupt images) before results are delivered to the user." ;
    oc:severityLevel "MEDIUM" .

oc:kn_30cf0a15 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running OCR on any scanned document" ;
    oc:directiveContent "Before OCR, verify: 300 DPI minimum resolution (600 for small text), clear contrast (black text on white), straight alignment (no skew), no cut-off edges, and no stains/marks/shadows." ;
    oc:hasRationale "Image quality directly determines OCR accuracy. Pre-processing issues are the leading cause of poor extraction results." ;
    oc:severityLevel "HIGH" .

oc:kn_49aaca71 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assessing OCR output quality" ;
    oc:directiveContent "Typed documents yield 95%+ accuracy, printed books 90%+, forms 85%+, tables 80%+, neat handwriting 60-80%, cursive 30-60%. Flag any output below 80% confidence for manual review." ;
    oc:hasRationale "Knowing expected accuracy ranges helps agents determine when manual verification is necessary versus when results are reliable." ;
    oc:severityLevel "MEDIUM" .

oc:kn_aa38c2d6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting OCR extraction results" ;
    oc:directiveContent "Always include a confidence score and flag uncertain text with alternatives. Preserve the original document structure (sections, tables, headers) in the output." ;
    oc:hasRationale "Confidence scores and uncertain text markers enable users to quickly identify and verify the most error-prone portions of the extraction." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b3ae0902 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting text from handwritten or critical documents" ;
    oc:directiveContent "Do not trust OCR output for handwritten cursive text without manual review. Never assume 100% accuracy on legal, financial, or compliance documents without verification." ;
    oc:hasRationale "Unverified OCR errors in critical documents can lead to serious legal, financial, or compliance consequences." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c171e668 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting user expectations for OCR results" ;
    oc:directiveContent "OCR cannot guarantee 100% accuracy. Handwritten text has low accuracy (30-80%), decorative fonts are problematic, and background images reduce quality." ;
    oc:hasRationale "Users must understand OCR limitations to properly interpret and verify results, especially for critical documents." ;
    oc:severityLevel "HIGH" .

oc:kn_d272acf7 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When OCR confidence is below expected levels" ;
    oc:directiveContent "For poor quality scans, apply pre-processing in order: upscale resolution → auto-deskew → adjust contrast/threshold → noise reduction → convert to grayscale." ;
    oc:hasRationale "Sequential pre-processing systematically addresses the most common image quality issues that degrade OCR accuracy." ;
    oc:severityLevel "MEDIUM" .

oc:req_2eca0e81 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "extract_text_from_pdf" .

