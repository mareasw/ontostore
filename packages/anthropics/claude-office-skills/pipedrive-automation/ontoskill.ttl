    oc:differentia "automates Pipedrive-specific deal management, pipeline tracking, activity workflows, and sales reporting via MCP integration" ;
    oc:extends oc:skill_ontoskills_crm_automation ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "workflow-type (e.g., deal-management, pipeline-tracking, activity-automation, reporting, integration)" ;
    oc:hasCategory "crm" ;
    oc:hasDescription "Automate Pipedrive CRM workflows including deal management, pipeline tracking, and sales reporting" ;
    oc:hasName "pipedrive-automation" ;
    oc:hasRequirement oc:req_4002cc97,
        oc:req_7007f4df,
        oc:req_790497c9,
        oc:req_7a16c5b6,
        oc:req_b44b9e78,
        oc:req_dcf80ded ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: Pipedrive Automation
description: Automate Pipedrive CRM workflows including deal management, pipeline tracking, and sales reporting
version: 1.0.0
author: Claude Office Skills
category: crm
tags:
  - pipedrive
  - crm
  - sales
  - deals
  - pipeline
department: sales
models:
  - claude-3-opus
  - claude-3-sonnet
  - gpt-4
mcp:
  server: crm-mcp
  tools:
    - pipedrive_deal
    - pipedrive_person
    - pipedrive_organization
    - pipedrive_activity
capabilities:
  - Deal management
  - Pipeline automation
  - Activity tracking
  - Sales reporting
input:
  - Deal information
  - Contact details
  - Pipeline stages
  - Activity logs
output:
  - Deal updates
  - Pipeline reports
  - Forecasts
  - Activity summaries
languages:
  - en
related_skills:
  - crm-automation
  - hubspot-automation
  - salesforce-automation
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Comprehensive skill for automating Pipedrive CRM and sales pipeline management." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """PIPEDRIVE PIPELINE FLOW:
┌─────────────────────────────────────────────────────────┐
│                     PIPELINE VIEW                        │
├──────────┬──────────┬──────────┬──────────┬────────────┤
│  Lead    │ Contact  │ Proposal │ Negoti-  │   Won/     │
│  In      │  Made    │  Sent    │  ation   │   Lost     │
├──────────┼──────────┼──────────┼──────────┼────────────┤
│ $15,000  │ $45,000  │ $80,000  │ $35,000  │ $125,000   │
│ 5 deals  │ 8 deals  │ 6 deals  │ 3 deals  │ 12 deals   │
├──────────┼──────────┼──────────┼──────────┼────────────┤
│ ┌──────┐ │ ┌──────┐ │ ┌──────┐ │ ┌──────┐ │            │
│ │Acme  │ │ │Tech  │ │ │StartX│ │ │BigCo │ │            │
│ │$5,000│ │ │$12K  │ │ │$25K  │ │ │$20K  │ │            │
│ └──────┘ │ └──────┘ │ └──────┘ │ └──────┘ │            │
└──────────┴──────────┴──────────┴──────────┴────────────┘
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 56-72" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "1. Sales Pipeline" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """automations:
  - name: new_deal_setup
    trigger:
      type: deal_created
    actions:
      - create_activity:
          type: call
          subject: "Initial discovery call"
          due_days: 1
      - send_email:
          template: welcome_sequence
      - add_label: "New"
      
  - name: stage_progression
    trigger:
      type: deal_stage_changed
      to_stage: "Proposal Sent"
    actions:
      - create_activity:
          type: task
          subject: "Follow up on proposal"
          due_days: 3
      - update_custom_field:
          field: "Proposal Date"
          value: "{{today}}"
          
  - name: stale_deal_alert
    trigger:
      type: deal_rotting
      days: 14
    actions:
      - send_notification:
          to: owner
          message: "Deal hasn't moved in 14 days"
      - add_label: "At Risk"
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 76-112" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "2. Automation Triggers" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Workflows" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """pipeline_config:
  name: "Sales Pipeline"
  
  stages:
    - name: "Lead In"
      probability: 10%
      rotting_days: 7
      
    - name: "Contact Made"
      probability: 20%
      rotting_days: 10
      
    - name: "Needs Defined"
      probability: 40%
      rotting_days: 14
      
    - name: "Proposal Sent"
      probability: 60%
      rotting_days: 14
      
    - name: "Negotiation"
      probability: 80%
      rotting_days: 7
      
    - name: "Won"
      probability: 100%
      
    - name: "Lost"
      probability: 0%
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 162-192" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Pipeline Stages" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """deal_structure:
  required_fields:
    - title
    - value
    - organization
    - stage
    - owner
    
  custom_fields:
    - name: "Lead Source"
      type: enum
      options:
        - "Inbound - Website"
        - "Inbound - Referral"
        - "Outbound - Cold"
        - "Event"
        - "Partner"
        
    - name: "Product Interest"
      type: set
      options:
        - "Product A"
        - "Product B"
        - "Services"
        
    - name: "Decision Timeline"
      type: enum
      options:
        - "< 1 month"
        - "1-3 months"
        - "3-6 months"
        - "6+ months"
        
    - name: "Proposal Amount"
      type: monetary
      
    - name: "Close Probability"
      type: numeric
      format: percentage
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 118-158" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Deal Configuration" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Deal Management" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """SALES DASHBOARD - JANUARY 2024
═══════════════════════════════════════

PIPELINE VALUE: $175,000
WEIGHTED: $89,500

BY STAGE:
Lead In       ████░░░░░░░░░░░░ $15,000
Contact Made  ████████░░░░░░░░ $45,000
Proposal      ████████████░░░░ $80,000
Negotiation   ██████░░░░░░░░░░ $35,000

SALES VELOCITY:
Deals Closed:     12
Average Value:    $10,400
Win Rate:         28%
Sales Cycle:      34 days

BY REP:
┌────────────┬────────┬──────────┬───────┐
│ Rep        │ Deals  │ Value    │ Win % │
├────────────┼────────┼──────────┼───────┤
│ Sarah      │ 5      │ $52,000  │ 35%   │
│ Mike       │ 4      │ $41,000  │ 28%   │
│ Lisa       │ 3      │ $32,000  │ 22%   │
└────────────┴────────┴──────────┴───────┘

FORECAST:
This Month:   $45,000 (weighted)
Next Month:   $68,000 (weighted)
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 314-345" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Sales Dashboard" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """win_loss_tracking:
  won_reasons:
    - "Best product fit"
    - "Competitive pricing"
    - "Relationship/trust"
    - "Implementation timeline"
    
  lost_reasons:
    - "Price too high"
    - "Chose competitor"
    - "No budget"
    - "No decision made"
    - "Lost contact"
    
  analysis:
    win_rate_by_source:
      inbound: 35%
      outbound: 18%
      referral: 45%
      
    win_rate_by_size:
      small: 42%
      medium: 28%
      enterprise: 15%
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 349-374" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Win/Loss Analysis" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Reporting & Analytics" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """activity_workflows:
  discovery_call_complete:
    trigger:
      activity_type: call
      marked_done: true
      deal_stage: "Lead In"
    actions:
      - move_deal_stage: "Contact Made"
      - create_activity:
          type: task
          subject: "Send follow-up email"
          due_days: 1
      - update_deal:
          custom_field: "First Contact Date"
          value: "{{activity.done_time}}"
          
  meeting_scheduled:
    trigger:
      activity_type: meeting
      created: true
    actions:
      - send_email:
          template: meeting_confirmation
          to: "{{deal.contact}}"
      - create_activity:
          type: task
          subject: "Prepare meeting agenda"
          due_before_meeting: 1_day
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 223-252" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Activity Automation" ],
