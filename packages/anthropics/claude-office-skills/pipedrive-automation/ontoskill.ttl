oc:kn_38a07568 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When setting up automation triggers" ;
    oc:directiveContent "Automate stage-progression triggers: new deal → create discovery call activity (due in 1 day) + send welcome email + add 'New' label. Stage changed to 'Proposal Sent' → create follow-up task (due in 3 days) + update Proposal Date field." ;
    oc:hasRationale "Automation ensures no deal falls through cracks and follow-ups happen on schedule" .

oc:kn_404abdb7 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding activities to deals" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """await pipedrive.activities.create({
  deal_id: deal.id,
  type: "call",
  subject: "Discovery call",
  due_date: "2024-01-20",
  due_time: "14:00"
});""" .

oc:kn_6b687194 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating sales reports" ;
    oc:directiveContent """SALES DASHBOARD - {MONTH} {YEAR}
PIPELINE VALUE: {total_value}
WEIGHTED: {weighted_value}
BY STAGE: {stage_breakdown}
SALES VELOCITY: Deals Closed / Avg Value / Win Rate / Sales Cycle
BY REP: Rep | Deals | Value | Win %
FORECAST: This Month / Next Month (weighted)""" ;
    oc:templateVariables "MONTH",
        "YEAR",
        "stage_breakdown",
        "total_value",
        "weighted_value" .

oc:kn_7dd6ec32 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When managing Pipedrive CRM workflows" ;
    oc:directiveContent "1. Define clear stage criteria for pipeline discipline 2. Log all interactions as activities 3. Review pipeline regularly for hygiene 4. Set rotting alerts (don't let deals stagnate) 5. Track key data via custom fields 6. Use templates for consistent communication 7. Run weekly pipeline reviews 8. Connect all touchpoints via integrations" ;
    oc:stepOrder 1 .

oc:kn_ac221569 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring pipeline stages" ;
    oc:directiveContent "Each pipeline stage must have clear entry/exit criteria with assigned probability and rotting thresholds. Lead In=10%, Contact Made=20%, Needs Defined=40%, Proposal Sent=60%, Negotiation=80%, Won=100%, Lost=0%." ;
    oc:hasRationale "Stage discipline ensures accurate weighted pipeline values and reliable forecasting" ;
    oc:severityLevel "HIGH" .

oc:kn_b1b6c21e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing pipeline or forecasting" ;
    oc:directiveContent "Track win/loss reasons to identify patterns. Inbound leads win ~35%, referrals win ~45%, outbound only ~18%. Small deals close at 42% vs enterprise at 15%. Use these benchmarks to prioritize pipeline efforts." ;
    oc:hasRationale "Historical win rates by source and deal size enable better resource allocation and forecast accuracy" ;
    oc:severityLevel "MEDIUM" .

oc:kn_db5c0aca a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating deals via Pipedrive API" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const deal = await pipedrive.deals.create({
  title: "Acme Corp - Enterprise Plan",
  value: 50000,
  currency: "USD",
  org_id: 123,
  person_id: 456,
  stage_id: 1,
  expected_close_date: "2024-02-28",
  custom_fields: { "Lead Source": "Inbound - Website" }
});""" .

oc:kn_eeec75e6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When monitoring pipeline health" ;
    oc:directiveContent "Never let deals sit without activity beyond their stage's rotting threshold (7-14 days depending on stage). Deals stagnating past rotting days should trigger alerts and be flagged 'At Risk'." ;
    oc:hasRationale "Stagnant deals inflate pipeline value and reduce forecast accuracy" ;
    oc:severityLevel "HIGH" .

oc:kn_efa6f7b1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or updating deals" ;
    oc:directiveContent "Required deal fields: title, value, organization, stage, owner. Custom fields (Lead Source, Product Interest, Decision Timeline, Proposal Amount, Close Probability) should be populated for full pipeline visibility." ;
    oc:hasRationale "Incomplete deal records lead to poor reporting and lost context" ;
    oc:severityLevel "MEDIUM" .

