                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Activity Management" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_37d991f4869fbbc1 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Best Practices" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """email_tracking:
  features:
    - open_tracking
    - link_tracking
    - attachment_tracking
    
  automations:
    on_email_opened:
      - create_activity:
          type: task
          subject: "Follow up - Email opened"
          due_hours: 2
          
    on_link_clicked:
      - add_note: "Clicked link: {{link_url}}"
      - update_custom_field:
          field: "Engagement Level"
          value: "High"
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 289-308" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Email Tracking" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """email_templates:
  - name: "Initial Outreach"
    subject: "{{company}} + {{prospect_company}}"
    body: |
      Hi {{first_name}},
      
      I noticed {{company_insight}} and thought 
      {{value_proposition}}.
      
      Would you be open to a 15-minute call this week?
      
      Best,
      {{sender_name}}
      
  - name: "Proposal Follow-up"
    subject: "Following up on our proposal"
    body: |
      Hi {{first_name}},
      
      I wanted to follow up on the proposal I sent 
      on {{proposal_date}}.
      
      Do you have any questions I can help answer?
      
      Best,
      {{sender_name}}
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 258-285" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Email Templates" ] ;
