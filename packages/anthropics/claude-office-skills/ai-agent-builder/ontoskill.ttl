                    oc:contentOrder 1 ;
                    oc:textContent "Design and build AI agents with tools, memory, and multi-step reasoning capabilities. Covers ChatGPT, Claude, Gemini integration patterns based on n8n's 5,000+ AI workflow templates." ] ;
