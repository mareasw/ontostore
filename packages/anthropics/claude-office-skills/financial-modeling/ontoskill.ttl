                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """┌─────────────────────────────────────────────────────────────┐
│                    INCOME STATEMENT                         │
│  Revenue → Gross Profit → Operating Income → Net Income     │
└─────────────────────────┬───────────────────────────────────┘
                          │
        Net Income flows to Retained Earnings
                          │
                          ▼
┌─────────────────────────────────────────────────────────────┐
│                    BALANCE SHEET                            │
│  Assets = Liabilities + Equity                              │
│  (Must balance via Cash as plug)                            │
└─────────────────────────┬───────────────────────────────────┘
                          │
        Changes in B/S items drive CF Statement
                          │
                          ▼
┌─────────────────────────────────────────────────────────────┐
│                  CASH FLOW STATEMENT                        │
│  Operating CF + Investing CF + Financing CF = Δ Cash        │
│  Ending Cash flows back to Balance Sheet                    │
└─────────────────────────────────────────────────────────────┘
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 107-130" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Three-Statement Linkages" ],
                        [ a oc:Section ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """Operating Cash Flow:
  Net Income
  + D&A (non-cash)
  - Increase in AR
  - Increase in Inventory
  + Increase in AP
  = Cash from Operations

Investing Cash Flow:
  - Capex
  = Cash from Investing

Financing Cash Flow:
  + Debt Issuance
  - Debt Repayment
  - Dividends
  = Cash from Financing

Net Change in Cash = CFO + CFI + CFF
""" ;
                                            oc:codeLanguage "" ;
                                            oc:contentOrder 1 ;
                                            oc:sourceLocation "lines 160-180" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 3 ;
                                    oc:sectionTitle "Cash Flow Statement" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """Revenue = Prior Year × (1 + Growth Rate)
COGS = Revenue × (1 - Gross Margin %)
Gross Profit = Revenue - COGS
SG&A = Revenue × SG&A %
EBITDA = Gross Profit - SG&A
D&A = Prior PP&E × D&A Rate OR Revenue × D&A %
EBIT = EBITDA - D&A
Interest = Avg Debt × Interest Rate
EBT = EBIT - Interest
Taxes = EBT × Tax Rate
Net Income = EBT - Taxes
""" ;
                                            oc:codeLanguage "" ;
                                            oc:contentOrder 1 ;
                                            oc:sourceLocation "lines 135-147" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 1 ;
                                    oc:sectionTitle "Income Statement Drivers" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """Accounts Receivable = Revenue × (DSO / 365)
Inventory = COGS × (DIO / 365)
Accounts Payable = COGS × (DPO / 365)
PP&E = Prior PP&E + Capex - D&A
Retained Earnings = Prior RE + Net Income - Dividends
Cash = Total Liabilities + Equity - Other Assets (plug)
""" ;
                                            oc:codeLanguage "" ;
