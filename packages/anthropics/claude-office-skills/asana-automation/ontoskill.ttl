oc:kn_075f6d0f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When triaging or assigning tasks in Asana" ;
    oc:directiveContent "Avoid creating tasks without assignees or due dates, and do not overload team members beyond 100% capacity." ;
    oc:hasRationale "Unassigned or undated tasks fall through cracks; overloading leads to missed deadlines and burnout." ;
    oc:severityLevel "HIGH" .

oc:kn_2c284201 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring custom fields for any Asana project" ;
    oc:directiveContent "Custom fields must be used consistently across all projects within a workspace to maintain reporting accuracy." ;
    oc:hasRationale "Inconsistent field definitions break cross-project reporting and portfolio dashboards." ;
    oc:severityLevel "MEDIUM" .

oc:kn_60a2d735 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or updating any Asana task" ;
    oc:directiveContent "Use action verbs in task names, assign a single accountable person per task, and always set realistic due dates." ;
    oc:hasRationale "Clear task names and single ownership reduce ambiguity and improve accountability across the team." ;
    oc:severityLevel "MEDIUM" .

oc:kn_804b21ce a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring any Asana project" ;
    oc:directiveContent "Break complex work into subtasks, use reusable project templates, and organize with sections (Backlog, To Do, In Progress, Review, Done)." ;
    oc:hasRationale "Granular subtasks with clear section-based workflows improve tracking, estimation, and velocity measurement." .

oc:kn_bbd97803 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When workload monitoring shows overallocation" ;
    oc:directiveContent "When team members exceed capacity (110%+), rebalance by reassigning tasks to underutilized members, extending deadlines, or adding resources." ;
    oc:hasRationale "Proactive rebalancing prevents burnout and keeps delivery timelines on track." .

