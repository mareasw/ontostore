    oc:appliesToContext "When building daily calendar digests or weekly analytics reports" ;
    oc:directiveContent "Categorize calendar events by type (meetings, focus time, 1:1s, interviews) before generating digest or analytics to enable meaningful breakdowns." ;
    oc:hasRationale "Categorization enables actionable insights rather than raw time tallies" .

oc:kn_11bd4959 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating time blocks or scheduling meetings" ;
    oc:directiveContent "Maintain a minimum 15-minute gap between meetings to avoid back-to-back scheduling. Limit meetings to 5 per day maximum." ;
    oc:hasRationale "Back-to-back meetings reduce cognitive recovery time and lower meeting quality" ;
    oc:severityLevel "HIGH" .

oc:kn_174386ea a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Meeting preparation document" ;
    oc:directiveContent """# Meeting Prep: {title}
**Time:** {start_time}
**Duration:** {duration}
**Link:** {meeting_link}
## Attendees
{attendee_profiles}
## Context
- Last interaction: {last_meeting_date}
- Open items: {open_tasks}
- Recent emails: {email_summary}
## Suggested Agenda
{ai_suggested_agenda}
## Talking Points
{ai_talking_points}""" ;
    oc:templateVariables "ai_suggested_agenda",
        "ai_talking_points",
        "attendee_profiles",
        "duration",
        "email_summary",
        "last_meeting_date",
        "meeting_link",
        "open_tasks",
        "start_time",
        "title" .

oc:kn_2a5351b2 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When automating meeting preparation" ;
    oc:directiveContent "1. Trigger 1 hour before meetings with attendees and duration >= 30min. 2. Extract meeting details. 3. Research each attendee (LinkedIn, CRM, email threads). 4. Generate prep doc with attendee profiles, context, suggested agenda, talking points. 5. Send Slack DM reminder with prep doc link and join link." ;
    oc:stepOrder 2 .

oc:kn_3992a4f9 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Weekly calendar analytics report" ;
    oc:directiveContent """# 📊 Weekly Calendar Analytics
## Time Distribution
| Category | Hours | % of Week |
|----------|-------|-----------|
| Meetings | {meetings_hours} | {meetings_pct}% |
| Focus Time | {focus_hours} | {focus_pct}% |
| Admin | {admin_hours} | {admin_pct}% |
| Available | {available_hours} | {available_pct}% |
## Meeting Insights
- Total meetings: {total_meetings}
- Average length: {avg_length} min
- Back-to-back: {b2b_count} ({b2b_pct}%)
- With agenda: {agenda_pct}%
## Productivity Score
🎯 **{productivity_score}/100**
## Recommendations
{ai_recommendations}""" ;
    oc:templateVariables "admin_hours",
        "admin_pct",
        "agenda_pct",
        "ai_recommendations",
        "available_hours",
        "available_pct",
        "avg_length",
        "b2b_count",
        "b2b_pct",
        "focus_hours",
        "focus_pct",
        "meetings_hours",
        "meetings_pct",
        "productivity_score",
        "total_meetings" .

oc:kn_54336713 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When daily digest finds empty calendar" ;
    oc:directiveContent "If calendar API returns no events, still send the digest with 'No meetings today' and a productivity tip instead of failing silently." ;
    oc:hasRationale "Consistent delivery builds habit; silent failures erode trust in the automation" .

oc:kn_7612bb2e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running auto time blocking workflow" ;
    oc:directiveContent "Never schedule focus blocks or admin time without first checking existing commitments — always analyze the current calendar state before creating new blocks." ;
    oc:hasRationale "Overwriting existing meetings causes missed appointments and loss of trust" ;
    oc:severityLevel "CRITICAL" .

oc:kn_99d2e5af a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When handling Calendly booking flow" ;
    oc:directiveContent "1. On Calendly booking, extract invitee details. 2. Enrich contact via Clearbit/LinkedIn. 3. Create Google Calendar event with reminders (1 day, 1 hour, 15 min). 4. Create/update CRM contact and engagement. 5. Send confirmation email with calendar invite. 6. Notify Slack channel." ;
    oc:stepOrder 3 .

oc:kn_c404e03f a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building daily calendar digest to Slack" ;
    oc:directiveContent "1. Fetch today's events from primary calendar. 2. Categorize events (meetings, focus, 1:1s, interviews). 3. Calculate stats (total meetings, hours, free time, back-to-back). 4. Format Slack message with overview + event list + daily tip. 5. Send to Slack channel or DM. 6. Log metrics to Google Sheets." ;
    oc:stepOrder 1 .

oc:kn_e59a8aa6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring auto time blocking" ;
    oc:directiveContent "Protect morning hours (9-11am) for deep work blocks of at least 2 hours. Reserve collaborative work for afternoon blocks (2-4pm)." ;
    oc:hasRationale "Circadian rhythm research shows peak analytical performance in mid-morning hours" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e6f2bc8d a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Daily calendar digest Slack message" ;
    oc:directiveContent """☀️ *Good morning! Here's your day:*
📅 *{date}*
*Schedule Overview:*
• {total_meetings} meetings ({total_hours}h)
• {free_time}h of free time
• {back_to_back} back-to-back slots ⚠️
*Today's Events:*
{event_list}
💡 *Tip:* {daily_tip}""" ;
    oc:templateVariables "back_to_back",
        "daily_tip",
        "date",
        "event_list",
        "free_time",
        "total_hours",
        "total_meetings" .

