        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasAllowedTool "calendar_create_event",
        "calendar_list_events",
        "calendar_update",
        "slack_notify" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Google Calendar and Outlook automation - scheduling optimization, meeting workflows, time blocking, and Slack/Sheets integration" ;
    oc:hasName "calendar-automation" ;
    oc:hasRequirement oc:req_1a93a60a,
        oc:req_1b783e40,
        oc:req_2b3bde49,
        oc:req_8e8bfed9,
        oc:req_9626a941,
        oc:req_b8a29706,
        oc:req_f5692e48 ;
