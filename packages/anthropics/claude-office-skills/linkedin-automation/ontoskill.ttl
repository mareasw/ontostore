oc:kn_2ffb61ba a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating and publishing LinkedIn content" ;
    oc:directiveContent "Follow the content pipeline sequence: Content Plan → Create Post → Optimize (hook, hashtags, CTA) → Schedule (best time, frequency) → Engage (comments, DMs)." ;
    oc:hasRationale "Structured content creation maximizes reach and engagement through systematic optimization at each stage." ;
    oc:severityLevel "HIGH" .

oc:kn_31df15e5 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When running B2B lead generation outreach campaigns" ;
    oc:directiveContent "Use a 4-step outreach sequence: (1) Connection request with personalized template → (2) Wait for acceptance, then message after 2 days asking about pain points → (3) Wait 5 days if no response, share free resource → (4) Manual personalized follow-up on response." ;
    oc:hasRationale "Graduated outreach with value-added touches avoids being perceived as spam and builds genuine relationships." ;
    oc:severityLevel "HIGH" .

oc:kn_6f55845d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When engaging with LinkedIn posts or responding to comments" ;
    oc:directiveContent "Never use generic or copy-pasted comments for engagement. All comments must be authentic and value-adding." ;
    oc:hasRationale "Generic engagement damages credibility and can trigger LinkedIn's spam detection, reducing account visibility." ;
    oc:severityLevel "HIGH" .

oc:kn_72be30d7 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """LINKEDIN ANALYTICS REPORT:
- Profile: Views, Connections, Search Appearances
- Post Performance: Per-post Impressions and Engagement %
- Engagement: Likes, Comments, Shares, Saves
- Audience Growth: Weekly connection additions
- Company Page: Followers, Page Views, Post Reach""" ;
    oc:templateVariables "Comments",
        "Connections",
        "Engagement_pct",
        "Followers",
        "Impressions",
        "Likes",
        "Page_Views",
        "Post_Reach",
        "Saves",
        "Search Appearances",
        "Shares",
        "Views" .

oc:kn_7f70f745 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting posting schedule and engagement strategy" ;
    oc:directiveContent "Post 3-5 times per week for optimal consistency. Use 3-5 relevant hashtags per post. Respond to engagement within the first hour." ;
    oc:hasRationale "LinkedIn's algorithm favors consistent posting cadence and early engagement signals." ;
    oc:severityLevel "MEDIUM" .

oc:kn_84e249ee a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When automating any LinkedIn activity via MCP tools" ;
    oc:directiveContent "LinkedIn aggressively detects and penalizes automated behavior. Space out actions, vary messaging, and avoid bulk operations that exceed human-scale patterns." ;
    oc:hasRationale "Account restriction from LinkedIn can halt all automation and damage brand reputation irreversibly." ;
    oc:severityLevel "CRITICAL" .

oc:kn_bcfc957f a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing the content pipeline workflow" ;
    oc:directiveContent "1. Plan content topics and calendar → 2. Create post (text, visual, or document) → 3. Optimize with hook, hashtags, and CTA → 4. Schedule at best time with 3-5x/week frequency → 5. Engage with comments and DMs within first hour" ;
    oc:stepOrder 1 .

oc:kn_c78bee88 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires social-mcp server with linkedin_post, linkedin_message, linkedin_analytics, and linkedin_leads tools configured and authenticated." .

oc:kn_ca2eea10 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing the lead generation workflow" ;
    oc:directiveContent "1. Search with filters (industry, company size, title, location) → 2. Qualify (recent activity, mutual connections, engagement score >50) → 3. Send connection request → 4. Wait 2 days, send intro message → 5. Wait 3 days, send value-add follow-up → 6. Score lead and route to appropriate tier" ;
    oc:stepOrder 2 .

oc:kn_cdcffead a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing LinkedIn post content" ;
    oc:directiveContent "First line of any LinkedIn post must be a hook that grabs attention. Personal stories outperform other formats." ;
    oc:hasRationale "LinkedIn truncates posts in feed, making the first line critical for stop-scrolling; stories drive the highest engagement rates." ;
    oc:severityLevel "HIGH" .

oc:kn_e32a5466 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When qualifying LinkedIn leads" ;
    oc:directiveContent "Lead scoring tiers: Hot (>75 points), Warm (50-75 points), Cold (<50 points). Weight fit criteria (title, company size, industry) highest at 20/15/10, then engagement signals (DM response=25, share=20, comment=15, like=5)." ;
    oc:hasRationale "Balancing fit and engagement signals ensures outreach targets the right people who are also actively interested." ;
    oc:severityLevel "MEDIUM" .

oc:kn_eee12c85 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing LinkedIn company pages" ;
    oc:directiveContent "Company page content should follow the 40/25/20/15 split: 40% thought leadership, 25% company culture, 20% product updates, 15% industry news. Post on Tue/Wed/Thu at 08:00, 12:00, or 17:30." ;
    oc:hasRationale "Content pillar ratios prevent over-promotion and maintain audience interest; timing aligns with peak LinkedIn usage." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f11eaeb7 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring automated outreach sequences" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """outreach_sequence:
  - step: 1
    type: connection_request
    template: mutual_connection
  - step: 2
    trigger: connection_accepted
    delay: 2_days
    type: message
  - step: 3
    trigger: no_response
    delay: 5_days
    type: message
  - step: 4
    trigger: response_received
    action: manual_follow_up""" .

