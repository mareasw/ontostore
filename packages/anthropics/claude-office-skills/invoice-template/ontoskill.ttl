    oc:appliesToContext "When creating invoices for any client" ;
    oc:directiveContent "Use templates for consistent branding across all invoices — same layout, fonts, colors, and logo placement." ;
    oc:hasRationale "Consistent branding reinforces professionalism and makes invoices recognizable by clients and accounts payable." ;
    oc:severityLevel "MEDIUM" .

