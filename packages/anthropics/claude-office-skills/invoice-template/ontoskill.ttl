oc:kn_972a95c3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing invoice items and totals" ;
    oc:directiveContent "Auto-calculate totals, tax, and line-item amounts from quantity and rate — never trust pre-computed input values." ;
    oc:hasRationale "Relying on input totals risks arithmetic errors and discrepancies that break trust with clients." ;
    oc:severityLevel "HIGH" .

oc:kn_ae953fc0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building invoice generation systems" ;
    oc:directiveContent "Do not hardcode styling or layout directly in generation code without template separation." ;
    oc:hasRationale "Hardcoded layouts make per-client customization difficult and error-prone." ;
    oc:severityLevel "MEDIUM" .

