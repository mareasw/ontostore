  - PPC campaign management
input:
  - Product listings
  - Inventory data
  - Order information
  - Ad campaigns
output:
  - Inventory reports
  - Sales analytics
  - Ad performance
  - Profit calculations
languages:
  - en
related_skills:
  - shopify-automation
  - woocommerce-automation
  - inventory-management
""" ] ;
