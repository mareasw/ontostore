    oc:appliesToContext "When planning FBA inventory replenishment" ;
    oc:directiveContent "Target 30 days of supply as the reorder point and 90 days as target stock, with a 21-day lead time for replenishment." ;
    oc:hasRationale "Preventing stockouts protects sales velocity and Buy Box placement while avoiding excess storage fees from overstocking." ;
