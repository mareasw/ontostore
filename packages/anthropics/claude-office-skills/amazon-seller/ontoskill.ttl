                                    oc:blockType "code_block" ;
                                    oc:codeContent """ppc_structure:
  sponsored_products:
    auto_campaigns:
      - name: "{{product}}_Auto_Research"
        targeting: auto
        budget: $20/day
        purpose: keyword_discovery
        
    manual_campaigns:
      - name: "{{product}}_Exact"
        match_type: exact
        keywords: top_performers
        budget: $50/day
        
      - name: "{{product}}_Phrase"
        match_type: phrase
        keywords: mid_performers
        budget: $30/day
        
      - name: "{{product}}_Broad"
        match_type: broad
        keywords: discovery
        budget: $20/day
        
  bid_optimization:
    target_acos: 25%
    rules:
      - condition: "acos < 20%"
        action: "increase_bid_10%"
      - condition: "acos > 35%"
        action: "decrease_bid_15%"
      - condition: "no_sales_7_days"
        action: "pause_keyword"
""" ;
