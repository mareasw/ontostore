oc:kn_35bc5d95 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating product profitability or setting prices" ;
    oc:directiveContent "Calculate profitability using the full cost stack: Sale Price - Product Cost - FBA Fee (size-based) - Referral Fee (typically 15%) - Storage Fee (monthly) - Inbound Shipping - PPC Cost (ACoS-based)." ;
    oc:hasRationale "Sellers often underestimate total fees (FBA + referral + storage + PPC), leading to inaccurate margin calculations and unprofitable sales." .

