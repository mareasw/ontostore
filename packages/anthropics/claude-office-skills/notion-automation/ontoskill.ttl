mcp:
  server: notion-mcp
  tools:
    - notion_create_page
    - notion_update_database
    - notion_query

capabilities:
  - database_automation
  - template_creation
  - cross_platform_sync
  - workflow_triggers
  - content_management

languages:
  - en
  - zh

related_skills:
  - sheets-automation
  - slack-workflows
  - crm-automation
""" ] ;
