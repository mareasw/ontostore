        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing cross-platform workflows feeding into Notion" ;
    oc:directiveContent "Structure automations as trigger → enrich → create → notify pipelines, using AI extraction for unstructured data (Slack messages, forms) before Notion page creation." ;
    oc:hasRationale "Raw unstructured data creates noisy Notion entries; enrichment and AI parsing produces clean, actionable database records." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9fd806e2 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When executing any integration recipe" ;
    oc:directiveContent "Cross-platform workflows (Notion + Slack, Calendar, GitHub) create artifacts on multiple systems simultaneously — Slack messages, calendar events, and GitHub issues." ;
    oc:hasRationale "Agents must be aware of external side effects for rollback and debugging scenarios." ;
    oc:severityLevel "HIGH" .

oc:kn_ac8009cd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining database automations for task/content pipelines" ;
    oc:directiveContent "Include automated follow-up triggers (Slack reminders, assignment rotation, due date enforcement) for status-change automations to prevent stale items." ;
    oc:hasRationale "Automations without follow-up triggers lead to abandoned items in databases." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c2db379d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring calendar sync or any two-way synchronization workflow" ;
    oc:directiveContent "Use bidirectional sync patterns with conflict resolution for Calendar ↔ Notion integrations to prevent data duplication and race conditions." ;
    oc:hasRationale "Unidirectional sync creates stale data; bidirectional without conflict resolution creates duplicates." ;
    oc:severityLevel "HIGH" .

oc:kn_d40b7fbd a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running bidirectional sync workflows" ;
    oc:directiveContent "Calendar sync workflows are NOT idempotent — running them twice creates duplicate events/pages. Add deduplication checks using unique identifiers." ;
    oc:hasRationale "Lack of idempotency causes data proliferation in production workflows." ;
    oc:severityLevel "HIGH" .

oc:kn_e864e716 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up any Notion automation or page creation" ;
    oc:directiveContent "Never create workflows that modify Notion databases without first verifying the database schema and property types match expected formats." ;
    oc:hasRationale "Schema mismatches cause silent data loss or workflow failures that are hard to debug." ;
    oc:severityLevel "CRITICAL" .

