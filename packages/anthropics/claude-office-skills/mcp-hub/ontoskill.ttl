oc:kn_38d286fb a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before enabling any MCP server" ;
    oc:directiveContent "Check server permissions before enabling an MCP server to understand what external resources it can access." ;
    oc:hasRationale "Understanding permissions prevents accidental data exposure or privilege escalation." ;
    oc:severityLevel "HIGH" .

oc:kn_8d69a0c7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which MCP server to use" ;
    oc:directiveContent "Use official MCP servers when available, as they are maintained by the protocol team and have better security/compatibility guarantees." ;
    oc:hasRationale "Official servers undergo more rigorous testing and have community trust." ;
    oc:severityLevel "MEDIUM" .

oc:kn_94b36074 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building multi-step integrations" ;
    oc:directiveContent "Combine multiple MCP servers for complex workflows — e.g., filesystem + database + API servers together for end-to-end data pipelines." ;
    oc:hasRationale "Individual MCP servers are narrow in scope; combining them enables rich, composable workflows." .

oc:kn_9ecb71c1 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using any MCP server configured with npx" ;
    oc:directiveContent "Node.js/npx must be available for running most MCP servers (launched via npx -y @modelcontextprotocol/server-xxx)." ;
    oc:severityLevel "HIGH" .

oc:kn_d40fa729 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When configuring MCP servers" ;
    oc:directiveContent "Only enable MCP servers you need — each enabled server expands the attack surface and grants access to external resources." ;
    oc:hasRationale "Minimizing enabled servers reduces the risk of unauthorized access or unintended side effects." ;
    oc:severityLevel "HIGH" .

oc:kn_ffd7a1f0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any MCP server" ;
    oc:directiveContent "MCP servers are configured via JSON in the mcpServers key, each requiring a command and args array specifying how to launch the server process." ;
    oc:hasRationale "The MCP protocol requires this specific configuration format for server discovery and launch." .

