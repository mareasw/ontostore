                                    oc:contentOrder 1 ;
                                    oc:rowCount 11 ;
                                    oc:tableCaption "### Layout Element Types" ;
                                    oc:tableMarkdown """| Element | Description |
|---------|-------------|
| Text | Regular paragraph text |
| Title | Document/section titles |
| Section-header | Section headings |
| List-item | Bulleted/numbered items |
| Table | Tabular data |
| Figure | Images/diagrams |
| Caption | Figure/table captions |
| Footnote | Footnotes |
| Formula | Mathematical equations |
| Page-header | Headers |
| Page-footer | Footers |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Layout Element Types" ],
