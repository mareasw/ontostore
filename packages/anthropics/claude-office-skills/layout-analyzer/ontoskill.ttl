    oc:appliesToContext "When analyzing handwritten or low-resolution documents" ;
    oc:directiveContent "Do not trust layout results blindly for handwritten documents or very small text regions — these cases produce inaccurate detections." ;
    oc:hasRationale "surya models are trained on printed/typed documents and struggle with handwritten content and tiny text" ;
    oc:severityLevel "MEDIUM" .

oc:kn_4a55a1cc a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After layout analysis completes" ;
    oc:directiveContent "Check confidence scores on detected elements — low confidence indicates potential misdetection requiring manual verification." ;
    oc:hasRationale "Confidence scores below ~0.7 often indicate borderline detections that should be validated" .

oc:kn_4e013ca3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before running layout analysis" ;
    oc:directiveContent "Preprocess documents before analysis: deskew rotated pages, ensure adequate contrast, and crop irrelevant margins." ;
    oc:hasRationale "Document rotation and poor contrast degrade detection accuracy; preprocessing normalizes input quality" .

oc:kn_54c25973 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When processing large multi-page PDFs" ;
    oc:directiveContent "Layout analysis on multi-page PDFs converts all pages to images in memory, which can be memory-intensive for large documents." ;
    oc:hasRationale "pdf2image loads all pages into memory simultaneously; batch processing may exhaust RAM" ;
    oc:severityLevel "MEDIUM" .

oc:kn_78fa3c7b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing documents for layout analysis" ;
    oc:directiveContent "Use 150+ DPI images for best layout detection results. Lower resolution degrades accuracy." ;
    oc:hasRationale "Higher DPI ensures text regions and boundaries are distinguishable by the surya model" ;
    oc:severityLevel "HIGH" .

oc:kn_bc3fbbc7 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When analyzing documents with complex nested visual structures" ;
    oc:directiveContent "Complex nested layouts (tables within figures, multi-level columns) may produce incorrect or overlapping bounding boxes." ;
    oc:hasRationale "surya's layout model treats elements as flat regions without hierarchical nesting awareness" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f39e2c97 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining reading order of document elements" ;
    oc:directiveContent "Reading order detection requires layout results as input — always run LayoutPredictor before ReadingOrderPredictor." ;
    oc:hasRationale "ReadingOrderPredictor depends on layout bboxes to establish spatial ordering" ;
    oc:severityLevel "CRITICAL" .

oc:req_0e5b56a5 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "pdf2image (pip install pdf2image)" .

oc:req_48e6620b a oc:RequirementHardware ;
    oc:isOptional true ;
    oc:requirementValue "GPU recommended for batch processing" .

oc:req_4f262d10 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "surya-ocr (pip install surya-ocr)" .

oc:req_7106622d a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Pillow (PIL)" .

oc:req_d70f4b6e a oc:RequirementAPI ;
    oc:isOptional true ;
    oc:requirementValue "office-mcp MCP server with analyze_document_structure tool" .

