oc:kn_2e197595 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing alert routing for notification bots" ;
    oc:directiveContent "Route notifications by severity: critical → admin group + on-call user, warning → team group, info → logging channel." ;
    oc:hasRationale "Proper severity routing ensures the right people see alerts at the right time without alert fatigue." .

oc:kn_38d4bbec a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing bot interaction flows" ;
    oc:directiveContent "Use inline keyboards with callback_data for interactive menus instead of free-text commands when offering known options." ;
    oc:hasRationale "Inline keyboards reduce user error and provide a guided experience compared to typed commands." .

oc:kn_3dbcb48b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sending formatted notification messages via Telegram bot" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """async function sendAlert(severity, message, details) {
  const emoji = { critical: '🚨', warning: '⚠️', info: 'ℹ️', success: '✅' };
  const text = `${emoji[severity]} *${severity.toUpperCase()}*\\n\\n${message}\\n\\n${details}`;
  await telegram.sendMessage({ chat_id: ALERT_CHANNEL_ID, text: text, parse_mode: 'Markdown' });
}""" .

oc:kn_5f93c1ca a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When deploying bot to production" ;
    oc:directiveContent "Bot deployment creates a persistent webhook or polling connection that consumes resources continuously." ;
    oc:hasRationale "Long-running bots need proper hosting infrastructure and error recovery." .

oc:kn_8070389a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before bot deployment" ;
    oc:directiveContent "Verify the Telegram Bot API token is valid by calling getUpdates endpoint before deploying message handlers." ;
    oc:hasRationale "An invalid token causes all bot operations to fail silently." .

oc:kn_923218cb a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When setting up a new Telegram bot" ;
    oc:directiveContent "1. Create bot via @BotFather (/newbot) 2. Configure description, about text, userpic, commands 3. Get chat ID via getUpdates API 4. Build message handlers (text, command, photo, document, voice, location) 5. Deploy via n8n workflow or custom code" ;
    oc:stepOrder 1 .

oc:kn_a9229ba0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sending bot responses" ;
    oc:directiveContent "Telegram message max length is 4096 characters. Split long messages and enable split_long_messages in bot config." ;
    oc:hasRationale "Messages exceeding 4096 chars will fail to send, breaking the user experience." ;
    oc:severityLevel "HIGH" .

oc:kn_cd81adc3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building message handlers" ;
    oc:directiveContent "Do not ignore message type routing. Bot must handle commands (starts with /), photos, voice, documents, and text differently." ;
    oc:hasRationale "Treating all message types the same leads to broken functionality for multi-modal interactions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fa8d140b a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When formatting alert notifications" ;
    oc:directiveContent """🚨 *Alert: {severity}*

*Service:* {service}
*Message:* {message}
*Time:* {timestamp}

[View Dashboard]({dashboard_link})""" ;
    oc:templateVariables "dashboard_link",
        "message",
        "service",
        "severity",
        "timestamp" .

