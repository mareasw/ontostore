oc:kn_01e0a1be a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating and sending an envelope from a template" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const envelope = await docusign.envelopes.create(accountId, {
  templateId: "template_123",
  templateRoles: [{ roleName: "Customer", email: "customer@example.com", name: "John Customer", tabs: { textTabs: [{ tabLabel: "CompanyName", value: "Customer Corp" }] } }],
  status: "sent"
});""" .

oc:kn_10bcd8a1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building integrations with CRM or other systems" ;
    oc:directiveContent "Use webhook subscriptions (envelope-sent, envelope-completed, envelope-declined, envelope-voided) for real-time status updates rather than polling the API." ;
    oc:hasRationale "Webhooks are more efficient, reduce API call volume, and provide immediate status change notifications." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1666dfa7 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When programmatically creating envelopes" ;
    oc:directiveContent "Envelope creation is not idempotent — calling create twice produces two separate envelopes. Use template-based creation and track envelope IDs carefully." ;
    oc:hasRationale "Duplicate envelopes can lead to multiple signing requests for the same document, causing confusion and legal ambiguity." ;
    oc:severityLevel "HIGH" .

oc:kn_39909562 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "Always, for compliance and legal defensibility" ;
    oc:directiveContent "Maintain complete audit trails for all envelope events (created, sent, viewed, signed, completed) with timestamps, user info, and IP addresses." ;
    oc:hasRationale "Audit trails are legally required for e-signature validity under ESIGN Act and UETA, and essential for dispute resolution." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3d5d638b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard signing workflow" ;
    oc:directiveContent "1. Create envelope with document and recipients → 2. Add signature/date fields using anchors → 3. Send for signature → 4. Signers sign in routing order → 5. Completed → Archive and distribute" ;
    oc:stepOrder 1 .

oc:kn_4584d4a2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding signature tabs to envelope templates" ;
    oc:directiveContent "Use anchor strings (e.g., /sig1/, /date1/) in document tabs to automatically position signature and date fields rather than absolute coordinates." ;
    oc:hasRationale "Anchor-based positioning adapts to document changes and works across different PDF layouts without manual adjustment." ;
    oc:severityLevel "HIGH" .

oc:kn_5b56926c a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before executing any DocuSign automation" ;
    oc:directiveContent "DocuSign API credentials (account ID, integration key, private key or OAuth token) must be configured before any envelope operations." .

oc:kn_863e679f a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating envelope status dashboard reports" ;
    oc:directiveContent """ENVELOPE STATUS
TOTAL: {count} envelopes
BY STATUS:
Completed  {bar} {count} ({pct}%)
Sent       {bar} {count} ({pct}%)
Delivered  {bar} {count} ({pct}%)
Declined   {bar} {count} ({pct}%)
Voided     {bar} {count} ({pct}%)
AVERAGE COMPLETION TIME: {days} days
PENDING SIGNATURES:
| Document | Awaiting | Sent |
| {doc_name} | {signer} | {days_sent} |""" ;
    oc:templateVariables "bar",
        "count",
        "days",
        "days_sent",
        "doc_name",
        "pct",
        "signer" .

oc:kn_982cb232 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing contract approval workflows" ;
    oc:directiveContent "Implement conditional routing based on document metadata (e.g., contract value > $100K requires VP approval, international contracts require legal review)." ;
    oc:hasRationale "Conditional routing enforces business rules automatically and ensures appropriate review for high-value or special-case contracts." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b8bf6261 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When executing send or void operations" ;
    oc:directiveContent "Sending an envelope triggers email notifications to all recipients. Voiding an envelope notifies all parties. These actions cannot be silently performed." ;
    oc:hasRationale "Unintended notifications to external parties can damage professional relationships and reveal premature contract terms." ;
    oc:severityLevel "HIGH" .

oc:kn_e6ab56b7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When configuring envelope settings" ;
    oc:directiveContent "Enable reminders with a 2-day delay and 2-day frequency, and set expiration dates (typically 30 days) on all envelopes." ;
    oc:hasRationale "Automated follow-ups and expirations ensure timely completion and prevent stale unsigned documents." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fc02ca6a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating envelopes for recurring document types (NDAs, MSAs, SOWs)" ;
    oc:directiveContent "Always use templates to standardize common document types rather than creating envelopes from scratch each time." ;
    oc:hasRationale "Templates ensure consistency, reduce errors, and speed up envelope creation across the organization." ;
    oc:severityLevel "HIGH" .

