oc:kn_1fe1f500 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When conducting company research" ;
    oc:directiveContent "1. Start with company website and LinkedIn 2. Check recent news (last 6 months) 3. Review press releases and blog 4. Look at job postings for insights 5. Check review sites (G2, Glassdoor) 6. Analyze social media presence" ;
    oc:hasRationale "This multi-source triangulation approach ensures comprehensive coverage and data accuracy" ;
    oc:stepOrder 1 .

oc:kn_36459a39 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When building contact profiles" ;
    oc:directiveContent "Contact details (email, phone) are often not publicly available; do not guess or fabricate them" ;
    oc:hasRationale "Wrong contact information damages credibility and wastes outreach effort" ;
    oc:severityLevel "MEDIUM" .

oc:kn_657ace2a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When prioritizing a batch of leads" ;
    oc:directiveContent "Score leads using weighted criteria: Company Size (25%), Industry Fit (20%), Tech Stack (20%), Timing Signals (20%), Contact Level (15%)" ;
    oc:hasRationale "Weighted scoring provides objective, consistent prioritization that balances firmographic fit with timing signals" .

oc:kn_786b16a8 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When generating a company brief" ;
    oc:directiveContent "Research is complete when the output includes: company quick facts, key people, recent news, pain points, outreach angle, and a fit score" ;
    oc:hasRationale "These components ensure the output is actionable for sales outreach preparation" .

oc:kn_9f7f5863 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When conducting contact research" ;
    oc:directiveContent "Respect privacy boundaries when researching individuals; do not scrape or aggregate personal data beyond professional context" ;
    oc:hasRationale "Privacy violations can have legal consequences and damage brand reputation" ;
    oc:severityLevel "HIGH" .

oc:kn_a18c93d9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When compiling research findings" ;
    oc:directiveContent "Never misrepresent sources or claim to have data from databases you cannot access" ;
    oc:hasRationale "Source misrepresentation is unethical and can damage trust with prospects" ;
    oc:severityLevel "HIGH" .

oc:kn_c6594cf6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When researching private or bootstrapped companies" ;
    oc:directiveContent "Private companies have limited publicly available data; acknowledge gaps rather than fabricating details" ;
    oc:hasRationale "Private company financials and metrics are rarely public; fabricating them undermines outreach credibility" ;
    oc:severityLevel "HIGH" .

oc:kn_e46c5370 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating company news and developments" ;
    oc:directiveContent "Prioritize recent signals (last 6 months) over historical data when assessing timing and pain points" ;
    oc:hasRationale "Recent events are far more relevant for timely, contextual outreach than older information" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f2ce6c49 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any research operation" ;
    oc:directiveContent "Verify network availability before starting research, as all operations require web access" ;
    oc:hasRationale "Network-dependent research will fail silently without connectivity verification" .

oc:kn_f456a7e7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "All lead research operations" ;
    oc:directiveContent "Use publicly available information only; never reference or rely on paid databases (ZoomInfo, etc.)" ;
    oc:hasRationale "Maintains research ethics and avoids hallucinating data from inaccessible sources" ;
    oc:severityLevel "CRITICAL" .

