oc:kn_25f0f7f0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When integrating Linear with GitHub" ;
    oc:directiveContent "Use consistent branch naming: {{username}}/lin-{{issue_number}}-{{issue_slug}} and commit message patterns (LIN-{{number}}) to enable automatic issue linking." ;
    oc:hasRationale "Consistent naming enables automatic PR-to-issue linking and status transitions" .

oc:kn_4b8fad12 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing Linear issues" ;
    oc:directiveContent "Never skip triage — untriaged issues accumulate and obscure priorities. Never manually update statuses that can be automated via GitHub/CI integration." ;
    oc:hasRationale "Manual status updates are error-prone and waste engineering time; untriaged backlogs lead to missed work" ;
    oc:severityLevel "HIGH" .

oc:kn_4ec28694 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning sprint cycles" ;
    oc:directiveContent "Use 2-week cycles with 20% buffer, 8 points capacity per engineer. Auto-rollover Backlog/Todo items (excluding 'blocked' label) into next cycle." ;
    oc:hasRationale "Buffer and auto-rollover prevent scope creep and ensure nothing falls through cracks" .

oc:kn_677f7e6e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or updating Linear issues" ;
    oc:directiveContent "Issue lifecycle must follow: Triage → Todo → In Progress → In Review → Done (or Cancelled). Linear's GraphQL API requires valid teamId and stateId for issue operations." ;
    oc:hasRationale "Linear enforces a strict state machine; skipping states causes workflow violations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b3e16781 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When querying all issues in a cycle for reporting" ;
    oc:codeLanguage "graphql" ;
    oc:directiveContent """query CycleIssues {
  cycle(id: "cycle-id") {
    name
    issues {
      nodes { identifier title state { name } assignee { name } estimate }
    }
  }
}""" .

oc:kn_b76c64a0 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating issue status or assignment via Linear GraphQL API" ;
    oc:codeLanguage "graphql" ;
    oc:directiveContent """mutation UpdateIssue {
  issueUpdate(id: "issue-id", input: { stateId: "state-id", assigneeId: "user-id" }) {
    success
  }
}""" .

oc:kn_cacbe02e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "General Linear workflow management" ;
    oc:directiveContent "1. Process/triage new issues daily 2. Use planning poker for consistent estimates 3. Link PRs, commits, docs to issues 4. Organize work with Projects 5. Protect sprint scope (cycle commitment) 6. Regularly groom backlog 7. Automate status updates via integrations 8. Track velocity to measure team capacity" ;
    oc:hasRationale "These 8 practices ensure healthy issue lifecycle and predictable delivery" ;
    oc:stepOrder 1 .

oc:kn_eeaf4656 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any Linear automation" ;
    oc:directiveContent "Verify Linear API access is configured (API key set) and network connectivity is available before attempting any Linear operations." ;
    oc:hasRationale "API calls will fail without proper authentication" .

