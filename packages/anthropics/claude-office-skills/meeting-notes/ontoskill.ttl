oc:kn_18535b1a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting output template" ;
    oc:directiveContent "Support multiple meeting types with tailored templates: standard summary, quick standup, client meeting, and project review — each with different structural emphasis." ;
    oc:hasRationale "Different meeting types have fundamentally different documentation needs (e.g., standups focus on blockers, client meetings focus on commitments)." ;
    oc:severityLevel "LOW" .

oc:kn_259a10a0 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """## Meeting Summary: {Title}
📅 **Date:** {Date}
👥 **Attendees:** {List}

### 📋 Summary
{2-3 sentence overview}

### 💡 Key Points
1. {Point}

### ✅ Decisions
- {Decision}

### 📌 Action Items
| # | Action | Owner | Due | Priority |

### 🔜 Next Steps
- {Next meeting or milestone}

### 📝 Parking Lot
- {Items to address later}""" ;
    oc:templateVariables "Date",
        "Decision",
        "Items to address later",
        "List",
        "Next meeting or milestone",
        "Point",
        "Title" .

oc:kn_2dfd35a3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning owners to action items" ;
    oc:directiveContent "Determine action item owners by: explicitly named persons, role-based references, defaulting to meeting organizer when unclear, and flagging unassigned items for follow-up." ;
    oc:hasRationale "Unassigned action items are the most common failure mode in meeting follow-through — flagging them ensures accountability." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7b6e94f8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before sharing output" ;
    oc:directiveContent "Do not distribute structured notes without human review of commitments, deadlines, and action item assignments." ;
    oc:hasRationale "Ambiguous pronouns, acronyms, or misattributed owners can lead to misinformation being circulated." ;
    oc:severityLevel "HIGH" .

oc:kn_86f6e08f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing raw meeting notes" ;
    oc:directiveContent "Identify decisions by looking for: 'we've decided', 'the decision is', 'going forward we will', 'agreed:', 'confirmed:', and consensus language like 'everyone agreed'." ;
    oc:hasRationale "Decision language is often implicit in meeting discourse; these markers help distinguish decisions from general discussion." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9277b268 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using this skill" ;
    oc:directiveContent "Cannot attend or record meetings; accuracy depends entirely on quality of input notes provided by user." ;
    oc:hasRationale "The skill is a text transformation tool, not a meeting capture tool — it cannot verify or generate information not present in the input." ;
    oc:severityLevel "HIGH" .

oc:kn_9e08c6b2 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Paste raw notes/transcript 2. Identify meeting type (standup, project review, client call) 3. Select or customize template 4. Extract action items using task-indicating phrases 5. Identify decisions using decision language markers 6. Assign owners (explicit name → role → organizer → flag unassigned) 7. Generate structured output in chosen format" ;
    oc:stepOrder 1 .

oc:kn_a292ddb5 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When input notes are informal or sparse" ;
    oc:directiveContent "May require clarification on ambiguous pronouns, acronyms, or unclear ownership in raw notes." ;
    oc:hasRationale "Raw meeting notes often contain shorthand and implicit context that is ambiguous without the original participants' knowledge." ;
    oc:severityLevel "LOW" .

oc:kn_adde8d49 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """# Daily Standup - {Date}
## {Team Member}
