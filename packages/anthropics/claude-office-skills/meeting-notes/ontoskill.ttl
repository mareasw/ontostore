oc:kn_ffefd519 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing raw meeting notes" ;
    oc:directiveContent "Extract action items by scanning for task-indicating phrases: 'we need to', 'someone should', 'can you', 'let's', 'Action:', and names paired with verbs plus deadlines." ;
