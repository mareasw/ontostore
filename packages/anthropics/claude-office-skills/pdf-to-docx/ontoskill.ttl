    oc:hasRationale "Encrypted PDFs will fail without the password; missing dependencies cause runtime errors." ;
    oc:severityLevel "HIGH" .

oc:kn_0d6e5dcc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting PDFs with complex formatting" ;
    oc:directiveContent "Do not assume perfect conversion for complex layouts. Complex tables, nested structures, and multi-column layouts may require manual post-conversion adjustment." ;
    oc:hasRationale "Layout fidelity is limited by how well pdf2docx can parse the PDF's internal structure; complex layouts often lose formatting nuance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_59d3031d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard PDF to Word conversion" ;
    oc:directiveContent "1. Verify PDF type (native vs scanned). 2. Install pdf2docx (pip install pdf2docx). 3. Create Converter instance with PDF path. 4. Call convert() with output path and optional page range. 5. Close converter. 6. Verify output file exists and is valid." ;
    oc:stepOrder 1 .

oc:kn_79b7bca1 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always during conversion" ;
    oc:directiveContent "Conversion creates a new .docx file. Watermarks in the PDF are included in the output. Some fonts may be substituted with system defaults." ;
    oc:hasRationale "Users should be aware that watermarks carry over and font substitutions may alter document appearance." ;
    oc:severityLevel "LOW" .

oc:kn_7a833b59 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When converting multiple PDFs" ;
    oc:directiveContent "Batch conversion supports ThreadPoolExecutor for parallel processing. Use max_workers parameter to control concurrency (default 4). Each conversion allocates memory proportional to PDF size." ;
    oc:hasRationale "Parallel processing significantly speeds up batch jobs but consumes more memory." ;
    oc:severityLevel "LOW" .

oc:kn_a6fe70fd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting scanned PDFs" ;
    oc:directiveContent "Scanned/image-based PDFs require OCR preprocessing (pytesseract or PaddleOCR) before conversion. pdf2docx works best with native text-based PDFs." ;
    oc:hasRationale "pdf2docx extracts native PDF content, not pixel-based text, so scanned documents yield poor results without OCR." ;
    oc:severityLevel "HIGH" .

oc:kn_d0e2d58f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before full document conversion" ;
    oc:directiveContent "Always test conversion with a few pages first before converting the full document. Use start/end parameters or pages list for partial conversion." ;
    oc:hasRationale "Previewing results on a subset catches formatting issues early and avoids wasting time on full conversions that may need different settings." ;
    oc:severityLevel "MEDIUM" .

oc:kn_db3c8ce1 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When converting encrypted PDFs" ;
    oc:directiveContent "Encrypted PDFs require passing the password parameter. Be cautious about handling PDF passwords in code — avoid hardcoding them." ;
    oc:hasRationale "Passwords in source code are a security risk; prefer environment variables or secure input." ;
    oc:severityLevel "MEDIUM" .

