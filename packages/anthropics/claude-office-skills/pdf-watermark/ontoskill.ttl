    oc:contentHash "14c8795e468dc767e84762a95745c76d676344c7ec77b263fab7b5dc09d6ba6f" ;
    oc:differentia "adds watermarks, page numbers, headers, footers, stamps, and Bates numbering to PDF documents using the office-mcp server" ;
    oc:extends oc:skill_ontoskills_office_mcp ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "PDF file path and watermark/overlay element instructions" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Add watermarks, page numbers, headers, and footers to PDFs" ;
    oc:hasName "pdf-watermark" ;
    oc:hasSection [ a oc:Section ;
