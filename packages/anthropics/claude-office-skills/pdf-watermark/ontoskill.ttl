oc:kn_4ef03f68 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring text watermark transparency" ;
    oc:directiveContent "Use appropriate opacity levels: 30% for confidential watermarks, 50% for draft, 25% for copy — high enough to be visible, low enough not to obscure content." ;
    oc:hasRationale "Overly opaque watermarks make documents unreadable; overly transparent ones are ineffective." ;
    oc:severityLevel "MEDIUM" .

oc:kn_709559ff a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When applying image watermarks or processing mixed-size documents" ;
    oc:directiveContent "Complex watermarks (high-res images, tiled patterns) may significantly increase PDF file size. Position may shift on pages with non-standard sizes." ;
    oc:hasRationale "File size bloat and misalignment are common side effects of complex watermark configurations." ;
    oc:severityLevel "LOW" .

oc:kn_b2e81e9e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When attempting to watermark a PDF that may have security restrictions" ;
    oc:directiveContent "Some secured or password-protected PDFs prevent modifications and cannot be watermarked." ;
    oc:hasRationale "PDF security settings may block write operations regardless of tool used." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cc3e3aa9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user expects direct watermark application" ;
    oc:directiveContent "This skill provides guidance only — it cannot perform actual watermarking directly; it relies on the office-mcp add_watermark_to_pdf tool for execution." ;
    oc:hasRationale "The skill is a configuration and guidance layer, not a standalone watermarking engine." ;
    oc:severityLevel "HIGH" .

oc:kn_d375d055 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When processing any PDF watermarking request" ;
    oc:directiveContent "1. Identify overlay element type (watermark, page numbers, headers/footers, stamps, Bates numbering). 2. Configure element settings (text/image, position, opacity, format). 3. Specify page range (all, first only, custom range, skip pages). 4. Call add_watermark_to_pdf via office-mcp. 5. Verify output against checklist." ;
    oc:stepOrder 1 .

oc:kn_e12caca3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user requests a standard watermark type" ;
    oc:directiveContent "Use the 6 built-in watermark presets (Draft, Confidential, Copy, Approved, Sample, Do Not Copy) for common use cases rather than configuring from scratch." ;
    oc:hasRationale "Presets encode best practices for opacity, color, and style per use case." ;
    oc:severityLevel "LOW" .

oc:kn_ecc002ac a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing watermark positioning" ;
    oc:directiveContent "Use diagonal rotation (45°) for text watermarks and background placement for image watermarks to avoid obscuring document content." ;
    oc:hasRationale "Diagonal text and background placement are the standard conventions for unobtrusive watermarking." ;
    oc:severityLevel "LOW" .

oc:kn_f8b6a028 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "After applying any overlay elements to a PDF" ;
    oc:directiveContent "Verify: (1) watermark is visible but not obscuring content, (2) page numbers are sequential and correct, (3) headers/footers are properly positioned, (4) no content overlap issues." ;
    oc:hasRationale "Visual verification catches positioning, readability, and numbering errors before distribution." ;
    oc:severityLevel "HIGH" .

