    oc:contentHash "624ffd0e7d02feeba4f1fcfd4bf98b25d1610ef793782c19d59ea2f38bae4314" ;
    oc:differentia "Designs keyword strategies, source matrices, alert configurations, and digest templates for media monitoring without executing real-time monitoring itself" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "create_docx" ;
    oc:hasArgumentHint "topic or brand to monitor" ;
    oc:hasCategory "research" ;
    oc:hasDescription "Set up news monitoring strategies, analyze news coverage, and synthesize current events. Create news digests and media analysis reports." ;
    oc:hasName "news-monitor" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """# ═══════════════════════════════════════════════════════════════════════════════
# CLAUDE OFFICE SKILL - News Monitor
# ═══════════════════════════════════════════════════════════════════════════════

name: news-monitor
description: "Set up news monitoring strategies, analyze news coverage, and synthesize current events. Create news digests and media analysis reports."
version: "1.0.0"
author: claude-office-skills
license: MIT

category: research
tags:
  - news
  - monitoring
  - media
  - alerts
  - current-events
department: Marketing/PR/Research

models:
  recommended:
    - claude-sonnet-4
    - claude-opus-4
  compatible:
    - claude-3-5-sonnet
    - gpt-4
    - gpt-4o

mcp:
  server: office-mcp
  tools:
    - create_docx

capabilities:
  - news_monitoring_setup
  - media_analysis
  - news_synthesis
  - alert_configuration
  - digest_creation

languages:
  - en
  - zh

related_skills:
  - web-search
  - deep-research
  - competitive-analysis
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """1. Go to google.com/alerts
2. Enter search query:
   "Your Company" OR "Your Product"
3. Show options:
   - How often: As-it-happens / Daily / Weekly
   - Sources: Automatic / News / Blogs / Web
   - Language: [Select]
   - Region: [Select]
   - How many: All results / Best results
4. Create alert
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 284-295" ] ;
