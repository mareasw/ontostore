    oc:resolvesIntent "analyze media coverage",
        "configure news alerts",
        "create news digest",
        "monitor brand mentions",
        "set up news monitoring strategy",
        "track competitor news" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_226109a9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring alert frequencies" ;
    oc:directiveContent "Do not set real-time alerts for all categories. Match alert frequency to urgency: real-time for brand/negative mentions, daily for product/competitor tracking, weekly for executive mentions and industry trends." ;
    oc:hasRationale "Over-alerting causes alert fatigue and desensitization, causing genuinely critical items to be missed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2b78600d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a complete monitoring strategy" ;
    oc:directiveContent "1. Define monitoring objectives (brand, industry, competitors, keywords, executives, regulations) 2. Set parameters (geography, language, source types, frequency, alert thresholds) 3. Build keyword strategy with Boolean queries and exclusion terms 4. Map source matrix by tier and priority 5. Select monitoring tools 6. Configure alerts with frequency per category 7. Design digest template and distribution schedule" ;
    oc:hasRationale "A systematic approach ensures comprehensive coverage without gaps or redundancies." ;
    oc:stepOrder 1 .

oc:kn_428c4656 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building monitoring queries for any topic" ;
    oc:codeLanguage "boolean-query" ;
    oc:directiveContent """"Company Name" OR "Product Name"                        # Simple
"Company Name" AND (launch OR announcement OR partnership) # Filtered
"Company Name" NOT jobs NOT careers                       # Exclusion
("Competitor A" OR "Competitor B") AND (funding OR acquisition OR launch)  # Competitor""" .

oc:kn_4bb750cf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building source matrices or evaluating media coverage" ;
    oc:directiveContent "Tier sources by authority (Tier 1: WSJ/NYT/Reuters at 10x weight, Tier 2: industry leaders at 5x, Tier 3: regional at 2x, Tier 4: blogs at 1x) to weight coverage analysis appropriately." ;
    oc:hasRationale "Not all coverage is equal — a single WSJ mention carries more strategic weight than dozens of small blog posts." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7cff87ce a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing keyword strategies for monitoring" ;
    oc:directiveContent "Use Boolean operators (AND, OR, NOT) to build targeted queries that maximize signal and minimize noise. Structure queries with inclusion terms for relevance and exclusion terms to filter out job postings and irrelevant content." ;
    oc:hasRationale "Effective Boolean queries are the foundation of any monitoring system — poor queries produce overwhelming noise or miss critical coverage." ;
    oc:severityLevel "MEDIUM" .

oc:kn_87e7a79f a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating a monitoring strategy document" ;
    oc:directiveContent """# Monitoring Strategy: {Topic/Brand}
## Monitoring Objectives (numbered list)
## Keyword Strategy — Primary keywords, Boolean queries (brand/competitor/industry), exclusion terms
## Source Matrix — Category, sources, priority (High/Medium/Low)
## Tool Configuration — Primary tool setup, secondary tools
## Workflow — Daily (review alerts, triage, flag), Weekly (digest, trends, share), Monthly (full report, review, refine)
## Distribution — Stakeholder, content type, frequency table
## Success Metrics — Volume, share of voice, sentiment, response time""" ;
    oc:templateVariables "Distribution",
        "Keywords",
        "Metrics",
        "Objectives",
        "Sources",
        "Tools",
        "Topic/Brand",
        "Workflow" .

oc:kn_8d2cf790 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating a news digest document" ;
    oc:directiveContent """# {Topic/Brand} News Digest
**Period**: {date_range} | **Prepared by**: {name} | **Distribution**: {internal/external}
## Headlines Summary — Top stories with source, date, key point, impact (H/M/L)
## Coverage by Category — Company News, Industry News, Competitor News tables
## Sentiment Analysis — Positive/Neutral/Negative by category with trend
## Key Themes — Named themes with description and articles
## Action Items — Checkbox list
## Upcoming Events — Date, event, potential impact
## Sources Monitored — List""" ;
    oc:templateVariables "Action Items",
        "Events",
        "Headlines",
        "Sentiment",
        "Sources",
        "Themes",
        "Topic/Brand",
        "date_range",
        "internal/external",
        "name" .

oc:kn_e88095f7 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When evaluating monitoring strategy effectiveness" ;
    oc:directiveContent "Key media analysis metrics: Volume (mention count), Reach (potential audience), Share of Voice (your mentions / total market mentions), Sentiment (Positive:Neutral:Negative ratio), and Message Pull-Through (% of articles containing key messages)." ;
    oc:hasRationale "These five metrics provide a comprehensive view of media presence, competitive positioning, and message effectiveness." ;
    oc:severityLevel "LOW" .

oc:kn_f4a0e152 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user expects live monitoring or breaking news" ;
    oc:directiveContent "Cannot access real-time news feeds, execute actual monitoring, provide breaking news, or access paywalled sources. All outputs are strategy documents and templates requiring manual implementation." ;
    oc:hasRationale "The skill is a planning and templating tool, not a live data aggregator. Users must implement strategies via external tools like Google Alerts or Feedly." ;
    oc:severityLevel "HIGH" .

