oc:kn_21c376bf a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a theme" ;
    oc:directiveContent "Available built-in themes are limited to: default, gaia, and uncover." ;
    oc:hasRationale "Marp only ships three built-in themes; custom themes require separate CSS authoring." .

oc:kn_2d726f63 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When styling presentation slides" ;
    oc:directiveContent "Use `<!-- _class: lead -->` comment directive on individual slides to apply centering for title slides; use global directives like `paginate: true`, `header`, `footer`, and `backgroundColor` in frontmatter for consistent branding." ;
    oc:hasRationale "Global directives ensure visual consistency; per-slide directives allow intentional variation." .

oc:kn_4d5feb3e a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting markdown to output format" ;
    oc:directiveContent """marp slides.md -o presentation.pdf
marp slides.md -o presentation.pptx
marp slides.md -o presentation.html""" .

oc:kn_52abf103 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Either @marp-team/marp-cli (npm) or the office-mcp server with md_to_pptx tool must be available for export." .

oc:kn_57ff2035 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a presentation from Markdown" ;
    oc:directiveContent "1. Write or provide Markdown content with slide separators (---). 2. Add Marp frontmatter (marp: true, theme, paginate, etc.). 3. Export to PDF/PPTX/HTML via marp CLI or md_to_pptx MCP tool." ;
    oc:stepOrder 1 .

oc:kn_86a725b6 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before first use, to install the Marp CLI" ;
    oc:directiveContent "npm install -g @marp-team/marp-cli" .

oc:kn_89c920fc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring any Marp slide deck" ;
    oc:directiveContent "Slides are separated by triple-dash (---) horizontal rules in Marp-flavored Markdown; the frontmatter must include `marp: true` to activate Marp processing." ;
    oc:hasRationale "Without the marp: true directive, the Markdown renders as a regular document instead of slides." .

oc:kn_aa39d309 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding images to slides" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent "![width:500px](image.png) for inline images, ![bg](background.jpg) for full-slide backgrounds, ![bg left:40%](sidebar.jpg) for split backgrounds." ;
    oc:hasRationale "Marp uses extended image syntax for layout control rather than standard HTML sizing." .

oc:kn_df7065d6 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating two-column slide layouts" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """<div class="columns">
<div>
## Left
Content
</div>
<div>
## Right
Content
</div>
</div>""" .

