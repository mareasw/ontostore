    oc:contentHash "e5bc44df1d5a48c70cf7666042f0aa62e65e4d5e4ed550e6a6b029a636efdc9e" ;
    oc:dependsOnSkill oc:skill_ontoskills_office_mcp ;
    oc:differentia "converts Markdown content into slide decks using the Marp framework, supporting PDF/PPTX/HTML export with professional themes" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "md_to_pptx" ;
    oc:hasArgumentHint "markdown content or file path for slide conversion" ;
    oc:hasCategory "presentation" ;
    oc:hasDescription ">" ;
    oc:hasName "md-slides" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """# ═══════════════════════════════════════════════════════════════════════════════
# CLAUDE OFFICE SKILL - Enhanced Metadata v2.0
# ═══════════════════════════════════════════════════════════════════════════════

# Basic Information
name: md-slides
description: ">"
version: "1.0"
author: claude-office-skills
license: MIT

# Categorization
category: presentation
tags:
  - markdown
  - slides
  - marp
department: All

# AI Model Compatibility
models:
  recommended:
    - claude-sonnet-4
    - claude-opus-4
  compatible:
    - claude-3-5-sonnet
    - gpt-4
    - gpt-4o

# MCP Tools Integration
mcp:
  server: office-mcp
  tools:
    - md_to_pptx

# Skill Capabilities
capabilities:
  - markdown_slides
  - presentation_generation

# Language Support
languages:
  - en
  - zh
""" ] ;
