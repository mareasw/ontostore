oc:kn_0372d435 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "List hygiene maintenance" ;
    oc:directiveContent "Remove bounces and unsubscribes immediately. Re-engage inactive subscribers at 60 days. Remove inactive subscribers at 90 days." ;
    oc:hasRationale "Clean lists improve sender reputation and deliverability scores" ;
    oc:severityLevel "MEDIUM" .

oc:kn_0b016aab a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any multi-email sequence" ;
    oc:directiveContent "Structure sequences with escalating intent: welcome → educate → engage → social proof → convert → urgency." ;
    oc:hasRationale "Gradual trust-building converts better than immediate hard sells" .

oc:kn_19f3a945 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up a new email domain or ESP" ;
    oc:directiveContent "Warm up new sending domains over 2-4 weeks with gradual volume increase of max 20%/week and consistent sending days/times." ;
    oc:hasRationale "Abrupt volume spikes trigger spam filters and damage sender reputation" ;
    oc:severityLevel "HIGH" .

oc:kn_1a690bda a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When building cart recovery sequences" ;
    oc:directiveContent "For cart abandonment: send 3 emails at 1 hour, 24 hours, and 72 hours. Escalate from reminder → social proof → incentive." ;
    oc:hasRationale "Multi-touch recovery with escalating incentives recovers 10-15% of abandoned carts" ;
    oc:severityLevel "MEDIUM" .

oc:kn_1f189a0e a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When analyzing email campaign performance" ;
    oc:directiveContent "Healthy benchmarks: open rate 20-25%, click rate 2-5%, conversion rate 1-3%, unsubscribe rate <0.5%, bounce rate <2%, spam complaints <0.1%." ;
    oc:hasRationale "These benchmarks indicate whether campaigns are performing at industry-standard levels" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3787a2ab a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before launching any email campaign" ;
    oc:directiveContent "SPF, DKIM, and DMARC authentication must be configured before sending campaigns. Check via mxtoolbox.com." ;
    oc:hasRationale "Missing email authentication causes emails to land in spam folders" ;
    oc:severityLevel "CRITICAL" .

oc:kn_3c312771 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning email targeting" ;
    oc:directiveContent "Segment by behavioral signals (purchase history, engagement level, product interest) for higher relevance than demographic-only segmentation." ;
    oc:hasRationale "Behavioral segments outperform demographic segments because they reflect actual intent" ;
    oc:severityLevel "MEDIUM" .

oc:kn_66a6b66b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any email campaign or sequence" ;
    oc:directiveContent "All emails must include a prominent unsubscribe link and physical address per CAN-SPAM requirements." ;
    oc:hasRationale "Non-compliance with CAN-SPAM is illegal and damages deliverability" ;
    oc:severityLevel "CRITICAL" .

oc:kn_69572266 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing email content" ;
    oc:directiveContent "Avoid spam trigger words: 'free', 'act now', 'limited time', 'click here'. Maintain a 60:40 text-to-image ratio." ;
    oc:hasRationale "Spam filters flag these words and imbalanced text/image ratios, destroying deliverability" ;
    oc:severityLevel "HIGH" .

oc:kn_f80022d3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing email campaigns" ;
    oc:directiveContent "A/B test high-impact elements first (subject lines, send time, CTA buttons) with 20% of list before sending to full list." ;
    oc:hasRationale "Subject lines have the highest impact on open rates; send time and CTA affect clicks" ;
    oc:severityLevel "MEDIUM" .

