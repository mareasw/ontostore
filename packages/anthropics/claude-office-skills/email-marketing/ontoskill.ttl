    - cta_button:
        variants: [text, color, placement]
        winner_criteria: click_rate
        
  medium_impact:
    - preview_text
    - email_length
    - personalization_level
    - image_vs_no_image
    
  low_impact:
    - font_choice
    - button_shape
    - footer_layout
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 282-308" ] ;
