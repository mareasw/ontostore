                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """unit_economics_benchmarks:
  ltv_cac_ratio:
    poor: <1x
    acceptable: 1-2x
    good: 2-3x
    great: 3-5x
    excellent: >5x
  
  cac_payback_months:
    enterprise: <18
    mid_market: <12
    smb: <6
    consumer: <3
  
  gross_margin:
    saas_typical: 70-85%
    infrastructure: 50-70%
    services_heavy: 40-60%
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 3 ;
                                    oc:sourceLocation "lines 209-228" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """┌─────────────────────────────────────────────────────────────┐
│                   UNIT ECONOMICS                            │
├─────────────────────────────────────────────────────────────┤
│                                                             │
│  Customer Lifetime Value (LTV)                              │
│  ────────────────────────────                               │
│  ARPU × Gross Margin %                                      │
│  ─────────────────────── = LTV                              │
│     Churn Rate                                              │
│                                                             │
│  Example:                                                   │
│  $100 ARPU × 80% margin / 3% churn = $2,667 LTV             │
│                                                             │
│  ═══════════════════════════════════════════════════════    │
│                                                             │
│  Customer Acquisition Cost (CAC)                            │
│  ────────────────────────────────                           │
│  Sales & Marketing Spend                                    │
│  ─────────────────────────── = CAC                          │
│    New Customers Acquired                                   │
│                                                             │
│  Example:                                                   │
│  $50,000 S&M / 50 customers = $1,000 CAC                    │
│                                                             │
│  ═══════════════════════════════════════════════════════    │
│                                                             │
│  LTV:CAC Ratio = $2,667 / $1,000 = 2.67x                   │
│  CAC Payback = $1,000 / ($100 × 80%) = 12.5 months         │
│                                                             │
└─────────────────────────────────────────────────────────────┘
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 175-206" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Benchmarks**:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "3. Unit Economics" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Template ;
                                    oc:blockType "template" ;
                                    oc:contentOrder 3 ;
                                    oc:templateContent """## Churn Analysis - {Month}

### Summary
| Metric | Value | Benchmark | Status |
|--------|-------|-----------|--------|
| Logo Churn | 3.2% | <5% | ✅ |
| Gross Revenue Churn | 2.8% | <3% | ✅ |
| Net Revenue Retention | 108% | >100% | ✅ |

### Churn Breakdown
| Reason | Customers | MRR Lost | % of Total |
|--------|-----------|----------|------------|
| Price | 5 | $2,500 | 35% |
| Competitor | 3 | $1,800 | 25% |
| No longer needed | 4 | $1,500 | 21% |
| Product issues | 2 | $800 | 11% |
| Other | 2 | $600 | 8% |

### Cohort Performance
- Q1 2025 cohort: 95% retention at month 6
- Q4 2024 cohort: 88% retention at month 9
- Enterprise segment: 97% retention (best)
""" ;
                                    oc:templateVariables "Month" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """churn_metrics:
  # Logo Churn (Customer Count)
  logo_churn_rate: 
    formula: customers_lost / customers_start_of_period × 100
    benchmark: <5% monthly for SMB, <2% for Enterprise
  
  # Revenue Churn (MRR)
  gross_revenue_churn:
    formula: churned_mrr / starting_mrr × 100
    benchmark: <3% monthly
  
  # Net Revenue Churn (includes expansion)
  net_revenue_churn:
    formula: (churned_mrr - expansion_mrr) / starting_mrr × 100
    target: negative (net expansion)
  
  # Net Revenue Retention (NRR)
  nrr:
    formula: (starting_mrr - churn + expansion) / starting_mrr × 100
    benchmark:
      good: 100-110%
      great: 110-120%
      best_in_class: >120%
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 119-143" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Churn Analysis Template**:" ] ;
