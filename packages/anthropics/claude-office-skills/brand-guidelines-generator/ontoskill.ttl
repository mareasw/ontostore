oc:kn_13d41352 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user expects visual asset creation" ;
    oc:directiveContent "Cannot create visual assets such as logos or images; only documents the specifications and rules for their usage." ;
    oc:hasRationale "This skill is a documentation generator, not a design tool. Users must provide or create visual assets separately." ;
    oc:severityLevel "HIGH" .

oc:kn_3f42d354 a oc:KnowledgeNode,
        oc:RequiresHumanClarification ;
    oc:appliesToContext "When finalizing brand guidelines for distribution" ;
    oc:directiveContent "Typography licensing and legal usage rights for brand assets should be reviewed by the user; the skill cannot verify these." ;
    oc:hasRationale "Font licensing and image rights are complex legal matters that require human judgment and legal review." .

