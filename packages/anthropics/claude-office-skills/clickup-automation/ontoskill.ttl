        - add_comment: "Branch created: {{branch.name}}"
        
    - trigger: pr_opened
      actions:
        - set_status: "In Review"
        - link_pr: "{{pr.url}}"
        
    - trigger: pr_merged
      actions:
        - set_status: "Complete"
""" ;
