oc:kn_003d540c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing workspace structure" ;
    oc:directiveContent "Do not create deeply nested folder hierarchies (more than 3 levels of Space → Folder → List). Avoid creating separate spaces for individual projects when a folder within a shared space would suffice." ;
    oc:hasRationale "Deep nesting increases navigation complexity, slows API queries, and makes it harder for team members to find tasks." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1746965d a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating time tracking reports" ;
    oc:directiveContent """TIME TRACKING - {period}
═══════════════════════════════════════

TOTAL: {total_hours}h {total_minutes}m

BY PROJECT:
{project_name}   ████████████████ {hours}h {minutes}m

BY DAY:
{day}    █████████████████ {hours}h {minutes}m

BILLABLE: {billable_hours}h {billable_minutes}m ({billable_pct}%)""" ;
    oc:templateVariables "billable_hours",
        "billable_minutes",
        "billable_pct",
        "day",
        "hours",
        "minutes",
        "period",
        "project_name",
        "total_hours",
        "total_minutes" .

oc:kn_1c3d4366 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When configuring time tracking entries and reports" ;
    oc:directiveContent "Time estimates must be specified in milliseconds. Enable billable-by-default and 15-minute rounding for consistent time tracking. Use time reports grouped by project and user for capacity planning." ;
    oc:hasRationale "Milliseconds is the ClickUp API standard. Consistent rounding and billable defaults ensure accurate invoicing and utilization reporting." .

oc:kn_3cba460d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up workspace automation" ;
    oc:directiveContent "Use automation rules to reduce manual work: auto-assign on task creation (by tag), due date reminders, status-change workflows (auto-reassign to reviewers), and subtask-completion triggers for parent tasks." ;
    oc:hasRationale "Automations eliminate repetitive manual steps and ensure consistent process enforcement across the team." .

oc:kn_5ce33d13 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When creating advanced automations like sprint rollover or escalation workflows" ;
    oc:directiveContent "Automation rules that reassign tasks or change priorities can have cascading effects. Always test automations on a non-production list first and review trigger conditions carefully." ;
    oc:hasRationale "Poorly scoped automations can reassign tasks to wrong users, incorrectly escalate items, or flood notification channels." ;
    oc:severityLevel "MEDIUM" .

oc:kn_86bbc370 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires ClickUp API access configured via MCP server (project-mcp) with tools: clickup_task, clickup_list, clickup_space, clickup_automation" .

oc:kn_8ca213c7 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating tasks via ClickUp API" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const task = await clickup.tasks.create(listId, {
  name: "Task name",
  description: "Description",
  assignees: [userId],
  priority: 2,
  due_date: Date.now() + 7 * 24 * 60 * 60 * 1000,
  time_estimate: 28800000,
  custom_fields: [{ id: "field_id", value: "5" }]
});""" .

oc:kn_b449d1b6 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When setting up a new ClickUp workspace or optimizing an existing one" ;
    oc:directiveContent "1. Design workspace hierarchy (Spaces → Folders → Lists) 2. Standardize statuses and priorities across lists 3. Configure custom fields for key metrics 4. Set up automation rules (auto-assign, reminders, status workflows) 5. Create task templates for recurring work types 6. Enable time tracking with billable defaults 7. Configure views per team need (list, board, calendar, timeline, workload) 8. Define goals and link to task lists" ;
    oc:stepOrder 1 .

oc:kn_c3cdebc6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring lists and task statuses" ;
    oc:directiveContent "Standardize statuses across all lists within a workspace. Use consistent priority values: 1=Urgent, 2=High, 3=Normal, 4=Low." ;
    oc:hasRationale "Inconsistent statuses break automations that rely on status transitions and make cross-list reporting unreliable." .

oc:kn_f560d9b2 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When designing or restructuring a ClickUp workspace" ;
    oc:directiveContent "Follow the ClickUp hierarchy: Workspace → Space → Folder → List → Task → Subtask. Design spaces by department or function, folders by project or time period, and lists by work type." ;
    oc:hasRationale "A well-structured hierarchy ensures tasks are organized logically, enables proper permissions scoping, and makes automation rules easier to target at the correct level." ;
    oc:severityLevel "HIGH" .

