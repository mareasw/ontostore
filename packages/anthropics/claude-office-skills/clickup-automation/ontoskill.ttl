    oc:differentia "automates ClickUp workspace management including task workflows, time tracking, goal tracking, and team productivity through MCP server integration" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasAllowedTool "clickup_automation",
        "clickup_list",
        "clickup_space",
        "clickup_task" ;
    oc:hasArgumentHint "task details, space configurations, automation rules, or time entries" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Automate ClickUp workspace management, task workflows, time tracking, and team productivity" ;
