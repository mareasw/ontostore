oc:kn_22ec5e79 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When any conversion is attempted" ;
    oc:directiveContent "Conversions require external tools: Pandoc for Markdown, LibreOffice for Office-to-PDF, Marp for MD-to-PPTX, and pdf2docx for PDF-to-DOCX. Missing tools will cause conversion failures." ;
    oc:hasRationale "The pipeline delegates to external CLI tools; if they are not installed, conversions will fail with subprocess errors." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3d34f039 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "When converting DOCX/XLSX/PPTX to PDF" ;
    oc:directiveContent "LibreOffice must be installed for Office-to-PDF conversions (soffice --headless)" .

oc:kn_48def2a9 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After batch conversion completes" ;
    oc:directiveContent "A successful batch conversion returns a results list where each entry has status='success' and an output path. Spot-check a sample of output files for formatting fidelity." ;
    oc:hasRationale "Programmatic success does not guarantee format fidelity; visual verification catches quality issues." ;
    oc:severityLevel "MEDIUM" .

oc:kn_49b6cabb a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting a single file" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """converter = DocumentConverter()
converter.convert('input.md', 'pdf', output_dir='./output')""" .

oc:kn_5482ff1f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting more than 10 files" ;
    oc:directiveContent "Use parallel processing (ThreadPoolExecutor) with max_workers=4-8 for batch operations to maximize throughput without overwhelming system resources." ;
    oc:hasRationale "Parallel processing significantly reduces total conversion time while keeping resource usage manageable." ;
    oc:severityLevel "MEDIUM" .

oc:kn_65f89fe5 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When converting large numbers of files or large documents" ;
    oc:directiveContent "Batch conversion creates new files in the output directory and may consume significant disk space. Ensure sufficient storage before starting large batches." ;
    oc:hasRationale "Running out of disk space mid-batch causes partial failures and corrupt output." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6f03e2cf a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Installing Python dependencies for document conversion" ;
    oc:directiveContent "pip install pdf2docx markitdown python-docx openpyxl" .

oc:kn_94b6daf7 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """[
  {'file': '{source_path}', 'status': 'success', 'output': '{output_path}'},
  {'file': '{source_path}', 'status': 'error', 'error': '{error_message}'}
]""" ;
    oc:templateVariables "error_message",
        "output_path",
        "source_path" .

oc:kn_95b40528 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any batch conversion" ;
    oc:directiveContent "Verify that all required external tools (pandoc, soffice, marp) are installed and accessible on PATH before starting a batch conversion." ;
    oc:hasRationale "Prevents partial batch failures caused by missing dependencies." ;
    oc:severityLevel "HIGH" .

oc:kn_ace63b3f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing batch conversion of files" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """converter = DocumentConverter(max_workers=4)
results = converter.batch_convert(
    input_dir='./source',
    output_format='pdf',
    output_dir='./converted',
    file_pattern='*.docx',
    recursive=False
)""" .

oc:kn_bb68bd9a a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "When converting to or from Markdown" ;
    oc:directiveContent "Pandoc must be installed for Markdown conversions (brew install pandoc / apt install pandoc)" .

oc:kn_dcd06f7d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before any batch conversion job" ;
    oc:directiveContent "Always test a small sample of files before running a full batch conversion to verify format fidelity and output quality." ;
    oc:hasRationale "Batch failures on hundreds of files waste time and may produce corrupt output that's hard to diagnose." ;
    oc:severityLevel "HIGH" .

oc:kn_e1fb700e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting documents with complex layouts or embedded media" ;
    oc:directiveContent "Do not assume complex formatting (tables, images, embedded objects) will survive conversion intact. Always verify output quality for documents with rich formatting." ;
    oc:hasRationale "Conversion tools simplify formatting; complex layouts may lose structure, resulting in inaccurate or broken output." ;
    oc:severityLevel "HIGH" .

oc:kn_e4bbe34c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Verify external tools installed (pandoc, soffice, marp) 2. Test convert a sample file 3. Check disk space for output 4. Run batch_convert with parallel workers 5. Review results list for errors 6. Spot-check output files for quality" ;
    oc:stepOrder 1 .

oc:kn_f060a6eb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting source and target formats" ;
    oc:directiveContent "Some format combinations are not supported (e.g., DOCX to PPTX, PDF to PPTX). Check the supported format matrix before attempting conversion." ;
    oc:hasRationale "Unsupported conversion paths will raise errors and halt processing." ;
    oc:severityLevel "MEDIUM" .

