                                    oc:blockType "code_block" ;
                                    oc:codeContent """order_status_notifications:
  confirmed:
    delay: immediate
    email: "Thank you for your order!"
    
  processing:
    delay: when_status_changes
    email: "We're preparing your order"
    
  shipped:
