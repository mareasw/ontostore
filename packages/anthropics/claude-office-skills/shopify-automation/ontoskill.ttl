oc:kn_29a58b37 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring customer lifecycle automation" ;
    oc:directiveContent "Segment customers into 4 tiers: VIP (>$1000 spent, ≥5 orders), at-risk (>90 days since last order, ≥2 previous), new (1 order, ≤30 days), wholesale (AOV ≥$500, ≥3 orders) — each with distinct automation actions." ;
    oc:hasRationale "Tiered segmentation enables targeted retention, acquisition, and upsell strategies that outperform one-size-fits-all approaches." .

oc:kn_53b17d36 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any Shopify automation workflow" ;
    oc:directiveContent "All Shopify workflows should be defined as declarative YAML pipelines with clear triggers, conditions, and actions rather than imperative code." ;
    oc:hasRationale "YAML-based workflow definitions are portable, auditable, and can be implemented across automation platforms like n8n, Zapier, or custom orchestrators." ;
    oc:severityLevel "HIGH" .

oc:kn_80c2a45d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring multi-channel inventory synchronization" ;
    oc:directiveContent "Multi-channel inventory sync must maintain a buffer stock of at least 5 units on secondary channels to prevent overselling." ;
    oc:hasRationale "Buffer stock prevents stockouts caused by sync latency between Shopify and secondary marketplaces (Amazon, eBay, Walmart)." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a9c3bff4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring predictive inventory reordering" ;
    oc:directiveContent "Use tiered safety factors for reorder points: 1.5x for high-velocity items, 1.3x for normal, 1.1x for slow-moving, based on 90-day sales history and 14-day velocity." ;
    oc:hasRationale "Different velocity categories need different safety margins to balance stockout risk against holding costs." .

oc:kn_b9cd5d4d a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When executing order processing pipelines" ;
    oc:directiveContent "Order fulfillment workflow updates multiple external systems: accounting (invoice), CRM (customer record), analytics (order data), and inventory (stock decrement)." ;
    oc:hasRationale "These side effects ensure cross-system consistency but require careful sequencing and error handling to avoid partial updates." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f09da348 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring multi-channel price synchronization" ;
    oc:directiveContent "Apply channel-specific price adjustments from a Shopify base: Amazon +15% (fees), eBay +10%, wholesale -30%, syncing on every price change." ;
    oc:hasRationale "Channel-specific markups account for platform fees and margin requirements while maintaining a single source of truth for pricing." .

oc:kn_f28d02fd a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When setting up abandoned cart recovery workflows" ;
    oc:directiveContent "Abandoned cart recovery should use a 3-email sequence: 1hr (gentle reminder), 24hr (free shipping offer), 72hr (10% discount with 24hr expiry), each conditional on cart not yet recovered." ;
    oc:hasRationale "Escalating urgency with increasing incentives maximizes recovery rate while minimizing discount cost." .

oc:kn_fb00b5a3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing new Shopify orders" ;
    oc:directiveContent "Never trigger auto-reorder or fulfillment without first validating fraud score, inventory availability, and payment capture status." ;
    oc:hasRationale "Skipping validation leads to shipping fraudulent orders, overselling out-of-stock items, or fulfilling unpaid orders." ;
    oc:severityLevel "CRITICAL" .

_:ref_02d9abb470193f0f a oc:WorkflowStep ;
    dcterms:description "Classify items as critical (≤5 units) or warning (≤10 units)." ;
    oc:expectedOutcome "Urgency-tagged inventory report" ;
    oc:stepDependsOn _:ref_49b283c888d0a8a7 ;
    oc:stepId "categorize-urgency" .

_:ref_49b283c888d0a8a7 a oc:WorkflowStep ;
    dcterms:description "Filter products where inventory_quantity <= reorder_threshold (default 10)." ;
    oc:expectedOutcome "List of low-stock items identified" ;
    oc:stepDependsOn _:ref_9e34e93e8a766e9a ;
    oc:stepId "filter-low-stock" .

_:ref_5d8366fac4612135 a oc:WorkflowStep ;
    dcterms:description "Generate and send Slack/email alert grouped by category and urgency." ;
    oc:stepDependsOn _:ref_02d9abb470193f0f ;
    oc:stepId "generate-alert" .

_:ref_62881594f2f6c7bc a oc:WorkflowStep ;
    dcterms:description "If cart not recovered after 24 hours, send free shipping offer." ;
    oc:expectedOutcome "Second incentive touchpoint sent" ;
    oc:stepDependsOn _:ref_887153cec37dc9a3 ;
    oc:stepId "email-2-incentive" .

_:ref_76e14e358df9d587 a oc:WorkflowStep ;
    dcterms:description "Route to appropriate warehouse based on order category (international hub, nearest, priority)." ;
    oc:expectedOutcome "Fulfillment location assigned" ;
    oc:stepDependsOn _:ref_bfab3ad6ac779ff3 ;
    oc:stepId "assign-fulfillment" .

_:ref_887153cec37dc9a3 a oc:WorkflowStep ;
    dcterms:description "Send gentle reminder email with cart contents and checkout link after 1 hour." ;
    oc:expectedOutcome "Customer receives initial recovery email" ;
    oc:stepDependsOn _:ref_9419a2fd3c235b68 ;
    oc:stepId "email-1-reminder" .

_:ref_9419a2fd3c235b68 a oc:WorkflowStep ;
    dcterms:description "Identify cart abandoned after 1 hour of inactivity." ;
    oc:expectedOutcome "Abandoned cart flagged for recovery" ;
    oc:stepId "detect-abandonment" .

_:ref_9e34e93e8a766e9a a oc:WorkflowStep ;
    dcterms:description "Fetch all Shopify products with variants from the inventory endpoint." ;
    oc:expectedOutcome "Complete product inventory data available for analysis" ;
    oc:stepId "fetch-products" .

_:ref_bfab3ad6ac779ff3 a oc:WorkflowStep ;
    dcterms:description "Classify order by value, geography, shipping speed, and subscription status." ;
    oc:expectedOutcome "Order tagged for appropriate routing" ;
    oc:stepDependsOn _:ref_dafc37716faedd46 ;
    oc:stepId "categorize-order" .

_:ref_dafc37716faedd46 a oc:WorkflowStep ;
    dcterms:description "Validate fraud score, inventory availability, and payment capture for new order." ;
    oc:expectedOutcome "Order confirmed as valid for processing" ;
    oc:stepId "validate-order" .

_:ref_e5e27ec9060d8beb a oc:WorkflowStep ;
    dcterms:description "Generate shipping label via ShipStation/EasyPost/Shippo integration." ;
    oc:expectedOutcome "Shipping label created with tracking number" ;
    oc:stepDependsOn _:ref_76e14e358df9d587 ;
