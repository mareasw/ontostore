        oc:skill_ontoskills_sheets_automation ;
    oc:differentia "that orchestrates Shopify inventory management, order processing, customer lifecycle workflows, multi-channel synchronization, and analytics through YAML-defined workflow templates" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
