                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """multi_channel_inventory:
  platforms:
    - shopify: primary
    - amazon: secondary
    - ebay: secondary
    - walmart: secondary
    
  sync_rules:
    frequency: real_time
    buffer_stock: 5_units  # Safety buffer
    
    allocation:
      shopify: 100%  # Full inventory
      amazon: available - buffer
      ebay: available - buffer
      walmart: available - buffer
      
  actions:
    on_sale:
      - update_all_channels: immediately
      - if_stockout: pause_listings
      
    on_restock:
      - update_all_channels: immediately
      - reactivate_listings: if_paused
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 304-330" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Inventory Sync" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """price_synchronization:
  base_price: shopify
  
  channel_adjustments:
    amazon:
      markup: +15%  # Account for fees
      
    ebay:
      markup: +10%
      
    wholesale:
      discount: -30%
      
  automation:
    - on_price_change: sync_all_channels
    - competitor_monitoring: optional
    - dynamic_pricing: based_on_demand
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 334-352" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Price Sync" ] ;
                    oc:sectionLevel 2 ;
