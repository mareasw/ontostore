                    oc:contentOrder 1 ;
                    oc:rawYaml """name: Microsoft Teams Automation
description: Automate Microsoft Teams messaging, meetings, channels, and workflow integrations
version: 1.0.0
author: Claude Office Skills
category: communication
tags:
  - teams
  - microsoft
  - collaboration
  - meetings
  - chat
department: operations
models:
  - claude-3-opus
  - claude-3-sonnet
  - gpt-4
mcp:
  server: microsoft-mcp
  tools:
    - teams_message
    - teams_meeting
    - teams_channel
    - teams_webhook
capabilities:
  - Channel messaging
  - Meeting scheduling
  - Workflow automation
  - Adaptive cards
input:
  - Message content
  - Meeting details
  - Channel configurations
  - Webhook payloads
output:
  - Sent messages
  - Meeting links
  - Channel updates
  - Bot responses
languages:
  - en
related_skills:
  - slack-workflows
  - outlook-automation
  - calendar-automation
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
