oc:kn_0ee84ac6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating search results" ;
    oc:directiveContent "Never rely on a single source. Always cross-reference findings across multiple sources and verify source dates — information expires." ;
    oc:hasRationale "Single-source reliance leads to misinformation propagation and outdated conclusions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_5f7f3613 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formulating any search strategy" ;
    oc:directiveContent "Start broad, then narrow: begin with a general term, add specificity progressively. Use synonyms, variations, and question-based queries to cover different result pools." ;
    oc:hasRationale "Progressive refinement surfaces better results than trying to guess the perfect query upfront" .

oc:kn_64b258ea a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When delivering search strategies to users" ;
    oc:directiveContent "Search engine algorithms change frequently and results vary by location and personalization. Strategies are guidelines, not guarantees." ;
    oc:hasRationale "Overconfidence in query effectiveness can mislead users into trusting incomplete results" .

oc:kn_b3d85d5d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assessing any search result or source" ;
    oc:directiveContent "Apply the CRAAP test (Currency, Relevance, Authority, Accuracy, Purpose) to evaluate every source. Classify sources into reliability tiers to calibrate trust." ;
    oc:hasRationale "Systematic evaluation prevents uncritical acceptance of low-quality or biased information" .

oc:kn_ddf85fec a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user expects live search execution" ;
    oc:directiveContent "Cannot execute actual web searches, access real-time results, or access paywalled content. This skill formulates queries and strategies only." ;
    oc:hasRationale "The skill is a query formulation and strategy advisor, not a search engine client" ;
    oc:severityLevel "HIGH" .

oc:req_a3961db0 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "Web browser or search API for executing queries" .

