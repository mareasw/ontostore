oc:kn_6ea33c3c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finalizing an offer letter for delivery" ;
    oc:directiveContent "Offer letters are generally not contracts. Include at-will employment disclaimer (US), reference full equity agreements, and have legal/HR review before sending." ;
    oc:hasRationale "Unclear legal status of offer letters can create unintended contractual obligations; jurisdiction-specific laws apply." ;
    oc:severityLevel "HIGH" .

oc:kn_7a02d7b1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating offers for different jurisdictions or complex compensation" ;
    oc:directiveContent "Employment laws vary by jurisdiction. Company-specific policies must be incorporated. Complex equity arrangements and international offers need legal review." ;
    oc:hasRationale "This skill provides template guidance, not legal advice. Non-compliance with local labor law creates legal risk." ;
    oc:severityLevel "HIGH" .

oc:kn_a5cb26cb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any offer letter" ;
    oc:directiveContent "Never make promises outside standard terms, include discriminatory language, or omit contingencies in offer letters." ;
    oc:hasRationale "Non-standard promises create legal exposure; missing contingencies leave the company vulnerable; discriminatory language violates employment law." ;
    oc:severityLevel "CRITICAL" .

oc:kn_cc93a778 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing offer letter content" ;
    oc:directiveContent "Use clear, straightforward language. Include all material terms, specify deadlines clearly, provide a contact for questions, and include a signature block." ;
    oc:hasRationale "Clear communication creates positive candidate experience and reduces back-and-forth clarification." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e5b8b6be a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating any offer letter" ;
    oc:directiveContent "Verify all 6 required fields are provided: candidate name, job title, start date, compensation, employment type, and reporting manager." ;
    oc:hasRationale "Missing required fields produce incomplete offers that cannot be sent to candidates." ;
    oc:severityLevel "HIGH" .

