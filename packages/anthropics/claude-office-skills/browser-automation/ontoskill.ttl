oc:kn_1e55d820 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On automation failure or test assertion errors" ;
    oc:directiveContent "Capture screenshots on test failures for debugging. Catch navigation failures with proper error handling and timeout management." ;
    oc:hasRationale "Screenshots provide visual context for failures that logs alone cannot capture, speeding up diagnosis." ;
    oc:severityLevel "MEDIUM" .

oc:kn_247b3aad a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring browser launch options" ;
    oc:directiveContent "Use headless mode for production automation runs and headed mode only for development/debugging." ;
    oc:hasRationale "Headless mode is faster, uses fewer resources, and is required for CI/CD and server environments." ;
    oc:severityLevel "LOW" .

oc:kn_29515633 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing selectors for element interaction or extraction" ;
    oc:directiveContent "Never use brittle CSS selectors like nth-child or deeply nested paths. Prefer data-testid attributes for stable element targeting." ;
    oc:hasRationale "Brittle selectors break on minor DOM changes, making automation fragile and maintenance-heavy." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3a021bed a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building any browser automation workflow" ;
    oc:directiveContent "1. Navigate to URL with wait_until strategy 2. Wait for target selector to appear 3. Interact with elements (click, type, select) 4. Wait for navigation or response 5. Extract data or capture screenshot 6. Handle pagination if needed" ;
    oc:stepOrder 1 .

oc:kn_7d191ebc a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When writing E2E test workflows" ;
    oc:directiveContent "1. Define test name and steps 2. Navigate to page 3. Fill form fields 4. Submit form 5. Assert expected element/text appears" ;
    oc:stepOrder 2 .

oc:kn_7e77a6ce a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any browser automation can run" ;
    oc:directiveContent "Requires a browser automation runtime (Puppeteer or Playwright) and the browser-mcp server with tools: browser_navigate, browser_click, browser_type, browser_screenshot" .

oc:kn_af7f2b83 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scraping or automating multi-page workflows" ;
    oc:directiveContent "Implement rate limiting and add delays between requests to be respectful to target servers." ;
    oc:hasRationale "Aggressive automated requests can overwhelm servers, trigger rate limits or IP bans, and violate terms of service." ;
    oc:severityLevel "HIGH" .

oc:kn_b5fd5764 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When navigating to or interacting with any page" ;
    oc:directiveContent "Always use proper wait strategies (wait_for_selector, wait_for_navigation, networkidle) before interacting with elements to avoid race conditions with dynamic content." ;
    oc:hasRationale "Dynamic content loads asynchronously; acting before elements are ready causes flaky failures and missed data." ;
    oc:severityLevel "HIGH" .

oc:kn_f31b5d3b a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When running any non-read-only browser automation" ;
    oc:directiveContent "Browser automation modifies external state: submits forms, clicks buttons, uploads files, and creates accounts on live websites." ;
    oc:hasRationale "Unlike read-only scraping, form automation and interactions permanently alter target systems." ;
    oc:severityLevel "CRITICAL" .

