oc:kn_04490913 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any bulk file organization plan" ;
    oc:directiveContent "Manual review is recommended for important files before applying bulk rename/move operations. Verify destination folders exist or will be created." ;
    oc:hasRationale "Automated categorization can misclassify files; manual review prevents irreversible misplacement of critical documents" ;
    oc:severityLevel "CRITICAL" .

oc:kn_35966b94 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any folder structure" ;
    oc:directiveContent "Avoid deep folder nesting. Keep structure to maximum 3-4 levels deep. Flat hierarchies are easier to navigate and maintain." ;
    oc:hasRationale "Deep nesting increases cognitive load and makes file paths unwieldy, reducing the chance people follow the system" ;
    oc:severityLevel "MEDIUM" .

oc:kn_64b77afb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming any file" ;
    oc:directiveContent "Use date-first naming (YYYY-MM-DD) to enable chronological sorting. Include key identifiers like client, project, type. Use underscores or hyphens instead of spaces. Keep names concise but descriptive." ;
    oc:hasRationale "Date-first naming ensures natural chronological ordering across all file systems and scripts" ;
    oc:severityLevel "HIGH" .

oc:kn_9d00dbe4 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When organizing files that may be encrypted, large, or in unsupported formats" ;
    oc:directiveContent "Cannot access protected or encrypted files. Content analysis depends on file format support. Large file moves require manual execution. Perfect categorization is not guaranteed." ;
    oc:hasRationale "Content-based categorization is inherently limited by file format readability and access permissions" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b41d6814 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating a top-level folder organization system" ;
    oc:directiveContent "Apply the PARA method: Projects (active work with deadlines), Areas (ongoing responsibilities), Resources (reference material), Archive (completed/inactive items)." ;
    oc:hasRationale "PARA is a proven framework that balances active work with knowledge management" .

