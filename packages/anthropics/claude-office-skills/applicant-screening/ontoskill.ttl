oc:kn_1088b02b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When screening any candidate" ;
    oc:directiveContent "Never use non-job-related criteria (protected characteristics, personal attributes) in scoring or ranking decisions." ;
    oc:hasRationale "Using non-job-related criteria creates legal liability and produces biased hiring outcomes." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1f43fc33 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up screening criteria for any position" ;
    oc:directiveContent "Separate requirements into Must-Have (weighted, required), Nice-to-Have (bonus points), and Disqualifiers (binary pass/fail) to create a structured scoring matrix." ;
    oc:hasRationale "Three-tier classification ensures mandatory qualifications are enforced while allowing flexibility for exceptional candidates with bonus skills." ;
    oc:severityLevel "MEDIUM" .

oc:kn_696003ed a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating individual candidates" ;
    oc:directiveContent "Score each candidate criterion independently before forming an overall impression — avoid letting one strong quality inflate scores on unrelated criteria (halo effect)." ;
    oc:hasRationale "Confirmation bias and halo effect are the most common screening biases; structured per-criterion scoring mitigates them." ;
    oc:severityLevel "HIGH" .

oc:kn_ba3ab971 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting final recommendations" ;
    oc:directiveContent "Scoring is guidance only — human judgment is essential for final hiring decisions. Cannot fully assess cultural fit or soft skills from resumes alone." ;
    oc:hasRationale "Automated screening cannot verify employment history or assess interpersonal qualities; recommendations must be validated by human reviewers." ;
    oc:severityLevel "HIGH" .

oc:kn_e6627800 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When screening candidates with unconventional career paths" ;
    oc:directiveContent "Candidates from non-traditional backgrounds (self-taught, career changers, bootcamp grads) may be systematically undervalued by standard scoring rubrics." ;
    oc:hasRationale "Rigid scoring tables favor linear career trajectories and may miss strong candidates with alternative qualifications." ;
    oc:severityLevel "MEDIUM" .

