oc:kn_6839f8e3 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When monitoring sprint health" ;
    oc:directiveContent "Stale issues (In Progress with no update for 7+ days) indicate blocked or abandoned work — use scheduled automation rules to flag them." ;
    oc:hasRationale "Stale issues inflate WIP and hide blockers, leading to inaccurate sprint metrics." .

oc:kn_d7e15a8b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring Jira automation rules" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """automation_rules:
  - name: auto_assign_on_transition
    trigger:
      type: issue_transitioned
      to_status: "In Progress"
    condition:
      assignee: unassigned
    action:
      assign_to: trigger_user""" .

oc:kn_d9ba4b22 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining custom Jira workflows" ;
    oc:directiveContent "Workflow transitions should enforce conditions and validators — e.g., story must have points set before entering Ready for Dev, PR must be linked before Code Review." ;
    oc:hasRationale "Unenforced transitions lead to status inconsistency, skipped steps, and lost information." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e36a1ee2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring sprint boards" ;
    oc:directiveContent "Use WIP limits on board columns (e.g., 6 for In Progress, 4 for In Review) to prevent bottlenecks and context-switching overhead." ;
    oc:hasRationale "WIP limits enforce flow and expose bottlenecks early in the development process." .

oc:kn_e948769d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When querying Jira issues" ;
    oc:codeLanguage "jql" ;
    oc:directiveContent """assignee = currentUser() AND resolution = Unresolved ORDER BY priority DESC
project = DEV AND Sprint = "Sprint 15" ORDER BY status
project = DEV AND status = "In Progress" AND updated < -7d
fixVersion = "v2.5.0" AND resolution = Unresolved""" .

oc:kn_eb6940bd a oc:KnowledgeNode,
