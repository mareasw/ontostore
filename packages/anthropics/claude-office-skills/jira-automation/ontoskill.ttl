oc:kn_02611e3a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or refining Jira issues" ;
    oc:directiveContent "Do not create issues that take longer than 1-2 days to complete — break large issues down into smaller subtasks." ;
    oc:hasRationale "Oversized issues obscure progress, reduce estimation accuracy, and block sprint velocity measurement." ;
    oc:severityLevel "HIGH" .

oc:kn_0895028c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning sprints" ;
    oc:directiveContent "Include a 10% buffer in sprint capacity for unplanned work to avoid overcommitment." ;
    oc:hasRationale "Unplanned work is inevitable; buffer prevents sprint failure and keeps velocity predictable." .

oc:kn_106f4294 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any Jira operation" ;
    oc:directiveContent "Verify Jira MCP server (project-mcp) is connected and tools (jira_create_issue, jira_update_issue, jira_search, jira_transition) are available before executing any Jira automation." ;
    oc:severityLevel "CRITICAL" .

oc:kn_175c4938 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating feature/story issues" ;
    oc:directiveContent """## User Story
