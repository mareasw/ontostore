oc:kn_f13013cc a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When managing Jira issues end-to-end" ;
    oc:directiveContent "1. Create issue from template (Bug/Feature/Epic) 2. Set fields: summary, description, priority, labels, components 3. Assign to sprint 4. Transition through lifecycle statuses 5. Use JQL queries to track progress 6. Generate sprint dashboard and velocity reports" ;
