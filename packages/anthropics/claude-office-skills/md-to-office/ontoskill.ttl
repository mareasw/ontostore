oc:kn_0267b6bd a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any conversion operation" ;
    oc:directiveContent "Verify Pandoc is installed (pandoc --version) and for PDF output, verify LaTeX or wkhtmltopdf is available." ;
    oc:hasRationale "Missing dependencies cause silent failures or unhelpful error messages at conversion time." ;
    oc:severityLevel "CRITICAL" .

oc:kn_06d52e43 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting markdown to PDF" ;
    oc:directiveContent "PDF conversion requires either LaTeX (xelatex/pdflatex) or wkhtmltopdf to be installed separately from Pandoc." ;
    oc:hasRationale "Pandoc itself does not include a PDF rendering engine; it delegates to an external engine." ;
    oc:severityLevel "CRITICAL" .

oc:kn_39d85c54 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running conversions" ;
    oc:directiveContent "Running the same pandoc conversion repeatedly overwrites the output file with identical content." ;
    oc:hasRationale "Safe to re-run without side effects on the output, though previous output is overwritten." ;
    oc:severityLevel "LOW" .

oc:kn_3cb7581f a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Pandoc must be installed (brew install pandoc / apt-get install pandoc / choco install pandoc). For PDF output, LaTeX or wkhtmltopdf is also required." .

oc:kn_4a9a11d2 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard conversion workflow" ;
    oc:directiveContent "1. Provide markdown content or file path 2. Specify target format (docx, pptx, pdf, html, etc.) 3. Optionally provide a reference template for styling 4. Run pandoc with appropriate flags (--toc, --reference-doc, metadata) 5. Verify output file was created and formatting is correct" ;
    oc:stepOrder 1 .

oc:kn_4c5c677d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using Python pypandoc wrapper for conversion" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import pypandoc
output = pypandoc.convert_file('input.md', 'docx', outputfile='output.docx', extra_args=['--toc', '--reference-doc=template.docx'])""" .

oc:kn_7c544518 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After running pandoc conversion" ;
    oc:directiveContent "Successful conversion produces the target file (docx/pptx/pdf) with preserved heading hierarchy, tables, and code blocks." ;
    oc:hasRationale "Key structural elements should map correctly; failures typically manifest as lost formatting or missing sections." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7decfb5a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting markdown to docx or pptx" ;
    oc:directiveContent "Use reference templates (--reference-doc) for consistent branding and styling across converted documents." ;
    oc:hasRationale "Templates ensure consistent visual identity without manual post-processing of each output file." ;
    oc:severityLevel "HIGH" .

oc:kn_b0170668 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting markdown with complex formatting expectations" ;
    oc:directiveContent "Do not expect PowerPoint animations, complex Word formatting, or precise image positioning to survive Pandoc conversion." ;
    oc:hasRationale "Pandoc's conversion is structural; advanced layout features require manual adjustment after conversion." ;
    oc:severityLevel "HIGH" .

oc:kn_c9352e91 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When preparing markdown for conversion with metadata" ;
    oc:directiveContent """# YAML Frontmatter Template
---
title: "{title}"
author: "{author}"
date: "{date}"
abstract: "{abstract}"
toc: true
toc-depth: 2
numbersections: true
geometry: margin=1in
fontsize: 11pt
---

# {Section Title}
{content}""" ;
    oc:templateVariables "Section Title",
        "abstract",
        "author",
        "content",
        "date",
        "title" .

oc:kn_da199fb6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before batch or large-file conversions" ;
    oc:directiveContent "Test conversions incrementally on small sections first to verify formatting before converting large documents." ;
    oc:hasRationale "Catching formatting issues early saves time and prevents having to rework entire documents." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ef25acac a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Core Pandoc CLI commands for all supported conversions" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """pandoc input.md -o output.docx
pandoc input.md --reference-doc=template.docx -o output.docx
pandoc input.md --toc --toc-depth=3 -o output.docx
pandoc input.md --pdf-engine=xelatex -V geometry:margin=1in -o output.pdf
pandoc slides.md --reference-doc=template.pptx -o output.pptx""" .

oc:kn_ef8b4159 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Always when converting markdown to any office format" ;
    oc:directiveContent "Use YAML frontmatter in markdown to set document metadata (title, author, date, abstract, TOC settings)." ;
    oc:hasRationale "Frontmatter metadata populates document properties and controls structural features like table of contents." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f26aff15 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When converting markdown to PowerPoint" ;
    oc:directiveContent "For slide presentations, use # for section dividers, ## for individual slide titles, and ::: notes blocks for speaker notes. Use {.columns} div blocks for multi-column slides." ;
    oc:hasRationale "Pandoc maps heading levels to slide structure; correct heading hierarchy ensures proper slide breaks." ;
    oc:severityLevel "HIGH" .

oc:kn_f71b39c6 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building conversion pipelines with subprocess" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """def md_to_docx(input_path, output_path, template=None):
    cmd = ['pandoc', input_path, '-o', output_path]
    if template:
        cmd.extend(['--reference-doc', template])
    subprocess.run(cmd, check=True)""" .

oc:kn_fea574fb a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always during execution" ;
    oc:directiveContent "Pandoc conversion creates new output files but does not modify source markdown files." ;
    oc:hasRationale "Source files remain untouched; conversion is a one-way transformation producing a new artifact." ;
    oc:severityLevel "LOW" .

