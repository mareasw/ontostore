oc:kn_3820bda4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling diagrams" ;
    oc:directiveContent "Use colors sparingly for emphasis only. Add legends when using symbols or colors. Maintain consistent top-down or left-right flow." ;
    oc:hasRationale "Overuse of colors and inconsistent direction creates visual noise" .

oc:kn_4a822170 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any diagram" ;
    oc:directiveContent "1. Gather description of process/system/concept to visualize, diagram type needed, level of detail, and target audience. 2. Choose format (Mermaid, PlantUML, ASCII, D2) based on target platform. 3. Specify style preferences (colors, theme, direction). 4. Generate diagram code. 5. Provide rendering instructions." ;
    oc:stepOrder 1 .

oc:kn_5ac3a550 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating Mermaid flowcharts with theme customization" ;
    oc:codeLanguage "mermaid" ;
    oc:directiveContent """%%{init: {'theme':'forest'}}%%
flowchart TD
    A[Start] --> B{Decision?}
    B -->|Yes| C[Action]""" .

oc:kn_7bf2693f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any diagram" ;
    oc:directiveContent "Keep diagrams simple — don't overcrowd nodes or connections. Use subgraphs/packages to group related items." ;
    oc:hasRationale "Overcrowded diagrams lose clarity and fail to communicate effectively" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7f199364 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting output format" ;
    oc:directiveContent "Choose format based on target platform: Mermaid for web/markdown/GitHub, PlantUML for UML/complex diagrams, ASCII for universal compatibility, D2 for modern styling." ;
    oc:hasRationale "Different platforms support different diagram syntaxes; matching format to platform ensures rendering works" .

oc:kn_93a93a67 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating complex or highly-styled diagrams" ;
    oc:directiveContent "Limited styling compared to design tools. Complex layouts may need manual adjustment. Some diagram types not supported in all tools." ;
    oc:hasRationale "Text-based diagram tools have inherent limitations in layout control and styling flexibility" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a302fe25 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """# Diagram: {Name}
**Type**: {type}
**Tool**: {tool}
**Purpose**: {purpose}
---
## Diagram Code
### Mermaid
```mermaid
{code}
```
### PlantUML (Alternative)
```plantuml
{code}
```
---
## Rendering Instructions
## Customization Options
## Notes""" ;
    oc:templateVariables "Name",
        "code",
        "purpose",
        "tool",
        "type" .

oc:kn_be994653 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a diagram type" ;
    oc:directiveContent "Match diagram type to concept: flowcharts for processes, sequence diagrams for interactions, ER diagrams for data models, class diagrams for OOP, state diagrams for workflows, Gantt for timelines." ;
    oc:hasRationale "Using the wrong diagram type obscures the concept rather than illuminating it" .

oc:kn_df094eb9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "Cannot render images directly — outputs are text-based code that must be rendered through external tools (Mermaid Live Editor, GitHub markdown, VS Code extension, etc.)." ;
    oc:hasRationale "The skill generates code, not images; users must use a rendering tool to produce visual output" ;
    oc:severityLevel "HIGH" .

