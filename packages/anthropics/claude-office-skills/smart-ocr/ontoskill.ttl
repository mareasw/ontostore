oc:kn_042eecf1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before running OCR on any image" ;
    oc:directiveContent "Preprocess images before OCR: convert to grayscale, enhance contrast (2.0x), and sharpen to significantly improve recognition accuracy." ;
    oc:hasRationale "Image quality is the single biggest factor in OCR accuracy; preprocessing addresses common issues like low contrast, blur, and noise." ;
    oc:severityLevel "HIGH" .

oc:kn_09d1754d a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When processing large volumes of images" ;
    oc:directiveContent "GPU acceleration is recommended for production workloads. CPU mode with enable_mkldnn=True provides acceptable performance for small batches. Use ThreadPoolExecutor for parallel batch processing." ;
    oc:hasRationale "OCR is compute-intensive; without GPU or parallelization, batch processing can be prohibitively slow." ;
    oc:severityLevel "LOW" .

oc:kn_0d981a80 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing multi-column layouts like newspapers or tables" ;
    oc:directiveContent "For multi-column documents, process each column separately using bounding box X-coordinate ranges rather than attempting full-page OCR which interleaves columns." ;
    oc:hasRationale "OCR engines read left-to-right by default and will interleave text from adjacent columns, producing garbled output." ;
    oc:severityLevel "MEDIUM" .

oc:kn_267b22da a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Basic OCR initialization and result iteration" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from paddleocr import PaddleOCR
ocr = PaddleOCR(use_angle_cls=True, lang='en')
result = ocr.ocr('image.png', cls=True)
for line in result[0]:
    box = line[0]      # [[x1,y1], [x2,y2], [x3,y3], [x4,y4]]
    text = line[1][0]  # Extracted text
    conf = line[1][1]  # Confidence score""" .

oc:kn_33ecb10a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the document language is known" ;
    oc:directiveContent "Specify the correct language code when initializing PaddleOCR rather than relying on auto-detection for best results." ;
    oc:hasRationale "Language-specific models have higher accuracy than multilingual auto-detect models, especially for CJK and RTL languages." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4a78765f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting raw OCR output to structured, position-sorted data" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """def process_ocr_result(result):
    lines = []
    for line in result[0]:
        box, text, confidence = line[0], line[1][0], line[1][1]
        x_coords = [p[0] for p in box]
        y_coords = [p[1] for p in box]
        lines.append({'text': text, 'confidence': confidence,
            'bbox': {'left': min(x_coords), 'top': min(y_coords),
                     'right': max(x_coords), 'bottom': max(y_coords)}})
    return sorted(lines, key=lambda x: (x['bbox']['top'], x['bbox']['left']))""" .

oc:kn_845478d0 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When encountering difficult source material" ;
    oc:directiveContent "Handwritten text accuracy varies significantly, very small text may not be detected, complex backgrounds reduce accuracy, and rotated text requires angle classification (use_angle_cls=True)." ;
    oc:hasRationale "Understanding limitations prevents over-reliance on OCR output for problematic document types." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9aede7b1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring language for OCR" ;
    oc:directiveContent "PaddleOCR supports 100+ languages with codes like 'en', 'ch', 'cht', 'japan', 'korean', 'french', 'german', 'spanish', 'russian', 'arabic', 'hindi', 'vi', 'th'. Use 'multilingual' for auto-detection." ;
    oc:hasRationale "Using the wrong language code will produce garbled or missing text output." ;
    oc:severityLevel "HIGH" .

oc:kn_b79bf6a2 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard OCR extraction workflow" ;
    oc:directiveContent "1. Preprocess image (grayscale, contrast, sharpen) 2. Initialize PaddleOCR with correct language and use_angle_cls=True 3. Run ocr.ocr() on image 4. Process results: extract text, confidence, bounding box 5. Sort results by position (top-to-bottom, left-to-right) 6. Filter low-confidence results 7. Reconstruct text layout grouping by Y-coordinate proximity" ;
    oc:hasRationale "Following this sequence maximizes extraction accuracy and produces well-ordered output." ;
    oc:severityLevel "HIGH" ;
    oc:stepOrder 1 .

oc:kn_d984ef85 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "OCR result output" ;
    oc:directiveContent """Lines sorted top-to-bottom, left-to-right:
--- Page N ---
{line1_text} [{confidence}]
{line2_text} [{confidence}]
...

Structured format per line:
- text: extracted string
- confidence: 0.0-1.0
- bbox: {left, top, right, bottom}
- raw_box: [[x1,y1],[x2,y2],[x3,y3],[x4,y4]]""" ;
    oc:templateVariables "N",
        "bottom",
        "confidence",
        "left",
        "line_text",
        "right",
        "top" .

oc:kn_dace6d70 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before first use" ;
    oc:directiveContent "pip install paddlepaddle paddleocr (CPU) or pip install paddlepaddle-gpu paddleocr (GPU with CUDA 11.x). Additional: pip install pdf2image Pillow" .

oc:kn_fd419fcd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing OCR results" ;
    oc:directiveContent "Do not trust low-confidence OCR results blindly. Filter results below a confidence threshold (e.g., 0.5) and flag them for manual review." ;
    oc:hasRationale "Low-confidence extractions often contain errors that propagate into downstream data processing." ;
    oc:severityLevel "MEDIUM" .

