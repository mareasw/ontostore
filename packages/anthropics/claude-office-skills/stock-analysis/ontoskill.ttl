        oc:kn_a4d9f92c,
        oc:kn_cb144a00,
        oc:kn_e57f91f2,
        oc:kn_f5f3fd4a ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CompanyIdentified ;
    oc:resolvesIntent "analyze a stock",
        "assess stock valuation",
        "compare stocks with peers",
        "evaluate stock fundamentals",
        "generate investment report",
        "perform technical stock analysis" ;
    oc:yieldsState oc:StockAnalysisComplete .

oc:kn_137d0af8 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When interpreting valuation results" ;
    oc:directiveContent "Valuation models have inherent assumptions and limitations. Results do not account for insider information or pending announcements." ;
    oc:hasRationale "Models are simplifications of reality; acknowledging limitations prevents overconfidence in outputs" ;
    oc:severityLevel "MEDIUM" .

oc:kn_597e6e5d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Obtain stock ticker/code and identify market (US/China A-shares/Hong Kong) 2. Select analysis type (Quick Analysis, Deep Dive, Technical Review, or Peer Comparison) 3. Calculate valuation ratios (P/E, P/B, P/S, EV/EBITDA, PEG) 4. Assess profitability (margins, ROE, ROIC) and growth metrics 5. Evaluate financial health (debt ratios, liquidity, FCF yield) 6. Generate structured report with executive summary, metrics table, fundamental/technical analysis, risks, and investment thesis" ;
    oc:stepOrder 1 .

oc:kn_5fd4c867 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating stock analysis output" ;
    oc:directiveContent "Structure every report with balanced bull and bear cases, explicit risk factors, and a clear rating (Bullish/Neutral/Bearish) with risk level (Low/Medium/High)." ;
    oc:hasRationale "Balanced analysis prevents confirmation bias and gives decision-makers a complete picture of both upside and downside scenarios" ;
    oc:severityLevel "HIGH" .

oc:kn_a4d9f92c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any stock analysis report" ;
    oc:directiveContent "Never present analysis as investment advice or guarantee future performance. Always include a disclaimer that the report is for informational purposes only." ;
    oc:hasRationale "Legal and ethical requirement to avoid liability and mislead users into treating analysis as financial advice" ;
    oc:severityLevel "CRITICAL" .

oc:kn_cb144a00 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing fundamental valuation assessment" ;
    oc:directiveContent "Use these valuation benchmarks as starting points: P/E <15 undervalued/>25 expensive, P/B <1 value/>3 growth priced in, EV/EBITDA <10 attractive/>15 expensive, PEG <1 undervalued relative to growth, ROE >15% good, Net Margin >10% healthy, Debt/Equity <1 safe." ;
    oc:hasRationale "These thresholds provide standardized reference points but should be adjusted for industry context and market conditions" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e57f91f2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always - fundamental skill boundary" ;
    oc:directiveContent "Cannot provide real-time stock prices, investment advice, or access proprietary trading data. Analysis is based on publicly available information only." ;
    oc:hasRationale "Prevents misuse of analysis as financial advice and sets correct user expectations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_f5f3fd4a a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating stock analysis report" ;
    oc:directiveContent """# Stock Analysis Report: {TICKER}
**Company**: {Full Name} | **Market**: {Exchange} | **Sector**: {Industry} | **Analysis Date**: {Date}
## Executive Summary - {2-3 sentence overview} | **Rating**: {Bullish/Neutral/Bearish} | **Risk Level**: {Low/Medium/High}
## Key Metrics at a Glance - Table: {Metric, Value, vs Industry, Assessment}
## Fundamental Analysis - Business Overview, Financial Performance, Valuation Assessment
## Technical Analysis - Price Trend, Key Levels (Support/Resistance/52-week Range)
## Risk Factors - Numbered list
## Investment Thesis - Bull Case, Bear Case
## Disclaimer""" ;
    oc:templateVariables "Assessment",
        "Bullish/Neutral/Bearish",
        "Date",
        "Exchange",
        "Full Name",
        "Industry",
        "Low/Medium/High",
        "Metric",
        "TICKER",
        "Value",
        "vs Industry" .

