        "optimize PDF for web or email",
        "reduce PDF file size" ;
    oc:yieldsState oc:FileOptimized .

oc:kn_26cab328 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working with previously compressed files" ;
    oc:directiveContent "Avoid recompressing JPEG images multiple times — each recompression cycle causes cumulative quality loss. Already-compressed PDFs yield diminishing returns." ;
    oc:hasRationale "Cumulative JPEG recompression degrades image quality progressively" ;
    oc:severityLevel "HIGH" .

oc:kn_3c1a00d6 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When compressing any PDF" ;
    oc:directiveContent "1. Assess current PDF (size, page count, image count, use case) 2. Select target size or quality level based on use case 3. Apply image optimization (DPI reduction + JPEG compression) 4. Subset fonts and remove unused characters 5. Clean up unused objects, metadata, and optional elements 6. Generate before/after comparison report" ;
    oc:stepOrder 1 .

oc:kn_402f7bb0 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When setting expectations or planning compression" ;
    oc:directiveContent "Expected size reductions by level: Minimum 5-15%, Low 15-30%, Medium 30-50%, High 50-70%, Maximum 70-90%. Biggest gains come from image downsampling and JPEG quality reduction." ;
    oc:hasRationale "Understanding expected savings helps set realistic targets" .

oc:kn_41d71eaa a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "This skill provides guidance only — it cannot perform actual compression itself. Use the office-mcp compress_pdf tool or external tools like Ghostscript/qpdf for execution." ;
    oc:hasRationale "The skill is advisory; actual compression requires a tool" ;
    oc:severityLevel "HIGH" .

oc:kn_4fa489a1 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When reporting compression results" ;
    oc:directiveContent """## PDF Compression Report
### File Summary
| Metric | Before | After | Change |
### Compression Applied
| Technique | Savings |
### Quality Assessment
| Aspect | Rating | Notes |
### Recommendations
✅ Suitable for: ...
⚠️ Not recommended for: ...""" ;
    oc:templateVariables "After",
        "Aspect",
        "Before",
        "Change",
        "Metric",
        "Notes",
        "Rating",
        "Savings",
        "Technique" .

oc:kn_6046056f a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before executing compression" ;
    oc:directiveContent "Requires the office-mcp MCP server with compress_pdf tool available, or external tools like Ghostscript, qpdf, or pdfcpu for command-line compression." .

oc:kn_751f4f70 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assessing compression impact" ;
    oc:directiveContent "Vector text remains crisp at all compression levels; only embedded raster images are affected. Prioritize image optimization over text manipulation." ;
    oc:hasRationale "Vector text is resolution-independent and unaffected by image compression settings" .

oc:kn_afc70911 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting compression settings" ;
    oc:directiveContent "Match compression level to use case: Minimum/Low for print, Medium/High for email, High for web, Maximum for preview only. Screen viewing needs only 72 DPI; professional print requires 300 DPI." ;
    oc:hasRationale "Over-compressing print materials degrades output; under-compressing web PDFs wastes bandwidth" .

