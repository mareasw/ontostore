    oc:dependsOnSkill oc:skill_ontoskills_stripe_payments ;
    oc:differentia "covers billing, upgrades/downgrades, churn prevention, health scoring, dunning, and revenue optimization across the full customer lifecycle" ;
    oc:extends oc:skill_ontoskills_saas_metrics ;
    oc:handlesFailure oc:ChurnDetected,
        oc:DowngradeRequested,
        oc:PaymentFailed ;
    oc:hasCategory "finance" ;
    oc:hasDescription "SaaS subscription lifecycle management - billing, upgrades, downgrades, churn prevention, and revenue optimization" ;
    oc:hasName "subscription-management" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: subscription-management
description: "SaaS subscription lifecycle management - billing, upgrades, downgrades, churn prevention, and revenue optimization"
version: "1.0.0"
author: claude-office-skills
license: MIT

category: finance
tags:
  - subscription
  - billing
  - saas
  - churn
  - revenue
department: Finance

models:
  recommended:
    - claude-sonnet-4
    - claude-opus-4

mcp:
  server: billing-mcp
  tools:
    - stripe_subscription
    - chargebee_api
    - paddle_billing

capabilities:
  - subscription_lifecycle
  - billing_optimization
  - churn_prevention
  - upgrade_paths
  - revenue_recognition

languages:
  - en
  - zh

related_skills:
  - saas-metrics
  - crm-automation
  - email-marketing
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Comprehensive SaaS subscription lifecycle management including billing operations, upgrade/downgrade flows, churn prevention strategies, and revenue optimization." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """lifecycle_stages:
  trial:
    duration: 14_days
    goal: activation + conversion
    key_metrics:
      - trial_starts
      - activation_rate
      - trial_to_paid_conversion
    automation:
      - onboarding_emails
      - in_app_guidance
      - sales_touch (if qualified)
      
  active:
    goal: value_delivery + expansion
    key_metrics:
      - feature_adoption
      - nps_score
      - expansion_revenue
    automation:
      - health_scoring
      - usage_alerts
      - upsell_triggers
      
  at_risk:
    trigger: health_score < 40 OR usage_drop > 50%
    goal: retention
    key_metrics:
      - save_rate
      - churn_reason
    automation:
      - csm_alert
      - retention_offer
      - executive_escalation
      
  churned:
    goal: win_back
    key_metrics:
      - reactivation_rate
      - time_to_reactivate
    automation:
      - exit_survey
      - win_back_campaigns
      - competitive_monitoring
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 83-128" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Stage Definitions" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """┌─────────────────────────────────────────────────────────────────┐
│                    SUBSCRIPTION LIFECYCLE                        │
├─────────────────────────────────────────────────────────────────┤
│                                                                 │
│  Trial ──▶ Conversion ──▶ Active ──▶ Expansion ──▶ Renewal     │
│    │           │            │           │            │          │
│    ▼           ▼            ▼           ▼            ▼          │
│  [Drop]    [Churn]     [Downgrade]  [Churn]     [Churn]        │
│                            │                        │           │
│                            ▼                        ▼           │
│                       [Win-back] ◀──────────── [Win-back]      │
│                                                                 │
└─────────────────────────────────────────────────────────────────┘
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 65-79" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Lifecycle Stages" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Subscription Lifecycle" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """customer_health_score:
  components:
    product_usage: 40%
      signals:
        - daily_active_users: vs_licensed_seats
        - feature_adoption: core_features_used
        - login_frequency: weekly_active
        - depth_of_use: actions_per_session
        
    engagement: 30%
      signals:
        - email_opens: last_30_days
        - support_sentiment: positive_vs_negative
        - nps_score: latest
        - community_participation: if_applicable
        
    relationship: 20%
      signals:
        - csm_touchpoints: recent_calls
        - executive_sponsor: identified
        - contract_length: multi_year_bonus
        
    financial: 10%
      signals:
        - payment_history: on_time_payments
        - expansion_history: upgrades_vs_downgrades
        - invoice_disputes: count
        
  scoring:
    90-100: healthy (green)
    70-89: stable (yellow)
    40-69: at_risk (orange)
    0-39: critical (red)
    
  automation:
    critical:
      - immediate: csm_alert + call_scheduled
      - if_no_response: manager_escalation
      
    at_risk:
      - same_day: csm_notification
      - action: health_check_call
      
    stable:
      - weekly: review_in_team_meeting
      
    healthy:
      - monthly: expansion_opportunity_review
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 315-364" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Health Scoring" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """dunning_sequence:
  payment_failed:
    day_0:
      - retry_payment: automatic
      - email: "Payment failed - please update"
      - in_app: banner_notification
      
    day_3:
      - retry_payment: automatic
      - email: "Action needed: Update payment"
      - include: direct_update_link
      
    day_7:
      - retry_payment: automatic
      - email: "Your account is at risk"
      - sms: if_enabled
      - downgrade_warning: true
      
    day_14:
      - final_retry: automatic
      - email: "Final notice before suspension"
      - csm_call: for_high_value_accounts
      
    day_21:
      - suspend_account: read_only_access
      - email: "Account suspended"
      - preserve_data: 90_days
      
    day_90:
      - delete_data: after_warning
      - final_email: account_closure
      
  recovery_metrics:
    track:
      - involuntary_churn_rate
      - recovery_rate_by_day
      - avg_days_to_recovery
      - revenue_recovered
""" ;
                                    oc:codeLanguage "yaml" ;
