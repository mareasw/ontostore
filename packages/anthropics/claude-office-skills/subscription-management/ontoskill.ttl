        "manage dunning and failed payments",
        "manage subscription lifecycle",
        "optimize subscription revenue",
        "prevent customer churn" ;
    oc:yieldsState oc:ChurnPreventionConfigured,
        oc:DunningSequenceActive,
        oc:SubscriptionManaged .

oc:kn_253a0085 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When processing plan changes" ;
    oc:directiveContent "Upgrades charge prorated difference immediately; downgrades credit at next billing cycle; mid-cycle changes calculate daily rates." ;
    oc:hasRationale "Immediate upgrade charges capture revenue while delayed downgrade credits reduce billing friction and support retention" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3a1fda95 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a customer requests a downgrade" ;
    oc:directiveContent "Never immediately execute a downgrade request without first intercepting with retention offers (pause, discount, free month) and collecting the churn reason." ;
    oc:hasRationale "Intercepting with tailored offers can save 25%+ of at-risk revenue and provides data for systemic improvement" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4f3626db a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing failed payments and dunning" ;
    oc:directiveContent "Dunning sequence must allow 90 days of data preservation after account suspension before deletion, with graduated retry attempts at days 0, 3, 7, and 14." ;
    oc:hasRationale "Premature data deletion prevents win-back opportunities and may violate data retention regulations" ;
    oc:severityLevel "HIGH" .

oc:kn_5219ed08 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When configuring upgrade automation" ;
    oc:directiveContent "Upgrade triggers should be automated based on three categories: usage-based (approaching limits, feature blocked, consistent overage), behavior-based (power user signals), and time-based (90 days on same plan)." ;
    oc:hasRationale "Multi-signal triggers catch expansion opportunities that any single signal type would miss" .

oc:kn_5e1184d7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing subscription management workflows" ;
    oc:directiveContent "Verify billing system integration (Stripe/Chargebee/Paddle) is configured and API keys are set before executing any subscription operations." ;
    oc:hasRationale "Subscription operations require live billing system connectivity; attempting operations without integration causes customer-facing errors" .

oc:kn_7ba0e3ce a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When monitoring customer health scores" ;
    oc:directiveContent "Health score below 40 triggers immediate CSM alert and call scheduling; 40-69 triggers same-day CSM notification; 70-89 gets weekly review; 90+ gets monthly expansion review." ;
    oc:hasRationale "Tiered response ensures critical accounts get immediate attention while healthy accounts receive appropriate growth focus" ;
    oc:severityLevel "HIGH" .

oc:kn_8e0c5194 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When handling payment failures" ;
    oc:directiveContent "For involuntary churn from failed payments, use automated retry + graduated communication (email day 0, email+SMS day 3, warning day 7, final notice day 14, suspend day 21) while preserving data for 90 days." ;
    oc:hasRationale "Graduated dunning with multiple touchpoints recovers revenue that would otherwise be lost to payment issues, not customer intent" .

oc:kn_daf4c3cb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing pricing and packaging strategy" ;
    oc:directiveContent "Use a hybrid value metric (base fee + usage overage) for mature products; per-seat for collaboration tools; usage-based for infrastructure/APIs; feature-tiered for distinct use case products." ;
    oc:hasRationale "Aligning the value metric to the product type ensures pricing scales with customer value perception" ;
    oc:severityLevel "MEDIUM" .

