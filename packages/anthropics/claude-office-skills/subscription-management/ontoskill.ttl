oc:skill_claude_office_skills_subscription_management a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "subscription-management" ;
    skos:broader "SaaS subscription lifecycle management framework" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/claude-office-skills/subscription-management" ;
