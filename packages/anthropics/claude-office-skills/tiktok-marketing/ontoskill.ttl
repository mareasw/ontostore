oc:kn_282ae1ae a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scaling TikTok content production" ;
    oc:directiveContent "Do not exceed 5 videos/day — quality degrades after 3/day. Do not ignore watch time metric if below 50%." ;
    oc:hasRationale "Spamming low-quality content damages account authority and triggers algorithmic demotion" ;
    oc:severityLevel "MEDIUM" .

oc:kn_33883e13 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When developing a TikTok content strategy" ;
    oc:directiveContent "Maintain 4-6 content pillars: ~40% Educational, ~30% Entertainment, ~15% Promotional, ~15% Community. One clear message per video. Use pattern interrupts every 3-5 seconds." ;
    oc:hasRationale "Balanced pillars prevent audience fatigue while driving authority, reach, conversions, and engagement simultaneously" .

oc:kn_52911b57 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When analyzing TikTok performance" ;
    oc:directiveContent "Target metrics: Watch Time >50%, Engagement Rate >5%, Share Rate >1%, Follow Rate >2%, Profile Visits >10% of views. If below targets, adjust hooks, CTAs, or value proposition." ;
    oc:hasRationale "These benchmarks indicate healthy content performance relative to platform averages" .

oc:kn_5bd36655 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When identifying and acting on TikTok trends" ;
    oc:directiveContent "Target trends within 48 hours of emergence (Day 1-2 highest potential, Day 3-5 still good, Day 6+ likely saturated). Check sound usage growth >500% in 48h with <10K uses." ;
    oc:hasRationale "TikTok trend windows are extremely short; early participation is the single biggest viral multiplier" .

oc:kn_6763d7a9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting a TikTok posting schedule" ;
    oc:directiveContent "Post minimum 1 video/day, optimal 2-3, maximum 5. Never go more than 24 hours without posting. Same time slots daily build audience habit." ;
    oc:hasRationale "Consistency signals to the algorithm that the account is active and reliable, improving organic distribution" ;
    oc:severityLevel "HIGH" .

oc:kn_69ad66ea a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any TikTok video script" ;
    oc:directiveContent "Structure TikTok videos as Hook (0-3s) → Content (3-50s) → CTA (last 2-3s). The hook must stop the scroll immediately." ;
    oc:hasRationale "TikTok's algorithm heavily weights watch time; losing viewers in the first 3 seconds kills video performance" ;
    oc:severityLevel "CRITICAL" .

oc:kn_958cbcb5 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "When setting up automated TikTok content workflows" ;
    oc:directiveContent "For full automation: n8n instance, OpenAI API key, ElevenLabs API key, TikTok Business Account with API access, Google Sheets or Airtable for tracking" .

oc:kn_968c26aa a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building an automated TikTok content pipeline with n8n" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """workflow: "AI TikTok Content Generator"
nodes:
  1. trigger: schedule (cron: "0 9 * * *")
  2. get_idea: google_sheets → get_next_unused_row
  3. generate_script: openai (gpt-4) → Hook (3s) + Content (20s) + CTA (3s)
  4. generate_voiceover: elevenlabs
  5. generate_visuals: dalle
  6. create_video: video_editor (tiktok_vertical template)
  7. publish: tiktok (caption, hashtags, schedule)
  8. update_tracker: google_sheets → mark_as_published""" .

oc:kn_9d542b38 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When researching hashtags for a TikTok campaign" ;
    oc:directiveContent "1. Search niche keyword on TikTok 2. Note hashtags on top 10 videos 3. Check hashtag view counts 4. Mix high (1B+), medium (1M-100M), low (100K-1M) reach tags 5. Test and track performance 6. Rotate bottom performers weekly" ;
    oc:stepOrder 2 .

oc:kn_a46c6dc2 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating weekly TikTok analytics reports" ;
    oc:directiveContent """# TikTok Weekly Performance Report

## Overview
- Videos Posted: {count}
- Total Views: {views}
- New Followers: {followers}
- Engagement Rate: {rate}%

## Top Performing Videos
| Video | Views | Likes | Comments | Shares |

## Content Analysis
- Best performing pillar: {pillar}
- Best posting time: {time}
- Best hook type: {hook}

## Recommendations
1. {rec_1}
2. {rec_2}
3. {rec_3}""" ;
    oc:templateVariables "count",
        "followers",
        "hook",
        "pillar",
        "rate",
        "rec_1",
        "rec_2",
        "rec_3",
        "time",
        "views" .

oc:kn_a5209667 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding hashtags to any TikTok post" ;
    oc:directiveContent "Use 5-7 hashtags total: 2-3 niche-specific, 1-2 trending, 1 branded, 1 community. This is TikTok's optimal range." ;
    oc:hasRationale "Over-hashtagging dilutes relevance signals; the mix strategy balances reach, targeting, and brand building" ;
    oc:severityLevel "HIGH" .

oc:kn_f0b4e925 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When running a complete TikTok marketing workflow" ;
    oc:directiveContent "1. Define 4-6 content pillars with ratios 2. Build weekly content calendar assigning pillar/format/hook/CTA per day 3. Research trending sounds and hashtags 4. Write scripts using Hook-Content-CTA structure 5. Generate or capture video assets 6. Publish at optimal times per audience timezone 7. Track metrics weekly and rotate underperforming hashtags" ;
    oc:stepOrder 1 .

oc:kn_f9c630a5 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing educational TikTok video scripts" ;
    oc:directiveContent """[HOOK - 3s] "Here's a [topic] hack most people don't know..."
[SETUP - 5s] "I used to struggle with [problem] until I discovered this."
[CONTENT - 20s] "Step 1: [action] → Step 2: [action] → Step 3: [action]"
[PROOF - 5s] "And look at the results: [show before/after]"
[CTA - 3s] "Follow for more [niche] tips!\"""" .

