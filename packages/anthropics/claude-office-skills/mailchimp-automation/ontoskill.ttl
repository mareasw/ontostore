oc:kn_1296240c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Ongoing audience management" ;
    oc:directiveContent "Clean your list regularly by removing bounces and inactive subscribers; maintain list hygiene for deliverability." ;
    oc:hasRationale "High bounce and inactive rates hurt sender reputation and inbox placement." ;
    oc:severityLevel "MEDIUM" .

oc:kn_12a2a34e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating email templates and content" ;
    oc:directiveContent "Design all emails mobile-first — 38%+ of opens occur on mobile devices." ;
    oc:hasRationale "Mobile readers represent a large share of email engagement; desktop-only layouts will underperform." ;
    oc:severityLevel "HIGH" .

oc:kn_14c0a546 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When scheduling campaign sends" ;
    oc:directiveContent "Peak email open times are 10:00 AM - 12:00 PM; schedule sends accordingly." ;
    oc:hasRationale "Timing sends to peak engagement windows maximizes open rates." .

oc:kn_2ec40671 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "All email campaigns and automations" ;
    oc:directiveContent "Comply with CAN-SPAM and GDPR regulations — always include unsubscribe links and company address." ;
    oc:hasRationale "Legal non-compliance can result in fines and blacklisting." ;
    oc:severityLevel "CRITICAL" .

oc:kn_34e9662f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before sending any campaign" ;
    oc:directiveContent "Never send campaigns without testing subject lines, content, and timing first via A/B or multivariate tests." ;
    oc:hasRationale "Untested campaigns risk poor engagement and wasted audience reach." ;
    oc:severityLevel "HIGH" .

oc:kn_4ff929ea a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Ongoing campaign planning" ;
    oc:directiveContent "Respect sending frequency — don't over-send to your audience. Monitor unsubscribe rates as a frequency signal." ;
    oc:hasRationale "Over-sending leads to list fatigue, higher unsubscribes, and spam complaints." ;
    oc:severityLevel "MEDIUM" .

oc:kn_85a987f6 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building cart recovery automations" ;
    oc:directiveContent "For abandoned cart recovery, use a 3-email sequence at 1 hour, 24 hours, and 72 hours with escalating incentives." ;
    oc:hasRationale "Timed follow-ups with increasing urgency recover the most revenue from abandoned carts." .

oc:kn_b5d3b2f1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring A/B tests" ;
    oc:directiveContent "Use 20% of your list for A/B testing with a 4-hour wait, then auto-send the winner to the remaining 80%." ;
    oc:hasRationale "This split balances statistical significance with maximizing reach of the winning variant." .

oc:kn_be433ca9 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "Post-campaign analysis" ;
    oc:directiveContent "If a campaign underperforms, check device breakdown, top clicked links, and open time distribution to diagnose and adjust next send." ;
    oc:hasRationale "Analytics breakdowns reveal whether the issue was timing, content, or audience targeting." .

oc:kn_fe355925 a oc:Heuristic,
