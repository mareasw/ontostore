                                    oc:blockType "code_block" ;
                                    oc:codeContent """// Create Campaign
const campaign = await mailchimp.campaigns.create({
  type: "regular",
  recipients: {
    list_id: "abc123",
    segment_opts: {
      saved_segment_id: "seg123"
    }
  },
  settings: {
    subject_line: "Your Weekly Update",
    preview_text: "This week's top stories",
    from_name: "Company Name",
    reply_to: "hello@company.com"
  }
});

// Set Content
await mailchimp.campaigns.setContent(campaign.id, {
  template: {
    id: "template_123",
    sections: {
      headline: "Welcome to our newsletter!"
    }
  }
});

// Send Campaign
await mailchimp.campaigns.send(campaign.id);
""" ;
                                    oc:codeLanguage "javascript" ;
