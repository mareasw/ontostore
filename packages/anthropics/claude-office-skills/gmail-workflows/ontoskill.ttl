oc:kn_058a7c68 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When troubleshooting Gmail workflow failures" ;
    oc:directiveContent "Attachments may not be detected due to MIME type filters — increase trigger frequency. Large files may fail — set size limits or use chunked upload. Rate limits require reducing trigger frequency or using batch processing." ;
    oc:hasRationale "Gmail API has rate limits and MIME type quirks that cause silent failures in automated workflows" ;
    oc:severityLevel "MEDIUM" .

oc:kn_47dcde54 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When setting up Gmail workflow automation" ;
    oc:directiveContent "Request minimal OAuth scopes (gmail.readonly for reading, gmail.modify for labels/archive, drive.file for Drive access). Never log email content. Use secure credential storage and separate service accounts." ;
    oc:hasRationale "Over-scoped tokens increase blast radius if compromised; email content is sensitive PII" ;
    oc:severityLevel "HIGH" .

oc:kn_575982b2 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing any Gmail automation workflow" ;
    oc:directiveContent "Follow the Filter → Process → Organize → Notify pattern for all Gmail workflows. Apply filters first to skip non-matching emails, then process content, organize results, and notify stakeholders." ;
    oc:hasRationale "This 4-stage pattern ensures efficient processing and avoids wasted computation on irrelevant emails" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8267506b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any Gmail attachment workflow" ;
    oc:directiveContent "Use specific sender filters to avoid processing spam emails; set file size limits to prevent storage issues; use date-based folder structure for easy retrieval; enable duplicate detection to avoid redundant uploads." ;
    oc:hasRationale "Broad filters cause noise and wasted processing; date-based paths scale well; deduplication prevents storage bloat" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d55b61a9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring invoice auto-archiver workflows" ;
    oc:directiveContent "Invoice detection supports multilingual subject patterns including English (invoice, bill, statement) and Chinese (付款, 发票). Workflow configurations support both English and Chinese language patterns." ;
    oc:hasRationale "International invoices require multilingual keyword matching to avoid missed documents" ;
    oc:severityLevel "LOW" .

oc:kn_efc93747 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring file upload destinations" ;
    oc:directiveContent "Use date-based folder structures (/{year}/{month}) for Drive uploads and consistent naming patterns ({filename}_{sender}_{date}) to ensure files are retrievable and avoid collisions." ;
    oc:hasRationale "Flat folder structures become unmanageable at scale; consistent naming enables search and deduplication" ;
    oc:severityLevel "MEDIUM" .

