oc:kn_99aa27da a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing on-page SEO elements" ;
    oc:directiveContent "Title tags must be 50-60 characters with keyword at start, unique per page. Meta descriptions must be 150-160 characters with keyword and CTA." ;
    oc:hasRationale "Character limits ensure full display in SERPs; keyword placement impacts click-through rate and relevance signals." ;
    oc:severityLevel "HIGH" .

oc:kn_d6d5708b a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating monthly SEO reports" ;
    oc:directiveContent """SEO Performance Report structure:
## Organic Traffic Summary (Sessions, Users, Conversions, Conv Rate with MoM/YoY)
## Keyword Rankings (Improved, Declined, New)
## Top Pages by Traffic (Sessions, Conv, CVR)
## Technical Health (crawl errors, CWV, mobile, index coverage)
## Actions Taken
## Next Month Plan""" ;
    oc:hasRationale "Standardized report format enables consistent tracking and stakeholder communication." ;
    oc:templateVariables "Conv Rate",
        "Conversions",
        "Keyword Rankings",
        "Month",
        "Sessions",
        "Users" .

oc:kn_e9c8896c a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before executing keyword research or technical audits" ;
    oc:directiveContent "Requires access to SEO tools (Google Keyword Planner, Ahrefs/SEMrush, Google Search Console) for keyword data and technical audit metrics." ;
    oc:hasRationale "SEO analysis depends on search volume, difficulty, and crawl data that requires tool access." .

oc:kn_ec417439 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring page URLs" ;
    oc:directiveContent "Avoid URLs with dates, parameters, uppercase letters, or excessive length (>75 chars). Keep URLs clean: domain.com/category/keyword-slug." ;
    oc:hasRationale "Clean URLs improve crawlability, click-through rate, and remain evergreen without date-stamped paths." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ed0d1642 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When prioritizing keywords during research" ;
    oc:directiveContent "Prioritize keywords using the formula: priority_score = (search_volume × business_relevance) / keyword_difficulty, scored 1-5 on each axis." ;
    oc:hasRationale "Balances traffic potential with ranking feasibility and business value to identify highest-impact targets." ;
    oc:severityLevel "HIGH" .

_:ref_072f72b323963084 a oc:WorkflowStep ;
    dcterms:description "Create content briefs with target keywords, outline structure, competitor analysis, and optimization checklist." ;
    oc:expectedOutcome "SEO-optimized content brief with complete outline and targeting strategy" ;
    oc:stepDependsOn _:ref_699acdf514b83788,
        _:ref_f1e06181769d6ba6 ;
    oc:stepId "content-optimization" .

_:ref_e01265e468c05679 a oc:WorkflowStep ;
    dcterms:description "Audit crawlability, indexability, site speed/Core Web Vitals, mobile-friendliness, HTTPS, and structured data." ;
    oc:expectedOutcome "Technical SEO health report with specific issues and fixes needed" ;
    oc:stepId "technical-audit" .

_:ref_699acdf514b83788 a oc:WorkflowStep ;
    dcterms:description "Audit title tags, meta descriptions, heading structure, content, images, internal/external links, and URL structure." ;
    oc:expectedOutcome "On-page optimization checklist with identified issues and recommendations" ;
    oc:stepDependsOn _:ref_f1e06181769d6ba6 ;
    oc:stepId "on-page-audit" .

_:ref_f1e06181769d6ba6 a oc:WorkflowStep ;
    dcterms:description "Generate seed keywords, expand using tools, categorize by intent, and prioritize by scoring formula." ;
    oc:expectedOutcome "Prioritized keyword list with volume, difficulty, relevance, and priority scores" ;
    oc:stepId "keyword-research" .

