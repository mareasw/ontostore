oc:kn_31921b4c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing source documents for conversion" ;
    oc:directiveContent "Use consistent heading levels in source documents and check that complex tables convert correctly — manually adjust any that don't." ;
    oc:hasRationale "Well-structured source documents produce cleaner Markdown output, reducing post-processing effort." ;
    oc:severityLevel "LOW" .

oc:kn_35cd0cae a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When converting .docx files with tracked changes or complex tables" ;
    oc:directiveContent "Track changes in Word documents are not preserved, comments may not be extracted, and some table structures may not convert perfectly." ;
    oc:hasRationale "markitdown's conversion focuses on content extraction rather than full fidelity of Word's revision and collaboration features." ;
    oc:severityLevel "MEDIUM" .

oc:kn_441be773 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running conversions on unchanged files" ;
    oc:directiveContent "Conversion is idempotent for static source files — running the same conversion multiple times produces identical output." ;
    oc:hasRationale "Safe to re-convert without side effects, enabling automated pipelines and CI/CD integration." ;
    oc:severityLevel "LOW" .

oc:kn_77c4a302 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting files containing images or audio" ;
    oc:directiveContent "Images are not embedded in Markdown output — use a vision model (llm_client parameter) for image description, and audio files require markitdown[all] or markitdown[audio] extras." ;
    oc:hasRationale "markitdown cannot embed binary content; images need OCR/vision processing and audio needs transcription, both requiring additional dependencies." ;
    oc:severityLevel "MEDIUM" .

