    oc:appliesToContext "When producing analysis output" ;
    oc:directiveContent "Rate threat level as HIGH/MEDIUM/LOW/SAFE with confidence percentage and provide actionable next steps including verification through official channels and reporting to appropriate authorities." ;
    oc:hasRationale "Structured output with clear threat level, confidence, and actions enables decisive user response" .

oc:kn_9d05271d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling any email flagged as potentially suspicious" ;
    oc:directiveContent "Never click, download, reply to, or call numbers in a suspicious email during analysis. Only analyze provided content passively." ;
    oc:hasRationale "Interacting with phishing content can trigger malware downloads, confirm active email addresses, or compromise credentials" ;
    oc:severityLevel "CRITICAL" .

