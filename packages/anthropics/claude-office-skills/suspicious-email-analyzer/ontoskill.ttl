oc:kn_090e214e a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When user reports having interacted with a suspicious email" ;
    oc:directiveContent "If a user has already clicked a suspicious link: disconnect from internet, change passwords immediately, enable 2FA, monitor accounts, run antivirus, report to IT, and consider credit monitoring if financial info was shared." ;
    oc:hasRationale "Rapid containment minimizes damage from potential credential theft or malware infection" ;
    oc:severityLevel "CRITICAL" .

oc:kn_1a561811 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When analyzing any email for phishing or scam indicators" ;
    oc:directiveContent "Analyze emails across four dimensions: sender authenticity, content red flags, link safety, and technical header indicators before rendering a verdict." ;
    oc:hasRationale "Multi-dimensional analysis catches sophisticated phishing that may pass single-dimension checks" ;
    oc:severityLevel "CRITICAL" .

oc:kn_424d1fc8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When providing analysis results" ;
    oc:directiveContent "Cannot access actual email headers, verify real-time domain reputation, or analyze live links. Some sophisticated phishing may pass analysis and legitimate emails may have warning signs." ;
    oc:hasRationale "The skill operates purely on provided content without external verification capabilities, limiting certainty" ;
    oc:severityLevel "HIGH" .

oc:kn_4c0c60c2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating email authenticity" ;
    oc:directiveContent "Key phishing indicators include: lookalike domains (paypa1.com), urgency/threat language, generic greetings, credential requests, shortened URLs, HTTP links, IP address URLs, and mismatched display names." ;
    oc:hasRationale "These patterns represent the most common and reliable signals of phishing attempts across scam types" .

oc:kn_57fa50ab a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting verdict and recommendations" ;
    oc:directiveContent "Human judgment is essential for the final decision. The analysis is advisory, not definitive." ;
    oc:hasRationale "Automated analysis cannot fully replace human context about expected communications and relationships" ;
    oc:severityLevel "MEDIUM" .

oc:kn_861c7da0 a oc:DesignPrinciple,
