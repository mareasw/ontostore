oc:skill_claude_office_skills_quickbooks_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "quickbooks-automation" ;
    skos:broader "Accounting automation workflow" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/claude-office-skills/quickbooks-automation" ;
    oc:contentHash "9fa2cd3ac3f4a0af215959d1bb3eb1a742c5b2f491a2044a390220c48b574aff" ;
    oc:dependsOnSkill oc:skill_ontoskills_expense_tracker,
        oc:skill_ontoskills_invoice_automation ;
    oc:differentia "Automates QuickBooks bookkeeping, invoicing, expense tracking, bank reconciliation, and financial reporting through MCP server integration" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "workflow type (invoice, expense, reconciliation, reporting) and relevant transaction data" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Automate QuickBooks accounting workflows including invoicing, expenses, reporting, and bank reconciliation" ;
    oc:hasName "quickbooks-automation" ;
    oc:hasRequirement oc:req_01faad16,
        oc:req_ccc5e435,
        oc:req_ee30b70a ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: QuickBooks Automation
description: Automate QuickBooks accounting workflows including invoicing, expenses, reporting, and bank reconciliation
version: 1.0.0
author: Claude Office Skills
category: accounting
tags:
  - quickbooks
  - accounting
  - invoicing
  - bookkeeping
  - finance
department: finance
models:
  - claude-3-opus
  - claude-3-sonnet
  - gpt-4
mcp:
  server: accounting-mcp
  tools:
    - qb_invoice
    - qb_expense
    - qb_customer
    - qb_reports
capabilities:
  - Invoice management
  - Expense tracking
  - Financial reporting
  - Bank reconciliation
input:
  - Transaction data
  - Customer information
  - Expense receipts
  - Bank statements
output:
  - Invoices
  - Financial reports
  - Reconciliation status
  - Tax summaries
languages:
  - en
related_skills:
  - invoice-automation
  - expense-tracker
  - financial-modeling
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Comprehensive skill for automating QuickBooks accounting and bookkeeping workflows." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """receipt_automation:
  capture:
    sources:
      - email_forward
      - mobile_app
      - bank_feed
      
  extraction:
    fields:
      - vendor
      - date
      - amount
      - payment_method
      
  matching:
    auto_match:
      threshold: 0.95
      rules:
        - amount_exact
        - date_within_3_days
        - vendor_fuzzy_match
        
  categorization:
    use_history: true
    default_category: "Ask Accountant"
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 194-220" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Receipt Processing" ],
