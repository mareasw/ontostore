                                    oc:blockType "code_block" ;
                                    oc:codeContent """// Query recent expenses
const expenses = await qbo.findPurchases({
  TxnDate: { $gt: '2024-01-01' },
  AccountRef: { value: '50' } // Operating Expenses
});

// Query unpaid invoices
