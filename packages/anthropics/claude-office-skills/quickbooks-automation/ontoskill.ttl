oc:kn_13e66c4b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard QuickBooks accounting cycle" ;
    oc:directiveContent "1. Enter data (invoices, expenses, payments, bank feeds) → 2. Categorize transactions (chart of accounts, classes, locations) → 3. Reconcile bank/credit card/clearing accounts → 4. Generate reports (P&L, Balance Sheet, Cash Flow, Tax)" ;
    oc:hasRationale "Following this pipeline ensures complete bookkeeping from data entry through financial reporting" ;
    oc:stepOrder 1 .

oc:kn_1fefe249 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When querying transactions or finding overdue invoices" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const expenses = await qbo.findPurchases({
  TxnDate: { $gt: '2024-01-01' },
  AccountRef: { value: '50' }
});
const unpaid = await qbo.findInvoices({
  Balance: { $gt: 0 },
  DueDate: { $lt: new Date().toISOString() }
});""" .

oc:kn_2c447317 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "Always when configuring QuickBooks access" ;
    oc:directiveContent "Limit user permissions via access controls. Maintain audit trail by reviewing changes regularly. Export data periodically for backups." ;
    oc:hasRationale "Financial data is sensitive; improper access could lead to fraud or data loss" ;
    oc:severityLevel "HIGH" .

oc:kn_3e85e4fd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up automation rules for recurring vendors" ;
    oc:directiveContent "Use historical categorization patterns for new transactions. Map payroll splits by historical ratios (e.g., 85% salaries / 15% payroll taxes) and vendor-specific auto-categorization rules." ;
    oc:hasRationale "Historical pattern matching dramatically reduces manual categorization effort while maintaining consistency" .

oc:kn_4cd73376 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Ongoing QuickBooks maintenance" ;
    oc:directiveContent "Review bank feeds daily, reconcile monthly, close books monthly. Use class tracking for department/project segmentation. Attach receipts to every transaction." ;
    oc:hasRationale "Regular cadence prevents backlog accumulation and ensures audit readiness" .

oc:kn_5daed191 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating bank reconciliation status reports" ;
    oc:directiveContent """BANK RECONCILIATION STATUS
Bank Balance:       ${bank_balance}
QuickBooks Balance: ${qb_balance}
Difference:         ${difference}

UNMATCHED TRANSACTIONS:
| Date | Description | Amount |

PENDING ITEMS:
Outstanding Checks:  ${outstanding}
Deposits in Transit: ${deposits}

LAST RECONCILED: ${last_date}""" ;
    oc:templateVariables "bank_balance",
        "deposits",
        "difference",
        "last_date",
        "outstanding",
        "qb_balance" .

oc:kn_9db62fef a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing receipts and bank feed transactions" ;
    oc:directiveContent "Auto-match receipts only when threshold ≥ 0.95 confidence using amount_exact, date_within_3_days, and vendor_fuzzy_match rules. Unmatched items should default to 'Ask Accountant' category." ;
    oc:hasRationale "High confidence threshold prevents miscategorization that would corrupt financial reporting accuracy" ;
    oc:severityLevel "HIGH" .

oc:kn_c4ddd957 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When bank reconciliation shows a difference" ;
    oc:directiveContent "Bank reconciliation differences often stem from unmatched checks, wire transfers, or deposits in transit. Investigate the difference between bank balance and QuickBooks balance by checking outstanding checks and deposits in transit first." ;
    oc:hasRationale "These are the most common sources of reconciliation discrepancies and should be checked first before deeper investigation" .

oc:kn_d530a917 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating invoices via QuickBooks API" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const invoice = {
  CustomerRef: { value: "123" },
  Line: [{
    DetailType: "SalesItemLineDetail",
    Amount: 1000,
    SalesItemLineDetail: {
      ItemRef: { value: "1" },
      Qty: 10,
      UnitPrice: 100
    }
  }],
  DueDate: "2024-02-15"
};
const response = await qbo.createInvoice(invoice);""" .

oc:kn_fce762b3 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating financial dashboard reports" ;
    oc:directiveContent """FINANCIAL DASHBOARD
PROFIT & LOSS:
Revenue: ${revenue} | COGS: ${cogs} | Gross Profit: ${gross} (${gross_pct}%)
Operating Exp: ${opex} | Net Income: ${net} (${net_pct}%)

BALANCE SHEET:
Assets: ${assets} | Liabilities: ${liabilities} | Equity: ${equity}

CASH POSITION:
Operating Cash: ${cash} | Receivables: ${ar} | Payables: ${ap}

AR AGING:
Current | 1-30 | 31-60 | 61-90 | 90+""" ;
