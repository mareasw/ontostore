oc:kn_0c76f993 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring public-facing release notes" ;
    oc:directiveContent "Never use vague entries like 'various fixes', include commit hashes in user docs, or expose internal changes (test, chore) in public changelogs." ;
    oc:hasRationale "Vague or overly technical entries reduce trust and usability of changelogs" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3daf0a78 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — this skill operates on provided text input only" ;
    oc:directiveContent "Cannot access git repositories directly. Requires commit messages or change descriptions as input. Cannot verify semantic versioning automatically." ;
    oc:hasRationale "The skill has no git integration; it processes textual descriptions of changes" ;
    oc:severityLevel "HIGH" .

oc:kn_9ab1a24d a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "This skill is read-only with respect to code repositories. It produces a text/markdown document as output but does not modify any source files." ;
    oc:hasRationale "Clarifies that the skill generates documentation artifacts without side effects on code" .

oc:kn_bed10b48 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring any changelog document" ;
    oc:directiveContent "Organize changes by impact (most important first), group logically by feature area or type, maintain consistent format throughout, and date every version." ;
    oc:hasRationale "Consistent structure and impact-first ordering helps readers quickly find relevant changes" .

oc:kn_d55f36df a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any changelog entry" ;
    oc:directiveContent "Write changelog entries from the user's perspective, not the developer's. Be specific about what changed and include relevant issue/PR numbers." ;
    oc:hasRationale "User-facing changelogs communicate value, not implementation details" .

