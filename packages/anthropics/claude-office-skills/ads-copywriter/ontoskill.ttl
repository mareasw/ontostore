oc:kn_096c48c2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating ad campaigns that need testing" ;
    oc:directiveContent "Generate 3-5 A/B test variants per ad group testing different elements: headlines (emotional vs rational), CTA (soft vs hard), social proof (numbers vs testimonial), urgency (scarcity vs deadline), benefit (primary vs secondary)." ;
    oc:hasRationale "A/B testing with controlled variable isolation enables data-driven optimization of ad performance." ;
    oc:severityLevel "HIGH" .

oc:kn_096d6529 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting any ad copy narrative" ;
    oc:directiveContent "Use AIDA (Attention→Interest→Desire→Action), PAS (Problem→Agitation→Solution), or BAB (Before→After→Bridge) frameworks to structure ad copy." ;
    oc:hasRationale "Proven persuasion frameworks increase conversion rates by guiding the reader through a psychological journey." ;
    oc:severityLevel "MEDIUM" .

oc:kn_161f90dd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when generating multi-platform ad copy" ;
    oc:directiveContent "Do not write ad copy that ignores platform-specific character limits or tries to use one generic copy across all platforms." ;
    oc:hasRationale "Cross-platform generic copy wastes character budget and misses platform-specific engagement patterns (e.g., TikTok needs casual tone, LinkedIn needs professional tone)." ;
    oc:severityLevel "HIGH" .

oc:kn_20664978 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When presenting final ad copy output" ;
    oc:directiveContent "Output should be organized by platform with sections for each format (headlines, descriptions, primary text), each variant numbered, character-counted, and tagged with variant strategy (keyword/benefit/urgency/trust/CTA)." ;
    oc:hasRationale "Structured output makes it easy for marketers to copy-paste into ad platforms and track which variant maps to which strategy." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5f8fd698 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating Meta, TikTok, or LinkedIn ad copy" ;
    oc:directiveContent "Meta/Facebook feed ad: primary text 125 chars visible (500 max), headline 40 chars, description 30 chars. TikTok in-feed ad text: 100 chars max. LinkedIn intro text: 150 chars, headline 70 chars, description 100 chars." ;
    oc:hasRationale "Each platform enforces strict character limits; exceeding visible thresholds hides content behind 'See More' or causes rejection." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a8a09921 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating Google Ads responsive search ads" ;
    oc:directiveContent "Google Ads headlines: max 30 chars, 15 variants (min 3). Descriptions: max 90 chars, 4 variants (min 2). Include keyword in 3+ headlines, brand in 2+, CTA in 2+, numbers/stats in 2+." ;
    oc:hasRationale "Character limits are enforced by the platform; exceeding them causes truncation or rejection." ;
    oc:severityLevel "CRITICAL" .

_:ref_285b52120486a86f a oc:WorkflowStep ;
    dcterms:description "Choose appropriate copy framework (AIDA, PAS, or BAB) based on product type and audience awareness level" ;
    oc:expectedOutcome "Selected framework matched to the selling context" ;
