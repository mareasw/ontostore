oc:kn_3d7abc9b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When any new ticket enters the system" ;
    oc:directiveContent "1. Receive new ticket → 2. AI analysis (intent, sentiment, urgency) → 3. Categorize (type, product, skill needed) → 4. Route & assign (team, agent, priority) → 5. Auto-respond if applicable" ;
    oc:stepOrder 1 .

oc:kn_7a1c8b4b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating auto-responses using macros" ;
    oc:directiveContent "Never send templated auto-responses without personalization. Always include the customer's name and reference their specific issue." ;
    oc:hasRationale "Impersonal responses increase frustration, especially for customers already experiencing issues" ;
    oc:severityLevel "MEDIUM" .

oc:kn_87e4b423 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When managing ticket backlog and SLA compliance" ;
    oc:directiveContent "Use bulk operations for stale tickets: close pending tickets with no response after 7 days, and escalate tickets approaching SLA breach every 15 minutes." ;
    oc:hasRationale "Automated stale ticket cleanup reduces manual overhead while SLA monitoring prevents breaches" .

oc:kn_a0a10f2a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing or updating any ticket" ;
    oc:directiveContent "Tag consistently across all tickets — tags drive routing, reporting, and integration triggers (e.g., bug_confirmed syncs to JIRA)." ;
    oc:hasRationale "Consistent tagging enables accurate analytics, automated workflows, and cross-system synchronization" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c2da30f5 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When intent detection identifies cancellation risk" ;
    oc:directiveContent "Cancellation intent (confidence 0.85+) must always route to retention team with high priority — never auto-close these tickets." ;
    oc:hasRationale "Cancellation requests represent revenue loss that can be mitigated with proper retention outreach" ;
    oc:severityLevel "HIGH" .

oc:kn_d9e777a9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing or routing any ticket" ;
    oc:directiveContent "Enterprise urgent tickets must receive first reply within 15 minutes and resolution within 4 hours. SLA targets vary by customer tier and priority level." ;
    oc:hasRationale "SLA breaches damage customer relationships and can have contractual penalties for enterprise accounts" ;
    oc:severityLevel "CRITICAL" .

oc:kn_fb21ba18 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling all incoming tickets" ;
    oc:directiveContent "Quick first response is critical even if resolution takes longer. Acknowledge tickets promptly to set expectations." ;
    oc:hasRationale "Customer satisfaction correlates more strongly with response speed than resolution speed" ;
    oc:severityLevel "HIGH" .

