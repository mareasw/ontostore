oc:skill_claude_office_skills_expense_tracker a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "expense-tracker" ;
    skos:broader "Expense management automation system" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/claude-office-skills/expense-tracker" ;
    oc:contentHash "274d1692684f836a799fb149411fcd15c6975b8c3b9b67c3273b791aad0b28a4" ;
    oc:dependsOnSkill oc:skill_ontoskills_invoice_automation ;
    oc:differentia "that processes receipts through OCR, enforces policy compliance, routes approvals by amount thresholds, and generates reimbursement reports" ;
    oc:handlesFailure oc:ApprovalRequired,
        oc:PolicyViolation,
        oc:ReceiptUnreadable ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Automate expense tracking, receipt processing, approval workflows, and reimbursement management" ;
    oc:hasName "expense-tracker" ;
    oc:hasRequirement oc:req_28f5ebbe,
        oc:req_5ad7379a,
        oc:req_a5b02990,
        oc:req_db5f4c9e,
        oc:req_ea1f4fa1 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: Expense Tracker
description: Automate expense tracking, receipt processing, approval workflows, and reimbursement management
version: 1.0.0
author: Claude Office Skills
category: finance
tags:
  - expense
  - receipts
  - reimbursement
  - approval
  - accounting
department: finance
models:
  - claude-3-opus
  - claude-3-sonnet
  - gpt-4
mcp:
  server: accounting-mcp
  tools:
    - expensify_submit
    - concur_api
    - quickbooks_expense
    - ocr_receipt
capabilities:
  - Receipt OCR and extraction
  - Expense categorization
  - Approval workflow automation
  - Policy compliance checking
input:
  - Receipt images
  - Expense details
  - Category assignments
  - Approval requirements
output:
  - Expense reports
  - Reimbursement requests
  - Compliance reports
  - Spending analytics
languages:
  - en
  - zh
related_skills:
  - invoice-automation
  - financial-modeling
  - saas-metrics
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Comprehensive expense management skill for tracking, processing, and automating expense workflows." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Template ;
                                    oc:blockType "template" ;
                                    oc:contentOrder 1 ;
                                    oc:templateContent """# Expense Report - {Month} {Year}

**Employee:** {name}
**Department:** {department}
**Submission Date:** {date}
**Report Period:** {start_date} to {end_date}

## Summary

| Category | Amount | Budget | Variance |
|----------|--------|--------|----------|
| Travel | $1,250 | $2,000 | -$750 |
| Meals | $380 | $400 | -$20 |
| Software | $150 | $200 | -$50 |
| Equipment | $0 | $500 | -$500 |
| **Total** | **$1,780** | **$3,100** | **-$1,320** |

## Itemized Expenses

### Travel
| Date | Description | Amount | Receipt |
|------|-------------|--------|---------|
| 01/05 | Flight to NYC | $450 | ✓ |
| 01/05 | Hotel (2 nights) | $600 | ✓ |
| 01/06 | Uber to client | $45 | ✓ |
| 01/07 | Train return | $155 | ✓ |

### Meals
| Date | Description | Attendees | Amount | Receipt |
|------|-------------|-----------|--------|---------|
| 01/06 | Client dinner | 4 | $280 | ✓ |
| 01/10 | Team lunch | 6 | $100 | ✓ |

## Approval Status
- [ ] Direct Manager: Pending
- [ ] Finance Review: Pending
""" ;
                                    oc:templateVariables "Month",
                                        "Year",
                                        "date",
                                        "department",
                                        "end_date",
                                        "name",
                                        "start_date" ] ;
                            oc:sectionLevel 3 ;
