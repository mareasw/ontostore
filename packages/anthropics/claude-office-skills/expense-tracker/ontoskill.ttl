oc:kn_1b46173d a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating monthly expense reports" ;
    oc:directiveContent """# Expense Report - {Month} {Year}
**Employee:** {name} | **Department:** {department}
**Submission Date:** {date} | **Report Period:** {start_date} to {end_date}

## Summary
| Category | Amount | Budget | Variance |
## Itemized Expenses (by category with date, description, amount, receipt status)
## Approval Status (checkboxes for each required approver)""" ;
    oc:templateVariables "Month",
        "Year",
        "date",
        "department",
        "end_date",
        "name",
        "start_date" .

oc:kn_1f22b07c a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Always when processing receipts through the expense pipeline" ;
    oc:directiveContent "Processing follows: Receipt Image → OCR Extract → Auto-Categorize → Policy Check → Submit Report. Each step must complete before the next begins." ;
    oc:hasRationale "Sequential pipeline ensures no step is skipped and data flows correctly" .

oc:kn_20643356 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When a policy compliance check fails" ;
    oc:directiveContent "Soft violations (minor policy deviations) allow justification and manual override. Hard violations require rejection, manager notification, and correction. Repeated violations escalate to HR with mandatory training." ;
    oc:hasRationale "Distinguishes between intentional and accidental violations for proportional response" ;
    oc:severityLevel "HIGH" .

oc:kn_42783cf3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing expense submissions" ;
    oc:directiveContent "Do not submit expenses more than 7 days after the transaction date. Delayed submissions reduce policy compliance and auditability." ;
    oc:hasRationale "Timely submission ensures accurate financial records and policy adherence" ;
    oc:severityLevel "MEDIUM" .

oc:kn_48d762de a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting data from receipt images or PDFs" ;
    oc:directiveContent "Receipt OCR must extract vendor_name, total_amount, transaction_date, and payment_method as required fields. Dates use YYYY-MM-DD format, amounts have 2 decimal precision, and currency codes follow ISO 4217." ;
    oc:hasRationale "Consistent extraction schema enables automated categorization and policy checking" .

oc:kn_552ffa41 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When categorizing expenses and checking budget limits" ;
    oc:directiveContent "Standard expense categories are: Travel ($500/day), Meals ($100/person), Software ($200/month), Equipment ($1000/item), Office ($50/month), Training ($2000/year). Default to these limits when no custom policy exists." ;
    oc:hasRationale "Provides consistent baseline for budget tracking and policy enforcement" .

oc:kn_6ed8a4e5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When submitting expense reports for approval" ;
    oc:directiveContent "Approval routing is tiered by amount: $0-100 auto-approves, $100-500 requires direct manager, $500-2000 requires manager + department head, $2000+ requires manager + department head + finance director." ;
    oc:hasRationale "Prevents unauthorized spending while reducing approval friction for small expenses" ;
    oc:severityLevel "CRITICAL" .

oc:kn_8e52d417 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before processing any receipt" ;
    oc:directiveContent "Requires an OCR tool or API capable of extracting text from receipt images (photos, PDFs). Supported currencies: USD, EUR, GBP, CNY." .

oc:kn_a0076eec a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring extracted receipt data for processing" ;
    oc:codeLanguage "json" ;
    oc:directiveContent "{\"vendor\": \"...\", \"date\": \"YYYY-MM-DD\", \"total\": 0.00, \"currency\": \"USD\", \"category\": \"...\", \"line_items\": [{\"description\": \"...\", \"amount\": 0.00}], \"payment_method\": \"...\", \"receipt_id\": \"RCP-YYYY-MMDD-NNN\"}" .

oc:kn_c045d5b7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing any expense submission" ;
    oc:directiveContent "Receipts are required for all expenses over $25. Expenses without receipts must be flagged and require justification." ;
    oc:hasRationale "Ensures auditability and compliance with financial regulations" ;
    oc:severityLevel "HIGH" .

oc:kn_d88c884e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Upload receipt image/PDF 2. Run OCR to extract vendor, amount, date, items 3. Auto-categorize into standard categories 4. Run policy compliance check against limits and approval matrix 5. Route to required approvers 6. Submit expense report" ;
    oc:stepOrder 1 .

