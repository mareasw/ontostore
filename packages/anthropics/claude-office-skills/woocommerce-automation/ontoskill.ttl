oc:kn_2b697fbf a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On inventory sync failure" ;
    oc:directiveContent "If inventory sync fails, fall back to manual stock verification and set affected products to 'on backorder' status to prevent overselling while sync is restored." ;
    oc:hasRationale "Conservative fallback prevents the worst-case scenario of selling unavailable products." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2e9b131c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up abandoned cart recovery" ;
    oc:directiveContent "Do not send all cart recovery emails at once or without timing delays. Use a graduated sequence: 1 hour → 24 hours → 72 hours with escalating incentives." ;
    oc:hasRationale "Immediate aggressive discounting devalues products; graduated sequences recover more revenue while protecting margins." ;
    oc:severityLevel "MEDIUM" .

oc:kn_31c1f2d7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring order processing pipelines" ;
    oc:directiveContent "Automate order status transitions end-to-end: placed → validated → processing → shipped → delivered, with customer notifications at each stage." ;
    oc:hasRationale "Full pipeline automation reduces manual errors, speeds fulfillment, and keeps customers informed proactively." ;
    oc:severityLevel "HIGH" .

oc:kn_3f26a0f9 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running any WooCommerce automation" ;
    oc:directiveContent "Verify WooCommerce REST API credentials are valid, MCP server connection is active, and store URL is accessible before executing any automation." ;
    oc:hasRationale "Prevents silent failures and data corruption from invalid API calls." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4050cbee a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing customer marketing campaigns" ;
    oc:directiveContent "Segment customers by lifecycle stage (VIP, at-risk, first-time buyer) and tailor marketing actions to each segment rather than using one-size-fits-all messaging." ;
    oc:hasRationale "Segmented campaigns have significantly higher conversion rates than blanket messaging." ;
    oc:severityLevel "HIGH" .

oc:kn_d879a5db a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When performing bulk operations on products" ;
    oc:directiveContent "Bulk product updates (price changes, sale promotions, shipping class changes) modify live store data immediately and affect customer-facing pricing." ;
    oc:hasRationale "Unintended bulk changes can cause revenue loss or customer confusion if not carefully scoped with filters." ;
    oc:severityLevel "HIGH" .

oc:kn_e09011a9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing inventory for WooCommerce stores" ;
    oc:directiveContent "Inventory must be synced in real-time (every 15 min minimum) to prevent overselling across all channels." ;
    oc:hasRationale "Overselling leads to canceled orders, refunds, and customer dissatisfaction that damages store reputation." ;
    oc:severityLevel "CRITICAL" .

