                    oc:rawYaml """# ═══════════════════════════════════════════════════════════════════════════════
# CLAUDE OFFICE SKILL - Crypto Report
# ═══════════════════════════════════════════════════════════════════════════════

name: crypto-report
description: "Analyze cryptocurrency projects with tokenomics, on-chain metrics, and market analysis. Generate comprehensive crypto research reports."
version: "1.0.0"
author: claude-office-skills
license: MIT

category: finance
tags:
  - crypto
  - blockchain
  - tokenomics
  - defi
  - research
department: Finance/Crypto

models:
  recommended:
    - claude-sonnet-4
    - claude-opus-4
  compatible:
    - claude-3-5-sonnet
    - gpt-4
    - gpt-4o

mcp:
  server: office-mcp
  tools:
    - create_docx
    - create_xlsx
    - create_chart

capabilities:
  - tokenomics_analysis
  - on_chain_metrics
  - protocol_research
  - market_analysis
  - risk_assessment

languages:
  - en
  - zh

related_skills:
  - stock-analysis
  - company-research
  - investment-memo
""" ] ;
