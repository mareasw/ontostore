                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """dashboard:
  name: "Project Dashboard"
  
  widgets:
    - summary_bar:
        metrics:
          - Total Projects: COUNT(Projects)
          - Active: COUNT(Status='Active')
          - At Risk: COUNT(Days Remaining < 7)
          
    - progress_chart:
        type: bar
        data: Projects grouped by Status
        
    - upcoming_deadlines:
        type: list
        query: Projects where Due Date in next 14 days
        sort: Due Date ascending
        limit: 10
        
    - team_utilization:
        type: horizontal_bar
        data: Team members by task count
""" ;
                                    oc:codeLanguage "yaml" ;
