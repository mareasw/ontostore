oc:kn_00bac5d9 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning automation architecture" ;
    oc:directiveContent "Use built-in Airtable automations for simple triggers (record created/updated/matches conditions) and n8n/Zapier for multi-step cross-platform workflows." ;
    oc:hasRationale "Built-in automations are faster to configure and more reliable for single-table operations; external platforms handle complex multi-service orchestration." .

oc:kn_17d01d6f a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When outputting an Airtable base design" ;
    oc:directiveContent """# {Base Name}

## Tables
### {Table Name}
| Field | Type | Purpose |
|-------|------|---------|
| {field} | {type} | {purpose} |

## Automations
**{N}. {Name}**
Trigger: {trigger}
Action: {action}

## Views
- {emoji} {View Name} ({description})""" ;
    oc:templateVariables "Base Name",
        "N",
        "Name",
        "Table Name",
        "View Name",
        "action",
        "description",
        "emoji",
        "field",
        "purpose",
        "trigger",
        "type" .

oc:kn_3956bc56 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any Airtable base schema" ;
    oc:directiveContent "Design Airtable bases with normalized table structures using link_to_records for relationships, rollups for aggregation, and formula fields for computed values." ;
    oc:hasRationale "Proper relational structure enables powerful cross-table queries, automations, and reporting without data duplication." .

oc:kn_6b83eb7c a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Airtable formula fields" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent "Key Airtable formula patterns: DATETIME_DIFF for date math, IF/AND for conditional logic, SWITCH for multi-way branching, REPT for visual progress bars, WORKDAY_DIFF for business days." ;
    oc:hasRationale "Airtable formulas use a specific syntax distinct from Excel; using the correct functions ensures formulas evaluate properly." .

oc:kn_8265eec4 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When configuring views for any Airtable table" ;
    oc:directiveContent "Always create multiple view types (Grid, Kanban, Calendar, Gallery) per table, each filtered and sorted for a specific use case." ;
    oc:hasRationale "Different stakeholders need different perspectives on the same data; views provide this without duplicating data." .

oc:kn_d2b0b604 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding fields to any table" ;
    oc:directiveContent "Avoid storing computed data in editable fields when a formula or rollup can derive it automatically from linked records." ;
    oc:hasRationale "Manual computed fields become stale and error-prone; formulas and rollups stay synchronized with source data automatically." .

oc:kn_dd63481c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring built-in automations" ;
    oc:directiveContent "Airtable automations support specific trigger types: record_created, record_updated, record_matches_conditions, and scheduled. Complex conditional logic may require formula fields as intermediaries." ;
    oc:hasRationale "Automation triggers have limited conditional expressiveness; using formula fields as trigger intermediaries extends capability." .

oc:kn_e8243f65 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building a complete Airtable base from scratch" ;
    oc:directiveContent "1. Define tables with primary fields and field types 2. Add link_to_records between related tables 3. Create rollup and formula fields for computed values 4. Configure views (Grid, Kanban, Calendar, Gallery) 5. Set up built-in automations for notifications and status changes 6. Add n8n/Zapier integrations for cross-platform workflows 7. Build reporting dashboards" ;
    oc:stepOrder 1 .

