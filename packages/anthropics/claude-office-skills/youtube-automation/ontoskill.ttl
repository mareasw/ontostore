                    oc:rawYaml """name: YouTube Automation
description: Automate YouTube content workflows including video management, analytics, scheduling, and channel optimization
version: 1.0.0
author: Claude Office Skills
category: video
tags:
  - youtube
  - video
  - content
  - analytics
  - automation
department: marketing
models:
  - claude-3-opus
  - claude-3-sonnet
  - gpt-4
mcp:
  server: youtube-mcp
  tools:
    - youtube_upload
    - youtube_update
    - youtube_analytics
    - youtube_comments
capabilities:
  - Video upload and scheduling
  - Metadata optimization
  - Analytics tracking
  - Comment management
input:
  - Video files
  - Metadata (title, description, tags)
  - Thumbnail images
  - Schedule preferences
output:
  - Published videos
  - Analytics reports
  - SEO recommendations
  - Engagement insights
languages:
  - en
  - zh
related_skills:
  - tiktok-marketing
  - social-publisher
  - video-editor
""" ] ;
