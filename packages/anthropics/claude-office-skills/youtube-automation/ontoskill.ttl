oc:kn_38856e35 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When executing the video publish workflow" ;
    oc:directiveContent "Publishing a video triggers cross-platform actions: creating short clips, posting to Twitter/LinkedIn, notifying Discord, and updating the website." ;
    oc:hasRationale "Cross-platform promotion amplifies reach but requires all connected integrations to be properly configured." .

oc:kn_5498ad8e a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing YouTube video titles" ;
    oc:directiveContent "Front-load primary keywords in video titles, keep titles under 60 characters, and include power words with brackets/parentheses for higher CTR." ;
    oc:hasRationale "Keyword front-loading and concise titles improve search ranking and click-through rate significantly." ;
    oc:severityLevel "HIGH" .

oc:kn_68a5aebb a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When processing YouTube comments" ;
    oc:directiveContent "Spam comments from new accounts containing URLs, repeated content, or promotional language must be held for review or auto-removed." ;
    oc:hasRationale "Unchecked spam damages community trust and can result in YouTube demonetizing the channel." .

oc:kn_74725b6c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting tags for YouTube videos" ;
    oc:directiveContent "Avoid irrelevant tags, competitor channel names, misleading tags, and excessive tags (>15) in video metadata." ;
    oc:hasRationale "Irrelevant or misleading tags hurt video discoverability and may result in YouTube policy violations." ;
    oc:severityLevel "HIGH" .

oc:kn_951d88cf a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When managing YouTube community engagement" ;
    oc:directiveContent "Reply to comments within 24 hours, heart valuable comments, pin best comments, and post 2-3 community posts per week." ;
    oc:hasRationale "Timely engagement signals to YouTube's algorithm that the channel is active, boosting recommendation potential." .

oc:kn_95c70099 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or uploading YouTube thumbnails" ;
    oc:directiveContent "Thumbnail images must be 1280x720 (16:9 aspect ratio), in PNG or JPG format, and under 2MB." ;
    oc:hasRationale "YouTube enforces specific thumbnail specs; non-compliant images will be rejected or display poorly." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9c89421a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing YouTube thumbnails" ;
    oc:directiveContent "Use high contrast colors, include readable text (3-5 words), show faces with expressions, and maintain brand-consistent styling in thumbnails." ;
    oc:hasRationale "Thumbnails with faces, high contrast, and minimal text significantly outperform generic thumbnails in CTR." .

oc:kn_dd3c708c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing YouTube video descriptions" ;
    oc:directiveContent "Structure descriptions with a hook in the first 150 characters (visible in search), followed by timestamps, links/CTAs, and 3-5 hashtags." ;
    oc:hasRationale "The first 150 characters are visible in search results and determine whether users click through." .

oc:kn_fc8e603f a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When reviewing YouTube analytics" ;
    oc:directiveContent "Key metrics to monitor after publishing: views, watch time, average view duration, CTR from impressions, and subscriber growth." ;
    oc:hasRationale "These core metrics determine YouTube's recommendation algorithm behavior and revenue potential." .

