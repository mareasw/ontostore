                                    oc:codeContent """video_upload:
  file: "video.mp4"
  
  metadata:
    title: "{{title}} | {{channel_name}}"
    description: |
      {{description}}
      
      ⏰ Timestamps:
      {{timestamps}}
      
      🔗 Links:
      {{links}}
      
      📱 Follow us:
      {{social_links}}
      
      #{{tags_hashtags}}
    
    tags:
      - "{{primary_keyword}}"
      - "{{secondary_keywords}}"
      - "{{channel_tags}}"
    
    category: "{{category_id}}"
    language: "en"
    
  settings:
    privacy: "public"  # public, private, unlisted
    made_for_kids: false
    age_restricted: false
    allow_comments: true
    allow_embedding: true
    notify_subscribers: true
    
  monetization:
    enabled: true
    mid_roll_ads: true
    
  schedule:
    publish_at: "2024-01-20T14:00:00Z"
    premiere: false
""" ;
