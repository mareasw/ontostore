        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Google Sheets formulas for automated reporting" ;
    oc:directiveContent "Use IFERROR wrappers for division-based formulas (conversion rates, cost-per-lead) to prevent #DIV/0! errors from propagating into dashboards" ;
    oc:hasRationale "Dashboards with visible error values undermine stakeholder trust and break downstream calculations" .

oc:kn_c90c8a6f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building reusable automation workflows" ;
    oc:directiveContent "Do not hardcode cell references or sheet names in workflow configurations; use named ranges or configurable parameters instead" ;
    oc:hasRationale "Hardcoded references break when sheet structure changes and make workflows non-portable across teams" .

oc:kn_f97f484f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When setting up task tracking in Google Sheets" ;
    oc:directiveContent "Structure task management sheets with columns: Task, Assignee, Due Date, Priority, Status, and Slack ID to enable automated reminder workflows" ;
    oc:hasRationale "This column schema supports both urgency categorization (overdue/today/tomorrow) and automated Slack DM delivery" .

