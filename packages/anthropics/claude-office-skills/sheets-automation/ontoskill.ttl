oc:kn_169fc858 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When activating any n8n workflow" ;
    oc:directiveContent "Automation workflows write data to Sheets, send Slack messages/DMs, send emails, update CRM records, and trigger external API calls" ;
    oc:hasRationale "These are irreversible side effects; always test workflows with sample data before activation" .

oc:kn_32864e2a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any multi-source data aggregation workflow" ;
    oc:directiveContent "Use a scheduled trigger pattern: fetch data from multiple sources → aggregate into a master sheet → distribute summaries via Slack/email" ;
    oc:hasRationale "This hub-and-spoke pattern centralizes data in Sheets as the single source of truth while keeping distribution automated" .

oc:kn_80505f89 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before enabling any multi-source automation" ;
    oc:directiveContent "Verify that all data source connections (HubSpot, Stripe, Google Analytics, Slack) are authenticated before activating a scheduled workflow" ;
    oc:hasRationale "Broken credentials cause silent failures in scheduled workflows that may go unnoticed until stakeholders report missing data" .

