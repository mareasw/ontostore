oc:kn_0a472548 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating monthly/quarterly expense summaries" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """# Monthly Expense Summary
**Period:** [Month Year]

## Overview (Total vs Last Month vs Budget)
## Expenses by Category (Operating, Professional Services, Marketing)
## Top 10 Expenses
## Notes & Anomalies""" .

oc:kn_0a743bb9 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating an expense report from raw expense data" ;
    oc:directiveContent "1. Collect all expense data (receipts, transactions, descriptions) 2. Determine report purpose (reimbursement, tax prep, budget tracking) 3. Apply expense categories (Travel, Meals, Transportation, etc.) 4. Create summary table with category totals 5. Build detailed line items grouped by category with date, vendor, amount, receipt status 6. Flag missing documentation and generate action items" ;
    oc:stepOrder 1 .

oc:kn_27e10003 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling multi-currency expenses" ;
    oc:directiveContent "Use exchange rates from the date of expense, document the rate source (bank, XE.com), and show both original currency and converted amount for international expenses." ;
    oc:hasRationale "Exchange rate accuracy affects reimbursement amounts and tax reporting; using spot rates on transaction dates is standard practice." ;
    oc:severityLevel "MEDIUM" .

oc:kn_29c2e680 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When validating report completeness" ;
    oc:directiveContent "A complete expense report includes: all expenses categorized, totals computed, receipt status noted per item, and a clear action item checklist for missing documentation." ;
    oc:hasRationale "Completeness prevents back-and-forth with finance teams and accelerates reimbursement." ;
    oc:severityLevel "MEDIUM" .

oc:kn_61ed5aef a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing receipt data" ;
    oc:directiveContent "Keep receipts for all expenses over $25 (US threshold); for meals, always include attendees and business purpose. Cannot scan or read receipt images directly." ;
    oc:hasRationale "Missing receipts and incomplete meal documentation are the most common reasons for expense report rejection." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9586ccdf a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "Always, as a disclaimer" ;
    oc:directiveContent "Tax advice, exchange rates, and company-specific policy requirements should be verified externally. Cannot submit reports directly to expense management systems." ;
    oc:hasRationale "The skill generates reports but does not replace professional tax advice or integrate with expense submission systems." ;
    oc:severityLevel "MEDIUM" .

oc:kn_aa106061 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting any expense report output" ;
    oc:directiveContent "Structure reports with a summary table (category totals) at the top, followed by detailed line items grouped by category, and conclude with action items and notes." ;
    oc:hasRationale "Executive summary first allows quick review; detailed breakdown supports audit trails and approval workflows." ;
    oc:severityLevel "LOW" .

oc:kn_b80fa460 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating travel-specific expense reports" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """# Travel Expense Report
**Traveler:** [Name]
**Trip Dates:** [Start] - [End]
**Destination:** [City, Country]
**Business Purpose:** [Reason]

## Trip Summary
- Duration / Total Expenses / Per Diem Allowance / Variance

## Daily Expenses (Day-by-day breakdown)
## Expense by Category (with % of Total)
## Receipt Checklist""" .

oc:kn_cd28207e a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "When calculating mileage reimbursement" ;
    oc:directiveContent "IRS standard mileage rate for 2024 is $0.67/mile — always verify the current rate before calculating mileage expenses." ;
    oc:hasRationale "Mileage rates change annually; using outdated rates creates reimbursement errors." .

oc:kn_e787dd3d a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating expense report output" ;
    oc:directiveContent """# Expense Report
**Period:** {dates}
**Total:** ${total}

## Summary by Category
| Category | Amount |
|----------|--------|

## Detailed Expenses
[Line items: Date, Description, Vendor, Amount, Receipt status]

## Missing/Notes
[Action items for incomplete documentation]""" ;
    oc:templateVariables "dates",
        "total" .

oc:kn_f6f8c400 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any expense report" ;
    oc:directiveContent "Never include expenses without proper categorization — uncategorized items delay reimbursement and create audit risks." ;
    oc:hasRationale "Proper categorization is essential for compliance, tax deduction eligibility, and approval workflows." ;
    oc:severityLevel "HIGH" .

