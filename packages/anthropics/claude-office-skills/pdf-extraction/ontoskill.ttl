                                    oc:blockType "code_block" ;
                                    oc:codeContent """def extract_columns(page, num_columns=2):
    \"\"\"Extract text from multi-column layout.\"\"\"
    width = page.width
    col_width = width / num_columns
    
    columns = []
    for i in range(num_columns):
        x0 = i * col_width
        x1 = (i + 1) * col_width
        
        cropped = page.crop((x0, 0, x1, page.height))
        columns.append(cropped.extract_text())
    
    return columns
