oc:kn_01272294 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting from multi-column layouts or specific page regions" ;
    oc:directiveContent "Use page.crop() with bounding boxes to isolate regions of interest before extracting text or tables" ;
    oc:hasRationale "Cropping reduces noise and improves accuracy by focusing extraction on relevant areas" .

oc:kn_0624ea33 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering a PDF with no extractable text" ;
    oc:directiveContent "Do not use this skill for scanned/image PDFs — pdfplumber only works with native text PDFs. Run OCR first." ;
    oc:hasRationale "pdfplumber cannot process rasterized text; using it on scanned PDFs silently returns empty results" ;
    oc:severityLevel "HIGH" .

oc:kn_0fb5b57e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running any extraction workflow" ;
    oc:directiveContent "Verify that the PDF contains extractable text by checking page.extract_text() is not empty before attempting full extraction" ;
    oc:hasRationale "Some PDFs are image-only; early detection prevents wasted processing and misleading empty results" .

oc:kn_656a12c9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extraction returns unexpected characters or fails silently" ;
    oc:directiveContent "Some PDF encryption types and embedded fonts may prevent text extraction or produce garbled output" ;
    oc:hasRationale "PDF encryption or custom font encoding can block or corrupt character-level access" ;
    oc:severityLevel "LOW" .

oc:kn_7f4a6d45 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Basic text and table extraction from all pages" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """with pdfplumber.open('document.pdf') as pdf:
    for page in pdf.pages:
        text = page.extract_text(x_tolerance=3, y_tolerance=3)
        tables = page.extract_tables({'vertical_strategy': 'lines', 'horizontal_strategy': 'lines'})""" .

oc:kn_88aa6b96 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When visually debugging table detection" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """im = page.to_image(resolution=150)
im.debug_tablefinder()
im.save('table_debug.png')""" .

oc:kn_8cf21b51 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting tables from PDFs with non-standard formatting" ;
    oc:directiveContent "Table extraction requires tuning tolerance settings (snap_tolerance, join_tolerance, intersection_tolerance) per PDF layout" ;
    oc:hasRationale "Default tolerance values may not match the PDF's internal structure, causing missed or merged cells" .

oc:kn_9cde0bf5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When table extraction results are unexpected or incomplete" ;
    oc:directiveContent "Use to_image() and debug_tablefinder() to visually understand PDF structure before extracting complex tables" ;
    oc:hasRationale "Visual debugging reveals hidden line structures, merged cells, and layout issues that affect table detection accuracy" .

oc:kn_d42d46e9 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When custom table detection settings are needed for complex layouts" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """tables = page.extract_tables({
    'vertical_strategy': 'lines',
    'horizontal_strategy': 'lines',
    'snap_tolerance': 5,
    'join_tolerance': 3,
    'edge_min_length': 3,
    'intersection_tolerance': 3,
})""" .

oc:kn_e17106bd a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When extracting from PDFs with many pages (>50)" ;
    oc:directiveContent "Process large PDFs page by page rather than loading all content into memory at once" ;
    oc:hasRationale "pdfplumber loads full page objects; batch processing avoids memory exhaustion on large documents" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f0a25861 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "pdfplumber must be installed (pip install pdfplumber). Pillow required for visual debugging (pip install Pillow)." .

oc:kn_f7ea673c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard PDF extraction workflow" ;
    oc:directiveContent "1. Open PDF with pdfplumber.open() 2. Check metadata and page count 3. For each target page: crop region if needed, extract text/tables with appropriate settings 4. Clean and structure extracted data 5. Output as DataFrames, CSV, or Excel" ;
    oc:stepOrder 1 .

