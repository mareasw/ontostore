    oc:nature "Tool" ;
    oc:requiresState oc:NetworkAvailable,
        oc:ToolInstalled ;
    oc:resolvesIntent "configure security automations",
        "control smart home devices",
        "create home automation workflows",
        "manage home assistant scenes",
        "monitor device states and sensors",
        "set up energy monitoring" ;
