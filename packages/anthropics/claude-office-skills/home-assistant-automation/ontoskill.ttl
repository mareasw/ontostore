                    oc:expectedOutcome "Current configuration preserved for rollback" ;
                    oc:stepDependsOn _:ref_40fe771d42a90075 ;
                    oc:stepId "backup-config" ] ;
            oc:workflowId "ha-automation-setup" ;
            oc:workflowName "Home Assistant Automation Setup" ] ;
    oc:impartsKnowledge oc:kn_28a37cda,
