oc:kn_28a37cda a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining multi-device scenes" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """scene:
  name: movie_night
  entities:
    light.living_room:
      state: on
      brightness: 20
    cover.blinds:
      state: closed
    media_player.soundbar:
      state: on
      source: "TV\"""" .

oc:kn_2fa9bcf2 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating presence-based away mode automations" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """trigger:
  platform: state
  entity_id: group.family
  to: "not_home"
  for: "00:10:00"
action:
  - service: climate.set_preset_mode
      data:
        preset_mode: away
  - service: light.turn_off
      target:
        entity_id: all
  - service: lock.lock
      target:
        entity_id: lock.front_door""" .

oc:kn_483db349 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any automation skill execution" ;
    oc:directiveContent "Home Assistant instance must be running and accessible via the homeassistant-mcp MCP server with configured entities." .

oc:kn_644843f1 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When setting up or referencing Home Assistant entities" ;
    oc:directiveContent "Use consistent entity naming conventions (e.g., light.living_room, climate.main_thermostat) and organize devices into logical groups." ;
    oc:hasRationale "Consistent naming ensures automations are readable, maintainable, and less prone to errors from typos or ambiguous references." ;
    oc:severityLevel "MEDIUM" .

oc:kn_64c3154e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any automation workflow" ;
    oc:directiveContent "Always add appropriate conditions to automations to prevent unintended triggers, such as checking person presence state before executing actions." ;
    oc:hasRationale "Without conditions, automations can fire at inappropriate times, causing nuisance actions like turning on lights when nobody is home." ;
    oc:severityLevel "HIGH" .

oc:kn_6bdcbd06 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When setting up Home Assistant automations" ;
    oc:directiveContent "1. Use consistent entity naming conventions 2. Organize devices into logical groups 3. Add appropriate conditions to all automations 4. Configure notifications sparingly 5. Test automations thoroughly 6. Maintain regular configuration backups" ;
    oc:stepOrder 1 .

oc:kn_848f2d29 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any Home Assistant automation" ;
    oc:directiveContent "Structure automations with trigger → condition → action pattern. Use delays between sequential actions to allow device state changes to propagate." ;
    oc:hasRationale "The trigger-condition-action pattern is Home Assistant's core automation model. Delays prevent race conditions where a second action fires before the first device has responded." .

oc:kn_9611310d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring notification actions in automations" ;
    oc:directiveContent "Do not over-notify users with automation alerts. Limit notification frequency and only send for significant events." ;
    oc:hasRationale "Notification fatigue causes users to ignore or disable important alerts, undermining the security and utility of the system." ;
    oc:severityLevel "MEDIUM" .

oc:kn_98ad3d2c a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When configuring security-related automations" ;
    oc:directiveContent "Security automations (motion detection, alarm, locks) should include state checks on the alarm panel before triggering alerts and use camera snapshots for verification." ;
    oc:hasRationale "Security automations control physical safety; incorrect configuration can either create false positives or fail to alert on real threats." ;
    oc:severityLevel "CRITICAL" .

oc:kn_daa54f82 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before deploying new automations and on an ongoing schedule" ;
    oc:directiveContent "Test automations thoroughly after creation and maintain regular configuration backups." ;
    oc:hasRationale "Automations control physical devices; untested automations can lock doors unexpectedly, fail to arm security, or waste energy." ;
    oc:severityLevel "HIGH" .

oc:kn_e5b6ddd5 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating time-based automations with presence conditions" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """automation:
  trigger:
    - platform: time
      at: "06:30:00"
  condition:
    - condition: state
      entity_id: person.owner
      state: "home"
  action:
    - service: light.turn_on
      target:
        entity_id: light.bedroom
      data:
        brightness_pct: 30
        transition: 300""" .

