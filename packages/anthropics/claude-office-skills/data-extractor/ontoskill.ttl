oc:kn_318cd96f a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When encountering unusual or proprietary file formats" ;
    oc:directiveContent "Some proprietary formats are not supported; the library may fail gracefully on unsupported formats." ;
    oc:hasRationale "Users should validate results rather than assuming complete extraction for exotic formats." ;
    oc:severityLevel "LOW" .

oc:kn_3b6b766c a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting structured elements from any document format" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from unstructured.partition.auto import partition

elements = partition(
    filename="document.pdf",
    strategy="auto",
    include_metadata=True,
    include_page_breaks=True,
)

for element in elements:
    print(f"Type: {type(element).__name__}")
    print(f"Text: {element.text}")
    print(f"Metadata: {element.metadata}")""" .

oc:kn_4b812b17 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Python 3.x with pip; unstructured library installed with appropriate extras for target formats (e.g., [pdf], [docx], [all-docs])" .

oc:kn_65c512d4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing scanned documents or complex layouts" ;
    oc:directiveContent "OCR quality depends on source image quality; complex layouts may need manual review after extraction." ;
    oc:hasRationale "No OCR or extraction tool is perfect; degraded inputs produce degraded outputs." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7d82557b a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When processing multiple documents" ;
    oc:directiveContent "Batch processing supports ThreadPoolExecutor with configurable max_workers; default of 4 workers for parallel document processing." ;
    oc:hasRationale "Parallel processing significantly reduces throughput time for multi-document workloads." .

oc:kn_95072847 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When extracting data from any document" ;
    oc:directiveContent "1. Install unstructured with needed extras (e.g. pip install 'unstructured[all-docs]') 2. Use partition() or format-specific function with appropriate strategy 3. Filter elements by type (Title, Table, NarrativeText) 4. Access element.text and element.metadata for content 5. Export via elements_to_json, elements_to_dicts, or custom structuring" ;
    oc:stepOrder 1 .

oc:kn_976f9c3f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing partition strategy" ;
    oc:directiveContent "Use 'fast' strategy for speed on simple documents, 'hi_res' for accuracy on complex layouts and scanned PDFs." ;
    oc:hasRationale "Strategy choice directly impacts extraction quality and processing time trade-off." .

oc:kn_ab022be7 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When outputting structured extraction results" ;
    oc:directiveContent """{
  'source': '{file_path}',
  'elements': [
    {
      'type': '{element_type}',
      'text': '{element_text}',
      'metadata': {
        'page': '{page_number}',
        'coordinates': '{coordinates}'
      }
    }
  ]
}""" ;
    oc:templateVariables "coordinates",
        "element_text",
        "element_type",
        "file_path",
        "page_number" .

oc:kn_c5e9f673 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing large documents or batch corpora" ;
    oc:directiveContent "Do not process large files without chunking — they may exhaust memory or hit API rate limits." ;
    oc:hasRationale "Large unchunked files cause memory issues and API throttling." ;
    oc:severityLevel "HIGH" .

oc:kn_c95b9d7f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When exporting extracted elements to JSON or dict format" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from unstructured.staging.base import elements_to_json, elements_to_dicts

elements = partition("document.pdf")
json_str = elements_to_json(elements)
dicts = elements_to_dicts(elements)""" .

oc:kn_d540d678 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When chunking documents for RAG or AI applications" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """from unstructured.partition.auto import partition
from unstructured.chunking.title import chunk_by_title

elements = partition("document.pdf")
chunks = chunk_by_title(elements, max_characters=1000, combine_text_under_n_chars=200)""" .

oc:kn_f97beab0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting partition function" ;
    oc:directiveContent "Use partition_auto for unknown file types; use format-specific partition functions (partition_pdf, partition_docx) when the format is known for better control." ;
    oc:hasRationale "Auto-detection adds overhead; format-specific functions offer more configuration options." .

oc:kn_f9f31e2a a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When installing unstructured with all format support" ;
    oc:directiveContent "pip install \"unstructured[all-docs]\"" .

