oc:kn_40b130ea a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring slide content" ;
    oc:directiveContent "Use <section> for horizontal slides and nested <section> elements within for vertical sub-slides. Use data-markdown attribute with <textarea data-template> for markdown content." ;
    oc:hasRationale "reveal.js uses section nesting to define horizontal (main) and vertical (drill-down) navigation paths" .

oc:kn_577c061d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any reveal.js presentation — this is the minimal boilerplate" ;
    oc:codeLanguage "html" ;
    oc:directiveContent """<!doctype html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4/dist/reveal.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@4/dist/theme/black.css">
</head>
<body>
    <div class="reveal">
        <div class="slides">
            <section>Slide 1</section>
            <section>Slide 2</section>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/reveal.js@4/dist/reveal.js"></script>
    <script>Reveal.initialize();</script>
</body>
</html>""" ;
    oc:hasRationale "Every reveal.js presentation requires the reveal.css theme, a .reveal > .slides container with <section> elements, and Reveal.initialize()" .

oc:kn_597acce6 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When displaying code with syntax highlighting and line focus" ;
    oc:codeLanguage "html" ;
    oc:directiveContent """<section>
    <pre><code data-trim data-line-numbers="1|3-4">
CODE HERE
    </code></pre>
</section>""" ;
    oc:hasRationale "data-trim removes whitespace, data-line-numbers with pipe syntax highlights specific lines for emphasis" .

oc:kn_8b054e75 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding step-by-step animations to slides" ;
    oc:codeLanguage "html" ;
    oc:directiveContent """<section>
    <p class="fragment">Appears first</p>
    <p class="fragment fade-up">Then this</p>
    <p class="fragment highlight-red">Highlight</p>
</section>""" ;
    oc:hasRationale "Fragments enable progressive content reveal; styles include fade-in, fade-out, fade-up/down/left/right, highlight-red/blue/green, strike" .

oc:kn_950ad8c7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a visual theme for the presentation" ;
    oc:directiveContent "Available themes: black, white, league, beige, sky, night, serif, simple, solarized, blood, moon. Apply via CSS link: reveal.js/dist/theme/{theme}.css" ;
    oc:hasRationale "Theme choice sets the visual tone; dark themes (black, night, moon, blood) suit tech/developer content, light themes (white, simple, beige) suit business/product content" .

oc:kn_c6dfd835 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — presentations depend on CDN-hosted CSS and JS" ;
    oc:directiveContent "reveal.js assets are loaded from CDN (cdn.jsdelivr.net/npm/reveal.js@4/). An active internet connection is required for the presentation to render." ;
    oc:hasRationale "Without network access, the presentation will not load its framework assets" ;
    oc:severityLevel "HIGH" .

oc:kn_eada24d4 a oc:CodePattern,
