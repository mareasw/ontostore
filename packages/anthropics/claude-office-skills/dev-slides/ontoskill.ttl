oc:kn_12d3a01d a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before creating or running Slidev presentations" ;
    oc:directiveContent "Node.js must be installed. Slidev can be initialized with `npm init slidev@latest`" .

oc:kn_4215b728 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up a new Slidev project" ;
    oc:directiveContent "npm init slidev@latest" .

oc:kn_86deed95 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing slide layouts" ;
    oc:directiveContent "Use layout: two-cols for side-by-side code and explanation, layout: center for impactful statements, and layout: cover for title slides" ;
    oc:hasRationale "Developer presentations benefit from code-explanation juxtaposition and focused single-concept slides" .

oc:kn_87ca38f7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when writing Slidev markdown" ;
    oc:directiveContent "Slides are separated by `---` on its own line. YAML frontmatter between `---` delimiters configures theme, layout, and behavior per slide." ;
    oc:hasRationale "Incorrect separator syntax will break slide parsing" ;
    oc:severityLevel "HIGH" .

oc:kn_b8a7e7e2 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding code examples to slides" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """```ts {all|1|2-3|4}
const name = 'Slidev'
console.log(name)
```

```ts {monaco}
// Editable code block
```

```ts {monaco-run}
// Runnable code
console.log('Hello!')
```""" ;
    oc:hasRationale "Slidev supports line-by-line highlighting with `{all|1|2-3}`, editable Monaco editors with `{monaco}`, and runnable code with `{monaco-run}`" .

oc:kn_d882ca42 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any Slidev presentation" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
theme: seriph
class: text-center
highlighter: shiki
lineNumbers: true
css: unocss
---

# Slide Title

Content

---
layout: two-cols
---

# Left Column
::right::
# Right Column""" ;
    oc:hasRationale "Slidev uses YAML frontmatter for configuration and `---` separators for slide breaks" .

oc:kn_ee7b8f9a a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating developer presentations" ;
    oc:directiveContent """1. Gather technical presentation topic and audience
2. Choose appropriate theme (seriph, default) and layouts (cover, two-cols, center, image-right)
3. Generate Slidev markdown with frontmatter config, slide separators, code blocks, diagrams, and Vue components
4. Include Monaco editor blocks for interactive/live code sections
5. Add v-click/v-clicks animations for progressive reveal""" ;
    oc:stepOrder 1 .

