                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "This skill enables creation of developer-focused presentations using **Slidev** - a Vue-powered presentation framework. Write slides in Markdown with live code demos, diagrams, and components." ] ;
