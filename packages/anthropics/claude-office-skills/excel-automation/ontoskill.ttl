oc:kn_118130e8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between xlwings and openpyxl" ;
    oc:directiveContent "Use xlwings for live interaction tasks (dashboard updates, VBA execution, UDFs) and openpyxl for file-processing tasks (bulk generation, server deployment)." ;
    oc:hasRationale "Each library has distinct strengths; choosing the wrong one leads to unnecessary complexity or failed deployments." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7c79135d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing VBA macros from Python" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """wb.macro('MacroName')()
result = wb.macro('CalculateTotal')(100, 200)""" .

oc:kn_7df0ffa2 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When reporting results of Excel automation tasks" ;
    oc:directiveContent """## {report_type}
- **Source**: {workbook_path}
- **Sheets Modified**: {sheet_list}
- **Charts Refreshed**: {count}
- **Timestamp**: {datetime}
- **Status**: Success/Error""" ;
    oc:templateVariables "count",
        "datetime",
        "report_type",
        "sheet_list",
        "workbook_path" .

oc:kn_901188b9 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When performing batch updates or large data operations" ;
    oc:directiveContent "Disable screen updating, use manual calculation mode, and read/write entire ranges as arrays rather than cell-by-cell for batch operations." ;
    oc:hasRationale "Cell-by-cell operations are extremely slow in xlwings due to COM interop overhead; array operations and disabled screen updating can improve performance by 10-100x." ;
    oc:severityLevel "HIGH" .

oc:kn_a5544fcd a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When installing xlwings and its Excel add-in" ;
    oc:directiveContent "pip install xlwings && xlwings addin install" .

oc:kn_bab27f68 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating Excel User Defined Functions" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """@xw.func
@xw.arg('data', ndim=2)
def my_array_func(data):
    import numpy as np
    return np.sum(data)""" .

oc:kn_d4144003 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, before executing any xlwings code" ;
    oc:directiveContent "xlwings requires Microsoft Excel to be installed on the machine. macOS support is limited for some features." ;
    oc:hasRationale "xlwings controls Excel through its COM API (Windows) or AppleScript (macOS); without Excel installed, all operations will fail." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e81ea1fa a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When running any xlwings automation" ;
    oc:directiveContent "xlwings controls a live Excel instance — operations will modify open workbooks, trigger recalculation, and may display alerts unless suppressed." ;
    oc:hasRationale "Unlike openpyxl which only modifies files on disk, xlwings operates on the actual running Excel application, meaning users can see changes in real-time but also that errors can affect live work." ;
    oc:severityLevel "HIGH" .

oc:kn_ec4f1c14 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deploying to a server environment or CI/CD pipeline" ;
    oc:directiveContent "Never use xlwings for server-side or headless processing. Use openpyxl instead for file-only operations without Excel installed." ;
    oc:hasRationale "xlwings requires a live Excel instance via COM; it will fail on headless servers where Excel is not installed." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ed3217df a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When fulfilling an Excel automation request" ;
    oc:directiveContent "1. Describe the Excel automation task 2. Specify if live Excel interaction or file processing is needed 3. Generate xlwings code 4. Execute and verify results" ;
    oc:stepOrder 1 .

oc:kn_f4b202ea a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When opening Excel workbooks programmatically" ;
    oc:directiveContent "Always use try/finally blocks to ensure workbooks are closed and the Excel app is quit even on failure. Restore screen_updating, calculation, and display_alerts settings in finally." ;
    oc:hasRationale "Orphaned Excel processes consume memory and lock files; failing to restore settings can leave Excel in a broken state for the user." ;
    oc:severityLevel "HIGH" .

oc:kn_fc6a322f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing batch updates or performance-critical operations" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import xlwings as xw

app = xw.App(visible=False)
try:
    app.screen_updating = False
    app.calculation = 'manual'
    wb = app.books.open(workbook_path)
    sheet = wb.sheets['Data']
    sheet['A1'].value = data
    app.calculation = 'automatic'
    wb.save()
finally:
    wb.close()
    app.quit()""" .

