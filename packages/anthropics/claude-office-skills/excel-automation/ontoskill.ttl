                                    oc:blockType "code_block" ;
                                    oc:codeContent """# Define a UDF (in Python file)
import xlwings as xw

@xw.func
def my_sum(x, y):
    \"\"\"Add two numbers\"\"\"
    return x + y

@xw.func
@xw.arg('data', ndim=2)
def my_array_func(data):
    \"\"\"Process array data\"\"\"
    import numpy as np
    return np.sum(data)

# These become Excel functions: =my_sum(A1, B1)
""" ;
