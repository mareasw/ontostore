oc:kn_007c069c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring extraction from any database source" ;
    oc:directiveContent "Use incremental extraction with a cursor column (e.g., updated_at) rather than full-table scans to minimize source load and pipeline duration." ;
    oc:hasRationale "Full scans on large tables consume excessive resources and increase pipeline runtime; incremental extraction only pulls changed records." ;
    oc:severityLevel "HIGH" .

oc:kn_65cc01aa a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When extracting data from REST API sources" ;
    oc:directiveContent "API sources have rate limits (e.g., Stripe 100/sec) that require pagination strategies (cursor-based) to avoid throttling during extraction." ;
    oc:hasRationale "Exceeding rate limits causes extraction failures and data gaps; proper pagination prevents hitting limits." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a0f804be a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When setting up error handling for any pipeline" ;
    oc:directiveContent "Configure retry with exponential backoff (max 3 attempts, 300s initial delay) and dead-letter queues for failed records." ;
    oc:hasRationale "Transient failures (network timeouts, rate limits) are common in distributed data systems; retries with backoff handle them gracefully." ;
    oc:severityLevel "HIGH" .

oc:kn_d94a6f9a a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any ETL pipeline" ;
    oc:directiveContent "Ensure every pipeline can be safely re-run without duplicating data or producing inconsistent results." ;
    oc:hasRationale "Idempotent pipelines allow safe retry after failures without manual data cleanup, which is essential for production reliability." ;
    oc:severityLevel "CRITICAL" .

oc:kn_daf0e12d a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When monitoring any running pipeline" ;
    oc:directiveContent "Pipeline duration, records processed, error count, and data freshness are the four critical telemetry metrics to track." ;
    oc:hasRationale "These four metrics provide complete observability into pipeline health, throughput, reliability, and timeliness." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f5276cd4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading data into BigQuery, Snowflake, or similar warehouses" ;
    oc:directiveContent "Partition large tables by date and configure time-based partitioning (e.g., DAY) on the load target to optimize query performance." ;
    oc:hasRationale "Date partitioning enables partition pruning on queries, dramatically reducing scan costs and improving query speed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f656db38 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before deploying any pipeline to production" ;
    oc:directiveContent "Never run untested transformation logic directly against production data warehouses. Always validate with sample data first." ;
    oc:hasRationale "Bad transformations can corrupt downstream datasets and break dependent analytics dashboards and reports." ;
    oc:severityLevel "HIGH" .

oc:kn_fb874ab3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining any ETL pipeline" ;
    oc:directiveContent "Every pipeline must include data quality validation rules covering null checks, uniqueness, referential integrity, range bounds, and data freshness." ;
    oc:hasRationale "Without quality gates, corrupted or stale data silently propagates to downstream analytics, leading to wrong business decisions." ;
    oc:severityLevel "CRITICAL" .

