oc:kn_2eda6639 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Auto-detecting extraction method" ;
    oc:directiveContent "When unsure which method to use, try lattice first. If no tables found or accuracy is below 70%, fall back to stream method." ;
    oc:hasRationale "Lattice is more precise when borders exist; stream is a reliable fallback" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3068278e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When tables span multiple pages" ;
    oc:directiveContent "For multi-page tables spanning several pages, group extracted tables by column structure (tuple of column headers) before concatenating with pd.concat and deduplicating header rows." ;
    oc:hasRationale "Multi-page tables produce separate Table objects that must be reassembled by matching column schemas" ;
    oc:severityLevel "MEDIUM" .

oc:kn_37dcbbe7 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On extraction failure" ;
    oc:directiveContent "If default extraction fails, try specifying table_areas with PDF coordinates, adjusting line_scale (lattice) or row_tol/column_tol (stream), or processing page-by-page for large PDFs." ;
    oc:hasRationale "Fine-tuning parameters can recover tables that default settings miss" ;
    oc:severityLevel "LOW" .

oc:kn_3f83e38c a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "ghostscript must be installed (brew install ghostscript on macOS, apt-get install ghostscript on Ubuntu)" .

oc:kn_42f435ac a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before execution" ;
    oc:directiveContent "Verify ghostscript is installed and camelot-py[cv] is available before attempting extraction. For batch operations, ensure output directory exists." ;
    oc:hasRationale "camelot depends on ghostscript for PDF parsing; missing dependency causes cryptic errors" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4f9751b3 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Try lattice method first (default) 2. Check accuracy scores — skip tables below 80% 3. If accuracy is low, try stream method 4. Use visual debugging (camelot.plot) to inspect 5. Specify table_areas or columns if needed for precision" ;
    oc:stepOrder 1 .

oc:kn_78639efe a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """Table {n}:
  Page: {page}
  Accuracy: {accuracy}%
  Shape: {rows} x {cols}
  Parsing Report: {report}""" ;
    oc:templateVariables "accuracy",
        "cols",
        "n",
        "page",
        "report",
        "rows" .

oc:kn_79092005 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Exporting extracted tables" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """tables[0].to_csv('table.csv')
tables[0].to_excel('table.xlsx')
tables[0].to_json('table.json')
tables[0].to_html('table.html')""" .

oc:kn_7dc5a55f a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Installing camelot with OpenCV dependencies" ;
    oc:directiveContent "pip install camelot-py[cv]" .

oc:kn_93258262 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before extraction" ;
    oc:directiveContent "Encrypted PDFs and image-based PDFs are not supported directly. Image-based PDFs require OCR preprocessing first." ;
    oc:hasRationale "camelot relies on text and vector data, not rasterized content" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a4f2b161 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "After extraction" ;
    oc:directiveContent "Do not trust extraction results with accuracy below 80%. Always check table.accuracy and use visual debugging (camelot.plot) to verify results before proceeding." ;
    oc:hasRationale "Low-accuracy extractions produce unreliable data that propagates errors downstream" ;
    oc:severityLevel "HIGH" .

oc:kn_b142bcb4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Basic table extraction from PDF" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import camelot

tables = camelot.read_pdf('document.pdf', flavor='lattice', pages='all')
for i, table in enumerate(tables):
    df = table.df
    print(f"Table {i+1}: Page {table.page}, Accuracy {table.accuracy}%")""" .

oc:kn_b97a5c97 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting extraction method" ;
    oc:directiveContent "Lattice method only works on tables with visible borders/lines; stream method is required for borderless tables. Always try both methods if extraction accuracy is below 70%." ;
    oc:hasRationale "Using the wrong method yields empty or garbled results" ;
    oc:severityLevel "HIGH" .

oc:kn_e5580cca a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Auto-detecting best extraction method" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """def smart_extract_tables(pdf_path, pages='1'):
    lattice = camelot.read_pdf(pdf_path, pages=pages, flavor='lattice')
    stream = camelot.read_pdf(pdf_path, pages=pages, flavor='stream')
    results = []
    if lattice and lattice[0].accuracy > 70:
        results.extend(lattice)
    elif stream:
        results.extend(stream)
    return results""" .

