oc:kn_004ba8f0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When conducting any research task" ;
    oc:directiveContent "Research should follow a structured 5-phase methodology: Scoping → Information Gathering → Analysis → Synthesis → Reporting, each phase producing distinct intermediate outputs." ;
    oc:hasRationale "Structured methodology ensures comprehensive coverage, reduces bias, and produces traceable reasoning from raw information to conclusions." .

oc:kn_008fad20 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting an analytical framework for the research" ;
    oc:directiveContent "Apply PESTEL analysis for market/industry topics and 5W1H framework for general topics. Use argument mapping to structure claims with supporting evidence and counter-arguments." ;
    oc:hasRationale "Structured frameworks ensure multi-dimensional coverage and prevent the researcher from defaulting to a single perspective or confirmation bias." .

oc:kn_8524402a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — fundamental limitation of this skill" ;
    oc:directiveContent "Cannot access real-time internet data, paywalled content, or proprietary databases without external tools provided. Knowledge has a training cutoff date." ;
    oc:hasRationale "Users must understand the boundaries of AI-assisted research to avoid relying on stale or inaccessible information for critical decisions." ;
    oc:severityLevel "HIGH" .

oc:kn_8dcb89cf a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting research, during scoping phase" ;
    oc:directiveContent "The skill assumes the user can provide sufficient context about their research purpose and constraints. Ambiguous or overly broad topics should be clarified before proceeding." ;
    oc:hasRationale "Research quality depends critically on how well the question is defined; vague questions produce vague reports." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e64a7243 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating final research reports" ;
    oc:directiveContent "Never present synthesized AI findings as verified facts without disclaimers. Always note gaps, limitations, and recommend verification with primary sources for critical decisions." ;
    oc:hasRationale "AI-synthesized information may contain inaccuracies or biases; failure to disclose this undermines trust and could lead to bad decisions." ;
    oc:severityLevel "CRITICAL" .

