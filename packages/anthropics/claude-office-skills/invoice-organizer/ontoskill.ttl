                [ a oc:WorkflowStep ;
                    dcterms:description "Produce tax-ready report with annual deductible total, documentation status, and recommended actions" ;
                    oc:expectedOutcome "Complete tax preparation report document" ;
                    oc:stepDependsOn _:ref_50b26e959a3c62f4 ;
                    oc:stepId "generate-tax-report" ] ;
            oc:workflowId "invoice-organizer-tax-prep" ;
            oc:workflowName "Tax Preparation Report" ],
        [ a oc:Workflow ;
            dcterms:description "Full pipeline for processing a new invoice: extract data, categorize, file, track, and report" ;
