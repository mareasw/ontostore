oc:kn_5b41c088 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "Cannot perform actual file operations — this skill provides guidance and structured output for organizing, not direct filesystem manipulation. Cannot integrate directly with accounting software. Exchange rates need external verification. Tax advice must come from professionals." ;
    oc:hasRationale "The skill is advisory and template-based; actual file moves, accounting integration, and tax decisions require external tools and human judgment" ;
    oc:severityLevel "HIGH" .

oc:kn_74fc758e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When categorizing any invoice or receipt" ;
    oc:directiveContent "Auto-categorize expenses by matching vendor names to known patterns: AWS→Software>Cloud, Office Depot→Office>Supplies, airlines→Travel>Transportation, hotels→Travel>Accommodation, Adobe/Microsoft→Software>Subscriptions. Flag uncertain categorizations for manual review." ;
    oc:hasRationale "Vendor-based rules provide high-confidence automatic categorization, reducing manual effort while flagging edge cases" .

oc:kn_78f1c746 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Renaming invoice files for consistent filing" ;
    oc:directiveContent """YYYY-MM-DD_Vendor_Amount_InvoiceNumber.pdf
Examples:
2026-01-15_AcmeCorp_1350.00_INV-2026-0042.pdf
2026-01-20_Adobe_54.99_Monthly.pdf
2026-01-22_DeltaAirlines_425.00_CONF123456.pdf""" .

oc:kn_ab044f9d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When maintaining the tracking register and preparing tax reports" ;
    oc:directiveContent "Track vendor payments exceeding $600 annually for 1099 reporting requirements. Flag missing receipts for expenses over $75. Track payment lifecycle: Received → Reviewed → Scheduled → Paid → Filed." ;
    oc:hasRationale "IRS requires 1099s for vendors paid over $600; receipts required for expenses over $75. Lifecycle tracking prevents lost invoices and late payments" .

oc:kn_bcba43d9 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Extracting and presenting data from any invoice" ;
    oc:directiveContent """## Invoice Data Extraction
### Extracted Information
| Field | Value | Confidence |
| **Vendor** | {vendor} | {conf} |
| **Invoice #** | {invoice_num} | {conf} |
| **Invoice Date** | {date} | {conf} |
| **Due Date** | {due_date} | {conf} |
| **Subtotal** | {subtotal} | {conf} |
| **Tax** | {tax} | {conf} |
| **Total** | {total} | {conf} |
### Line Items
| Description | Qty | Unit Price | Total |
### Vendor Details / Payment Information""" ;
    oc:templateVariables "conf",
        "date",
        "due_date",
        "invoice_num",
        "subtotal",
        "tax",
        "total",
        "vendor" .

oc:kn_ec297fc9 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Processing any new invoice or receipt" ;
    oc:directiveContent "1. Extract key data from invoice PDF (vendor, invoice #, dates, amounts, line items, vendor details, payment terms). 2. Auto-categorize expense using vendor-matching rules. 3. Rename and file using convention YYYY-MM-DD_Vendor_Amount_InvoiceNumber.pdf into year/category folder. 4. Add to tracking register with status (Pending/Paid/Overdue). 5. Generate summary reports by category, vendor, and time period." ;
    oc:stepOrder 1 .

oc:kn_ef25c104 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When setting up or maintaining the invoice filing system" ;
    oc:directiveContent "Use the standard folder structure: Invoices/{Year}/{Category}/ with categories: Office, Software, Travel, Professional, Marketing, Utilities, Other. Include an Archive/ folder for prior years. Maintain a master tracking register with columns: Invoice #, Vendor, Date, Due, Amount, Status, Days outstanding." ;
    oc:hasRationale "Consistent structure enables quick retrieval, accurate reporting, and audit readiness" .

oc:kn_f9dc4067 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before extracting data from any invoice" ;
    oc:directiveContent "Before processing, verify the invoice file is a readable PDF or image, confirm the source document is complete (not truncated), and check OCR quality for scanned documents." .

oc:kn_fa4626fa a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing invoices with low OCR confidence or unfamiliar vendors" ;
    oc:directiveContent "Do not assume auto-categorization is always correct. Categories may need manual adjustment, especially for unfamiliar vendors, ambiguous expenses, or multi-category invoices. Always verify OCR-extracted data against the source document." ;
    oc:hasRationale "Blind reliance on auto-categorization and OCR leads to misfiled expenses and inaccurate reporting" ;
    oc:severityLevel "MEDIUM" .

