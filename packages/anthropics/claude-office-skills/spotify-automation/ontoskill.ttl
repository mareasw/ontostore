oc:kn_0238b1e1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before executing any playback control operation" ;
    oc:directiveContent "Do not attempt playback commands without verifying the user has an active Spotify Premium account and valid OAuth scope." ;
    oc:hasRationale "Playback APIs require Premium; free-tier users will get 403 errors." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1acb9413 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building repetitive or scheduled workflows" ;
    oc:directiveContent "Cache frequently accessed data such as audio features, top tracks, and user profile info to reduce API calls." ;
    oc:hasRationale "Spotify API has rate limits; caching avoids unnecessary calls and improves performance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_329c3791 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When adding tracks to playlists or playing tracks" ;
    oc:directiveContent "When a track is unavailable (removed or region-locked), skip it and proceed with the next track rather than failing the entire operation." ;
    oc:hasRationale "Track availability changes frequently; graceful degradation maintains workflow continuity." ;
    oc:severityLevel "MEDIUM" .

oc:kn_55d650a1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating smart playlists or music discovery workflows" ;
    oc:directiveContent "Use seed tracks, artists, and genres in combination with target audio features (energy, danceability, valence) to generate contextually relevant recommendations." ;
    oc:hasRationale "Spotify's recommendation engine works best with 1-5 seed inputs combined with tunable audio feature targets." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7c2931a9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making any Spotify API calls" ;
    oc:directiveContent "Respect Spotify API rate limits at all times; implement exponential backoff on 429 responses." ;
    oc:hasRationale "Exceeding rate limits causes temporary bans and degraded user experience." ;
    oc:severityLevel "HIGH" .

oc:kn_ecd0c8c0 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When authenticating with Spotify API" ;
    oc:directiveContent "Request only the minimum OAuth scopes needed for the operation (e.g., playlist-modify-private vs playlist-modify-public)." ;
    oc:hasRationale "Over-scoping violates least-privilege principle and may concern users about data access." ;
    oc:severityLevel "HIGH" .

