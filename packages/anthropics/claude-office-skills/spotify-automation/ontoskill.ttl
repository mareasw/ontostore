oc:skill_claude_office_skills_spotify_automation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "spotify-automation" ;
    skos:broader "Automation skill" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/claude-office-skills/spotify-automation" ;
    oc:contentHash "83f37ea0a74dd8344af4ffa6c1351e38ff86296412e2eb14481740f0bde22741" ;
    oc:differentia "integrates with Spotify API for music playback control, playlist management, music discovery, and audio feature analysis" ;
    oc:handlesFailure oc:NetworkTimeout,
        oc:PermissionDenied,
        oc:RateLimitExceeded ;
    oc:hasArgumentHint "playback command, playlist config, or search query" ;
    oc:hasCategory "media" ;
    oc:hasDescription "Automate Spotify music playback, playlist management, and audio analysis workflows" ;
    oc:hasName "spotify-automation" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Automate Spotify music playback, playlist management, and discovery workflows." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """// Search and Play
const results = await spotify.search("Bohemian Rhapsody", ["track"]);
await spotify.play({ uris: [results.tracks.items[0].uri] });

// Create Smart Playlist
const recs = await spotify.getRecommendations({
  seed_genres: ["chill"],
  target_energy: 0.4,
  limit: 30
});
const playlist = await spotify.createPlaylist("Chill Vibes", {
  description: "AI-curated relaxation",
  public: false
});
await spotify.addTracksToPlaylist(playlist.id, recs.tracks.map(t => t.uri));
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 159-175" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "API Examples" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """workflow:
  trigger: daily at 6:00 AM
  steps:
    - get_recently_played: 50
    - analyze_mood: based_on_audio_features
    - get_recommendations: 
        based_on: recent_tracks
        mood: current_time_appropriate
    - create_playlist: "Today's Mix - {{date}}"
    - add_tracks: recommended
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 128-139" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Daily Mix Generator" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """party_playlist:
  trigger: "party mode"
  actions:
    - get_top_tracks:
        time_range: medium_term
        limit: 20
    - get_recommendations:
        seed: top_tracks
        energy: "> 0.8"
        danceability: "> 0.7"
    - shuffle_and_play
    - set_crossfade: 5  # seconds
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 142-155" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Party Mode" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Workflow Examples" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_5f1f774a296ea783 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Best Practices" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """audio_features:
  - acousticness: 0.0-1.0
  - danceability: 0.0-1.0
  - energy: 0.0-1.0
  - instrumentalness: 0.0-1.0
  - liveness: 0.0-1.0
  - loudness: -60 to 0 dB
  - speechiness: 0.0-1.0
  - tempo: BPM
  - valence: 0.0-1.0 (mood)
  - key: 0-11 (C to B)
  - mode: 0 (minor) or 1 (major)
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 110-123" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Audio Analysis" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """playlist_operations:
  create:
    name: "{{playlist_name}}"
    description: "{{description}}"
    public: false
    collaborative: false
    
  add_tracks:
    playlist_id: "xxx"
    tracks:
      - "spotify:track:xxx"
      - "spotify:track:yyy"
    position: 0  # optional
    
  smart_playlist:
    name: "Workout Mix"
    criteria:
      energy: "> 0.8"
      tempo: "> 120"
      genres: ["electronic", "pop"]
    limit: 50
    refresh: weekly
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 69-92" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Playlist Management" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """recommendations:
  seed_tracks: ["track_id_1", "track_id_2"]
  seed_artists: ["artist_id"]
  seed_genres: ["pop", "rock"]
  
  target_features:
    energy: 0.8
    danceability: 0.7
    valence: 0.6  # positiveness
    
  limit: 20
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 95-107" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Music Discovery" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """playback_commands:
  - play_track: "spotify:track:xxx"
  - pause
  - next_track
  - previous_track
  - set_volume: 75
  - set_shuffle: true
  - set_repeat: "context"  # track, context, off
  - seek_position: 30000  # milliseconds
  - transfer_playback:
      device_id: "device_xxx"
""" ;
                                    oc:codeLanguage "yaml" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 54-66" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Playback Control" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Capabilities" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Spotify Automation" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: Spotify Automation
description: Automate Spotify music playback, playlist management, and audio analysis workflows
version: 1.0.0
author: Claude Office Skills
category: media
tags:
  - spotify
  - music
  - playlist
  - audio
  - entertainment
department: content
models:
  - claude-3-opus
  - claude-3-sonnet
  - gpt-4
mcp:
  server: media-mcp
  tools:
    - spotify_playback
    - spotify_playlist
    - spotify_search
    - spotify_analysis
capabilities:
  - Playback control
  - Playlist management
  - Music discovery
  - Audio analysis
input:
  - Search queries
  - Playlist configurations
  - Playback commands
  - Analysis parameters
output:
  - Playback status
  - Playlist updates
  - Track recommendations
  - Audio features
languages:
  - en
related_skills:
  - youtube-automation
  - podcast-automation
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
