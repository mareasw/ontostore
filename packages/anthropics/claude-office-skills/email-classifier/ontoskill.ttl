oc:kn_086adac7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When classifying any email" ;
    oc:directiveContent "Classify emails into 6 primary categories: Action Required, FYI, Waiting, Delegated, Archive, or Delete. Assign one of 10 email types (Meeting, Task/Request, Question, Update/Report, Approval, Newsletter, Marketing, Alert/Notification, Personal, Spam/Phishing) and one of 4 priority levels (Urgent, High, Normal, Low)." ;
    oc:hasRationale "A consistent taxonomy ensures reliable triage across all email processing sessions" ;
    oc:severityLevel "HIGH" .

oc:kn_30c6a4e9 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When the user provides organization-specific classification rules" ;
    oc:directiveContent "Support custom rules including VIP senders (always high priority), auto-archive patterns (newsletters, CC-only), auto-delegate mappings (IT requests → it-team@), and red-flag keywords (URGENT, legal, compliance, customer complaints)." ;
    oc:hasRationale "Custom rules adapt the generic framework to the user's specific organizational hierarchy and workflow" .

oc:kn_56c49743 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing a batch of classified emails" ;
    oc:directiveContent "Process emails in priority order: Urgent first, then High, then quick wins under 2 minutes, batch Normal for a scheduled block, and defer Low/FYI to end of day." ;
    oc:hasRationale "Tackling urgent items first prevents missed deadlines while batching low-priority items avoids context switching" .

oc:kn_8c327155 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating emails for spam/phishing" ;
    oc:directiveContent "Do not mark emails as safe solely because they lack obvious red flags. Always check sender domain vs display name, urgency pressure tactics, credential requests, suspicious links, unexpected attachments, and generic greetings." ;
    oc:hasRationale "Sophisticated phishing emails may pass surface-level checks; a structured checklist prevents false negatives" ;
    oc:severityLevel "HIGH" .

oc:kn_9450ea42 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — these are inherent skill limitations" ;
    oc:directiveContent "Cannot access email accounts directly; classification is based solely on content provided by the user. May miss context from email threads and cannot guarantee phishing detection." ;
    oc:hasRationale "The agent operates on user-provided text only, so it lacks thread history and authentication context needed for definitive phishing verdicts" ;
    oc:severityLevel "CRITICAL" .

