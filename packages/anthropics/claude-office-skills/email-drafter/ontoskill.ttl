  recommended:
    - claude-sonnet-4
    - claude-opus-4
  compatible:
    - claude-3-5-sonnet
    - gpt-4
    - gpt-4o

# MCP Tools Integration
mcp:
  server: office-mcp
  tools:
    - create_docx

# Skill Capabilities
capabilities:
  - email_writing
  - professional_tone
  - template_usage

# Language Support
languages:
  - en
  - zh
""" ] ;
