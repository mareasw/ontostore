oc:kn_0af8b5c6 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating drafts for any organizational context" ;
    oc:directiveContent "This skill does not know the user's organization-specific communication norms, templates, or approval workflows." ;
    oc:hasRationale "Every organization has unique communication standards; the agent cannot assume norms without explicit input." ;
    oc:severityLevel "LOW" .

oc:kn_4dc6da89 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any email subject line" ;
    oc:directiveContent "Never use vague subject lines like 'Hello' or 'Quick question', exceed 50 characters, use ALL CAPS, or write misleading clickbait subject lines." ;
    oc:hasRationale "Vague or misleading subject lines reduce open rates, cause miscommunication, and appear unprofessional." ;
    oc:severityLevel "HIGH" .

oc:kn_9a090afa a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting tone for any email draft" ;
    oc:directiveContent "Match tone to audience: professional+warm for clients, direct+friendly for internal teams, concise+respectful for executives, engaging+value-focused for cold outreach, empathetic+clear for difficult news, polite+persistent for follow-ups." ;
    oc:hasRationale "Tone mismatch damages credibility — e.g., overly casual to an executive or overly formal to a teammate creates friction." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a88cf723 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring any professional email" ;
    oc:directiveContent """Subject: [Clear, specific, action-oriented]

[Greeting - appropriate to relationship]

[Opening - context/reference]

[Body - main message, organized by priority]

[Call to action - clear next steps]

[Closing - appropriate sign-off]

[Signature]""" .

oc:kn_ae3f4bb5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — this is a draft-only skill" ;
    oc:directiveContent "This skill can only draft emails, not send them. All drafts must be reviewed for accuracy of names, dates, and details before use. Not suitable for legal or highly sensitive communications without human review." ;
    oc:hasRationale "Automated drafts may contain factual errors or inappropriate language for sensitive contexts; human review is essential." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c2cd7214 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any email" ;
    oc:directiveContent "Structure emails as: subject line → greeting → opening with context → body organized by priority → clear call to action → appropriate sign-off." ;
    oc:hasRationale "This structure ensures clarity, scannability, and drives the recipient toward the desired action." ;
    oc:severityLevel "MEDIUM" .

oc:kn_db28f03d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When drafting any professional email" ;
    oc:directiveContent "1. Identify email scenario type (follow-up, request, decline, apology, outreach, thank-you) 2. Gather context: recipient, relationship, purpose 3. Select appropriate tone from tone guidelines 4. Draft using matching template structure 5. Compose clear, action-oriented subject line 6. Present draft in standardized output format with notes" ;
    oc:stepOrder 1 .

oc:kn_e39b71fc a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """## Email Draft

**Subject:** {subject_line}

**To:** {recipient}
**CC:** {cc_if_applicable}

---

{email_body}

---

## Notes
- {considerations_or_alternatives}
- {suggested_timing_for_sending}""" ;
    oc:templateVariables "cc_if_applicable",
        "considerations_or_alternatives",
        "email_body",
        "recipient",
        "subject_line",
        "suggested_timing_for_sending" .

oc:kn_fe37bd84 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating any email draft" ;
    oc:directiveContent "Before drafting, gather: email scenario type (reply/new/follow-up), recipient identity and relationship, purpose of the email, and any specific points to include." ;
    oc:hasRationale "Missing context leads to generic, ineffective emails that don't achieve their communication goal." ;
    oc:severityLevel "MEDIUM" .

