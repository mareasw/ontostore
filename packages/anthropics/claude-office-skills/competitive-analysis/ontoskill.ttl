                    oc:contentOrder 1 ;
                    oc:rawYaml """# ═══════════════════════════════════════════════════════════════════════════════
# CLAUDE OFFICE SKILL - Competitive Analysis
# ═══════════════════════════════════════════════════════════════════════════════

name: competitive-analysis
description: "Analyze competitors systematically. Compare products, features, pricing, positioning, and market strategies. Generate comprehensive competitive intelligence reports."
version: "1.0.0"
author: claude-office-skills
license: MIT

category: research
tags:
  - competitive
  - analysis
  - market
  - strategy
  - benchmarking
department: Strategy/Marketing

models:
  recommended:
    - claude-sonnet-4
    - claude-opus-4
  compatible:
    - claude-3-5-sonnet
    - gpt-4
    - gpt-4o

mcp:
  server: office-mcp
  tools:
    - create_docx
    - create_xlsx
    - create_chart

capabilities:
  - competitor_profiling
  - feature_comparison
  - pricing_analysis
  - positioning_mapping
  - swot_analysis

languages:
  - en
  - zh

related_skills:
  - company-research
  - deep-research
  - proposal-writer
""" ] ;
