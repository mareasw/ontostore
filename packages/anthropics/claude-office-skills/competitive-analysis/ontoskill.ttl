    oc:contentHash "4c988e99e697fcd9c805d6d3f904c39778ff723d4f8694e5dff0ae7dcf535db6" ;
    oc:differentia "that systematically compares competitors across products, features, pricing, positioning, and market strategies to generate competitive intelligence reports" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasAllowedTool "create_chart",
        "create_docx",
        "create_xlsx" ;
    oc:hasArgumentHint "company/product, competitors to analyze, industry/market segment, analysis type (quick comparison, full profile, strategic analysis, battle card)" ;
