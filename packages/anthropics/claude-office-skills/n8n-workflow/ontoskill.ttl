oc:kn_1f4cf85c a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When configuring n8n nodes that connect to external services" ;
    oc:directiveContent "Always store credentials using n8n's built-in credential manager, never hardcode API keys or tokens directly in workflow nodes." ;
    oc:hasRationale "Hardcoded credentials in workflow JSON are visible in exports and version control, creating security vulnerabilities." ;
    oc:severityLevel "CRITICAL" .

oc:kn_20cd06ff a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building production workflows" ;
    oc:directiveContent "Never deploy n8n workflows without error handling nodes — unhandled errors in one node silently break downstream nodes." ;
    oc:hasRationale "n8n pipelines data between nodes; a failure without error handling cascades silently." ;
    oc:severityLevel "HIGH" .

oc:kn_262a90a1 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before activating any workflow in production" ;
    oc:directiveContent "Test workflows with sample data before deploying to production to validate node outputs and data flow." ;
    oc:hasRationale "Node output schema mismatches between nodes are the most common runtime failure mode." ;
    oc:severityLevel "HIGH" .

oc:kn_7b9031e3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any n8n workflow" ;
    oc:directiveContent "Structure workflows as Trigger → Action → Action → Output, where each node processes and passes data to the next." ;
    oc:hasRationale "The node-based pipeline pattern is n8n's fundamental execution model." .

oc:kn_9b864fff a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any new n8n workflow" ;
    oc:directiveContent "Start with existing n8n community templates (7800+ available) and customize as needed rather than building workflows from scratch." ;
    oc:hasRationale "Templates provide battle-tested patterns that reduce errors and development time." ;
    oc:severityLevel "MEDIUM" .

