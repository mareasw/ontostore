    oc:contentHash "aaa666c97b5723234f95c1b3ecd1537d202bbf4ac5accfb04d661dae730cb5df" ;
    oc:differentia "that creates personalized, professionally structured cover letters tailored to specific job applications" ;
    oc:extends oc:skill_ontoskills_docx_manipulation ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "job posting or role description, along with relevant experience details" ;
    oc:hasCategory "hr" ;
