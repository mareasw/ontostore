oc:kn_17f7d1d5 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Standard professional cover letter template" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent "[Your Name]\\n[Email] | [Phone] | [LinkedIn]\\n[City, State]\\n\\n[Date]\\n\\n[Hiring Manager Name]\\n[Title]\\n[Company Name]\\n[City, State]\\n\\nDear [Mr./Ms. Last Name],\\n\\n[Opening Hook]\\n\\n[Value Proposition]\\n\\n[Why This Company]\\n\\n[Strong Close]\\n\\nSincerely,\\n[Your Name]" ;
    oc:templateVariables "City State",
        "Company Name",
        "Date",
        "Email",
        "Hiring Manager Name",
        "LinkedIn",
        "Phone",
        "Position",
        "Title",
        "X years",
        "Your Name",
        "company mission",
        "key achievement",
        "relevant field" .

oc:kn_367745d0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any cover letter" ;
    oc:directiveContent "Never repeat your resume in a cover letter — add new insights, quantified achievements, and context not found in the resume." ;
    oc:hasRationale "A cover letter that merely summarizes the resume provides zero additional value and wastes the reader's time." ;
    oc:severityLevel "HIGH" .

oc:kn_5e3aad54 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating cover letter output" ;
    oc:directiveContent "Keep cover letters to one page, 3-4 paragraphs maximum (250-450 words depending on tone preference)." ;
    oc:hasRationale "Hiring managers spend 30-60 seconds on a cover letter; exceeding one page signals poor communication skills." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8598504c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing cover letter structure" ;
    oc:directiveContent "Structure the letter as: attention-grabbing opening hook → value proposition matching job requirements → company-specific research → strong close with call to action." ;
    oc:hasRationale "This four-part structure mirrors the hiring manager's decision process: attention → relevance → fit → action." ;
    oc:severityLevel "MEDIUM" .

oc:kn_85ec4dfc a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "After generating any cover letter" ;
    oc:directiveContent "Generated cover letters should always be reviewed by the user for accuracy of dates, company names, and personal details before sending." ;
    oc:hasRationale "The LLM may hallucinate or misattribute specific details that only the applicant can verify." ;
    oc:severityLevel "HIGH" .

oc:kn_8b362a3c a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Before generating a cover letter" ;
    oc:directiveContent "The skill cannot access actual job postings — the user must provide the job description text, company details, and personal experience context." ;
    oc:hasRationale "Without real job posting data, the letter cannot be properly tailored and will produce generic results." ;
    oc:severityLevel "HIGH" .

oc:kn_a3f14ccb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the opening paragraph" ;
    oc:directiveContent "Avoid generic openings like 'I am writing to apply for...' or 'To whom it may concern' — always open with something specific and compelling." ;
    oc:hasRationale "Generic openings signal a mass-produced letter and immediately lose the reader's attention." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a7efe1ad a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "User must provide the job posting text or role description, their relevant experience details, and any specific points to highlight." .

oc:kn_c76fe2d5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing value proposition paragraphs" ;
    oc:directiveContent "Quantify every achievement with specific numbers, percentages, dollar amounts, or timeframes rather than vague descriptors." ;
    oc:hasRationale "Quantified achievements are 3x more memorable and demonstrate concrete impact versus generic claims." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cd54963e a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When formatting final cover letter output" ;
    oc:directiveContent "Output should include: position and company header, full letter text, key points highlighted (matched accomplishments to requirements), and customization notes for further personalization." ;
    oc:hasRationale "Structured output helps the user quickly verify alignment and make targeted edits before submission." .

oc:kn_d9f2eb9d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Collect job posting text and user's relevant experience 2. Identify key requirements to match against 3. Select appropriate template (standard, referral, career change, entry level) 4. Draft opening hook with specific achievement or connection 5. Write value proposition paragraphs with quantified accomplishments 6. Add company-specific research paragraph 7. Close with clear call to action 8. Output with key points highlighted and customization notes" ;
    oc:stepOrder 1 .

oc:kn_ffa4bc7d a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When user provides minimal input" ;
    oc:directiveContent "If insufficient context is provided, ask the user for: (1) the job posting or role description, (2) years of experience and key skills, (3) specific achievements to highlight, (4) why they're interested in this company." ;
    oc:hasRationale "Cover letters without sufficient context produce generic, ineffective results." .

