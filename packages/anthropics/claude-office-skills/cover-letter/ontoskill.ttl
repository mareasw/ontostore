    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """# ═══════════════════════════════════════════════════════════════════════════════
# CLAUDE OFFICE SKILL - Enhanced Metadata v2.0
# ═══════════════════════════════════════════════════════════════════════════════

# Basic Information
name: cover-letter
description: ">"
version: "1.0.0"
author: Claude Office Skills Contributors
license: MIT

# Categorization
category: hr
tags:
  - cover-letter
  - job-application
  - writing
department: HR/Personal

# AI Model Compatibility
models:
  recommended:
    - claude-sonnet-4
    - claude-opus-4
  compatible:
    - claude-3-5-sonnet
    - gpt-4
    - gpt-4o

# MCP Tools Integration
mcp:
  server: office-mcp
  tools:
    - create_docx
    - docx_to_pdf

# Skill Capabilities
capabilities:
  - letter_writing
  - personalization
  - professional_tone

# Language Support
languages:
  - en
  - zh
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """## Cover Letter

**Position:** [Role]
**Company:** [Company]
**Tailored for:** [Specific aspects addressed]

---

[Full cover letter text]

---

## Key Points Highlighted
- [Accomplishment 1 matched to requirement]
- [Accomplishment 2 matched to requirement]

## Customization Notes
- [Any suggestions for further personalization]
""" ;
                            oc:codeLanguage "markdown" ;
