                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 10 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Go and Python expertise (matches tech stack)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Direct payment systems experience (matches domain)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Familiarity with Stripe products (shows research)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Infrastructure scale mindset (matches Stripe's challenges)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Quantified achievements ($50M, 40% reduction, 10x throughput)" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "Building payment infrastructure that processes $50M+ monthly has been the highlight of my engineering career – and it's exactly why I'm excited about the Senior Software Engineer role at Stripe. Your mission to increase the GDP of the internet resonates deeply with my experience making financial technology accessible and reliable." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Dear Hiring Manager," ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "What draws me to Stripe specifically is your developer-first approach. I've used Stripe's APIs extensively and appreciate the thoughtfulness in your documentation and SDKs. The opportunity to build infrastructure that millions of businesses depend on, while working alongside engineers who've set the standard for API design, is exactly the challenge I'm seeking." ],
