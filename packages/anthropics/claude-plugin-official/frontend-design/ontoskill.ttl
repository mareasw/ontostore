@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_claude_plugin_official_frontend_design a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "frontend-design" ;
    skos:broader "Frontend Interface Generator" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/claude-plugin-official/frontend-design" ;
    oc:contentHash "e02cb16b9749174327314036821ed5faabd248e34501c045ac0243a62fb9f091" ;
    oc:differentia "that produces distinctive, production-grade web interfaces with bold aesthetic direction and meticulous design execution, avoiding generic AI aesthetics" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Read",
        "Write" ;
    oc:hasArgumentHint "description of the frontend component, page, or application to build, optionally with purpose, audience, and technical constraints" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Create distinctive, production-grade frontend interfaces with high design quality. Use this skill when the user asks to build web components, pages, or applications. Generates creative, polished code that avoids generic AI aesthetics." ;
    oc:hasName "frontend-design" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "This skill guides creation of distinctive, production-grade frontend interfaces that avoid generic \"AI slop\" aesthetics. Implement real working code with exceptional attention to aesthetic details and creative choices." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "The user provides frontend requirements: a component, page, application, or interface to build. They may include context about the purpose, audience, or technical constraints." ],
                [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: frontend-design
description: Create distinctive, production-grade frontend interfaces with high design quality. Use this skill when the user asks to build web components, pages, or applications. Generates creative, polished code that avoids generic AI aesthetics.
license: Complete terms in LICENSE.txt
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Before coding, understand the context and commit to a BOLD aesthetic direction:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Differentiation**: What makes this UNFORGETTABLE? What's the one thing someone will remember?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Purpose**: What problem does this interface solve? Who uses it?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Constraints**: Technical requirements (framework, performance, accessibility)." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Tone**: Pick an extreme: brutally minimal, maximalist chaos, retro-futuristic, organic/natural, luxury/refined, playful/toy-like, editorial/magazine, brutalist/raw, art deco/geometric, soft/pastel, industrial/utilitarian, etc. There are so many flavors to choose from. Use these for inspiration but design one that is true to the aesthetic direction." ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**CRITICAL**: Choose a clear conceptual direction and execute it with precision. Bold maximalism and refined minimalism both work - the key is intentionality, not intensity." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "Then implement working code (HTML/CSS/JS, React, Vue, etc.) that is:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 5 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Cohesive with a clear aesthetic point-of-view" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Visually striking and memorable" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Production-grade and functional" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Meticulously refined in every detail" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Design Thinking" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "Interpret creatively and make unexpected choices that feel genuinely designed for the context. No design should be the same. Vary between light and dark themes, different fonts, different aesthetics. NEVER converge on common choices (Space Grotesk, for example) across generations." ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "**Backgrounds & Visual Details**: Create atmosphere and depth rather than defaulting to solid colors. Add contextual effects and textures that match the overall aesthetic. Apply creative forms like gradient meshes, noise textures, geometric patterns, layered transparencies, dramatic shadows, decorative borders, custom cursors, and grain overlays." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Color & Theme**: Commit to a cohesive aesthetic. Use CSS variables for consistency. Dominant colors with sharp accents outperform timid, evenly-distributed palettes." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Typography**: Choose fonts that are beautiful, unique, and interesting. Avoid generic fonts like Arial and Inter; opt instead for distinctive choices that elevate the frontend's aesthetics; unexpected, characterful font choices. Pair a distinctive display font with a refined body font." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Motion**: Use animations for effects and micro-interactions. Prioritize CSS-only solutions for HTML. Use Motion library for React when available. Focus on high-impact moments: one well-orchestrated page load with staggered reveals (animation-delay) creates more delight than scattered micro-interactions. Use scroll-triggering and hover states that surprise." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Spatial Composition**: Unexpected layouts. Asymmetry. Overlap. Diagonal flow. Grid-breaking elements. Generous negative space OR controlled density." ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent "Remember: Claude is capable of extraordinary creative work. Don't hold back, show what can truly be created when thinking outside the box and committing fully to a distinctive vision." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 5 ;
                    oc:textContent "**IMPORTANT**: Match implementation complexity to the aesthetic vision. Maximalist designs need elaborate code with extensive animations and effects. Minimalist or refined designs need restraint, precision, and careful attention to spacing, typography, and subtle details. Elegance comes from executing the vision well." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "NEVER use generic AI-generated aesthetics like overused font families (Inter, Roboto, Arial, system fonts), cliched color schemes (particularly purple gradients on white backgrounds), predictable layouts and component patterns, and cookie-cutter design that lacks context-specific character." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Focus on:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Frontend Aesthetics Guidelines" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Structured workflow for creating distinctive frontend interfaces from concept to implementation" ;
            oc:hasStep _:ref_0e46c4794f6558a6,
                [ a oc:WorkflowStep ;
                    dcterms:description "Refine micro-interactions, motion orchestration, scroll-triggered effects, hover states, and atmospheric textures" ;
                    oc:expectedOutcome "Polished interface where every detail serves the aesthetic vision" ;
                    oc:stepDependsOn _:ref_df668c0727e1cadc ;
                    oc:stepId "refine-details" ],
                _:ref_6a1277af604b209e,
                _:ref_8e2e54ded078cf2e,
                _:ref_df668c0727e1cadc,
                _:ref_fc026ede7b684a54 ;
            oc:workflowId "frontend-design-workflow" ;
            oc:workflowName "Design and Build Frontend Interface" ] ;
    oc:impartsKnowledge oc:kn_09c7ff2d,
        oc:kn_536c2c91,
        oc:kn_72504572,
        oc:kn_a45fd68f,
        oc:kn_b8b1c250,
        oc:kn_c41d5688,
        oc:kn_ce2536fc,
        oc:kn_ff19369c ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build distinctive web applications",
        "build frontend interfaces",
        "create production-grade UI",
        "create web components",
        "design web pages" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_09c7ff2d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making any font, color, or layout decision" ;
    oc:directiveContent "Never use generic AI aesthetics: avoid Inter, Roboto, Arial, system fonts; avoid purple gradients on white; avoid predictable layouts and cookie-cutter design patterns. Never converge on common choices like Space Grotesk across generations." ;
    oc:hasRationale "Generic AI-generated aesthetics lack context-specific character and produce forgettable, indistinguishable interfaces" ;
    oc:severityLevel "CRITICAL" .

oc:kn_536c2c91 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing the chosen aesthetic direction" ;
    oc:directiveContent "Match implementation complexity to aesthetic vision: maximalist designs need elaborate code with extensive animations; minimalist designs need restraint, precision, and careful attention to spacing and typography." ;
    oc:hasRationale "Mismatched complexity undermines the design — overwrought minimalism feels busy, underbuilt maximalism feels hollow" .

oc:kn_72504572 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before writing any frontend code" ;
    oc:directiveContent "Before coding, commit to a BOLD aesthetic direction by analyzing purpose, tone, constraints, and differentiation. Choose an extreme aesthetic (brutalist, retro-futuristic, luxury/refined, editorial/magazine, etc.) and execute with intentionality." ;
    oc:hasRationale "Intentionality is the key to distinctive design — bold maximalism and refined minimalism both work, but timid middle-ground always fails" .

oc:kn_a45fd68f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing backgrounds and visual atmosphere" ;
    oc:directiveContent "Create atmosphere with backgrounds and visual details: gradient meshes, noise textures, geometric patterns, layered transparencies, dramatic shadows, decorative borders, custom cursors, and grain overlays. Never default to solid color backgrounds." ;
    oc:hasRationale "Atmospheric backgrounds create depth and emotional resonance; solid colors feel flat and generic" .

oc:kn_b8b1c250 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing colors, themes, and animations" ;
    oc:directiveContent "Always use CSS variables for color consistency. Prioritize CSS-only animation solutions for HTML. Use Motion library for React animations when available. Focus on high-impact moments like orchestrated page loads with staggered reveals." ;
    oc:hasRationale "CSS variables ensure cohesive palettes; CSS-only animations avoid unnecessary JS dependencies; orchestrated animations create more delight than scattered micro-interactions" .

oc:kn_c41d5688 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During the design thinking phase before coding" ;
    oc:directiveContent "Every design must answer: What makes this UNFORGETTABLE? Identify the one thing someone will remember about the interface and ensure it is executed perfectly." ;
    oc:hasRationale "A single memorable element anchors the entire experience and differentiates it from generic output" .

oc:kn_ce2536fc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, across all generations" ;
    oc:directiveContent "Never produce the same design twice. Vary between light and dark themes, different fonts, different aesthetics across generations. Each interface should feel genuinely designed for its specific context." ;
    oc:hasRationale "Convergent output across multiple requests reveals AI-generated patterns and defeats the purpose of distinctive design" .

oc:kn_ff19369c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring page layouts" ;
    oc:directiveContent "Use unexpected spatial composition: asymmetry, overlap, diagonal flow, grid-breaking elements, generous negative space OR controlled density. Avoid predictable centered layouts." ;
    oc:hasRationale "Unexpected spatial composition creates visual interest and memorability; predictable layouts are instantly forgettable" .

_:ref_0e46c4794f6558a6 a oc:WorkflowStep ;
    dcterms:description "Select distinctive, characterful fonts — pair a unique display font with a refined body font; avoid generic AI defaults" ;
    oc:expectedOutcome "Font choices that elevate the aesthetic and are context-appropriate" ;
    oc:stepDependsOn _:ref_6a1277af604b209e ;
    oc:stepId "select-typography" .

_:ref_8e2e54ded078cf2e a oc:WorkflowStep ;
    dcterms:description "Analyze purpose, audience, and technical constraints of the requested interface" ;
    oc:expectedOutcome "Clear understanding of what the interface must accomplish and for whom" ;
    oc:stepId "analyze-context" .

_:ref_df668c0727e1cadc a oc:WorkflowStep ;
    dcterms:description "Implement production-grade code (HTML/CSS/JS or framework) with spatial composition, animations, backgrounds, and atmospheric details matching the aesthetic" ;
    oc:expectedOutcome "Working, functional frontend code that is visually striking and meticulously refined" ;
    oc:stepDependsOn _:ref_0e46c4794f6558a6,
        _:ref_fc026ede7b684a54 ;
    oc:stepId "implement-code" .

_:ref_fc026ede7b684a54 a oc:WorkflowStep ;
    dcterms:description "Define a cohesive color palette using CSS variables — dominant colors with sharp accents, avoiding timid even distribution" ;
    oc:expectedOutcome "CSS variable-based color system that supports the aesthetic vision" ;
    oc:stepDependsOn _:ref_6a1277af604b209e ;
    oc:stepId "define-palette" .

_:ref_6a1277af604b209e a oc:WorkflowStep ;
    dcterms:description "Choose a bold, specific aesthetic direction from extreme options (brutalist, retro-futuristic, luxury, editorial, etc.) — identify the ONE unforgettable element" ;
    oc:expectedOutcome "A committed aesthetic direction with a memorable differentiator" ;
    oc:stepDependsOn _:ref_8e2e54ded078cf2e ;
    oc:stepId "choose-aesthetic" .

