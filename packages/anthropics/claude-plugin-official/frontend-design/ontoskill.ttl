@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_frontend_design a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "frontend-design" ;
    skos:broader "Frontend interface generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/frontend-design" ;
    oc:contentHash "e02cb16b9749174327314036821ed5faabd248e34501c045ac0243a62fb9f091" ;
    oc:differentia "that produces distinctive, production-grade web interfaces with bold aesthetic direction, avoiding generic AI-generated design patterns" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "frontend requirements: component, page, application, or interface description" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Create distinctive, production-grade frontend interfaces with high design quality. Use this skill when the user asks to build web components, pages, or applications. Generates creative, polished code that avoids generic AI aesthetics." ;
    oc:hasName "frontend-design" ;
    oc:impartsKnowledge oc:kn_0d75ea45,
        oc:kn_8531f3ef,
        oc:kn_93513800,
        oc:kn_9e2259cd,
        oc:kn_b817601c,
        oc:kn_e44dd2b1 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build frontend interfaces",
        "build visually distinctive web applications",
        "create production-grade UI",
        "create web components",
        "design web pages" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0d75ea45 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing spatial composition and visual details" ;
    oc:directiveContent "Use unexpected layouts: asymmetry, overlap, diagonal flow, grid-breaking elements, generous negative space OR controlled density. Create atmosphere with gradient meshes, noise textures, geometric patterns, layered transparencies, dramatic shadows, decorative borders, custom cursors, and grain overlays." ;
    oc:hasRationale "Breaking conventional grid patterns and adding atmospheric depth transforms generic layouts into memorable, distinctive interfaces" .

oc:kn_8531f3ef a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing frontend code after choosing an aesthetic direction" ;
    oc:directiveContent "Match implementation complexity to the aesthetic vision. Maximalist designs need elaborate code with extensive animations and effects. Minimalist designs need restraint, precision, and careful attention to spacing, typography, and subtle details." ;
    oc:hasRationale "Elegance comes from executing the vision well — mismatched complexity undermines the chosen aesthetic" .

oc:kn_93513800 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any frontend code or design" ;
    oc:directiveContent "Never use generic AI-generated aesthetics: overused fonts (Inter, Roboto, Arial, system fonts), cliched color schemes (purple gradients on white), predictable layouts, or cookie-cutter design lacking context-specific character." ;
    oc:hasRationale "Generic AI aesthetics make interfaces indistinguishable and forgettable, defeating the purpose of intentional design" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9e2259cd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting any new frontend design task" ;
    oc:directiveContent "Before coding, commit to a BOLD aesthetic direction by understanding purpose, tone, constraints, and differentiation. Choose extreme aesthetic positions: brutally minimal, maximalist chaos, retro-futuristic, organic/natural, luxury/refined, playful/toy-like, editorial/magazine, brutalist/raw, art deco/geometric, etc." ;
    oc:hasRationale "Intentionality in aesthetic direction is the key differentiator — bold maximalism and refined minimalism both work when executed with precision" .

oc:kn_b817601c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating multiple frontend designs over time" ;
    oc:directiveContent "Vary between light and dark themes, different fonts, and different aesthetics across generations. Never converge on common choices (e.g., Space Grotesk) across multiple designs." ;
    oc:hasRationale "Convergence on repeated choices produces homogeneous output indistinguishable from generic AI-generated content" .

oc:kn_e44dd2b1 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When implementing typography, color, and motion in any frontend project" ;
    oc:directiveContent "Use CSS variables for color consistency. Choose distinctive, characterful typography — pair a distinctive display font with a refined body font. Prioritize CSS-only animation solutions for HTML, use Motion library for React. Focus on high-impact moments with staggered reveals using animation-delay." ;
    oc:hasRationale "Cohesive design systems with intentional typography, consistent theming, and well-orchestrated motion create memorable interfaces" .

