oc:skill_anthropics_claude_plugin_official_build_mcp_server_versions a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "versions" ;
    skos:broader "version registry" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/build-mcp-server" ;
    oc:contentHash "f7592e72c5c357153c3e031c7c768e32f670a654b146509cbeaf6d8d4f2e3752" ;
    oc:differentia "that centralizes all version-sensitive dependency pins and claims for the build-mcp-server skill family in a single auditable table" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_build_mcp_server ;
    oc:handlesFailure oc:VersionMismatch ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_9fbf8538,
        oc:req_d71f6c59,
        oc:req_fc83f74c ;
    oc:impartsKnowledge oc:kn_450960fb,
        oc:kn_56b57442,
        oc:kn_76a0284a,
        oc:kn_ea410c97 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "audit MCP dependency compatibility",
        "check dependency versions",
        "update version-sensitive claims",
        "verify version pins" ;
    oc:yieldsState oc:VersionsVerified .

oc:kn_450960fb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before modifying any skill that references versioned dependencies" ;
    oc:directiveContent "When updating any skill in the build-mcp-server family, check this version pin table first to ensure no dependency claims become stale or invalid." ;
    oc:hasRationale "Centralized version tracking prevents silent breakage from dependency drift across multiple skill files." ;
    oc:severityLevel "HIGH" .

oc:kn_56b57442 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When relying on version pin accuracy" ;
    oc:directiveContent "All claims were last verified as of 2026-03. Any change to these dependencies after that date may require re-verification." ;
    oc:hasRationale "Time-sensitive claims degrade in accuracy; the last-verified date establishes the trust boundary." ;
    oc:severityLevel "MEDIUM" .

oc:kn_76a0284a a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running version verification commands" ;
    oc:directiveContent "Verification commands are read-only (npm view, gh api, curl -sI) and can be safely re-run without side effects." ;
    oc:hasRationale "Read-only checks ensure audits are non-destructive and repeatable." ;
    oc:severityLevel "LOW" .

oc:kn_ea410c97 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before building or deploying MCP servers, apps, or bundles" ;
    oc:directiveContent "Use the provided bash commands (npm view, gh api, curl -sI) to verify each pinned version or resource still exists before proceeding with builds." ;
    oc:hasRationale "Catching stale pins early prevents cryptic build failures downstream." ;
    oc:severityLevel "HIGH" .

oc:req_9fbf8538 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "npm" .

oc:req_d71f6c59 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "curl" .

oc:req_fc83f74c a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "gh (GitHub CLI)" .

