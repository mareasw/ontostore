@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_claude_plugin_official_build_mcp_server_versions a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "versions" ;
    skos:broader "Version pin registry" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/build-mcp-server" ;
    oc:contentHash "f7592e72c5c357153c3e031c7c768e32f670a654b146509cbeaf6d8d4f2e3752" ;
    oc:differentia "that centralizes all version-sensitive dependency claims for the build-mcp-server skill family with verification commands" ;
    oc:extends oc:skill_claude_plugin_official_build_mcp_server ;
    oc:handlesFailure oc:DependencyNotFound,
        oc:VersionMismatch ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Table ;
                    oc:blockType "table" ;
                    oc:contentOrder 2 ;
                    oc:rowCount 6 ;
                    oc:tableCaption "Every version-sensitive claim in this skill, in one place. When updating the skill, check these first." ;
                    oc:tableMarkdown """| Claim | Where stated | Last verified |
|---|---|---|
| `@modelcontextprotocol/ext-apps@1.2.2` CDN pin | `build-mcp-app/SKILL.md`, `build-mcp-app/references/widget-templates.md` (4×) | 2026-03 |
| Claude Code ≥2.1.76 for elicitation | `elicitation.md:15`, `build-mcp-server/SKILL.md:43,76` | 2026-03 |
| MCP spec 2025-11-25 CIMD/DCR status | `auth.md:20,24,41` | 2026-03 |
| MCPB manifest schema v0.4 | `build-mcpb/references/manifest-schema.md` | 2026-03 |
| CF `agents` SDK / `McpAgent` API | `deploy-cloudflare-workers.md` | 2026-03 |
| CF template path `cloudflare/ai/demos/remote-mcp-authless` | `deploy-cloudflare-workers.md` | 2026-03 |
""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Every version-sensitive claim in this skill, in one place. When updating the skill, check these first." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# ext-apps latest
npm view @modelcontextprotocol/ext-apps version

# CF template still exists
gh api repos/cloudflare/ai/contents/demos/remote-mcp-authless/src/index.ts --jq '.sha'

# MCPB schema
curl -sI https://raw.githubusercontent.com/anthropics/mcpb/main/schemas/mcpb-manifest-v0.4.schema.json | head -1
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 16-25" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "How to verify" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Version pins" ] ;
    oc:impartsKnowledge oc:kn_740fb250,
        oc:kn_94474f62,
        oc:kn_e9f9b786,
        oc:kn_f5fe623f ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "check version compatibility for MCP server toolchain",
        "update version-sensitive dependencies",
        "verify version pins" ;
    oc:yieldsState oc:VersionsVerified .

oc:kn_740fb250 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When maintaining or updating any skill in the build-mcp-server family" ;
    oc:directiveContent "All version-sensitive claims (CDN pins, minimum CLI versions, schema versions, template paths) must be centralized in a single versions table. When updating any skill file, check this table first." ;
    oc:hasRationale "Scattered version claims across multiple files create silent breakage when dependencies update; centralization enables single-point verification." ;
    oc:severityLevel "HIGH" .

oc:kn_94474f62 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — verification commands are non-destructive" ;
    oc:directiveContent "Version verification commands are read-only and safe to run multiple times; they query remote registries without side effects." ;
    oc:hasRationale "Safe to include in CI pipelines or pre-commit hooks without risk of state mutation." .

oc:kn_e9f9b786 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using elicitation features, auth flows, or MCPB packaging" ;
    oc:directiveContent "Claude Code must be ≥2.1.76 for elicitation support. MCP spec 2025-11-05 defines CIMD/DCR status. MCPB manifest schema is v0.4." ;
    oc:hasRationale "Using features not yet supported by the installed CLI version causes silent failures or undefined behavior." .

oc:kn_f5fe623f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before releasing updates to build-mcp-server skills" ;
    oc:directiveContent "Before shipping skill updates, run the verification commands: npm view for ext-apps version, gh api for CF template existence, and curl for MCPB schema availability." ;
    oc:hasRationale "Proactive verification catches broken pins before they reach users." .

