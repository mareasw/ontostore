@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_build_mcp_server_tool_design a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "tool-design" ;
    skos:broader "MCP tool design guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/build-mcp-server" ;
    oc:contentHash "548198ecfcf319971d9bfea63436d24722f577c01ccbd7251d5fd0e3ab6a7caa" ;
    oc:differentia "that specifies how to write tool schemas, descriptions, parameter constraints, return shapes, and annotations so Claude correctly selects and calls MCP tools" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_build_mcp_server ;
    oc:handlesFailure oc:AmbiguousToolDescription,
        oc:InvalidSchema ;
    oc:hasArgumentHint "tool-name or tool-design context" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_04d9e9f4,
        oc:kn_07775871,
        oc:kn_1e14168c,
        oc:kn_7f7180c9,
        oc:kn_ba856d0a,
        oc:kn_bb188199,
        oc:kn_c41ab64a,
        oc:kn_d79f334f,
        oc:kn_f83d0513 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:MCPServerInitialized,
        oc:ToolHandlerWritten ;
    oc:resolvesIntent "configure tool annotations for host UX hints",
        "constrain parameter schemas to prevent bad arguments",
        "design MCP tool schemas that Claude uses correctly",
        "structure tool return values for Claude consumption",
        "write tool descriptions that prevent wrong-tool calls" ;
    oc:yieldsState oc:ToolAnnotationsConfigured,
        oc:ToolDescriptionsWritten,
        oc:ToolSchemaDefined .

oc:kn_04d9e9f4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When registering multiple related tools" ;
    oc:directiveContent "When two tools are similar, each description should say when to use the other one. Disambiguate siblings explicitly in descriptions." ;
    oc:hasRationale "Without cross-references, Claude cannot distinguish between near-duplicate tools and may call the wrong one." ;
    oc:severityLevel "HIGH" .

oc:kn_07775871 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any MCP tool description" ;
    oc:directiveContent "Tool descriptions are the contract Claude reads before deciding whether to call the tool. Write them like one-line manpage entries plus disambiguating hints — say what it does, what it returns, and what it doesn't do." ;
    oc:hasRationale "Vague descriptions cause Claude to call the wrong tool for anything vaguely search-shaped. Most MCP integration bugs trace back to vague descriptions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1e14168c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling errors in tool handlers" ;
    oc:directiveContent "Never throw exceptions that crash the transport. Return MCP tool errors with isError: true and include enough detail for Claude to recover or retry — specifically hint at the next step tool to call." ;
    oc:hasRationale "A bare error is a dead end. A hint like 'Use search_items to find valid IDs' turns a failure into a recoverable next step." ;
    oc:severityLevel "HIGH" .

oc:kn_7f7180c9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between resource_link and embedded resource content types" ;
    oc:directiveContent "Use resource_link for large payloads or when the client might not need the data. Use embedded resource when content is small and always needed." ;
    oc:hasRationale "resource_link lets the client decide whether to fetch, saving bandwidth and context tokens. Embedding is wasteful for large optional data." ;
    oc:severityLevel "LOW" .

oc:kn_ba856d0a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding how many tools to expose on an MCP server" ;
    oc:directiveContent "Keep tool count at 1–15 for one-tool-per-action. At 15–30 audit for near-duplicates. At 30+ switch to search + execute pattern and promote top 3–5 to dedicated tools. Every tool schema costs tokens every turn." ;
    oc:hasRationale "Thirty tools with rich schemas can eat 3–5k tokens before the conversation starts. Context-window economics limit tool count." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bb188199 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When registering tools on an MCP server" ;
    oc:directiveContent "Use tool annotations to communicate behavior to hosts: readOnlyHint for no side effects, destructiveHint for deletes/overwrites, idempotentHint for safe retries, openWorldHint for external API calls." ;
    oc:hasRationale "Annotations enable host UX optimizations like auto-approve for readonly tools, confirmation dialogs for destructive ones, and retry behavior for idempotent ones." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c41ab64a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing tool return values" ;
    oc:directiveContent "Return structured JSON for data, short confirmations with IDs for mutations, and always truncate large payloads with a note. Never return raw HTML, megabytes of unfiltered API response, or bare success with no identifier." ;
    oc:hasRationale "Claude reads whatever is in content[].text. Unparseable or oversized returns waste context and lose information Claude needs for follow-up calls." ;
    oc:severityLevel "HIGH" .

oc:kn_d79f334f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing typed structured output for tools" ;
    oc:directiveContent "When using structured output (outputSchema + structuredContent), always include a text fallback in content[].text since not all hosts read structuredContent yet." ;
    oc:hasRationale "Backward compatibility — hosts that don't support structuredContent will silently drop the typed output, leaving Claude with no data." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f83d0513 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining tool input schemas" ;
    oc:directiveContent "Use tight parameter schemas with regex patterns, enums, min/max bounds, and .describe() on every parameter. Every constraint expressed in the schema is one fewer thing that can go wrong at runtime." ;
    oc:hasRationale "Loose schemas (plain z.string() or z.number()) allow invalid arguments through, causing runtime failures that could have been caught structurally." ;
    oc:severityLevel "HIGH" .

