oc:kn_225a8ad6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring the fetch handler in src/index.ts" ;
    oc:directiveContent "Route /mcp pathname to MyMCP.serve('/mcp').fetch() and return 404 for all other paths." ;
    oc:hasRationale "MCP clients expect the SSE/streamable-HTTP endpoint at /mcp; all other routes are irrelevant" .

oc:kn_296a530b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When renaming the MCP agent class" ;
    oc:directiveContent "Never rename the MyMCP class without also updating both new_sqlite_classes and class_name in wrangler.jsonc — they must match." ;
    oc:hasRationale "Durable Objects binding requires class name consistency or runtime initialization fails" ;
    oc:severityLevel "CRITICAL" .

oc:kn_495bc90f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the MCP server entry point for Cloudflare Workers" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent "export class MyMCP extends McpAgent { server = new McpServer(...); async init() { this.server.registerTool(...) } } — use McpAgent wrapper and only touch this.server for tool registration" .

oc:kn_5f94eac5 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running any deploy commands" ;
    oc:directiveContent "Node.js and npm must be installed. Wrangler CLI via npx (no global install needed)." .

oc:kn_611510f1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between Workers and Express scaffolds" ;
    oc:directiveContent "This is a Workers-native scaffold, NOT a deploy target for the Express scaffold from remote-http-scaffold.md. Different runtime. Use Express scaffold for cross-host portability." ;
    oc:hasRationale "Workers runtime has different APIs and constraints than Node.js/Express — code is not portable between them" ;
    oc:severityLevel "HIGH" .

oc:kn_86e1ff38 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When architecting the server code" ;
    oc:directiveContent "McpAgent handles streamable-HTTP transport, session routing, and Durable Object plumbing automatically. Your code only touches this.server (same McpServer class from SDK)." ;
    oc:hasRationale "Avoids reimplementing transport/session concerns — McpAgent abstracts them away" .

oc:kn_a4d29b99 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting upstream API keys as secrets" ;
    oc:directiveContent "npx wrangler secret put UPSTREAM_API_KEY" .

oc:kn_ac118cdf a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When deploying from scratch" ;
    oc:directiveContent "1. npm create cloudflare@latest -- my-mcp-server --template=cloudflare/ai/demos/remote-mcp-authless  2. cd my-mcp-server  3. Replace template calculator with your tools using registerTool() in src/index.ts  4. Update wrangler.jsonc if class name changes  5. npx wrangler dev (local test)  6. npx wrangler deploy (live URL)" ;
    oc:stepOrder 1 .

oc:kn_e630b5d3 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When authentication is needed" ;
    oc:directiveContent "For OAuth support, use the cloudflare/ai/demos/remote-mcp-github-oauth template instead of the authless template, and add @cloudflare/workers-oauth-provider for authorization server handling." ;
    oc:hasRationale "Cloudflare provides a drop-in OAuth provider that handles CIMD/DCR endpoints, token issuance, and consent UI" .

