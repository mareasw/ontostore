    oc:stepOrder 3 .

_:ref_df1f85883b5aa7d4 a oc:WorkflowStep ;
    dcterms:description "**MCP app (UI widgets)** → Summarize the decisions so far, then load the **`build-mcp-app`** skill." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_e03fe04834b1e917 a oc:WorkflowStep ;
