    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_0ada78147f878e9c a oc:WorkflowStep ;
    dcterms:description "Select tool-design pattern: one-per-action (<15 actions), search+execute (50+), or hybrid." ;
    oc:expectedOutcome "Tool surface pattern determined" ;
