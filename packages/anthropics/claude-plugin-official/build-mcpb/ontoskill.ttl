oc:kn_0caaa8d2 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating a manifest.json for an MCPB bundle" ;
    oc:directiveContent """{
  "$schema": "https://raw.githubusercontent.com/anthropics/mcpb/main/schemas/mcpb-manifest-v0.4.schema.json",
  "manifest_version": "0.4",
  "name": "{package-name}",
  "version": "{semver}",
  "description": "{one-line summary}",
  "author": { "name": "{author}" },
  "server": {
    "type": "{node|python|binary}",
    "entry_point": "server/index.js",
    "mcp_config": {
      "command": "{runtime}",
      "args": ["${__dirname}/server/index.js"],
      "env": { "{ENV_VAR}": "${user_config.{key}}" }
    }
  },
  "user_config": { ... },
  "compatibility": { "platforms": ["darwin", "win32", "linux"] }
}""" ;
    oc:templateVariables "ENV_VAR",
        "author",
        "key",
        "node|python|binary",
        "one-line summary",
        "package-name",
        "runtime",
        "semver" .

oc:kn_16c93561 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when building MCPB servers" ;
    oc:directiveContent "MCPB has NO sandbox, NO permissions block, NO filesystem/network scoping. The server process runs with full user privileges. You must build all security boundaries yourself in tool handlers." ;
    oc:hasRationale "Unlike mobile app stores, there is no platform-level enforcement. Prompt-injected inputs can make Claude call tools with unintended arguments." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1afa3a58 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When bundling Node.js server code for MCPB packaging" ;
    oc:directiveContent "npx esbuild src/index.ts --bundle --platform=node --outfile=server/index.js" .

oc:kn_38ccac35 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building an MCPB from scratch" ;
    oc:directiveContent "1. Create manifest.json with server config, user_config, and compatibility 2. Write stdio MCP server code (standard MCP SDK) 3. Validate every path parameter through containment check (resolve + relative) 4. Bundle dependencies (esbuild for Node, pip -t for Python) 5. Run npx @anthropic-ai/mcpb validate 6. Run npx @anthropic-ai/mcpb pack 7. Test on a machine WITHOUT your dev toolchain" ;
    oc:hasRationale "Order ensures manifest validity, security, proper bundling, and real-world compatibility" ;
    oc:severityLevel "HIGH" ;
    oc:stepOrder 1 .

oc:kn_3f4dea1e a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When accepting path parameters in any MCPB tool handler" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """function safeJoin(root: string, userPath: string): string {
  const full = resolve(root, userPath);
  const rel = relative(root, full);
  if (rel.startsWith('..') || isAbsolute(rel)) {
    throw new Error(`Path escapes root: ${userPath}`);
  }
  return full;
}""" ;
    oc:hasRationale "resolve() normalizes .., symlink segments; relative() detects root escape. String.includes('..') misses encoded and symlink-based escapes." .

oc:kn_5bf1fd7d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When spawning processes in MCPB tool handlers" ;
    oc:directiveContent "Never pass user input through a shell (exec(), shell=True). Always use array-args (execFile, subprocess with array argv). Validate flags against an allowlist." ;
    oc:hasRationale "Shell injection allows arbitrary command execution with full user privileges" ;
    oc:severityLevel "CRITICAL" .

oc:kn_652d748c a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When vendoring Python dependencies for MCPB packaging" ;
    oc:directiveContent "pip install -t server/vendor -r requirements.txt" .

oc:kn_6ec1cbd1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining allowed filesystem paths" ;
    oc:directiveContent "Before hardcoding ROOT from a config env var, check if the host supports roots/list — the spec-native way to get user-approved directories. Fall back to config env var only if roots are unavailable." ;
    oc:hasRationale "Using the host's roots mechanism gives user-controlled boundaries rather than hardcoded assumptions" ;
    oc:severityLevel "MEDIUM" .

oc:kn_83ceff33 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing MCPB tool interfaces" ;
    oc:directiveContent "Split read and write into separate tools. Make read-only tools the default with readOnlyHint: true. Put destructiveHint: true on delete/overwrite tools. Consider not shipping delete tools at all." ;
    oc:hasRationale "Read-only tools can't be weaponized into data loss regardless of what Claude is tricked into calling" ;
    oc:severityLevel "HIGH" .

oc:kn_9236687c a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building and packaging the MCPB bundle after code is ready" ;
    oc:directiveContent "npx @anthropic-ai/mcpb validate && npx @anthropic-ai/mcpb pack" .

oc:kn_97f72e8a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring server.mcp_config in manifest.json" ;
    oc:directiveContent "There are no auto-prefixed env vars. The env var names your server reads are exactly what you declare in server.mcp_config.env. Use ${__dirname} for bundle-relative paths and ${user_config.KEY} for install-time config." ;
    oc:hasRationale "No MCPB_CONFIG_* convention exists; explicit wiring prevents confusion about where config values come from" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9f6e7337 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running npx @anthropic-ai/mcpb pack" ;
    oc:directiveContent "Before shipping: every path parameter goes through containment check, no exec()/shell=True, write/delete split from read tools, size caps on reads, secrets never logged or returned, tested with adversarial inputs (../../etc/passwd, ; rm -rf ~, 10GB file)." ;
    oc:hasRationale "Security checklist prevents common local MCP server vulnerabilities from reaching users" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ad43b25a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to build an MCPB vs a remote MCP server" ;
    oc:directiveContent "Do NOT use MCPB packaging for servers that only hit cloud APIs — use a remote HTTP MCP server instead. MCPB is for servers that must run locally (filesystem, desktop apps, localhost services, OS APIs)." ;
    oc:hasRationale "MCPB adds packaging complexity and local-security burden that is unnecessary for cloud-only servers" ;
    oc:severityLevel "HIGH" .

oc:kn_b55be86e a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "Before distributing an MCPB file" ;
    oc:directiveContent "'Works on my machine' failures in MCPB almost always trace to a dependency that wasn't actually bundled. Test on a clean machine without your dev toolchain before shipping." ;
    oc:hasRationale "Native dependencies or unbundled packages cause runtime failures that are invisible in development" ;
    oc:severityLevel "HIGH" .

oc:kn_cd5a7f2f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing tool handlers that read files or list directories" ;
    oc:directiveContent "Cap file reads, directory listings, and search results. Never return unbounded data — Claude will happily ask to read a 4GB log file." ;
    oc:hasRationale "Uncapped reads cause memory exhaustion and degrade the chat experience with enormous outputs" ;
    oc:severityLevel "MEDIUM" .

oc:kn_deedf3c4 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When handling API keys and other sensitive config values" ;
    oc:directiveContent "Config secrets (sensitive: true in user_config) are stored in OS keychain but delivered via env var. Never log them or include them in tool results — tool results flow into the chat transcript." ;
    oc:hasRationale "Chat transcripts are visible to users and log exports, creating secret exposure risk" ;
    oc:severityLevel "HIGH" .

