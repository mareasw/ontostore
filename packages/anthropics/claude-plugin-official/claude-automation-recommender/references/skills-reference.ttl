oc:kn_002b9839 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When configuring skill frontmatter" ;
    oc:directiveContent "Choose invocation control based on use case: default (both user and Claude), disable-model-invocation: true (user-only, for side effects), user-invocable: false (Claude-only, for background knowledge)." ;
    oc:hasRationale "Prevents unintended side effects from Claude auto-invoking deploy/send skills, while allowing background knowledge skills to operate silently" .

oc:kn_137ff5f8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When recommending skill creation" ;
    oc:directiveContent "Skills go in .claude/skills/<name>/SKILL.md. Each skill requires a SKILL.md file; optional supporting files include templates, scripts, and examples directories." ;
    oc:hasRationale "Consistent directory structure enables discoverability and maintainability of skills across projects" .

oc:kn_4ac248d8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When recommending skills for unfamiliar or niche codebases" ;
    oc:directiveContent "Use web search to find skill ideas specific to the codebase's tools and frameworks — do not limit recommendations to the patterns listed in the reference file." ;
    oc:hasRationale "The reference file contains common patterns only; codebase-specific recommendations are more valuable" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a56116d0 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When generating skill recommendations in Phase 2 of the recommender workflow" ;
    oc:directiveContent "1. Check for official plugin skills matching codebase signals (plugin-dev, commit-commands, frontend-design, hookify, feature-dev) 2. Identify custom skill opportunities from project structure (API routes, migrations, tests, components) 3. For each custom skill, determine invocation mode and whether it needs templates, scripts, or examples 4. Provide SKILL.md frontmatter and structure guidance" ;
    oc:stepOrder 1 .

oc:kn_a6a8284d a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Skills are created as .claude/skills/<name>/SKILL.md files; the .claude/ directory must exist in the project root" .

oc:kn_db3852e5 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When outputting skills section of recommendations report" ;
    oc:directiveContent """### 🎯 Skills

#### [skill name]
