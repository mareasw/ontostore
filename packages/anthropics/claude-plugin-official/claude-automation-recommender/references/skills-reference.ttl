@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_claude_automation_recommender_skills_reference a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "skills-reference" ;
    skos:broader "Reference catalog" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/claude-automation-recommender" ;
    oc:contentHash "b4b57d953526a07146d5757ca5332034b9b4b4eeba839e4bb08111398c94556f" ;
    oc:differentia "indexes official plugin skills and documents custom skill creation patterns with frontmatter, invocation control, templates, scripts, and examples" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_claude_automation_recommender ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_0a3cad53,
        oc:kn_2a92fcc3,
        oc:kn_307a32dd,
        oc:kn_4e4e8da3,
        oc:kn_d2aa3186 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "discover automation opportunities via skills",
        "find official plugin skills",
        "learn custom skill creation patterns",
        "recommend skills for a codebase",
        "understand skill structure and frontmatter options" .

oc:kn_0a3cad53 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When skills need current environment state" ;
    oc:directiveContent "Use dynamic context injection with !`command` backtick syntax to embed live data like git branch, status, or diff output directly into skill content before execution." ;
    oc:hasRationale "Live context injection ensures skills operate on up-to-date information without manual copying." .

oc:kn_2a92fcc3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or recommending custom skills" ;
    oc:directiveContent "Skills should be placed in .claude/skills/<name>/SKILL.md with optional subdirectories for templates/, scripts/, and examples/ to organize supporting materials." ;
    oc:hasRationale "Consistent directory structure enables Claude to discover and load skill resources predictably." .

oc:kn_307a32dd a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When designing skill invocation semantics" ;
    oc:directiveContent "Use frontmatter to control invocation: default allows both user and Claude; disable-model-invocation restricts to user-only for side effects; user-invocable: false restricts to Claude-only for background knowledge." ;
    oc:hasRationale "Proper invocation control prevents unintended side effects and keeps background knowledge invisible to users." .

oc:kn_4e4e8da3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing a codebase and recommending skills" ;
    oc:directiveContent "Match codebase signals to appropriate skills: building plugins → skill-development, git commits → commit, React/Vue/Angular → frontend-design, automation rules → writing-rules, feature planning → feature-dev." ;
    oc:hasRationale "Signal-based matching ensures recommendations are contextually relevant rather than generic." .

oc:kn_d2aa3186 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building skills that generate code or documents" ;
    oc:directiveContent "Skills can bundle templates (YAML, TSX), validation scripts (bash), and example files to ensure consistent output formats and enforce project conventions." ;
    oc:hasRationale "Bundled resources transform a skill from generic instructions into packaged expertise with reproducible outputs." .

