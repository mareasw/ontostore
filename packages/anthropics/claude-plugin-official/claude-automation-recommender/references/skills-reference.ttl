oc:kn_e4faf940 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating skill recommendations" ;
    oc:directiveContent "Match codebase signals to official plugin skills first (e.g., React/Vue → frontend-design, git commits → commit-commands), then recommend custom skills for project-specific needs (API routes → api-doc, database → create-migration, components → new-component)." ;
    oc:hasRationale "Official plugins provide battle-tested patterns; custom skills fill gaps specific to the project" .

oc:kn_f8ae66e5 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing SKILL.md frontmatter" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent "Skill frontmatter supports: name, description, disable-model-invocation, user-invocable, allowed-tools, context (fork for isolation), agent (type when forked). Use $ARGUMENTS for parameterized invocation and !`command` for dynamic context injection." ;
    oc:hasRationale "These frontmatter fields control how and when skills are invoked, and what tools they can access" .

