                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "### Learning & Guidance" ;
                                    oc:tableMarkdown """| Plugin | Best For | Key Features |
