                                    oc:contentOrder 1 ;
                                    oc:rowCount 1 ;
                                    oc:tableCaption "### Frontend" ;
                                    oc:tableMarkdown """| Plugin | Best For | Key Features |
|--------|----------|--------------|
| **frontend-design** | UI development | Production-grade UI, avoids generic aesthetics |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Frontend" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
