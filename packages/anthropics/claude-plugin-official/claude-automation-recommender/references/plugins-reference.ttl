oc:skill_anthropics_claude_plugin_official_claude_automation_recommender_plugins_reference a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "plugins-reference" ;
    skos:broader "Reference catalog" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/claude-automation-recommender" ;
    oc:contentHash "6570ff4c853253b3f15fb62e5d540cbf0ce3371936437791dde8fb53b7d444f3" ;
    oc:differentia "that maps Claude Code official plugins to use cases for recommendation during automation analysis" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_claude_automation_recommender ;
    oc:hasArgumentHint "codebase context or automation need" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_4cbcf480,
        oc:kn_817c43c9,
        oc:kn_97e532ea,
        oc:kn_ea1d3ed4,
        oc:kn_eef30f31 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "discover available Claude Code plugins",
        "guide plugin installation decisions",
        "match codebase signals to plugins",
        "recommend plugins for a codebase" .

oc:kn_4cbcf480 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing a codebase for automation recommendations" ;
    oc:directiveContent "Recommend plugins based on concrete codebase signals (language, workflow patterns, team needs) rather than blanket suggestions." ;
    oc:hasRationale "Targeted recommendations match real needs and avoid overwhelming users with irrelevant plugin options." ;
    oc:severityLevel "MEDIUM" .

oc:kn_817c43c9 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When deciding whether to suggest a plugin vs. individual skill/hook/command" ;
    oc:directiveContent "Recommend plugin installation specifically when: user wants Claude Code automations, needs multiple related capabilities, team wants standardized workflows, or it is a first-time Claude Code setup." ;
    oc:hasRationale "Plugins bundle related capabilities cohesively and provide team-standardized workflows, which individual automations do not." ;
    oc:severityLevel "MEDIUM" .

oc:kn_97e532ea a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before making any plugin recommendation" ;
    oc:directiveContent "Before recommending a plugin, verify it exists in the official repository and that its key features actually match the user's stated or inferred needs." ;
    oc:hasRationale "Recommending non-existent or poorly matched plugins erodes trust and wastes the user's time." ;
    oc:severityLevel "HIGH" .

oc:kn_ea1d3ed4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the official plugin catalog is insufficient for the user's requirements" ;
    oc:directiveContent "The listed plugins are from the official repository only; use web search to discover additional community plugins when the official list does not cover the user's needs." ;
    oc:hasRationale "The official catalog is limited; community plugins may address niche or emerging needs not yet represented officially." ;
    oc:severityLevel "LOW" .

oc:kn_eef30f31 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When matching a codebase to appropriate plugins" ;
    oc:directiveContent "Use the codebase signal → plugin mapping table as the primary decision heuristic: language detected → corresponding LSP plugin, PR workflow → pr-review-toolkit, UI code → frontend-design, automation desire → hookify." ;
    oc:hasRationale "The signal-based mapping provides fast, reliable recommendations without requiring deep analysis of every plugin." ;
    oc:severityLevel "MEDIUM" .

