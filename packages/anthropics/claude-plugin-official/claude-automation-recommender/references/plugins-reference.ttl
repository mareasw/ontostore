    oc:contentHash "6570ff4c853253b3f15fb62e5d540cbf0ce3371936437791dde8fb53b7d444f3" ;
    oc:differentia "that maps Claude Code plugins to codebase signals and use cases for recommendation during automation analysis" ;
    oc:extends oc:skill_claude_plugin_official_claude_automation_recommender ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Note**: These are plugins from the official repository. Use web search to discover additional community plugins." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Plugins are installable collections of skills, commands, agents, and hooks. Install via `/plugin install`." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Install a plugin
