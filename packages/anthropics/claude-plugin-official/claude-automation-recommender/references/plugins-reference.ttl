oc:kn_0a1b249e a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing Claude Code plugins" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """/plugin install <plugin-name>
/plugin list
/plugin info <plugin-name>""" .

oc:kn_0f71b8d4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining which plugins to recommend" ;
    oc:directiveContent "Use the Quick Reference table to match codebase signals (language, framework, workflow pattern) to the most relevant plugin before recommending individual skills." ;
    oc:hasRationale "Signal-based matching ensures recommendations are relevant to the user's actual tech stack rather than generic suggestions." .

oc:kn_72ca3128 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When recommending plugins during automation analysis" ;
    oc:directiveContent "1. Detect codebase signals (language, framework, workflow) → 2. Match signals to Quick Reference table → 3. Check if plugin covers needed capabilities → 4. Recommend /plugin install <name> → 5. Suggest web search for gaps" ;
    oc:stepOrder 1 .

oc:kn_77cb32d7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the listed plugins don't cover the user's needs" ;
    oc:directiveContent "This reference only covers official repository plugins. Use web search to discover additional community plugins not listed here." ;
    oc:hasRationale "The official repository is a subset of all available plugins; community plugins may address niche or emerging use cases." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7eb90b4f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing a codebase and recommending automations" ;
    oc:directiveContent "Recommend plugin installation when: user wants automations from official repository, needs multiple related capabilities, team wants standardized workflows, or first-time Claude Code setup." ;
    oc:hasRationale "Plugins bundle related skills/commands/agents/hooks together, making them more valuable than individual skill recommendations for team standardization." .

