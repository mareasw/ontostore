oc:kn_39f5b798 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a model for a subagent" ;
    oc:directiveContent "Use sonnet as the default model for most review/analysis subagents. Use haiku for simple repetitive checks. Reserve opus for complex migrations and architectural reasoning." ;
    oc:hasRationale "Balances quality, speed, and cost appropriately for each task complexity level" .

oc:kn_46aed3f0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring security-reviewer subagent" ;
    oc:directiveContent "Security reviewer subagents should use read-only tools (Read, Grep, Glob) only — never Write or Bash — to prevent accidental modifications to security-sensitive code." ;
    oc:hasRationale "Read-only access prevents unintended changes to auth, payment, or PII-handling code during security review" ;
    oc:severityLevel "HIGH" .

oc:kn_c00ff8d4 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating subagent configuration files" ;
    oc:directiveContent "Place subagent definitions in .claude/agents/ as individual markdown files (e.g., code-reviewer.md, security-reviewer.md)." ;
    oc:hasRationale "Consistent placement enables Claude to discover and invoke subagents automatically" .

oc:kn_c7c41b72 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When analyzing a codebase to recommend subagents" ;
    oc:directiveContent "Match subagent recommendations to detected codebase patterns: large codebase→code-reviewer, auth/payment code→security-reviewer, few tests→test-writer, API routes→api-documenter, database heavy→performance-analyzer, frontend components→ui-reviewer, outdated packages→dependency-updater, old framework→migration-helper." ;
    oc:hasRationale "Detection-driven recommendations ensure subagents are suggested only when relevant to the project" .

oc:kn_da9bf81d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When recommending subagents for a codebase" ;
    oc:directiveContent "Subagents run in parallel with their own context window and tool access; recommend them when detection criteria match the codebase characteristics." ;
    oc:hasRationale "Parallel execution allows reviews/analysis to proceed without blocking the main agent's work" ;
    oc:severityLevel "MEDIUM" .

