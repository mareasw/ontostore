oc:skill_anthropics_claude_plugin_official_claude_automation_recommender_mcp_servers a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "mcp-servers" ;
    skos:broader "MCP server recommendation guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/claude-automation-recommender" ;
    oc:contentHash "64a12ab24618e4987ba947638fb598683635e80db92f3253e87d5b06c878174d" ;
    oc:differentia "that maps codebase technologies to appropriate MCP servers for extending Claude's capabilities" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_claude_automation_recommender ;
    oc:handlesFailure oc:NoMatchingTechnologies ;
    oc:hasArgumentHint "codebase analysis or technology stack description" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_1a89862f,
        oc:kn_2ceef548,
        oc:kn_79b10976,
        oc:kn_8aa86ad3,
        oc:kn_a8697778 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CodebaseAnalyzed ;
    oc:resolvesIntent "find MCP servers that match detected technologies",
        "identify which MCP servers to configure for a team",
        "recommend MCP servers for a codebase",
        "suggest MCP server integrations based on project dependencies" ;
    oc:yieldsState oc:MCPServersRecommended .

oc:kn_1a89862f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When advising on MCP server setup and team sharing" ;
    oc:directiveContent "Recommend checking .mcp.json into git so the entire team shares the same MCP server configuration." ;
    oc:hasRationale "Checked-in config ensures consistent development environments across team members and reduces onboarding friction." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2ceef548 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the codebase uses services not covered by the standard MCP server list" ;
    oc:directiveContent "The listed MCP servers are common ones; use web search to find MCP servers specific to the codebase's services and integrations." ;
    oc:hasRationale "The MCP ecosystem is growing rapidly and project-specific integrations may exist beyond the well-known servers." ;
    oc:severityLevel "MEDIUM" .

oc:kn_79b10976 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the codebase uses well-known frameworks (React, Express, Prisma, etc.) or third-party APIs (Stripe, Twilio, AWS SDK)" ;
    oc:directiveContent "Prefer context7 MCP for projects using popular libraries/SDKs so Claude fetches live documentation instead of relying on potentially outdated training data." ;
    oc:hasRationale "Live documentation reduces hallucinated APIs and outdated patterns, which are common when working with rapidly evolving libraries." ;
    oc:severityLevel "HIGH" .

oc:kn_8aa86ad3 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When MCP servers are not connecting or behaving unexpectedly" ;
    oc:directiveContent "Use `claude --mcp-debug` to identify and diagnose MCP server configuration issues." ;
    oc:hasRationale "The debug flag provides visibility into MCP connection lifecycle, helping quickly isolate misconfigurations." ;
    oc:severityLevel "LOW" .

oc:kn_a8697778 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing a codebase to recommend MCP servers" ;
    oc:directiveContent "Match MCP server recommendations to detected dependencies and technologies in the codebase (e.g., @supabase/supabase-js → Supabase MCP, @aws-sdk/* → AWS MCP, @sentry/* → Sentry MCP)." ;
    oc:hasRationale "Recommendations based on actual dependencies are far more relevant than generic suggestions and demonstrate understanding of the project." ;
    oc:severityLevel "HIGH" .

