oc:kn_388ba872 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When any popular framework or SDK is detected in dependencies" ;
    oc:directiveContent "context7 is the primary MCP server for reducing hallucinated APIs — recommend it whenever the project uses popular libraries/SDKs." ;
    oc:hasRationale "Live documentation fetching significantly reduces outdated or fabricated API usage patterns." ;
    oc:severityLevel "HIGH" .

oc:kn_42476d5a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the codebase uses niche or lesser-known services" ;
    oc:directiveContent "Do not rely solely on this catalog — use web search to find MCP servers specific to the codebase's services and integrations that may not be listed here." ;
    oc:hasRationale "This catalog covers common MCP servers only; specialized services may have dedicated MCP servers available." ;
    oc:severityLevel "MEDIUM" .

oc:kn_af38e078 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before recommending MCP servers" ;
    oc:directiveContent "MCP server configuration requires one of three connection methods: project config (.mcp.json), global config (~/.claude.json), or checked-in .mcp.json." ;
    oc:hasRationale "Understanding available connection methods determines how recommendations should be implemented." ;
    oc:severityLevel "LOW" .

oc:kn_cf67d638 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring MCP server connections" ;
    oc:directiveContent "Prefer checked-in .mcp.json for team-wide MCP configuration so all team members get the same servers automatically." ;
    oc:hasRationale "Checked-in config ensures consistency across the team and reduces per-developer setup friction." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f56cc5f9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing a codebase for MCP recommendations" ;
    oc:directiveContent "Match MCP server recommendations to detected dependencies and tech stack — use the detection patterns quick reference table for fast lookup." ;
    oc:hasRationale "Pattern-based detection ensures relevant, useful MCP server suggestions rather than generic recommendations." ;
    oc:severityLevel "HIGH" .

oc:kn_fae1f5ee a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When MCP servers fail to connect or behave unexpectedly" ;
    oc:directiveContent "Use `claude --mcp-debug` to identify and diagnose MCP configuration issues when servers aren't connecting properly." ;
    oc:hasRationale "The debug flag surfaces configuration parsing errors, connection failures, and permission issues." ;
    oc:severityLevel "MEDIUM" .

