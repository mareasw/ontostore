oc:kn_059160b3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user's project uses tools not covered by the catalog" ;
    oc:directiveContent "For tools/frameworks not listed in the patterns, use web search to find appropriate hooks before recommending" ;
    oc:hasRationale "The catalog covers common patterns only; less common tools need current, accurate hook configurations" .

oc:kn_1044fa6c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring Edit/Write hooks" ;
    oc:directiveContent "Never recommend hooks that directly edit lock files (package-lock.json, yarn.lock, pnpm-lock.yaml, Cargo.lock, poetry.lock, Pipfile.lock) — these should only change via package managers" ;
    oc:hasRationale "Direct lock file edits corrupt dependency trees and cause reproducibility failures" ;
    oc:severityLevel "CRITICAL" .

oc:kn_230cf4ad a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding hook type for a recommendation" ;
    oc:directiveContent "Use PostToolUse hooks for reactive automation (formatting, linting, testing after edits) and PreToolUse hooks for proactive enforcement (blocking edits to sensitive/lock files)" ;
    oc:hasRationale "PostToolUse enriches output without blocking flow; PreToolUse prevents damage before it occurs" .

oc:kn_3528ec12 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing a codebase to recommend hooks" ;
    oc:directiveContent "Map detected config files to hook recommendations: .prettierrc → auto-format, .eslintrc → auto-lint, pyproject.toml with black/ruff → Python formatting, tsconfig.json → type-check, test directories → test runner hooks, .env files → block edits, lock files → block edits, go.mod → gofmt, Cargo.toml → rustfmt" ;
    oc:hasRationale "Each config file signals an established toolchain; hooking into it provides immediate automated value without changing developer workflow" ;
    oc:severityLevel "HIGH" .

oc:kn_511bfb9c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When recommending hooks for any project" ;
    oc:directiveContent "1. Scan project for config files (prettierrc, eslintrc, pyproject.toml, tsconfig.json, etc.) 2. Match detections to hook patterns (auto-format, type-check, protect, test, notify) 3. Generate PostToolUse hooks for formatting/linting/testing, PreToolUse hooks for protection 4. Configure notification hooks if user multitasks 5. Write hooks to .claude/settings.json" ;
    oc:stepOrder 1 .

oc:kn_84097a8d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When configuring notification hooks" ;
    oc:directiveContent "Available notification matchers: permission_prompt (tool permission needed), idle_prompt (waiting 60+ sec), auth_success (authentication succeeds), elicitation_dialog (MCP tool needs input)" ;
    oc:hasRationale "Using correct matchers ensures hooks fire at the right moments" .

oc:kn_9c7cfb10 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing hook configurations" ;
    oc:directiveContent "Hooks are configured in .claude/settings.json. Recommend creating the .claude/ directory if it doesn't exist." ;
    oc:hasRationale "Claude Code only reads hook configurations from this specific location" ;
    oc:severityLevel "HIGH" .

oc:kn_cb2ba27b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring protection hooks" ;
    oc:directiveContent "Never recommend hooks that allow editing sensitive files (.env, .env.local, .env.production, credentials.json, secrets.yaml) or .git/ internals" ;
    oc:hasRationale "Accidental secret exposure or git corruption can cause irreversible damage" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e3a7c0d2 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring notification hooks for permission prompts and idle alerts" ;
    oc:codeLanguage "json" ;
    oc:directiveContent """{
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [{ "type": "command", "command": "afplay /System/Library/Sounds/Ping.aiff" }]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [{ "type": "command", "command": "osascript -e 'display notification ...'" }]
      }
    ]
  }
}""" .

oc:req_5dee6df3 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Claude Code hooks configuration format and settings.json structure" .

