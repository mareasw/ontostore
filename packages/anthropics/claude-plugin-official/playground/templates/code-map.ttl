@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_playground_code_map a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "code-map" ;
    skos:broader "Playground template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/playground" ;
    oc:contentHash "0eb7c0d1ac3dbd1401c4a2348631e7be2a02ec30739dd514aab6f162cfade77f" ;
    oc:differentia "Visualizes codebase architecture as an interactive SVG diagram with component nodes, typed connections, layer filtering, and click-to-comment feedback system" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_playground ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "codebase architecture description or project name" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_186c61bf,
        oc:kn_2ea02fff,
        oc:kn_4a3456b3,
        oc:kn_75336323,
        oc:kn_b414c828 ;
    oc:isUserInvocable true ;
    oc:nature "Template" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create interactive architecture diagrams with feedback",
        "explore system architecture by layers",
        "map component relationships and data flow",
        "visualize codebase architecture" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_186c61bf a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When implementing the click-to-comment system" ;
    oc:directiveContent "Include component context (node label, file path) in every comment object so feedback is traceable to specific code locations." ;
    oc:hasRationale "Comments without component context lose their architectural meaning; including file paths makes feedback actionable for developers." .

oc:kn_2ea02fff a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When styling connections in the code map" ;
    oc:directiveContent "Define 3-5 connection types with distinct colors and dash patterns: data-flow (blue solid), tool-call (green dashed), event (red short dash), skill-invoke (orange long dash), dependency (gray dotted)." ;
    oc:hasRationale "Distinct visual styles per connection type allow users to quickly distinguish data flows from events, tool calls, and dependencies in complex architectures." .

oc:kn_4a3456b3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering the SVG canvas diagram" ;
    oc:directiveContent "Render SVG connections before nodes so that connection paths appear beneath node rectangles, ensuring clean layering." ;
    oc:hasRationale "Drawing connections under nodes prevents arrow paths from visually overlapping component boxes, improving readability." .

oc:kn_75336323 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating a code map for a specific project" ;
    oc:directiveContent "Pre-populate real codebase maps with 15-25 key component nodes and 20-40 relationships, organized into logical layer groupings." ;
    oc:hasRationale "This density provides enough detail to be useful without overwhelming the SVG canvas or making the diagram unreadable." .

oc:kn_b414c828 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When laying out nodes on the SVG canvas" ;
    oc:directiveContent "Organize nodes in horizontal Y-position bands by layer (e.g., y:30-80 = Client, y:130-180 = Server) with consistent spacing." ;
    oc:hasRationale "Layer-based Y-banding creates a natural top-to-bottom reading flow that mirrors typical system architecture (client → server → data)." .

