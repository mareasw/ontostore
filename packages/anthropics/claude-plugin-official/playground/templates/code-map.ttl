oc:kn_20956ad7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering code map playgrounds" ;
    oc:directiveContent "Use SVG canvas for architecture diagrams with dynamically generated nodes (rounded rectangles) and curved bezier connections with arrow markers, grouped by layer in horizontal Y-position bands." ;
    oc:hasRationale "SVG provides scalable, interactive rendering that supports click events on individual components and smooth zoom/pan controls." .

oc:kn_65f551d8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning visual styles to architectural layers" ;
    oc:directiveContent "Use the layer color palette for node fills: Client/UI=#dbeafe, Server/API=#fef3c7, SDK/Core=#f3e8ff, Agent/Logic=#dcfce7, Data=#fce7f3, External=#fbcfe8." .

oc:kn_9aad8eeb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering the SVG diagram" ;
    oc:directiveContent "Do not draw nodes before connections — always render connections first (underneath), then nodes on top." ;
    oc:hasRationale "Connections drawn after nodes would overlap and obscure node content, breaking visual clarity." .

oc:kn_ab163a02 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining connection types for code maps" ;
    oc:directiveContent "Define 3-5 connection types with distinct colors and dash styles (solid, dashed, short-dash, long-dash, dotted) to differentiate data-flow, tool-call, event, skill-invoke, and dependency relationships." ;
    oc:hasRationale "Visual distinction between connection types is essential for users to understand different kinds of relationships in the architecture at a glance." ;
    oc:severityLevel "HIGH" .

oc:kn_addda762 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing the click-to-comment system" ;
    oc:directiveContent "1. Click node → open modal with component name, file path, textarea. 2. Save comment → add to comments list, mark node with colored border indicator. 3. View comments → sidebar list with component name, preview, delete button. 4. Delete comment → remove from list, update node visual, regenerate prompt." ;
    oc:stepOrder 1 .

oc:kn_f532c185 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building code maps for real projects" ;
    oc:directiveContent "Pre-populate with 15-25 key components and 20-40 relationships based on actual imports/calls when visualizing a specific codebase." ;
    oc:hasRationale "Too few nodes undersells the architecture; too many overwhelms the visual. 15-25 components is the sweet spot for readable diagrams." .

