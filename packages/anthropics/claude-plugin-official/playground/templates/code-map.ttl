                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Filtering:** Toggle visibility of nodes by layer, connections by type" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
