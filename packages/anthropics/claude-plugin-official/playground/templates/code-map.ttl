                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Use SVG markers for arrowheads:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Connection types and styling" ],
