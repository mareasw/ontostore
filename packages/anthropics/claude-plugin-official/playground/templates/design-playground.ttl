@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_playground_design_playground a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "design-playground" ;
    skos:broader "Playground" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/playground" ;
    oc:contentHash "190f7da424ebd3226a679045420b64171a98d081b7d84e26be4553de13c91fe7" ;
    oc:differentia "Focused on visual design decisions including components, layouts, spacing, color, typography, animation, and responsive behavior with live preview rendering and developer-oriented prompt output" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_playground ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "Read",
        "Write" ;
    oc:hasArgumentHint "design topic or component to explore (e.g., button styles, card component, layout builder, typography scale)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_2b59cd77,
        oc:kn_5636046c,
        oc:kn_bfdc61e0,
        oc:kn_eec5496d,
        oc:kn_f1514dd4 ;
    oc:isUserInvocable true ;
    oc:nature "Template" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build interactive design playgrounds for components",
        "configure spacing color typography and layout properties visually",
        "explore visual design decisions interactively",
        "generate developer-ready design direction prompts",
        "preview component styling with live controls" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_2b59cd77 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing preview rendering for design playgrounds" ;
    oc:directiveContent "Apply state values directly to preview elements via inline styles so changes are instantly visible without re-rendering or compilation." ;
    oc:hasRationale "Immediate visual feedback is essential for design exploration; any delay between control change and visual result breaks the creative flow." .

oc:kn_5636046c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the control panel for a design playground" ;
    oc:directiveContent "Group controls by design decision category: Spacing, Color, Typography, Shadow/Border, and Interaction — each mapped to the most intuitive control type (slider for sizes, toggle for on/off, dropdown for sets, HSL sliders for colors, clickable cards for layout, viewport-width slider for responsive)." ;
    oc:hasRationale "Grouping by decision category reduces cognitive load and makes the relationship between controls and visual outcomes immediately clear." .

oc:kn_bfdc61e0 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating the copyable prompt output from design playground state" ;
    oc:directiveContent "Frame the prompt output as a natural-language direction to a developer, not a dry spec sheet. Adapt the format to the user's framework — Tailwind classes for Tailwind projects, raw CSS properties for vanilla CSS." ;
    oc:hasRationale "Developer-friendly output that matches their workflow reduces friction between design exploration and implementation." .

oc:kn_eec5496d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering live component previews" ;
    oc:directiveContent "Show the preview on both light and dark backgrounds when relevant, and include a context toggle so the user can verify their design works across themes." ;
    oc:hasRationale "Designs that look good on one background may fail on another; dual-preview prevents unpleasant surprises at implementation time." .

oc:kn_f1514dd4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring the playground page layout" ;
    oc:directiveContent "Use the two-panel layout: left side for grouped controls, right side split between live preview and prompt output with a copy button." ;
    oc:hasRationale "This layout keeps controls and results co-visible, enabling real-time adjustment without context switching." ;
    oc:severityLevel "MEDIUM" .

