@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_claude_plugin_official_playground_data_explorer a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "data-explorer" ;
    skos:broader "Playground template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/playground" ;
    oc:contentHash "4b884e4b400f3af82b7f33210c5c2017a5296cab16f1496963bd42061a1fe342" ;
    oc:differentia "that provides a structured data query/configuration builder layout with controls panel and syntax-highlighted output for SQL, API, pipeline, or regex playgrounds" ;
    oc:extends oc:skill_claude_plugin_official_playground ;
    oc:hasArgumentHint "topic type (sql-builder, api-designer, pipeline, regex, cron, graphql)" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Use this template when the playground is about data queries, APIs, pipelines, or structured configuration: SQL builders, API designers, regex builders, pipeline visuals, cron schedules." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 6 ;
                            oc:tableCaption "## Control types by decision" ;
                            oc:tableMarkdown """| Decision | Control | Example |
|---|---|---|
| Select from available items | Clickable cards/chips | table names, columns, HTTP methods |
| Add filter/condition rows | Add button → row of dropdowns + input | WHERE column op value |
| Join type or aggregation | Dropdown per row | INNER/LEFT/RIGHT, COUNT/SUM/AVG |
| Limit/offset | Slider | result count 1–500 |
| Ordering | Dropdown + ASC/DESC toggle | order by column |
| On/off features | Toggle | show descriptions, include header |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Control types by decision" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Data transformation pipeline (source → filter → map → aggregate → output)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "API endpoint designer (routes, methods, request/response field builder)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "SQL query builder (tables, joins, filters, group by, order by, limit)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Regex builder (sample strings, match groups, live highlight)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "GraphQL query builder (type selection, field picker, nested resolvers)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Cron schedule builder (visual timeline, interval, day toggles)" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Example topics" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """+-------------------+----------------------+
|                   |                      |
|  Controls         |  Formatted output    |
|  grouped by:      |  (syntax-highlighted |
|  • Source/tables  |   code, or a         |
|  • Columns/fields |   visual diagram)    |
|  • Filters        |                      |
|  • Grouping       |                      |
|  • Ordering       |                      |
|  • Limits         |                      |
|                   +----------------------+
|                   |  Prompt output       |
|                   |  [ Copy Prompt ]     |
+-------------------+----------------------+
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 7-22" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Layout" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Frame it as a specification of what to build, not the raw query itself:" ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent "\"Write a SQL query that joins orders to users on user_id, filters for orders after 2024-01-01 with total > $50, groups by user, and returns the top 10 users by order count.\"" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Include the schema context (table names, column types) so the prompt is self-contained." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Prompt output for data" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Render syntax-highlighted output using `<span>` tags with color classes:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """function renderPreview() {
  const el = document.getElementById('preview');
  // Color-code by token type
  el.innerHTML = sql
    .replace(/\\b(SELECT|FROM|WHERE|JOIN|ON|GROUP BY|ORDER BY|LIMIT)\\b/g, '<span class="kw">$1</span>')
    .replace(/\\b(users|orders|products)\\b/g, '<span class="tbl">$1</span>')
    .replace(/'[^']*'/g, '<span class="str">$&</span>');
}
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 39-48" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "For pipeline-style playgrounds, render a horizontal or vertical flow diagram using positioned divs with arrow connectors." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Preview rendering" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Data Explorer Template" ] ;
    oc:impartsKnowledge oc:kn_0278f617,
        oc:kn_11fe9d26,
        oc:kn_23a167d1,
        oc:kn_3f7a822d,
        oc:kn_5c04e8a0,
        oc:kn_bd6c0205 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:resolvesIntent "build data pipeline visual playgrounds",
        "build data query playgrounds",
        "create SQL builder interfaces",
        "create regex builder playgrounds",
        "design API endpoint builder UIs" .

oc:kn_0278f617 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the prompt output section" ;
    oc:directiveContent "Do not output the raw query as the prompt; instead frame it as a natural-language specification of what to build, including schema context (table names, column types) so the prompt is self-contained." ;
    oc:hasRationale "A specification prompt is more useful to an LLM than raw query text, and self-contained prompts avoid missing context errors" ;
    oc:severityLevel "HIGH" .

oc:kn_11fe9d26 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building data transformation or pipeline playgrounds" ;
    oc:directiveContent "For pipeline-style playgrounds, render a horizontal or vertical flow diagram using positioned divs with arrow connectors to visualize source → filter → map → aggregate → output." ;
    oc:hasRationale "Visual flow diagrams make multi-stage transformations immediately comprehensible" .

oc:kn_23a167d1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoping what the data explorer template supports" ;
    oc:directiveContent "The playground must handle these topic types: SQL query builder, API endpoint designer, data transformation pipeline, regex builder, cron schedule builder, GraphQL query builder." ;
    oc:hasRationale "The template is designed for structured data/configuration scenarios, not freeform content creation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3f7a822d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing UI controls for data configuration options" ;
    oc:directiveContent "Match control type to decision type: clickable cards/chips for selecting available items, add-button rows of dropdowns+input for filter conditions, dropdowns for join/aggregation type, sliders for limit/offset, dropdown+toggle for ordering, toggles for on/off features." ;
    oc:hasRationale "Each decision type maps to a control that minimizes cognitive load and prevents invalid input" .

oc:kn_5c04e8a0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any data explorer playground" ;
    oc:directiveContent "Use a two-column layout: left panel for grouped controls (source/tables, columns/fields, filters, grouping, ordering, limits), right panel split between syntax-highlighted output and a prompt output area with a Copy Prompt button." ;
    oc:hasRationale "Separates input configuration from output preview, giving users a clear mental model of query construction" ;
    oc:severityLevel "HIGH" .

oc:kn_bd6c0205 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering SQL preview output" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent "Use regex-based token replacement with <span> class tags to render syntax-highlighted SQL: keywords get class 'kw', table names get 'tbl', string literals get 'str'." ;
    oc:hasRationale "Client-side syntax highlighting avoids external dependencies and keeps the playground self-contained" .

