@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_playground_data_explorer a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "data-explorer" ;
    skos:broader "Interactive template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/playground" ;
    oc:contentHash "4b884e4b400f3af82b7f33210c5c2017a5296cab16f1496963bd42061a1fe342" ;
    oc:differentia "generates data query/exploration playgrounds with structured controls, syntax-highlighted preview, and self-contained prompt output for SQL, API, pipeline, and configuration builders" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_playground ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "data playground topic (e.g., SQL builder, API designer, regex builder)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_258dd658,
        oc:kn_527f9e8c,
        oc:kn_675f0ede,
        oc:kn_80d5d72f,
        oc:kn_9bea3755 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build GraphQL query builder",
        "build SQL query playground",
        "build regex tester playground",
        "create API endpoint designer",
        "create cron schedule builder",
        "design data transformation pipeline visualizer" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_258dd658 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When rendering code previews in the output panel" ;
    oc:directiveContent "Render syntax-highlighted preview output using span tags with color classes, tokenizing keywords, table names, and string literals separately." ;
    oc:hasRationale "Syntax highlighting makes generated queries, API specs, and pipelines immediately readable and verifiable." ;
    oc:severityLevel "MEDIUM" .

oc:kn_527f9e8c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the copyable prompt output for data playgrounds" ;
    oc:directiveContent "Frame the prompt output as a natural-language specification of what to build, including schema context (table names, column types), not the raw query itself." ;
    oc:hasRationale "A self-contained specification prompt enables any LLM to reproduce the intended query without needing access to the playground state." ;
    oc:severityLevel "HIGH" .

oc:kn_675f0ede a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any data explorer playground" ;
    oc:directiveContent "Use a two-panel layout with grouped controls on the left and syntax-highlighted output plus prompt output on the right." ;
    oc:hasRationale "Separates configuration from output so users can iterate on decisions without losing context of the generated result." ;
    oc:severityLevel "HIGH" .

oc:kn_80d5d72f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing control types for data playground UI elements" ;
    oc:directiveContent "Match each user decision type to an appropriate control: clickable cards/chips for selection, add-button rows for filter conditions, dropdowns for joins/aggregations, sliders for limits, toggles for on/off features." ;
    oc:hasRationale "Correct control-to-decision mapping reduces cognitive load and prevents invalid configurations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9bea3755 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building data transformation pipeline or workflow playgrounds" ;
    oc:directiveContent "For pipeline-style playgrounds, render a horizontal or vertical flow diagram using positioned divs with arrow connectors rather than raw text." ;
    oc:hasRationale "Visual flow diagrams communicate transformation pipelines more intuitively than linear text representations." ;
    oc:severityLevel "LOW" .

