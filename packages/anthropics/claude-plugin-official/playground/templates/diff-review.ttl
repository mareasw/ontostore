oc:kn_2c122779 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning identifiers to diff lines for comment tracking" ;
    oc:directiveContent "Use unique compound line IDs (e.g., '0-1-5' for file 0, hunk 1, line 5) to avoid collisions when multiple files and hunks exist in the same diff." ;
    oc:hasRationale "Simple sequential numbering would collide across files or hunks, breaking comment association" .

oc:kn_6c6bc5d5 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parsing and rendering git diff output" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent "Structure diff data as: [{ file: 'path', hunks: [{ header: '@@ ... @@', lines: [{ type: 'context'|'addition'|'deletion', oldNum, newNum, content }] }] }]" ;
    oc:hasRationale "Normalized structure enables consistent rendering of additions, deletions, and context lines with proper styling" .

oc:kn_83b5efd1 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When pre-populating the playground with a real commit" ;
    oc:directiveContent "1. Run `git show <commit> --format='%H%n%s%n%an%n%ad' -p` to get diff data. 2. Parse output into the diffData structure (files → hunks → lines). 3. Render commit metadata in header section. 4. Render diff lines with type-based styling." ;
    oc:hasRationale "Structured parsing ensures all metadata and diff hunks are captured for interactive review" ;
    oc:stepOrder 1 .

oc:kn_9cf6b34e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling diff line types" ;
    oc:directiveContent "Support both light and dark themes with specific color values: additions use green (#dafbe1 / rgba(46,160,67,0.15)), deletions use red (#ffebe9 / rgba(248,81,73,0.15)), hunk headers use blue (#ddf4ff)." ;
    oc:hasRationale "Consistent, accessible color coding ensures added/removed/unchanged lines are immediately distinguishable in both themes" .

oc:kn_a38d086d a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating the prompt output from user comments" ;
    oc:directiveContent """Code Review Comments:

📍 {file}:{lineNum}
   Code: {content}
   Comment: {userComment}

""" ;
    oc:hasRationale "Structured format with emoji markers makes comments easy to parse in downstream review workflows" ;
    oc:templateVariables "content",
        "file",
        "lineNum",
        "userComment" .

oc:kn_d9e4ae5e a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating line elements in the DOM" ;
    oc:directiveContent "Each diff line must carry data attributes: data-line-id (unique), data-file (file path), data-line-num (line number), data-content (line text) for prompt generation." ;
    oc:hasRationale "These attributes enable the prompt output to reconstruct file:line context for each comment" ;
    oc:severityLevel "HIGH" .

oc:kn_eac79ce6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the diff review playground layout" ;
    oc:directiveContent "Use a two-panel layout: left sidebar for commit metadata (hash, message, author, date), main area for diff content with file hunks and line numbers." ;
    oc:hasRationale "Mirrors familiar code review interfaces (GitHub, GitLab) for immediate user familiarity" ;
    oc:severityLevel "MEDIUM" .

