@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_playground_concept_map a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "concept-map" ;
    skos:broader "Playground template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/playground" ;
    oc:contentHash "153810786435a1f3e3948aba075ebf3c887df827464bebca61f48ce7974e9622" ;
    oc:differentia "generates interactive concept map canvases for learning, exploration, and relationship mapping with draggable nodes, edges, and knowledge-level tagging" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_playground ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "topic or domain to map (e.g., codebase name, framework, system design)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_3ac4f065,
        oc:kn_3b14a9b3,
        oc:kn_57ed9fec,
        oc:kn_a2042d1f,
        oc:kn_ea631b9a ;
    oc:isUserInvocable true ;
    oc:nature "Template" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create concept map playground",
        "decompose tasks with dependency mapping",
        "explore codebase architecture visually",
        "identify knowledge gaps in a domain",
        "map knowledge relationships interactively" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_3ac4f065 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing canvas rendering for concept maps" ;
    oc:directiveContent "Render edges first (underneath nodes) and nodes on top using clear separation in the draw loop: edges.forEach then nodes.forEach." ;
    oc:hasRationale "Drawing edges first ensures nodes always appear visually on top and are not obscured by crossing edges, maintaining readability." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3b14a9b3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating the prompt output from a concept map" ;
    oc:directiveContent "Only include user-drawn edges and only mention concepts marked as 'fuzzy' or 'unknown' in the generated prompt output — never hallucinate relationships or knowledge states the user didn't specify." ;
    oc:hasRationale "The prompt must be a targeted learning request shaped entirely by the user's own markings to ensure the explanation is relevant and builds on their actual knowledge." ;
    oc:severityLevel "CRITICAL" .

oc:kn_57ed9fec a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building concept map playgrounds" ;
    oc:directiveContent "Use a canvas-based layout with draggable nodes and edge drawing as the primary interaction, supplemented by a sidebar with toggles and list controls — not the standard two-panel split." ;
    oc:hasRationale "Canvas-based playgrounds make the interactive visual the primary control, enabling spatial layout that reflects the user's mental model rather than abstract slider adjustments." ;
    oc:severityLevel "HIGH" .

oc:kn_a2042d1f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing knowledge level controls for concept map nodes" ;
    oc:directiveContent "Implement knowledge levels as a three-state cycle (Know → Fuzzy → Unknown) per node, using click-to-cycle buttons in the sidebar list for quick toggling." ;
    oc:hasRationale "A simple three-state cycle is faster than dropdowns or modals, enabling rapid marking of many nodes during a learning session." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ea631b9a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating concept maps for codebases or domains" ;
    oc:directiveContent "Pre-populate concept maps with 15-20 key concepts and 20-30 pre-drawn relationships based on actual architecture, defaulting all knowledge levels to 'Fuzzy' so users adjust from a meaningful baseline." ;
    oc:hasRationale "Starting with real data and a neutral default ('Fuzzy') gives users a substantive starting point and reduces blank-canvas paralysis while preserving user agency in marking actual knowledge." ;
    oc:severityLevel "MEDIUM" .

