@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_claude_plugin_official_playground_concept_map a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "concept-map" ;
    skos:broader "Playground template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/playground" ;
    oc:contentHash "153810786435a1f3e3948aba075ebf3c887df827464bebca61f48ce7974e9622" ;
    oc:differentia "that generates interactive concept maps with draggable nodes, knowledge-level tagging, and relationship edges for learning and exploration" ;
    oc:extends oc:skill_claude_plugin_official_playground ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "automation" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Use this template when the playground is about learning, exploration, or mapping relationships: concept maps, knowledge gap identification, scope mapping, task decomposition with dependencies." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Canvas-based playgrounds differ from the two-panel split. The interactive visual IS the control — users drag nodes and draw connections rather than adjusting sliders. The sidebar supplements with toggles and list controls." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """+--------------------------------------+
|  Canvas (draggable nodes, edges)     |
|  with tooltip on hover               |
+-------------------------+------------+
|                         |            |
|  Sidebar:               | Prompt     |
|  • Knowledge levels     | output     |
|  • Connection types     |            |
|  • Node list            | [Copy]     |
|  • Actions              |            |
+-------------------------+------------+
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 7-19" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Layout" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Framework learning (how React hooks connect, Next.js data fetching layers)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Codebase architecture map (modules, data flow, state management)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "API surface map (endpoints grouped by resource, shared middleware, auth layers)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "System design (services, databases, queues, caches and how they relate)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Task decomposition (goals → sub-tasks with dependency arrows, knowledge tags)" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Example topics" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use a `<canvas>` element with manual draw calls. Key patterns:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Tooltips:** On hover, position a div absolutely over the canvas with description text" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Hit testing:** Check mouse position against node bounding circles on mousedown/mousemove" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Force-directed auto-layout:** Simple spring simulation — repulsion between all pairs, attraction along edges, iterate 100-200 times with damping" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Drag:** On mousedown on a node, track offset and update position on mousemove" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Edge drawing:** Click node A, then click node B. Draw arrow between them with the selected relationship type" ] ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """function draw() {
  ctx.clearRect(0, 0, W, H);
  edges.forEach(e => drawEdge(e));  // edges first, under nodes
  nodes.forEach(n => drawNode(n));  // nodes on top
}
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 43-49" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Canvas rendering" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 5 ;
                            oc:tableCaption "## Control types for concept maps" ;
                            oc:tableMarkdown """| Decision | Control | Example |
|---|---|---|
| Knowledge level per node | Click-to-cycle button in sidebar list | Know → Fuzzy → Unknown |
| Connection type | Selector before drawing | calls, depends on, contains, reads from |
| Node arrangement | Drag on canvas | spatial layout reflects mental model |
| Which nodes to include | Toggle or checkbox per node | hide/show concepts |
| Actions | Buttons | Auto-layout (force-directed), clear edges, reset |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Control types for concept maps" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Knowledge:** Default all to \"Fuzzy\" so the user adjusts from there" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Presets:** \"Zoom out\" (hide internal nodes, show only top-level), \"Focus on [layer]\" (highlight nodes in one area)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Nodes:** 15-20 key concepts with real file paths and short descriptions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Edges:** 20-30 pre-drawn relationships based on actual architecture" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "For codebases or domains, pre-populate with:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Pre-populating with real data" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The prompt should be a targeted learning request shaped by the user's knowledge markings:" ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent "\"I'm learning [CODEBASE/DOMAIN]. I already understand: [know nodes]. I'm fuzzy on: [fuzzy nodes]. I have no idea about: [unknown nodes]. Here are the relationships I want to understand: [edge list in natural language]. Please explain the fuzzy and unknown concepts, focusing on these relationships. Build on what I already know. Use concrete code references.\"" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Only include edges the user drew. Only mention concepts they marked as fuzzy or unknown in the explanation request." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Prompt output for concept maps" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Concept Map Template" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Create an interactive concept map playground from a domain or codebase" ;
            oc:hasStep _:ref_2d13aca7cec24f0a,
                [ a oc:WorkflowStep ;
                    dcterms:description "Generate targeted learning prompt from user's knowledge markings and drawn edges" ;
                    oc:expectedOutcome "Copyable prompt text requesting explanation of fuzzy/unknown concepts" ;
                    oc:stepDependsOn _:ref_f5eaea93406d189b ;
                    oc:stepId "cm-5" ],
                _:ref_9af6e14c5c60efe1,
                [ a oc:WorkflowStep ;
                    dcterms:description "Set default knowledge level for all nodes to 'Fuzzy' and create presets for zoom/focus views" ;
                    oc:expectedOutcome "Default state that users can adjust from" ;
                    oc:stepDependsOn _:ref_2d13aca7cec24f0a ;
                    oc:stepId "cm-3" ],
                _:ref_f5eaea93406d189b ;
            oc:workflowId "concept-map-build" ;
            oc:workflowName "Build Concept Map Playground" ] ;
    oc:impartsKnowledge oc:kn_21cfc667,
        oc:kn_4fee9ce2,
        oc:kn_a17a3d7e,
        oc:kn_c2199db1,
        oc:kn_cdbbe265,
        oc:kn_dec94170,
        oc:kn_e224a858 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create concept map",
        "decompose tasks with dependency visualization",
        "explore domain architecture visually",
        "identify knowledge gaps",
        "map knowledge relationships" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_21cfc667 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating prompt output" ;
    oc:directiveContent "Only include edges the user actually drew and only mention concepts marked as fuzzy or unknown in the explanation request prompt." ;
    oc:hasRationale "Including unrelated edges or already-known concepts dilutes the learning focus and wastes the LLM's context window." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4fee9ce2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing canvas interaction and force-directed layout" ;
    oc:directiveContent "Use hit testing against node bounding circles on mousedown/mousemove for interaction detection; for auto-layout, run a simple spring simulation with repulsion between all pairs and attraction along edges for 100-200 iterations with damping." ;
    oc:hasRationale "Spring simulations with damping produce readable spatial layouts that group related concepts while keeping unrelated ones apart." .

oc:kn_a17a3d7e a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing edge creation and tooltip display on the concept map canvas" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent "Edge drawing: Click node A, then click node B. Draw arrow between them with selected relationship type. Tooltips: On hover, position a div absolutely over canvas with description text." .

oc:kn_c2199db1 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering the concept map canvas — always draw edges before nodes so nodes appear on top" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """function draw() {
  ctx.clearRect(0, 0, W, H);
  edges.forEach(e => drawEdge(e));  // edges first, under nodes
  nodes.forEach(n => drawNode(n));  // nodes on top
}""" .

oc:kn_cdbbe265 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building concept map playgrounds" ;
    oc:directiveContent "Canvas-based playgrounds use the interactive visual as the primary control — users drag nodes and draw connections rather than adjusting sliders or filling forms." ;
    oc:hasRationale "Concept maps are inherently spatial and relational; direct manipulation on canvas maps naturally to the mental model the user is building." .

oc:kn_dec94170 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building concept maps from real codebase or domain data" ;
    oc:directiveContent "1. Pre-populate 15-20 key concept nodes with real file paths and short descriptions. 2. Pre-draw 20-30 relationships based on actual architecture. 3. Default all knowledge levels to 'Fuzzy'. 4. Provide presets like 'Zoom out' and 'Focus on [layer]'. 5. Generate prompt output shaped by user's knowledge markings." ;
    oc:stepOrder 1 .

oc:kn_e224a858 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating the learning prompt output from a concept map" ;
    oc:directiveContent "\"I'm learning [DOMAIN]. I already understand: [know nodes]. I'm fuzzy on: [fuzzy nodes]. I have no idea about: [unknown nodes]. Here are the relationships I want to understand: [edge list]. Please explain the fuzzy and unknown concepts, focusing on these relationships. Build on what I already know. Use concrete code references.\"" ;
    oc:templateVariables "DOMAIN",
        "edge list",
        "fuzzy nodes",
        "know nodes",
        "unknown nodes" .

_:ref_9af6e14c5c60efe1 a oc:WorkflowStep ;
    dcterms:description "Pre-draw 20-30 relationships (edges) based on actual architecture" ;
    oc:expectedOutcome "Edges array with source, target, and relationship type fields" ;
    oc:stepDependsOn _:ref_2d13aca7cec24f0a ;
    oc:stepId "cm-2" .

_:ref_f5eaea93406d189b a oc:WorkflowStep ;
    dcterms:description "Implement canvas rendering with hit testing, drag, edge drawing, tooltips, and force-directed auto-layout" ;
    oc:expectedOutcome "Interactive canvas where users can manipulate nodes and edges" ;
    oc:stepDependsOn _:ref_2d13aca7cec24f0a,
        _:ref_9af6e14c5c60efe1 ;
    oc:stepId "cm-4" .

_:ref_2d13aca7cec24f0a a oc:WorkflowStep ;
    dcterms:description "Pre-populate 15-20 key concept nodes with real file paths and short descriptions" ;
    oc:expectedOutcome "Nodes array with id, label, description, position, and knowledge level fields" ;
    oc:stepId "cm-1" .

