        oc:PromptGenerated .

oc:kn_2117b719 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building a critique playground for a specific document" ;
    oc:directiveContent "1. Read document content. 2. Analyze and generate suggestions with specific line references, actionable text, and category tags (clarity, completeness, performance, accessibility, ux). 3. Embed both document content and suggestions array in the generated HTML." ;
    oc:hasRationale "Pre-populating suggestions ensures the playground launches with useful, actionable feedback rather than an empty state" ;
    oc:stepOrder 1 .

oc:kn_2538efc0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating suggestions for any document critique" ;
    oc:directiveContent "Suggestions must include specific line references, clear actionable text, and category tags. Use fuzzy matching (±2 lines) to associate suggestions with document lines." ;
    oc:hasRationale "Precise line anchoring makes suggestions immediately locatable; fuzzy matching tolerates minor formatting drift" ;
    oc:severityLevel "HIGH" .

oc:kn_42311422 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When initializing the critique playground data model" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const suggestions = [{ id, lineRef: 'Line 3', targetText, suggestion, category: 'clarity', status: 'pending', userComment: '' }];
let state = { suggestions: [...], activeFilter: 'all', activeSuggestionId: null };""" ;
    oc:hasRationale "This state shape supports filtering, highlighting, and prompt generation from a single source of truth" .

oc:kn_6ebe4928 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the final prompt output" ;
    oc:directiveContent "Do not include rejected suggestions in the prompt output. Rejected items are listed for context only, not as actionable changes." ;
    oc:hasRationale "Including rejected items as action items defeats the purpose of the approve/reject workflow and creates confusing instructions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_731ed7c1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating suggestions" ;
    oc:directiveContent "Categories are limited to: clarity, completeness, performance, accessibility, ux. Statuses are limited to: pending, approved, rejected." ;
    oc:hasRationale "A fixed taxonomy enables filter tabs and consistent grouping in the prompt output" ;
    oc:severityLevel "MEDIUM" .

oc:kn_815854d4 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating the copyable prompt output" ;
    oc:directiveContent """Please update [DOCUMENT] with the following changes:

## Approved Improvements

**{lineRef}:** {suggestion}
  → User note: {userComment}

## Additional Feedback
{non-approved items with user comments}

## Rejected (for context)
{rejected items}""" ;
    oc:hasRationale "This format separates actionable changes from context-only items, producing a ready-to-paste instruction prompt" .

oc:kn_bac91d00 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When rendering suggestion states in the document panel" ;
    oc:directiveContent "Color-code suggestion status consistently: pending (amber), approved (green), rejected (red with 0.6 opacity). Use left border highlighting on document lines." ;
    oc:hasRationale "Consistent visual encoding lets users instantly assess review progress at a glance" .

