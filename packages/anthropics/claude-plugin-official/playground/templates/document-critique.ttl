oc:skill_claude_plugin_official_playground_document_critique a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "document-critique" ;
    skos:broader "Interactive playground template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/playground" ;
    oc:contentHash "c5bd7a68a53f2075d127e482c93b5f3d0b51c24bf8d301c1124801cca7be2d41" ;
    oc:differentia "that provides a structured document review interface with approve/reject/comment workflow for line-by-line suggestions" ;
    oc:extends oc:skill_claude_plugin_official_playground ;
    oc:hasAllowedTool "Write" ;
    oc:hasArgumentHint "document content to critique" ;
    oc:hasCategory "document" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Use this template when the playground helps review and critique documents: SKILL.md files, READMEs, specs, proposals, or any text that needs structured feedback with approve/reject/comment workflow." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Only include actionable items:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """function updatePrompt() {
  const approved = state.suggestions.filter(s => s.status === 'approved');
  const withComments = state.suggestions.filter(s => s.userComment?.trim());

  if (approved.length === 0 && withComments.length === 0) {
    // Show placeholder
    return;
  }

  let prompt = 'Please update [DOCUMENT] with the following changes:\\n\\n';

  if (approved.length > 0) {
    prompt += '## Approved Improvements\\n\\n';
    for (const s of approved) {
      prompt += `**${s.lineRef}:** ${s.suggestion}`;
      if (s.userComment?.trim()) {
        prompt += `\\n  → User note: ${s.userComment.trim()}`;
      }
      prompt += '\\n\\n';
    }
  }

  // Additional feedback from non-approved items with comments
  // Rejected items listed for context only
}
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 106-132" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Prompt output generation" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Groups by: Approved Improvements, Additional Feedback, Rejected (for context)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Generates a prompt only from approved suggestions and user comments" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Copy button with \"Copied!\" feedback" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Prompt output (bottom)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
