    oc:isUserInvocable true ;
    oc:nature "Template" ;
    oc:requiresState oc:DocumentContentAvailable ;
    oc:resolvesIntent "critique skills, READMEs, specs, or proposals",
        "generate structured feedback with approval workflow",
        "produce actionable change prompts from approved suggestions",
        "review documents interactively" ;
