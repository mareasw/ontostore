_:ref_a12a403e49a94107 a oc:WorkflowStep ;
    dcterms:description "Identify the playground type from user request: design, data explorer, concept map, document critique, diff review, or code map" ;
    oc:expectedOutcome "Correct template type determined" ;
    oc:stepId "identify-type" .

_:ref_d8b69d41dcf9678e a oc:WorkflowStep ;
