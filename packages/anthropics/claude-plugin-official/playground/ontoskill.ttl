_:ref_c530467cfd1ab7ec a oc:WorkflowStep ;
    dcterms:description "**Identify the playground type** from the user's request" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_03d951278ce82d8a a oc:WorkflowStep ;
    dcterms:description "Construct the single HTML file following the template: inline all CSS/JS, implement state management, live preview, prompt output, copy button, presets, dark theme" ;
    oc:expectedOutcome "Complete self-contained HTML file written to disk" ;
    oc:stepDependsOn _:ref_d8b69d41dcf9678e ;
    oc:stepId "build-html" .

