@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_playground a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "playground" ;
    skos:broader "Interactive HTML artifact generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/playground" ;
    oc:contentHash "100f45302e6ac7adc8bf295f2ed12fc68756c5986bb2900051659e7dbd627359" ;
    oc:differentia "Creates self-contained single-file playgrounds with controls, live preview, and natural-language prompt output that users configure visually and copy back into Claude" ;
    oc:handlesFailure oc:FileNotFound,
        oc:PermissionDenied ;
    oc:hasAllowedTool "Bash",
        "Write" ;
    oc:hasArgumentHint "topic or domain for the playground (e.g., 'design playground for card component', 'code map for my project architecture')" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Creates interactive HTML playgrounds — self-contained single-file explorers that let users configure something visually through controls, see a live preview, and copy out a prompt. Use when the user asks to make a playground, explorer, or interactive tool for a topic." ;
    oc:hasName "playground" ;
    oc:impartsKnowledge oc:kn_10c26d43,
        oc:kn_37824603,
        oc:kn_73676581,
        oc:kn_7cfc1bcd,
        oc:kn_c5659228,
        oc:kn_d9796ef9,
        oc:kn_e1c39730,
        oc:kn_e54b6796 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build design playground",
        "build visual explorer",
        "create code map visualization",
        "create data explorer",
        "create interactive playground",
        "generate interactive tool",
        "review code diffs interactively",
        "review documents interactively" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_10c26d43 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any playground" ;
    oc:directiveContent "Every playground must be a single self-contained HTML file with all CSS and JS inlined — no external dependencies or CDN references." ;
    oc:hasRationale "External dependencies create single points of failure; if a CDN is down, the playground is dead." ;
    oc:severityLevel "CRITICAL" .

oc:kn_37824603 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing the control panel layout" ;
    oc:directiveContent "Avoid showing too many controls at once — group by concern and hide advanced options in a collapsible section." ;
    oc:hasRationale "Overwhelming users with all controls simultaneously reduces usability and increases cognitive load." ;
    oc:severityLevel "MEDIUM" .

oc:kn_73676581 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When designing the initial state and preset system" ;
    oc:directiveContent "Include 3-5 named presets that snap all controls to cohesive combinations, so the playground looks good on first load with sensible defaults." ;
    oc:hasRationale "Good defaults and presets let users start exploring immediately instead of configuring from scratch." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7cfc1bcd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing state management in playground JavaScript" ;
    oc:directiveContent "Use a single state object pattern where every control writes to it and every render reads from it. All controls call updateAll() on change to trigger both renderPreview() and updatePrompt()." ;
    oc:hasRationale "A single state object prevents sync bugs between controls, preview, and prompt output." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c5659228 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When the playground HTML file has been written" ;
    oc:directiveContent "After writing the HTML file, run 'open <filename>.html' to launch it in the user's default browser for immediate interaction." ;
    oc:hasRationale "Users need to see and interact with the playground to evaluate it; auto-opening saves a manual step." ;
    oc:severityLevel "LOW" .

oc:kn_d9796ef9 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When identifying which playground type to build" ;
    oc:directiveContent "Match the user's request to one of six template types (design-playground, data-explorer, concept-map, document-critique, diff-review, code-map) and adapt the closest match if no template fits cleanly." ;
    oc:hasRationale "Templates provide proven layout and interaction patterns tailored to specific domains, reducing design errors." ;
    oc:severityLevel "HIGH" .

oc:kn_e1c39730 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing control-to-preview binding" ;
    oc:directiveContent "Live preview must update instantly on every control change — no 'Apply' button or delayed rendering." ;
    oc:hasRationale "Immediate visual feedback is the core value proposition of a playground; delayed updates break the exploratory workflow." ;
    oc:severityLevel "HIGH" .

oc:kn_e54b6796 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating prompt output text" ;
    oc:directiveContent "Never output the prompt as a raw value dump (e.g., 'radius: 12, shadow: 4'). Write it as a natural language instruction that only mentions non-default choices." ;
    oc:hasRationale "Natural language prompts are actionable without the playground context; value dumps require the user to interpret raw settings." ;
    oc:severityLevel "HIGH" .

