        oc:Skill ;
    dcterms:identifier "advanced-plugin" ;
    skos:broader "Reference example" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/plugin-structure" ;
    oc:contentHash "3d24f5856048a94cb99fe2b8207d99f2f5d69325771b361d63ec73024290759c" ;
    oc:differentia "that demonstrates enterprise-grade Claude Code plugin architecture with MCP server integration, multi-level component organization, shared libraries, security hooks, and environment-specific configuration" ;
