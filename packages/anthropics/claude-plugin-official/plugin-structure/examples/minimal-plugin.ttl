oc:skill_anthropics_claude_plugin_official_plugin_structure_minimal_plugin a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "minimal-plugin" ;
    skos:broader "Reference example" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/plugin-structure" ;
    oc:contentHash "c4f14fe56b153be3c532b7947bb10b453fc92e280dca5a7da752d2b1b5d17448" ;
    oc:differentia "demonstrates the simplest possible Claude Code plugin with a single command and minimal manifest" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_plugin_structure ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidManifest ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_0516562b,
        oc:kn_7c8808d0,
        oc:kn_aaa61c82,
        oc:kn_b01f2746,
        oc:kn_fe146015 ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build a simple single-command plugin",
        "create a minimal plugin",
        "learn plugin development basics",
        "understand minimal plugin structure" ;
    oc:yieldsState oc:PluginCreated .

oc:kn_0516562b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between minimal vs standard vs advanced plugin patterns" ;
    oc:directiveContent "Use the minimal plugin pattern for quick prototypes, single-purpose utilities, learning plugin development, or internal team tools with one specific function." ;
    oc:hasRationale "Over-engineering a simple plugin adds maintenance burden without proportional benefit" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7c8808d0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when creating any plugin" ;
    oc:directiveContent "The plugin.json manifest MUST be located at .claude-plugin/plugin.json — any other location will not be recognized by Claude Code." ;
    oc:hasRationale "Claude Code's auto-discovery mechanism specifically looks for the manifest at this exact path" ;
    oc:severityLevel "CRITICAL" .

oc:kn_aaa61c82 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating any command .md file in the commands/ directory" ;
    oc:directiveContent "Command markdown files must include YAML frontmatter with 'name' and 'description' fields, followed by implementation instructions in the body." ;
    oc:hasRationale "Claude Code auto-discovers commands by scanning for .md files and parsing their frontmatter metadata" ;
    oc:severityLevel "HIGH" .

oc:kn_b01f2746 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating a simple, single-purpose plugin" ;
    oc:directiveContent "The minimal plugin requires only a plugin.json with the 'name' field and a single command markdown file in commands/. No other files or directories are needed." ;
    oc:hasRationale "Keeps the learning curve low and enables rapid prototyping without unnecessary configuration overhead" ;
    oc:severityLevel "LOW" .

oc:kn_fe146015 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When a minimal plugin needs to grow beyond a single command" ;
    oc:directiveContent "Extend the minimal plugin incrementally by adding more .md files in commands/, updating plugin.json with metadata, creating an agents/ directory, or adding hooks/hooks.json." ;
    oc:hasRationale "Incremental extension avoids the need to restructure from scratch and follows the natural evolution of plugin complexity" ;
    oc:severityLevel "LOW" .

