@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_plugin_structure_standard_plugin a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "standard-plugin" ;
    skos:broader "Reference example" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/plugin-structure" ;
    oc:contentHash "b8cfba84bd4dbdc83365cebcde5dcc6391252372300df0c1ea7890441582d784" ;
    oc:differentia "that demonstrates a complete, production-grade plugin structure with commands, agents, skills, hooks, and scripts" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_plugin_structure ;
    oc:handlesFailure oc:InvalidPluginStructure,
        oc:MissingManifest ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_03129198,
        oc:kn_224e1591,
        oc:kn_39edabf5,
        oc:kn_8b2ff27d,
        oc:kn_a3a526b4,
        oc:kn_d81c9939 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:PluginStructureUnderstood ;
    oc:resolvesIntent "create a well-structured plugin with multiple components",
        "learn plugin directory layout conventions",
        "see example of commands agents skills and hooks integration",
        "understand standard plugin structure" ;
    oc:yieldsState oc:PluginComponentsIntegrated,
        oc:StandardPluginPatternKnown .

oc:kn_03129198 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating skills that contain substantial domain knowledge" ;
    oc:directiveContent "Skills should include a references/ directory for detailed documentation and an examples/ directory for code patterns, enabling progressive disclosure of information." ;
    oc:hasRationale "Progressive disclosure keeps SKILL.md focused on essential directives while allowing the agent to load detailed references only when needed, reducing token usage." ;
    oc:severityLevel "MEDIUM" .

oc:kn_224e1591 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring hooks in hooks.json" ;
    oc:directiveContent "The hooks.json file must use specific hook types ('prompt' or 'command'), define matchers for tool patterns, and specify timeouts to prevent blocking." ;
    oc:hasRationale "Properly structured hooks ensure they execute reliably without causing timeouts or unexpected behavior." ;
    oc:severityLevel "HIGH" .

oc:kn_39edabf5 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When scaffolding a new plugin with multiple component types" ;
    oc:directiveContent "Organize plugin components into dedicated directories: commands/ for slash commands, agents/ for sub-agents, skills/ for knowledge skills, hooks/ for lifecycle hooks with hooks.json, and scripts/ for executable scripts." ;
    oc:hasRationale "Consistent directory structure makes plugins navigable, maintainable, and understandable by other developers." ;
    oc:severityLevel "HIGH" .

oc:kn_8b2ff27d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing the interaction between plugin components" ;
    oc:directiveContent "Plugin components should integrate cohesively: agents should automatically load relevant skills, commands should reference scripts, and hooks should invoke skill-based checks." ;
    oc:hasRationale "Cross-component integration creates a unified experience where each part reinforces the others, rather than isolated tools." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a3a526b4 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When setting up automated quality enforcement in a plugin" ;
    oc:directiveContent "Use hooks to automatically enforce standards: PreToolUse hooks validate code against skills before writes/edits, and Stop hooks run quality validation before task completion." ;
    oc:hasRationale "Automated enforcement via hooks ensures consistency without relying on manual compliance, making standards unavoidable." ;
    oc:severityLevel "HIGH" .

oc:kn_d81c9939 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any production-grade plugin" ;
    oc:directiveContent "A standard plugin should contain a complete manifest in .claude-plugin/plugin.json with name, version, description, author, homepage, repository, license, and keywords." ;
    oc:hasRationale "Complete metadata enables discoverability, versioning, and proper distribution of the plugin." ;
    oc:severityLevel "HIGH" .

