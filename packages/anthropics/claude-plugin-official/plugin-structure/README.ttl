oc:kn_61b64790 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When maintaining and updating the plugin-structure skill" ;
    oc:directiveContent "Keep SKILL.md lean and focused on core concepts. Move detailed information to references/ directory. Add new examples/ for common patterns." ;
    oc:hasRationale "Maintaining separation between core, reference, and example content prevents skill bloat and preserves the progressive disclosure pattern" .

oc:kn_b8943f9f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring plugin documentation" ;
    oc:directiveContent "Use progressive disclosure: SKILL.md (~1600 words) for core concepts, references/ (~6000 words) for detailed field references and patterns, examples/ (~8000 words) for complete working examples. Load deeper layers only as needed." ;
    oc:hasRationale "Progressive disclosure manages context window usage by loading only the depth of information required for the current task" .

oc:kn_c22945d8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing or updating skill documentation" ;
    oc:directiveContent "Ensure all documentation uses imperative/infinitive form. Update version in SKILL.md frontmatter when making changes." ;
    oc:hasRationale "Consistent voice and version tracking keeps documentation professional and change-aware" .

