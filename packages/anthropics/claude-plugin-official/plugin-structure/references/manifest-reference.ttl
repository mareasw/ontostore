@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_plugin_structure_manifest_reference a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "manifest-reference" ;
    skos:broader "Reference specification" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/plugin-structure" ;
    oc:contentHash "d0ff8ffece4754df92c543266b8d0b689fb85473f51fbb57e215f2d235ee9782" ;
    oc:differentia "that defines the complete schema, validation rules, path resolution, and best practices for plugin.json manifest configuration in Claude Code plugins" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_plugin_structure ;
    oc:hasArgumentHint "field-name or validation-query" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_3326b2bc,
        oc:kn_48cc9715,
        oc:kn_5626be6a,
        oc:kn_64ddf043,
        oc:kn_66bb0493,
        oc:kn_721b77db,
        oc:kn_ba3d8e0c ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "configure plugin metadata",
        "resolve component paths in plugins",
        "understand plugin.json schema",
        "validate plugin manifest" .

oc:kn_3326b2bc a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before deploying or distributing a plugin" ;
    oc:directiveContent "Validate that plugin.json has valid JSON syntax, a correctly formatted name field, semantic versioning (if present), and that all referenced component paths exist before publishing." ;
    oc:hasRationale "Claude Code validates the manifest on load and will reject plugins with syntax errors, invalid names, or missing paths." ;
    oc:severityLevel "HIGH" .

oc:kn_48cc9715 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or validating any Claude Code plugin" ;
    oc:directiveContent "The plugin manifest MUST be located at .claude-plugin/plugin.json — no other path is recognized by Claude Code." ;
    oc:hasRationale "Claude Code will not discover or load plugins without this file in the exact required location." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5626be6a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When setting the plugin name in manifest" ;
    oc:directiveContent "The name field must match /^[a-z][a-z0-9]*(-[a-z0-9]+)*$/ — lowercase kebab-case starting with a letter, ending with a letter or number." ;
    oc:hasRationale "Ensures unique identification, prevents conflicts, and enables safe namespacing across installed plugins." ;
    oc:severityLevel "HIGH" .

oc:kn_64ddf043 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing path values in plugin.json" ;
    oc:directiveContent "Do not use absolute paths, omit the ./ prefix, use backslashes, or navigate with ../ in any manifest path field." ;
    oc:hasRationale "These cause validation errors on plugin load and prevent component discovery." ;
    oc:severityLevel "HIGH" .

oc:kn_66bb0493 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using multiple command or agent directories in the manifest" ;
    oc:directiveContent "Component name conflicts across multiple path locations cause registration errors — all discovered components from default and custom paths must have unique names." ;
    oc:hasRationale "Default directories and custom paths are merged without overwriting; duplicate names result in load failures." ;
    oc:severityLevel "HIGH" .

oc:kn_721b77db a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between inline vs. external configuration for hooks and MCP servers" ;
    oc:directiveContent "Use inline configuration for hooks/mcpServers only when under 50/20 lines respectively; otherwise use external JSON files." ;
    oc:hasRationale "Keeps the manifest readable and maintainable while allowing simple plugins to stay self-contained." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ba3d8e0c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any path field in plugin.json" ;
    oc:directiveContent "All component paths (commands, agents, hooks, mcpServers) must be relative, start with ./, use forward slashes only, and cannot use ../ for parent directory navigation." ;
    oc:hasRationale "Ensures portable, cross-platform path resolution and prevents security issues from escaping the plugin directory." ;
    oc:severityLevel "HIGH" .

