oc:kn_0903a981 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When writing plugin.json manifest" ;
    oc:directiveContent """## Minimal manifest:
{"name": "plugin-name"}

## Recommended manifest:
{"name": "plugin-name", "version": "1.0.0", "description": "...", "author": {"name": "...", "email": "..."}, "homepage": "...", "repository": "...", "license": "MIT", "keywords": [...]}

## Component paths (supplement defaults):
{"commands": ["./custom-cmds"], "agents": "./specialized", "hooks": "./config/hooks.json", "mcpServers": "./.mcp.json"}""" ;
    oc:templateVariables "agents",
        "author",
        "commands",
        "description",
        "homepage",
        "hooks",
        "keywords",
        "license",
        "mcpServers",
        "name",
        "repository",
        "version" .

oc:kn_2dbdbb2e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or validating any plugin" ;
    oc:directiveContent "The manifest MUST be located at .claude-plugin/plugin.json — no other location is recognized. Only the 'name' field is required." ;
    oc:hasRationale "Claude Code scans specifically for .claude-plugin/plugin.json to identify and load plugins; incorrect placement means the plugin is invisible." ;
    oc:severityLevel "CRITICAL" .

oc:kn_31bd2690 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring MCP servers in .mcp.json" ;
    oc:codeLanguage "json" ;
    oc:directiveContent """{
  "mcpServers": {
    "server-name": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/servers/server.js"],
      "env": {"API_KEY": "${API_KEY}"}
    }
  }
}""" .

oc:kn_34d41f56 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing plugin directory structure" ;
    oc:directiveContent "All component directories (commands/, agents/, skills/, hooks/) MUST be at the plugin root level, NOT nested inside .claude-plugin/." ;
    oc:hasRationale "The .claude-plugin/ directory is reserved for manifest configuration only; component auto-discovery only scans root-level directories." ;
    oc:severityLevel "CRITICAL" .

oc:kn_354698ab a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When scaffolding a new plugin from scratch" ;
    oc:directiveContent "1. Create plugin directory with .claude-plugin/plugin.json (name field required) 2. Add component directories at root level (commands/, agents/, skills/, hooks/) 3. Create component files with YAML frontmatter in kebab-case 4. Use ${CLAUDE_PLUGIN_ROOT} for all intra-plugin references 5. Optionally add custom paths in manifest to supplement defaults 6. Test by restarting Claude Code session" ;
    oc:stepOrder 1 .

oc:kn_36a390ac a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When setting the name field in plugin.json" ;
    oc:directiveContent "Plugin name must match /^[a-z][a-z0-9]*(-[a-z0-9]+)*$/ — unique across installed plugins, no spaces or special characters." ;
    oc:hasRationale "Used for plugin identification, conflict detection, and optional command namespacing." ;
    oc:severityLevel "HIGH" .

oc:kn_390ffb50 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring hooks in hooks.json" ;
    oc:codeLanguage "json" ;
    oc:directiveContent """{
  "PreToolUse": [{
    "matcher": "Write|Edit",
    "hooks": [{
      "type": "command",
      "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate.sh",
      "timeout": 30
    }]
  }]
}""" .

oc:kn_3d80ec7f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When troubleshooting component loading failures" ;
    oc:directiveContent "Before finalizing a plugin, verify: manifest at correct location, all paths use ./ prefix, names are kebab-case, skills have SKILL.md (not README.md), and no hardcoded absolute paths." ;
    oc:hasRationale "Most plugin loading failures stem from incorrect file placement, naming, or path configuration." ;
    oc:severityLevel "HIGH" .

oc:kn_4dff6bc8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When naming any plugin component or the plugin itself" ;
    oc:directiveContent "Use kebab-case for all directory names, file names, and the plugin name field. Names must start with a letter and contain only lowercase letters, numbers, and hyphens." ;
    oc:hasRationale "Consistent naming ensures cross-platform compatibility, avoids conflicts, and matches Claude Code's auto-discovery expectations." ;
    oc:severityLevel "HIGH" .

oc:kn_7f864816 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring commands, agents, or other component path arrays in plugin.json" ;
    oc:directiveContent "Custom paths in plugin.json supplement default directories — they do NOT replace them. Components in both default and custom paths will all load." ;
    oc:hasRationale "This additive behavior means you can extend the standard layout without duplicating components, but name conflicts across directories will cause errors." ;
    oc:severityLevel "HIGH" .

oc:kn_a1bfa056 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding on plugin organization complexity" ;
    oc:directiveContent "Start with flat structure for 5-15 components, move to categorized structure at 15+, and use hierarchical structure at 20+. Only create directories for components the plugin actually uses." ;
    oc:hasRationale "Over-engineering directory structure early adds unnecessary complexity; scale the structure as the plugin grows." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b5904470 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring plugin paths and directories" ;
    oc:directiveContent "Do NOT nest component directories inside .claude-plugin/, use absolute paths in manifest, or use ../ parent directory navigation in component path fields." ;
    oc:hasRationale "These patterns break auto-discovery, portability, and security boundaries of the plugin system." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c9740eaf a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When debugging why a component is not loading" ;
    oc:directiveContent "Auto-discovery order: 1) Read .claude-plugin/plugin.json 2) Scan commands/ for .md files 3) Scan agents/ for .md files 4) Scan skills/ for subdirs with SKILL.md 5) Load hooks/hooks.json or manifest hooks 6) Load .mcp.json or manifest mcpServers" ;
    oc:stepOrder 2 .

oc:kn_d316700d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating slash command files in commands/" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
name: command-name
description: Command description
---
Command implementation instructions...""" .

oc:kn_d796798c a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When organizing commands in hierarchical directory structure" ;
    oc:directiveContent "Claude Code does not support nested command auto-discovery in subdirectories — use custom paths in plugin.json to explicitly list each subdirectory." ;
    oc:hasRationale "Auto-discovery only scans one level deep in default directories; nested subdirectories require explicit path entries." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f7a93146 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When referencing scripts, resources, or any files within a plugin from hook commands, MCP server args, or component files" ;
    oc:directiveContent "Always use ${CLAUDE_PLUGIN_ROOT} for all intra-plugin path references — never hardcode absolute paths, relative paths from working directory, or home directory shortcuts." ;
    oc:hasRationale "Plugins install in different locations depending on OS, installation method, and user preferences; ${CLAUDE_PLUGIN_ROOT} resolves to the correct path at runtime." ;
    oc:severityLevel "CRITICAL" .

