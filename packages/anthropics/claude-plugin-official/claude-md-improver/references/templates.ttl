@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_claude_md_improver_templates a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "templates" ;
    skos:broader "Reference template library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/claude-md-improver" ;
    oc:contentHash "de0aa3ac30120a0c77f9cd82738a75ed8326864f98feb89356a253f2deaf3ab0" ;
    oc:differentia "that provides standardized section structures and formatting patterns for CLAUDE.md project documentation files" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_claude_md_improver ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "project-type (minimal, comprehensive, monorepo, package)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_29af385c,
        oc:kn_5e95f271,
        oc:kn_a42767ea,
        oc:kn_fa7ba5a1,
        oc:kn_ff5710a3 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CodebaseAnalyzed ;
    oc:resolvesIntent "generate CLAUDE.md from templates",
        "learn what sections belong in CLAUDE.md",
        "select appropriate CLAUDE.md template for a project",
        "structure CLAUDE.md sections" ;
    oc:yieldsState oc:DocumentTemplateSelected .

oc:kn_29af385c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating the Commands section of CLAUDE.md" ;
    oc:directiveContent "Commands section should use a table format with Command and Description columns documenting install, dev, build, test, and lint commands." ;
    oc:hasRationale "Tabular command documentation ensures quick lookup and copy-paste readiness for essential project operations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5e95f271 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which CLAUDE.md sections to include" ;
    oc:directiveContent "Use only sections relevant to the project. Not all recommended sections are needed for every project." ;
    oc:hasRationale "Over-documentation with irrelevant sections reduces clarity and increases maintenance burden." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a42767ea a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which CLAUDE.md template to apply" ;
    oc:directiveContent "Choose template based on project complexity: Minimal for simple projects, Comprehensive for full projects, Package/Module for monorepo sub-packages, Monorepo Root for multi-package repos." ;
    oc:hasRationale "Matching template granularity to project complexity ensures appropriate documentation density without over- or under-documenting." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fa7ba5a1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or updating any CLAUDE.md file" ;
    oc:directiveContent "Never include generic advice or placeholder content in CLAUDE.md. All content must reference actual file paths, real commands, and verified codebase state." ;
    oc:hasRationale "Generic or unverified content erodes trust and provides no value over what the AI already knows, while potentially misleading it with inaccurate project-specific information." ;
    oc:severityLevel "HIGH" .

oc:kn_ff5710a3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating or updating any CLAUDE.md file" ;
    oc:directiveContent "CLAUDE.md content must be concise (one line per concept), actionable (copy-paste ready commands), project-specific (not generic advice), and current (reflecting actual codebase state)." ;
    oc:hasRationale "These four principles ensure CLAUDE.md files are maximally useful to AI sessions while remaining human-readable and maintainable." ;
    oc:severityLevel "HIGH" .

