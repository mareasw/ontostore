oc:skill_anthropics_claude_plugin_official_claude_md_improver_quality_criteria a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "quality-criteria" ;
    skos:broader "Evaluation rubric" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/claude-md-improver" ;
    oc:contentHash "383def16b05dca948297dd1acb33f007cb1b1b2c368454d424c5634348a8bab1" ;
    oc:differentia "Scores CLAUDE.md files across six weighted criteria to assess documentation quality and identify improvements" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_claude_md_improver ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "Bash",
        "Glob",
        "Grep",
        "Read" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_c1d6c3d1,
        oc:req_ddd349a5 ;
    oc:impartsKnowledge oc:kn_095f5fcb,
        oc:kn_0ca3794d,
        oc:kn_378eba2e,
        oc:kn_9ff5b39d,
        oc:kn_c0d36b6c ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:FileExists ;
    oc:resolvesIntent "assess documentation completeness",
        "audit CLAUDE.md for red flags",
        "evaluate CLAUDE.md quality",
        "score CLAUDE.md against rubric" ;
    oc:yieldsState oc:DocumentAnalyzed .

oc:kn_095f5fcb a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When performing a CLAUDE.md quality audit" ;
    oc:directiveContent "Follow the assessment process: read CLAUDE.md completely, cross-reference with the actual codebase (verify commands work, files exist, architecture descriptions match), score each criterion, calculate total, list specific issues, and propose concrete improvements." ;
    oc:hasRationale "Cross-referencing against the live codebase is essential — documentation quality can only be judged relative to reality" ;
    oc:severityLevel "HIGH" .

oc:kn_0ca3794d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing a CLAUDE.md quality assessment" ;
    oc:directiveContent "Before scoring, verify that documented commands would actually run, referenced file paths exist, and the tech stack described matches what's in use." ;
    oc:hasRationale "Currency and actionability cannot be judged without cross-referencing against the actual codebase state" ;
    oc:severityLevel "HIGH" .

oc:kn_378eba2e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing CLAUDE.md for common quality failures" ;
    oc:directiveContent "Flag red flags: commands that would fail, references to deleted files, outdated tech versions, copy-paste from templates without customization, generic non-project-specific advice, unresolved TODOs, and duplicate info across multiple CLAUDE.md files." ;
    oc:hasRationale "These are the most common and damaging documentation defects that actively mislead agents or developers" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9ff5b39d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When evaluating any CLAUDE.md file for quality" ;
    oc:directiveContent "Score CLAUDE.md files across six criteria: Commands/Workflows (20pts), Architecture Clarity (20pts), Non-Obvious Patterns (15pts), Conciseness (15pts), Currency (15pts), and Actionability (15pts) for a total of 100 points." ;
    oc:hasRationale "Provides a consistent, repeatable scoring framework that ensures all critical documentation dimensions are assessed" ;
    oc:severityLevel "HIGH" .

oc:kn_c0d36b6c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating conciseness or recommending CLAUDE.md improvements" ;
    oc:directiveContent "Value density over length: each line in CLAUDE.md should add unique value with no filler, no redundancy with code comments, and no obvious information restated." ;
    oc:hasRationale "CLAUDE.md files have an implicit token budget — dense, high-value content maximizes agent effectiveness" ;
    oc:severityLevel "MEDIUM" .

oc:req_c1d6c3d1 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Ability to cross-reference documentation against actual codebase" .

oc:req_ddd349a5 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of CLAUDE.md file conventions and purpose" .

