                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Principle" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Before finalizing an update, verify:" ],
