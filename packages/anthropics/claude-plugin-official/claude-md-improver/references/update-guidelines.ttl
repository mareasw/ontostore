@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_claude_md_improver_update_guidelines a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "update-guidelines" ;
    skos:broader "Guideline framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/claude-md-improver" ;
    oc:contentHash "02a158d6ca41a0ab702a67a213e92205f09c073cea53796633251bc62fd7ec55" ;
    oc:differentia "governs what information should and should not be added to CLAUDE.md files to maximize utility while minimizing context window waste" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_claude_md_improver ;
    oc:hasArgumentHint "proposed CLAUDE.md additions or current file content" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_1cd8aa51,
        oc:kn_223f9392,
        oc:kn_472c080c,
        oc:kn_7c6b3e85,
        oc:kn_b2d24d63 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "determine what information belongs in CLAUDE.md",
        "format CLAUDE.md updates as diffs",
        "update CLAUDE.md with useful project knowledge",
        "validate CLAUDE.md additions for usefulness" .

oc:kn_1cd8aa51 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing proposed CLAUDE.md additions" ;
    oc:directiveContent "Never add obvious code info (redundant with names), generic best practices, one-off fixes, or verbose explanations to CLAUDE.md." ;
    oc:hasRationale "Generic and obvious information wastes context window space without providing actionable value; one-off fixes won't recur" ;
    oc:severityLevel "HIGH" .

oc:kn_223f9392 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When deciding what content to include in CLAUDE.md" ;
    oc:directiveContent "Add project-specific commands/workflows, gotchas/non-obvious patterns, package relationships, testing approaches that worked, and configuration quirks." ;
    oc:hasRationale "These categories capture tribal knowledge that isn't discoverable from code alone and saves future sessions from re-discovery" ;
    oc:severityLevel "HIGH" .

oc:kn_472c080c a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After drafting CLAUDE.md updates before committing them" ;
    oc:directiveContent "Before finalizing a CLAUDE.md update, verify: each addition is project-specific, no generic advice, commands are tested and work, file paths are accurate, a new Claude session would find it helpful, and it's the most concise expression." ;
    oc:hasRationale "Systematic validation prevents quality regression and ensures every addition justifies its context window cost" ;
    oc:severityLevel "HIGH" .

oc:kn_7c6b3e85 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating any proposed addition to CLAUDE.md" ;
    oc:directiveContent "Only add information that will genuinely help future Claude sessions. The context window is precious — every line must earn its place." ;
    oc:hasRationale "CLAUDE.md occupies context window space on every invocation; bloated files reduce Claude's effective reasoning capacity" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b2d24d63 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any CLAUDE.md content" ;
    oc:directiveContent "Express information as concisely as possible — prefer terse reference lines over explanatory prose. E.g., 'Auth: JWT with HS256, tokens in Authorization: Bearer header' over multi-paragraph JWT explanations." ;
    oc:hasRationale "Concise formatting maximizes information density per context token, allowing more useful knowledge to fit in the file" ;
    oc:severityLevel "MEDIUM" .

