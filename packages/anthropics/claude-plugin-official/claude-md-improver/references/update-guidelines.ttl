        oc:kn_b15fba7b ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DirectoryWritable,
        oc:FileExists ;
    oc:resolvesIntent "decide what to add to CLAUDE.md",
        "format CLAUDE.md updates as diffs",
        "update CLAUDE.md with useful information",
        "validate CLAUDE.md changes" ;
    oc:yieldsState oc:DocumentUpdated .

oc:kn_1f7829ac a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing proposed CLAUDE.md additions" ;
    oc:directiveContent "Never add: obvious code info (class names describe themselves), generic best practices, one-off fixes that won't recur, or verbose explanations." ;
    oc:hasRationale "These categories waste context window space without providing actionable, project-specific value to future sessions." ;
    oc:severityLevel "HIGH" .

oc:kn_3cf963cd a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When formatting CLAUDE.md update proposals" ;
    oc:directiveContent """File: ./CLAUDE.md
Section: {section_name} ({new|after ## X})

```diff
 ## {context}
 ...

+## {new_section}
+
+| {col1} | {col2} |
+|---------|---------|
+| `{cmd}` | {purpose} |
```

> **Why this helps:** {justification}""" ;
    oc:hasRationale "Provides a consistent, reviewable format for all proposed changes." ;
    oc:templateVariables "cmd",
        "col1",
        "col2",
        "context",
        "justification",
        "new",
        "new_section",
        "purpose",
        "section_name" .

oc:kn_5851bd5c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding what content merits inclusion in CLAUDE.md" ;
    oc:directiveContent "Add 5 categories of high-value content: (1) commands/workflows discovered, (2) gotchas and non-obvious patterns, (3) package/dependency relationships, (4) testing approaches that worked, (5) configuration quirks." ;
    oc:hasRationale "These categories capture project-specific knowledge that saves future sessions from rediscovery and prevents repeated debugging." ;
    oc:severityLevel "HIGH" .

oc:kn_7a4fdfd5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any CLAUDE.md content" ;
    oc:directiveContent "Be maximally concise. Replace verbose explanations with terse one-liners (e.g., 'Auth: JWT with HS256, tokens in Authorization: Bearer header')." ;
    oc:hasRationale "Concise notation preserves context window capacity while retaining all essential information." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7b47fe45 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When proposing CLAUDE.md changes" ;
    oc:directiveContent "1. Identify the file and section for the update. 2. Show the change as a unified diff with context lines. 3. Explain why the addition helps future sessions." ;
    oc:hasRationale "Structured diff format with rationale ensures changes are reviewable, traceable, and justified." ;
    oc:stepOrder 1 .

oc:kn_9595f34c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when considering any CLAUDE.md update" ;
    oc:directiveContent "Only add information that will genuinely help future Claude sessions. Every line must earn its place in the context window." ;
    oc:hasRationale "The context window is a scarce resource; clutter reduces the effectiveness of every future session that reads the file." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b15fba7b a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "Before finalizing any CLAUDE.md update" ;
    oc:directiveContent "Validate each update against this checklist: project-specific, no generic advice, commands tested and working, file paths accurate, helpful to a new session, most concise expression possible." ;
    oc:hasRationale "Prevents low-quality additions that degrade the file's signal-to-noise ratio over time." ;
    oc:severityLevel "HIGH" .

