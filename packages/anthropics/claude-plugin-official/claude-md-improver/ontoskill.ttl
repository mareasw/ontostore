    oc:hasRationale "Prevents unwanted changes; user must approve all modifications" ;
    oc:severityLevel "CRITICAL" .

oc:kn_5f29787d a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When outputting quality report in Phase 3" ;
    oc:directiveContent """## CLAUDE.md Quality Report

### Summary
- Files found: {count}
- Average score: {score}/100
- Files needing update: {count}

### File-by-File Assessment

#### {n}. {filepath} ({type})
**Score: {score}/100 (Grade: {grade})**

| Criterion | Score | Notes |
|-----------|-------|-------|
| Commands/workflows | {s}/20 | {notes} |
| Architecture clarity | {s}/20 | {notes} |
| Non-obvious patterns | {s}/15 | {notes} |
| Conciseness | {s}/15 | {notes} |
| Currency | {s}/15 | {notes} |
| Actionability | {s}/15 | {notes} |

**Issues:**
- {issues}

**Recommended additions:**
- {additions}""" ;
    oc:templateVariables "additions",
