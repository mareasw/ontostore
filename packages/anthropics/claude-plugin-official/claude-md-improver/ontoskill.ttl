@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_claude_md_improver a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "claude-md-improver" ;
    skos:broader "Codebase audit tool" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/claude-md-improver" ;
    oc:contentHash "8241fc8482f8caf48cab457986ab669debfa34eeb511845101866ea89a954a83" ;
    oc:differentia "Discovers, evaluates, and improves CLAUDE.md files across a repository using a quality rubric with targeted diff-based updates" ;
    oc:handlesFailure oc:FileNotFound,
        oc:PermissionDenied ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Glob",
        "Grep",
        "Read" ;
    oc:hasArgumentHint "repository path or directory to scan for CLAUDE.md files" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Audit and improve CLAUDE.md files in repositories. Use when user asks to check, audit, update, improve, or fix CLAUDE.md files. Scans for all CLAUDE.md files, evaluates quality against templates, outputs quality report, then makes targeted updates. Also use when the user mentions \"CLAUDE.md maintenance\" or \"project memory optimization\"." ;
    oc:hasName "claude-md-improver" ;
    oc:impartsKnowledge oc:kn_0cfc38b5,
        oc:kn_704ac3d6,
        oc:kn_a6b1bfde,
        oc:kn_b9cea48f,
        oc:kn_d129ae00 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DirectoryWritable,
        oc:FileExists ;
    oc:resolvesIntent "audit CLAUDE.md files",
        "check project memory files",
        "evaluate CLAUDE.md against quality criteria",
        "fix CLAUDE.md issues",
        "improve CLAUDE.md quality" ;
    oc:yieldsState oc:DocumentUpdated,
        oc:ReportGenerated .

oc:kn_0cfc38b5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When proposing or writing CLAUDE.md updates" ;
    oc:directiveContent "Never add obvious code info, generic best practices, one-off fixes, or verbose explanations to CLAUDE.md files." ;
    oc:hasRationale "Context window is precious — every line must earn its place; generic advice clutters the file without adding value" ;
    oc:severityLevel "HIGH" .

oc:kn_704ac3d6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Phase 2 quality assessment of each CLAUDE.md file" ;
    oc:directiveContent "CLAUDE.md quality scoring must evaluate 6 weighted criteria: Commands/Workflows (20pts), Architecture Clarity (20pts), Non-Obvious Patterns (15pts), Conciseness (15pts), Currency (15pts), and Actionability (15pts) totaling 100 points." ;
    oc:hasRationale "Standardized rubric ensures consistent, objective evaluation across all files and prevents subjective bias" ;
    oc:severityLevel "HIGH" .

oc:kn_a6b1bfde a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before applying updates to CLAUDE.md files" ;
    oc:directiveContent "Before finalizing any CLAUDE.md update, verify: each addition is project-specific, no generic advice, commands are tested and work, file paths are accurate, a new session would find it helpful, and it is the most concise expression." ;
    oc:hasRationale "Prevents propagation of incorrect or low-value information into project memory files" ;
    oc:severityLevel "HIGH" .

oc:kn_b9cea48f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining what updates to propose" ;
    oc:directiveContent "Focus targeted additions on 5 high-value categories: discovered commands/workflows, gotchas and non-obvious patterns, package relationships, testing approaches that worked, and configuration quirks." ;
    oc:hasRationale "These categories represent information that saves future Claude sessions from repeated discovery and debugging" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d129ae00 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Before modifying any CLAUDE.md file" ;
    oc:directiveContent "Always output the quality report BEFORE making any updates, and get user confirmation before applying changes to CLAUDE.md files." ;
    oc:hasRationale "Ensures user has visibility and control over changes to project memory files, preventing unintended modifications" ;
    oc:severityLevel "CRITICAL" .

