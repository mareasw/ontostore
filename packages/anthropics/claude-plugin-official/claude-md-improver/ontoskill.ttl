        "filepath",
        "grade",
        "issues",
        "notes",
        "s",
        "score",
        "type" .

oc:kn_8912480e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "During quality assessment phase" ;
    oc:directiveContent "Cross-reference CLAUDE.md content with actual codebase: verify documented commands work, check referenced files exist, confirm architecture descriptions are accurate, verify tech stack is current" ;
    oc:hasRationale "Stale or incorrect information is worse than no information — it actively misleads future sessions" ;
    oc:severityLevel "HIGH" .

oc:kn_94485f9c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating or writing CLAUDE.md content" ;
    oc:directiveContent "CLAUDE.md content must be: concise (dense, one-line per concept), actionable (copy-paste ready commands), project-specific (not generic advice), current (reflects actual codebase state)" ;
    oc:hasRationale "These four principles maximize the value of limited context window for future Claude sessions" .

oc:kn_aa16c7d8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When proposing CLAUDE.md additions" ;
    oc:directiveContent "Never add: obvious code info (class names explain themselves), generic best practices, one-off fixes unlikely to recur, verbose explanations when a one-liner suffices" ;
    oc:hasRationale "Context window is precious — every line must earn its place by being project-specific and non-obvious" ;
    oc:severityLevel "HIGH" .

oc:kn_b9ab5335 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating template recommendations or evaluating completeness" ;
    oc:directiveContent "Use only relevant sections from: Commands, Architecture, Key Files, Code Style, Environment, Testing, Gotchas, Workflow. Not all sections needed for every project." ;
    oc:hasRationale "Over-documentation with irrelevant sections wastes context window and reduces readability" .

oc:kn_c6303865 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Phase 1 Discovery — finding all CLAUDE.md files in a repository" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "find . -name \"CLAUDE.md\" -o -name \".claude.md\" -o -name \".claude.local.md\" 2>/dev/null | head -50" .

oc:kn_d5c451ba a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every execution of this skill" ;
    oc:directiveContent "1. Discovery: find all CLAUDE.md files with `find . -name \"CLAUDE.md\" -o -name \".claude.md\" -o -name \".claude.local.md\"` 2. Quality Assessment: score each file against 6 criteria (Commands/Workflows 20pts, Architecture Clarity 20pts, Non-Obvious Patterns 15pts, Conciseness 15pts, Currency 15pts, Actionability 15pts) 3. Output Quality Report: present file-by-file assessment with scores BEFORE any changes 4. Targeted Updates: propose minimal diff-based additions with explanations 5. Apply Updates: after user approval, apply changes via Edit tool" ;
    oc:hasRationale "Ensures consistent, thorough audits with user control over all changes" ;
    oc:stepOrder 1 .

