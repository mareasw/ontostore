oc:kn_02dbad88 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining winner" ;
    oc:directiveContent "Prioritize overall rubric score (content + structure) as primary, assertion pass rates as secondary, and declare TIE only as last resort." ;
    oc:hasRationale "Overall output quality is more important than passing specific assertions, which are only secondary evidence." .

oc:kn_68ac903c a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When both outputs are poor or both are excellent" ;
    oc:directiveContent "If both outputs fail, pick the one that fails less badly. If both are excellent, pick the one that's marginally better." ;
    oc:hasRationale "Even in edge cases, a useful comparison should identify the relatively better output." .

oc:kn_77d24c44 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating outputs" ;
    oc:directiveContent "Do not favor outputs based on style preferences; focus on correctness and completeness." ;
    oc:hasRationale "Style bias can mask substantive quality differences and lead to unfair comparisons." ;
    oc:severityLevel "HIGH" .

oc:kn_821f821e a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When writing comparison results" ;
    oc:directiveContent "The reasoning field should cite specific examples from the outputs to explain strengths, weaknesses, and the winner choice." ;
    oc:hasRationale "Specific citations make the comparison auditable and trustworthy." .

oc:kn_ac61ef05 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining winner" ;
    oc:directiveContent "Be decisive — choose a winner unless outputs are genuinely equivalent. Ties should be rare." ;
    oc:hasRationale "One output is usually better even if marginally; indecisiveness reduces evaluation utility." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b7c593a9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always during comparison" ;
    oc:directiveContent "Never attempt to infer which skill produced which output. Judge purely on output quality." ;
    oc:hasRationale "Preventing bias toward a particular skill or approach ensures fair evaluation." ;
    oc:severityLevel "CRITICAL" .

