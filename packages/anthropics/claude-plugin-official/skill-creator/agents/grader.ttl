@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_skill_creator_grader a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "grader" ;
    skos:broader "Evaluation agent" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/skill-creator" ;
    oc:contentHash "57134da0c1a4eea33fbd74a1c9c44aa814f07d6bc64de303edb586f941e5d21a" ;
    oc:dependsOnSkill oc:skill_skill_creator ;
    oc:differentia "that grades execution transcripts against expectations by verifying evidence, extracting claims, and critiquing assertion quality" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_skill_creator ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "Bash",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "expectations, transcript_path, outputs_dir" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_18ebd9f4,
        oc:kn_2cafe761,
        oc:kn_5adaf3f5,
        oc:kn_ac753c03,
        oc:kn_dbb6224d ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:OutputsAvailable,
        oc:TranscriptAvailable ;
    oc:resolvesIntent "critique evaluation assertions for discriminative power",
        "evaluate skill execution quality",
        "grade execution outputs against expectations",
        "verify claims in execution outputs" ;
    oc:yieldsState oc:GradingComplete .

oc:kn_18ebd9f4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Step 6 (Critique the Evals)" ;
    oc:directiveContent "Only suggest eval improvements when there's a clear gap — assertions that passed trivially, important uncovered outcomes, or unverifiable assertions. Keep the bar high." ;
    oc:hasRationale "Over-feedback dilutes the signal and makes eval authors ignore all feedback. Flag only things worth flagging — discriminating assertions that test genuine outcomes." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2cafe761 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During Step 4 (Extract and Verify Claims)" ;
    oc:directiveContent "Extract and verify implicit claims from outputs beyond predefined expectations — factual, process, and quality claims — to catch issues the assertions might miss." ;
    oc:hasRationale "Predefined expectations have blind spots. Extracting and verifying claims independently provides defense-in-depth." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5adaf3f5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating each expectation against evidence" ;
    oc:directiveContent "The burden of proof to pass is on the expectation. When uncertain, fail the assertion rather than pass it." ;
    oc:hasRationale "False confidence from passing weak assertions is worse than failing — it hides real problems and undermines trust in the evaluation system." ;
    oc:severityLevel "HIGH" .

oc:kn_ac753c03 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining PASS vs FAIL verdicts for expectations" ;
    oc:directiveContent "Never pass an assertion based on surface-level compliance alone (e.g., correct filename but empty/wrong content). Verify genuine task completion." ;
    oc:hasRationale "Surface compliance can be satisfied trivially or by coincidence without the underlying work being correct, creating false confidence." ;
    oc:severityLevel "CRITICAL" .

oc:kn_dbb6224d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When examining output files during Step 2" ;
    oc:directiveContent "Don't rely solely on what the transcript says the executor produced — independently inspect output files to verify their actual content and quality." ;
    oc:hasRationale "Transcripts can report actions that didn't actually produce correct results; independent verification catches discrepancies." ;
    oc:severityLevel "HIGH" .

