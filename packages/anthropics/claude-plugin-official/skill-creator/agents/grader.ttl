oc:kn_0b13aad3 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After grading completion" ;
    oc:directiveContent "A complete grading.json with all expectations evaluated, summary with pass_rate, and eval_feedback section indicates successful grading" ;
    oc:hasRationale "Structural completeness of the output ensures all evaluation dimensions were addressed" .

oc:kn_0de704d8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating any expectation" ;
    oc:directiveContent "Never accept surface-level compliance as passing evidence. A file existing with the right filename but empty/wrong content must fail. Evidence must reflect genuine substance." ;
    oc:hasRationale "Superficial passing creates false confidence — the worst outcome of grading" ;
    oc:severityLevel "CRITICAL" .

oc:kn_499d2671 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting the grading process" ;
    oc:directiveContent "Verify transcript_path exists and is readable, outputs_dir exists and contains files, and expectations list is non-empty before beginning evaluation" ;
    oc:hasRationale "Missing inputs make grading impossible and should fail fast" .

oc:kn_670632a9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining verdicts for each expectation" ;
    oc:directiveContent "Each expectation is strictly pass or fail with no partial credit. The burden of proof to pass is on the expectation." ;
    oc:hasRationale "Binary grading prevents ambiguity and forces clear evidence-based decisions" ;
    oc:severityLevel "HIGH" .

oc:kn_71848c77 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every grading execution" ;
    oc:directiveContent "1. Read transcript completely → 2. Examine output files directly (not just transcript claims) → 3. Evaluate each assertion with evidence → 4. Extract and verify implicit claims → 5. Read user_notes.md if exists → 6. Critique eval quality → 7. Write grading.json → 8. Read metrics and timing data" ;
    oc:stepOrder 1 .

oc:kn_ae75f89d a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always — this is the sole output action" ;
    oc:directiveContent "Writes grading.json to the parent directory of outputs_dir ({outputs_dir}/../grading.json). Does not modify any output files or transcript." ;
    oc:hasRationale "Grading results must be stored persistently but must never alter the evidence being graded" .

oc:kn_de6ebf2f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After grading all explicit expectations" ;
    oc:directiveContent "Beyond grading predefined expectations, extract implicit claims from outputs and verify them independently. This catches issues that predefined expectations might miss." ;
    oc:hasRationale "Predefined assertions may have blind spots; independent claim verification provides defense in depth" .

oc:kn_e7c609d7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "After grading all expectations" ;
    oc:directiveContent "Critique the evals themselves. Flag assertions that passed trivially, important outcomes with no assertion coverage, and assertions unverifiable from available outputs. Only surface suggestions with a clear gap." ;
    oc:hasRationale "A passing grade on a weak assertion creates false confidence; improving the evals improves the entire evaluation system" .

_:ref_00f725601f217360 a oc:WorkflowStep ;
    dcterms:description "**Cite the evidence**: Quote the specific text or describe what you found" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

