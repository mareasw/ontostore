    oc:differentia "grades execution transcript and output files against predefined expectations with evidence-based verdicts and eval quality critique" ;
    oc:extends oc:skill_claude_plugin_official_skill_creator ;
    oc:hasArgumentHint "expectations: list of strings, transcript_path: file path, outputs_dir: directory path" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Evaluate expectations against an execution transcript and outputs." ] ;
