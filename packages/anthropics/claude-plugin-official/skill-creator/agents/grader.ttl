    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 1 ;
            oc:itemText "**PASS**: Clear evidence the expectation is true AND the evidence reflects genuine task completion, not just surface-level compliance" ],
        [ a oc:BulletItem ;
