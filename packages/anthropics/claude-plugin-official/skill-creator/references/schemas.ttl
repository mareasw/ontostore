oc:kn_5ae11034 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When subagent tasks complete" ;
    oc:directiveContent "Timing data (total_tokens, duration_ms) arrives only in the subagent task notification and is not persisted elsewhere — save to timing.json immediately upon receipt." ;
    oc:hasRationale "Once the notification is dismissed, the timing data cannot be recovered" ;
    oc:severityLevel "HIGH" .

oc:kn_b831c3fd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating grading.json" ;
    oc:directiveContent "The grading.json expectations array must use the fields 'text', 'passed', and 'evidence' — not 'name'/'met'/'details' or other variants." ;
    oc:hasRationale "The eval viewer depends on these exact field names to render pass/fail results" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ca791c2d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When understanding the overall evaluation architecture" ;
    oc:directiveContent "Seven distinct JSON schemas define the evaluation pipeline: evals.json (test definitions), history.json (version tracking), grading.json (assertion results), metrics.json (execution stats), timing.json (wall clock), benchmark.json (aggregated comparisons), comparison.json (blind A/B results), analysis.json (post-hoc insights)." ;
    oc:hasRationale "Each schema serves a distinct purpose in the create-test-grade-improve lifecycle" .

oc:kn_caac5f30 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating run entries in benchmark.json" ;
    oc:directiveContent "benchmark.json runs must use 'configuration' with values 'with_skill' or 'without_skill' exactly — the viewer uses this string for grouping and color coding." ;
    oc:hasRationale "The viewer groups runs by this exact string value to produce with/without skill comparisons" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d5b04002 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating benchmark.json manually" ;
    oc:directiveContent "The benchmark.json viewer reads field names exactly — using 'config' instead of 'configuration', or putting 'pass_rate' at the top level of a run instead of nested under 'result', will cause the viewer to show empty/zero values." ;
    oc:hasRationale "The viewer depends on exact field names for grouping and color coding; any deviation silently breaks the display" ;
    oc:severityLevel "CRITICAL" .

