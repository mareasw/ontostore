_:ref_2e36beeca13b02f0 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_05eb2380459553cc,
        _:ref_0aad709050196bf6,
