    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_3ce0fa2088227a54 a oc:WorkflowStep ;
    dcterms:description "Write SKILL.md with frontmatter (name, description) and markdown instructions following skill writing guide" ;
    oc:expectedOutcome "Draft SKILL.md created" ;
    oc:stepDependsOn _:ref_af5e0f871f47dd1d ;
    oc:stepId "write-skill" .

_:ref_417109664878d923 a oc:WorkflowStep ;
    dcterms:description "Generate trigger eval queries, review with user, run optimization loop, apply best description" ;
    oc:expectedOutcome "Optimized skill description with improved triggering" ;
    oc:stepDependsOn _:ref_b94082e8aab3eaff ;
