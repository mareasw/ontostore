        oc:kn_29792a02,
        oc:kn_2b1cd119,
        oc:kn_32dd61b4,
        oc:kn_3f1b7d39,
        oc:kn_7c5f2144,
        oc:kn_8182e9d7,
        oc:kn_8e9c8d8f,
        oc:kn_9698529b,
        oc:kn_9807e0f8,
        oc:kn_9b5437b5,
        oc:kn_9c22da75,
        oc:kn_b191e9ae,
        oc:kn_b29f4915,
        oc:kn_d82ed514,
        oc:kn_e18175cd,
        oc:kn_fd9476ea ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "benchmark skill performance with variance analysis",
        "create new skills from scratch",
        "modify and improve existing skills",
        "optimize skill descriptions for better triggering accuracy",
        "package skills for distribution",
        "run evals to test skill quality" ;
    oc:yieldsState oc:DocumentCreated,
        oc:TestsPassed .

oc:kn_1281442d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing skill instructions" ;
    oc:directiveContent "Do not use ALL CAPS directives (ALWAYS, NEVER, MUST) excessively. Instead, explain the reasoning behind instructions so the model understands why something matters." ;
    oc:hasRationale "Today's LLMs are smart and respond better to reasoned explanations than rigid commands; ALL CAPS is a yellow flag that the instruction may need better justification" .

oc:kn_1d63b116 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When creating any skill content" ;
    oc:directiveContent "Skills must not contain malware, exploit code, or content that could compromise system security. Do not create misleading skills or skills designed to facilitate unauthorized access or data exfiltration." ;
    oc:hasRationale "The Principle of Lack of Surprise — a skill's contents should not surprise the user in their intent if described" ;
    oc:severityLevel "CRITICAL" .

oc:kn_2198c436 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When communicating with users during skill creation" ;
    oc:directiveContent "The skill creator serves users across a wide range of technical familiarity. Pay attention to context cues before using jargon like 'JSON' or 'assertion'. Briefly explain terms when in doubt." ;
    oc:hasRationale "Users range from plumbers opening terminals for the first time to experienced developers; mismatched communication creates friction" .

oc:kn_2394db0b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When improving a skill after receiving user feedback" ;
    oc:directiveContent "Generalize from user feedback rather than making overfitty changes. When improving a skill, look for patterns across test cases, bundle repeated helper scripts, and explain the 'why' behind instructions instead of using rigid MUST/NEVER constraints." ;
    oc:hasRationale "Skills are used across thousands of diverse prompts. Overfitting to a few test cases makes the skill brittle; explaining reasoning leverages the model's intelligence more effectively than rigid rules" .

oc:kn_2429250a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or structuring any skill" ;
    oc:directiveContent "Skills use progressive disclosure: metadata always in context (~100 words), SKILL.md body loaded on trigger (<500 lines ideal), bundled resources loaded as needed. Keep SKILL.md under 500 lines with clear pointers to reference files for deeper content." ;
    oc:hasRationale "Manages context window budget efficiently — the model only loads what it needs for the current task" ;
    oc:severityLevel "HIGH" .

oc:kn_29792a02 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When launching the eval viewer for human review" ;
    oc:directiveContent "python <skill-creator-path>/eval-viewer/generate_review.py <workspace>/iteration-N --skill-name \"my-skill\" --benchmark <workspace>/iteration-N/benchmark.json [--previous-workspace <workspace>/iteration-<N-1>] [--static <output_path>]" .

oc:kn_2b1cd119 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When optimizing a skill's description for better triggering" ;
    oc:directiveContent "1. Create 20 trigger eval queries (8-10 should-trigger, 8-10 should-not-trigger) with realistic, specific user prompts including backstory, file paths, and casual speech 2. Present to user via eval_review.html for review 3. Run scripts.run_loop with --max-iterations 5 4. Apply best_description from output to SKILL.md frontmatter" ;
    oc:stepOrder 2 .

oc:kn_32dd61b4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting eval assertions for a skill" ;
    oc:directiveContent "Do not force quantitative assertions onto subjective outputs (writing style, design quality). Subjective skills are better evaluated qualitatively through human review." ;
    oc:hasRationale "Forcing objective assertions on subjective outputs creates false precision and wastes time; human judgment is the right tool for qualitative assessment" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3f1b7d39 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When packaging a finished skill for distribution" ;
    oc:directiveContent "python -m scripts.package_skill <path/to/skill-folder>" .

oc:kn_7c5f2144 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing grading output from the grader agent" ;
    oc:directiveContent "The grading.json expectations array must use exactly the field names 'text', 'passed', and 'evidence' — the eval viewer depends on these exact names." ;
    oc:hasRationale "The viewer parses these fields by name; using alternatives like 'name'/'met'/'details' will cause the viewer to fail silently" ;
    oc:severityLevel "CRITICAL" .

oc:kn_8182e9d7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running run_loop.py for description optimization" ;
    oc:directiveContent "For description optimization, use the model ID from the current session's system prompt so the triggering test matches what the user actually experiences." ;
    oc:hasRationale "Different models may trigger skills differently; testing against the same model the user is using ensures the optimization is valid" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8e9c8d8f a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Full skill creation workflow" ;
    oc:directiveContent "1. Capture user intent (what the skill does, when it triggers, output format, need for test cases) 2. Interview and research edge cases 3. Write SKILL.md with frontmatter and instructions 4. Write 2-3 realistic test prompts 5. Spawn with-skill and baseline runs in parallel 6. Draft assertions while runs execute 7. Capture timing data as runs complete 8. Grade, aggregate into benchmark, launch eval viewer 9. Read user feedback and improve skill 10. Repeat until satisfied, then optimize description" ;
    oc:stepOrder 1 .

oc:kn_9698529b a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When subagent tasks complete during eval runs" ;
    oc:directiveContent "Timing data from subagent notifications (total_tokens, duration_ms) must be saved immediately to timing.json — it is not persisted anywhere else and cannot be recovered after the notification is processed." ;
    oc:hasRationale "This is the only opportunity to capture execution metrics; batching notifications risks losing data" ;
    oc:severityLevel "HIGH" .

oc:kn_9807e0f8 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating a new skill directory structure" ;
    oc:directiveContent """skill-name/
├── SKILL.md (required: YAML frontmatter with name + description, then markdown instructions)
└── Bundled Resources (optional)
    ├── scripts/    - Executable code for deterministic/repetitive tasks
    ├── references/ - Docs loaded into context as needed
    └── assets/     - Files used in output (templates, icons, fonts)""" .

oc:kn_9b5437b5 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running the description optimization loop" ;
    oc:directiveContent "python -m scripts.run_loop --eval-set <path-to-trigger-eval.json> --skill-path <path-to-skill> --model <model-id> --max-iterations 5 --verbose" .

oc:kn_9c22da75 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating the evals.json file for a skill" ;
    oc:directiveContent """{
  "skill_name": "example-skill",
  "evals": [
    {
      "id": 1,
      "prompt": "User's task prompt",
      "expected_output": "Description of expected result",
      "files": [],
      "expectations": ["verifiable statements"]
    }
  ]
}""" ;
    oc:templateVariables "expectations",
        "expected_output",
        "files",
        "id",
        "prompt",
        "skill_name" .

oc:kn_b191e9ae a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When aggregating benchmark results after grading" ;
    oc:directiveContent "python -m scripts.aggregate_benchmark <workspace>/iteration-N --skill-name <name>" .

oc:kn_b29f4915 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running any skill-creator scripts" ;
    oc:directiveContent "Python 3.x must be available for running evaluation, benchmarking, and packaging scripts" .

oc:kn_d82ed514 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After running test cases in any environment (Claude Code or Cowork)" ;
    oc:directiveContent "Generate the eval viewer (generate_review.py) BEFORE evaluating inputs yourself. Get outputs in front of the human ASAP rather than revising the skill based on your own analysis." ;
    oc:hasRationale "Human review is the primary quality signal; deferring it while you self-evaluate wastes time and risks missing issues the user would catch immediately" ;
    oc:severityLevel "HIGH" .

oc:kn_e18175cd a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When running and evaluating test cases" ;
    oc:directiveContent "1. For each test case spawn TWO subagents simultaneously (with-skill + baseline) 2. Save timing data immediately on notification 3. Grade using agents/grader.md 4. Aggregate with scripts.aggregate_benchmark 5. Launch viewer with generate_review.py (use --static for Cowork/headless) 6. Read feedback.json after user review" ;
    oc:stepOrder 3 .

oc:kn_fd9476ea a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing skill description in YAML frontmatter" ;
    oc:directiveContent "Make skill descriptions slightly 'pushy' — include specific contexts and phrases for when to use the skill, even if the user doesn't explicitly name it. Claude tends to undertrigger skills." ;
    oc:hasRationale "The description is the primary triggering mechanism. Under-triggering is a known failure mode; explicit context cues improve invocation accuracy" .

_:ref_05eb2380459553cc a oc:WorkflowStep ;
    dcterms:description "What should this skill enable Claude to do?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_0aad709050196bf6 a oc:WorkflowStep ;
    dcterms:description "What's the expected output format?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_0dbf56f12453c3d7 a oc:WorkflowStep ;
    dcterms:description "Replace the placeholders:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 3 ;
                    oc:itemText "`__SKILL_DESCRIPTION_PLACEHOLDER__` → the skill's current description" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "`__SKILL_NAME_PLACEHOLDER__` → the skill's name" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "`__EVAL_DATA_PLACEHOLDER__` → the JSON array of eval items (no quotes around it — it's a JS variable assignment)" ] ] ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_0f157918bf4f6657 a oc:WorkflowStep ;
    dcterms:description "Read the template from `assets/eval_review.html`" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_23e21fa97c24ea41 a oc:WorkflowStep ;
    dcterms:description "**Keep the prompt lean.** Remove things that aren't pulling their weight. Make sure to read the transcripts, not just the final outputs — if it looks like the skill is making the model waste a bunch of time doing things that are unproductive, you can try getting rid of the parts of the skill that are making it do that and seeing what happens." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_3050aea510893c45 a oc:Paragraph ;
    oc:blockType "paragraph" ;
    oc:contentOrder 2 ;
    oc:textContent """This produces `benchmark.json` and `benchmark.md` with pass_rate, time, and tokens for each configuration, with mean ± stddev and the delta. If generating benchmark.json manually, see `references/schemas.md` for the exact schema the viewer expects.
Put each with_skill version before its baseline counterpart.""" .

_:ref_32d9486f1c58b979 a oc:WorkflowStep ;
    dcterms:description "Rerun all test cases into a new `iteration-<N+1>/` directory, including baseline runs. If you're creating a new skill, the baseline is always `without_skill` (no skill) — that stays the same across iterations. If you're improving an existing skill, use your judgment on what makes sense as the baseline: the original version the user came in with, or the previous iteration." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_33b12c642ad25554 a oc:Paragraph ;
    oc:blockType "paragraph" ;
    oc:contentOrder 3 ;
    oc:textContent "**Cowork / headless environments:** If `webbrowser.open()` is not available or the environment has no display, use `--static <output_path>` to write a standalone HTML file instead of starting a server. Feedback will be downloaded as a `feedback.json` file when the user clicks \"Submit All Reviews\". After download, copy `feedback.json` into the workspace directory for the next iteration to pick up." .

_:ref_3e156be3a3d2fe26 a oc:WorkflowStep ;
    dcterms:description "Read the new feedback, improve again, repeat" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_4caa3009c6476124 a oc:WorkflowStep ;
    dcterms:description "Wait for the user to review and tell you they're done" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_544463db30f54803 a oc:WorkflowStep ;
    dcterms:description "Should we set up test cases to verify the skill works? Skills with objectively verifiable outputs (file transforms, data extraction, code generation, fixed workflow steps) benefit from test cases. Skills with subjective outputs (writing style, art) often don't need them. Suggest the appropriate default based on the skill type, but let the user decide." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_599a40f92ec49364 a oc:Paragraph ;
    oc:blockType "paragraph" ;
    oc:contentOrder 2 ;
    oc:textContent "For iteration 2+, also pass `--previous-workspace <workspace>/iteration-<N-1>`." .

_:ref_65d9f631713872af a oc:WorkflowStep ;
    dcterms:description "**Tell the user** something like: \"I've opened the results in your browser. There are two tabs — 'Outputs' lets you click through each test case and leave feedback, 'Benchmark' shows the quantitative comparison. When you're done, come back here and let me know.\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_804e4545a3689523 a oc:WorkflowStep ;
    dcterms:description "**Aggregate into benchmark** — run the aggregation script from the skill-creator directory:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild _:ref_3050aea510893c45,
        [ a oc:CodeExample ;
            oc:blockType "code_block" ;
            oc:codeContent """python -m scripts.aggregate_benchmark <workspace>/iteration-N --skill-name <name>
""" ;
            oc:codeLanguage "bash" ;
            oc:contentOrder 1 ;
            oc:sourceLocation "lines 228-230" ] ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_92bdf0d0cfe3bcba a oc:WorkflowStep ;
    dcterms:description "**SKILL.md body** - In context whenever skill triggers (<500 lines ideal)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_930af61db3f5d966 a oc:WorkflowStep ;
    dcterms:description "**Grade each run** — spawn a grader subagent (or grade inline) that reads `agents/grader.md` and evaluates each assertion against the outputs. Save results to `grading.json` in each run directory. The grading.json expectations array must use the fields `text`, `passed`, and `evidence` (not `name`/`met`/`details` or other variants) — the viewer depends on these exact field names. For assertions that can be checked programmatically, write and run a script rather than eyeballing it — scripts are faster, more reliable, and can be reused across iterations." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_9c07994d867ebac8 a oc:WorkflowStep ;
    dcterms:description "Apply your improvements to the skill" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_a357a31746b2b07f a oc:WorkflowStep ;
    dcterms:description "Write to a temp file (e.g., `/tmp/eval_review_<skill-name>.html`) and open it: `open /tmp/eval_review_<skill-name>.html`" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_b3112b7e845f5ebf a oc:WorkflowStep ;
    dcterms:description "The user can edit queries, toggle should-trigger, add/remove entries, then click \"Export Eval Set\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_b44faa267e393e79 a oc:CodeExample ;
    oc:blockType "code_block" ;
    oc:codeContent """nohup python <skill-creator-path>/eval-viewer/generate_review.py \\
  <workspace>/iteration-N \\
  --skill-name "my-skill" \\
  --benchmark <workspace>/iteration-N/benchmark.json \\
  > /dev/null 2>&1 &
VIEWER_PID=$!
""" ;
    oc:codeLanguage "bash" ;
    oc:contentOrder 1 ;
    oc:sourceLocation "lines 237-244" .

_:ref_bf19dff63f6ccaed a oc:WorkflowStep ;
    dcterms:description "The file downloads to `~/Downloads/eval_set.json` — check the Downloads folder for the most recent version in case there are multiple (e.g., `eval_set (1).json`)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_c3df1200d77dd9d3 a oc:WorkflowStep ;
    dcterms:description "**Generalize from the feedback.** The big picture thing that's happening here is that we're trying to create skills that can be used a million times (maybe literally, maybe even more who knows) across many different prompts. Here you and the user are iterating on only a few examples over and over again because it helps move faster. The user knows these examples in and out and it's quick for them to assess new outputs. But if the skill you and the user are codeveloping works only for those examples, it's useless. Rather than put in fiddly overfitty changes, or oppressively constrictive MUSTs, if there's some stubborn issue, you might try branching out and using different metaphors, or recommending different patterns of working. It's relatively cheap to try and maybe you'll land on something great." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_d20435de8e7d6aa6 a oc:WorkflowStep ;
    dcterms:description "When should this skill trigger? (what user phrases/contexts)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_d3d2064b7700e3f6 a oc:WorkflowStep ;
    dcterms:description "**Explain the why.** Try hard to explain the **why** behind everything you're asking the model to do. Today's LLMs are *smart*. They have good theory of mind and when given a good harness can go beyond rote instructions and really make things happen. Even if the feedback from the user is terse or frustrated, try to actually understand the task and why the user is writing what they wrote, and what they actually wrote, and then transmit this understanding into the instructions. If you find yourself writing ALWAYS or NEVER in all caps, or using super rigid structures, that's a yellow flag — if possible, reframe and explain the reasoning so that the model understands why the thing you're asking for is important. That's a more humane, powerful, and effective approach." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_d4dc2ee613012070 a oc:WorkflowStep ;
    dcterms:description "Launch the reviewer with `--previous-workspace` pointing at the previous iteration" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_e2d4cf253e0a4329 a oc:WorkflowStep ;
    dcterms:description "**Bundled resources** - As needed (unlimited, scripts can execute without loading)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_e50bed77bc2cba29 a oc:WorkflowStep ;
    dcterms:description "**Do an analyst pass** — read the benchmark data and surface patterns the aggregate stats might hide. See `agents/analyzer.md` (the \"Analyzing Benchmark Results\" section) for what to look for — things like assertions that always pass regardless of skill (non-discriminating), high-variance evals (possibly flaky), and time/token tradeoffs." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_f0e087a5edae2f3f a oc:WorkflowStep ;
    dcterms:description "**Look for repeated work across test cases.** Read the transcripts from the test runs and notice if the subagents all independently wrote similar helper scripts or took the same multi-step approach to something. If all 3 test cases resulted in the subagent writing a `create_docx.py` or a `build_chart.py`, that's a strong signal the skill should bundle that script. Write it once, put it in `scripts/`, and tell the skill to use it. This saves every future invocation from reinventing the wheel." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_f2c1f9b3cf6c8abd a oc:WorkflowStep ;
    dcterms:description "**Launch the viewer** with both qualitative outputs and quantitative data:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild _:ref_33b12c642ad25554,
        _:ref_599a40f92ec49364,
        _:ref_b44faa267e393e79 ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_fd4b13c032832f80 a oc:WorkflowStep ;
    dcterms:description "**Metadata** (name + description) - Always in context (~100 words)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_093a9e768b3d96c2 a oc:WorkflowStep ;
    dcterms:description "Spawn with-skill and baseline subagents for all test cases simultaneously, capture timing data" ;
    oc:expectedOutcome "All test runs completed with timing data saved" ;
    oc:stepDependsOn _:ref_00611b16c97f4cb7 ;
    oc:stepId "run-test-cases" .

