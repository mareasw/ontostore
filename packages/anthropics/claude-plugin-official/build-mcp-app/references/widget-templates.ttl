                            oc:contentOrder 2 ;
                            oc:textContent "**Tool returns:** `{ content: [{ type: \"text\", text: JSON.stringify({ items: [{ id, label, sub? }] }) }] }`" ] ;
                    oc:sectionLevel 2 ;
