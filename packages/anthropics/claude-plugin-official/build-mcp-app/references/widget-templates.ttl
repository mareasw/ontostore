oc:kn_1613fce1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building carousel widgets" ;
    oc:directiveContent "For carousel widgets, skip navigation chevrons and scroll-snap-type. Users know how to scroll horizontally. Reset scrollLeft to 0 after rendering instead." ;
    oc:hasRationale "scroll-snap-type can cause a few-pixel-off initial render; nav chevrons add unnecessary complexity for a horizontal scroll rail." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2a30f1cc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building interactive widgets with ongoing state" ;
    oc:directiveContent "For carousel widgets, use silent state updates via app.updateModelContext for selection/cart changes, reserving app.sendMessage only for terminal actions like 'checkout' or 'done'." ;
    oc:hasRationale "Avoids spamming the chat with intermediate state changes while keeping Claude informed of current context." .

oc:kn_3973ee12 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing widget HTML/CSS/JS" ;
    oc:directiveContent "Never use window.open(), <a target=\"_blank\">, external CSS, external fonts, eval(), new Function(), or inline event handlers (onclick=\"...\") in widget HTML." ;
    oc:hasRationale "The iframe sandbox and CSP block popups, external resources, eval, and inline event handlers. Use addEventListener, inline <style> tags, system-ui fonts, and app.openLink() instead." ;
    oc:severityLevel "CRITICAL" .

oc:kn_52d6e740 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When widgets need to display images" ;
    oc:directiveContent "Fetch external images server-side in the tool handler and embed as data: URLs in the JSON payload — the iframe CSP blocks remote img-src and referrer hotlink policies block direct CDN images." ;
    oc:hasRationale "Both CSP restrictions and CDN referrer policies prevent loading external images directly in the sandboxed iframe." ;
    oc:severityLevel "HIGH" .

oc:kn_665adcf5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any MCP widget" ;
    oc:directiveContent "All widget templates must inline the @modelcontextprotocol/ext-apps bundle at build time via the /*__EXT_APPS_BUNDLE__*/ placeholder — the iframe CSP blocks CDN script imports." ;
    oc:hasRationale "The sandboxed iframe enforces a restrictive Content-Security-Policy that prevents loading external scripts." ;
    oc:severityLevel "CRITICAL" .

oc:kn_67d6e00d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between elicitation and a confirm widget" ;
    oc:directiveContent "For simple confirmations, prefer MCP elicitation over a custom confirm widget. Use the confirm widget only when custom styling or richer context is needed." ;
    oc:hasRationale "Elicitation is lighter weight and native to the protocol; widgets add iframe overhead." .

oc:kn_7e7e59a9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing widget architecture" ;
    oc:directiveContent "Keep widgets framework-free (no React/Vue). Widgets are small enough that framework hydration cost isn't worth it." ;
    oc:hasRationale "Simplicity and fast loading matter more than component architecture for small interactive surfaces inside iframes." .

oc:kn_8c5d6ecf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building chart/preview display widgets" ;
    oc:directiveContent "Display-only widgets should return a text summary alongside visual data so Claude can keep reasoning while the user sees the visual." ;
    oc:hasRationale "Claude needs the data in text form to continue the conversation; the widget is for the human's visual benefit." .

oc:kn_9aa6220f a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building any MCP widget" ;
    oc:directiveContent "1. Choose template type (picker, confirm, progress, display, carousel). 2. Copy the HTML scaffold. 3. Inline ext-apps bundle by replacing /*__EXT_APPS_BUNDLE__*/. 4. Register as app resource via registerAppResource with ui:// URI. 5. Create tool with _meta.ui.resourceUri pointing to the resource URI. 6. Return JSON data matching the template's expected shape from the tool handler." ;
    oc:hasRationale "Provides the standard creation workflow from template to working widget." ;
    oc:stepOrder 1 .

oc:kn_a5a7e339 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Every widget's script module body" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const { App } = globalThis.ExtApps;
(async () => {
  const app = new App({ name: "WidgetName", version: "1.0.0" }, {});
  app.ontoolresult = ({ content }) => { /* parse and render */ };
  await app.connect();
})();""" ;
    oc:hasRationale "This is the universal scaffold pattern for all MCP widgets — set handlers before connect to avoid missing early results." .

oc:kn_cd2f6acf a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When returning tool results for each widget type" ;
    oc:directiveContent """Picker: { items: [{ id, label, sub? }] }
Confirm: { message, confirmLabel? }
Progress: { progress, total, message?, done? }
Display: text summary + JSON data on separate lines
Carousel: items with note field for inline reasoning""" ;
    oc:hasRationale "Each widget template expects a specific JSON shape from the tool handler to render correctly." .

oc:kn_cf459ffc a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Server-side bundle preparation for all widget templates" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """const bundle = readFileSync(
  require.resolve("@modelcontextprotocol/ext-apps/app-with-deps"), "utf8",
).replace(/export\\{([^}]+)\\};?\\s*$/, (_, body) =>
  "globalThis.ExtApps={" +
  body.split(",").map((p) => {
    const [local, exported] = p.split(" as ").map((s) => s.trim());
    return `${exported ?? local}:${local}`;
  }).join(",") + "};",
);""" ;
    oc:hasRationale "Rewrites the ESM export into a globalThis assignment so it works from an inline script module without import statements." .

oc:kn_fa6fcbf6 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before serving any widget HTML" ;
    oc:directiveContent "Bundle the ext-apps/app-with-deps once per server startup (or at build time) and reuse across all widget templates. Use the replacer function form () => bundle in String.replace to avoid $-sequence mangling in the minified bundle." ;
    oc:hasRationale "The minified bundle contains $ characters that String.replace would misinterpret as special replacement patterns if passed as a bare string." ;
    oc:severityLevel "HIGH" .

