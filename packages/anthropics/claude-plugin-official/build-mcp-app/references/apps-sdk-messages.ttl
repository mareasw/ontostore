@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_build_mcp_app_apps_sdk_messages a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "apps-sdk-messages" ;
    skos:broader "messaging API reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/build-mcp-app" ;
    oc:contentHash "098476e15b109681c3f0d3e8ee0f852dfcd337628e67e0acc58ab66f91fa8039" ;
    oc:differentia "governs bidirectional communication between ext-apps widgets, the Claude host, and MCP servers via sendMessage, updateModelContext, callServerTool, ontoolresult, and progress notifications" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_build_mcp_app ;
    oc:handlesFailure oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "messaging direction (widget-to-host, host-to-widget, server-to-widget)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_05f75ed8,
        oc:kn_51b7368c,
        oc:kn_9bafeea0,
        oc:kn_ac75c1be,
        oc:kn_b613a1b3,
        oc:kn_d3ec29b7,
        oc:kn_dae53eaa,
        oc:kn_f9f3814c ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "call MCP server tools directly from widget",
        "debug iframe sandbox and CSP restrictions",
        "emit progress notifications for long-running server operations",
        "handle tool results in widget",
        "navigate or download files from sandboxed widget",
        "send messages from widget to conversation",
        "silently update Claude context from widget",
        "subscribe to host context changes like theme" ;
    oc:yieldsState oc:WidgetConnected .

oc:kn_05f75ed8 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a widget renders incorrectly or appears blank" ;
    oc:directiveContent "When debugging CSP issues, open the iframe's own DevTools console (not the main app's) — CSP violations log there. If edited HTML doesn't appear in Desktop, fully quit (⌘Q) and relaunch, not just window-close." ;
    oc:hasRationale "CSP violations are logged in the iframe context, not the parent. Desktop caches UI resources aggressively and requires a full quit to clear." ;
    oc:severityLevel "HIGH" .

oc:kn_51b7368c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When initializing a widget's data-in handler" ;
    oc:directiveContent "Set `app.ontoolresult` BEFORE calling `await app.connect()` — the result may arrive immediately after connection." ;
    oc:hasRationale "If ontoolresult is set after connect(), the first tool result may be missed, leaving the widget blank." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9bafeea0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing widget lifecycle and state management" ;
    oc:directiveContent "Treat widgets as long-lived persistent surfaces — there is no explicit submit-and-close. Subsequent calls to the same tool reuse the iframe and fire `ontoolresult` again." ;
    oc:hasRationale "The widget persists until conversation context moves on, so design for incremental updates rather than one-shot form submission." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ac75c1be a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before deploying any widget to production" ;
    oc:directiveContent "Ensure the ext-apps bundle is inlined (not CDN-imported) and all JS uses `addEventListener` (not inline handlers) before deploying a widget." ;
    oc:hasRationale "CDN imports and inline event handlers are the two most common causes of blank or non-functional widgets due to CSP restrictions." ;
    oc:severityLevel "HIGH" .

oc:kn_b613a1b3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling widgets that must respond to host theme changes" ;
    oc:directiveContent "Keep widget colors in CSS custom properties with a `:root.dark {}` override block and set `color-scheme: light | dark` so native form controls follow the host theme." ;
    oc:hasRationale "The host can toggle themes mid-conversation via `onhostcontextchanged`; CSS custom properties with a dark override provide the cleanest reactive pattern." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d3ec29b7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a widget needs to navigate to an external URL" ;
    oc:directiveContent "Use `app.openLink({url})` for all outbound navigation — the iframe sandbox blocks `window.open()` and `<a target='_blank'>`. Intercept clicks with `preventDefault()` + `app.openLink`." ;
    oc:hasRationale "The sandbox attribute and CSP prevent all direct navigation; host-mediated openLink is the only path." ;
    oc:severityLevel "CRITICAL" .

oc:kn_dae53eaa a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which widget-to-host messaging method to use" ;
    oc:directiveContent "Use `app.sendMessage` for user-visible actions that should become conversation turns; use `app.updateModelContext` for silent state that informs Claude without a chat bubble; use `app.callServerTool` for data fetches that don't need Claude's reasoning." ;
    oc:hasRationale "Choosing the right method avoids unnecessary conversation clutter and optimizes latency by bypassing Claude when reasoning isn't needed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f9f3814c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any widget HTML/JS for the ext-apps iframe" ;
    oc:directiveContent "Do not use CDN imports, external CSS, external fonts, `<a target='_blank'>`, inline event handlers (`onclick`), `eval`, `new Function`, or direct `fetch()` to external APIs in widgets." ;
    oc:hasRationale "The restrictive CSP and sandbox attribute block all external resource loading and unsafe JS evaluation. Use inline bundles, `addEventListener`, system fonts, and route API calls through `app.callServerTool()`." ;
    oc:severityLevel "HIGH" .

