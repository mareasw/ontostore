oc:skill_claude_plugin_official_build_mcp_app_apps_sdk_messages a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "apps-sdk-messages" ;
    skos:broader "Messaging API reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/build-mcp-app" ;
    oc:contentHash "098476e15b109681c3f0d3e8ee0f852dfcd337628e67e0acc58ab66f91fa8039" ;
    oc:differentia "that defines bidirectional communication patterns between MCP ext-apps widgets, hosts, and servers via the App class SDK" ;
    oc:extends oc:skill_claude_plugin_official_build_mcp_app ;
    oc:hasArgumentHint "messaging-direction (widget-to-host, host-to-widget, server-to-widget)" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "The `@modelcontextprotocol/ext-apps` package provides the `App` class (browser side) and `registerAppTool`/`registerAppResource` helpers (server side). Messaging is bidirectional and persistent." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "When in doubt, open the **iframe's own** devtools console (not the main app's) — CSP violations log there. See `iframe-sandbox.md` for the bundle-inlining pattern." ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 10 ;
                            oc:tableCaption "The iframe runs under both an HTML `sandbox` attribute **and** a restrictive Content-Security-Policy. The practical effect is that almost nothing external is allowed — widgets should be self-contained." ;
                            oc:tableMarkdown """| Symptom | Cause | Fix |
|---|---|---|
| Widget is a blank rectangle, nothing renders | CDN `import` of ext-apps blocked (transitive SDK fetches) | **Inline** the `ext-apps/app-with-deps` bundle — see `iframe-sandbox.md` |
| Widget renders but JS doesn't run | Inline event handlers blocked | Use `addEventListener` — never `onclick="..."` in HTML |
| `eval` / `new Function` errors | Script-src restriction | Don't use them; use JSON.parse for data |
| `fetch()` to your API fails | Cross-origin blocked | Route through `app.callServerTool()` instead |
| External CSS doesn't load | `style-src` restriction | Inline styles in a `<style>` tag |
| Fonts don't load | `font-src` restriction | Use system fonts (`font: 14px system-ui`) |
| External `<img src>` broken | CSP `img-src` + referrer hotlink blocking | Fetch server-side, inline as `data:` URL in the tool result payload |
| `window.open()` does nothing | Sandbox lacks `allow-popups` | Use `app.openLink({url})` |
| `<a target="_blank">` does nothing | Same | Intercept click → `preventDefault()` → `app.openLink` |
| Edited HTML doesn't appear in Desktop | Desktop caches UI resources | Fully quit (⌘Q) + relaunch, not just window-close |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The iframe runs under both an HTML `sandbox` attribute **and** a restrictive Content-Security-Policy. The practical effect is that almost nothing external is allowed — widgets should be self-contained." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Sandbox & CSP gotchas" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Fires with the arguments Claude passed to the tool. Useful if the widget needs to know what was asked for (e.g., highlight the search term)." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "`app.ontoolinput = ({ arguments }) => {...}`" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """app.ontoolresult = ({ content }) => {
  const data = JSON.parse(content[0].text);
  renderUI(data);
};
""" ;
                                    oc:codeLanguage "js" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 74-79" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Set this BEFORE `await app.connect()`** — the result may arrive immediately after connection." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Fires when the tool handler's return value is piped to the widget. This is the primary data-in path." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "`app.ontoolresult = ({ content }) => {...}`" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Keep colors in CSS custom props with a `:root.dark {}` override block and set `color-scheme: light | dark` so native form controls follow." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Read and subscribe to host context — `theme` (`\"light\"` / `\"dark\"`), locale, etc. Call `getHostContext()` **after** `connect()`. Subscribe for live updates (user toggles dark mode mid-conversation)." ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """const applyTheme = (t) =>
  document.documentElement.classList.toggle("dark", t === "dark");

app.onhostcontextchanged = (ctx) => applyTheme(ctx.theme);
await app.connect();
applyTheme(app.getHostContext()?.theme);
""" ;
                                    oc:codeLanguage "js" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 91-98" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "`app.getHostContext()` / `app.onhostcontextchanged = (ctx) => {...}`" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Host → Widget" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "No `{ notify }` destructure — `extra` is `RequestHandlerExtra`; progress goes through `sendNotification`." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "For long-running operations, emit progress notifications. The client sends a `progressToken` in the request's `_meta`; the server emits against it." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """// In the tool handler
async ({ query }, extra) => {
  const token = extra._meta?.progressToken;
  for (let i = 0; i < steps.length; i++) {
    if (token !== undefined) {
      await extra.sendNotification({
        method: "notifications/progress",
        params: { progressToken: token, progress: i, total: steps.length, message: steps[i].name },
      });
    }
    await steps[i].run();
  }
  return { content: [{ type: "text", text: "Complete" }] };
}
""" ;
                            oc:codeLanguage "typescript" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 108-123" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Server → Widget (progress)" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """app.updateModelContext({
  content: [{ type: "text", text: "Currently viewing: orders from last 30 days" }],
});
""" ;
                                    oc:codeLanguage "js" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 26-30" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Update Claude's context **silently** — no visible message. Use for state that informs but doesn't warrant a chat bubble." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "`app.updateModelContext({ content })`" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Host-mediated download (sandbox blocks direct `<a download>`). `content` is a base64 string." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "`app.downloadFile({ name, mimeType, content })`" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """const result = await app.callServerTool({
  name: "fetch_order_details",
  arguments: { orderId: "1234" },
});
""" ;
                                    oc:codeLanguage "js" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 36-41" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Call a tool on your MCP server directly, bypassing Claude. Returns the tool result." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Use for data fetches that don't need Claude's reasoning — pagination, detail lookups, refreshes." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "`app.callServerTool({ name, arguments })`" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "The message appears in chat and Claude responds to it. Use `role: \"user\"` — the widget speaks on the user's behalf." ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """app.sendMessage({
  role: "user",
  content: [{ type: "text", text: "User selected order #1234" }],
});
""" ;
                                    oc:codeLanguage "js" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 13-18" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Inject a visible message into the conversation. This is how user actions become conversation turns." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "`app.sendMessage({ role, content })`" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "For anchors in rendered HTML, intercept the click:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """card.querySelector("a").addEventListener("click", (e) => {
  e.preventDefault();
  app.openLink({ url: e.currentTarget.href });
});
""" ;
                                    oc:codeLanguage "js" ;
                                    oc:contentOrder 4 ;
                                    oc:sourceLocation "lines 55-60" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """await app.openLink({ url: "https://example.com/cart" });
""" ;
                                    oc:codeLanguage "js" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 49-51" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Open a URL in a new browser tab, host-mediated. **Required** for any outbound navigation — the iframe sandbox blocks `window.open()` and `<a target=\"_blank\">`." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "`app.openLink({ url })`" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Widget → Host" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_581890eb1351dc37,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "There's no explicit \"submit and close\" — the widget is a long-lived surface." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Lifecycle" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "ext-apps messaging — widget ↔ host ↔ server" ] ;
    oc:hasWorkflow _:ref_581890eb1351dc37,
        [ a oc:Workflow ;
            dcterms:description "The full lifecycle of an ext-apps widget from tool invocation to persistent interaction" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Widget persists until conversation moves on — subsequent same-tool calls reuse the iframe and re-fire ontoolresult" ;
                    oc:expectedOutcome "Widget remains a long-lived surface across multiple tool invocations" ;
                    oc:stepDependsOn _:ref_cfa69314dc6a9682 ;
                    oc:stepId "lifecycle-7" ],
                _:ref_8919231140c07c8c,
                _:ref_bf6351b54f101c5b,
                _:ref_cfa69314dc6a9682,
                _:ref_d2f1ecf5b4b34b75,
                _:ref_da2d76321ac59798,
                _:ref_fbd8785d3b9f6b82 ;
            oc:workflowId "widget-lifecycle" ;
            oc:workflowName "Widget Lifecycle" ] ;
    oc:impartsKnowledge oc:kn_06f0d8bd,
        oc:kn_3a7934f0,
        oc:kn_7dadffcc,
        oc:kn_9b454af2,
        oc:kn_b20aef45,
        oc:kn_d71920ef,
        oc:kn_f5af3285 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "call server tools from widget",
        "emit progress notifications from server",
        "handle tool results in widget",
        "implement widget lifecycle and sandbox-safe communication",
        "send messages from widget to host" .

oc:kn_06f0d8bd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up widget event handlers" ;
    oc:directiveContent "Set app.ontoolresult BEFORE await app.connect() — results may arrive immediately after connection." ;
    oc:hasRationale "Race condition: if the handler is not set before connect(), the first tool result will be silently dropped." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3a7934f0 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a widget renders incorrectly or appears blank" ;
    oc:directiveContent "When debugging CSP or rendering issues, open the iframe's own DevTools console (not the main app's console) — CSP violations log there." ;
    oc:hasRationale "The iframe has its own execution context; errors are not surfaced in the parent page's console." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7dadffcc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which messaging method to use from widget to host" ;
    oc:directiveContent "Use app.sendMessage for user-visible actions, app.updateModelContext for silent state updates, and app.callServerTool for data fetches that don't need Claude's reasoning." ;
    oc:hasRationale "Each method has a distinct purpose: sendMessage creates a conversation turn, updateModelContext provides invisible context, callServerTool bypasses Claude for efficiency." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9b454af2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing widget interaction patterns" ;
    oc:directiveContent "Widgets are long-lived surfaces, not request-response forms. Subsequent calls to the same tool reuse the iframe and fire ontoolresult again. There is no explicit submit-and-close." ;
    oc:hasRationale "Understanding the persistence model is essential for correct state management and avoiding unnecessary re-initialization." ;
    oc:severityLevel "HIGH" .

oc:kn_b20aef45 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When developing widgets on Claude Desktop" ;
    oc:directiveContent "Desktop app caches UI resources — edited widget HTML may not appear after changes. Fully quit (Cmd+Q) and relaunch, not just window-close." ;
    oc:hasRationale "The Desktop client aggressively caches iframe resources; simple window-close does not clear the cache." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d71920ef a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When opening URLs or handling link clicks in widget HTML" ;
    oc:directiveContent "All outbound navigation must use app.openLink({url}) — the iframe sandbox blocks window.open() and <a target=\"_blank\">." ;
    oc:hasRationale "The iframe sandbox lacks allow-popups and CSP blocks external navigation; host-mediated openLink is the only path." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f5af3285 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing widget HTML/JS/CSS" ;
    oc:directiveContent "Never use inline event handlers (onclick=\"...\"), eval(), new Function(), external CDN imports, external CSS, or external fonts in widgets." ;
    oc:hasRationale "CSP and sandbox restrictions block all of these; violations result in blank widgets or silent JS failures." ;
    oc:severityLevel "HIGH" .

