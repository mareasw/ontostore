oc:kn_010e63b8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing tool descriptions for widget-enabled tools" ;
    oc:directiveContent "Tool descriptions must mention the widget behavior (e.g., 'Opens an interactive picker') so Claude knows when to reach for it instead of guessing an ID." ;
    oc:hasRationale "Claude only sees the tool description when deciding what to call — without the widget hint it may skip the tool entirely." ;
    oc:severityLevel "HIGH" .

oc:kn_05b39161 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up a new MCP app project" ;
    oc:directiveContent "npm install @modelcontextprotocol/sdk @modelcontextprotocol/ext-apps zod express" .

oc:kn_204b0636 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing widget-enabled tools" ;
    oc:directiveContent "Never build one mega-widget that handles multiple concerns. Use one tool → one focused widget → one clear result shape." ;
    oc:hasRationale "Claude reasons about focused single-purpose tools far better than overloaded ones, and widget code stays maintainable." ;
    oc:severityLevel "HIGH" .

oc:kn_2bc0abb7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing widget functionality" ;
    oc:directiveContent "Widgets cannot access the host page's DOM/cookies/storage, make network calls to arbitrary origins, open popups, or load remote images. Route all external access through app.callServerTool() and app.openLink()." ;
    oc:hasRationale "The iframe sandbox and CSP are designed for security isolation — violations silently fail." ;
    oc:severityLevel "HIGH" .

oc:kn_4c6680c6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between widget vs elicitation" ;
    oc:directiveContent "Before building a widget, check if MCP elicitation (spec-native, zero UI code) covers the use case. Use widgets only for: searchable/large lists, visual previews, charts/maps/diffs, or live-updating progress." ;
    oc:hasRationale "Elicitation is simpler, works in any compliant host, and avoids all iframe/CSP complexity." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4fb6c765 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When testing widget changes in Claude Desktop" ;
    oc:directiveContent "Claude Desktop caches UI resources aggressively. After editing widget HTML, fully quit (Cmd+Q / Alt+F4, not just window-close) and relaunch to force a cold resource re-fetch." ;
    oc:hasRationale "Window-close doesn't clear the resource cache, leading to confusing stale-render debugging." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5e247539 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When inlining the ext-apps bundle into widget HTML at server startup" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """const bundle = readFileSync(
  require.resolve("@modelcontextprotocol/ext-apps/app-with-deps"), "utf8",
).replace(/export\\{([^}]+)\\};?\\s*$/, (_, body) =>
  "globalThis.ExtApps={" +
  body.split(",").map((p) => {
    const [local, exported] = p.split(" as ").map((s) => s.trim());
    return `${exported ?? local}:${local}`;
  }).join(",") + "};",
);
const widgetHtml = readFileSync("./widgets/widget.html", "utf8")
  .replace("/*__EXT_APPS_BUNDLE__*/", () => bundle);""" .

oc:kn_89068f20 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When registering app resources" ;
    oc:directiveContent "Widget HTML resources MUST use mime type 'text/html;profile=mcp-app' (RESOURCE_MIME_TYPE) so the host knows to render them as interactive iframes rather than displaying source code." ;
    oc:hasRationale "This is the signal that distinguishes an interactive widget from a static HTML document in the MCP protocol." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8c7cf268 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the widget-side App initialization inside iframe HTML" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const { App } = globalThis.ExtApps;
(async () => {
  const app = new App({ name: "Widget", version: "1.0.0" }, {});
  app.ontoolresult = ({ content }) => {
    const data = JSON.parse(content[0].text);
    render(data);
  };
  await app.connect();
})();""" .

oc:kn_b331cecb a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """Tool return: { content: [{ type: "text", text: JSON.stringify(data) }] }
Resource return: { contents: [{ uri: "ui://widgets/x.html", mimeType: RESOURCE_MIME_TYPE, text: inlinedHtml }] }""" ;
    oc:templateVariables "data",
        "inlinedHtml" .

oc:kn_b4e21261 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building any MCP app with widgets" ;
    oc:directiveContent "1. Install @modelcontextprotocol/sdk, @modelcontextprotocol/ext-apps, zod, express 2. Inline the ext-apps browser bundle into widget HTML (replace /*__EXT_APPS_BUNDLE__*/ placeholder) 3. Register the tool with _meta.ui.resourceUri pointing to the widget resource 4. Register the resource separately with RESOURCE_MIME_TYPE serving the inlined HTML 5. Set widget handlers (ontoolresult, ontoolinput) BEFORE app.connect() 6. Use app.sendMessage for user actions, app.updateModelContext for silent state" ;
    oc:hasRationale "The dual registration (tool + resource) with bundle inlining is the essential architectural pattern for MCP apps." ;
    oc:stepOrder 1 .

oc:kn_c8ec5677 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing widget-enabled tool handlers" ;
    oc:directiveContent "Widgets are optional at runtime. The tool handler must return meaningful text/JSON data as its primary content — hosts without the apps surface simply ignore _meta.ui and render the text directly." ;
    oc:hasRationale "Graceful degradation ensures the tool works across all MCP hosts, not just those supporting the apps surface." ;
    oc:severityLevel "HIGH" .

oc:kn_c9a96820 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When registering a widget-enabled tool and its corresponding resource" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """registerAppTool(server, "tool_name", {
  description: "Open an interactive X",
  inputSchema: { filter: z.string().optional() },
  _meta: { ui: { resourceUri: "ui://widgets/x.html" } },
}, async ({ filter }) => {
  const data = await fetchData(filter);
  return { content: [{ type: "text", text: JSON.stringify(data) }] };
});

registerAppResource(server, "X Widget", "ui://widgets/x.html", {},
  async () => ({
    contents: [{ uri: "ui://widgets/x.html", mimeType: RESOURCE_MIME_TYPE, text: widgetHtml }],
  }),
);""" .

oc:kn_d4f72a56 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing widget HTML/JS" ;
    oc:directiveContent "Never use CDN imports (e.g., import from esm.sh) inside widget HTML — the iframe CSP blocks transitive dependency fetches and the widget renders as a blank rectangle with no visible error." ;
    oc:hasRationale "CSP violations only appear in the iframe's own devtools console, not the host's main console, making them extremely hard to debug." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f94be125 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When debugging blank or broken widgets" ;
    oc:directiveContent "When a widget renders as a blank rectangle: 1) Open the iframe's own devtools console (not the host's main console) 2) Check for CSP violations 3) Verify the ext-apps bundle is inlined (no CDN imports) 4) Fully quit and relaunch the host to clear resource cache" ;
    oc:hasRationale "Widget failures are almost always CSP-related and errors only surface in the iframe's dedicated console." ;
    oc:severityLevel "HIGH" .

