@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_claude_plugin_official_math_olympiad_solver_heuristics a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "solver-heuristics" ;
    skos:broader "Heuristic playbook" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/math-olympiad" ;
    oc:contentHash "a934fc5252d1a0776e6390c5a943af7f7b32324cf5454e3dce94b3681daa842e" ;
    oc:differentia "curates Pólya-inspired problem-solving strategies and olympiad-specific tactics (invariants, extremals, coordinate bashing, inversion) for solver subagents when the direct approach stalls" ;
    oc:extends oc:skill_claude_plugin_official_math_olympiad ;
    oc:handlesFailure oc:ComputationalOverflow,
        oc:StrategyExhausted ;
    oc:hasCategory "research" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent """For solver subagents. These are the moves to try when the direct approach
stalls.""" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """These answers often come from a structure that is NOT the obvious/symmetric one.
The diagonal, the identity, the "natural" choice frequently gives the WORST
case, not the best — it clusters the constraint in a way that prevents large
substructures.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**For pure-reasoning solvers**: Before claiming the symmetric choice is optimal,
ask "what if I deliberately break the symmetry?" For grid/covering problems:
what if the gaps are SPREAD OUT instead of clustered? For sequences: what if the
extremal sequence is NOT constant or linear?""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**For deep-mode agents**: Brute-force n=3..8 before theorizing. If the formula
that fits is n+c√n instead of cn, the structure has √n-sized blocks.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "When the answer involves √n or log n" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText """**Is your bound tight?** If you proved ≤ N and the answer is exactly N, find
the extremal case. If you can't, your bound might be loose.""" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText """**Can you check it?** Plug in small cases. Does n=3 give what your formula
says?""" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText """**What did you actually use?** Sometimes you used less than all the hypotheses
— the real theorem is stronger.""" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText """**Can you prove it differently?** A second proof is a verification. And often
shorter.""" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "The Look Back phase (after you have a proof)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """The standard angles (invariant, extremal, induction) don't fit
circles/circumcenters/orthocenters. Geometry needs:""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent """**Angle chasing / cyclic quads.** Four points are concyclic iff opposite angles
sum to π. Chase angles until enough equalities force concyclicity.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**Auxiliary point.** Introduce a point not in the problem — the reflection, the
foot of a perpendicular, the second intersection. Olympiad geometry lives on
finding the right extra point.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**Coordinate bash.** Place one point at origin, another on the x-axis. Compute
everything explicitly. The algebra is heavy but mechanical. For two circles with
centers M, N and radii r, R: set M=(0,0), N=(d,0), then the intersection points
have x-coordinate (r²+d²−R²)/2d and everything follows.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent """**Inversion.** Circles through the center become lines. Sometimes the inverted
problem is trivial.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent """**Power of a point.** For point P and circle Γ: PA·PB is constant for any line
through P meeting Γ at A,B. This converts circles to products.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Geometry-specific moves (these are DIFFERENT)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Have you seen a related problem?** Not the same problem — one with the same
UNKNOWN, or the same STRUCTURE. A problem about covering points with lines has
the same shape as one about covering lattice points with arithmetic
progressions.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**Specialize.** If you can't solve the given problem, solve n=3, n=4, n=5 by
hand. The pattern is often the proof. (But: test past the first nontrivial case
— n≤3 may be degenerate.)""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**Generalize (inventor's paradox).** The more ambitious problem sometimes has
MORE structure and is easier. "Prove for all primes" might be harder than "prove
for all integers" if the integer case has a clean induction.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent """**Work backwards.** Start from what you want to prove. What would imply it? What
would imply THAT? If this chain meets something you can prove directly, you have
the proof (reversed).""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent """**Drop a condition.** What happens if you relax one hypothesis? Does the result
become trivially false? Where? That WHERE is often the key step — the point
where the condition is load-bearing.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent """**Auxiliary element.** Introduce something not in the problem — a new variable,
a reflection, a well-chosen function. Olympiad geometry lives on this (auxiliary
points, circles).""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Pólya's core moves (from \"How to Solve It\")" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """For recurrences like b\\_{n+1} = P(b_n) where P is polynomial degree ≥ 2: **b_n
grows doubly-exponentially**. You cannot compute b_30 exactly — it has trillions
of digits. Work in ℤ/2^m (or ℤ/p^m) from the start. Prove b_n ≡ r_n (mod 2^m) by
induction on n, NOT by computing b_n.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Recurrence-specific trap" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent """**Smoothing / adjusting.** For inequalities: if you perturb two variables closer
together (or further apart), does the expression increase or decrease?
Extremize.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent """**Coloring / parity.** Can you 2-color the objects so the claim becomes a parity
statement?""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Find the invariant.** If there's a process (game, transformation, iteration),
what quantity is preserved? Parity, sum, product modulo something.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**Double count.** Count the same thing two ways. Incidences, edges, sums over
pairs.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent """**Symmetry → WLOG.** If the problem is symmetric in x,y,z, you can assume x≤y≤z.
But only if the conclusion is ALSO symmetric.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**Find the extremal.** Take the LARGEST, or SMALLEST, or LEFTMOST object.
Extremal choices often have extra properties that generic choices don't.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Olympiad-specific moves" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**Auxiliary point.** Introduce a point not in the problem — a reflection, a
second intersection, the point where two lines "should" meet. Often the key
construction is finding the right extra point.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent """**Power of a point.** For any point P and circle ω, PA·PB is the same for every
line through P meeting ω at A, B. Use it to turn ratios into equalities.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent """**Inversion.** When there are many circles or tangencies, invert about a
well-chosen center. Circles through the center become lines; tangencies become
simpler tangencies.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent """**Angle chase.** Cyclic quadrilaterals give equal angles. Tangent-chord gives an
angle equal to the inscribed angle. Chase around the figure.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """Standard angles (induction, invariants, extremal) are often wrong-shaped for
olympiad geometry. Use these instead:""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**Coordinate bash.** Place the configuration in coordinates. Choose them to kill
degrees of freedom (origin at a center, axis along a line). Grind out the
algebra. Ugly but reliable.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent """**Spiral similarity / rotation.** Two directly similar triangles are related by
a spiral similarity (rotation + scaling about a fixed point). Find that point —
it often lies on a circle you already have.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Geometry-specific moves" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Solver Heuristics (Pólya + Olympiad Practice)" ] ;
    oc:impartsKnowledge oc:kn_1f737671,
        oc:kn_2f8092fd,
        oc:kn_5f45d19b,
        oc:kn_6649f56f,
        oc:kn_67dc7248,
        oc:kn_69c0c021,
        oc:kn_75ec9764,
        oc:kn_8974692c,
        oc:kn_a9ef175b,
        oc:kn_bc6a4344,
        oc:kn_d0a317ec,
        oc:kn_ec046520 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProblemStalled ;
    oc:resolvesIntent "apply geometry-specific techniques",
        "avoid computational traps in recurrence problems",
        "select a problem-solving strategy for olympiad mathematics",
        "unstall a blocked proof",
        "verify a completed proof" ;
    oc:yieldsState oc:ProofVerified,
        oc:StrategySelected .

oc:kn_1f737671 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the answer involves √n or log n — these come from asymmetric structures" ;
    oc:directiveContent "Before claiming the symmetric/natural choice is optimal, ask 'what if I deliberately break the symmetry?' The diagonal or identity often gives the WORST case, not the best." ;
    oc:hasRationale "√n and log n answers signal that the extremal structure is spread out, not clustered. Symmetric assumptions produce wrong bounds." ;
    oc:severityLevel "HIGH" .

oc:kn_2f8092fd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the problem involves counting objects or relationships" ;
    oc:directiveContent "Double count: count the same thing two ways (incidences, edges, sums over pairs). The resulting equation is often the entire proof." ;
    oc:hasRationale "Two perspectives on the same count yield an identity that directly implies the result." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5f45d19b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no forward approach is visible" ;
    oc:directiveContent "Work backwards from what you want to prove: what would imply it? What would imply THAT? If this chain meets something provable directly, reverse it for the proof." ;
    oc:hasRationale "Backward chaining discovers the logical bridge between knowns and the target." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6649f56f a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "After completing a proof" ;
    oc:directiveContent "Look Back after proving: (1) Plug in small cases to verify. (2) Seek a different proof as verification. (3) Check if bound is tight — find the extremal case. (4) Identify which hypotheses were actually used — the real theorem may be stronger." ;
    oc:hasRationale "Verification catches errors; alternative proofs strengthen confidence; minimizing hypotheses reveals the true theorem." ;
    oc:severityLevel "MEDIUM" ;
    oc:stepOrder 1 .

oc:kn_67dc7248 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the problem involves a dynamic process or repeated operation" ;
    oc:directiveContent "Find the invariant: for processes (games, transformations, iterations), identify what quantity is preserved — parity, sum, product modulo something." ;
    oc:hasRationale "Invariants constrain possible outcomes and often directly prove impossibility or classify reachable states." ;
    oc:severityLevel "HIGH" .

oc:kn_69c0c021 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specialization doesn't help" ;
    oc:directiveContent "Generalize (inventor's paradox): the more ambitious problem sometimes has MORE structure and is easier. E.g., 'prove for all integers' may be cleaner than 'prove for all primes'." ;
    oc:hasRationale "A broader claim can unlock cleaner induction or algebraic structure." ;
    oc:severityLevel "MEDIUM" .

oc:kn_75ec9764 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When solving recurrence or modular-arithmetic problems with polynomial recurrences of degree ≥ 2" ;
    oc:directiveContent "For recurrences b_{n+1} = P(b_n) with deg(P) ≥ 2: b_n grows doubly-exponentially. Never compute b_30 directly — work in ℤ/2^m from the start and prove congruences by induction." ;
    oc:hasRationale "Direct computation is infeasible (trillions of digits); modular reasoning avoids the explosion entirely." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8974692c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When struggling with a problem's hypotheses" ;
    oc:directiveContent "Drop a condition and observe where the result becomes trivially false — that WHERE is often the key step where the condition is load-bearing." ;
    oc:hasRationale "Identifying the load-bearing condition isolates the essential difficulty." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a9ef175b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When solving olympiad geometry problems" ;
    oc:directiveContent "For olympiad geometry, do NOT default to invariant/extremal/induction — use coordinate bash, auxiliary points, power of a point, inversion, spiral similarity, or angle chasing instead." ;
    oc:hasRationale "Standard combinatorial angles are wrong-shaped for circles/circumcenters/orthocenters; geometry has its own toolkit." ;
    oc:severityLevel "HIGH" .

oc:kn_bc6a4344 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When proving existence or bounding a quantity" ;
    oc:directiveContent "Find the extremal: take the LARGEST, SMALLEST, or LEFTMOST object. Extremal choices often have extra properties that generic choices don't." ;
    oc:hasRationale "Extremal objects carry structural constraints that generic objects do not, enabling stronger conclusions." ;
    oc:severityLevel "HIGH" .

oc:kn_d0a317ec a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the general problem is intractable" ;
    oc:directiveContent "Specialize first: solve n=3, n=4, n=5 by hand. The pattern is often the proof. But test past the first nontrivial case — n≤3 may be degenerate." ;
    oc:hasRationale "Small cases reveal structure that generalizes; degenerate small cases can mislead." ;
    oc:severityLevel "HIGH" .

oc:kn_ec046520 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no synthetic insight is available for a geometry problem" ;
    oc:directiveContent "Coordinate bash: place the configuration in coordinates chosen to kill degrees of freedom (origin at a center, axis along a line). Grind out the algebra — ugly but reliable." ;
    oc:hasRationale "Computation is mechanical and always works; coordinate choices minimize algebraic complexity." ;
    oc:severityLevel "MEDIUM" .

