oc:skill_anthropics_claude_plugin_official_math_olympiad_solver_heuristics a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "solver-heuristics" ;
    skos:broader "Problem-solving heuristic framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/math-olympiad" ;
    oc:contentHash "a934fc5252d1a0776e6390c5a943af7f7b32324cf5454e3dce94b3681daa842e" ;
    oc:differentia "that codifies Pólya's general moves and olympiad-specific tactics for mathematical proof agents when direct approaches stall" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_math_olympiad ;
    oc:handlesFailure oc:DirectApproachStalled ;
    oc:hasCategory "research" ;
    oc:impartsKnowledge oc:kn_09827501,
        oc:kn_1f1a4fb3,
        oc:kn_3e2c7134,
        oc:kn_5a1be3a1,
        oc:kn_f98eb95e ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProblemStated ;
    oc:resolvesIntent "apply heuristics when stuck on olympiad problems",
        "choose the right proof strategy for a given problem structure",
        "recognize problem structures that require specialized tactics like invariants, extremal arguments, or coordinate bashing" ;
    oc:yieldsState oc:HeuristicsApplied .

oc:kn_09827501 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When stuck on a general problem statement" ;
    oc:directiveContent "When the direct approach stalls, try specializing: solve n=3, n=4, n=5 by hand. The pattern is often the proof. But test past the first nontrivial case — n≤3 may be degenerate." ;
    oc:hasRationale "Small cases reveal structure that is hidden in the general formulation, and the pattern discovered often generalizes directly into a proof." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1f1a4fb3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After completing any proof" ;
    oc:directiveContent "The Look Back phase is mandatory after obtaining a proof: check small cases, seek an alternate proof, verify bound tightness, and identify whether all hypotheses were actually used." ;
    oc:hasRationale "A second proof is a verification. Sometimes fewer hypotheses were used than assumed, meaning the real theorem is stronger. Untight bounds indicate the argument may be incomplete." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3e2c7134 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the conjectured answer involves √n or log n, especially in grid/covering/sequence problems" ;
    oc:directiveContent "Never assume the symmetric or 'natural' choice is optimal without checking. For answers involving √n or log n, the extremal structure is often NOT the symmetric one — it deliberately breaks symmetry." ;
    oc:hasRationale "The diagonal or identity choice frequently gives the WORST case because it clusters constraints. Gaps that are SPREAD OUT often achieve the extremal value." ;
    oc:severityLevel "HIGH" .

oc:kn_5a1be3a1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When solving recurrence relations with polynomial degree ≥ 2" ;
    oc:directiveContent "For recurrences like b_{n+1} = P(b_n) with polynomial degree ≥ 2: b_n grows doubly-exponentially. Do NOT compute b_n exactly — work in ℤ/2^m (or ℤ/p^m) from the start and prove congruences by induction on n." ;
    oc:hasRationale "b_30 has trillions of digits and cannot be computed exactly. Modular arithmetic from the start avoids catastrophic blowup." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f98eb95e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the problem involves circles, circumcenters, orthocenters, or concyclic points" ;
    oc:directiveContent "Standard heuristic angles (induction, invariants, extremal) are often wrong-shaped for olympiad geometry. Use geometry-specific moves instead: coordinate bash, auxiliary points, power of a point, spiral similarity, inversion, angle chasing." ;
    oc:hasRationale "Geometry problems have structure (incidence, concyclicity, tangency) that doesn't map cleanly to the generic heuristic toolkit. Domain-specific constructions like auxiliary points and inversion unlock proofs that generic methods miss." ;
    oc:severityLevel "HIGH" .

