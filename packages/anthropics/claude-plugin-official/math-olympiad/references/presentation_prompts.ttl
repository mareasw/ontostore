        oc:kn_e9200faa,
        oc:kn_f231f65f,
        oc:kn_fa5476ff ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:resolvesIntent "format olympiad solution for publication",
        "generate clean LaTeX from verified proof",
        "improve proof presentation",
        "rewrite verified proof for clarity" .

oc:kn_0c5f2c0a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running the presentation pass after proof verification" ;
    oc:directiveContent "The presentation pass must be done by a fresh agent with no discovery context — the discoverer is too attached to scaffolding and dead ends." ;
    oc:hasRationale "Separation of discovery and presentation eliminates discovery-order bias and overkill constructions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_567aa773 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing proof scope" ;
    oc:directiveContent "Unnecessary generality — proving for all n when the problem asks about n=3 and the general case adds no insight — must be stripped back to what the problem requires." ;
    oc:hasRationale "Generality that adds indices without insight is overkill in disguise" ;
    oc:severityLevel "MEDIUM" .

oc:kn_70888810 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding lemma granularity" ;
    oc:directiveContent "Inline a lemma if used once and ≤3 lines. Keep standalone if used twice or if its statement alone clarifies structure. Name descriptively — 'Combinatorial dimension bound', not 'Lemma 2'." ;
    oc:hasRationale "Proper lemma granularity balances readability with structural clarity" .

oc:kn_85537025 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When copy-editing any proof step" ;
    oc:directiveContent "Proof by intimidation ('trivial to see', 'obviously', 'a standard argument shows') must be replaced with the actual one-sentence argument. If it's truly trivial, write the sentence." ;
    oc:hasRationale "Unfilled gaps break the reader's ability to reconstruct suppressed details" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a9b1b60e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When ordering proof steps" ;
    oc:directiveContent "Isolate the one genuinely clever step — there's almost always exactly one — and let everything else be obviously routine by contrast. Lead with the main statement, then the key idea, then details." ;
    oc:hasRationale "Highlighting the single non-obvious step gives the reader a mental anchor and makes the routine steps feel routine" .

oc:kn_b0123071 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing any bound or construction in the proof" ;
    oc:directiveContent "Overkill constructions — where the bound proved is parametrically stronger than what the next step consumes — must be weakened until tight. Match tool strength to what's being proved." ;
    oc:hasRationale "Overkill forces the reader to wonder what the excess strength is hiding and obscures the true reason the result holds" ;
    oc:severityLevel "HIGH" .

oc:kn_ceaa19ad a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When formatting the final LaTeX output" ;
    oc:directiveContent "Number steps AND name them: 'Step 3: Fourier inversion and translation invariance.' The name is a promise about what the block accomplishes. Signpost reductions: 'We are reduced to showing that…'" ;
    oc:hasRationale "Named steps let a professor skim step names and nod; they serve as a table of contents for the proof" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e9200faa a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting the presentation pass" ;
    oc:directiveContent "Check for hindsight shortcuts: now that the answer is known, is there a 3-line argument? Long case-bashes often collapse once you spot the invariant." ;
    oc:hasRationale "Discovery builds machinery to find the key step; once you have the key step, the machinery can often be discarded" .

oc:kn_f231f65f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing proof output for presentation quality" ;
    oc:directiveContent "Discovery-order exposition ('First I tried X, which led me to notice Y…') must be rewritten to state the key insight directly. The reader doesn't care about the journey." ;
    oc:hasRationale "Discovery narrative obscures the actual logical structure and wastes reader attention" ;
    oc:severityLevel "HIGH" .

oc:kn_fa5476ff a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When typesetting equations and bounds" ;
    oc:directiveContent "Display math for the equation a step produces; inline math for the algebra getting there. Integer bounds earn the ceiling: write d ≥ ⌈n/k⌉. Cite named results precisely." ;
    oc:hasRationale "Visual hierarchy guides the reader's eye to the important outputs; precise citations and sharp bounds reflect mathematical maturity" ;
    oc:severityLevel "MEDIUM" .

