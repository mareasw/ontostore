oc:skill_anthropics_claude_plugin_official_math_olympiad_presentation_prompts a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "presentation-prompts" ;
    skos:broader "Post-verification presentation pass" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/math-olympiad" ;
    oc:contentHash "19eb3e242eb5879a5fe2768eea9d0e5a35b3df38a5c02cccd101e0b1f07e7d09" ;
    oc:differentia "that restructures verified mathematical proofs via a fresh agent to produce clean, publication-quality LaTeX output by eliminating discovery-order scaffolding, overkill constructions, and exposition anti-patterns" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_math_olympiad ;
    oc:handlesFailure oc:InvalidProofStructure,
        oc:PresentationDegraded ;
    oc:hasArgumentHint "verified proof (passed to fresh subagent)" ;
    oc:hasCategory "research" ;
    oc:hasRequirement oc:req_4da17534,
        oc:req_716fc496 ;
    oc:impartsKnowledge oc:kn_4f8eba68,
        oc:kn_5a42462b,
        oc:kn_7454d31e,
        oc:kn_c4efd65c,
        oc:kn_cc334bac ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:ProofVerified ;
    oc:resolvesIntent "eliminate discovery scaffolding from proof",
        "generate publication-quality LaTeX from verified proof",
        "present proof cleanly",
        "restructure mathematical proof for readability" ;
    oc:yieldsState oc:CleanLaTeXOutput .

oc:kn_4f8eba68 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When ordering proof steps for any presentation" ;
    oc:directiveContent "Structure proof presentation as: lead with the main statement, then the one key idea, then details. Isolate the genuinely clever step and let everything else be routine by contrast. Number steps AND name them descriptively. Signpost reductions explicitly ('We are reduced to showing that…')." ;
    oc:hasRationale "A professor should be able to skim step names alone and nod; a strong grad student should be able to reconstruct every suppressed detail." ;
    oc:severityLevel "HIGH" .

oc:kn_5a42462b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing bounds and constructions in a proof" ;
    oc:directiveContent "Match the strength of each tool to the strength of what it's proving — if a linear function works, don't use a double exponential. Weaken overkill bounds until they are tight." ;
    oc:hasRationale "Overkill bounds make readers wonder what the stronger tool is hiding and obscure the true nature of the argument." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7454d31e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reformatting any verified proof for presentation" ;
    oc:directiveContent "Check for hindsight shortcuts: now that the answer is known, can a 3-line argument replace the machinery? Case-bashes often collapse once the invariant is spotted." ;
    oc:hasRationale "Discovery builds exploratory machinery; presentation only needs the key step, which is already known." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c4efd65c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "After any proof is verified correct, before generating final LaTeX output" ;
    oc:directiveContent "The discoverer of a proof is too attached to their scaffolding; a fresh agent without discovery-context must perform the presentation pass to find the cleanest exposition." ;
    oc:hasRationale "Discovery order is almost never the optimal reading order. The discoverer built machinery to find key steps that can be discarded once the answer is known." ;
    oc:severityLevel "HIGH" .

oc:kn_cc334bac a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or reviewing any mathematical proof presentation" ;
    oc:directiveContent "Never use discovery-order exposition ('First I tried X, which led me to notice Y…'), proof by intimidation ('It is trivial to see that…'), unnecessary generality (proving for all n when n=3 suffices), or orphan lemmas (stated, proved, cited once, three lines long)." ;
    oc:hasRationale "These anti-patterns obscure the actual argument, add cognitive load, and violate the principle that every line must illuminate." ;
    oc:severityLevel "HIGH" .

oc:req_4da17534 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Mathematical proof writing conventions" .

oc:req_716fc496 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "LaTeX" .

