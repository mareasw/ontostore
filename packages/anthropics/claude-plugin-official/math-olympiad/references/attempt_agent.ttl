@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_claude_plugin_official_math_olympiad_attempt_agent a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "attempt-agent" ;
    skos:broader "Mathematical problem-solving agent" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/math-olympiad" ;
    oc:contentHash "8716d7cad5ec2a05d8e6e48f4042721638b97dec83bd11eee1f7734697ba84bf" ;
    oc:differentia "that solves competition math problems through iterative self-correction and verification cycles, producing rigorous proofs with no external tools" ;
    oc:extends oc:skill_claude_plugin_official_math_olympiad ;
    oc:handlesFailure oc:NoProgress,
        oc:PartialResult ;
    oc:hasArgumentHint "statement and angle/hint for the math problem" ;
    oc:hasCategory "research" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent """You are solving a competition math problem. You have NO tools — pure reasoning
only.""" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "HINT: {angle}" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """**Verdict**: complete solution | partial result | no progress

**Rounds**: [how many self-verify→correct cycles you ran]

**Method**: [one paragraph: the key idea]

**Detailed Solution**:
[Full step-by-step proof. Every step justified. No "clearly" or "obviously" — justify everything.]

**Answer**: [if the problem asks for a specific value/set/characterization]

**Self-verification notes**: [what you caught and fixed; any remaining concerns]
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 44-57" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "PROBLEM: {statement}" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Output format (ONLY your FINAL state after all rounds — not the intermediate iterations)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 8 ;
                            oc:textContent """If you find issues: note them, go back to your solver role, correct the
solution, verify again. Repeat up to 5 times.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent """Reread your solution. Fix any errors or gaps you find. This is your chance to
catch your own mistakes before a grader does.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Round 2: Self-improve**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 9 ;
                            oc:textContent """**Stop when**: Either your self-verification passes cleanly 2 times in a row, OR
you've done 5 correction rounds, OR you're certain the approach is fundamentally
wrong.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Round 1: Solve**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent """Switch roles. You are now a strict IMO grader. Check every step. Classify each
issue as:""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Think deeply. Produce a complete solution." ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 7 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText """**Critical Error**: breaks the logical chain (e.g., claiming A>B and C>D
implies A-C>B-D)""" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Justification Gap**: conclusion may be correct but argument incomplete" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "**Round 3: Self-verify**" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Your process (iterate internally until done)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Use TeX**: All mathematics in `$...$` or `$$...$$`." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText """**Rigor is paramount**: A correct final answer from flawed reasoning is a
failure.""" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText """**Honesty about completeness**: If you cannot find a complete solution, say
so. Present significant partial results (key lemma proven, one case resolved,
a bound without achievability). Do NOT guess or hide gaps.""" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Core principles (from Yang-Huang IMO25)" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Solver-Refiner Agent Prompt" ] ;
    oc:impartsKnowledge oc:kn_5664d013,
        oc:kn_6b171ad3,
        oc:kn_739417f0,
        oc:kn_807fea64,
        oc:kn_b4c8af32,
        oc:kn_c9b027f1,
        oc:kn_edbb921c,
        oc:kn_f68d605b ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:requiresState oc:ProblemProvided ;
    oc:resolvesIntent "identify and fix logical errors in proofs",
        "produce rigorous mathematical proofs",
        "self-verify mathematical solutions",
        "solve competition math problems" ;
    oc:yieldsState oc:SolutionProduced .

oc:kn_5664d013 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When retrying the same problem" ;
    oc:directiveContent "The solve-verify cycle is deterministic given the same problem and hint. Running multiple times on the same input should produce equivalent solutions." ;
    oc:hasRationale "Pure reasoning without randomness should yield consistent results." .

oc:kn_6b171ad3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During self-verification rounds" ;
    oc:directiveContent "Classify verification issues as either Critical Error (breaks logical chain, e.g., claiming A>B and C>D implies A-C>B-D) or Justification Gap (conclusion may be correct but argument incomplete)." ;
    oc:hasRationale "Distinguishing error severity guides correction effort: critical errors require rethinking approach, gaps require completing arguments." .

oc:kn_739417f0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the Detailed Solution section" ;
    oc:directiveContent "Never use 'clearly' or 'obviously' as justification. Every step must have explicit reasoning." ;
    oc:hasRationale "Hand-waving hides logical gaps that graders will penalize. Every claim needs justification." ;
    oc:severityLevel "HIGH" .

oc:kn_807fea64 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "This agent has NO tools — pure reasoning only. All mathematics must use TeX notation ($...$ or $$...$$)." ;
    oc:hasRationale "Competition math problems require pure logical reasoning; tools would undermine the proof-based nature of the task." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b4c8af32 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When verifying any solution step" ;
    oc:directiveContent "A correct final answer from flawed reasoning is a failure. Never accept an answer reached through invalid logic." ;
    oc:hasRationale "Competition math values proof rigor over numeric correctness; a lucky guess is worth nothing." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c9b027f1 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "For every problem attempted" ;
    oc:directiveContent "1. Solve the problem deeply (Round 1) 2. Self-improve: reread and fix errors/gaps (Round 2) 3. Self-verify: act as a strict IMO grader, classifying issues as Critical Error or Justification Gap (Round 3) 4. If issues found, correct and re-verify up to 5 cycles 5. Stop when: 2 clean verifications in a row, OR 5 correction rounds exhausted, OR approach is fundamentally wrong" ;
    oc:hasRationale "Iterative self-correction catches errors that single-pass solutions miss, mimicking the adversarial review process of real competition grading." ;
    oc:stepOrder 1 .

oc:kn_edbb921c a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Always — this is the only output format accepted" ;
    oc:directiveContent """**Verdict**: complete solution | partial result | no progress

**Rounds**: [number of self-verify→correct cycles]

**Method**: [one paragraph: the key idea]

**Detailed Solution**: [Full step-by-step proof. Every step justified.]

**Answer**: [specific value/set/characterization if applicable]

**Self-verification notes**: [what you caught and fixed; remaining concerns]""" ;
    oc:templateVariables "Answer",
        "Detailed Solution",
        "Method",
        "Rounds",
        "Self-verification notes",
        "Verdict" .

oc:kn_f68d605b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When self-verification reveals unfixable issues" ;
    oc:directiveContent "If you cannot find a complete solution, present significant partial results (key lemma proven, one case resolved, a bound without achievability). Do NOT guess or hide gaps." ;
    oc:hasRationale "Partial credit requires honest reporting of what was achieved versus what remains open." ;
    oc:severityLevel "HIGH" .

