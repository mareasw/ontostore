oc:skill_anthropics_claude_plugin_official_math_olympiad_attempt_agent a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "attempt-agent" ;
    skos:broader "Solver-refiner agent" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/math-olympiad" ;
    oc:contentHash "8716d7cad5ec2a05d8e6e48f4042721638b97dec83bd11eee1f7734697ba84bf" ;
    oc:differentia "that solves competition math problems through iterative self-verification with pure reasoning and no external tools" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_math_olympiad ;
    oc:handlesFailure oc:InvalidInput,
        oc:SolutionFailed ;
    oc:hasArgumentHint "statement and angle (math problem with optional hint)" ;
    oc:hasCategory "research" ;
    oc:impartsKnowledge oc:kn_098b5456,
        oc:kn_50025051,
        oc:kn_51a199a1,
        oc:kn_718a7cf8,
        oc:kn_adffd252 ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady,
        oc:ProblemProvided ;
    oc:resolvesIntent "self-correct solution errors through adversarial verification",
        "solve competition math problems",
        "verify mathematical proofs rigorously" ;
    oc:yieldsState oc:ProofVerified,
        oc:SolutionProduced .

oc:kn_098b5456 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any mathematical proof or solution" ;
    oc:directiveContent "Rigor is paramount: a correct final answer from flawed reasoning is a failure. Every step must be justified — no 'clearly' or 'obviously'." ;
    oc:hasRationale "Competition math grading penalizes unjustified leaps; logical completeness is the core quality metric" ;
    oc:severityLevel "CRITICAL" .

oc:kn_50025051 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During the self-verification round" ;
    oc:directiveContent "Classify issues found during verification as either 'Critical Error' (breaks the logical chain) or 'Justification Gap' (conclusion may be correct but argument incomplete)." ;
    oc:hasRationale "Distinguishing severity of issues guides correction priority — critical errors require reworking logic, gaps require补充argumentation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_51a199a1 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Always — this is the mandatory process for every problem attempt" ;
    oc:directiveContent "Use three-phase iteration: (1) Solve deeply, (2) Self-improve by rereading and fixing errors, (3) Self-verify as a strict grader classifying issues as Critical Errors or Justification Gaps." ;
    oc:hasRationale "The solver-refiner pattern catches errors that self-verification alone would miss by forcing role-switching between creator and critic" ;
    oc:severityLevel "CRITICAL" .

oc:kn_718a7cf8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When unable to fully solve a problem" ;
    oc:directiveContent "Never guess or hide gaps. If a complete solution cannot be found, present significant partial results explicitly (key lemma, one case resolved, a bound without achievability)." ;
    oc:hasRationale "Honesty about completeness is a core principle from Yang-Huang IMO25; partial credit requires transparent partial results" ;
    oc:severityLevel "HIGH" .

oc:kn_adffd252 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During the self-verify correction loop" ;
    oc:directiveContent "Stop iterating after either 2 consecutive clean self-verifications, 5 correction rounds, or confirmed fundamental approach failure." ;
    oc:hasRationale "Prevents infinite loops while allowing sufficient iteration for convergence on a correct solution" ;
    oc:severityLevel "HIGH" .

