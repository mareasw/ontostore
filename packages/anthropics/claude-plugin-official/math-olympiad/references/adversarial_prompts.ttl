oc:skill_anthropics_claude_plugin_official_math_olympiad_adversarial_prompts a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "adversarial-prompts" ;
    skos:broader "Prompt bank" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/math-olympiad" ;
    oc:contentHash "686f5913da4e3291d64989f1bacb8f99fe69cdb3b5b9e64c8390151e870bae2a" ;
    oc:differentia "that supplies adversarial verification prompts for mathematical proof checking via isolated verifier subagents with no tool access" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_math_olympiad ;
    oc:handlesFailure oc:ProofGapDetected,
        oc:ProofRefuted,
        oc:TautologyDetected ;
    oc:hasAlias "adversarial-verifier",
        "proof-verifier-prompts",
        "verifier-prompt-bank" ;
    oc:hasArgumentHint "problem statement and proposed solution" ;
    oc:hasCategory "research" ;
    oc:hasRequirement oc:req_3d1b0739,
        oc:req_9743672d ;
    oc:impartsKnowledge oc:kn_263df77b,
        oc:kn_2adf2ce8,
        oc:kn_3e6b4376,
        oc:kn_3ee5e3b5,
        oc:kn_76c63c11,
        oc:kn_e3977485,
        oc:kn_e68c3bb0 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:SolutionGenerated ;
    oc:resolvesIntent "check if arguments prove too much",
        "detect subtle errors in olympiad solutions",
        "force binary resolution of flagged proof issues",
        "identify tautological reductions in proofs",
        "refute incorrect proofs through structured attack patterns",
        "verify mathematical proofs adversarially" ;
    oc:yieldsState oc:ProofVerified .

oc:kn_263df77b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a solution is well-written, confident, and uses standard machinery correctly in most places" ;
    oc:directiveContent "Press hardest on the step you can't quite follow in an otherwise clean proof. The place that resists quick verification is the most likely location of a subtle error." ;
    oc:hasRationale "A strong student who made one subtle error will have convinced themselves before convincing the reader. The weak point is camouflaged by surrounding correctness." ;
    oc:severityLevel "HIGH" .

oc:kn_2adf2ce8 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When a verifier flags a suspiciously brief load-bearing step in a proof" ;
    oc:directiveContent "For one-line lemmas suspected of being false: extract the general claim, test it at the smallest nontrivial instance (2×2 case), and if the general form fails, force a binary resolution — either find special structure that saves it, or confirm the conclusion is false." ;
    oc:hasRationale "This pattern catches cases where the author got the right answer for the wrong reason — the specific instance works but the invoked principle is false in general, meaning the proof lacks the real reason." ;
    oc:severityLevel "HIGH" .

oc:kn_3e6b4376 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When starting verification of any olympiad-level solution" ;
    oc:directiveContent "Before verifying, read the problem statement alone and enumerate 2-3 plausible readings ranked by difficulty. Check whether the solution addresses the easiest reading rather than the intended hardest one." ;
    oc:hasRationale "Olympiad problems are calibrated to their point values. A solution that turns a hard problem into a trivial exercise likely solved the wrong interpretation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3ee5e3b5 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When evaluating whether a proof's argument structure is sound independent of its specific objects" ;
    oc:directiveContent "When using the 'proves too much' attack, strip the argument to its skeleton, substitute the most famous object sharing exactly those properties, and check if the conclusion becomes a known open problem or falsehood." ;
    oc:hasRationale "If an argument proves something famously false when applied to a structurally similar object, the original proof has an unstated dependency on a property the author never identified." ;
    oc:severityLevel "MEDIUM" .

oc:kn_76c63c11 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or executing adversarial verification of any mathematical proof" ;
    oc:directiveContent "Use the seven-category refutation taxonomy to systematically hunt for errors: (1) step doesn't follow, (2) hypothesis not satisfied, (3) claim false in small case, (4) tautological, (5) proves too much, (6) wrong interpretation, (7) hand-wave at the crux." ;
    oc:hasRationale "Structured attack patterns prevent the verifier from falling into sympathetic reading by providing specific failure modes to check." ;
    oc:severityLevel "HIGH" .

oc:kn_e3977485 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running multi-pass consecutive verification or any ensemble of verifiers" ;
    oc:directiveContent "Verifiers must be isolated from each other's votes and must not know if others confirmed or refuted. Social proof ('3 others confirmed') biases toward agreement." ;
    oc:hasRationale "Independent verification prevents diffusion of responsibility where each pass assumes another will catch the error." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e68c3bb0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating any mathematical proof for correctness" ;
    oc:directiveContent "Never confirm a proof because it sounds confident or is well-written. A subtly wrong solution looks exactly like a correct one — well-written and confident." ;
    oc:hasRationale "Self-verification achieves 85.7% IMO success but drops to <5% under human grading (arXiv:2503.21934). Sympathetic reading glosses over the exact error." ;
    oc:severityLevel "CRITICAL" .

oc:req_3d1b0739 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Familiarity with mathematical proof techniques and common olympiad problem patterns" .

oc:req_9743672d a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of the seven-category refutation taxonomy (step doesn't follow, hypothesis not satisfied, claim false in small case, tautological, proves too much, wrong interpretation, hand-wave at crux)" .

