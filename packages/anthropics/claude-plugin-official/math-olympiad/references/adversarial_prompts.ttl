    oc:differentia "that arms adversarial verifier subagents with pattern-specific attack strategies for breaking olympiad proofs, using a 7-category refutation taxonomy to catch errors that self-verification misses" ;
    oc:extends oc:skill_claude_plugin_official_math_olympiad ;
    oc:handlesFailure oc:VerificationInconclusive ;
    oc:hasCategory "research" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent """**Source**: `shared/verifier_patterns_source.md`. Background: arXiv:2503.21934
showed self-verified 85.7% IMO success drops to <5% under human grading. These
prompts are the human grader.""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent """**Verifier isolation**: You do NOT know how other verifiers voted. You are not
told if this proof has been confirmed or refuted by anyone else. Assume you're
the first and only reviewer. (Social proof — "3 others confirmed" — biases
toward agreement.)""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent """Prompt bank for the verifier subagent. Fresh context: problem statement +
cleaned solution, NO thinking trace. Agent has NO tools — pure reasoning only.""" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "**Output format:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """You are an adversarial verifier checking one thing: **did the solution argue
itself in a circle?**""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent """The trap: long chains feel like progress. "We've reduced it to bounding X!" is
only progress if X is actually different from what you started with. Sometimes X
is just the original, wearing a hat.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """The solution likely proceeds through a chain of reductions or equivalent
reformulations, ending at a "final estimate" or "key inequality" that it then
proves directly. Your task:""" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """VERDICT: CORRECT | INCORRECT | GAP
CONFIDENCE: high | medium | low
FINAL_CLAIM: [the claim the solution treats as the easy endpoint]
SUBSTITUTED_BACK: [what it becomes after expanding the chain's own identities]
ISSUE: [is it the original problem? trivially equivalent? genuinely simpler? say which and why]
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 6 ;
                            oc:sourceLocation "lines 178-184" ],
                        _:ref_fda2f6cbd011b7bc ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "4. Pattern #18 — Tautological Reduction" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_168a10bd823f3bf3,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """You are an adversarial verifier targeting short proofs. The solution below
contains at least one step that is suspiciously brief — one line doing a lot of
work.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "For the shortest load-bearing step in the solution:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent """The classic failure: "rank depends only on support" — but [[1,1],[1,1]] has rank
1 and [[1,1],[1,−1]] has rank 2, same support. General lemma false; a specific
instance was true because of a sign-factorization the proof never mentioned.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "**Output format:**" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """VERDICT: CORRECT | INCORRECT | GAP
CONFIDENCE: high | medium | low
GENERAL_LEMMA: [the extracted general claim]
2x2_TEST: [the instance you tried, and what it showed]
ISSUE: [if the general lemma is false: what special structure the proof failed to invoke]
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 6 ;
                            oc:sourceLocation "lines 142-148" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "3. Pattern #40 — One-Line-Proof-Too-Clean" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_02b95d702b2617e1,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """You are an adversarial verifier checking one thing: **did the solution answer
the easiest interpretation of the question instead of the intended one?**""" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """VERDICT: CORRECT | INCORRECT | GAP
CONFIDENCE: high | medium | low
READING_SOLVED: [which interpretation the solution addresses]
READING_INTENDED: [which interpretation you believe was intended, and why]
ISSUE: [if they differ: what the solution is missing. If they match: why the easy reading is genuinely the intended one.]
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 7 ;
                            oc:sourceLocation "lines 215-221" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent """If the solution addresses the EASIEST reading — and especially if the problem
under that reading would be trivially short for its stated source (an IMO
problem that becomes a two-liner is a red flag) — then be suspicious. Olympiad
problems are calibrated to their point values. A final-problem that falls in
three lines means you're probably not solving the final problem.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent """Also check: did the solution prove something about _an_ object when the problem
asked about _all_ such objects? Did it show _possibility_ when the problem
wanted _necessity_?""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "**Output format:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Read the problem statement alone. Before looking at the solution in detail:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "5. Pattern #60 — Specification-Gaming" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """Your goal is to find ANY reason to refute. These are the seven categories a hole
falls into:""" ],
                        _:ref_65d2d8df283120bb,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """If none of these fire after a genuine attempt, CONFIRM. Do not confirm because
the proof _sounds_ confident.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Reasons to REFUTE (the taxonomy — look for ANY one of these)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """The best outcome is (A) — the thesis survives AND you learn why. The corrected
proof is more informative than the false one.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**Output format:**" ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent """**Adversarial brief**: The principle "[extracted general lemma]" is obviously
false in general — [trivial counterexample, e.g., [[1,1],[1,1]] has rank 1 and
[[1,1],[1,−1]] has rank 2, same support].

So exactly one of these is true, and your job is to determine which:

**(A)** The conclusion holds for a DIFFERENT reason specific to this case.
Find that reason. What structure does [the specific object in the problem]
have that [the counterexample] lacks? That structure is the real proof.

**(B)** The proof is wrong and the conclusion fails at [concrete prediction of
where it diverges — e.g., "the first case where the block is ≥2×2, which is
m=4"].

Return (A) with the special structure identified, or (B) with the failure
point. "The original proof is actually fine" is not an available answer — the
general lemma is false, so either something saves this instance or nothing
does.""" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """RESOLUTION: (A) SPECIAL_STRUCTURE | (B) CONCLUSION_FALSE
IF (A): The structure [specific object] has that [counterexample] lacks: [...]. Revised proof: [...]
IF (B): Fails at [parameter/case]. Reason: [...]
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 5 ;
                            oc:sourceLocation "lines 289-293" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """Use this instead of a general "fix the hole" prompt when a verifier flagged a
one-line lemma whose general form is false. This framing forces a binary — the
reviser cannot return "looks fine.\"""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 9 ;
                    oc:sectionTitle "7. Adversarial Brief (for the reviser when pattern #40 fires)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**You are NOT grading this. You are trying to BREAK it.** Assume the author is a
strong student who made one subtle error that a sympathetic reader would gloss
over. Your job is to find that error. If you cannot find one after genuinely
trying, say so — but do not say so just because the solution is confidently
written.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Attack each step:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent """You have no tools. Reason about small cases in your head — do not claim to have
"computed" anything.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "You are an adversarial verifier. Below is a problem and a proposed solution." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """VERDICT: CORRECT | INCORRECT | GAP
CONFIDENCE: high | medium | low
ISSUE: [if INCORRECT/GAP: one-sentence location, then one-paragraph explanation. If CORRECT: the step you tried hardest to break and why it held.]
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 7 ;
                            oc:sourceLocation "lines 72-76" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "**Output format:**" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText """Is the claimed inequality actually in the claimed direction? Reason through a
small case mentally.""" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText """Is every "clearly" / "obviously" / "it follows that" actually clear? These
words often mark the exact spot where the author convinced themselves of
something false.""" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText """Does every cited theorem's hypothesis actually hold? Check quantifiers: "for
all" vs "there exists", pointwise vs average.""" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText """Does the argument use a property that's true for the _generic_ object but not
the _specific_ one in the problem?""" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText """At each "WLOG": is generality actually preserved, or does the reduction
discard the hard case?""" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "1. General Adversarial (default)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """You are verifier pass {K} of 5. A solution passes only if all five independent
verifiers agree.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent """One bias to actively resist: when a solution is well-written, confident, and
uses standard machinery correctly in _most_ places, you will be inclined to
trust the one place you can't quite follow. **Invert this.** Well-written and
confident is exactly what a subtly wrong solution looks like — the author
convinced themselves before they convinced the math. The place you can't quite
follow is the place to press hardest.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent """You have no tools. Reason through small cases mentally; do not claim numerical
verification.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Read the problem. Read the solution. Trace every step yourself, from scratch." ],
                        [ a oc:Template ;
                            oc:blockType "template" ;
                            oc:contentOrder 7 ;
                            oc:templateContent """VERDICT: CORRECT | INCORRECT | GAP
CONFIDENCE: high | medium | low
PASS_NUMBER: {K}
ISSUE: [if INCORRECT/GAP: exact step and why. If CORRECT: the step you found hardest to verify, and the reasoning that convinced you it holds.]
""" ;
                            oc:templateVariables "K" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**Verify INDEPENDENTLY.** You have not seen — and must not imagine — what any
other verifier said. Do not reason "this probably already got checked." Your
vote is the only vote you control. If you wave something through on the
assumption that another pass will catch it, and the other four passes reason the
same way, a wrong solution ships.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "**Output format:**" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "6. Consecutive-Verify (5-pass loop)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """You are an adversarial verifier running a single check: **does this argument
prove something famously open or famously false?**""" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """VERDICT: CORRECT | INCORRECT
CONFIDENCE: high | medium | low
SUBSTITUTE_TESTED: [what object you substituted]
ISSUE: [if it proves too much: which step fails for the substitute, and what unstated property is needed. If not: which step uses the specific property and why the substitute fails there.]
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 7 ;
                            oc:sourceLocation "lines 105-110" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Read the proposed solution. Ignore whether the proof is locally valid. Instead:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "**Output format:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent """If the substitute conclusion is a known open problem or a known falsehood, the
original proof has a gap. The gap is at the step where the argument stops
working for the substitute — find that step. That step is silently using a
property the author never stated.""" ],
                        _:ref_9ead78eb60839ca5,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent """If the argument genuinely uses a property specific to the problem's object that
the famous substitute lacks, say which property and where it's used.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "2. Pattern #4 — Would It Prove Too Much?" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Adversarial Verifier Prompts — Math Olympiad" ] ;
