        oc:kn_bc5da0e2,
        oc:kn_fe33baeb ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "catch circular reasoning in proof chains",
        "check mathematical arguments without computational tools",
        "identify scope-creep errors in theorem application",
        "validate that proof techniques don't accidentally solve famous open problems",
        "verify a proof for subtle logical gaps" .

oc:kn_01acdc27 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a proof generalizes from small cases (Pattern 17)" ;
    oc:directiveContent "Never accept small-case patterns without testing past the first nontrivial structural threshold — small cases often have degeneracies that force the pattern trivially." ;
    oc:hasRationale "Small cases can have forced structure (e.g., 1×2 blocks always have rank 1) that disappears at larger sizes, making the pattern an artifact of degeneracy rather than a genuine phenomenon." ;
    oc:severityLevel "HIGH" .

oc:kn_08340122 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When approaching olympiad or competition problems (Pattern 60)" ;
    oc:directiveContent "Before solving, write down 2-3 readings of the problem statement. If your interpretation makes it trivial and the problem is worth significant points, you've likely chosen the easy misreading." ;
    oc:hasRationale "Olympiad problems often plant an easy grammatically-valid misreading; technically correct solutions to the wrong reading are the most common failure mode." ;
    oc:severityLevel "HIGH" .

oc:kn_19666e53 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When checking identities and formula applications (Pattern 23)" ;
    oc:directiveContent "For any identity used in a proof, trace it to where it was first introduced and verify the standing assumptions there still hold at the point of use — formulas often have unstated scope restrictions." ;
    oc:hasRationale "Formulas derived under special assumptions (e.g., 2-piece Cantor sets) are frequently silently applied to more general settings where they fail by a constant factor or worse." ;
    oc:severityLevel "MEDIUM" .

oc:kn_284c6e74 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating sum bounds in analytic number theory (Pattern 22)" ;
    oc:directiveContent "Before accepting Σₖ Xₖ = O(1) as hard because |Xₖ| sums to O(K), separate Xₖ into mean + fluctuation — if orthogonality forces the mean to zero, you're fighting √K terms, not K." ;
    oc:hasRationale "Mean-zero decomposition via equidistribution can halve the difficulty of a problem; the absolute-sum bound is a pessimistic outer estimate that ignores cancellation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_54f76990 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When comparing the strength of mathematical statements (Pattern 58)" ;
    oc:directiveContent "Before claiming one statement is strictly stronger than another due to domain size, make the quantifier explicit: ∀ over smaller domain is weaker (fewer obligations); ∃ over smaller domain is stronger (fewer witnesses)." ;
    oc:hasRationale "Backwards strength claims from domain size are a systematic error — the direction of 'harder' depends entirely on whether the quantifier is universal or existential." ;
    oc:severityLevel "MEDIUM" .

oc:kn_62d706c0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working with diagonalization arguments in computational complexity (Pattern 35)" ;
    oc:directiveContent "Before diagonalizing against a class using a property, write the diagonalization as a formula and count quantifier alternations — certifying 'no small circuit computes x' requires ∀∃, putting you in Σ₂ not NP." ;
    oc:hasRationale "Quantifier counting reveals the true complexity of diagonalization; missing an alternation leads to claiming results at the wrong level of the hierarchy." ;
    oc:severityLevel "HIGH" .

oc:kn_87f3afbd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When verifying proofs with universal claims over a class of objects (Pattern 4)" ;
    oc:directiveContent "Always specialize a claimed theorem to the most famous/hardest object in its class (ζ(s), Ramsey numbers, Collatz map) — if the specialization would settle a known open problem, the proof has a gap where it treats arithmetic input as generic." ;
    oc:hasRationale "This catches the most embarrassing category of error: proofs that would resolve famous open problems as a corollary, indicating the argument illegitimately treats a structured object as generic." ;
    oc:severityLevel "HIGH" .

oc:kn_8d436ff7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating reduction chains in proofs (Pattern 18)" ;
    oc:directiveContent "Never accept a reduction chain that 'estimates X' without substituting the chain's own identities back into X — you may recover the original conjecture unchanged, revealing a circular argument." ;
    oc:hasRationale "Circular reductions are the most common undetected error in research sessions; they look like progress because identities are proven along the way, but the final gap is the starting conjecture in disguise." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9f0bfa04 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When multiple proof approaches are blocked by seemingly the same obstruction (Pattern 19)" ;
    oc:directiveContent "When the same obstruction kills 3+ independent approaches, check the disputed property on the original object before any reduction — the obstruction may live only in the proxy." ;
    oc:hasRationale "Derived/proxy objects can have obstructions that the original object does not; checking the base object directly can instantly resolve an apparent impasse." ;
    oc:severityLevel "HIGH" .

oc:kn_bafea434 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a proof feels suspiciously short or clean (Pattern 40)" ;
    oc:directiveContent "Never trust a proof whose key lemma, stated in full generality, admits a trivial 2×2 counterexample — the specific case may hold, but the real reason is hidden structure, not the stated lemma." ;
    oc:hasRationale "One-line proofs that feel too clean often rely on a lemma that is false in general; the specific instance survives due to hidden structure that constitutes the real proof." ;
    oc:severityLevel "CRITICAL" .

oc:kn_bc5da0e2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a proof cites a theorem by name and the fit feels slightly off (Pattern 10)" ;
    oc:directiveContent "Never apply a theorem based on keyword matching alone — always verify that the cited theorem's exact hypotheses (pointwise vs averaged, uniform vs a.e., finite vs asymptotic) match what the proof needs." ;
    oc:hasRationale "Near-synonyms in mathematical language ('bounded' vs 'bounded on the line', 'entire' vs 'analytic on a domain') create the illusion of hypothesis satisfaction where there is a gap." ;
    oc:severityLevel "HIGH" .

oc:kn_fe33baeb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating sums bounded by analytic functions (Pattern 6)" ;
    oc:directiveContent "When a divergent-looking sum is bounded by a function like ζ(s), evaluate the bounding function at the boundary of the claimed range — a pole there means the sum diverges regardless of what the continuation says elsewhere." ;
    oc:hasRationale "The analytic continuation of a sum is not the sum itself; substituting boundary values exposes divergence that the continued function's finite values elsewhere hide." ;
    oc:severityLevel "HIGH" .

oc:req_442da8ee a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Familiarity with olympiad-level mathematics including analytic number theory, combinatorics, and computational complexity" .

_:ref_59bd1308fc4315f1 a oc:WorkflowStep ;
    dcterms:description "Trace any reduction chain: substitute proven identities back into the 'final gap' to check for circularity (Pattern 18)" ;
    oc:expectedOutcome "Circular reductions are detected if the starting conjecture is recovered" ;
    oc:stepId "v4" .

_:ref_f6a866415200a623 a oc:WorkflowStep ;
    dcterms:description "Identify the proof's key lemma and state it in full generality — test with a 2×2 counterexample (Pattern 40)" ;
    oc:expectedOutcome "Either the general lemma holds, or hidden structure is identified that constitutes the real proof" ;
    oc:stepId "v1" .

