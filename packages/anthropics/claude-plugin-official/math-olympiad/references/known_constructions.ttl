@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_claude_plugin_official_math_olympiad_known_constructions a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "known-constructions" ;
    skos:broader "Methodological pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/math-olympiad" ;
    oc:contentHash "5135bca2eb1c448f1144cda2b1cfa796be5cb6a082306e589ad8308636b1e065" ;
    oc:differentia "that provides reusable construction techniques for finding optimal structures in competition math problems" ;
    oc:extends oc:skill_claude_plugin_official_math_olympiad ;
    oc:hasCategory "research" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent """Methodological patterns for finding optimal constructions. No specific problem
answers.""" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """This file is for construction _techniques_, not solutions. If you find yourself
writing "the answer to Problem X is Y," delete it.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Avoid: storing specific answers here" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**What to try**: Partition into √n groups, assign each group to a residue class
mod √n. Within a group, place in reverse order. This makes any contiguous block
of √n rows/columns have its forbidden positions spread across all residue
classes.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**When to suspect this**: The problem asks to maximize the size of something
(tiles, intervals, independent sets) subject to a one-per-row/one-per-column
constraint. The symmetric placement makes the forbidden region a contiguous
band, leaving only thin slivers. Spreading the forbidden positions leaves fat
windows.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """For optimization problems over permutations/configurations: the **symmetric
choice (identity, diagonal, regular spacing) is often the worst case, not the
best**. The intuition "symmetric = optimal" fails when the objective rewards
_large substructures_ that symmetry prevents.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Spread vs cluster" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """If brute-forcing n=2..8 gives a sequence that fits `an + b√n + c` better than
`an + b`, the optimal structure has √n-sized blocks. Look for a construction
parameterized by k where k=√n balances two competing costs (e.g., k things each
of size n/k).""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "When brute-force reveals √n" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**Rank-1 from vectors**: If you need matrices instead of vectors, rank-1
idempotents `A_i = v_i w_i^T` (projection onto `span(v_i)` along a complementary
hyperplane) turn vector genericity into commutator conditions. `[A_i, A_j] = 0`
iff a specific determinant vanishes.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """When you need n objects in ℝ^k where "any k are independent" (or similar
genericity), the moment curve `(1, t, t², ..., t^{k-1})` at n distinct parameter
values gives this for free. Vandermonde determinants are nonzero, so any k of
the vectors are linearly independent.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Moment curve for distinctness" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Construction Patterns" ] ;
    oc:impartsKnowledge oc:kn_1841f156,
        oc:kn_2db79bed,
        oc:kn_4f3d6f5b,
        oc:kn_b3f8f386,
        oc:kn_d088197e,
        oc:kn_de118130 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "apply moment curve technique for distinctness problems",
        "choose between symmetric and asymmetric placements",
        "find optimal constructions for olympiad problems",
        "recognize √n structure from brute-force data" .

oc:kn_1841f156 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when writing or editing this knowledge base" ;
    oc:directiveContent "Never store specific problem solutions in this file. This file is for construction techniques, not answers. If you find yourself writing 'the answer to Problem X is Y,' delete it." ;
    oc:hasRationale "Separating generalizable techniques from specific solutions ensures the knowledge remains reusable across problems." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2db79bed a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When you need n objects where any k are independent or similar genericity condition" ;
    oc:directiveContent "Use the moment curve (1, t, t², ..., t^{k-1}) at n distinct parameter values to produce n objects in ℝ^k where any k are linearly independent. Vandermonde determinants are nonzero, guaranteeing genericity." .

oc:kn_4f3d6f5b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the problem requires matrices with commutativity or independence conditions" ;
    oc:directiveContent "If you need matrices instead of vectors, use rank-1 idempotents A_i = v_i w_i^T (projection onto span(v_i) along a complementary hyperplane). [A_i, A_j] = 0 iff a specific determinant vanishes, turning vector genericity into commutator conditions." .

oc:kn_b3f8f386 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the problem asks to maximize the size of something (tiles, intervals, independent sets) subject to a one-per-row/one-per-column constraint" ;
    oc:directiveContent "For optimization problems over permutations/configurations, the symmetric choice (identity, diagonal, regular spacing) is often the worst case, not the best. Symmetry fails when the objective rewards large substructures that symmetry prevents." ;
    oc:hasRationale "Symmetric placement makes the forbidden region a contiguous band, leaving only thin slivers. Spreading the forbidden positions leaves fat windows." ;
    oc:severityLevel "HIGH" .

oc:kn_d088197e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When brute-force data is available and the growth pattern is ambiguous" ;
    oc:directiveContent "If brute-forcing n=2..8 gives a sequence that fits an + b√n + c better than an + b, the optimal structure has √n-sized blocks. Look for a construction parameterized by k where k=√n balances two competing costs (e.g., k things each of size n/k)." ;
    oc:hasRationale "The √n term in the fitted polynomial signals that the optimal construction involves blocks of size √n, arising from balancing two competing quantities." ;
    oc:severityLevel "MEDIUM" .

oc:kn_de118130 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When spread-vs-cluster analysis shows asymmetric placement is needed" ;
    oc:directiveContent "Partition into √n groups, assign each group to a residue class mod √n. Within a group, place in reverse order. Any contiguous block of √n rows/columns has its forbidden positions spread across all residue classes." .

