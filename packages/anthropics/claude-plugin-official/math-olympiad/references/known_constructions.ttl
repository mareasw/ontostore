oc:skill_anthropics_claude_plugin_official_math_olympiad_known_constructions a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "known-constructions" ;
    skos:broader "Mathematical construction pattern library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/math-olympiad" ;
    oc:contentHash "5135bca2eb1c448f1144cda2b1cfa796be5cb6a082306e589ad8308636b1e065" ;
    oc:differentia "that provides meta-heuristics for finding optimal combinatorial constructions in olympiad problems, emphasizing spread-over-cluster strategies, moment curve genericity, and structural size discovery through brute-force analysis" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_math_olympiad ;
    oc:handlesFailure oc:NoPatternMatch ;
    oc:hasArgumentHint "construction type hint (e.g., spread-vs-cluster, moment-curve, brute-force-pattern)" ;
