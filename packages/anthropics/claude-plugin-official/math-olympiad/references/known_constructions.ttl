    oc:impartsKnowledge oc:kn_0dddd46a,
        oc:kn_233a48ef,
        oc:kn_50c0d5eb,
        oc:kn_6bd987fa,
        oc:kn_d5d08ea0 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:ConstructionNeeded,
        oc:ProblemAnalyzed ;
    oc:resolvesIntent "apply spread vs cluster strategy for permutation and configuration problems",
        "discover structural block sizes from brute-force data",
        "find optimal constructions for combinatorial optimization problems",
        "use moment curve for distinctness and genericity requirements" ;
    oc:yieldsState oc:ConstructionPatternIdentified .

oc:kn_0dddd46a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When exploring small cases computationally and the answer sequence exhibits non-linear growth" ;
    oc:directiveContent "If brute-forcing small cases n=2..8 yields a sequence fitting an + b√n + c better than an + b, the optimal structure has √n-sized blocks. Look for a construction parameterized by k where k=√n balances two competing costs (k things each of size n/k)." ;
    oc:hasRationale "The √n term in the closed form is a fingerprint of a balanced bipartition structure where the optimum occurs at the geometric mean" ;
    oc:severityLevel "MEDIUM" .

oc:kn_233a48ef a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the problem asks to maximize the size of something (tiles, intervals, independent sets) subject to a one-per-row/one-per-column constraint" ;
    oc:directiveContent "For optimization problems over permutations with one-per-row/column constraints, the symmetric choice (identity, diagonal, regular spacing) is often the worst case, not the best. Spread placements that partition into √n groups and assign each to a residue class mod √n, with reverse ordering within groups, create fat windows instead of thin slivers." ;
    oc:hasRationale "Symmetry creates a contiguous forbidden band leaving only thin slivers; spreading forbidden positions across residue classes leaves larger exploitable regions" ;
    oc:severityLevel "HIGH" .

oc:kn_50c0d5eb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When you need n objects in ℝ^k with genericity conditions like 'any k are independent' or need matrices satisfying commutativity constraints" ;
    oc:directiveContent "Use the moment curve (1, t, t², ..., t^{k-1}) at n distinct parameter values to obtain n objects in ℝ^k where any k are linearly independent. Vandermonde determinants guarantee non-degeneracy. For matrices, use rank-1 idempotents A_i = v_i w_i^T to translate vector genericity into commutator conditions." ;
    oc:hasRationale "The moment curve is a well-known algebraic geometry construction that provides maximal genericity; Vandermonde structure ensures linear independence for free" ;
    oc:severityLevel "HIGH" .

oc:kn_6bd987fa a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating candidate constructions for combinatorial optimization problems" ;
    oc:directiveContent "The intuition 'symmetric = optimal' fails systematically when the objective rewards large substructures that symmetry prevents. Always check whether the constraint structure creates contiguous forbidden bands that symmetric placements maximize." ;
    oc:hasRationale "This is a deep cognitive bias in mathematical intuition — symmetry feels optimal but is provably suboptimal when the objective function favors large substructures" ;
    oc:severityLevel "HIGH" .

oc:kn_d5d08ea0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When contributing to or updating the known constructions reference" ;
    oc:directiveContent "Never store specific problem answers or solutions in this construction patterns file. It is exclusively for construction techniques and meta-heuristics, not for solved problem results." ;
    oc:hasRationale "Mixing techniques with specific answers pollutes the meta-pattern library and defeats its purpose as a transferable methodology reference" ;
    oc:severityLevel "MEDIUM" .

