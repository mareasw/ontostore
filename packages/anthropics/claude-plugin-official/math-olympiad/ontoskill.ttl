_:ref_484f0a0d5d372373 a oc:WorkflowStep ;
    dcterms:description "Launch 8-12 parallel solver agents with varied starting angles using VERBATIM no-computation prompt. Each internally iterates: solve→self-improve→self-verify→correct up to 5 rounds" ;
    oc:expectedOutcome "Candidate solutions with verdicts (complete/partial/no progress), key methods, and detailed proofs" ;
    oc:stepDependsOn _:ref_67d6063c4dca3a6a ;
