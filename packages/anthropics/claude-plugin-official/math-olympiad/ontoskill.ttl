    oc:workflowName "Ordered Procedure" .

_:ref_67d6063c4dca3a6a a oc:WorkflowStep ;
    dcterms:description "Interpretation check: list 2-3 possible readings, identify the hard (intended) one, state chosen interpretation with rationale" ;
    oc:expectedOutcome "Correct problem interpretation identified; trivial misreadings ruled out" ;
    oc:stepId "interpret" .

_:ref_6e7e91e43a3472aa a oc:WorkflowStep ;
    dcterms:description "Clean solutions: strip all thinking-block content, false starts, and backtracking. Extract only Method + Proof + Answer from each solver" ;
    oc:expectedOutcome "Context-isolated clean arguments with no solver thinking trace" ;
    oc:stepDependsOn _:ref_484f0a0d5d372373 ;
    oc:stepId "clean" .

_:ref_9ac27aa240e43418 a oc:WorkflowStep ;
    dcterms:description "Rank solutions by verdict/confidence. Run up to 5 fresh verifiers with asymmetric thresholds (4 HOLDS confirm, 2 HOLE refutes). Apply pigeonhole early exit." ;
    oc:expectedOutcome "Proof confirmed (4+ HOLDS), refuted (2+ HOLES), or undecided" ;
    oc:stepDependsOn _:ref_269534020c9b82d4 ;
    oc:stepId "vote" .

_:ref_acb860e316245dd5 a oc:WorkflowStep ;
    dcterms:description "If tight-budget abstains: launch one deep-mode agent with partial proof + gap descriptions + bounded computation. No web access. Auto-triggered — do not skip." ;
    oc:expectedOutcome "Either a complete proof from sustained attention, or confirmation of abstention" ;
    oc:stepDependsOn _:ref_cae7ee3818b2be15 ;
    oc:stepId "deep-mode" .

_:ref_cae7ee3818b2be15 a oc:WorkflowStep ;
    dcterms:description "If holes found: launch reviser agents (up to 3 cycles) with hole report only. Pattern #40 fires get adversarial brief forcing binary outcome. Re-vote after revision." ;
    oc:expectedOutcome "Revised proof that either passes verification or triggers calibrated abstention" ;
    oc:stepDependsOn _:ref_9ac27aa240e43418 ;
    oc:stepId "revise" .

_:ref_cd90994c2c9cf945 a oc:WorkflowStep ;
    dcterms:description "Launch 5-7 solver agents with varied approaches, no proof machinery" ;
    oc:expectedOutcome "Multiple numeric answer candidates" ;
    oc:stepId "solve-numeric" .

