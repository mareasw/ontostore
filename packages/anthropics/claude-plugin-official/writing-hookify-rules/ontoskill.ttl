    oc:contentHash "69f5bf9b487a2b1d1e6b0f58ee4f8d4416cc4e5124c5fd2ea08f608c7e304277" ;
    oc:differentia "that defines how to author hookify rules — markdown files with YAML frontmatter that trigger pattern-matched warnings or blocks on bash, file, stop, and prompt events" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Write" ;
    oc:hasArgumentHint "description of the behavior to watch for and the event type (bash, file, stop, prompt)" ;
    oc:hasCategory "development" ;
    oc:hasDescription "This skill should be used when the user asks to \"create a hookify rule\", \"write a hook rule\", \"configure hookify\", \"add a hookify rule\", or needs guidance on hookify rule syntax and patterns." ;
    oc:hasName "writing-hookify-rules" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Hookify rules are markdown files with YAML frontmatter that define patterns to watch for and messages to show when those patterns match. Rules are stored in `.claude/hookify.{rule-name}.local.md` files." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Overview" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """**Temporary:** Set `enabled: false` in frontmatter
**Permanent:** Delete the `.local.md` file""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Disabling a Rule" ],
                        [ a oc:Section ;
