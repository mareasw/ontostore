oc:kn_398ff253 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When debugging MCP connection or authentication failures" ;
    oc:directiveContent "When MCP server fails to connect: verify URL is correct, check server is running (stdio), validate network connectivity, clear cached auth tokens, and restart Claude Code." ;
    oc:hasRationale "Systematic verification of each failure point isolates the root cause efficiently." ;
    oc:severityLevel "MEDIUM" .

oc:kn_43d67269 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting allowed-tools in command or agent frontmatter" ;
    oc:directiveContent "Avoid wildcard tool pre-allowing (e.g., mcp__plugin_name_server__*). Pre-allow only specific tools needed by each command." ;
    oc:hasRationale "Wildcards grant excessive permissions and violate the principle of least privilege, potentially exposing destructive operations." ;
    oc:severityLevel "HIGH" .

oc:kn_465bfc08 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "After modifying .mcp.json or plugin.json MCP configuration" ;
    oc:directiveContent "Configuration changes to MCP servers require restarting Claude Code to take effect. Tools may not appear in /mcp output until restart." ;
    oc:hasRationale "MCP server configuration is parsed at plugin load time; runtime changes are not hot-reloaded." ;
    oc:severityLevel "HIGH" .

oc:kn_66dfa72d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding how to bundle MCP server configuration" ;
    oc:directiveContent "Prefer dedicated .mcp.json at plugin root over inline mcpServers in plugin.json. Use inline only for simple single-server plugins." ;
    oc:hasRationale "Separate .mcp.json provides clearer separation of concerns, easier maintenance, and scales better for multi-server plugins." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7401e37f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which MCP server type to configure" ;
    oc:directiveContent "Use stdio for local/custom servers, SSE for hosted cloud services with OAuth, HTTP for REST API backends with token auth, and WebSocket for real-time bidirectional communication." ;
    oc:hasRationale "Each transport type is optimized for specific use cases; choosing the wrong type leads to unnecessary complexity or missing capabilities." ;
    oc:severityLevel "MEDIUM" .

oc:kn_80cd4854 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring SSE, HTTP, or WebSocket MCP server URLs" ;
    oc:directiveContent "Always use HTTPS/WSS URLs for network-based MCP servers (SSE, HTTP, WebSocket), never HTTP/WS." ;
    oc:hasRationale "Unencrypted connections expose tokens, data, and tool calls to interception." ;
    oc:severityLevel "CRITICAL" .

oc:kn_888fc0e2 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before publishing or deploying an MCP-integrated plugin" ;
    oc:directiveContent "Before publishing a plugin with MCP integration: validate JSON syntax, verify server connectivity, confirm environment variables are documented in README, test authentication flows, and verify tools appear in /mcp output." ;
    oc:hasRationale "Incomplete MCP configuration causes runtime failures that are difficult to debug after deployment." ;
    oc:severityLevel "HIGH" .

oc:kn_bd134b3d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing MCP tool call performance" ;
    oc:directiveContent "Batch similar MCP tool requests using filters rather than making many individual calls. Use parallel calls when tools don't depend on each other." ;
    oc:hasRationale "Batching reduces latency and avoids rate limiting; parallel execution improves throughput for independent operations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d4e0eb55 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When referencing MCP tools in command or agent configurations" ;
    oc:directiveContent "MCP tool names follow the format mcp__plugin_<plugin-name>_<server-name>__<tool-name>. These names are case-sensitive and must match exactly in allowed-tools lists." ;
    oc:hasRationale "Incorrect tool names silently fail to match, either blocking legitimate access or granting unintended access." ;
    oc:severityLevel "HIGH" .

oc:kn_e54d3c2d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any MCP server with file references" ;
    oc:directiveContent "Always use ${CLAUDE_PLUGIN_ROOT} for file paths in MCP configuration, never hardcode absolute paths, to ensure plugin portability." ;
    oc:hasRationale "Hardcoded paths break when plugins are installed on different machines or in different directories." ;
    oc:severityLevel "HIGH" .

oc:kn_f8f29c51 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring authentication headers or environment variables for MCP servers" ;
    oc:directiveContent "Never hardcode tokens, API keys, or credentials directly in MCP configuration JSON. Always use environment variable substitution (${VAR_NAME})." ;
    oc:hasRationale "Hardcoded credentials in config files get committed to git and exposed, creating security vulnerabilities." ;
    oc:severityLevel "CRITICAL" .

