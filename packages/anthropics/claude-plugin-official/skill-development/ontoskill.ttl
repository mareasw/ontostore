                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "**Use cases**: Templates, images, icons, boilerplate code, fonts, sample documents that get copied or modified" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "**Examples**: `assets/logo.png` for brand assets, `assets/slides.pptx` for PowerPoint templates, `assets/frontend-template/` for HTML/React boilerplate, `assets/font.ttf` for typography" ] ] ;
                                            oc:sectionLevel 5 ;
                                            oc:sectionOrder 9 ;
                                            oc:sectionTitle "Assets (`assets/`)" ],
                                        [ a oc:Section ;
                                            oc:hasContent [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 1 ;
                                                    oc:textContent "Documentation and reference material intended to be loaded as needed into context to inform Claude's process and thinking." ],
                                                [ a oc:BulletList ;
                                                    oc:blockType "bullet_list" ;
                                                    oc:contentOrder 2 ;
                                                    oc:hasItem [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 3 ;
                                                            oc:itemText "**Use cases**: Database schemas, API documentation, domain knowledge, company policies, detailed workflow guides" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 2 ;
                                                            oc:itemText "**Examples**: `references/finance.md` for financial schemas, `references/mnda.md` for company NDA template, `references/policies.md` for company policies, `references/api_docs.md` for API specifications" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 1 ;
                                                            oc:itemText "**When to include**: For documentation that Claude should reference while working" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 5 ;
                                                            oc:itemText "**Best practice**: If files are large (>10k words), include grep search patterns in SKILL.md" ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 6 ;
                                                            oc:itemText "**Avoid duplication**: Information should live in either SKILL.md or references files, not both. Prefer references files for detailed information unless it's truly core to the skill—this keeps SKILL.md lean while making information discoverable without hogging the context window. Keep only essential procedural instructions and workflow guidance in SKILL.md; move detailed reference material, schemas, and examples to references files." ],
                                                        [ a oc:BulletItem ;
                                                            oc:blockType "bullet_item" ;
                                                            oc:itemOrder 4 ;
                                                            oc:itemText "**Benefits**: Keeps SKILL.md lean, loaded only when Claude determines it's needed" ] ] ;
