                                    oc:contentOrder 5 ;
                                    oc:textContent "Example: When designing a `frontend-webapp-builder` skill for queries like \"Build me a todo app\" or \"Build me a dashboard to track my steps,\" the analysis shows:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "To turn concrete examples into an effective skill, analyze each example by:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 7 ;
                                    oc:textContent "Example: When building a `big-query` skill to handle queries like \"How many users have logged in today?\" the analysis shows:" ],
