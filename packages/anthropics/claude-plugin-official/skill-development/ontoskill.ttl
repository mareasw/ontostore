                            oc:sectionTitle "Step 6: Iterate" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "When editing the (newly-created or existing) skill, remember that the skill is being created for another instance of Claude to use. Focus on including information that would be beneficial and non-obvious to Claude. Consider what procedural knowledge, domain-specific details, or reusable assets would help another Claude instance execute these tasks more effectively." ] ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "To begin implementation, start with the reusable resources identified above: `scripts/`, `references/`, and `assets/` files. Note that this step may require user input. For example, when implementing a `brand-guidelines` skill, the user may need to provide brand assets or templates to store in `assets/`, or documentation to store in `references/`." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 2 ;
                                            oc:textContent "Also, delete any example files and directories not needed for the skill. Create only the directories you actually need (references/, examples/, scripts/)." ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 16 ;
                                    oc:sectionTitle "Start with Reusable Skill Contents" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 2 ;
                                            oc:textContent "**Description (Frontmatter):** Use third-person format with specific trigger phrases:" ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 11 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Advanced techniques → `references/advanced.md`" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "API references → `references/api-reference.md`" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Detailed patterns → `references/patterns.md`" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "Migration guides → `references/migration.md`" ] ],
                                        [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """---
name: Skill Name
description: This skill should be used when the user asks to "specific phrase 1", "specific phrase 2", "specific phrase 3". Include exact phrases users would say that should trigger this skill. Be concrete and specific.
version: 0.1.0
---
""" ;
                                            oc:codeLanguage "yaml" ;
                                            oc:contentOrder 3 ;
                                            oc:sourceLocation "lines 164-170" ],
                                        _:ref_669745388731f855,
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 4 ;
                                            oc:textContent "**Good description examples:**" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**Writing Style:** Write the entire skill using **imperative/infinitive form** (verb-first instructions), not second person. Use objective, instructional language (e.g., \"To accomplish X, do Y\" rather than \"You should do X\" or \"If you need to do X\"). This maintains consistency and clarity for AI consumption." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 12 ;
                                            oc:textContent "**Reference resources in SKILL.md:**" ],
                                        [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """description: This skill should be used when the user asks to "create a hook", "add a PreToolUse hook", "validate tool use", "implement prompt-based hooks", or mentions hook events (PreToolUse, PostToolUse, Stop).
""" ;
                                            oc:codeLanguage "yaml" ;
                                            oc:contentOrder 5 ;
                                            oc:sourceLocation "lines 173-175" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 10 ;
                                            oc:textContent "**Keep SKILL.md lean:** Target 1,500-2,000 words for the body. Move detailed content to references/:" ],
                                        [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """## Additional Resources

