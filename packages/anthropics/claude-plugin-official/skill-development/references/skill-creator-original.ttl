@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_skill_development_skill_creator_original a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "skill-creator-original" ;
    skos:broader "Skill authoring guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/skill-development" ;
    oc:contentHash "8c0ce23bb87be91f5b0853c2e9815617c3858b63acdddfe5da47d2c2d3a60816" ;
    oc:differentia "that provides the foundational methodology for creating, initializing, editing, packaging, and iterating Claude Code skills using the standard directory structure with SKILL.md, scripts/, references/, and assets/" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_skill_development ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "skill-name and optional output directory" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_5c3efadf,
        oc:req_7bf13844,
        oc:req_883dcb03,
        oc:req_b173cdaa,
        oc:req_f4e28ef8 ;
    oc:impartsKnowledge oc:kn_072027aa,
        oc:kn_4f02380d,
        oc:kn_6e21c648,
        oc:kn_8ad9963b,
        oc:kn_8ba7f21f,
        oc:kn_c4a50372,
        oc:kn_cae659e7 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create a new skill",
        "initialize skill directory structure",
        "iterate on skill improvements",
        "package a skill for distribution",
        "plan skill contents from concrete examples",
        "update an existing skill" ;
    oc:yieldsState oc:DocumentCreated,
        oc:FileDownloaded .

oc:kn_072027aa a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running package_skill.py" ;
    oc:directiveContent "Before packaging, verify: YAML frontmatter has required name and description fields, directory structure follows conventions, description includes specific trigger phrases, and all referenced files exist." ;
    oc:hasRationale "The packaging script validates these requirements, but pre-checking saves iteration cycles and ensures a clean first packaging attempt." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4f02380d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing skill content across files" ;
    oc:directiveContent "Avoid duplicating information between SKILL.md and references/ files. Information should live in exactly one place, with SKILL.md containing only essential procedural instructions and references/ holding detailed schemas, examples, and domain knowledge." ;
    oc:hasRationale "Duplication creates maintenance burden and risks inconsistency. Keeping SKILL.md lean ensures it loads efficiently while references are available when deeper knowledge is needed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6e21c648 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing YAML frontmatter for any skill" ;
    oc:directiveContent "The frontmatter description must include specific trigger phrases that users would actually say, written in third-person format. Vague descriptions like 'Provides guidance for X' will cause poor skill matching." ;
    oc:hasRationale "The description is the primary signal for skill auto-discovery. Without concrete trigger phrases, Claude cannot reliably determine when to activate the skill." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8ad9963b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any content in SKILL.md or YAML frontmatter" ;
    oc:directiveContent "Never use second-person voice in SKILL.md or frontmatter description. Use imperative/infinitive form for instructions and third-person for descriptions (e.g., 'This skill should be used when...' not 'Use this skill when...')." ;
    oc:hasRationale "Second-person writing reduces clarity for AI consumption and makes descriptions less scannable for skill matching. Third-person descriptions with specific trigger phrases improve skill auto-discovery accuracy." ;
    oc:severityLevel "HIGH" .

oc:kn_8ba7f21f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When creating any new skill from scratch" ;
    oc:directiveContent "Follow the 6-step skill creation process in order: (1) understand with concrete examples, (2) plan reusable contents, (3) initialize with init_skill.py, (4) edit the skill, (5) package with package_skill.py, (6) iterate. Skip steps only with clear justification." ;
    oc:hasRationale "This ordered process ensures skills are grounded in real usage patterns, properly structured, validated, and packaged before distribution, reducing iteration cycles." ;
    oc:severityLevel "HIGH" .

oc:kn_c4a50372 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Step 2 (Planning Reusable Skill Contents)" ;
    oc:directiveContent "When planning skill contents, analyze each concrete usage example to identify which reusable resources (scripts/, references/, assets/) would eliminate repetitive work. Store code that is repeatedly rewritten as scripts, schemas/docs as references, and templates/output files as assets." ;
    oc:hasRationale "The three resource types serve distinct purposes: scripts for deterministic reliability, references for on-demand knowledge, and assets for output production. Proper categorization maximizes skill effectiveness." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cae659e7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or editing any skill" ;
    oc:directiveContent "Use progressive disclosure: keep SKILL.md lean (<5k words), move detailed reference material to references/ files, and load bundled resources only as needed by Claude." ;
    oc:hasRationale "Progressive disclosure prevents context window bloat and ensures Claude loads only relevant information when the skill triggers, improving both token efficiency and response quality." ;
    oc:severityLevel "HIGH" .

oc:req_5c3efadf a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Read" .

oc:req_7bf13844 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of progressive disclosure design principle" .

oc:req_883dcb03 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Write" .

oc:req_b173cdaa a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Bash" .

