oc:kn_07fa57d4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When modifying hook configuration during an active session" ;
    oc:directiveContent "Hooks are loaded at session start and cannot be hot-swapped. Editing hooks.json requires restarting Claude Code." ;
    oc:hasRationale "Hook configuration is read once at startup; changes mid-session are silently ignored until restart" ;
    oc:severityLevel "CRITICAL" .

oc:kn_14f36986 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When configuring hook timeout values" ;
    oc:directiveContent "Default timeouts: command hooks 60s, prompt hooks 30s. Set explicit timeouts to prevent long-running hooks from blocking workflows." ;
    oc:hasRationale "Overly long hooks degrade user experience; overly short hooks may fail before completing validation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_2ac5ceb8 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before deploying hooks to production" ;
    oc:directiveContent "Always validate hooks.json with validate-hook-schema.sh and lint scripts with hook-linter.sh before deploying." ;
    oc:hasRationale "Invalid JSON or missing fields cause silent hook loading failures that are hard to diagnose" .

oc:kn_742a4f69 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating hooks.json for a plugin vs user settings" ;
    oc:directiveContent "Plugin hooks.json uses wrapper format {\"description\": \"...\", \"hooks\": {...}} while user settings uses direct format with events at top level." ;
    oc:hasRationale "Mixing up the two formats causes hook loading failures" .

oc:kn_8c0f53e1 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing bash hook scripts" ;
    oc:directiveContent "Command hooks should always use `set -euo pipefail` and read input from stdin via `cat`. Exit 0 for approve, exit 2 for deny/block." ;
    oc:hasRationale "Proper error handling prevents silent failures and ensures consistent hook behavior" .

oc:kn_9d1403cd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing multiple hooks for the same matcher/event" ;
    oc:directiveContent "Never rely on hook execution order within the same event. All matching hooks run in parallel and don't see each other's output." ;
    oc:hasRationale "Parallel execution means hook ordering is non-deterministic; state-sharing between parallel hooks will fail unpredictably" ;
    oc:severityLevel "CRITICAL" .

oc:kn_aecd4319 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When writing command hook validation scripts" ;
    oc:directiveContent "Always validate all input fields in command hooks. Never trust tool_name, file_path, or command values without sanitization." ;
    oc:hasRationale "Hook input comes from tool execution context and may contain malicious or malformed data" ;
    oc:severityLevel "HIGH" .

oc:kn_b236a667 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring prompt-type hooks" ;
    oc:directiveContent "Prompt-based hooks are only supported on Stop, SubagentStop, UserPromptSubmit, and PreToolUse events." ;
    oc:hasRationale "Other events (PostToolUse, SessionStart, SessionEnd, PreCompact, Notification) only support command-type hooks" ;
    oc:severityLevel "HIGH" .

oc:kn_b329eadf a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between prompt and command hook types" ;
    oc:directiveContent "Use prompt-based hooks for complex reasoning and edge cases; use command hooks only for fast deterministic checks (< 50ms) or external tool integration." ;
    oc:hasRationale "Prompt hooks leverage LLM reasoning for context-aware decisions; command hooks are faster but limited to scripted logic" .

oc:kn_ef545e7c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing command hook configurations" ;
    oc:directiveContent "Never use hardcoded absolute paths in hook commands. Always use ${CLAUDE_PLUGIN_ROOT} for plugin-relative paths." ;
    oc:hasRationale "Hardcoded paths break portability across different installations and environments" ;
    oc:severityLevel "HIGH" .

oc:kn_fb66d2d4 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When writing command hook bash scripts" ;
    oc:directiveContent "Unquoted bash variables in hook scripts create injection vulnerabilities. Always use double quotes around variables." ;
    oc:hasRationale "Unquoted variables allow command injection through crafted tool input, compromising security" ;
    oc:severityLevel "HIGH" .

