oc:kn_070ff045 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When combining multiple hook patterns" ;
    oc:directiveContent "Never use a single hook matcher for all concerns — separate matchers by tool type (Write|Edit, Bash, mcp__*) for clear, maintainable hook logic." ;
    oc:hasRationale "Broad catch-all matchers make hooks hard to debug and maintain; specificity enables layered protection." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5769e512 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing prompt-type hooks for PreToolUse matchers" ;
    oc:directiveContent "Use `$TOOL_INPUT.file_path` and `$TOOL_INPUT.command` in prompt templates to inject tool-specific context into LLM safety decisions." ;
    oc:hasRationale "These variables provide the exact input the agent is about to pass to a tool, enabling precise validation." ;
    oc:severityLevel "HIGH" .

oc:kn_65949005 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using Pattern 9 (temporarily active hooks)" ;
    oc:directiveContent "Flag-file-gated hooks require a Claude Code restart after creating or removing the flag file for changes to take effect." ;
    oc:hasRationale "Hooks are registered at session start; flag file changes mid-session won't be recognized without restart." ;
    oc:severityLevel "HIGH" .

oc:kn_93b5186a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing hook type for a pattern" ;
    oc:directiveContent "Use prompt-type hooks for contextual decisions (approve/deny/ask) and command-type hooks for side effects (logging, linting, environment setup)." ;
    oc:hasRationale "Prompt hooks leverage LLM reasoning for nuanced decisions; command hooks execute deterministic scripts reliably." ;
    oc:severityLevel "HIGH" .

oc:kn_9da3b946 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When implementing Pattern 1 (security validation)" ;
    oc:directiveContent "Security validation hooks should check for path traversal ('..'), sensitive directories ('/etc', system dirs), and credential files ('.env') to prevent accidental or malicious file modifications." ;
    oc:hasRationale "These are the most common vectors for unintended system damage via file write operations." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c6e10d15 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When implementing deny/block logic in bash command hooks" ;
    oc:directiveContent "Use `exit 0` for no-op early returns in command hooks, and `exit 2` with a JSON `{\"decision\": \"deny\", \"reason\": \"...\"}` on stderr to block operations." ;
    oc:hasRationale "Exit code 2 signals denial to Claude Code; exit 0 allows the operation. Stderr JSON provides the denial reason to the agent." ;
    oc:severityLevel "HIGH" .

oc:kn_d02e4c58 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing bash scripts for command-type hooks" ;
    oc:directiveContent "Command hooks should read stdin via `cat`, parse with `jq`, and exit cleanly even when no action is needed (e.g., flag files absent, config disabled)." ;
    oc:hasRationale "Hooks fire on every matching event; scripts must handle repeated invocations gracefully without side effects on no-op runs." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fe9f61ec a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing a multi-layered hook strategy" ;
    oc:directiveContent "Combine PreToolUse (safety checks), PostToolUse (quality enforcement), Stop (completeness verification), and SessionStart (context setup) hooks for comprehensive protection." ;
    oc:hasRationale "Each hook event type covers a different phase of the agent lifecycle; together they provide defense in depth." ;
    oc:severityLevel "MEDIUM" .

