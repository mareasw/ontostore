cache_key=$(echo -n "$file_path" | md5sum | cut -d' ' -f1)
cache_file="/tmp/hook-cache-$cache_key"
if [ -f "$cache_file" ]; then
  cache_age=$(($(date +%s) - $(stat -c%Y "$cache_file")))
  if [ "$cache_age" -lt 300 ]; then
    cat "$cache_file"
    exit 0
  fi
fi
# Perform validation, then cache and output result""" .

oc:kn_1077aa82 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing validation pipelines that need both speed and intelligence" ;
    oc:directiveContent "Combine command hooks (fast deterministic checks) with prompt hooks (intelligent analysis) for layered validation — command hooks approve safe cases quickly, prompt hooks handle complex ones." ;
    oc:hasRationale "Command hooks are fast but limited to pattern matching; prompt hooks are slower but can reason about context. Layering gives best of both." .

oc:kn_380d12bd a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing security hooks to prevent secret leakage" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """# Secret detection pattern
content=$(echo "$input" | jq -r '.tool_input.content')
if echo "$content" | grep -qE "(api[_-]?key|password|secret|token).{0,20}['\\"]?[A-Za-z0-9]{20,}"; then
  echo '{"decision": "deny", "reason": "Potential secret detected"}' >&2
  exit 2
fi""" .

oc:kn_39096c66 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating environment-conditional hooks or project-configurable hooks" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """# Skip hook in non-CI
if [ -z "$CI" ]; then
  echo '{"continue": true}'
  exit 0
fi
# Read project config
if [ -f ".claude-hooks-config.json" ]; then
  strict_mode=$(jq -r '.strict_mode' .claude-hooks-config.json)
fi""" .

oc:kn_47c1d573 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires understanding of Claude Code hook system fundamentals (event types, hook types, matchers, exit codes) covered in the parent skill" .

oc:kn_4c0425c3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing multiple hooks for the same event (e.g., PreToolUse)" ;
    oc:directiveContent "Never assume hook execution order — hooks within the same event run in parallel, not sequentially. State sharing between parallel hooks will fail." ;
    oc:hasRationale "Parallel execution means hooks cannot rely on each other's side effects. State sharing only works across sequential events (PreToolUse → PostToolUse)." ;
    oc:severityLevel "CRITICAL" .

oc:kn_92757163 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When writing bash hook scripts that parse JSON input" ;
    oc:directiveContent "Scripts crash on unexpected input when jq field access fails or file paths don't exist. Always guard with existence checks and provide fallback behavior." ;
    oc:hasRationale "Hook scripts receive unstructured tool input; missing fields or unexpected formats will cause uncaught errors that silently break validation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9f4480d9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any hook" ;
    oc:directiveContent "Always set timeouts on hooks — command hooks should typically be 2-5 seconds, prompt hooks 10-15 seconds. Long-running hooks will timeout and block the entire workflow." ;
    oc:hasRationale "Without timeouts, a slow or hung hook blocks the agent's entire operation. Default timeouts may be too generous for production use." ;
    oc:severityLevel "HIGH" .

oc:kn_aab72a07 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When hooks need to communicate or share data" ;
    oc:directiveContent "Design hooks to be independent and stateless. If state must be shared, use temp files with process-specific names (e.g., /tmp/hook-state-$$) and only between sequential events." ;
    oc:hasRationale "Independent hooks can run in parallel safely. State coupling introduces fragility and limits composability." .

oc:kn_afcdcf4d a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When hooks perform repeated expensive checks (e.g., file content analysis)" ;
    oc:directiveContent "Use caching (keyed by file path hash, 5-minute TTL) for expensive validations. Design independent hooks to run in parallel, reducing total latency." ;
    oc:hasRationale "Caching avoids redundant work across invocations. Parallel independent hooks reduce wall-clock latency." .

oc:kn_b397c649 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building any advanced hook system" ;
    oc:directiveContent "1. Keep hooks independent — don't rely on execution order. 2. Use timeouts for each hook type. 3. Handle errors gracefully with clear messages. 4. Document complex patterns. 5. Test edge cases and failure modes. 6. Monitor hook execution time. 7. Version control hook configs. 8. Provide escape hatches for users." ;
    oc:hasRationale "These practices ensure reliability, maintainability, and debuggability of production hook systems." ;
    oc:stepOrder 1 .

oc:kn_c58829ba a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing rate limiting in hooks" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """# Rate limiting pattern
rate_file="/tmp/hook-rate-$$"
current_minute=$(date +%Y%m%d%H%M)
count=1
if [ -f "$rate_file" ]; then
  last_minute=$(head -1 "$rate_file")
  count=$(tail -1 "$rate_file")
  if [ "$current_minute" = "$last_minute" ]; then
    if [ "$count" -gt 10 ]; then
      echo '{"decision": "deny", "reason": "Rate limit exceeded"}' >&2
      exit 2
    fi
    count=$((count + 1))
  else
    count=1
  fi
fi
echo "$current_minute" > "$rate_file"
echo "$count" >> "$rate_file\"""" .

oc:kn_c694a9dd a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When hooks process sensitive data like API keys, passwords, or secrets" ;
    oc:directiveContent "Implement rate limiting, audit logging, and secret detection as hook patterns. Never log full tool input to unencrypted locations." ;
    oc:hasRationale "Hooks intercept all tool interactions, making them ideal security checkpoints but also potential leak vectors if logging is careless." ;
    oc:severityLevel "HIGH" .

