    oc:yieldsState oc:HookConfigured .

oc:kn_1d3ddf6d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing multiple hooks for the same event (e.g., multiple PreToolUse hooks)" ;
    oc:directiveContent "Never assume hooks execute in a specific order — hooks within the same event run in parallel, so state sharing between them is unreliable." ;
    oc:hasRationale "Parallel hook execution means race conditions and non-deterministic behavior if hooks depend on each other's output." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3e20eee2 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When writing any bash command hook script" ;
    oc:directiveContent "Always handle errors gracefully in hook scripts — check for missing files, invalid JSON input, and unexpected values, returning continue/approve with a system message rather than crashing." ;
    oc:hasRationale "An uncaught exception in a hook script causes unpredictable behavior; graceful degradation ensures the workflow continues safely." ;
    oc:severityLevel "HIGH" .

oc:kn_6cf3e46f a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When hooks guard sensitive operations or are deployed in shared/CI environments" ;
    oc:directiveContent "Use rate limiting, audit logging, and secret detection patterns to prevent abuse and maintain security visibility in hook workflows." ;
    oc:hasRationale "Without rate limiting, hooks can be bypassed through rapid repeated invocation; without audit logging, blocked operations leave no trace." ;
    oc:severityLevel "MEDIUM" .

oc:kn_93f816f1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any hook in hooks.json" ;
    oc:directiveContent "Always set appropriate timeouts for hooks — command hooks typically 2-5 seconds, prompt hooks 10-15 seconds. Long-running hooks will timeout and block the workflow." ;
    oc:hasRationale "Without timeouts, a hung hook can freeze the entire Claude Code workflow, degrading user experience." ;
    oc:severityLevel "HIGH" .

oc:kn_ad7381b9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing cross-event hook workflows" ;
    oc:directiveContent "Keep hooks independent and stateless where possible. When state sharing is necessary, use temporary files with unique identifiers (e.g., $$) and only between sequential events (PreToolUse → PostToolUse → Stop)." ;
    oc:hasRationale "Independent hooks are more reliable, testable, and maintainable. Stateful hooks introduce coupling and failure modes." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cc4318f6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing validation workflows that need both speed and depth" ;
    oc:directiveContent "Combine command hooks (fast, deterministic) with prompt hooks (intelligent, contextual) in a layered validation pipeline for optimal performance." ;
    oc:hasRationale "Command hooks provide instant approval for obviously safe operations while prompt hooks handle nuanced analysis, minimizing latency." ;
    oc:severityLevel "HIGH" .

oc:kn_e664c2de a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When hooks perform repeated expensive operations like file scanning or content analysis" ;
    oc:directiveContent "Use caching (e.g., file-based cache with TTL) for expensive validation results and leverage parallel hook execution by designing independent hooks that run simultaneously." ;
    oc:hasRationale "Caching avoids redundant computation per-tool-invocation, and parallel execution reduces total latency from sum-of-serial to max-of-parallel." ;
    oc:severityLevel "MEDIUM" .

