oc:kn_081c5fd4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing hook scripts and configuring hooks.json" ;
    oc:directiveContent "Exit codes must be 0 (allow) or 2 (block with message). Timeout values must be in valid ranges. Avoid long-running operations in hooks." ;
    oc:hasRationale "Invalid exit codes cause unexpected behavior; timeouts block Claude Code workflows" ;
    oc:severityLevel "HIGH" .

oc:kn_0a8f3aeb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before deploying any hook to production" ;
    oc:directiveContent "Always test hooks before deploying to avoid breaking user workflows. Create different test inputs for various scenarios (safe operations, dangerous operations, edge cases)." ;
    oc:hasRationale "A broken hook can block all user interactions with Claude Code, causing workflow disruption" ;
    oc:severityLevel "MEDIUM" .

oc:kn_2bf003f0 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Generate sample test input for a specific hook event type" ;
    oc:directiveContent "./test-hook.sh --create-sample PreToolUse > test-input.json" .

oc:kn_44cfb768 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before testing or deploying any hook script" ;
    oc:directiveContent "Before deploying hooks, verify: script has shebang (#!/bin/bash), script is executable (chmod +x), path in hooks.json uses ${CLAUDE_PLUGIN_ROOT}" ;
    oc:hasRationale "Missing shebang, lack of execute permission, or hardcoded paths are the most common reasons hooks fail to execute" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4866edb7 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Test a hook script with verbose output and custom timeout" ;
    oc:directiveContent "./test-hook.sh -v -t 30 <hook-script> <test-input.json>" .

oc:kn_4a455ac2 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Lint one or more hook scripts for best practices and security issues" ;
    oc:directiveContent "./hook-linter.sh <hook-script.sh> [hook-script2.sh ...]" .

oc:kn_7ad89c9c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Always follow this sequence when developing a new hook" ;
    oc:directiveContent "1. Write hook script → 2. Lint with hook-linter.sh → 3. Create test input with test-hook.sh --create-sample → 4. Test hook with test-hook.sh -v → 5. Add to hooks.json → 6. Validate with validate-hook-schema.sh → 7. Test in Claude Code with --debug" ;
    oc:hasRationale "Ensures hooks are validated at each stage before deployment, catching issues early" ;
    oc:stepOrder 1 .

oc:kn_b3c7e1d4 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When writing any hook script that processes stdin JSON input" ;
    oc:directiveContent "Always quote variables (\"$variable\"), use set -euo pipefail, validate all input fields, and run the linter to catch injection vulnerabilities" ;
    oc:hasRationale "Unquoted variables and missing input validation create injection vulnerabilities that can compromise the system" ;
    oc:severityLevel "HIGH" .

oc:kn_dfaad5a3 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Validate hooks.json configuration structure" ;
    oc:directiveContent "./validate-hook-schema.sh path/to/hooks.json" .

oc:kn_fdfff8fd a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a hook doesn't produce expected output" ;
    oc:directiveContent "If hook fails silently: check exit codes (should be 0 or 2), ensure errors go to stderr (>&2), validate JSON output structure" ;
    oc:hasRationale "Exit code 2 means block with message; other non-zero codes indicate failure. stderr is needed for debugging" .

