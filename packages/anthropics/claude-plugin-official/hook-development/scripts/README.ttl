@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_hook_development_readme a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "readme" ;
    skos:broader "hook development utilities" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/hook-development" ;
    oc:contentHash "08a28b12ffa9fcb16f257ea685c70a920f4f835978b9ffbbac055137c6f6aca0" ;
    oc:differentia "provides validation, testing, and linting scripts for hook implementations before deployment" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_hook_development ;
    oc:handlesFailure oc:InvalidInput,
        oc:SchemaValidationError,
        oc:TimeoutExceeded ;
    oc:hasArgumentHint "script-path or hooks.json-path" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_6a683cce,
        oc:req_7aaf5e05,
        oc:req_b5dae539 ;
    oc:impartsKnowledge oc:kn_0a411a4c,
        oc:kn_2792975c,
        oc:kn_3de41e1e,
        oc:kn_6d0f9dfd,
        oc:kn_7aef41e4,
        oc:kn_7ccf2085,
        oc:kn_969c8fe6 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "debug hook development issues",
        "lint hook scripts for best practices",
        "test hook scripts with sample input",
        "validate hook schema configuration" ;
    oc:yieldsState oc:HookLinted,
        oc:HookTested,
        oc:HookValidated .

oc:kn_0a411a4c a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When writing hook scripts that process untrusted input" ;
    oc:directiveContent "Always quote shell variables, use set -euo pipefail, validate all input fields, and never use hardcoded paths to prevent injection vulnerabilities." ;
    oc:hasRationale "Hook scripts receive JSON input from tool usage — unquoted variables and missing input validation create injection attack vectors." ;
    oc:severityLevel "CRITICAL" .

oc:kn_2792975c a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When developing any new hook script" ;
    oc:directiveContent "Follow the write → lint → test → configure → validate → deploy workflow for hook development. Each step catches progressively different classes of errors." ;
    oc:hasRationale "Sequential validation catches syntax/style issues first (linting), then functional issues (testing), then configuration issues (schema validation), preventing deployment of broken hooks." ;
    oc:severityLevel "HIGH" .

oc:kn_3de41e1e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing test cases for hook scripts" ;
    oc:directiveContent "Use --create-sample to generate test inputs for different event types, then edit them to cover safe operations, dangerous operations, and edge cases." ;
    oc:hasRationale "Diverse test inputs ensure hooks behave correctly across the full range of real-world scenarios they will encounter." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6d0f9dfd a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When debugging hooks that fail to execute" ;
    oc:directiveContent "If a hook doesn't execute, check for missing shebang (#!/bin/bash), missing executable permission (chmod +x), or incorrect paths in hooks.json — use ${CLAUDE_PLUGIN_ROOT} for relative paths." ;
    oc:hasRationale "These are the most common deployment issues that cause silent hook failures and are easy to overlook." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7aef41e4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing hook scripts" ;
    oc:directiveContent "Hook exit codes must be 0 (allow/continue) or 2 (block). Exit code 1 indicates an error. Errors must go to stderr, not stdout." ;
    oc:hasRationale "Incorrect exit codes cause hooks to fail silently or produce unexpected behavior in Claude Code's hook processing pipeline." ;
    oc:severityLevel "HIGH" .

oc:kn_7ccf2085 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any hook deployment" ;
    oc:directiveContent "Never deploy untested hooks to Claude Code — always lint, create test inputs, and test with sample JSON before adding to hooks.json." ;
    oc:hasRationale "Broken hooks can block user workflows and cause silent failures that are hard to diagnose in production." ;
    oc:severityLevel "CRITICAL" .

oc:kn_969c8fe6 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When hooks time out during execution" ;
    oc:directiveContent "Hook scripts should complete within their configured timeout (default 60s). Reduce timeout in hooks.json, optimize performance, and remove long-running operations." ;
    oc:hasRationale "Hooks block Claude Code's operation while running — timeouts indicate performance issues that degrade user experience." ;
    oc:severityLevel "MEDIUM" .

oc:req_6a683cce a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "bash" .

oc:req_7aaf5e05 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Claude Code hook events and types" .

oc:req_b5dae539 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "hooks.json schema structure" .

