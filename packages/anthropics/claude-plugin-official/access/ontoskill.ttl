                [ a oc:WorkflowStep ;
                    dcterms:description "Show dmPolicy, allowFrom count/list, pending entries with codes and age, groups count" ;
                    oc:expectedOutcome "User sees complete access status" ;
                    oc:stepDependsOn _:ref_053715391427cde6 ;
                    oc:stepId "display-status" ] ;
            oc:workflowId "status-check" ;
            oc:workflowName "Status Display" ],
        _:ref_a9bdc3262380d181,
        _:ref_c13dc6ba5317361a,
        _:ref_c8066a762f1c2688 ;
    oc:impartsKnowledge oc:kn_283f237e,
        oc:kn_28b81ddf,
        oc:kn_2a97b07e,
