oc:kn_25173d35 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing code review or code analysis agents" ;
    oc:directiveContent "For code review agents, assume the user wants recently written code reviewed, not the entire codebase, unless explicitly stated otherwise" ;
    oc:hasRationale "Scoping to recent changes prevents overwhelming the agent and aligns with typical review workflows" .

oc:kn_2d5425f0 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always - this is the required output format" ;
    oc:codeLanguage "json" ;
    oc:directiveContent "{\"identifier\": \"descriptive-name\", \"whenToUse\": \"Use this agent when... (with <example> blocks)\", \"systemPrompt\": \"You are...\\n\\n**Your Core Responsibilities:**\\n1. ...\\n...\"}" .

oc:kn_3200f641 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When generating any agent configuration" ;
    oc:directiveContent "1. Extract core intent (purpose, responsibilities, success criteria) from user request 2. Design expert persona with domain knowledge 3. Architect comprehensive instructions (boundaries, methodologies, edge cases, output format) 4. Optimize for performance (decision frameworks, quality control, escalation strategies) 5. Create concise identifier (lowercase, hyphens, 2-4 words) 6. Write whenToUse with trigger conditions and examples 7. Output JSON with identifier, whenToUse, systemPrompt fields" ;
    oc:hasRationale "Structured agent creation ensures consistent quality and completeness across all generated agents" ;
    oc:stepOrder 1 .

oc:kn_4eb3db24 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating agent identifiers" ;
    oc:directiveContent "Agent identifiers must use lowercase letters, numbers, and hyphens only; be 2-4 words; clearly indicate primary function; avoid generic terms like 'helper' or 'assistant'" ;
    oc:hasRationale "Identifiers serve as filenames and CLI invocations — they must be memorable and easy to type" .

oc:kn_60726b7d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When integrating generated agent into a plugin" ;
    oc:directiveContent "1. Take user request for agent functionality 2. Feed to Claude with the system prompt 3. Get JSON output 4. Convert to agent markdown file with frontmatter (name, description, model: inherit, color) 5. Validate with agent validation rules 6. Test triggering conditions 7. Add to plugin's agents/ directory" ;
    oc:hasRationale "Ensures proper file structure and validation before deployment" ;
    oc:stepOrder 2 .

oc:kn_61e69ba2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing whenToUse examples" ;
    oc:directiveContent "Never make agent examples show the assistant responding directly to the task — examples must always show the assistant using the Agent tool to delegate" ;
    oc:hasRationale "Correct triggering behavior demonstrates that agents are invoked via the Agent tool, not by direct response" ;
    oc:severityLevel "HIGH" .

oc:kn_88f3263e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always - this is the required output schema" ;
    oc:directiveContent "Output must be a valid JSON object with exactly three fields: identifier, whenToUse, systemPrompt — no additional top-level fields" ;
    oc:hasRationale "Downstream systems expect this exact structure for agent file generation" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b5f80589 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any agent system prompt" ;
    oc:directiveContent "System prompts should be specific not generic, include concrete examples, balance comprehensiveness with clarity, build in quality assurance and self-correction mechanisms, and make the agent proactive in seeking clarification" ;
    oc:hasRationale "Vague instructions produce unreliable agents; every instruction should add value" .

oc:kn_ba7ca274 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating agent configuration" ;
    oc:directiveContent "Consider CLAUDE.md project context — align agent with project patterns, coding standards, and established practices before generating" ;
    oc:hasRationale "Project context ensures the agent integrates naturally with existing workflows" .

oc:kn_d5241093 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When converting JSON output to agent markdown file" ;
    oc:directiveContent """---
name: {identifier}
description: {whenToUse}
model: inherit
color: {color}
---

{systemPrompt}""" ;
    oc:templateVariables "color",
        "identifier",
        "systemPrompt",
        "whenToUse" .

