oc:kn_2c6cc9b4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining output format" ;
    oc:directiveContent "Never leave the output format undefined. 'Provide a report' is insufficient — specify exact headings, sections, and data each section should contain." ;
    oc:hasRationale "Without a defined output format, agents produce inconsistent results that vary in structure and completeness" ;
    oc:severityLevel "HIGH" .

oc:kn_31da4ac5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any instructional content in a system prompt" ;
    oc:directiveContent "Use second person ('You are responsible for...', 'Your process should...') when addressing the agent. Be specific with actionable instructions ('Read the file using the Read tool, then search for patterns using Grep') rather than vague commands ('Analyze the code')." ;
    oc:hasRationale "Second person creates clear agency; specific instructions eliminate ambiguity about what tools and steps to use" ;
    oc:severityLevel "MEDIUM" .

oc:kn_35ae83ed a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When testing a completed system prompt" ;
    oc:directiveContent "Before deploying a system prompt, verify it handles: typical task execution, mentioned edge cases, error scenarios, unclear requirements, large/complex inputs, and empty/missing inputs." ;
    oc:hasRationale "Incomplete coverage of these scenarios leads to agent failures in production" ;
    oc:severityLevel "MEDIUM" .

oc:kn_630accc6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any agent system prompt" ;
    oc:directiveContent "Every agent system prompt must include: role description, core responsibilities, step-by-step process, quality standards, output format, and edge cases." ;
    oc:hasRationale "These six sections provide the minimum structure for an agent to operate autonomously without ambiguity" ;
    oc:severityLevel "HIGH" .

oc:kn_74a5e272 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing core responsibilities section" ;
    oc:directiveContent "Never write vague responsibilities like 'help the user' or 'provide assistance'. Always specify exactly what the agent analyzes, generates, or validates and the criteria it uses." ;
    oc:hasRationale "Vague instructions lead to inconsistent agent behavior and inability to determine if the agent is performing correctly" ;
    oc:severityLevel "HIGH" .

oc:kn_7ff42b12 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When selecting and customizing a system prompt template" ;
    oc:directiveContent "Match agent type to the correct pattern: Analysis agents (gather → scan → deep analyze → synthesize → prioritize → report), Generation agents (understand requirements → gather context → design structure → generate → validate → document), Validation agents (load criteria → scan target → check rules → collect violations → assess severity → determine result), Orchestration agents (plan → prepare → execute phases → monitor → verify → report)." ;
    oc:hasRationale "Each agent archetype has a distinct cognitive workflow that maps to predictable step sequences" ;
    oc:severityLevel "MEDIUM" .

oc:kn_be9fd5d1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining system prompt length" ;
    oc:directiveContent "System prompts should be 500-5,000 words. Minimum viable: ~500 words (role, 3 responsibilities, 5-step process, output format). Standard: ~1,000-2,000 words. Avoid exceeding 10,000 words due to diminishing returns." ;
    oc:hasRationale "Too short fails to guide behavior; too long causes diminishing returns and potential instruction ignoring" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c16d9f69 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When iterating on a system prompt after testing" ;
    oc:directiveContent "1. Identify where the agent struggled during testing → 2. Add missing guidance to system prompt → 3. Clarify ambiguous instructions → 4. Add process steps for edge cases → 5. Re-test" ;
    oc:stepOrder 1 .

_:ref_1d8bf780ac071b7c a oc:WorkflowStep ;
    dcterms:description "Add missing guidance to system prompt" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_209a92dadf93102f a oc:WorkflowStep ;
    dcterms:description "Identify where it struggled" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_61eb057a3ef84210 a oc:WorkflowStep ;
    dcterms:description "Add process steps for edge cases" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_8b9e27aa318f395b a oc:WorkflowStep ;
    dcterms:description "Clarify ambiguous instructions" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_ba0ff03f47333db3 a oc:WorkflowStep ;
    dcterms:description "Re-test" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
