oc:skill_anthropics_claude_plugin_official_agent_development_system_prompt_design a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "system-prompt-design" ;
    skos:broader "Design guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/agent-development" ;
    oc:contentHash "eaac53eaaf8326ac04428987280fb5041920b7571477ad41742517c5aac683fc" ;
    oc:dependsOnSkill oc:skill_agent_development ;
    oc:differentia "that provides templates and patterns for writing effective agent system prompts with proven structures for analysis, generation, validation, and orchestration agent types" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_agent_development ;
    oc:handlesFailure oc:AmbiguousAgentBehavior,
        oc:InsufficientPromptSpecification ;
    oc:hasArgumentHint "agent-type (analysis|generation|validation|orchestration)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_03b5142c,
        oc:kn_1d52300f,
        oc:kn_3f9ab4be,
        oc:kn_72a46c22,
        oc:kn_b1459d07,
        oc:kn_d1a4004f ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:AgentRoleDefined ;
    oc:resolvesIntent "choose system prompt pattern",
        "create agent instructions",
        "design system prompt",
        "structure agent behavior",
        "write agent system prompt" ;
    oc:yieldsState oc:SystemPromptDesigned .

oc:kn_03b5142c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any agent system prompt" ;
    oc:directiveContent "Every agent system prompt must follow the core structure: role description, core responsibilities, task process, quality standards, output format, and edge cases." ;
    oc:hasRationale "This proven structure ensures the agent has sufficient guidance to operate autonomously and produce high-quality, consistent output." ;
    oc:severityLevel "HIGH" .

oc:kn_1d52300f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining system prompt length" ;
    oc:directiveContent "System prompts should be 500 words minimum (viable), 1,000-2,000 words (standard), or 2,000-5,000 words (comprehensive). Avoid exceeding 10,000 words due to diminishing returns." ;
    oc:hasRationale "Too-short prompts lack sufficient guidance; too-long prompts waste tokens and can confuse the agent with conflicting instructions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3f9ab4be a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining core responsibilities in a system prompt" ;
    oc:directiveContent "Never write vague responsibilities like 'help the user' or 'provide assistance' — always specify concrete tasks with measurable outcomes and actionable steps." ;
    oc:hasRationale "Vague responsibilities give the agent no actionable guidance, leading to unpredictable or shallow outputs that don't meet user needs." .

oc:kn_72a46c22 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing the process section of a system prompt" ;
    oc:directiveContent "Select the appropriate pattern based on agent type: Analysis (gather → scan → deep analyze → synthesize → prioritize → report), Generation (understand → gather context → design → generate → validate → document), Validation (load criteria → scan → check rules → collect violations → assess severity → determine result), or Orchestration (plan → prepare → execute phases → monitor → verify → report)." ;
    oc:hasRationale "Each agent type has a fundamentally different operational model, and using the right pattern ensures the agent follows a logical, effective workflow." .

oc:kn_b1459d07 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the tone and voice of system prompt instructions" ;
    oc:directiveContent "Use second person ('You are...') when addressing the agent, and be specific rather than vague in all instructions — specify exact tools, file paths, and validation criteria." ;
    oc:hasRationale "Second-person voice directly engages the agent's identity. Specificity eliminates ambiguity that causes inconsistent agent behavior." .

oc:kn_d1a4004f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After drafting a system prompt, before deployment" ;
    oc:directiveContent "Test system prompt completeness by verifying the agent can handle: typical tasks, edge cases, error scenarios, unclear requirements, large/complex inputs, and empty/missing inputs — then iterate based on results." ;
    oc:hasRationale "Iterative testing catches gaps in guidance that the author assumed were obvious but the agent cannot infer from the prompt alone." .

