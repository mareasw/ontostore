@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_agent_development_triggering_examples a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "triggering-examples" ;
    skos:broader "Reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/agent-development" ;
    oc:contentHash "2a5ea013c97fc9f2c1ed55f96c6d5da2c2378695f7714bfb2c2e61bfbc9d228f" ;
    oc:differentia "that provides best practices and templates for writing effective example blocks in agent descriptions for reliable triggering" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_agent_development ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_6c88abfa,
        oc:kn_7637dfbe,
        oc:kn_91d6df29,
        oc:kn_9b31b8e3,
        oc:kn_cca15fdd ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "create example blocks for agent descriptions",
        "debug agent triggering issues",
        "improve agent triggering reliability",
        "write agent triggering examples" .

oc:kn_6c88abfa a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating multiple examples for the same agent" ;
    oc:directiveContent "Vary the phrasing of user messages across examples to cover different ways users express the same intent (e.g., 'review my code', 'check my implementation', 'look over these changes')." ;
    oc:hasRationale "Users rarely use the exact same words; varied phrasing ensures the agent triggers regardless of how the request is worded" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7637dfbe a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When debugging agent triggering issues" ;
    oc:directiveContent "If an agent doesn't trigger, add more examples with relevant keywords. If it triggers too often, make examples more specific and add negative examples. If it triggers in wrong scenarios, revise examples to show only correct triggering scenarios." ;
    oc:hasRationale "Triggering problems are almost always caused by insufficient or overly broad example coverage, and can be fixed by adjusting example specificity and breadth" ;
    oc:severityLevel "MEDIUM" .

oc:kn_91d6df29 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring any agent description example block" ;
    oc:directiveContent "Never omit context or commentary from example blocks. Generic examples without context, commentary, or a triggering step fail to teach Claude when and why to use the agent." ;
    oc:hasRationale "Without context, the example lacks the situational grounding needed for Claude to recognize similar scenarios. Without commentary, the reasoning for triggering is lost. Without the agent invocation step, Claude learns to respond directly instead of delegating." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9b31b8e3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Always, when writing agent triggering examples" ;
    oc:directiveContent "Each example block must include all five elements: Context (what led to the interaction), user message (exact phrasing), assistant response before triggering (acknowledgment), commentary (WHY the agent triggers), and assistant response triggering the agent (invocation using Agent tool)." ;
    oc:hasRationale "Complete examples provide a full behavioral model that Claude can pattern-match against real interactions" ;
    oc:severityLevel "HIGH" .

oc:kn_cca15fdd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing example blocks for any agent description" ;
    oc:directiveContent "Include 2-4 concrete, specific examples per agent description covering explicit requests, proactive triggers, implicit requests, and edge cases. Maximum 6 examples to avoid bloating the description." ;
    oc:hasRationale "Diverse examples with varied phrasing ensure Claude reliably triggers the agent across different user communication styles and scenarios" ;
    oc:severityLevel "HIGH" .

