oc:skill_anthropics_claude_plugin_official_agent_development_complete_agent_examples a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "complete-agent-examples" ;
    skos:broader "Agent template collection" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/agent-development" ;
    oc:contentHash "36fde2ac46665ba98804ec0fb6e94022795cba063e932d670c9463deedd30e72" ;
    oc:dependsOnSkill oc:skill_agent_development ;
    oc:differentia "provides four production-ready agent examples (code reviewer, test generator, docs generator, security analyzer) with complete frontmatter, triggering examples, process steps, quality standards, output formats, and edge case handling" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_agent_development ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "Bash",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "agent-type (code-reviewer | test-generator | docs-generator | security-analyzer)" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_72bbe44a,
        oc:req_7b32abac,
        oc:req_9eb320e6 ;
    oc:impartsKnowledge oc:kn_47665ac2,
        oc:kn_51bc0baa,
        oc:kn_9a6c574a,
        oc:kn_9d234a7e,
        oc:kn_f64e3823 ;
    oc:isUserInvocable true ;
    oc:nature "Reference" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create code review agent",
        "create documentation generator agent",
        "create security analyzer agent",
        "create test generation agent",
        "customize agent templates for specific domains",
        "learn agent frontmatter patterns and triggering examples" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_47665ac2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring agent tools in frontmatter" ;
    oc:directiveContent "Restrict agent tool access to the minimum set needed: Read-only agents get [Read, Grep, Glob], generators get [Read, Write, Grep], executors add Bash." ;
    oc:hasRationale "Principle of least privilege applies to agents — limiting tool access reduces side-effect risk and makes agent behavior more predictable." ;
    oc:severityLevel "HIGH" .

oc:kn_51bc0baa a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When designing agent output templates" ;
    oc:directiveContent "Agent output formats should include categorized sections (critical/major/minor), specific file:line references, and both positive observations and areas for improvement." ;
    oc:hasRationale "Structured output with severity levels and precise locations makes agent results actionable and scannable for the user." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9a6c574a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing agent instructions" ;
    oc:directiveContent "Include edge case handling sections in every agent: no-issues-found scenarios, overflow scenarios (too many issues), ambiguous input, and missing context." ;
    oc:hasRationale "Edge case coverage prevents agents from producing confusing or empty output in non-ideal conditions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9d234a7e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing agent frontmatter descriptions" ;
    oc:directiveContent "Every agent frontmatter must include a rich description with multiple <example> blocks covering both proactive triggers (agent acts on context) and explicit triggers (user directly requests)." ;
    oc:hasRationale "Rich examples with <commentary> tags teach the orchestrator when and why to dispatch the agent, reducing mis-triggering and missed invocations." ;
    oc:severityLevel "HIGH" .

oc:kn_f64e3823 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing the color field in agent frontmatter" ;
    oc:directiveContent "Use semantic colors to signal agent purpose: blue for analysis, green for generation, cyan for documentation, red for security, yellow for validation, magenta for transformation." ;
    oc:hasRationale "Consistent color semantics help users quickly identify agent type in UI and logs." ;
    oc:severityLevel "LOW" .

oc:req_72bbe44a a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Agent directory structure (agents/*.md)" .

oc:req_7b32abac a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Agent triggering example format with <example>, <commentary> tags" .

oc:req_9eb320e6 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Agent frontmatter YAML syntax (name, description, model, color, tools)" .

