oc:kn_077ceeee a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between AI-assisted vs manual agent creation" ;
    oc:directiveContent "Start with AI-assisted generation, then refine manually for best results. Use manual editing for: very specific project patterns, custom tool combinations, unique persona/style, integration with existing agents, or precise triggering conditions." ;
    oc:hasRationale "AI generation provides comprehensive coverage and consistent patterns, but manual refinement adds domain-specific precision" .

oc:kn_0a9c855e a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When verifying agent generation completed successfully" ;
    oc:directiveContent "A successful generation produces: valid JSON with all 3 required fields, identifier matching naming rules (3-50 chars, lowercase-hyphens), whenToUse with 2+ <example> blocks, systemPrompt under 10,000 chars using second person, and a valid agent .md file that passes validation." .

oc:kn_0b76c014 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When generating a new agent via AI-assisted workflow" ;
    oc:directiveContent "1. Describe agent need (task, trigger, proactive/reactive, responsibilities) 2. Send generation prompt to Claude with system prompt loaded: 'Create an agent configuration based on this request: \"[DESCRIPTION]\" Return ONLY the JSON object' 3. Claude returns JSON with identifier, whenToUse, systemPrompt 4. Convert JSON to agents/[identifier].md with YAML frontmatter (name, description, model, color, tools) and systemPrompt as body 5. Validate with scripts/validate-agent.sh 6. Test triggering with real scenarios 7. Iterate if needed" ;
    oc:stepOrder 1 .

oc:kn_1317149e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the natural language description for agent generation" ;
    oc:directiveContent "Be specific in agent requests: include exact task, triggering preferences (proactive vs reactive), project context (frameworks, languages), and output expectations (format, file:line references, estimated impact). Vague requests produce generic agents." ;
    oc:hasRationale "Specificity in the request directly correlates with agent quality and triggering accuracy" .

oc:kn_5c1a7208 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When iterating on a generated agent that needs improvement" ;
    oc:directiveContent "Manual refinement steps: 1. Identify what's missing or wrong 2. Edit agent file directly focusing on better examples, more specific system prompt, clearer process steps, better output format 3. Re-validate 4. Test triggering again" ;
    oc:stepOrder 2 .

oc:kn_c4c245d6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After any agent generation or modification" ;
    oc:directiveContent "Always validate generated agents with scripts/validate-agent.sh and test triggering before considering the agent complete." ;
    oc:hasRationale "Generated agents may have structural issues or triggering gaps that only surface during validation and testing" ;
    oc:severityLevel "HIGH" .

oc:kn_d8b6fe00 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Final agent markdown file created at agents/[identifier].md" ;
    oc:directiveContent """---
name: {identifier}
description: {whenToUse}
model: inherit
color: {blue|cyan|green|yellow|magenta|red}
tools: ["Read", "Write", "Grep"]  # Optional
---

{systemPrompt}""" ;
    oc:templateVariables "color",
        "identifier",
        "systemPrompt",
        "tools",
        "whenToUse" .

