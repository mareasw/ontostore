oc:kn_118ab1b0 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When using AI-assisted agent generation" ;
    oc:directiveContent "AI-assisted generation returns JSON: {\"identifier\": \"agent-name\", \"whenToUse\": \"Use this agent when... <example>...</example>\", \"systemPrompt\": \"You are...\"}" ;
    oc:templateVariables "identifier",
        "systemPrompt",
        "whenToUse" .

oc:kn_264246b3 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any agent file" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
name: {agent-name}
description: Use this agent when {conditions}. Examples:

<example>
Context: {situation}
user: "{user message}"
assistant: "{response}"
<commentary>
{why trigger}
</commentary>
</example>

model: inherit
color: {color}
tools: ["{tool1}", "{tool2}"]
---

You are {role} specializing in {domain}.

**Your Core Responsibilities:**
1. {responsibility}

**Process:**
1. {step}

**Output Format:**
{format}""" ;
    oc:templateVariables "agent-name",
        "color",
        "conditions",
        "domain",
        "format",
        "response",
        "responsibility",
        "role",
        "situation",
        "step",
        "tool1",
        "tool2",
        "user message",
        "why trigger" .

oc:kn_34e4091f a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating an agent file" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "bash scripts/validate-agent.sh agents/{agent-name}.md" .

oc:kn_3c7431fe a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After agent file is created" ;
    oc:directiveContent "After creating an agent, run validate-agent.sh, test triggering with similar phrasings from examples, verify system prompt produces expected output format, and check edge cases." ;
    oc:hasRationale "End-to-end testing confirms the agent works autonomously without additional guidance" .

oc:kn_5bfb8ea5 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating an agent for a plugin" ;
    oc:directiveContent "1. Define agent purpose and triggering conditions 2. Choose creation method (AI-assisted or manual) 3. Create agents/{name}.md file 4. Write frontmatter with name, description (including 2-4 examples), model, color, tools 5. Write system prompt with responsibilities, process, output format, edge cases 6. Validate with scripts/validate-agent.sh 7. Test triggering with real scenarios 8. Document agent in plugin README" ;
    oc:stepOrder 1 .

oc:kn_5cec8860 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing agent system prompts" ;
    oc:directiveContent "Never write system prompts in first person ('I am...', 'I will...'). Always use second person ('You are...', 'You will...')." ;
    oc:hasRationale "Second person addresses the agent directly, ensuring it interprets instructions as its own behavioral directives" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8c82d964 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting agent creation" ;
    oc:directiveContent "Before creating an agent, verify the agents/ directory exists in the plugin, the agent purpose is clearly defined, and triggering conditions are distinct from existing agents." ;
    oc:hasRationale "Prevents duplicate agents and ensures organizational consistency" .

oc:kn_903f807c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing agent descriptions" ;
    oc:directiveContent "The description field is the most critical field — it must include 'Use this agent when...' triggering conditions plus 2-4 <example> blocks with Context, user, assistant, and <commentary> sub-elements." ;
    oc:hasRationale "Description controls when Claude triggers the agent; poor descriptions cause missed or incorrect triggering" ;
    oc:severityLevel "HIGH" .

oc:kn_92d3b0c2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing agent system prompts" ;
    oc:directiveContent "System prompts should be 500-3,000 characters with clear responsibilities, step-by-step process, output format, and edge cases. Never exceed 10,000 characters." ;
    oc:hasRationale "Prompts under 500 chars lack sufficient guidance; over 10,000 chars have diminishing returns and waste context window" ;
    oc:severityLevel "MEDIUM" .

oc:kn_aa6286e3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing an agent identifier" ;
    oc:directiveContent "Agent name must be 3-50 characters, lowercase letters/numbers/hyphens only, must start and end with alphanumeric. No underscores, spaces, or special characters." ;
    oc:hasRationale "Names are used for namespacing and invocation; invalid names break auto-discovery and routing" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b732fcd7 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When debugging agent triggering issues" ;
    oc:directiveContent "If agent doesn't trigger: check examples include relevant keywords, context matches usage scenarios, commentary explains triggering logic, assistant shows use of Agent tool. If agent triggers too often: make examples more specific and add negative examples." .

oc:kn_bb21a62d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When writing agent system prompts" ;
    oc:directiveContent "System prompt structure: 1. Role definition ('You are [role] specializing in [domain]') 2. Core Responsibilities (numbered list) 3. Process/Analysis steps (numbered with details) 4. Quality Standards (bullet list) 5. Output Format (template) 6. Edge Cases (situation → handling approach)" ;
    oc:stepOrder 3 .

oc:kn_be09f8f0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing agent color field" ;
    oc:directiveContent "Use distinct colors for different agents in the same plugin. Follow semantic color mapping: blue/cyan=analysis, green=creation, yellow=validation, red=security, magenta=creative." ;
    oc:hasRationale "Distinct colors enable users to visually identify which agent is running in the UI" ;
    oc:severityLevel "LOW" .

oc:kn_bf11da8b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "After creating or modifying an agent file" ;
    oc:directiveContent "Always validate agent files with scripts/validate-agent.sh before deploying, checking frontmatter structure, field formats, example blocks, and system prompt completeness." ;
    oc:hasRationale "Validation catches structural errors that would prevent auto-discovery or cause runtime failures" ;
    oc:severityLevel "HIGH" .

oc:kn_c5079a75 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any agent file" ;
    oc:directiveContent "Required frontmatter fields are: name, description, model, color. Only 'tools' is optional." ;
    oc:hasRationale "Missing required fields cause agent to fail validation and not be auto-discovered" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ddc084bd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring agent tools" ;
    oc:directiveContent "Apply principle of least privilege to the tools field — only grant the minimum tools needed (e.g., read-only agents get ['Read', 'Grep', 'Glob'])." ;
    oc:hasRationale "Over-provisioned agents can cause unintended side effects; restricted tools prevent accidental file deletion or modification" ;
    oc:severityLevel "HIGH" .

oc:kn_e29f4271 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When using AI-assisted agent generation" ;
    oc:directiveContent "AI-assisted method: 1. Describe agent need with specific requirements 2. Send generation prompt to Claude 3. Receive JSON with identifier, whenToUse, systemPrompt 4. Convert JSON to agent markdown file with frontmatter 5. Validate and test" ;
    oc:stepOrder 2 .

oc:kn_e717e093 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before creating agents" ;
    oc:directiveContent "Plugin must have an agents/ directory for auto-discovery of .md agent files" .

