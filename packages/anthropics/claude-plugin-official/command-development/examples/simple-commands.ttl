oc:kn_1d29c615 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When commands accept user input" ;
    oc:directiveContent "Always include argument-hint in frontmatter when a command accepts arguments. Use $1, $2 for positional args, $ARGUMENTS for free-form text, @$1 for file references." ;
    oc:hasRationale "Argument hints document expected input and enable proper argument interpolation in the command body" .

oc:kn_276898ef a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any new slash command" ;
    oc:directiveContent "1. Define single responsibility and descriptive command name 2. Create .claude/commands/<name>.md 3. Add frontmatter (description required; allowed-tools, argument-hint, model optional) 4. Write agent instructions with structured analysis sections 5. Test with /<command-name> 6. Add argument handling if needed 7. Document usage examples" ;
    oc:hasRationale "Progressive refinement from minimal to full-featured ensures each addition is validated" ;
    oc:stepOrder 1 .

oc:kn_2db437d9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when writing command body text" ;
    oc:directiveContent "Commands are instructions FOR Claude (agent consumption), not messages TO users. Write directives telling the agent what to analyze, check, or produce." ;
    oc:hasRationale "The agent interprets and executes the command; user-facing output is generated by the agent, not hardcoded in the command" ;
    oc:severityLevel "CRITICAL" .

oc:kn_860b7cd9 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any slash command file" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
description: [what command does]
allowed-tools: Read, Bash(git:*)
argument-hint: [target]
model: sonnet
---

[Instructions for Claude]""" ;
    oc:hasRationale "Frontmatter controls tool access, model selection, and argument handling; body contains agent instructions" .

oc:kn_961b76ae a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing new commands" ;
    oc:directiveContent "Start with single-responsibility commands — one clear purpose per command file. Add complexity gradually: begin without frontmatter, then add allowed-tools, argument-hint, and model as needed." ;
    oc:hasRationale "Incremental complexity prevents over-engineering and makes debugging easier" ;
    oc:severityLevel "MEDIUM" .

oc:kn_96f90f44 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When embedding live command output or file references in command body" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """!`git status`
!`npm test $1`
@$1""" ;
    oc:hasRationale "Backtick-wrapped commands with ! prefix execute live; @ prefix reads file content as context" .

oc:kn_b9669e3e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting model tier for a command" ;
    oc:directiveContent "Use model: haiku for simple repetitive tasks (quick fixes), model: sonnet for analysis/research tasks requiring deeper reasoning." ;
    oc:hasRationale "Matching model capability to task complexity optimizes cost and response quality" .

oc:kn_bb198bda a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining command security scope" ;
    oc:directiveContent "Use allowed-tools to restrict command permissions: Read+Grep for read-only analysis, Bash(git:*) for git operations, Bash(npm:*) for test execution." ;
    oc:hasRationale "Least-privilege tool access prevents unintended modifications and ensures safe execution" ;
    oc:severityLevel "HIGH" .

