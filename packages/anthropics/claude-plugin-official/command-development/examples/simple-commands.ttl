    oc:contentHash "f2533ed834305166603bcb4dd870d695af4a33b9a49d330937a4c70ed964767c" ;
    oc:differentia "that provides 10 ready-to-use basic slash command templates covering code review, security review, testing, documentation, git status, deployment, file comparison, quick fixes, research, and code explanation for Claude Code" ;
