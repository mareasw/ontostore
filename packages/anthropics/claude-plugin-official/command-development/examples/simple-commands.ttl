    oc:yieldsState oc:DocumentCreated .

oc:kn_354add0a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any slash command prompt body" ;
    oc:directiveContent "Commands must be written as instructions FOR Claude (agent consumption), not messages TO users. The command content becomes Claude's instructions when invoked." ;
    oc:hasRationale "Commands that describe what will happen to the user instead of instructing Claude fail to produce the desired behavior, because Claude treats the text as its own instructions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3e2276ff a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating commands that accept user input" ;
    oc:directiveContent "Always include argument-hint in frontmatter and use $1, $2 for positional arguments or $ARGUMENTS for the full argument string. Validate arguments within the command prompt." ;
    oc:hasRationale "argument-hint provides autocomplete guidance and documentation. Proper argument handling prevents runtime errors and confusing behavior." ;
    oc:severityLevel "HIGH" .

oc:kn_d3fb23c8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring the allowed-tools frontmatter field" ;
    oc:directiveContent "Use the most restrictive allowed-tools possible. For read-only analysis use 'Read, Grep'; for git operations use 'Bash(git:*)'; avoid 'Bash(*)' unless truly necessary." ;
    oc:hasRationale "Restrictive tool permissions follow the principle of least privilege, preventing unintended side effects like accidental file modifications during read-only reviews." ;
    oc:severityLevel "HIGH" .

oc:kn_ea042558 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming and designing new slash commands" ;
    oc:directiveContent "Use the verb-noun naming pattern for command files (e.g., review.md, security-review.md, test-file.md) and start with a single responsibility before adding complexity." ;
    oc:hasRationale "Descriptive names improve discoverability in /help and single-responsibility commands are easier to test, maintain, and compose." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f878de8c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting the model frontmatter field for a command" ;
    oc:directiveContent "Choose the appropriate model via frontmatter: haiku for fast simple tasks (quick fixes), sonnet for standard workflows (security review, research), opus for complex analysis." ;
    oc:hasRationale "Model selection balances speed and capability. Over-provisioning wastes resources; under-provisioning produces poor results for complex tasks." .

