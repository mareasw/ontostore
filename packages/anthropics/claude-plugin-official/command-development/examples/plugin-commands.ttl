@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_command_development_plugin_commands a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "plugin-commands" ;
    skos:broader "Pattern catalog" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/command-development" ;
    oc:contentHash "7d71d7b516020a6c171171399b40dd2cad02b842c9faa78b90e0983906c9ee94" ;
    oc:differentia "that provides practical examples of Claude Code plugin commands demonstrating plugin-specific features like CLAUDE_PLUGIN_ROOT, multi-script workflows, agent/skill integration, input validation, and environment-aware execution" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_command_development ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_0477260c,
        oc:kn_7e1d6586,
        oc:kn_ade6c9dc,
        oc:kn_c9a740ab,
        oc:kn_d7897e70 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "build environment-aware plugin commands",
        "create plugin commands with scripts and templates",
        "design multi-step plugin command workflows",
        "integrate plugin agents and skills into commands",
        "validate inputs in plugin commands" .

oc:kn_0477260c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding bash execution syntax to any plugin command" ;
    oc:directiveContent "Commands using bash execution (!`...`) must include the required tool in the allowed-tools frontmatter field (e.g., 'Bash(*)', 'Bash(node:*)', 'Bash(git:*)') or execution will fail." ;
    oc:hasRationale "Claude Code enforces tool access restrictions; without explicit allowed-tools declaration, the bash execution block will be denied permission." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7e1d6586 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any plugin command that references files within the plugin directory" ;
    oc:directiveContent "Never use relative paths like ./scripts/analyze.js in plugin commands; always use ${CLAUDE_PLUGIN_ROOT}/scripts/analyze.js for portable paths that work across installations." ;
    oc:hasRationale "Relative paths resolve from the current working directory, not the plugin directory, causing failures when commands are invoked from different project locations." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ade6c9dc a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When creating complex plugin commands that need multiple analysis dimensions" ;
    oc:directiveContent "Use a multi-phase approach combining scripts (for automated analysis), agents (for deep review), skills (for standards compliance), and templates (for structured reporting) to build comprehensive plugin command workflows." ;
    oc:hasRationale "Each plugin component type has distinct strengths: scripts for deterministic execution, agents for multi-step reasoning, skills for domain knowledge, and templates for consistent output formatting." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c9a740ab a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building commands that operate across multiple environments with different risk profiles" ;
    oc:directiveContent "Use environment-aware command patterns that adapt behavior, validation strictness, and script execution based on the target environment (e.g., full checks for prod, basic for dev)." ;
    oc:hasRationale "Production environments demand stricter validation and more comprehensive checks than development, and commands should encode this differentiation to prevent both false failures and missed issues." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d7897e70 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing plugin commands that accept arguments, especially for deployment or build commands" ;
    oc:directiveContent "Validate all user inputs early in the command using grep/test patterns before executing any side-effecting operations, and provide helpful error messages with expected values and corrective actions on failure." ;
    oc:hasRationale "Early validation prevents destructive or confusing operations on invalid inputs and provides actionable guidance to the user." ;
    oc:severityLevel "HIGH" .

