oc:kn_0c70e256 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When commands depend on plugin files (configs, scripts, templates)" ;
    oc:directiveContent "Check that required plugin resources exist before using them: `test -f ${CLAUDE_PLUGIN_ROOT}/path/file && echo \"YES\" || echo \"NO\"`. This provides graceful failure messages instead of cryptic errors." ;
    oc:hasRationale "Missing resources cause confusing bash errors; explicit checks enable helpful error messages and troubleshooting steps" ;
    oc:severityLevel "MEDIUM" .

oc:kn_2adc0923 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building multi-component commands that combine scripts, agents, and skills" ;
    oc:directiveContent "Complex commands should follow a phased approach: Phase 1 automated analysis (scripts), Phase 2 deep review (agent), Phase 3 standards check (skill), Phase 4 template-based reporting, Phase 5 prioritized recommendations." ;
    oc:hasRationale "Phased decomposition makes commands debuggable, testable, and produces structured output" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3ec5b5d8 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When command input validation or resource checks fail" ;
    oc:directiveContent "When validations fail in a command, explain which validation failed, provide expected values/locations, suggest corrective actions, and document troubleshooting steps." ;
    oc:hasRationale "Actionable error messages reduce user frustration and support overhead" ;
    oc:severityLevel "MEDIUM" .

oc:kn_42888c49 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When referencing any plugin resource (scripts, configs, templates)" ;
    oc:directiveContent "Never use relative paths like ./scripts/analyze.js in plugin commands. Always use ${CLAUDE_PLUGIN_ROOT} for portable paths that work across installations." ;
    oc:hasRationale "Relative paths break when the working directory changes or the plugin is installed in a different location" ;
    oc:severityLevel "CRITICAL" .

oc:kn_bad5f85e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring any plugin command" ;
    oc:directiveContent "Use argument-hint in frontmatter to document expected arguments (e.g., '[file-path]', '[environment]', '[version]'). Use description to explain what the command does." ;
    oc:hasRationale "Clear hints and descriptions make commands discoverable and self-documenting for users" ;
    oc:severityLevel "LOW" .

oc:kn_e3088124 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When commands execute multiple scripts or long-running workflows" ;
    oc:directiveContent "Use 'model: sonnet' in frontmatter for commands that run multiple heavy scripts or need faster execution. Default model may be slower for complex multi-step workflows." ;
    oc:hasRationale "Sonnet is faster for tool-heavy workflows where deep reasoning is less critical" ;
    oc:severityLevel "LOW" .

oc:kn_f1ac1f9c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When commands accept user arguments that control behavior (environment names, file paths, versions)" ;
    oc:directiveContent "Always validate command inputs before executing destructive or deployment operations. Use grep patterns like `echo \"$1\" | grep -E \"^(dev|staging|prod)$\"` to validate arguments." ;
    oc:hasRationale "Invalid inputs can trigger unintended deployments or operations with significant consequences" ;
    oc:severityLevel "HIGH" .

oc:kn_fb7adef0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing command frontmatter for any command that runs scripts" ;
    oc:directiveContent "Every command that executes scripts via !`...` must declare allowed-tools in frontmatter (e.g., 'Bash(*)', 'Bash(node:*)', 'Read'). Scripts will fail silently without proper tool permissions." ;
    oc:hasRationale "Claude Code enforces tool permissions — undeclared tools are blocked at runtime" ;
    oc:severityLevel "CRITICAL" .

