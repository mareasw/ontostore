_:ref_170b33a4c9cb2afa a oc:Template ;
    oc:blockType "template" ;
    oc:contentOrder 1 ;
    oc:templateContent """# Missing allowed-tools
!`bash script.sh`  # Will fail without Bash permission

# Correct
---
allowed-tools: Bash(*)
---
!`bash ${CLAUDE_PLUGIN_ROOT}/scripts/script.sh`
""" ;
    oc:templateVariables "CLAUDE_PLUGIN_ROOT" .

