oc:kn_1348e2a0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing the initial user experience for an unknown user" ;
    oc:directiveContent "Provide a first-run welcome experience explaining what the command does, quick start examples, and setup requirements. Use progressive disclosure for advanced features." ;
    oc:hasRationale "First impressions determine adoption; unknown users need context that personal-use commands don't require" ;
    oc:severityLevel "MEDIUM" .

oc:kn_209d457f a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When adding usage analytics or telemetry to marketplace commands" ;
    oc:directiveContent "Track only aggregate analytics (common arguments, failure rates, execution time). Never collect PII. Respect user opt-out." ;
    oc:hasRationale "Privacy violations destroy trust and may violate regulations; marketplace commands must be privacy-preserving by default" ;
    oc:severityLevel "HIGH" .

oc:kn_2caa1571 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any shell command that interacts with system utilities (clipboard, paths, device files)" ;
    oc:directiveContent "Never use platform-specific commands without fallback detection. Always check tool availability with `command -v` and provide alternatives for each platform." ;
    oc:hasRationale "Hardcoded platform-specific commands break for users on other OSes and produce confusing errors" ;
    oc:severityLevel "CRITICAL" .

oc:kn_2ec62b83 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When formatting branded command output" ;
    oc:directiveContent """## {Command Name}
Part of the {Plugin Name} suite

{Results}

---
**Need Help?**
- Documentation: {docs_url}
- Support: {support_email}
- Community: {community_url}

Powered by {Plugin Name} v{version}""" ;
    oc:templateVariables "Command Name",
        "Plugin Name",
        "Results",
        "community_url",
        "docs_url",
        "support_email",
        "version" .

oc:kn_2f52d9dd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming a command for distribution" ;
    oc:directiveContent "Namespace commands with a plugin prefix to avoid collisions. Choose names balancing discoverability, brevity, and uniqueness. Document naming rationale." ;
    oc:hasRationale "Generic names conflict with other plugins; clear ownership aids discovery and prevents user confusion" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3b82e144 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When preparing a command for marketplace publication" ;
    oc:directiveContent "Before release, verify: cross-platform functionality (macOS, Linux, Windows/WSL), all arguments tested, error cases handled, no hardcoded paths, dependencies documented, version set, changelog updated." ;
    oc:hasRationale "The pre-release checklist catches common distribution failures before they reach users" ;
    oc:severityLevel "HIGH" .

oc:kn_448628bb a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing dependency checking in commands" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """for tool in git jq node; do
  if ! command -v $tool > /dev/null; then
    MISSING_DEPS="$MISSING_DEPS $tool"
  fi
done
if [ -n "$MISSING_DEPS" ]; then
  echo "Missing: $MISSING_DEPS"
  exit 1
fi""" .

oc:kn_4bd4469f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any command intended for marketplace distribution" ;
    oc:directiveContent "Commands must be universal, self-contained, graceful, forgiving, and helpful — work across platforms, minimize dependencies, degrade gracefully, handle user mistakes, and provide clear documentation." ;
    oc:hasRationale "Unknown users will run commands in unpredictable environments; robustness and UX determine marketplace success" ;
    oc:severityLevel "HIGH" .

oc:kn_615fd834 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a command relies on external tools (git, jq, node, gh, docker, etc.)" ;
    oc:directiveContent "All required and optional dependencies must be documented in a DEPENDENCIES comment block, and checked at runtime with informative install URLs." ;
    oc:hasRationale "Users need to know what to install; runtime checks prevent cryptic failures" ;
    oc:severityLevel "HIGH" .

oc:kn_6516084c a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing commands that modify state or perform one-time setup" ;
    oc:directiveContent "Commands should be safe to run multiple times by using completion markers (flag files) and checking for prior execution before proceeding." ;
    oc:hasRationale "Idempotent commands prevent duplicate side effects and are safe to retry on failure" ;
    oc:severityLevel "MEDIUM" .

oc:kn_65392e00 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing atomic file operations" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """TEMP_DIR=$(mktemp -d)
[Make changes in $TEMP_DIR]
if [ $? -eq 0 ]; then
  mv $TEMP_DIR/* ./target/
else
  rm -rf $TEMP_DIR
fi""" .

oc:kn_6b0082a2 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building a marketplace-ready command" ;
    oc:directiveContent "1. Detect platform with uname and adjust behavior. 2. Check dependencies with command -v. 3. Load user config from .claude/plugin-name.local.md with sensible defaults. 4. Detect available features and degrade gracefully. 5. Execute atomically with rollback capability." ;
    oc:hasRationale "This sequence ensures robust cross-platform execution for unknown users" ;
    oc:stepOrder 1 .

oc:kn_bbc72752 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a command modifies files or performs multi-step transformations" ;
    oc:directiveContent "Use atomic operations: perform changes in a temp directory, validate, then apply atomically via mv. Roll back by removing the temp dir on failure." ;
    oc:hasRationale "Atomic operations ensure no partial state is left behind on failure, making retry safe" ;
    oc:severityLevel "HIGH" .

oc:kn_cafb8173 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When optimizing a command for marketplace discovery and adoption" ;
    oc:directiveContent "1. Use descriptive names and searchable KEYWORDS in comments. 2. Include compelling demo examples with sample output. 3. Provide a feedback mechanism (emoji ratings, /command feedback). 4. Show consistent branding with help/support links. 5. Maintain semver versioning with migration guides for breaking changes." ;
    oc:hasRationale "Marketplace success depends on discoverability, professional presentation, and user trust" ;
    oc:stepOrder 2 .

