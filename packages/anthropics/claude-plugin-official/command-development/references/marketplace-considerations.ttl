@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_command_development_marketplace_considerations a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "marketplace-considerations" ;
    skos:broader "distribution quality guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/command-development" ;
    oc:contentHash "ab30835431d06a8e65cd629ba0e73b3f1de5b043126c6fef7ea70163400e90f4" ;
    oc:differentia "provides marketplace-specific best practices for cross-platform compatibility, user experience, error handling, configurability, version management, and presentation of commands intended for public distribution" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_command_development ;
    oc:handlesFailure oc:MissingDependencies,
        oc:PlatformIncompatibility ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_d40a47f7 ;
    oc:impartsKnowledge oc:kn_5487efd7,
        oc:kn_61af972a,
        oc:kn_6f9d73dc,
        oc:kn_9233e18f,
        oc:kn_9ea7cd2d,
        oc:kn_c55b4a3a ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:CommandCreated ;
    oc:resolvesIntent "create professional command user experience",
        "design graceful degradation for commands",
        "ensure command cross-platform compatibility",
        "handle command versioning and deprecation",
        "prepare command for marketplace distribution" ;
    oc:yieldsState oc:MarketplaceReady .

oc:kn_5487efd7 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When packaging commands for marketplace release" ;
    oc:directiveContent "Namespace commands with plugin prefix, provide smart defaults with override capability, implement idempotent operations with completion markers, and use semver for version compatibility checking." ;
    oc:hasRationale "Namespacing prevents collision, smart defaults reduce friction, idempotency prevents duplicate side effects, and semver ensures upgrade safety." ;
    oc:severityLevel "MEDIUM" .

oc:kn_61af972a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring any command intended for public distribution" ;
    oc:directiveContent "Commands for distribution must detect platform at runtime (macOS, Linux, Windows/WSL) and adapt behavior accordingly, never assuming a specific OS." ;
    oc:hasRationale "Unknown users run commands on diverse platforms; hardcoded platform-specific commands break silently for a significant portion of users." ;
    oc:severityLevel "HIGH" .

oc:kn_6f9d73dc a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before executing any command that depends on external CLI tools" ;
    oc:directiveContent "All required dependencies must be checked at command startup using `command -v` and missing tools reported with installation URLs before any execution proceeds." ;
    oc:hasRationale "Users will encounter cryptic errors without dependency checking; proactive validation with helpful install instructions prevents frustration." ;
    oc:severityLevel "HIGH" .

oc:kn_9233e18f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before publishing or updating a command in the marketplace" ;
    oc:directiveContent "Run the pre-release checklist covering platform testing (macOS/Linux/Windows), argument validation, error handling, documentation completeness, dependency documentation, and security review before submitting to marketplace." ;
    oc:hasRationale "Distributed commands face diverse environments and unknown users; the checklist catches issues that would generate negative reviews and support burden." ;
    oc:severityLevel "HIGH" .

oc:kn_9ea7cd2d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When commands have optional features depending on tools like gh, docker, or xclip" ;
    oc:directiveContent "Implement graceful degradation: detect available optional tools at runtime and reduce functionality rather than fail when optional dependencies are missing." ;
    oc:hasRationale "Feature detection allows commands to provide value in constrained environments while advertising full capabilities when tools are available." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c55b4a3a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing bash execution blocks or inline commands for distributed commands" ;
    oc:directiveContent "Never use hardcoded file paths, platform-specific clipboard commands (pbcopy/xclip), or assume specific tool versions without checking." ;
    oc:hasRationale "Hardcoded paths and platform-specific commands cause silent failures across environments and undermine marketplace trust." ;
    oc:severityLevel "CRITICAL" .

oc:req_d40a47f7 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "command-development fundamentals" .

