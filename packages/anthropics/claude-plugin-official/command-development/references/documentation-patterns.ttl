@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_command_development_documentation_patterns a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "documentation-patterns" ;
    skos:broader "documentation strategy" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/command-development" ;
    oc:contentHash "70c6c9b0a9b2d46a925ada6c45808a73498a457e1d641c82cc05de8a29a33b05" ;
    oc:differentia "provides patterns and templates for creating self-documenting, maintainable slash commands with embedded help text, error messages, usage examples, and maintenance metadata" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_command_development ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "command-name" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_026a97e5,
        oc:kn_0ab8029a,
        oc:kn_1ee3a197,
        oc:kn_4dbcd65a,
        oc:kn_59a1d3f4,
        oc:kn_e62789a7,
        oc:kn_fbf11db0 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create self-documenting commands",
        "design error messages with recovery guidance",
        "maintain command documentation and changelogs",
        "structure command README files",
        "write command help text and usage examples" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_026a97e5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing multi-step or interactive command logic" ;
    oc:directiveContent "Use inline HTML comments to annotate sections, decision points, and implementation rationale within the command body. Mark decision points where user confirmation is required." ;
    oc:hasRationale "Inline comments preserve institutional knowledge about why decisions were made, aiding future maintainers and enabling safer modifications." ;
    oc:severityLevel "MEDIUM" .

oc:kn_0ab8029a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When updating or versioning existing commands" ;
    oc:directiveContent "Maintain a VERSION header and CHANGELOG in command comments. Include migration notes for breaking changes and deprecation warnings with removal timelines." ;
    oc:hasRationale "Version tracking prevents confusion about command behavior; migration notes and deprecation warnings give users time to adapt before breaking changes." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1ee3a197 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling command validation failures or runtime errors" ;
    oc:directiveContent "Never display bare error messages without context. Always include what happened, what it means, common causes, suggestions, and recovery steps." ;
    oc:hasRationale "Bare errors like 'File not found' leave users stranded; structured error messages with recovery guidance enable self-service troubleshooting." ;
    oc:severityLevel "HIGH" .

oc:kn_4dbcd65a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring any command documentation section" ;
    oc:directiveContent "Show examples before explanations. Use example-driven documentation that demonstrates input/output pairs before describing abstract behavior." ;
    oc:hasRationale "Users learn faster from concrete examples than abstract descriptions; examples-first follows progressive disclosure principles." ;
    oc:severityLevel "MEDIUM" .

oc:kn_59a1d3f4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building commands with subcommands or multiple operations" ;
    oc:directiveContent "Always include a help subcommand (help/--help/-h) for complex commands, and provide contextual help when arguments are missing rather than failing silently." ;
    oc:hasRationale "Graceful fallback to help text when arguments are missing or help is requested makes commands discoverable without external documentation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e62789a7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing command frontmatter" ;
    oc:directiveContent "Keep the frontmatter description under 60 characters, clear, and actionable. Include argument-hint and allowed-tools fields." ;
    oc:hasRationale "Concise descriptions improve discoverability in command lists and autocomplete; argument-hint guides correct invocation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fbf11db0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring any slash command" ;
    oc:directiveContent "Embed documentation directly in the command file using HTML comment blocks (PURPOSE, USAGE, ARGUMENTS, EXAMPLES, REQUIREMENTS, RELATED COMMANDS, TROUBLESHOOTING, CHANGELOG) so it travels with the code and stays synchronized." ;
    oc:hasRationale "Embedded documentation is always accessible to users and maintainers without looking up external files, reducing doc-code drift." ;
    oc:severityLevel "HIGH" .

