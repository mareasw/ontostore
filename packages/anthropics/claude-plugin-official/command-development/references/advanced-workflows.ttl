oc:kn_1c6f99bb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing command composition patterns" ;
    oc:directiveContent "Each command should have single responsibility and be composable — commands do one thing well and can be orchestrated together by meta-commands." ;
    oc:hasRationale "Single-responsibility commands are testable, reusable, and can be combined into complex workflows without tight coupling" ;
    oc:severityLevel "HIGH" .

oc:kn_2676b10a a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing command chaining / meta-command pattern" ;
    oc:directiveContent "1. Format code (/format-code) → 2. Run linter (/lint-code) → 3. Run tests (/test-all) → 4. Generate coverage (/coverage-report) → 5. Create review summary (/review-summary)" ;
    oc:stepOrder 2 .

oc:kn_4a84e9b9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When commands accept user arguments" ;
    oc:directiveContent "Use argument defaults with ${1:-default_value} syntax and validate inputs against allowed values before proceeding with workflow execution." ;
    oc:hasRationale "Defaults improve usability while validation prevents invalid states from propagating through the workflow" ;
    oc:severityLevel "MEDIUM" .

oc:kn_54675995 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When workflows modify shared state or external resources" ;
    oc:directiveContent "Never allow concurrent workflow execution without locking — use a .lock file (e.g., .claude/deployment.lock) to prevent parallel runs of the same workflow." ;
    oc:hasRationale "Concurrent execution can corrupt state, cause conflicting deployments, or produce inconsistent results" ;
    oc:severityLevel "CRITICAL" .

oc:kn_6ac291c6 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing pipeline pattern for test failure analysis" ;
    oc:directiveContent "1. Get test results → 2. Categorize failures (flaky/consistent/new) → 3. Prioritize by impact, frequency, effort → 4. Generate fix plan with root cause, approach, estimate" ;
    oc:stepOrder 3 .

oc:kn_6b97be47 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating workflow state files" ;
    oc:directiveContent """---
workflow: {workflow_name}
stage: {current_stage}
started: {timestamp}
environment: {env}
branch: {branch}
commit: {commit_hash}
---
# {Workflow Name} State
Current stage: {stage}
Completed steps:
- ✅ {completed_step}
Pending steps:
- {pending_step}""" ;
    oc:templateVariables "branch",
        "commit_hash",
        "completed_step",
        "current_stage",
        "env",
        "pending_step",
        "stage",
        "timestamp",
        "workflow_name" .

oc:kn_9a1a57a1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing state between command steps" ;
    oc:directiveContent "Store workflow state in .local.md files (e.g., .claude/plugin-name-workflow.local.md) with YAML frontmatter to ensure state persists across command invocations." ;
    oc:hasRationale ".local.md files are the Claude Code convention for plugin-local state that persists between invocations without polluting version control" ;
    oc:severityLevel "HIGH" .

oc:kn_a1796350 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building a complete multi-stage workflow" ;
    oc:directiveContent "1. Create state file with initialized stage → 2. Run validation checks → 3. Execute main operation → 4. Update state to completed → 5. Clean up state/lock files" ;
    oc:hasRationale "This ordered sequence ensures proper lifecycle management from initialization through cleanup" ;
    oc:stepOrder 1 .

oc:kn_af1853b1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing multi-step workflows" ;
    oc:directiveContent "Use numbered steps, show current position, display completed and pending steps to give users clear visibility into workflow progress." ;
    oc:hasRationale "Clear progression indicators prevent user confusion and enable resumption after interruption" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c24caaaa a oc:KnowledgeNode,
        oc:RollbackProcedure ;
    oc:appliesToContext "When workflows perform destructive or hard-to-reverse operations" ;
    oc:directiveContent "Save current state (e.g., previous version) before making changes, and implement automatic rollback on failure by executing a rollback script or restoring from saved state." ;
    oc:hasRationale "Automatic rollback ensures systems return to a known-good state when deployment or migration steps fail" ;
    oc:severityLevel "CRITICAL" .

oc:kn_cc6264cc a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When initializing any multi-step workflow" ;
    oc:directiveContent "Before starting a workflow, check for: existing lock files, incomplete prior runs, branch status, and environment validity." ;
    oc:hasRationale "Pre-flight checks prevent conflicts with in-progress workflows and catch environment issues before they cause mid-execution failures" ;
    oc:severityLevel "HIGH" .

oc:kn_d60a3471 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a multi-stage workflow fails mid-execution" ;
    oc:directiveContent "Implement checkpoint recovery by logging completed stages to a checkpoint file, allowing workflows to resume from the last successful step via a dedicated resume command." ;
    oc:hasRationale "Checkpoint-based recovery avoids restarting entire workflows from scratch, saving time and reducing repeated side effects" ;
    oc:severityLevel "HIGH" .

oc:kn_d75d95ba a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating a command with conditional branching" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
description: Deploy to validated environment
argument-hint: [environment]
allowed-tools: Bash(git:*), Bash(npm:*), Read
---
# Deploy to $1
Branch: !`git branch --show-current`
Status: !`git status --short`
[Conditional steps based on environment]""" .

oc:kn_e7f94622 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing workflow locking" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
description: Start deployment
allowed-tools: Read, Write, Bash
---
# Start Deployment
if [ -f .claude/deployment.lock ]; then
  ERROR: Deployment already in progress
  Exit.
fi
Creating deployment lock...""" .

oc:kn_eb1496b9 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing rollback-safe operations" ;
    oc:directiveContent "1. Save current state for rollback → 2. Execute operation → 3. On failure: auto-rollback to saved state → 4. On success: update state and clean up" ;
    oc:stepOrder 4 .

oc:kn_ef29b1b9 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining workflow state file format" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
