@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_claude_plugin_official_command_development_interactive_commands a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "interactive-commands" ;
    skos:broader "Interactive command pattern guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/command-development" ;
    oc:contentHash "09ab1f18bfa3ff5f7088e45d5810ac20eb25ffc97fc9e8bb79416d40e0b4516b" ;
    oc:dependsOnSkill oc:skill_command_development ;
    oc:differentia "uses the AskUserQuestion tool to create commands that gather user feedback, present multi-choice decisions, and build adaptive multi-stage workflows within Claude Code plugins" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_command_development ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasAllowedTool "AskUserQuestion",
        "Bash",
        "Read",
        "Write" ;
    oc:hasArgumentHint "[project-name]" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_12972d16,
        oc:kn_2712c795,
        oc:kn_2dedd7a9,
        oc:kn_4566a131,
        oc:kn_5d6d121d,
        oc:kn_a78a9792,
        oc:kn_c57a96c9,
        oc:kn_e98a85ee ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build multi-stage interactive workflow",
        "create interactive command",
        "design user prompts with AskUserQuestion",
        "gather user feedback in commands",
        "implement conditional question flows" ;
    oc:yieldsState oc:InteractiveCommandCreated .

oc:kn_12972d16 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring multiSelect on AskUserQuestion options" ;
    oc:directiveContent "Do not use multiSelect=true for mutually exclusive choices (e.g., selecting a database engine or auth method). Only use it when any combination of selections is valid." ;
    oc:hasRationale "MultiSelect on exclusive choices produces invalid configurations that must be rejected, wasting the user's time." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2712c795 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing multi-stage interactive command flows" ;
    oc:directiveContent "Structure interactive commands as progressive stages: start simple (quick/custom/guided), branch conditionally based on earlier answers, validate before executing, and always offer a confirmation step." ;
    oc:hasRationale "Progressive disclosure reduces cognitive load, conditional branching avoids irrelevant questions, and confirmation prevents costly mistakes." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2dedd7a9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between interactive prompts vs command arguments" ;
    oc:directiveContent "Use AskUserQuestion for complex multi-choice decisions, preference gathering, multi-select scenarios, and conditional workflows. Use plain command arguments for simple values like file paths, numbers, or names." ;
    oc:hasRationale "Arguments enable scriptable, fast invocations; AskUserQuestion enables rich, guided decision-making. Choosing the wrong mechanism frustrates users." ;
    oc:severityLevel "HIGH" .

oc:kn_4566a131 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When configuration validation detects errors in an interactive flow" ;
    oc:directiveContent "When validation fails mid-flow, offer three recovery options via AskUserQuestion: Fix (adjust settings), Override (proceed with warnings), or Cancel (abort cleanly)." ;
    oc:hasRationale "Giving users control over error recovery builds trust and avoids dead ends in the workflow." ;
    oc:severityLevel "LOW" .

oc:kn_5d6d121d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating any command that uses AskUserQuestion" ;
    oc:directiveContent "Include AskUserQuestion in the command's allowed-tools frontmatter, or the interactive prompts will not appear at all." ;
    oc:hasRationale "Without the tool declaration, the agent cannot invoke AskUserQuestion and the interactive flow silently fails." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a78a9792 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing AskUserQuestion prompts" ;
    oc:directiveContent "Limit questions to 2-4 options per question and 1-4 questions per AskUserQuestion call. Keep headers to max 12 characters." ;
    oc:hasRationale "Exceeding these limits overwhelms the user and degrades the decision-making experience; the UI is optimized for small, focused choice sets." ;
    oc:severityLevel "HIGH" .

oc:kn_c57a96c9 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When handling AskUserQuestion response failures" ;
    oc:directiveContent "If AskUserQuestion responses come back empty or invalid, show the user an alternative manual approach rather than silently failing or looping infinitely." ;
    oc:hasRationale "Interactive prompts can fail due to UI issues or user cancellation; a fallback path ensures the command still delivers value." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e98a85ee a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any AskUserQuestion prompt" ;
    oc:directiveContent "Write question text that stands alone with full context, option labels that are 1-5 specific words, and descriptions that explain trade-offs in 1-2 sentences." ;
    oc:hasRationale "Vague questions ('Database?') and undescriptive options ('Option 1') force users to guess, leading to poor decisions and rework." ;
    oc:severityLevel "MEDIUM" .

