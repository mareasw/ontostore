oc:kn_236a3e83 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before releasing any command" ;
    oc:directiveContent "Never deploy a command without testing edge cases: empty arguments, special characters, long inputs, non-existent file references, and disallowed bash commands" ;
    oc:hasRationale "Happy-path-only testing misses the failures users will encounter in real usage" ;
    oc:severityLevel "HIGH" .

oc:kn_5c1092f9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building a testing strategy for commands" ;
    oc:directiveContent "Automate what you can (structure validation, frontmatter checks) with scripts; manually test what requires judgment (UX, output quality, error messages)" ;
    oc:hasRationale "Automation catches syntax issues reliably; UX quality requires human judgment" .

oc:kn_6d0cf2d4 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When testing commands with Bash execution" ;
    oc:directiveContent "Test that commands with allowed-tools restrictions properly block disallowed bash execution. Commands using !` syntax should only execute permitted tools" ;
    oc:hasRationale "allowed-tools bypass could lead to arbitrary command execution" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7a4d179a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When setting up continuous testing for a team" ;
    oc:directiveContent "Use pre-commit hooks to validate commands before they enter the repo, and run full test suites in CI/CD on every push or PR" ;
    oc:hasRationale "Pre-commit catches issues locally before they waste CI time; CI ensures nothing slips through" .

oc:kn_9817fc7c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating command frontmatter" ;
    oc:directiveContent "YAML frontmatter must have exactly 2 '---' markers, model field values must be sonnet/opus/haiku, and description should be under 60 characters" ;
    oc:hasRationale "Invalid frontmatter causes silent failures or unexpected behavior in Claude Code" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c8c80b0e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When testing any slash command before deployment" ;
    oc:directiveContent "1. Validate syntax/structure (YAML, .md extension, file location) → 2. Validate frontmatter fields (model, allowed-tools, description) → 3. Manual invocation (appears in /help, executes, output correct) → 4. Argument testing (positional, $ARGUMENTS, missing/invalid args) → 5. File reference testing (@ syntax, missing files, large files) → 6. Bash execution testing (!` commands, allowed-tools enforcement) → 7. Integration testing (hooks, command sequences, MCP)" ;
    oc:hasRationale "Progressive testing from simple to complex catches issues at the cheapest level first" ;
    oc:stepOrder 1 .

oc:kn_f1df5591 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before invoking any test suite" ;
    oc:directiveContent "Verify command file exists at .claude/commands/<name>.md, has valid YAML frontmatter (2 markers), non-empty content, and .md extension" ;
    oc:hasRationale "Structural issues prevent the command from being recognized by Claude Code at all" .

