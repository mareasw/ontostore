oc:kn_0465a4e8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing the description field" ;
    oc:directiveContent "Keep description under 60 characters, start with a verb (Review, Deploy, Generate), be specific about what the command does, and avoid redundant phrasing like 'This command' or 'A command that'." ;
    oc:hasRationale "Short, verb-led descriptions are scannable in /help output and clearly communicate command purpose" ;
    oc:severityLevel "MEDIUM" .

oc:kn_0c7fd2d6 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When deciding whether to restrict programmatic invocation" ;
    oc:directiveContent "Use disable-model-invocation: true for commands requiring human judgment (approvals), destructive operations (deletions), or interactive workflows. Use sparingly as it limits Claude's autonomy." ;
    oc:hasRationale "Prevents Claude from autonomously executing sensitive or irreversible operations without explicit human initiation" ;
    oc:severityLevel "HIGH" .

oc:kn_1215d489 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the argument-hint field" ;
    oc:directiveContent "In argument-hint, use square brackets [] for each argument, use descriptive names (not arg1/arg2), match order to positional arguments ($1, $2, $3) in the command body, and keep hints concise." ;
    oc:hasRationale "Consistent argument formatting aids discoverability and autocomplete while matching positional reference order prevents bugs" ;
    oc:severityLevel "MEDIUM" .

oc:kn_2487475a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing any command file" ;
    oc:directiveContent "Before committing a command: validate YAML syntax, check description is under 60 chars, verify allowed-tools uses proper format (especially Bash filters), confirm model is valid (sonnet/opus/haiku), ensure argument-hint matches positional args, and verify disable-model-invocation is used appropriately." ;
    oc:hasRationale "Catches common errors like invalid YAML, incorrect tool specs, and mismatched arguments before they reach users" ;
    oc:severityLevel "HIGH" .

oc:kn_304e2e74 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring allowed-tools field" ;
    oc:directiveContent "Never use bare 'Bash' in allowed-tools — always use the command filter pattern like Bash(git:*) or Bash(npm:*). Avoid using '*' for allowed-tools." ;
    oc:hasRationale "Bare Bash grants unrestricted shell access; command filters enforce least-privilege and prevent accidental destructive operations" ;
    oc:severityLevel "HIGH" .

oc:kn_b945e5ad a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing the model field" ;
    oc:directiveContent "Use haiku for simple/formulaic tasks and frequent invocations, sonnet (default) for balanced use cases, and opus only for genuinely complex analysis or architectural decisions. Omit the model field unless there's a specific need." ;
    oc:hasRationale "Matching model capability to task complexity optimizes for both speed and cost" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f0437f4c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any command file" ;
    oc:directiveContent "All frontmatter fields are optional — commands work without any frontmatter. Only add fields when there is a specific need." ;
    oc:hasRationale "Keeps commands minimal and avoids unnecessary configuration overhead" ;
    oc:severityLevel "LOW" .

