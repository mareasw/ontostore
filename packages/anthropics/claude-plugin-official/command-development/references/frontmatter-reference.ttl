oc:skill_anthropics_claude_plugin_official_command_development_frontmatter_reference a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "frontmatter-reference" ;
    skos:broader "Reference specification" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/claude-plugin-official/command-development" ;
    oc:contentHash "db1ea175ca4b0bb7d11c75cb8a7d00b353ea7cf4df2027b4263e45ded4d39475" ;
    oc:dependsOnSkill oc:skill_command_development ;
    oc:differentia "that defines all YAML frontmatter configuration fields (description, allowed-tools, model, argument-hint, disable-model-invocation) available for Claude Code slash commands" ;
    oc:extends oc:skill_anthropics_claude_plugin_official_command_development ;
    oc:hasArgumentHint "[field-name]" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_1f67dc9f,
        oc:kn_7e3ee11d,
        oc:kn_a0313221,
        oc:kn_a7b8c2c6,
        oc:kn_c56d1ff4,
        oc:kn_ea651aa9 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "choose correct model or tool settings for a command",
        "configure command frontmatter fields",
        "understand YAML frontmatter options for slash commands",
        "validate command frontmatter syntax" .

oc:kn_1f67dc9f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying allowed-tools or model frontmatter fields" ;
    oc:directiveContent "Use Bash with command filters (e.g., Bash(git:*)) rather than bare Bash or wildcard (*). Model values must be exactly sonnet, opus, or haiku." ;
    oc:hasRationale "Unrestricted Bash access is a security risk; invalid model names silently fail or cause unexpected behavior." ;
    oc:severityLevel "HIGH" .

oc:kn_7e3ee11d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating any slash command" ;
    oc:directiveContent "All YAML frontmatter fields (description, allowed-tools, model, argument-hint, disable-model-invocation) are optional. Commands function without any frontmatter." ;
    oc:hasRationale "Enables progressive complexity — start minimal and add fields only when specific behavior is needed, reducing friction for simple commands." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a0313221 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the description frontmatter field" ;
    oc:directiveContent "Keep description under 60 characters, start with a verb (Review, Deploy, Generate), and be specific about what the command does. Avoid redundant phrases like 'This command'." ;
    oc:hasRationale "Descriptions appear in /help output where space is limited; verb-first descriptions are scannable and actionable." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a7b8c2c6 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing any slash command with frontmatter" ;
    oc:directiveContent "Before committing a command, validate: YAML syntax is correct, description is under 60 chars, allowed-tools uses proper format (Bash(filter:*) not bare Bash), model is a valid value, and argument-hint matches positional arguments in the body." ;
    oc:hasRationale "Invalid frontmatter silently breaks or misconfigures commands; systematic validation prevents common errors." ;
    oc:severityLevel "HIGH" .

oc:kn_c56d1ff4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring tool access for a command" ;
    oc:directiveContent "Use the most restrictive allowed-tools set that works for the command. Only specify allowed-tools when it differs from conversation permissions." ;
    oc:hasRationale "Principle of least privilege — restricting tool access minimizes accidental damage and makes command behavior predictable." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ea651aa9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to set disable-model-invocation" ;
    oc:directiveContent "Do not use disable-model-invocation: true for commands that could be safely automated. Reserve it only for manual-only commands requiring human judgment, destructive operations, or interactive workflows." ;
    oc:hasRationale "Overusing this flag unnecessarily limits Claude's autonomy and defeats the purpose of having programmable commands." ;
    oc:severityLevel "LOW" .

