                                    oc:textContent "Commands should validate inputs before processing:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 29 ;
                            oc:sectionTitle "Input Validation" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Handle errors gracefully with helpful messages:" ],
                                [ a oc:Template ;
                                    oc:blockType "template" ;
                                    oc:contentOrder 2 ;
                                    oc:templateContent """---
description: Process file with error handling
argument-hint: [file-path]
---

Try processing: !`node ${CLAUDE_PLUGIN_ROOT}/scripts/process.js $1 2>&1 || echo "ERROR: $?"`

If processing succeeded:
- Report results
- Suggest next steps

If processing failed:
- Explain likely causes
- Provide troubleshooting steps
- Suggest alternative approaches
""" ;
                                    oc:templateVariables "CLAUDE_PLUGIN_ROOT" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 34 ;
                            oc:sectionTitle "Graceful Error Handling" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Validate required arguments provided:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """---
description: Create deployment with version
argument-hint: [environment] [version]
---

Validate inputs: !`test -n "$1" -a -n "$2" && echo "OK" || echo "MISSING"`

$IF($1 AND $2,
  Deploy version $2 to $1 environment,
  ERROR: Both environment and version required. Usage: /deploy [env] [version]
)
""" ;
                                    oc:codeLanguage "markdown" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 488-500" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 31 ;
                            oc:sectionTitle "Required Arguments" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 28 ;
