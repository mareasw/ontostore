                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**When to use:** Commands that behave differently per environment" ],
                                [ a oc:Template ;
                                    oc:blockType "template" ;
                                    oc:contentOrder 2 ;
                                    oc:templateContent """---
description: Deploy based on environment
argument-hint: [dev|staging|prod]
---

Environment config: @${CLAUDE_PLUGIN_ROOT}/config/$1.json

Environment check: !`echo "Deploying to: $1"`

Deploy application using $1 environment configuration.
Verify deployment and run smoke tests.
""" ;
                                    oc:templateVariables "CLAUDE_PLUGIN_ROOT" ],
                                [ a oc:Paragraph ;
