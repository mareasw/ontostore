oc:kn_13c9a9fc a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing any command file" ;
    oc:directiveContent "Before releasing a command: validate YAML frontmatter syntax, verify description under 60 chars, confirm allowed-tools format, check argument-hint matches positional arguments, test with different argument counts including empty/missing" ;
    oc:hasRationale "Systematic validation catches the most common command failures before they reach users" .

oc:kn_26ad3334 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building multi-step command workflows that need to persist state across invocations" ;
    oc:directiveContent "Store workflow state in .local.md files with YAML frontmatter. Use atomic writes, include stage/status/timestamp fields, and clean up state files on completion" ;
    oc:hasRationale "Structured state files enable workflow recovery, resume capability, and cross-command coordination while .local.md convention keeps them out of version control" ;
    oc:severityLevel "MEDIUM" .

oc:kn_4781e350 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing and naming new commands" ;
    oc:directiveContent "Each command should have a single clear purpose (single responsibility). Use verb-noun naming (review-pr, fix-issue, deploy-app). Keep descriptions under 60 characters for clean /help display" ;
    oc:hasRationale "Single-responsibility commands are composable, testable, and discoverable. Clear naming and descriptions make the command library self-documenting" ;
    oc:severityLevel "MEDIUM" .

oc:kn_51ece86a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between interactive AskUserQuestion and command arguments" ;
    oc:directiveContent "Use AskUserQuestion only for complex choices with trade-offs (2-4 options per question, 1-4 questions per call, max 12 char headers). Use simple command arguments ($1, $2) for straightforward inputs like file paths, numbers, or names" ;
    oc:hasRationale "Overusing AskUserQuestion for simple inputs slows down scriptable workflows. Arguments are for known values; questions are for decisions requiring context and explanation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_69d82443 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any command prompt content" ;
    oc:directiveContent "Commands must be written as instructions FOR Claude (agent consumption), not messages TO the user. Use directives like 'Review this code for...' not 'This command will review...'" ;
    oc:hasRationale "Command content becomes Claude's instructions when invoked; writing for agent consumption ensures Claude executes correctly rather than narrating to the user" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9ac85699 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating plugin commands that reference files within the plugin directory" ;
    oc:directiveContent "Never use relative paths like ./scripts/analyze.js in plugin commands. Always use ${CLAUDE_PLUGIN_ROOT} for all plugin-internal file references" ;
    oc:hasRationale "Relative paths resolve relative to the user's working directory, not the plugin directory. ${CLAUDE_PLUGIN_ROOT} resolves to the plugin's absolute path, ensuring portability across installations" ;
    oc:severityLevel "HIGH" .

oc:kn_9cfce326 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring the allowed-tools frontmatter field" ;
    oc:directiveContent "Use the most restrictive allowed-tools that works. Prefer Bash(git:*) over Bash(*), and Read,Grep over broader access. Only specify allowed-tools when different from conversation permissions" ;
    oc:hasRationale "Restrictive tool access follows the principle of least privilege, preventing unintended side effects and documenting the command's actual requirements" ;
    oc:severityLevel "HIGH" .

oc:kn_ebcb1806 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a command receives user input that may be invalid" ;
    oc:directiveContent "Validate inputs early in the command (argument presence, file existence, environment validity). Provide helpful error messages with valid options, usage examples, and suggested corrective actions" ;
    oc:hasRationale "Early validation with clear error messages prevents confusing failures deep in execution and helps users self-correct without support" ;
    oc:severityLevel "MEDIUM" .

