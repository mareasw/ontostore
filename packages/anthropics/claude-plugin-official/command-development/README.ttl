oc:kn_45dfcffa a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing command file structure with all features" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
description: Brief description
argument-hint: [arg1] [arg2]
allowed-tools: Read, Bash(git:*)
---

Command content using $1, $2 or $ARGUMENTS for arguments, @path for file references, !`command` for bash output.""" .

oc:kn_47ab6a50 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When iterating on command development" ;
    oc:directiveContent "Start with minimal frontmatter (just description), then add allowed-tools, model, argument-hint as needed. Over-configuring early adds unnecessary complexity." ;
    oc:hasRationale "Incremental configuration prevents premature optimization and keeps commands maintainable" .

oc:kn_5e88bc10 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any slash command" ;
    oc:directiveContent "Command files must use .md extension with optional YAML frontmatter delimited by ---. Files placed in .claude/commands/ (project), ~/.claude/commands/ (personal), or plugin-name/commands/ (plugin)." ;
    oc:hasRationale "Claude Code only discovers and loads commands from these specific locations with the correct format" ;
    oc:severityLevel "CRITICAL" .

oc:kn_6325e7c8 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When testing and refining commands" ;
    oc:directiveContent "Missing arguments, invalid file references in @ syntax, and failed bash commands in !` syntax will cause runtime errors. Always handle missing $ARGUMENTS and validate @file paths exist." ;
    oc:hasRationale "Commands run without developer oversight so edge cases must be anticipated" ;
    oc:severityLevel "MEDIUM" .

oc:kn_69e1a34c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring frontmatter allowed-tools field" ;
    oc:directiveContent "Use the most restrictive allowed-tools setting possible. Only grant tools the command actually needs." ;
    oc:hasRationale "Minimal tool access reduces blast radius if a command prompt is misunderstood or misused" ;
    oc:severityLevel "HIGH" .

oc:kn_7857e86d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing command scope and interface" ;
    oc:directiveContent "Each command should have a single, clear purpose. Make descriptions discoverable in /help. Always use argument-hint to document expected arguments." ;
    oc:hasRationale "Single responsibility makes commands composable, testable, and discoverable by users" .

oc:kn_b645a6b0 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When developing a new slash command" ;
    oc:directiveContent "1. Define purpose and required arguments → 2. Create .md file in appropriate commands/ directory → 3. Add minimal frontmatter (description) → 4. Write command prompt body → 5. Test with /command-name → 6. Refine prompt and handle edge cases" ;
    oc:hasRationale "Iterative development from minimal to complete ensures commands work correctly at each stage" ;
    oc:stepOrder 1 .

oc:kn_f4c4946d a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Command files must be placed in a recognized commands/ directory (.claude/commands/, ~/.claude/commands/, or plugin commands/) for Claude Code to discover them." .

