oc:kn_0a96bc42 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When settings file parsing fails or returns unexpected results" ;
    oc:directiveContent "Handle missing or corrupt settings files gracefully: exit silently if file missing, log error and clean up if fields are empty." ;
    oc:hasRationale "Hooks run on every session; crashing creates poor UX. Silent exit for missing files, cleanup for corrupt ones." ;
    oc:severityLevel "HIGH" .

