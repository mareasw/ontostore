oc:kn_4e427c8c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing hooks or scripts that read .claude/*.local.md files" ;
    oc:directiveContent "Always use the quick-exit pattern: check if the settings file exists before any parsing, exiting immediately if not found." ;
    oc:hasRationale "Avoids errors when plugin isn't configured and keeps hook execution fast for non-users." ;
    oc:severityLevel "HIGH" .

oc:kn_66e9bf88 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When referencing settings files in scripts or hooks" ;
    oc:directiveContent "Never hardcode absolute paths to settings files; always use relative paths like .claude/plugin-name.local.md." ;
    oc:hasRationale "Absolute paths break portability across machines and user accounts." ;
    oc:severityLevel "HIGH" .

oc:kn_6f3afd3b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing any hook or script that reads plugin settings" ;
    oc:directiveContent "1. Check file existence → quick exit if absent. 2. Parse frontmatter fields with sed/grep. 3. Check enabled flag. 4. Extract needed values with defaults. 5. Perform action based on settings. 6. Update state atomically if needed." ;
    oc:stepOrder 1 .

oc:kn_95b350a7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting string values from YAML frontmatter in bash" ;
    oc:directiveContent "Strip surrounding quotes from YAML values using sed 's/^\"\\(.*\\)\"$/\\1/' to handle both quoted and unquoted YAML styles." ;
    oc:hasRationale "YAML allows both field: value and field: \"value\" forms; inconsistent quoting causes subtle bugs." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b119e03a a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parsing YAML frontmatter + markdown body from .local.md files" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "sed -n '/^---$/,/^---$/{ /^---$/d; p; }' \"$STATE_FILE\" to extract frontmatter; awk '/^---$/{i++; next} i>=2' for body content." .

oc:kn_ea2de57d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing plugin settings schemas" ;
    oc:directiveContent "Include an enabled flag in settings frontmatter to allow temporary deactivation without deleting the file." ;
    oc:hasRationale "Users can toggle plugin behavior off without losing their configuration." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f675c82d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating frontmatter fields in .claude/*.local.md files" ;
    oc:directiveContent "Use atomic updates (temp file + mv) when modifying settings files, never in-place sed -i." ;
    oc:hasRationale "Prevents file corruption if the process is interrupted during the write." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fd91e36d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parsing frontmatter values in bash scripts" ;
    oc:directiveContent "Never use unquoted shell variables or assume fields exist without defaults." ;
    oc:hasRationale "Unquoted variables cause word splitting and globbing; missing fields cause unset-variable errors." ;
    oc:severityLevel "HIGH" .

