oc:kn_013e2b0e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a parsing approach" ;
    oc:directiveContent "Use sed/grep for simple field extraction, yq for complex YAML structures (nested objects, lists). Prefer pure bash when yq is not guaranteed available." ;
    oc:hasRationale "yq adds a dependency but handles YAML properly; sed/grep are universally available but fragile with complex structures." ;
    oc:severityLevel "LOW" .

oc:kn_09ea2952 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When feeding parsed body content into JSON output" ;
    oc:directiveContent "When constructing JSON from parsed values, always use jq -n --arg to safely embed user content. Never interpolate shell variables directly into JSON strings." ;
    oc:hasRationale "Direct string interpolation can break JSON structure and enable injection if the content contains quotes or special characters." ;
    oc:severityLevel "CRITICAL" .

oc:kn_13c99757 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting markdown body content after frontmatter" ;
    oc:directiveContent "The awk '/^---$/{i++; next} i>=2' pattern correctly handles --- appearing in the markdown body because it only counts the first two markers." ;
    oc:hasRationale "A naive sed approach would break if the body content itself contains --- separators." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1f6a0322 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """Settings file structure:
---
{field}: {value}
{boolean_field}: true|false
{numeric_field}: 42
{list_field}: ["item1", "item2"]
---
{Markdown body content}""" ;
    oc:templateVariables "Markdown body content",
        "boolean_field",
        "field",
        "list_field",
        "numeric_field",
        "value" .

oc:kn_23581ce7 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When parsing a plugin settings file" ;
    oc:directiveContent "1. Check if settings file exists 2. Extract frontmatter with sed range 3. Cache FRONTMATTER variable 4. Extract fields with grep+sed, stripping quotes 5. Apply defaults for missing fields 6. Validate values (enums, ranges, types) 7. Exit early if disabled 8. Apply logic based on settings" ;
    oc:stepOrder 1 .

oc:kn_2609df5d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Extracting markdown body after frontmatter" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "BODY=$(awk '/^---$/{i++; next} i>=2' \"$FILE\")" .

oc:kn_50754e0d a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating settings files" ;
    oc:directiveContent "Reading/parsing settings is idempotent; writing must use atomic temp-file+mv to prevent corruption on concurrent access or crash mid-write." ;
    oc:hasRationale "Non-atomic writes can leave the file in a corrupted state if the process is interrupted between write and replace." ;
    oc:severityLevel "HIGH" .

oc:kn_524532c0 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Atomically updating a field in a settings file" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """TEMP_FILE="${FILE}.tmp.$$"
sed "s/^field: .*/field: $NEW_VALUE/" "$FILE" > "$TEMP_FILE"
mv "$TEMP_FILE" "$FILE\"""" .

oc:kn_6e4ad726 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Validating frontmatter structure before parsing" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """MARKER_COUNT=$(grep -c '^---$' "$FILE" 2>/dev/null || echo "0")
if [[ $MARKER_COUNT -lt 2 ]]; then
  echo "Invalid settings file" >&2; exit 1
fi""" .

oc:kn_92292284 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting multiple fields from a settings file" ;
    oc:directiveContent "Never re-parse the file for each field extraction. Cache the FRONTMATTER variable once and extract all fields from it." ;
    oc:hasRationale "Re-reading the file for each field is wasteful I/O and can lead to inconsistent reads if the file changes between parses." ;
    oc:severityLevel "MEDIUM" .

oc:kn_92a66edb a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any settings parsing" ;
    oc:directiveContent "Before parsing, verify the file exists (-f), is readable (-r), and has exactly 2 frontmatter markers. Exit early if disabled." ;
    oc:hasRationale "Prevents cryptic errors from missing or malformed files and avoids unnecessary work when settings are disabled." ;
    oc:severityLevel "HIGH" .

oc:kn_9c140b8f a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a field is missing or has an invalid value" ;
    oc:directiveContent "Always provide default values when extracting fields: VALUE=${VALUE:-default}. Validate extracted values and fall back to defaults on invalid input." ;
    oc:hasRationale "Settings files may be incomplete or manually edited; robust scripts degrade gracefully rather than failing." ;
    oc:severityLevel "HIGH" .

oc:kn_b9bde1b9 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Parsing all fields in a single pass" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """while IFS=': ' read -r key value; do
  value=$(echo "$value" | sed 's/^"\\(.*\\)"$/\\1/')
  case "$key" in
    enabled) ENABLED="$value" ;;
    mode) MODE="$value" ;;
  esac
done <<< "$FRONTMATTER\"""" .

oc:kn_d79d929a a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Extracting a string field with default from YAML frontmatter" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """FRONTMATTER=$(sed -n '/^---$/,/^---$/{ /^---$/d; p; }' "$FILE")
VALUE=$(echo "$FRONTMATTER" | grep '^field:' | sed 's/field: *//' | sed 's/^"\\(.*\\)"$/\\1/')
VALUE=${VALUE:-default}""" .

