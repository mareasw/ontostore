oc:kn_15a8cb0a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any plugin settings schema" ;
    oc:directiveContent "Use the 'enabled' frontmatter key as the standard boolean toggle for activating/deactivating plugin behavior." ;
    oc:hasRationale "A consistent 'enabled' field across all plugins allows uniform guard checks in hooks and predictable user experience." ;
    oc:severityLevel "MEDIUM" .

oc:kn_698b12a5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or reading any plugin configuration file" ;
    oc:directiveContent "Plugin settings use YAML frontmatter in .local.md files under the .claude/ directory, separating configuration from documentation in the same file." ;
    oc:hasRationale "YAML frontmatter provides machine-parseable config while the markdown body provides human-readable documentation, enabling both hooks and users to consume the same file." ;
    oc:severityLevel "HIGH" .

oc:kn_91dffa83 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "After editing any .claude/*.local.md settings file" ;
    oc:directiveContent "Settings changes require a Claude Code restart to take effect — hooks cannot be hot-swapped." ;
    oc:hasRationale "Hook configurations are loaded at startup; in-memory state is not refreshed during a running session." ;
    oc:severityLevel "HIGH" .

oc:kn_c828ecde a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing bash hooks that consume plugin settings" ;
    oc:directiveContent "Hooks should check for the existence of a settings file before attempting to read it, exiting gracefully (exit 0) if the file is not present." ;
    oc:hasRationale "Plugins are optional — absence of a config file means the hook should be skipped cleanly rather than fail with an error." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f9b2f2d6 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When setting up plugin configuration files in any project" ;
    oc:directiveContent "All .claude/*.local.md and .claude/*.local.json files must be added to .gitignore to prevent committing user-local or sensitive configuration." ;
    oc:hasRationale "Local settings may contain paths, credentials, or user-specific preferences that should not be shared with other contributors or pushed to remote repositories." ;
    oc:severityLevel "CRITICAL" .

