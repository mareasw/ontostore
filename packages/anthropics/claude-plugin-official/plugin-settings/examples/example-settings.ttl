oc:kn_017e67e6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up plugin configuration files" ;
    oc:directiveContent "Never commit .claude/*.local.md or .claude/*.local.json files to version control" ;
    oc:hasRationale "These are user-local settings that should be gitignored to prevent personal config from leaking into shared repos" ;
    oc:severityLevel "CRITICAL" .

oc:kn_0838ef7d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming settings files" ;
    oc:directiveContent "Use .local.md extension to distinguish user-local settings from shared plugin files" ;
    oc:hasRationale "The .local convention signals that the file is machine-specific and should not be shared or committed" .

oc:kn_4982f3d4 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before reading plugin settings in hooks" ;
    oc:directiveContent "Always check if the settings file exists before reading it: if [[ ! -f '.claude/my-plugin.local.md' ]]; then exit 0; fi" ;
    oc:hasRationale "Gracefully handles cases where plugin is not yet configured — hook should skip silently rather than fail" .

oc:kn_8033f457 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading plugin settings from hooks" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """FRONTMATTER=$(sed -n '/^---$/,/^---$/{ /^---$/d; p; }' ".claude/my-plugin.local.md")
ENABLED=$(echo "$FRONTMATTER" | grep '^enabled:' | sed 's/enabled: *//')""" ;
    oc:hasRationale "Extracts YAML frontmatter values using sed for lightweight parsing without requiring YAML tools" .

oc:kn_c3556d98 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing .claude/*.local.md files" ;
    oc:directiveContent "Settings changes require Claude Code restart — hooks cannot be hot-swapped" ;
    oc:hasRationale "Hooks read settings at startup time; in-process changes will not take effect until restart" ;
    oc:severityLevel "HIGH" .

oc:kn_d3bfb77b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any plugin settings file" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """---
enabled: true
key: value
---
# Config Title
Description text""" ;
    oc:hasRationale "Frontmatter between --- delimiters is parsed by hooks to extract structured config values" .

