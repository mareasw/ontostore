oc:kn_067fa879 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating a plugin settings file template" ;
    oc:directiveContent """---
enabled: {boolean}
mode: {strict|standard|lenient}
max_value: {integer}
list_setting: ["{item1}", "{item2}"]
---

# {Section Title}

{Markdown body with additional context or prompts}""" ;
    oc:templateVariables "Markdown body",
        "Section Title",
        "boolean",
        "integer",
        "item1",
        "item2",
        "mode" .

oc:kn_14b47dbb a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When adding settings support to a new plugin" ;
    oc:directiveContent "1. Design settings schema (fields, types, defaults) 2. Create template in plugin docs 3. Add .claude/*.local.md to .gitignore 4. Implement frontmatter parsing in hooks/commands 5. Use quick-exit pattern (check exists, check enabled) 6. Document settings in README 7. Remind users restart is required" ;
    oc:stepOrder 1 .

oc:kn_2677b998 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "After editing .claude/plugin-name.local.md" ;
    oc:directiveContent "Settings changes require Claude Code restart. Hooks cannot be hot-swapped within a session." ;
    oc:hasRationale "Hooks are loaded at session start. In-session edits to settings files won't affect already-loaded hook behavior." ;
    oc:severityLevel "HIGH" .

oc:kn_5449f943 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When creating or updating settings from user input" ;
    oc:directiveContent "Sanitize user input before writing to settings files. Escape quotes, validate numeric ranges, and check file paths for traversal attempts (..)." ;
    oc:hasRationale "Settings files are sourced by bash scripts. Unsanitized input could enable injection attacks or path traversal." ;
    oc:severityLevel "HIGH" .

oc:kn_6916919d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing hooks that read settings" ;
    oc:directiveContent "Always use the quick-exit pattern: check file existence first, then check enabled flag, then proceed with logic. This avoids unnecessary I/O and errors when plugin is not configured." ;
    oc:hasRationale "Most hooks run frequently. The quick-exit pattern ensures unconfigured plugins impose near-zero overhead." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7a9bfd94 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating a single field in settings files" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """# Atomic field update
TEMP_FILE="${FILE}.tmp.$$"
sed "s/^field_name: .*/field_name: $NEW_VALUE/" "$FILE" > "$TEMP_FILE"
mv "$TEMP_FILE" "$FILE\"""" .

oc:kn_7e53504e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading any setting field" ;
    oc:directiveContent "Always provide sensible defaults when the settings file doesn't exist or a field is missing. Use the pattern: VALUE=${VALUE:-default}." ;
    oc:hasRationale "Plugins should work out-of-the-box without requiring users to create settings files. Defaults ensure graceful degradation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_875fd4d4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any hook that reads plugin settings" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """# Quick exit pattern
if [[ ! -f "$STATE_FILE" ]]; then
  exit 0  # Not configured
fi
FRONTMATTER=$(sed -n '/^---$/,/^---$/{ /^---$/d; p; }' "$STATE_FILE")
ENABLED=$(echo "$FRONTMATTER" | grep '^enabled:' | sed 's/enabled: *//')
if [[ "$ENABLED" != "true" ]]; then
  exit 0  # Disabled
fi""" .

oc:kn_b91be21c a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "When parsing frontmatter in hooks" ;
    oc:directiveContent "Bash sed, grep, and awk must be available (standard on Unix/macOS/Linux). For complex YAML, yq is optional." .

oc:kn_bec70671 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parsing YAML frontmatter from .local.md settings files" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """# Extract frontmatter
FRONTMATTER=$(sed -n '/^---$/,/^---$/{ /^---$/d; p; }' "$FILE")
# Read field with quote stripping
VALUE=$(echo "$FRONTMATTER" | grep '^field:' | sed 's/field: *//' | sed 's/^"\\(.*\\)"$/\\1/')
# Read body after second ---
BODY=$(awk '/^---$/{i++; next} i>=2' "$FILE")""" .

oc:kn_c90d6a9c a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading or updating settings" ;
    oc:directiveContent "Reading settings files is idempotent. Writing should use atomic temp+mv pattern to be safe for repeated execution." ;
    oc:hasRationale "Hooks may read settings multiple times per session; reads must be side-effect-free." .

oc:kn_f9361e5e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any plugin settings file" ;
    oc:directiveContent "Settings files MUST use the path .claude/plugin-name.local.md with .local.md suffix to avoid accidental git commits. Always add '.claude/*.local.md' to .gitignore." ;
    oc:hasRationale "The .local.md suffix signals user-local, non-committed configuration. Without it, sensitive or user-specific settings could be pushed to shared repositories." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fe857666 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating settings file fields" ;
    oc:directiveContent "Never use sed -i for in-place editing of settings files. Always use temp file + atomic mv to prevent corruption on interrupt." ;
    oc:hasRationale "Non-atomic updates can leave zero-byte or partially-written files if the process is killed mid-write, breaking plugin behavior." ;
    oc:severityLevel "HIGH" .

