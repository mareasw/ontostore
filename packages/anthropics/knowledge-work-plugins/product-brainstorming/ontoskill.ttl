_:ref_7a795e6650d6002d a oc:WorkflowStep ;
    dcterms:description "Converge: group ideas into themes, evaluate against user impact/feasibility/strategic alignment/evidence, identify top 2-3 with biggest unknowns" ;
    oc:expectedOutcome "Top 2-3 ideas worth pursuing, each with its biggest unknown and cheapest test identified" ;
    oc:stepDependsOn _:ref_d15af3e328342d82 ;
    oc:stepId "converge" .

_:ref_9e6e2eefc5891d75 a oc:WorkflowStep ;
