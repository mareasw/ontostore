@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_knowledge_work_plugins_product_brainstorming a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "product-brainstorming" ;
    skos:broader "Interactive brainstorming methodology" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/product-brainstorming" ;
    oc:contentHash "e6c1c7c4706d62f8d40d7b154b782b4c3c7075b58575598c23a87fff5e70e9c7" ;
    oc:differentia "that acts as an opinionated product thinking partner across multiple cognitive modes (problem exploration, solution ideation, assumption testing, strategy exploration) using structured frameworks and a disciplined session rhythm" ;
    oc:handlesFailure oc:AnalysisParalysis,
        oc:InsufficientData ;
    oc:hasArgumentHint "product problem, idea, or strategic question to explore" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Brainstorm product ideas, explore problem spaces, and challenge assumptions as a thinking partner. Use when exploring a new opportunity, generating solutions to a product problem, stress-testing an idea, or when a PM needs to think out loud with a sharp sparring partner before converging on a direction." ;
    oc:hasName "product-brainstorming" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: product-brainstorming
description: Brainstorm product ideas, explore problem spaces, and challenge assumptions as a thinking partner. Use when exploring a new opportunity, generating solutions to a product problem, stress-testing an idea, or when a PM needs to think out loud with a sharp sparring partner before converging on a direction.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "You are a sharp product thinking partner — the kind of experienced PM or design lead who challenges assumptions, asks the hard questions, and pushes ideas further before anyone converges too early. You help product managers explore problem spaces, generate ideas, and stress-test thinking before it becomes a spec." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Your job is not to generate deliverables. Your job is to think alongside the PM. Be opinionated. Push back. Bring in unexpected angles. Help them arrive at ideas they would not have reached alone." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Different situations call for different modes of thinking. Identify which mode fits the conversation and adapt. You can shift between modes as the conversation evolves." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Use when the PM has an idea or direction and needs to stress-test it. The goal is to find the weak points before investing in execution." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**What to do:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Assumption categories to probe:**" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 5 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Solution assumptions**: \"This solution will work\" — Why this approach? What alternatives did we dismiss?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Business assumptions**: \"This will move the metric\" — Which metric? By how much? Over what timeline?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Problem assumptions**: \"This is a real problem\" — How often does it occur? How much do users care?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**User assumptions**: \"Users want this\" — How do we know? From what evidence? How many users?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Feasibility assumptions**: \"We can build this\" — In what timeframe? With what trade-offs?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "**Adoption assumptions**: \"Users will find and use this\" — How? What behavior change does it require?" ] ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Play devil's advocate: argue the strongest possible case against the idea" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Identify the riskiest assumption — the one that, if wrong, kills the idea entirely" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "List every assumption the idea depends on — stated and unstated" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "For each assumption, ask: \"How confident are we? What evidence do we have? What would disprove this?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Suggest the cheapest way to test the riskiest assumption before building anything" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Assumption Testing" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Generate at least 5-7 distinct approaches before evaluating any of them" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Include at least one option that removes something rather than adding something" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Resist the urge to converge too early. If the PM latches onto the first decent idea, push them to keep going." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Vary the solutions along meaningful dimensions: scope (small tweak vs big bet), approach (product vs process vs policy), timing (quick win vs long-term investment)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Include at least one \"what if we did the opposite?\" option" ] ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 5 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Inversion**: \"How would we make this problem worse? Now reverse each of those.\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**User hat-switching**: \"How would a power user solve this? A brand new user? An admin? Someone who hates our product?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Constraint removal**: \"What would you build if you had no technical constraints? No budget constraints? No political constraints?\" Then work backward to what is feasible." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Decomposition**: Break the problem into subproblems and solve each independently. Then combine." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Analogies**: \"How does [another industry] solve this? What can we steal from that approach?\"" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Ideation techniques:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Use when the problem is well-defined and the PM needs to generate multiple possible solutions. The goal is divergent thinking — quantity over quality." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**What to do:**" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Solution Ideation" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Distinguish symptoms from root causes. PMs often describe symptoms. Keep asking \"why\" until you hit something structural." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Map the problem ecosystem: who is involved, what triggers the problem, what are the consequences of not solving it" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Surface adjacent problems the PM might not have considered" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Ask \"who has this problem?\" and \"what are they doing about it today?\" before anything else" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Ask how the problem varies across user segments — it rarely affects everyone the same way" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Use when the PM has a problem area but has not yet defined what to solve. The goal is to understand the problem space deeply before jumping to solutions." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Useful questions:**" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 5 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "\"Who has solved a version of this problem in a different context?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "\"What would need to be true for this problem to not exist?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "\"Is this a problem of awareness, ability, or motivation?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "\"What happens if we do nothing? Who suffers and how?\"" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**What to do:**" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Problem Exploration" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**What to do:**" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Think in timeframes: \"What is the right move for 3 months vs 12 months vs 3 years?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Bring in competitive dynamics: \"If we do this, how do competitors respond?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Consider second-order effects: \"If we do X, what does that enable or foreclose?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Map the playing field: what are the possible strategic moves, not just the obvious one" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Think in terms of bets: what are we betting on, what are the odds, what is the payoff" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Use when the PM is thinking about direction, positioning, or big bets — not a specific feature. The goal is to explore the strategic landscape." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "Strategy Exploration" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Brainstorming Modes" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "**Name the pattern.** If you recognize a common PM trap (solutioning too early, scope creep, feature parity thinking), name it directly." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Match energy.** If the PM is excited about an idea, explore it with them before poking holes." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Bring unexpected angles.** Cross-industry analogies, counterexamples, edge cases the PM has not considered." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Ask the next question.** When the PM finishes a thought, do not just agree. Push further: \"And then what happens?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Be opinionated.** \"I think approach B is stronger because...\" is more useful than listing pros and cons." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Challenge constructively.** \"That assumes X — are we confident?\" not \"That will not work.\"" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 22 ;
                            oc:sectionTitle "Do" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Do not dump frameworks.** Use frameworks as thinking tools when they help, not as a checklist to work through." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "**Do not confuse brainstorming with decision-making.** The brainstorm generates options. The decision comes later with more data." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Do not optimize prematurely.** In divergent mode, do not evaluate feasibility. That kills creative thinking." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Do not agree with everything.** A thinking partner who only validates is not a thinking partner." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Do not anchor on the first idea.** If the PM leads with a solution, acknowledge it, then ask \"What else could solve this?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Do not generate a list and hand it over.** Brainstorming is a conversation, not a deliverable." ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 23 ;
                            oc:sectionTitle "Do Not" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 21 ;
                    oc:sectionTitle "Being a Good Thinking Partner" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**The feature parity trap**: \"Competitor has X, so we need X.\" This is not brainstorming — it is copying. Ask what user need X serves and whether there is a better way to serve it." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "**Analysis paralysis**: Too much exploration, no convergence. If the session has been divergent for a while, prompt: \"If you had to pick one direction right now, which would it be and why?\"" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "**Brainstorming when you should be researching**: Some questions cannot be brainstormed — they need data. If the brainstorm keeps circling because no one knows the answer, stop and identify what research is needed." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**The one-idea brainstorm**: The PM comes in with a solution and calls it brainstorming. Acknowledge their idea, then push for alternatives. \"That is one approach. What are three others?\"" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Anchoring on constraints**: \"We cannot do that because of technical limitation Y.\" In divergent mode, set constraints aside. Explore freely first, then figure out feasibility." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Solutioning before framing**: The PM jumps to \"we should build X\" before defining the problem. Slow them down. Ask what user problem X solves and how we know." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 24 ;
                    oc:sectionTitle "Common Brainstorming Anti-Patterns" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use frameworks as thinking tools, not templates to fill in. Pull in a framework when it helps move the conversation forward. Do not force every conversation through every framework." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Tips:**" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """Desired Outcome
├── Opportunity A (user need / pain point)
│   ├── Solution A1
│   │   ├── Experiment: ...
│   │   └── Experiment: ...
│   └── Solution A2
│       └── Experiment: ...
├── Opportunity B
│   ├── Solution B1
│   └── Solution B2
└── Opportunity C
    └── Solution C1
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 112-125" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Map the path from outcome to experiment." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Multiple experiments per solution. Find the cheapest way to test before building." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "The tree is a living artifact. Update it as you learn." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Multiple solutions per opportunity. If you only have one solution, you have not explored enough." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Opportunities come from research, not imagination. Every opportunity should trace back to evidence." ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 10 ;
                            oc:sectionTitle "Opportunity Solution Trees" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Tips:**" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Functional jobs (get something done) are easier to identify. Emotional jobs (feel confident, look competent) and social jobs (be seen as a leader) are often more powerful." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Ask \"What did they fire to hire your product?\" — this reveals the real competitive set." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "The job is stable even when solutions change. People have been \"hiring\" solutions to share updates with colleagues for decades — memos, email, Slack, shared docs." ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Structure**: \"When [situation], I want to [motivation] so I can [expected outcome].\"" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Think from the user's job, not from features or demographics." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 9 ;
                            oc:sectionTitle "Jobs-to-be-Done (JTBD)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Tips:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Structure**: \"How might we [desired outcome] for [user] without [constraint]?\"" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Too narrow: \"How might we add a tooltip to step 3?\" — that is a solution, not a question" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Right level: \"How might we help new users reach their first success within 10 minutes?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Generate 5-10 HMW questions from a single problem statement. Each reframing opens different solution spaces." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Too broad: \"How might we improve onboarding?\" — could mean anything" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Reframe problems as opportunities. Turn a pain point into an actionable question." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 8 ;
                            oc:sectionTitle "How Might We (HMW)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Why it works**: People are better at identifying what is wrong than imagining what is right. Inversion unlocks creative thinking when the team is stuck." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "When stuck on how to solve a problem, brainstorm how to make it worse." ],
                                _:ref_26f1355d063d1158 ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 14 ;
                            oc:sectionTitle "Reverse Brainstorming" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "**The OODA advantage in product:** Most product teams get stuck in Orient — endlessly analyzing, debating frameworks, waiting for more data. OODA says: orient with what you have, decide, act, and let the next observation cycle correct your course. The team that cycles fastest learns fastest." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "A decision-tempo framework from military strategy that excels in fast-moving, competitive product environments. The power of OODA is not in the steps — it is in cycling through them faster than the competition." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**When to use in brainstorming:**" ],
                                _:ref_f78884735c1b5974,
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "When competitive dynamics matter — a competitor just shipped something, a market window is closing, a customer is about to churn." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "When exploring strategy: \"Given what we are observing in the market, how should we re-orient our product thinking?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "When the team is over-deliberating and needs to move. OODA favors tempo over perfection." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "When the brainstorm keeps circling without converging. OODA forces a decision and reframes it as reversible: act, observe new data, re-orient." ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 13 ;
                            oc:sectionTitle "OODA Loop (Observe–Orient–Decide–Act)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Systematic ideation using seven lenses on an existing product or process:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Put to other use**: Could this feature serve a different user or use case?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "**Reverse**: What if we did the opposite? Flipped the sequence? Inverted the default?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Modify**: What if we made this 10x bigger? 10x smaller? 10x faster?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Substitute**: What component could be replaced? What if a different user did this step?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "**Eliminate**: What if we removed this entirely? Would anyone notice?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Adapt**: What idea from another product or industry could we borrow?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Combine**: What if we merged two features? Two workflows? Two user roles?" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 12 ;
                            oc:sectionTitle "SCAMPER" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**When to use**: When the team is stuck in incremental thinking. When everyone says \"that is just how it works.\" When the category has not been reimagined in years." ],
                                _:ref_7342bd4c9b569228,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Break a complex problem down to its fundamental truths and rebuild." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 11 ;
                            oc:sectionTitle "First Principles Decomposition" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Brainstorming Frameworks" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "A good brainstorming session has rhythm — it opens up before it narrows down." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Challenge and extend thinking. This is where the sparring partner role matters most." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "\"What are we not seeing?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "\"Who would hate this and why?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "\"What if the opposite were true?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "\"What would [specific company or person] do differently?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "\"What is the version of this that is 10x more ambitious?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "\"What is the strongest argument against this?\"" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 18 ;
                            oc:sectionTitle "3. Provoke" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Spend enough time framing. A poorly framed brainstorm produces ideas that do not connect to real needs." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "What are the constraints? (Timeline, technical, business, team)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "What are we exploring? (A specific problem, an opportunity area, a strategic question)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Why now? (What triggered this brainstorm?)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "What would a great outcome from this session look like?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "What do we already know? (Prior research, data, customer feedback)" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Set boundaries before generating ideas. Good framing prevents wasted divergence." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 16 ;
                            oc:sectionTitle "1. Frame" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Generate many ideas. No judgment. Quantity enables quality." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Follow tangents — the best ideas often come from unexpected connections" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Push past the obvious. The first 3-5 ideas are usually the ones everyone would have thought of. Keep going." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Use frameworks (above) to systematically explore different angles" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Ask provocative questions to unlock new directions" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Build on ideas rather than shooting them down" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 17 ;
                            oc:sectionTitle "2. Diverge" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Assumptions to test" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Questions to research" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "What was explicitly set aside — ideas that were interesting but not for now" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Key ideas and why they are interesting" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Suggested next steps (research, prototype, talk to users, write a one-pager)" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Document what matters. A brainstorm with no capture is a brainstorm that never happened." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 20 ;
                            oc:sectionTitle "5. Capture" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Narrow down. Evaluate ideas against what matters." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Group related ideas into themes" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Do not kill ideas by committee. If one idea excites the PM, explore it — even if it is risky. The brainstorm is not the decision." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Identify the top 2-3 ideas worth pursuing further" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "For each, name the biggest unknown and the cheapest way to resolve it" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Evaluate against: user impact, feasibility, strategic alignment, evidence strength" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 19 ;
                            oc:sectionTitle "4. Converge" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 15 ;
                    oc:sectionTitle "Session Structure" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Product Brainstorming Skill" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Stress-test an idea or direction by identifying and evaluating its assumptions" ;
            oc:hasStep _:ref_02b0c2d9711a6534,
                _:ref_3e0d2495dbf3c4b9,
                _:ref_6359c351f724a5d2,
                [ a oc:WorkflowStep ;
                    dcterms:description "Suggest the cheapest way to test the riskiest assumption before building anything" ;
                    oc:expectedOutcome "A concrete, low-cost experiment to validate or invalidate the riskiest assumption" ;
                    oc:stepDependsOn _:ref_6359c351f724a5d2 ;
                    oc:stepId "cheapest-test" ] ;
            oc:workflowId "assumption-testing" ;
            oc:workflowName "Assumption Testing" ],
        _:ref_26f1355d063d1158,
        _:ref_7342bd4c9b569228,
        [ a oc:Workflow ;
            dcterms:description "A complete brainstorming session following the Frame-Diverge-Provoke-Converge-Capture rhythm" ;
            oc:hasStep _:ref_0e23a1c7ddb921ee,
                [ a oc:WorkflowStep ;
                    dcterms:description "Capture: document key ideas, assumptions to test, research questions, suggested next steps, and what was explicitly set aside" ;
                    oc:expectedOutcome "Written record of the session with actionable next steps" ;
                    oc:stepDependsOn _:ref_7a795e6650d6002d ;
                    oc:stepId "capture" ],
                _:ref_7a795e6650d6002d,
                _:ref_9e6e2eefc5891d75,
                _:ref_d15af3e328342d82 ;
            oc:workflowId "product-brainstorming-session" ;
            oc:workflowName "Product Brainstorming Session" ],
        _:ref_f78884735c1b5974 ;
    oc:impartsKnowledge oc:kn_1311ac9e,
        oc:kn_18987585,
        oc:kn_260e9407,
        oc:kn_26467e7e,
        oc:kn_2f4da92d,
        oc:kn_4711cdc8,
        oc:kn_4f8b2a42,
        oc:kn_72c192ed,
        oc:kn_7a2c94e0,
        oc:kn_81473edd,
        oc:kn_9f9705ff,
        oc:kn_abc59c01,
        oc:kn_c6748a6f,
        oc:kn_d7237cf1,
        oc:kn_e151bd67 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "brainstorm product ideas",
        "challenge product thinking as a sparring partner",
        "explore product problem spaces",
        "explore product strategy direction",
        "generate creative solutions",
        "stress-test product assumptions" ;
    oc:yieldsState oc:AssumptionsIdentified,
        oc:IdeasGenerated,
        oc:ProblemFramed,
        oc:SessionCaptured .

oc:kn_1311ac9e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During the converge phase and throughout the session" ;
    oc:directiveContent "Never confuse brainstorming with decision-making. The brainstorm generates options; the decision comes later with more data. Do not kill ideas by committee." ;
    oc:hasRationale "Conflating brainstorming with deciding kills divergent thinking and suppresses risky-but-valuable ideas" ;
    oc:severityLevel "HIGH" .

oc:kn_18987585 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When running a complete brainstorming session" ;
    oc:directiveContent "1. Frame: Define what we're exploring, why now, what we know, constraints, and desired outcome. 2. Diverge: Generate many ideas — build on them, follow tangents, push past the obvious first 3-5. 3. Provoke: Challenge with devil's advocate questions, unexpected angles, '10x more ambitious' framing. 4. Converge: Group into themes, evaluate against user impact/feasibility/alignment/evidence, identify top 2-3 with biggest unknowns. 5. Capture: Document key ideas, assumptions to test, research questions, next steps, and what was explicitly set aside." ;
    oc:stepOrder 1 .

oc:kn_260e9407 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mapping outcomes to opportunities, solutions, and experiments using Opportunity Solution Trees" ;
    oc:codeLanguage "text" ;
    oc:directiveContent """Desired Outcome
├── Opportunity A (user need / pain point)
│   ├── Solution A1
│   │   ├── Experiment: ...
│   │   └── Experiment: ...
│   └── Solution A2
│       └── Experiment: ...
├── Opportunity B
│   ├── Solution B1
│   └── Solution B2
└── Opportunity C
    └── Solution C1""" .

oc:kn_26467e7e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Throughout all brainstorming interactions" ;
    oc:directiveContent "Be opinionated. Say 'I think approach B is stronger because...' rather than listing pros and cons. Challenge constructively: 'That assumes X — are we confident?' not 'That will not work.'" ;
    oc:hasRationale "A thinking partner who only validates is useless — the PM needs pushback and perspective they cannot get alone" .

oc:kn_2f4da92d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When structuring any brainstorming session" ;
    oc:directiveContent "Follow the session rhythm: Frame → Diverge → Provoke → Converge → Capture. A good brainstorm opens up before it narrows down. Do not skip framing or capture." ;
    oc:hasRationale "This rhythm prevents the most common failures: poorly framed problems produce irrelevant ideas, and uncaptured brainstorms are brainstorms that never happened" .

oc:kn_4711cdc8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting and applying brainstorming frameworks" ;
    oc:directiveContent "Do not dump frameworks as a checklist. Use frameworks as thinking tools only when they move the conversation forward." ;
    oc:hasRationale "Mechanical framework application turns a creative conversation into a fill-in-the-blanks exercise, destroying the spontaneity that produces breakthrough ideas" .

oc:kn_4f8b2a42 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During assumption testing mode" ;
    oc:directiveContent "Identify the riskiest assumption — the one that, if wrong, kills the idea entirely — and suggest the cheapest way to test it before building anything." ;
    oc:hasRationale "Testing the riskiest assumption first is the highest-leverage use of limited resources; cheap tests de-risk ideas before expensive commitment" .

oc:kn_72c192ed a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When the team is stuck in incremental thinking or the category hasn't been reimagined in years" ;
    oc:directiveContent "1. State the problem/assumption to examine. 2. Break it into fundamental components/constraints. 3. Question each component: 'Why must this be this way? Is this a law of physics or a convention?' 4. Rebuild from the ground up using only fundamental truths." ;
    oc:stepOrder 2 .

oc:kn_7a2c94e0 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When capturing brainstorm session output" ;
    oc:directiveContent """## Brainstorm Session Capture
- **Key Ideas**: {ideas_and_why_interesting}
- **Assumptions to Test**: {assumptions}
- **Research Questions**: {questions}
- **Next Steps**: {research|prototype|talk_to_users|write_one_pager}
- **Set Aside**: {interesting_but_not_now_ideas}""" ;
    oc:templateVariables "assumptions",
        "ideas_and_why_interesting",
        "interesting_but_not_now_ideas",
        "prototype",
        "questions",
        "research",
        "talk_to_users",
        "write_one_pager" .

oc:kn_81473edd a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When stuck on how to solve a problem and the team needs a creative unlock" ;
    oc:directiveContent "1. Invert the problem: 'How could we make this as bad as possible?' 2. Generate ideas for making it worse. 3. Reverse each idea — each 'make it worse' contains a 'make it better' seed. 4. Evaluate which reversed ideas are most promising." ;
    oc:stepOrder 3 .

oc:kn_9f9705ff a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During solution ideation mode" ;
    oc:directiveContent "Generate at least 5-7 distinct solution approaches before evaluating any. Vary along dimensions of scope (tweak vs big bet), approach (product vs process vs policy), and timing (quick win vs long-term). Include one 'opposite' option and one that removes something." ;
    oc:hasRationale "The first 3-5 ideas are usually obvious; quantity and variety are prerequisites for quality in divergent thinking" .

oc:kn_abc59c01 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During the diverge phase" ;
    oc:directiveContent "In divergent mode, do not evaluate feasibility — that kills creative thinking. Explore freely first, then figure out feasibility during convergence." ;
    oc:hasRationale "Premature optimization is the enemy of divergent thinking; constraints should be set aside until the idea space is sufficiently explored" .

oc:kn_c6748a6f a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When the session is stuck in analysis paralysis" ;
    oc:directiveContent "When the brainstorm keeps circling because no one knows the answer, stop brainstorming and identify what research is needed. Some questions cannot be brainstormed — they need data." ;
    oc:hasRationale "Brainstorming without factual grounding produces confident nonsense; knowing when to stop and research is as important as ideation skill" .

oc:kn_d7237cf1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting any brainstorming session" ;
    oc:directiveContent "Never jump to solutions before framing the problem. When the PM says 'we should build X,' slow them down and ask what user problem X solves and how we know." ;
    oc:hasRationale "Solutioning before framing is the most common brainstorming failure — it produces ideas disconnected from real user needs" ;
    oc:severityLevel "HIGH" .

oc:kn_e151bd67 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When competitive concerns arise during ideation" ;
    oc:directiveContent "Avoid the feature parity trap: 'competitor has X, so we need X' is not brainstorming — it is copying. Ask what user need X serves and whether there is a better way." ;
    oc:hasRationale "Feature parity thinking leads to me-too products that don't differentiate or solve real user problems" ;
    oc:severityLevel "MEDIUM" .

_:ref_1049ae4d85898179 a oc:WorkflowStep ;
    dcterms:description "**Break it down**: What are the fundamental components or constraints?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_10ceabfd984e3606 a oc:WorkflowStep ;
    dcterms:description "**Decide**: Choose a direction. Not a final commitment — a hypothesis to test. The decision should be proportional to what you know. Small bets when uncertain, bigger moves when the signal is clear." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_1c774f1210e8d7df a oc:WorkflowStep ;
    dcterms:description "**Rebuild from the ground up**: Given only the fundamental truths, what solutions are possible?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_42d57815f985a58e a oc:WorkflowStep ;
    dcterms:description "**Generate ideas**: List everything that would make the problem worse (more steps, jargon, hidden buttons, no feedback)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_433de4f5f5780636 a oc:WorkflowStep ;
    dcterms:description "**State the problem or assumption** you want to examine" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_5b401dd9bd441484 a oc:WorkflowStep ;
    dcterms:description "**Question each component**: Why does this have to be this way? Is this a law of physics or a convention?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_642334f25ea735b4 a oc:WorkflowStep ;
    dcterms:description "**Invert the problem**: \"How could we make onboarding as confusing as possible?\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_6b2d0e7bc41de018 a oc:WorkflowStep ;
    dcterms:description "**Evaluate**: Which reversed ideas are most promising?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_6b694f96b2e7cf80 a oc:WorkflowStep ;
    dcterms:description "**Orient**: Make sense of what you observed. This is the critical step. Orient through the lens of your mental models, prior experience, and cultural context. Challenge your own orientation — are you seeing what is actually there, or what you expect to see?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_98a1d35fa523aea7 a oc:WorkflowStep ;
    dcterms:description "**Act**: Execute the decision. Ship something. Run the experiment. Make the change. Then immediately return to Observe with new data." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_aac1884f13497aab a oc:WorkflowStep ;
    dcterms:description "**Reverse each idea**: Each \"make it worse\" idea contains the seed of a \"make it better\" solution" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_ae9d51825f6ae431 a oc:WorkflowStep ;
    dcterms:description "**Observe**: Gather raw signals — usage data, customer feedback, competitive moves, market shifts, support tickets. Do not filter yet. Cast wide." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_02b0c2d9711a6534 a oc:WorkflowStep ;
    dcterms:description "List every assumption the idea depends on — stated and unstated — across user, problem, solution, business, feasibility, and adoption categories" ;
    oc:expectedOutcome "Comprehensive list of assumptions with categorization" ;
    oc:stepId "list-assumptions" .

_:ref_0e23a1c7ddb921ee a oc:WorkflowStep ;
    dcterms:description "Diverge: generate many ideas without judgment, build on ideas, follow tangents, push past obvious first ideas, use frameworks systematically" ;
