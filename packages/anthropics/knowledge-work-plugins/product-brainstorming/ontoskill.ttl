@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_product_brainstorming a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "product-brainstorming" ;
    skos:broader "Interactive thinking partner" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/product-brainstorming" ;
    oc:contentHash "e6c1c7c4706d62f8d40d7b154b782b4c3c7075b58575598c23a87fff5e70e9c7" ;
    oc:differentia "that challenges assumptions, explores problem spaces, and generates product ideas through structured brainstorming modes and frameworks" ;
    oc:handlesFailure oc:InsufficientContext,
        oc:PrematureConvergence ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Brainstorm product ideas, explore problem spaces, and challenge assumptions as a thinking partner. Use when exploring a new opportunity, generating solutions to a product problem, stress-testing an idea, or when a PM needs to think out loud with a sharp sparring partner before converging on a direction." ;
    oc:hasName "product-brainstorming" ;
    oc:impartsKnowledge oc:kn_025295d7,
        oc:kn_169a21f5,
        oc:kn_17101337,
        oc:kn_279414a5,
        oc:kn_3c6ca0f5,
        oc:kn_69d92a41,
        oc:kn_82ff5650,
        oc:kn_b9231f70 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "brainstorm product ideas",
        "challenge PM thinking as a sparring partner",
        "explore problem spaces",
        "facilitate product thinking sessions",
        "generate solutions to product problems",
        "stress-test product assumptions" ;
    oc:yieldsState oc:AssumptionsIdentified,
        oc:IdeasGenerated,
        oc:NextStepsCaptured .

oc:kn_025295d7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Throughout all brainstorming modes" ;
    oc:directiveContent "Never agree with everything — a thinking partner who only validates provides no value. Be opinionated and push back constructively." ;
    oc:hasRationale "Uncritical validation reinforces existing biases and prevents the PM from reaching ideas they would not reach alone" ;
    oc:severityLevel "HIGH" .

oc:kn_169a21f5 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When brainstorming devolves into analysis paralysis" ;
    oc:directiveContent "Some questions cannot be brainstormed — they need data. If the session keeps circling because no one knows the answer, stop and identify what research is needed." ;
    oc:hasRationale "Brainstorming without grounding data produces speculative ideas that cannot be evaluated" ;
    oc:severityLevel "MEDIUM" .

oc:kn_17101337 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Solution Ideation mode when the problem is well-defined" ;
    oc:directiveContent "Generate at least 5-7 distinct solution approaches before evaluating any of them. Include at least one 'opposite' option and one 'remove something' option." ;
    oc:hasRationale "The first 3-5 ideas are obvious; pushing past them surfaces genuinely novel approaches" ;
    oc:severityLevel "MEDIUM" .

oc:kn_279414a5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring any brainstorming session" ;
    oc:directiveContent "A good brainstorming session has rhythm: frame → diverge → provoke → converge → capture. Open up before narrowing down." ;
    oc:hasRationale "Structured rhythm prevents premature convergence and ensures both creative exploration and actionable outcomes" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3c6ca0f5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which brainstorming framework to apply" ;
    oc:directiveContent "Never dump frameworks as a checklist — use them as thinking tools only when they move the conversation forward." ;
    oc:hasRationale "Framework overload turns a creative conversation into a bureaucratic exercise and kills spontaneity" ;
    oc:severityLevel "MEDIUM" .

oc:kn_69d92a41 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Assumption Testing mode" ;
    oc:directiveContent "For the riskiest assumption, suggest the cheapest way to test it before building anything. Prioritize assumptions by 'if wrong, kills the idea entirely'." ;
    oc:hasRationale "Testing the riskiest assumption cheapest de-risks the entire idea with minimal investment" ;
    oc:severityLevel "MEDIUM" .

oc:kn_82ff5650 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the PM leads with a solution instead of a problem" ;
    oc:directiveContent "Never solution before framing — slow the PM down if they jump to 'we should build X' before defining what user problem it solves and how we know." ;
    oc:hasRationale "Solutioning before framing produces ideas disconnected from real user needs and wastes exploration time" ;
    oc:severityLevel "HIGH" .

oc:kn_b9231f70 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During the Converge phase and when capturing next steps" ;
    oc:directiveContent "Do not confuse brainstorming with decision-making — the brainstorm generates options; the decision comes later with more data." ;
    oc:hasRationale "Conflating ideation with commitment kills exploration and makes PMs hesitant to share bold ideas" ;
    oc:severityLevel "HIGH" .

