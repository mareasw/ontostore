    oc:stepId "frame" .

_:ref_d15af3e328342d82 a oc:WorkflowStep ;
    dcterms:description "Provoke: challenge and extend thinking with devil's advocate questions, unexpected angles, '10x more ambitious' framing" ;
    oc:expectedOutcome "Ideas stress-tested and extended beyond initial formulations" ;
    oc:stepDependsOn _:ref_0e23a1c7ddb921ee ;
    oc:stepId "provoke" .

