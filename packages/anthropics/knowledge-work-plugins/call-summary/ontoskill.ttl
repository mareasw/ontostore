        oc:kn_994babd8 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:InputProvided ;
    oc:resolvesIntent "capture objections and next steps",
        "draft follow-up email after call",
        "extract action items from call",
        "generate internal call summary",
        "summarize call notes" ;
