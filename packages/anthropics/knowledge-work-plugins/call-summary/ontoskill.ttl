        oc:SummaryGenerated .

oc:kn_1cf0f0c5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting customer follow-up emails" ;
    oc:directiveContent "Never use markdown formatting (asterisks, bold, headers) in customer-facing follow-up emails — write in plain text that renders naturally in any email client." ;
    oc:hasRationale "Markdown syntax appears as raw text in most email clients, making the message look unprofessional." ;
    oc:severityLevel "HIGH" .

oc:kn_3dbc99fb a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When receiving input from user" ;
    oc:directiveContent "Accept three input modes: pasted rough notes, pasted full transcripts, or a described summary of what happened. Structure any of these into the same output format." ;
    oc:hasRationale "Users may have different levels of detail available — all modes should produce useful output." ;
    oc:severityLevel "LOW" .

oc:kn_5b15cb8f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When CRM, email, or transcript tools are connected" ;
    oc:directiveContent "When connectors are available, proactively offer to update CRM (log activity, update opportunity stage, create tasks), draft or send email, and pull transcript context." ;
    oc:hasRationale "The standalone output is valuable but connected tools turn the summary into actionable workflow updates across systems." ;
    oc:severityLevel "MEDIUM" .

oc:kn_70993216 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When receiving call notes or transcripts" ;
    oc:directiveContent "More detail in input yields better structured output. Even vague observations like 'they seemed concerned about X' provide valuable context for the summary." ;
    oc:hasRationale "The skill works by extracting and structuring information — richer input enables richer extraction." ;
    oc:severityLevel "MEDIUM" .

oc:kn_994babd8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any customer-facing email" ;
    oc:directiveContent "Customer-facing emails must be concise, scannable, and use simple structure — short paragraphs, plain dashes or numbers for lists, line breaks between sections." ;
    oc:hasRationale "Customers are busy; concise scannable emails get read and acted upon." ;
    oc:severityLevel "MEDIUM" .

_:ref_0a0e3b37ba152869 a oc:WorkflowStep ;
    dcterms:description "**Be concise but informative** — Get to the point quickly. Customers are busy." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_0d849d6564c9ead6 a oc:WorkflowStep ;
    dcterms:description "**Tell me the deal stage** — Helps me tailor the follow-up tone and next steps." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_5bd16bb700d2ca70 a oc:WorkflowStep ;
    dcterms:description "**Name the attendees** — Helps me structure the summary and assign action items." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_6c82c102ebffcb7f a oc:WorkflowStep ;
    dcterms:description "**Flag what matters** — If something was important, tell me: \"The big thing was...\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_90202cad5034ab18 a oc:WorkflowStep ;
    dcterms:description "**Use simple structure** — Short paragraphs, line breaks between sections. No headers or bullet formatting unless the customer's email client will render it." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_91d6993cb15d7045 a oc:WorkflowStep ;
    dcterms:description "**Keep it scannable** — If listing items, use plain dashes or numbers, not fancy formatting." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_de05515b70e72162 a oc:WorkflowStep ;
    dcterms:description "**More detail = better output** — Even rough notes help. \"They seemed concerned about X\" is useful context." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_dec8f5c686d0a3a6 a oc:WorkflowStep ;
    dcterms:description "**No markdown formatting** — Don't use asterisks, bold, or other markdown syntax. Write in plain text that looks natural in any email client." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_02b5e7f40ddbe40a a oc:WorkflowStep ;
    dcterms:description "Generate internal summary following the markdown template with attendees, call type, discussion points, action items table, next steps, and deal impact" ;
    oc:stepDependsOn _:ref_4aaa8d9d41aa8ed0 ;
    oc:stepId "generate-internal-summary" .

_:ref_1034ca99e482008e a oc:WorkflowStep ;
    dcterms:description "Accept call notes, transcript, or a description of the call" ;
    oc:expectedOutcome "Raw input captured for processing" ;
    oc:stepId "receive-input" .

_:ref_142e78f12606beac a oc:WorkflowStep ;
    dcterms:description "Draft a concise, plain-text customer follow-up email with key points discussed, commitments made, and clear next step with timeline" ;
    oc:expectedOutcome "Customer-ready follow-up email in plain text" ;
    oc:stepDependsOn _:ref_4aaa8d9d41aa8ed0 ;
    oc:stepId "draft-follow-up-email" .

