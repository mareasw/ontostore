    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_4aaa8d9d41aa8ed0 a oc:WorkflowStep ;
    dcterms:description "Extract key discussion points, decisions, customer priorities, objections, competitive intel, and action items with owners and due dates" ;
