oc:kn_83dab947 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no data connectors are available" ;
    oc:directiveContent "No connectors required — if calendar/CRM/email are not connected, ask user directly for meetings, deals, and urgents and work with whatever they provide" ;
    oc:hasRationale "Skill must deliver value standalone without any integrations" ;
    oc:severityLevel "HIGH" .

oc:kn_a9cf4f37 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any briefing format" ;
    oc:directiveContent "Output must be a scannable 2-minute briefing — concise, structured, action-oriented" ;
    oc:hasRationale "Sales professionals need fast consumption before their first meeting" .

oc:kn_c6bb41f6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining the top priority for the briefing" ;
    oc:directiveContent "Select #1 Priority: if meeting with >$50K deal today → prep that; if deal closing today → focus on close; if urgent email from buyer → respond first; else → highest-value stale deal" ;
    oc:hasRationale "Revenue proximity and time-sensitivity drive priority ranking" .

oc:kn_cad06012 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every briefing generation" ;
    oc:directiveContent "1. Gather context — pull calendar events, CRM pipeline, email priorities, enrichment signals if connectors available; otherwise ask user for meetings, deals, and urgents. 2. Prioritize — rank by: urgent closing deals > high-value meetings > unread from decision-makers > deals closing this week > stale deals > routine tasks. 3. Generate briefing — assemble sections based on available data, always include #1 Priority and Suggested Actions." ;
    oc:hasRationale "Three-step flow ensures briefings are data-driven, prioritized, and actionable regardless of connector availability" ;
    oc:stepOrder 1 .

oc:kn_fbac063c a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When advising user on connector setup priority" ;
    oc:directiveContent "Connect calendar first (biggest time saver), add CRM second (unlocks pipeline alerts), then email and enrichment for maximum value" ;
    oc:hasRationale "Incremental value ordering maximizes ROI on integration effort" .

_:ref_2157d02643e071ef a oc:WorkflowStep ;
    dcterms:description "**Even without connectors** — Just tell me your meetings and I'll help prioritize" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_3763940e17d52129 a oc:WorkflowStep ;
    dcterms:description "**Add CRM second** — Unlocks pipeline alerts" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_5d58030f86c12228 a oc:WorkflowStep ;
    dcterms:description "**Connect your calendar first** — Biggest time saver" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_a8c0fd0e5e1358a1 a oc:WorkflowStep ;
    dcterms:description "Pull data from connectors (calendar events, CRM pipeline, email priorities, enrichment signals) or prompt user for manual input" ;
    oc:expectedOutcome "All available context data collected" ;
    oc:stepId "gather-context" .

_:ref_dd8137c2756c9fe7 a oc:WorkflowStep ;
    dcterms:description "Rank items by priority: urgent closing deals > high-value meetings > decision-maker emails > weekly closes > stale deals > routine tasks. Select #1 priority." ;
    oc:expectedOutcome "Ordered priority list with #1 priority identified" ;
    oc:stepDependsOn _:ref_a8c0fd0e5e1358a1 ;
    oc:stepId "prioritize" .

_:ref_f192ca87f6a7bd81 a oc:Workflow ;
