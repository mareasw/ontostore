@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_daily_briefing a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "daily-briefing" ;
    skos:broader "briefing generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/daily-briefing" ;
    oc:contentHash "7f19d0b46a1fb57e458eee6a30aae41739d029b1979abf6060a68bd44a8770f7" ;
    oc:dependsOnSkill oc:skill_account_research,
        oc:skill_call_prep ;
    oc:differentia "aggregates calendar, CRM, email, and enrichment data into a prioritized daily sales action plan with multiple output modes" ;
    oc:handlesFailure oc:APIKeySet,
        oc:InvalidInput ;
    oc:hasAlias "daily brief",
        "end of day summary",
        "morning briefing",
        "prep my day",
        "quick brief",
        "start my day",
        "tldr my day",
        "what's on my plate today",
        "wrap up my day" ;
    oc:hasArgumentHint "Optional: \"quick brief\" for abbreviated mode, \"wrap up my day\" for end-of-day mode, or just trigger for full briefing" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Start your day with a prioritized sales briefing. Works standalone when you tell me your meetings and priorities, supercharged when you connect your calendar, CRM, and email. Trigger with \"morning briefing\", \"daily brief\", \"what's on my plate today\", \"prep my day\", or \"start my day\"." ;
    oc:hasName "daily-briefing" ;
    oc:impartsKnowledge oc:kn_3411f2f1,
        oc:kn_4d318945,
        oc:kn_4db4cce3,
        oc:kn_6b265a4f,
        oc:kn_fca21d7c ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "end of day summary and wrap-up",
        "generate daily sales briefing",
        "get morning briefing summary",
        "prioritize daily meetings and deals",
        "quick brief for the day" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_3411f2f1 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During Step 2 prioritization of all gathered context" ;
    oc:directiveContent "Priority ranking order: URGENT (deal closing today/tomorrow not yet won) > HIGH (meeting with high-value opportunity, unread email from decision-maker) > MEDIUM (deal closing this week, stale deal 7+ days) > LOW (tasks due this week). For #1 Priority: >$50K deal meeting today wins, then closing deal, then urgent buyer email, then highest-value stale deal." ;
    oc:hasRationale "Ensures the briefing surfaces the most revenue-critical actions first, preventing sales reps from losing deals due to poor prioritization" ;
    oc:severityLevel "HIGH" .

oc:kn_4d318945 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining output format based on user trigger phrase" ;
    oc:directiveContent "Support three output modes: Full Briefing (default), Quick Brief (triggered by 'quick brief' or 'tldr my day'), and End of Day (triggered by 'wrap up my day' or 'end of day summary'). Each mode has its own distinct output format optimized for the time of day and user need." ;
    oc:hasRationale "Different moments in the sales day require different information density — morning needs full context, midday needs quick scan, evening needs wrap-up" ;
    oc:severityLevel "MEDIUM" .

oc:kn_4db4cce3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, during initial data gathering phase" ;
    oc:directiveContent "The skill must work standalone with user-provided information and get richer when connectors (Calendar, CRM, Email, Enrichment) are available. Never block on missing connectors — gracefully degrade by asking the user for manual input." ;
    oc:hasRationale "Ensures the skill delivers value immediately without requiring setup, while incentivizing tool connections for richer output" ;
    oc:severityLevel "CRITICAL" .

oc:kn_6b265a4f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assembling the final briefing output" ;
    oc:directiveContent "Do not generate empty sections in the briefing. If a data source is unavailable, omit the corresponding section entirely rather than showing blank tables or placeholder text." ;
    oc:hasRationale "Empty sections signal broken functionality and reduce trust in the briefing quality" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fca21d7c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Step 3 briefing assembly based on available data sources" ;
    oc:directiveContent "Always include #1 Priority and Suggested Actions sections even with minimal data. Conditionally include Today's Numbers and Pipeline Alerts only if CRM is connected, and Email Priorities only if email is connected." ;
    oc:hasRationale "Guarantees a minimum viable briefing that still provides value, while avoiding empty sections that undermine credibility" ;
    oc:severityLevel "HIGH" .

