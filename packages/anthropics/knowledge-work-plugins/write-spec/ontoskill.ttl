@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_write_spec a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "write-spec" ;
    skos:broader "document generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/write-spec" ;
    oc:contentHash "46ceb47d25ef44dff1c302a42367283ead256d4054c2b29a4e92b18db6f6b158" ;
    oc:differentia "produces structured product requirements documents from vague ideas, problem statements, or feature requests through conversational elicitation and contextual research" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<feature or problem statement>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Write a feature spec or PRD from a problem statement or feature idea. Use when turning a vague idea or user request into a structured document, scoping a feature with goals and non-goals, defining success metrics and acceptance criteria, or breaking a big ask into a phased spec." ;
    oc:hasName "write-spec" ;
    oc:impartsKnowledge oc:kn_0bddf979,
        oc:kn_27e4f540,
        oc:kn_52c023f5,
        oc:kn_6573d91a,
        oc:kn_78f524e0,
        oc:kn_ca92da5b,
        oc:kn_de82d7cf ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "break a large ask into a phased specification",
        "create a PRD",
        "define feature requirements with goals and non-goals",
        "scope a feature with success metrics and acceptance criteria",
        "turn an idea into a structured spec",
        "write a feature spec" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0bddf979 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any PRD" ;
    oc:directiveContent "Non-goals are as important as goals and must be explicitly listed (3-5 items) with rationale for why each is out of scope." ;
    oc:hasRationale "Non-goals prevent scope creep during implementation and set clear expectations with stakeholders" .

oc:kn_27e4f540 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining success metrics in the PRD" ;
    oc:directiveContent "Success metrics must include both leading indicators (adoption rate, task completion, error rate) and lagging indicators (retention, revenue, NPS) with specific targets and measurement methods." ;
    oc:hasRationale "Specific, dual-horizon metrics enable teams to evaluate feature impact both immediately and over time" .

oc:kn_52c023f5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing user stories in the PRD" ;
    oc:directiveContent "Never write solution-prescriptive user stories ('As a user, I want a dropdown menu') — describe the user need, not the UI implementation. Avoid vague stories without specific benefit statements." ;
    oc:hasRationale "Solution-prescriptive stories constrain design decisions prematurely; vague stories cannot be estimated or tested" ;
    oc:severityLevel "HIGH" .

oc:kn_6573d91a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During the context-gathering phase (Step 2)" ;
    oc:directiveContent "Gather context conversationally — ask the most important questions first and fill in gaps incrementally rather than dumping all questions at once." ;
    oc:hasRationale "Conversational elicitation reduces user fatigue and allows the agent to prioritize based on early answers" .

oc:kn_78f524e0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When categorizing requirements by priority" ;
    oc:directiveContent "Challenge every P0 requirement: 'If we cut this, does the feature still solve the core problem?' If everything is P0, nothing is P0." ;
    oc:hasRationale "Inflated must-have lists slow shipping and dilute focus; ruthless prioritization accelerates learning" .

oc:kn_ca92da5b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating the PRD document" ;
    oc:directiveContent "Check for connected tools (project tracker, knowledge base, design) and pull relevant context before generating the PRD. If tools are not connected, proceed with available information without asking the user to connect them." ;
    oc:hasRationale "Leveraging connected tools enriches the spec with existing artifacts, but blocking on unavailable tools wastes time" .

oc:kn_de82d7cf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoping any feature specification" ;
    oc:directiveContent "Be opinionated about scope — a tight, well-defined spec is better than an expansive vague one. If the idea is too big, suggest breaking it into phases and spec only the first phase." ;
    oc:hasRationale "Tight scoping prevents scope creep and ensures the team ships and learns faster" .

