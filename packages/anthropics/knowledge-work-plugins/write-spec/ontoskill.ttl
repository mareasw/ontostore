oc:kn_0d3a1e31 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any PRD" ;
    oc:directiveContent "Be opinionated about scope — a tight, well-defined spec is better than an expansive vague one. If the idea is too big, suggest breaking it into phases and spec the first phase." ;
    oc:hasRationale "Tight scope prevents scope creep and accelerates learning" .

oc:kn_30f7059f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When categorizing requirements" ;
    oc:directiveContent "Requirements must be categorized by priority: P0 (Must-Have — feature cannot ship without), P1 (Nice-to-Have — improves experience), P2 (Future Considerations — out of scope but guides design). If everything is P0, nothing is P0." ;
    oc:hasRationale "Clear prioritization enables faster shipping and learning by forcing hard trade-off decisions" ;
    oc:severityLevel "HIGH" .

oc:kn_35ff727a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During context gathering phase" ;
    oc:directiveContent "Gather context conversationally — ask the most important questions first, fill gaps incrementally. Do not dump all questions at once. If connected tools (project tracker, knowledge base, design) are available, pull related artifacts automatically; if not, proceed with user-provided info." ;
    oc:hasRationale "Conversational gathering reduces user fatigue and builds rapport; connected tools enrich the spec without requiring extra user effort" .

oc:kn_62d747fb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoping any feature" ;
    oc:directiveContent "Non-goals are as important as goals — write 3-5 explicit non-goals with rationale to prevent scope creep. Any scope addition must come with a scope removal or timeline extension." ;
    oc:hasRationale "Non-goals set stakeholder expectations and protect the team during implementation" .

oc:kn_6b0a03fd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Goals and Success Metrics sections" ;
    oc:directiveContent "Avoid vague goals like 'improve user experience' — goals must be specific, measurable outcomes tied to user or business metrics. Goals should be outcomes ('reduce time to first value by 50%') not outputs ('build onboarding wizard')." ;
    oc:hasRationale "Vague goals are untestable and provide no guidance for implementation trade-offs" ;
    oc:severityLevel "HIGH" .

oc:kn_887566be a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating the PRD output" ;
    oc:directiveContent """## Problem Statement
{2-3 sentences: user problem, who is affected, cost of not solving}

## Goals
- {3-5 measurable outcomes tied to metrics}

## Non-Goals
- {3-5 out-of-scope items with rationale}

## User Stories
### {Persona}
- As a {user type}, I want {capability} so that {benefit}

## Requirements
### Must-Have (P0)
- {requirement} — Acceptance: {Given/When/Then}
### Nice-to-Have (P1)
- {requirement}
### Future (P2)
- {requirement}

## Success Metrics
### Leading Indicators
- {metric}: {target} by {date}
### Lagging Indicators
- {metric}: {target}

## Open Questions
- {question} — @who (blocking/non-blocking)

## Timeline
- Hard deadlines: {dates}
- Dependencies: {deps}
- Phasing: {phases}""" ;
    oc:templateVariables "Acceptance",
        "Goals",
        "Non-Goals",
        "Persona",
        "Problem Statement",
        "Requirements",
        "User Stories",
        "benefit",
        "capability",
        "date",
        "dates",
        "deps",
        "metric",
        "phases",
        "question",
        "target",
        "user type",
        "who" .

oc:kn_d4c2caf2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing user stories" ;
    oc:directiveContent "Do not write user stories that are too vague ('product should be faster'), solution-prescriptive ('I want a dropdown menu'), lack benefit ('I want to click a button'), too large ('manage my team'), or internally focused ('refactor the database')." ;
    oc:hasRationale "Bad user stories lead to unclear requirements, wrong solutions, or scope that can't be estimated" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f4532116 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing acceptance criteria for requirements" ;
    oc:codeLanguage "gherkin" ;
    oc:directiveContent """Given [precondition]
When [action]
Then [expected outcome]""" .

oc:kn_fff58781 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing the write-spec skill" ;
    oc:directiveContent "1. Accept feature name/problem/user request/vague idea → 2. Gather context conversationally (problem, users, metrics, constraints, prior art) → 3. Pull from connected tools if available → 4. Generate PRD (Problem Statement, Goals, Non-Goals, User Stories, Requirements P0/P1/P2, Success Metrics, Open Questions, Timeline) → 5. Review and iterate with user" ;
    oc:stepOrder 1 .

_:ref_2a4ad744cd124aff a oc:WorkflowStep ;
    dcterms:description "Gather context from user conversationally — user problem, target users, success metrics, constraints, prior art" ;
    oc:expectedOutcome "Sufficient context to write a well-grounded PRD" ;
