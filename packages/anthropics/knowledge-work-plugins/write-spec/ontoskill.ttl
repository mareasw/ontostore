                            oc:contentOrder 6 ;
                            oc:textContent "**Checklist format**:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Given/When/Then**:" ],
                        [ a oc:Paragraph ;
