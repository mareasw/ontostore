                                            oc:itemOrder 5 ;
                                            oc:itemText "Stakeholders add requirements without removing anything" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "\"Small\" additions accumulate into a significantly larger project" ],
                                        [ a oc:BulletItem ;
