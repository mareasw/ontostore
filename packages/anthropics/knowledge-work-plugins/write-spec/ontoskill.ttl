_:ref_59d0e90d3ec1900c a oc:WorkflowStep ;
    dcterms:description "Generate the PRD with Problem Statement, Goals, Non-Goals, User Stories, Requirements, Success Metrics, Open Questions, Timeline Considerations" ;
    oc:expectedOutcome "A structured, complete PRD document in markdown" ;
    oc:stepDependsOn _:ref_5ae55c8544610483 ;
    oc:stepId "generate-prd" .

_:ref_5ae55c8544610483 a oc:WorkflowStep ;
