        oc:kn_fdb2596d ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:FileExists ;
    oc:resolvesIntent "configure signing order and signers",
        "prepare contract for signing",
        "route document for electronic or wet signature",
        "send document for e-signature",
        "verify document completeness before signature" ;
    oc:yieldsState oc:DocumentRoutedForSignature .

oc:kn_163d120d a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After Step 4 completion" ;
    oc:directiveContent "Signature request is successful when the document has been sent via the e-signature platform, or a complete signing instruction document has been generated for manual routing." .

oc:kn_1c85aa70 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing signature blocks before sending" ;
    oc:directiveContent "The most common signing error is incorrect legal entity names on signature blocks — always verify entity names character by character." ;
    oc:hasRationale "Incorrect entity names can render a contract unenforceable or create ambiguity about which legal entity is bound." ;
    oc:severityLevel "HIGH" .

oc:kn_2de39d34 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """## Signature Request: {Document Title}
### Document Details
- **Type**: {type}
- **Parties**: {Party A} and {Party B}
- **Pages**: {X}
### Pre-Signature Check: {PASS / ISSUES FOUND}
{issues list}
### Signing Configuration
| Order | Signer | Email | Role |
| 1 | {Name} | {email} | {role} |
### CC Recipients
- {Name} — {email}
### Status
{status}
### Next Steps
- {expectations}
- {turnaround}
- {follow-up}""" ;
    oc:templateVariables "Document Title",
        "Name",
        "PASS / ISSUES FOUND",
        "Party A",
        "Party B",
        "X",
        "email",
        "expectations",
        "follow-up",
        "issues list",
        "role",
        "status",
        "turnaround",
        "type" .

oc:kn_4ec3bf3d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before routing any document for signature" ;
    oc:directiveContent "Never send a document for signature that has open redlines or is not in final agreed form." ;
    oc:hasRationale "Sending incomplete or non-final documents for signature creates legal risk and can result in executing the wrong version." ;
    oc:severityLevel "CRITICAL" .

oc:kn_571e7c59 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Accept document (PDF, DOCX, URL, or reference) 2. Run pre-signature checklist (final form, exhibits, entity names, dates, authority, approvals, counsel review) 3. Configure signing (signers, order, internal approvals, CC recipients) 4. Route for signature via e-signature platform or manual signing instructions" ;
    oc:stepOrder 1 .

oc:kn_5ee2a09a a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When e-signature connector is not available" ;
    oc:directiveContent "If no e-signature platform is connected, generate a signing instruction document with all signer contact information formatted for wet signature or manual e-sign." ;
    oc:hasRationale "Ensures the workflow can proceed even without electronic signing tools, maintaining document execution timelines." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ea14ac0c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring signers" ;
    oc:directiveContent "Verify that each signer is authorized to bind their organization before adding them to the signing order." ;
    oc:hasRationale "Unauthorized signers create voidable contracts and potential disputes about enforceability." ;
    oc:severityLevel "HIGH" .

oc:kn_f3c06895 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "This skill assists with legal workflows but does not provide legal advice. Documents must be in final form before sending." ;
    oc:hasRationale "AI cannot replace legal judgment; human verification of final document form is a mandatory safeguard." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fdb2596d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before routing for signature" ;
    oc:directiveContent "Verify all 7 pre-signature checklist items: (1) final form with no open redlines, (2) all exhibits/schedules attached, (3) correct entity names, (4) dates correct or blank, (5) signature blocks match signers, (6) internal approvals obtained, (7) counsel review complete." ;
    oc:hasRationale "Catching issues before sending prevents re-work, delays, and potential legal complications from incorrectly executed documents." ;
    oc:severityLevel "HIGH" .

_:ref_21ea91ca6a0d802b a oc:WorkflowStep ;
    dcterms:description "**Verify authority** — Make sure each signer is authorized to bind their organization." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_982bbf9b31f3808e a oc:WorkflowStep ;
    dcterms:description "**Check entity names carefully** — The most common signing error is incorrect legal entity names." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_b45b10a135934a69 a oc:WorkflowStep ;
    dcterms:description "**Keep a copy** — Executed copies should be filed in ~~cloud storage or ~~CLM immediately after execution." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_34ab8311b51351b0 a oc:WorkflowStep ;
    dcterms:description "Gather signing details: signers (names, emails, titles), signing order (sequential or parallel), internal approvals, and CC recipients" ;
    oc:expectedOutcome "Complete signing configuration with all signer details captured" ;
    oc:stepDependsOn _:ref_d456a55ef4952065 ;
    oc:stepId "configure-signing" .

_:ref_6dc6210cd49771b2 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_21ea91ca6a0d802b,
        _:ref_982bbf9b31f3808e,
        _:ref_b45b10a135934a69 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_9302a0642972e646 a oc:WorkflowStep ;
    dcterms:description "Accept the document in any format (PDF, DOCX upload, URL to cloud storage/CLM, or reference by name)" ;
    oc:expectedOutcome "Document is loaded and ready for pre-signature review" ;
    oc:stepId "accept-document" .

_:ref_d456a55ef4952065 a oc:WorkflowStep ;
    dcterms:description "Run pre-signature checklist: verify final form, exhibits attached, correct entity names, dates, signature blocks, internal approvals, and counsel review" ;
    oc:expectedOutcome "All checklist items pass or issues are flagged for resolution" ;
    oc:stepDependsOn _:ref_9302a0642972e646 ;
    oc:stepId "pre-signature-check" .

