@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_policy_lookup a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "policy-lookup" ;
    skos:broader "Knowledge retrieval system" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/policy-lookup" ;
    oc:contentHash "d206e2b8f6a0ffadcd5cf6c05af70c842d46b93d38e9133b413527424408bef0" ;
    oc:differentia "that searches connected knowledge bases and explains company policies in plain language with source citation" ;
    oc:handlesFailure oc:FileNotFound,
        oc:NetworkTimeout ;
    oc:hasArgumentHint "<policy topic — PTO, benefits, travel, expenses, etc.>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Find and explain company policies in plain language. Trigger with \"what's our PTO policy\", \"can I work remotely from another country\", \"how do expenses work\", or any plain-language question about benefits, travel, leave, or handbook rules." ;
    oc:hasName "policy-lookup" ;
    oc:impartsKnowledge oc:kn_5b871055,
        oc:kn_5d367cd8,
        oc:kn_678781cb,
        oc:kn_d8d54d72,
        oc:kn_fb909d0c ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "answer employee policy questions",
        "explain benefits and leave policies",
        "find company policies",
        "look up handbook rules",
        "search for PTO and remote work policies" ;
    oc:yieldsState oc:PolicyAnswered .

oc:kn_5b871055 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When search returns no results for a policy topic" ;
    oc:directiveContent "Never guess or fabricate policy information if no matching policy is found — say so clearly." ;
    oc:hasRationale "Fabricated policy answers could lead to compliance violations or employee decisions based on false information." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5d367cd8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the question involves legal interpretation or compliance requirements" ;
    oc:directiveContent "For legal or compliance questions, recommend consulting HR or legal directly rather than providing a definitive answer." ;
    oc:hasRationale "AI-generated legal guidance is not authoritative and could create liability if acted upon." ;
    oc:severityLevel "CRITICAL" .

oc:kn_678781cb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting any policy lookup response" ;
    oc:directiveContent "Structure answers with a quick 1-2 sentence direct answer first, then detailed explanation, exceptions, contact info, and source." ;
    oc:hasRationale "Employees want fast answers; leading with the direct response respects their time while preserving completeness." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d8d54d72 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user provides a vague or overly abstract policy query" ;
    oc:directiveContent "Plain-language specific queries like 'Can I work from Europe for a month?' yield better results than abstract ones like 'international remote work policy.'" ;
    oc:hasRationale "Specific queries match more relevant policy sections and reduce ambiguity in interpretation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fb909d0c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When answering any policy question" ;
    oc:directiveContent "Always cite the source document and section when providing policy answers." ;
    oc:hasRationale "Source citation enables employees to verify information and HR to correct inaccuracies." ;
    oc:severityLevel "HIGH" .

