    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "answer employee policy questions",
        "check remote work or travel policy",
        "explain PTO benefits leave",
        "find company policy",
        "look up handbook rules" ;
    oc:yieldsState oc:DocumentRetrieved,
        oc:PolicyExplained .

oc:kn_4b6c92f9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When answering any policy question" ;
    oc:directiveContent "Always cite the source document and section when providing policy answers. Never guess or fabricate policy content." ;
    oc:hasRationale "Employees rely on accurate policy information for decisions; fabricated answers could lead to compliance violations or incorrect employee actions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_6ef77c60 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When helping users formulate policy questions" ;
    oc:directiveContent "Encourage users to ask in plain natural language and be specific about jurisdiction, employment type, or location for better results." ;
    oc:hasRationale "Specific queries like 'PTO for part-time employees in California' yield more targeted answers than vague ones like 'PTO policy'" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8c7c1195 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When search returns no results" ;
    oc:directiveContent "If no matching policy is found, say so clearly rather than inferring or guessing the answer." ;
    oc:hasRationale "Guessing about policies can mislead employees into taking actions that violate actual company rules" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9b4836b6 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When evaluating the completeness of a policy answer" ;
    oc:directiveContent "A successful policy lookup includes a direct answer, supporting details from the source, noted exceptions, and a contact for edge cases." ;
    oc:hasRationale "Complete answers reduce follow-up questions and ensure employees have all actionable information" .

oc:kn_b0c0ab60 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the question involves legal interpretation or compliance requirements" ;
    oc:directiveContent "For legal or compliance questions, recommend consulting HR or legal directly rather than providing a definitive answer." ;
    oc:hasRationale "Policy lookup is informational only; legal and compliance matters require professional guidance" ;
    oc:severityLevel "HIGH" .

oc:req_06a838a9 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Employee handbook or policy documents" .

oc:req_089b6295 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "HRIS system for employee-specific data" .

oc:req_ee2a70ee a oc:RequirementTool ;
