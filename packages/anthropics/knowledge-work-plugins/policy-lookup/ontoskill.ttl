oc:skill_knowledge_work_plugins_policy_lookup a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "policy-lookup" ;
    skos:broader "Policy information retrieval system" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/policy-lookup" ;
    oc:contentHash "d206e2b8f6a0ffadcd5cf6c05af70c842d46b93d38e9133b413527424408bef0" ;
    oc:differentia "searches connected knowledge bases and HRIS to answer employee policy questions in plain language with source citations" ;
    oc:extends oc:skill_ontoskills_search ;
    oc:handlesFailure oc:DocumentNotFound,
        oc:SearchReturnedNoResults ;
    oc:hasArgumentHint "<policy topic — PTO, benefits, travel, expenses, etc.>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Find and explain company policies in plain language. Trigger with \"what's our PTO policy\", \"can I work remotely from another country\", \"how do expenses work\", or any plain-language question about benefits, travel, leave, or handbook rules." ;
    oc:hasName "policy-lookup" ;
    oc:hasRequirement oc:req_06a838a9,
        oc:req_089b6295,
        oc:req_ee2a70ee ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: policy-lookup
description: Find and explain company policies in plain language. Trigger with "what's our PTO policy", "can I work remotely from another country", "how do expenses work", or any plain-language question about benefits, travel, leave, or handbook rules.
argument-hint: "<policy topic — PTO, benefits, travel, expenses, etc.>"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Look up and explain company policies in plain language. Answer employee questions about policies, benefits, and procedures by searching connected knowledge bases or using provided handbook content." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent _:ref_70e4b0a6b2badfdc ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Tips" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Always cite the source document and section" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "For legal or compliance questions, recommend consulting HR or legal directly" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "If no policy is found, say so clearly rather than guessing" ] ],
                        _:ref_682018ae2bf4d1e8,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Important guardrails:**" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "How to Answer" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Search for policies matching: $ARGUMENTS" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/policy-lookup $ARGUMENTS
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 15-17" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Usage" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Remote Work**: WFH policy, remote locations, equipment stipend, coworking" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "**Growth**: Professional development budget, conference policy, tuition reimbursement" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Travel**: Booking policy, per diem, expense reporting, approval process" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Compensation**: Pay schedule, bonus timing, equity vesting, expense reimbursement" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Conduct**: Code of conduct, harassment policy, conflicts of interest" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Benefits**: Health insurance, dental, vision, 401k, HSA/FSA, wellness" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**PTO and Leave**: Vacation, sick leave, parental leave, bereavement, sabbatical" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Common Policy Topics" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Cite the specific document, section, and page number" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Search employee handbook and policy documents automatically" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Pull employee-specific details like PTO balance, benefits elections, and enrollment status" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "If **~~HRIS** is connected:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "If **~~knowledge base** is connected:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "If Connectors Available" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """┌─────────────────────────────────────────────────────────────────┐
│                    POLICY LOOKUP                                   │
├─────────────────────────────────────────────────────────────────┤
│  STANDALONE (always works)                                       │
│  ✓ Ask any policy question in plain language                    │
│  ✓ Paste your employee handbook and I'll search it              │
│  ✓ Get clear, jargon-free answers                               │
├─────────────────────────────────────────────────────────────────┤
│  SUPERCHARGED (when you connect your tools)                      │
│  + Knowledge base: Search handbook and policy docs automatically │
│  + HRIS: Pull employee-specific details (PTO balance, benefits) │
└─────────────────────────────────────────────────────────────────┘
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 23-36" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "How It Works" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """## Policy: [Topic]

### Quick Answer
[1-2 sentence direct answer to their question]

### Details
[Relevant policy details, explained in plain language]

### Exceptions / Special Cases
[Any relevant exceptions or edge cases]

### Who to Contact
[Person or team for questions beyond what's documented]

### Source
[Where this information came from — document name, page, or section]
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 63-80" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Output" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "/policy-lookup" ] ;
