                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Natural language questions** (e.g., \"What is the deadline for project X?\") — Best for fuzzy, conceptual searches where you don't know exact keywords." ] ] ;
