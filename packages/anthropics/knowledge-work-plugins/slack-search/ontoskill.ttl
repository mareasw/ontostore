    dcterms:description "If too few results, remove filters and try synonyms or related terms." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_b0268293ead287c9 a oc:WorkflowStep ;
    dcterms:description "If too many results, add filters (`in:`, `from:`, date ranges)." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_d749980a414b61f2 a oc:WorkflowStep ;
    dcterms:description "Begin with a simple keyword or natural language question." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_9d5feca9ce57a089 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
