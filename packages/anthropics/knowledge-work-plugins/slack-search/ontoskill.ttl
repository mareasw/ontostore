                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Use `slack_read_channel` with `oldest`/`latest` timestamps to read surrounding messages for context." ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "After finding relevant messages:" ] ;
