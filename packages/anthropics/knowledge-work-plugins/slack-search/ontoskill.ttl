@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_slack_search a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "slack-search" ;
    skos:broader "search methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/slack-search" ;
    oc:contentHash "18bf191ca0d451cc121d76755f807bdc607f6c276be0acaf068cec8aafc32cba" ;
    oc:differentia "provides structured guidance for querying Slack messages, files, channels, and people using modifiers, filters, and multi-strategy search patterns" ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied,
        oc:SearchReturnedNoResults ;
    oc:hasAllowedTool "slack_read_channel",
        "slack_read_thread",
        "slack_read_user_profile",
        "slack_search_channels",
        "slack_search_public",
        "slack_search_public_and_private",
        "slack_search_users" ;
    oc:hasArgumentHint "search query with optional modifiers (e.g., 'project X deadline in:#engineering from:@alice after:2025-01-01')" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Guidance for effectively searching Slack to find messages, files, channels, and people" ;
    oc:hasName "slack-search" ;
    oc:hasRequirement oc:req_0a2d0167,
        oc:req_18df69b5,
        oc:req_37bf0935,
        oc:req_579699a2,
        oc:req_5b017c60,
        oc:req_79c8400c,
        oc:req_85b71719 ;
    oc:impartsKnowledge oc:kn_42bcc42b,
        oc:kn_88f7707a,
        oc:kn_8dd24aad,
        oc:kn_a54908c3,
        oc:kn_ce541e4c,
        oc:kn_d9162eb9,
        oc:kn_dccf41c8 ;
    oc:isUserInvocable true ;
    oc:nature "concept" ;
    oc:requiresState oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "find files in slack",
        "find people on slack",
        "find slack channels",
        "locate information in slack conversations",
        "search slack messages" ;
    oc:yieldsState oc:SlackSearchCompleted .

oc:kn_42bcc42b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing any Slack search query" ;
    oc:directiveContent "Never use Boolean operators (AND, OR, NOT) or parentheses in Slack search queries — they are not supported. Use spaces for implicit AND and minus sign (-) for exclusion." ;
    oc:hasRationale "Boolean operators and parentheses will be treated as literal text, producing incorrect or empty results" ;
    oc:severityLevel "HIGH" .

oc:kn_88f7707a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any Slack search" ;
    oc:directiveContent "Determine whether the search needs private channel/DM access before choosing between slack_search_public and slack_search_public_and_private, and obtain user consent for the latter." ;
    oc:hasRationale "Choosing the wrong tool upfront means missing relevant private results or failing to obtain necessary consent" .

oc:kn_8dd24aad a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When searching for messages that were just posted" ;
    oc:directiveContent "Slack search is not real-time — very recent messages (last few seconds) may not appear in search results. Use slack_read_channel for the most recent messages instead." ;
    oc:hasRationale "Search indexing has a small delay, so relying on search for real-time messages will produce false negatives" .

oc:kn_a54908c3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning any Slack search task" ;
    oc:directiveContent "Start with a broad, simple keyword or natural language query, then iteratively narrow with filters (in:, from:, date ranges) if too many results, or broaden with synonyms if too few." ;
    oc:hasRationale "Iterative refinement avoids both overwhelming results and missed information from overly narrow initial queries" .

oc:kn_ce541e4c a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When answering complex or multi-faceted questions using Slack data" ;
    oc:directiveContent "Break complex questions into multiple smaller searches: first search for the topic, then for specific people's contributions, then in specific channels, rather than trying one monolithic query." ;
    oc:hasRationale "Slack search lacks Boolean grouping and complex query support, so decomposition into multiple targeted searches yields more complete results" .

oc:kn_d9162eb9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When search scope requires private channel or DM access" ;
    oc:directiveContent "Use slack_search_public_and_private (not slack_search_public) when private channels, DMs, or group DMs must be included, and always request user consent before doing so." ;
    oc:hasRationale "Private channel search requires explicit user consent for privacy compliance; using the wrong tool silently omits relevant results" .

oc:kn_dccf41c8 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After search results are returned" ;
    oc:directiveContent "After finding relevant messages, follow up with slack_read_thread for full thread context, slack_read_channel with oldest/latest timestamps for surrounding messages, and slack_read_user_profile to identify unfamiliar user IDs." ;
    oc:hasRationale "Search results are summaries; full context is needed to accurately interpret and act on found messages" .

oc:req_0a2d0167 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "slack_search_public" .

oc:req_18df69b5 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "slack_read_user_profile" .

oc:req_37bf0935 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "slack_search_channels" .

oc:req_579699a2 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "slack_search_public_and_private" .

oc:req_5b017c60 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "slack_read_channel" .

oc:req_79c8400c a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "slack_search_users" .

oc:req_85b71719 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "slack_read_thread" .

