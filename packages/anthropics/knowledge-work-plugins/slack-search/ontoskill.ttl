oc:kn_057f42c0 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When searching for very recent Slack messages" ;
    oc:directiveContent "Slack search is not real-time — very recent messages (last few seconds) may not appear. Use slack_read_channel for the most recent messages instead." ;
    oc:hasRationale "Search indexing has a small delay; direct channel reads bypass the index" ;
    oc:severityLevel "MEDIUM" .

oc:kn_22bce857 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When answering complex questions that require Slack context" ;
    oc:directiveContent "Break complex questions into multiple smaller searches: search the topic first, then specific people's contributions, then specific channels." ;
    oc:hasRationale "Multiple targeted searches capture more relevant context than a single broad query" ;
    oc:severityLevel "MEDIUM" .

oc:kn_38bd5aef a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When searching for files in Slack" ;
    oc:directiveContent """Use content_types="files" with type filters (type:images, type:documents, type:pdfs, type:spreadsheets, type:canvases) for file-specific searches.
Example: content_types="files" type:pdfs budget after:2025-01-01""" ;
    oc:templateVariables "content_types",
        "date_filter",
        "query",
        "type" .

oc:kn_5102dc5e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formulating any Slack search strategy" ;
    oc:directiveContent "Start with a broad keyword or natural language question, then narrow with filters (in:, from:, date ranges) if too many results, or broaden with synonyms if too few." ;
    oc:hasRationale "Iterative refinement yields better results than trying to construct a perfect query upfront" ;
    oc:severityLevel "MEDIUM" .

oc:kn_756e2f84 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing Slack search modifier expressions" ;
    oc:directiveContent """Location: in:channel-name, in:<#C123456>, -in:channel-name, in:<@U123456>
User: from:<@U123456>, from:username, to:me
Content: is:thread, has:pin, has:link, has:file, has::emoji:
Date: before:YYYY-MM-DD, after:YYYY-MM-DD, on:YYYY-MM-DD, during:month
Text: "exact phrase", -word, wild*""" .

oc:kn_82c4ceb8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing any Slack search query" ;
    oc:directiveContent "Never use Boolean operators (AND, OR, NOT) or parentheses in Slack search queries — they are not supported. Use spaces for implicit AND and -prefix for exclusion." ;
    oc:hasRationale "Slack search does not parse Boolean logic; using these operators will return incorrect or zero results" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9aafc4bf a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing any Slack search task" ;
    oc:directiveContent "1. Choose appropriate search tool (public vs public+private vs channels vs users) 2. Start with broad keyword/natural language query 3. Narrow with modifiers (in:, from:, before:/after:, has:, is:) if too many results 4. Follow up with slack_read_thread, slack_read_channel, or slack_read_user_profile for context" ;
    oc:stepOrder 1 .

oc:kn_aa3008df a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When searching non-public Slack content" ;
    oc:directiveContent "slack_search_public_and_private requires user consent before searching private channels, DMs, and group DMs." ;
    oc:hasRationale "Privacy controls ensure users explicitly authorize access to sensitive conversation data" ;
    oc:severityLevel "HIGH" .

oc:kn_ce407ff3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding search query format" ;
    oc:directiveContent "Choose natural language questions for fuzzy conceptual searches where exact keywords are unknown; use keyword search for finding specific exact content." ;
    oc:hasRationale "Matching query style to information need maximizes search effectiveness" ;
    oc:severityLevel "LOW" .

