                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Search Strategy" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Apply this skill whenever you need to find information in Slack — including when a user asks you to locate messages, conversations, files, or people, or when you need to gather context before answering a question about what's happening in Slack." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
