@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_comp_analysis a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "comp-analysis" ;
    skos:broader "Compensation analysis framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/comp-analysis" ;
    oc:contentHash "39f64e92e6fdf32d347a0a1a31880a0c11f3532e298413b3100e56fdad74dc3e" ;
    oc:differentia "that benchmarks roles against market data, evaluates band placement, and models equity grants for hiring, retention, and planning decisions" ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput ;
    oc:hasArgumentHint "<role, level, or dataset>" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Analyze compensation — benchmarking, band placement, and equity modeling. Trigger with \"what should we pay a [role]\", \"is this offer competitive\", \"model this equity grant\", or when uploading comp data to find outliers and retention risks." ;
    oc:hasName "comp-analysis" ;
    oc:impartsKnowledge oc:kn_13bbc5d5,
        oc:kn_27937013,
        oc:kn_55755958,
        oc:kn_70342244,
        oc:kn_f4751749 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "analyze compensation benchmarks for a role",
        "determine band placement for employees",
        "evaluate offer competitiveness",
        "identify comp outliers and retention risks from employee data",
        "model equity grants and refresh packages" ;
    oc:yieldsState oc:CompensationBenchmarked .

oc:kn_13bbc5d5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling uploaded comp data or HRIS-connected employee records" ;
    oc:directiveContent "Compensation data is sensitive. Keep results confidential within the conversation and do not expose individual employee data." ;
    oc:hasRationale "Comp data leaks can create legal liability, damage team morale, and violate privacy policies." ;
    oc:severityLevel "CRITICAL" .

oc:kn_27937013 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When presenting final compensation analysis output" ;
    oc:directiveContent "Provide percentile bands (25th, 50th, 75th, 90th) for base, equity, and total comp, along with location adjustments and company-stage context." ;
    oc:hasRationale "Percentile bands give decision-makers a range to work within rather than a single point estimate, enabling more nuanced offers and adjustments." ;
    oc:severityLevel "MEDIUM" .

oc:kn_55755958 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When a user requests comp analysis for a role" ;
    oc:directiveContent "Always specify location when benchmarking compensation. SF, Austin, and London have vastly different pay scales." ;
    oc:hasRationale "Geographic pay adjustments can swing compensation by 30-50% or more. Omitting location produces misleading benchmarks." ;
    oc:severityLevel "HIGH" .

oc:kn_70342244 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When delivering compensation analysis results" ;
    oc:directiveContent "Always note data freshness and source limitations when presenting benchmarks. Distinguish between verified compensation data and web-researched estimates." ;
    oc:hasRationale "Stale or low-quality data leads to poor comp decisions. Users must understand the confidence level of the data driving their decisions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f4751749 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any compensation analysis" ;
    oc:directiveContent "Always include total compensation (base, equity, bonus, benefits) rather than focusing solely on base salary." ;
    oc:hasRationale "Base salary alone gives an incomplete picture; equity and bonus can represent 30-70% of total comp especially at tech companies, leading to poor benchmarking decisions." ;
    oc:severityLevel "HIGH" .

