oc:kn_1e744043 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Gather inputs (role, level, location, company stage) or uploaded comp data. 2. Pull market benchmarks from compensation data tools or web research. 3. Compute percentile bands (25th, 50th, 75th, 90th) for base, equity, and total comp. 4. If employee data provided, perform band placement analysis identifying outliers. 5. Generate recommendations including equity considerations and retention risks." ;
    oc:stepOrder 1 .

oc:kn_34eb1925 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When outputting any compensation analysis" ;
    oc:directiveContent "Always note data freshness and source limitations when presenting benchmarks." ;
    oc:hasRationale "Stale or unverified comp data leads to poor hiring and retention decisions." .

oc:kn_98615ba6 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When determining data sources for analysis" ;
    oc:directiveContent "When compensation data tools are connected, pull verified market benchmarks; otherwise rely on web research, public salary data, and user-provided context." ;
    oc:hasRationale "Verified connector data is more reliable but not always available; fallback strategies ensure the skill always produces useful output." .

oc:kn_9c0113d4 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """## Compensation Analysis: [Role/Scope]

### Market Benchmarks
| Percentile | Base | Equity | Total Comp |
| 25th | $X | $X | $X |
| 50th | $X | $X | $X |
| 75th | $X | $X | $X |
| 90th | $X | $X | $X |

**Sources:** [list sources]

### Band Analysis (if data provided)
| Employee | Current Base | Band Min | Band Mid | Band Max | Position |

### Recommendations
- [Specific comp recommendations]
- [Equity considerations]
- [Retention risks]""" ;
    oc:templateVariables "Name",
        "Role/Scope",
        "X",
        "sources" .

oc:kn_a861f738 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running any analysis" ;
    oc:directiveContent "Requires either user-provided comp data (CSV/bands), a role description with level and location, or equity grant details to analyze." .

oc:kn_b9fd2d29 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting or comparing compensation" ;
    oc:directiveContent "Use total compensation (base + equity + bonus + benefits) rather than base salary alone for a complete picture." ;
    oc:hasRationale "Base salary alone can be misleading, especially at companies where equity and bonuses represent 30-60% of total comp." .

oc:kn_c9412fc4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When benchmarking any role" ;
    oc:directiveContent "Always specify location when benchmarking compensation — SF vs. Austin vs. London yield very different market rates." ;
    oc:hasRationale "Geographic pay differentials can be 30-50%+ for the same role, making location a critical variable." .

oc:kn_dd5e4522 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When handling any employee compensation data" ;
    oc:directiveContent "Compensation data is sensitive — keep results confidential within the conversation." ;
    oc:hasRationale "Comp data leaks can create legal liability, employee relations issues, and competitive intelligence exposure." ;
    oc:severityLevel "HIGH" .

_:ref_31d32089f205355c a oc:WorkflowStep ;
    dcterms:description "**Keep data confidential** — Comp data is sensitive. Results stay in your conversation." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_6ee11c78debc04fa a oc:WorkflowStep ;
    dcterms:description "**Location matters** — Always specify location for benchmarking. SF vs. Austin vs. London are very different." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_f8264c07eb9a10fd a oc:WorkflowStep ;
    dcterms:description "**Total comp, not just base** — Include equity, bonus, and benefits for a complete picture." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_f35bc906204f1fe8 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_31d32089f205355c,
