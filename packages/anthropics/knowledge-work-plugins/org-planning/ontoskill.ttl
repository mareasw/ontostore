@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_org_planning a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "org-planning" ;
    skos:broader "Organizational planning framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/org-planning" ;
    oc:contentHash "b0db5c6bc4ec57a2b7ee8f9cb6203879301accfe2b1820c7d7b73c527fbceba8" ;
    oc:differentia "Structures headcount planning, org design, and team optimization using benchmarks for span of control, management layers, IC-to-manager ratios, and team size" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "team size, roles, or org structure description" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Headcount planning, org design, and team structure optimization. Trigger with \"org planning\", \"headcount plan\", \"team structure\", \"reorg\", \"who should we hire next\", or when the user is thinking about team size, reporting structure, or organizational design." ;
    oc:hasName "org-planning" ;
    oc:impartsKnowledge oc:kn_3c37bf6b,
        oc:kn_5ac63be5,
        oc:kn_5c0a7228,
        oc:kn_5c8c3b1f,
        oc:kn_ec305925 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "design organizational structure and reporting lines",
        "identify structural issues in org design",
        "model headcount costs and trade-offs",
        "optimize team structure and span of control",
        "plan headcount and hiring roadmap" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_3c37bf6b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining team boundaries and groupings" ;
    oc:directiveContent "Optimal team size is 5-9 people; teams below 4 feel isolated and teams above 12 become hard to manage." ;
    oc:hasRationale "Research on team dynamics (Amazon's two-pizza rule, Dunbar-like cognitive limits) shows productivity and cohesion drop outside this range." ;
    oc:severityLevel "LOW" .

oc:kn_5ac63be5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or evaluating reporting structures" ;
    oc:directiveContent "Target a span of control of 5-8 direct reports per manager; flags below 3 or above 12 as warning signs." ;
    oc:hasRationale "Spans outside this range indicate either underutilized management capacity or overloaded managers, both of which degrade organizational effectiveness." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5c0a7228 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or producing org charts and headcount plans" ;
    oc:directiveContent "Flag single points of failure and excessive management overhead as structural issues in any org plan." ;
    oc:hasRationale "Single points of failure create organizational risk if a key person leaves; excessive overhead drains resources and slows execution." ;
    oc:severityLevel "HIGH" .

oc:kn_5c8c3b1f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning org structure for mid-size organizations" ;
    oc:directiveContent "Management layers should be 4-6 for an organization of ~500 people; too many layers slow decisions." ;
    oc:hasRationale "Excessive layers create communication latency, decision bottlenecks, and dilute accountability." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ec305925 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing team composition and management overhead" ;
    oc:directiveContent "Maintain an IC-to-manager ratio between 6:1 and 10:1; below 4:1 indicates a top-heavy organization." ;
    oc:hasRationale "A top-heavy org wastes budget on management coordination instead of productive output, and often signals unnecessary bureaucracy." ;
    oc:severityLevel "MEDIUM" .

