oc:skill_knowledge_work_plugins_org_planning a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "org-planning" ;
    skos:broader "Organizational planning framework" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/org-planning" ;
    oc:contentHash "b0db5c6bc4ec57a2b7ee8f9cb6203879301accfe2b1820c7d7b73c527fbceba8" ;
    oc:differentia "Provides headcount modeling, org structure benchmarks, and hiring sequencing guidance" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Headcount planning, org design, and team structure optimization. Trigger with \"org planning\", \"headcount plan\", \"team structure\", \"reorg\", \"who should we hire next\", or when the user is thinking about team size, reporting structure, or organizational design." ;
    oc:hasName "org-planning" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Help plan organizational structure, headcount, and team design." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Produce org charts (text-based), headcount plans with cost modeling, and sequenced hiring roadmaps. Flag structural issues like single points of failure or excessive management overhead." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Sequencing**: Which hires are most critical? What's the right order?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Headcount**: How many people do we need, in what roles, by when?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Budget**: Headcount cost modeling and trade-offs" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Structure**: Reporting lines, span of control, team boundaries" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Planning Dimensions" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 4 ;
                            oc:tableCaption "## Healthy Org Benchmarks" ;
                            oc:tableMarkdown """| Metric | Healthy Range | Warning Sign |
|--------|---------------|--------------|
| Span of control | 5-8 direct reports | < 3 or > 12 |
| Management layers | 4-6 for 500 people | Too many = slow decisions |
| IC-to-manager ratio | 6:1 to 10:1 | < 4:1 = top-heavy |
| Team size | 5-9 people | < 4 = lonely, > 12 = hard to manage |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Healthy Org Benchmarks" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Org Planning" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: org-planning
description: Headcount planning, org design, and team structure optimization. Trigger with "org planning", "headcount plan", "team structure", "reorg", "who should we hire next", or when the user is thinking about team size, reporting structure, or organizational design.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Complete organizational planning workflow from assessment to output delivery." ;
            oc:hasStep _:ref_477ac53ced680ccb,
                _:ref_481c1a77ac9e620e,
                _:ref_511819b6ffd82b5d,
                [ a oc:WorkflowStep ;
                    dcterms:description "Generate text-based org charts, headcount plans with cost modeling, sequenced hiring roadmaps, and flag structural issues." ;
                    oc:expectedOutcome "Complete org planning deliverables" ;
                    oc:stepDependsOn _:ref_481c1a77ac9e620e,
                        _:ref_511819b6ffd82b5d ;
                    oc:stepId "produce-deliverables" ],
                _:ref_f2cca107cc3e917b ;
            oc:workflowId "org-planning-main" ;
            oc:workflowName "Org Planning Analysis" ] ;
    oc:impartsKnowledge oc:kn_145af051,
        oc:kn_4cc11a73,
        oc:kn_51acffa2,
        oc:kn_86f7a76e,
        oc:kn_b82eacf6,
        oc:kn_cd8c4dce ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "assess org health with benchmarks",
        "create hiring roadmap with cost modeling",
        "design organizational structure",
        "optimize team composition",
        "plan headcount and hiring" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_145af051 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating management density" ;
    oc:directiveContent "IC-to-manager ratio should be 6:1 to 10:1. Below 4:1 indicates a top-heavy organization." ;
    oc:hasRationale "Top-heavy orgs spend disproportionate resources on coordination rather than execution." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4cc11a73 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When producing org charts and headcount plans" ;
    oc:directiveContent "Flag single points of failure and excessive management overhead as structural issues to address." ;
    oc:hasRationale "Single points of failure create organizational risk; excessive overhead wastes budget and slows execution." ;
    oc:severityLevel "HIGH" .

oc:kn_51acffa2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sizing individual teams within the org" ;
    oc:directiveContent "Team size should be 5-9 people. Teams under 4 feel isolated; teams over 12 become hard to manage." ;
    oc:hasRationale "Team sizes outside this range correlate with lower cohesion, communication breakdown, or management overload." ;
    oc:severityLevel "HIGH" .

oc:kn_86f7a76e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — when performing any org planning exercise" ;
    oc:directiveContent "Org planning must address four dimensions: headcount (who, how many, when), structure (reporting lines, span, boundaries), sequencing (hire priority and order), and budget (cost modeling and trade-offs)." ;
    oc:hasRationale "Addressing all four dimensions ensures a complete and actionable plan rather than a partial analysis." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b82eacf6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or evaluating reporting structures" ;
    oc:directiveContent "Span of control should be 5-8 direct reports per manager; fewer than 3 or more than 12 signals structural problems." ;
    oc:hasRationale "Too narrow a span wastes management capacity; too wide a span reduces manager effectiveness and team support." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cd8c4dce a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assessing org depth and hierarchy" ;
    oc:directiveContent "Management layers should be 4-6 for an organization of ~500 people. Excessive layers indicate slow decision-making." ;
    oc:hasRationale "Each additional layer adds communication overhead and slows execution velocity." ;
    oc:severityLevel "MEDIUM" .

_:ref_481c1a77ac9e620e a oc:WorkflowStep ;
    dcterms:description "Compare current state against healthy org benchmarks (span of control, management layers, IC-to-manager ratio, team size)." ;
    oc:expectedOutcome "Identified structural issues and warning signs" ;
    oc:stepDependsOn _:ref_477ac53ced680ccb ;
    oc:stepId "benchmark-health" .

_:ref_511819b6ffd82b5d a oc:WorkflowStep ;
    dcterms:description "Prioritize and sequence hires based on criticality and dependencies." ;
    oc:expectedOutcome "Ordered hiring roadmap" ;
    oc:stepDependsOn _:ref_f2cca107cc3e917b ;
    oc:stepId "sequence-hires" .

_:ref_f2cca107cc3e917b a oc:WorkflowStep ;
    dcterms:description "Model target headcount by role, timeline, and budget with cost modeling and trade-offs." ;
    oc:expectedOutcome "Headcount plan with cost projections" ;
    oc:stepDependsOn _:ref_477ac53ced680ccb ;
    oc:stepId "plan-headcount" .

_:ref_477ac53ced680ccb a oc:WorkflowStep ;
    dcterms:description "Assess current org structure: gather existing headcount, reporting lines, team sizes, and management layers." ;
    oc:expectedOutcome "Clear picture of current organizational state with metrics" ;
    oc:stepId "assess-current" .

