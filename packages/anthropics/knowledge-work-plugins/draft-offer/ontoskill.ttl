    oc:workflowName "Ordered Procedure" .

_:ref_0fe9d5f30f78d9c2 a oc:WorkflowStep ;
    dcterms:description "If HRIS connected: pull comp band data, verify headcount approval, auto-populate benefits. If ATS connected: pull candidate details, update offer status." ;
    oc:expectedOutcome "Offer data enriched with system-sourced comp bands, benefits, and candidate info." ;
    oc:stepDependsOn _:ref_10160e61a83adb11 ;
    oc:stepId "enrich-from-connectors" .

_:ref_10160e61a83adb11 a oc:WorkflowStep ;
    dcterms:description "Collect role, level, location, compensation (base, equity, signing bonus), start date, and hiring manager from user." ;
    oc:expectedOutcome "All required offer details are collected or partially available with gaps identified." ;
    oc:stepId "gather-inputs" .

