oc:kn_26915908 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before generating the offer letter" ;
    oc:directiveContent "Assumes the hiring manager provides role, level, location, compensation details, start date, and reporting structure. If details are missing, help the user think through them rather than blocking." ;
    oc:hasRationale "Incomplete comp data leads to inaccurate offers that may need retraction or revision." .

oc:kn_3dc171d9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any offer letter" ;
    oc:directiveContent "Always include total compensation (base + equity + signing bonus + target bonus), not just base salary — candidates compare total comp packages." ;
    oc:hasRationale "Candidates evaluate offers holistically; omitting total comp creates ambiguity and may lose the candidate to competing offers." ;
    oc:severityLevel "HIGH" .

oc:kn_92e87f90 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When connected HR systems (HRIS/ATS) are available" ;
    oc:directiveContent "If HRIS or ATS connectors are available, the skill may pull comp band data, verify headcount approval, auto-populate benefits, and update offer status in the pipeline." ;
    oc:hasRationale "Connector usage modifies HR system state and should be confirmed before auto-updating pipeline records." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e31d977f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When equity is part of the compensation package" ;
    oc:directiveContent "Be specific about equity: include share count, current valuation method, and vesting schedule." ;
    oc:hasRationale "Vague equity terms are the #1 source of candidate confusion and post-acceptance disputes." ;
    oc:severityLevel "HIGH" .

oc:kn_faddccf1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the offer letter text" ;
    oc:directiveContent "Personalize the offer letter by referencing something from the interview process to make it warm rather than generic." ;
    oc:hasRationale "A warm, personalized offer reinforces the candidate's positive experience and increases acceptance rates." ;
    oc:severityLevel "MEDIUM" .

_:ref_412e20f73c640698 a oc:WorkflowStep ;
    dcterms:description "**Personalize** — Reference something from the interview process to make it warm." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_ac2c45c8df89af7e a oc:WorkflowStep ;
    dcterms:description "**Be specific about equity** — Share count, current valuation method, vesting schedule." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_c5bd332713220353 a oc:WorkflowStep ;
    dcterms:description "**Include total comp** — Candidates compare total compensation, not just base." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_0db5031d881b60e5 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_412e20f73c640698,
        _:ref_ac2c45c8df89af7e,
        _:ref_c5bd332713220353 ;
