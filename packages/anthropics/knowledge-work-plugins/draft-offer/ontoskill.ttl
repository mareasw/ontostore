@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_draft_offer a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "draft-offer" ;
    skos:broader "document generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/draft-offer" ;
    oc:contentHash "97ee62a2f53d3708c85d1af4a234c835f4db3f4ff3bc57d876cacbd67c525f6c" ;
    oc:differentia "that produces formal employment offer letters with compensation breakdown, terms, and negotiation guidance" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<role and level>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Draft an offer letter with comp details and terms. Use when a candidate is ready for an offer, assembling a total comp package (base, equity, signing bonus), writing the offer letter text itself, or prepping negotiation guidance for the hiring manager." ;
    oc:hasName "draft-offer" ;
    oc:impartsKnowledge oc:kn_6079d1d4,
        oc:kn_874016ac,
        oc:kn_8773eaf4,
        oc:kn_87b91093,
        oc:kn_f940c6d9 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create a compensation package for a candidate",
        "draft an offer letter",
        "generate negotiation guidance for hiring manager",
        "prepare offer letter with comp details and terms" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_6079d1d4 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When drafting offer letter text" ;
    oc:directiveContent "Personalize the offer letter by referencing something from the interview process to make it warm." ;
    oc:hasRationale "Personalized offers improve candidate experience and acceptance rates." .

oc:kn_874016ac a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When equity is part of the compensation package" ;
    oc:directiveContent "Be specific about equity: include share count, current valuation method, and vesting schedule." ;
    oc:hasRationale "Vague equity terms create confusion and erode trust; specificity enables informed candidate decisions." .

oc:kn_8773eaf4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assembling compensation details" ;
    oc:directiveContent "Location affects both compensation benchmarks and benefits eligibility — always confirm candidate location." ;
    oc:hasRationale "Compensation bands and statutory benefits vary by geography; incorrect assumptions produce non-competitive or non-compliant offers." .

oc:kn_87b91093 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any offer letter" ;
    oc:directiveContent "Always present total compensation, not just base salary — candidates compare total comp packages." ;
    oc:hasRationale "Candidates evaluate holistic packages; omitting total comp leads to misaligned expectations and failed negotiations." ;
    oc:severityLevel "HIGH" .

oc:kn_f940c6d9 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When user provides incomplete information" ;
    oc:directiveContent "If the user doesn't have all offer details, help them think through the missing pieces rather than blocking." ;
    oc:hasRationale "Guiding the user through missing fields ensures completeness without creating friction." .

