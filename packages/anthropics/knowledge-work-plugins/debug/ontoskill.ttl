@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_debug a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "debug" ;
    skos:broader "debugging methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/debug" ;
    oc:contentHash "d5a6c5fcace4ff7f1408cad6f2e601342b725fbc3cd56a4b388ebcb4bee5f42f" ;
    oc:differentia "that structures error investigation into reproduce, isolate, diagnose, and fix phases with systematic root cause analysis" ;
    oc:handlesFailure oc:CannotReproduce,
        oc:InsufficientContext ;
    oc:hasArgumentHint "<error message or problem description>" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Structured debugging session — reproduce, isolate, diagnose, and fix. Trigger with an error message or stack trace, \"this works in staging but not prod\", \"something broke after the deploy\", or when behavior diverges from expected and the cause isn't obvious." ;
    oc:hasName "debug" ;
    oc:impartsKnowledge oc:kn_07a55844,
        oc:kn_7b39a8f0,
        oc:kn_98a2c207,
        oc:kn_ac26842d,
        oc:kn_e08b27bd ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "debug an error or stack trace",
        "diagnose unexpected behavior",
        "find root cause of a bug",
        "fix a production issue",
        "investigate regression after deployment" ;
    oc:yieldsState oc:FixProposed,
        oc:RootCauseIdentified .

oc:kn_07a55844 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Always, when initiating any debugging session" ;
    oc:directiveContent "Follow a strict 4-phase debugging workflow: Reproduce → Isolate → Diagnose → Fix. Never skip to fixing without first reproducing and isolating." ;
    oc:hasRationale "Jumping to conclusions without systematic reproduction and isolation leads to treating symptoms instead of root causes, wasting time and potentially introducing new bugs" ;
    oc:severityLevel "HIGH" .

oc:kn_7b39a8f0 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting a debugging session" ;
    oc:directiveContent "Gather context before debugging: exact error message or stack trace, steps to reproduce, recent changes, logs, and expected vs actual behavior" ;
    oc:hasRationale "Insufficient context is the most common reason debugging sessions stall or go in wrong directions; complete information upfront dramatically reduces time to resolution" ;
    oc:severityLevel "MEDIUM" .

oc:kn_98a2c207 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning isolation phase after reproducing the issue" ;
    oc:directiveContent "Prioritize investigating recent changes (deploys, dependency updates, config changes) as top suspects when behavior diverges unexpectedly" ;
    oc:hasRationale "Most production bugs are caused by recent changes rather than latent defects, making recent diffs the highest-yield area to investigate first" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ac26842d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When receiving bug reports or error descriptions from users" ;
    oc:directiveContent "Never paraphrase error messages — always use the exact error text when investigating issues" ;
    oc:hasRationale "Exact error messages contain critical details like line numbers, error codes, and specific variable names that are essential for accurate diagnosis" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e08b27bd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When delivering the fix phase of a debug session" ;
    oc:directiveContent "Always propose regression tests alongside fixes to prevent the same bug from recurring" ;
    oc:hasRationale "A fix without a test is only a temporary patch; regression tests lock in the correct behavior and serve as living documentation of the issue" ;
    oc:severityLevel "HIGH" .

