oc:skill_knowledge_work_plugins_debug a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "debug" ;
    skos:broader "Debugging methodology" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/debug" ;
    oc:contentHash "d5a6c5fcace4ff7f1408cad6f2e601342b725fbc3cd56a4b388ebcb4bee5f42f" ;
    oc:differentia "Structures root cause analysis into reproduce, isolate, diagnose, fix phases with connector-enhanced investigation" ;
    oc:handlesFailure oc:InsufficientInformation,
        oc:RootCauseAmbiguous ;
    oc:hasArgumentHint "<error message or problem description>" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Structured debugging session — reproduce, isolate, diagnose, and fix. Trigger with an error message or stack trace, \"this works in staging but not prod\", \"something broke after the deploy\", or when behavior diverges from expected and the cause isn't obvious." ;
    oc:hasName "debug" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: debug
description: Structured debugging session — reproduce, isolate, diagnose, and fix. Trigger with an error message or stack trace, "this works in staging but not prod", "something broke after the deploy", or when behavior diverges from expected and the cause isn't obvious.
argument-hint: "<error message or problem description>"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Run a structured debugging session to find and fix issues systematically." ],
                [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent _:ref_a51a279b7effcc7d ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Tips" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/debug $ARGUMENTS
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 15-17" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Usage" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Identify recent commits and PRs that touched affected code paths" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Check if the issue correlates with a specific change" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "If **~~source control** is connected:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "If **~~project tracker** is connected:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Show recent deploys and config changes that may correlate" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Pull logs, error rates, and metrics around the time of the issue" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "If **~~monitoring** is connected:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 6 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Create a ticket for the fix once identified" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Search for related bug reports or known issues" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "If Connectors Available" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """## Debug Report: [Issue Summary]

### Reproduction
- **Expected**: [What should happen]
- **Actual**: [What happens instead]
- **Steps**: [How to reproduce]

### Root Cause
[Explanation of why the bug occurs]

### Fix
[Code changes or configuration fixes needed]

### Prevention
- [Test to add]
- [Guard to put in place]
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 58-75" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """┌─────────────────────────────────────────────────────────────────┐
│                       DEBUG                                        │
├─────────────────────────────────────────────────────────────────┤
│  Step 1: REPRODUCE                                                │
│  ✓ Understand the expected vs. actual behavior                   │
│  ✓ Identify exact reproduction steps                             │
│  ✓ Determine scope (when did it start? who is affected?)        │
│                                                                    │
│  Step 2: ISOLATE                                                   │
│  ✓ Narrow down the component, service, or code path             │
│  ✓ Check recent changes (deploys, config changes, dependencies) │
│  ✓ Review logs and error messages                                │
│                                                                    │
│  Step 3: DIAGNOSE                                                  │
│  ✓ Form hypotheses and test them                                 │
│  ✓ Trace the code path                                           │
│  ✓ Identify root cause (not just symptoms)                      │
│                                                                    │
│  Step 4: FIX                                                       │
│  ✓ Propose a fix with explanation                                │
│  ✓ Consider side effects and edge cases                          │
│  ✓ Suggest tests to prevent regression                           │
└─────────────────────────────────────────────────────────────────┘
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 21-45" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "How It Works" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "What changed recently" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Steps to reproduce" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Logs or screenshots" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Expected vs. actual behavior" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Error message or stack trace" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Tell me about the problem. Any of these help:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "What I Need From You" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "/debug" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Systematic 4-phase debugging workflow: reproduce the issue, isolate the cause, diagnose the root cause, and propose a fix with prevention measures." ;
            oc:hasStep _:ref_05bc7d6f6ef6155e,
                [ a oc:WorkflowStep ;
                    dcterms:description "Generate structured debug report with reproduction steps, root cause, fix, and prevention sections" ;
                    oc:expectedOutcome "Complete debug report delivered to user" ;
                    oc:stepDependsOn _:ref_9aaf1767dacc8afa ;
                    oc:stepId "report" ],
                _:ref_9aaf1767dacc8afa,
                _:ref_d1cdd96cae7931f2,
                _:ref_f0fa43ae0982a84b ;
            oc:workflowId "debug-session" ;
            oc:workflowName "Structured Debugging Session" ],
        _:ref_a51a279b7effcc7d ;
    oc:impartsKnowledge oc:kn_0288c343,
        oc:kn_059d7319,
        oc:kn_6edc2dca,
        oc:kn_84318d54,
        oc:kn_a0f41afb,
        oc:kn_aa7af0e8,
        oc:kn_edc9390d ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady,
        oc:NetworkAvailable ;
    oc:resolvesIntent "debug an error",
        "diagnose a bug",
        "fix broken behavior",
        "investigate a stack trace",
        "troubleshoot a production issue" ;
    oc:yieldsState oc:FixProposed,
        oc:RootCauseIdentified .

oc:kn_0288c343 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During the DIAGNOSE phase" ;
    oc:directiveContent "Always distinguish root cause from symptoms. A fix that only addresses symptoms will recur." ;
    oc:hasRationale "Treating symptoms wastes time and creates false confidence; the real issue remains latent" ;
    oc:severityLevel "CRITICAL" .

oc:kn_059d7319 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When diagnosing new or sudden issues" ;
    oc:directiveContent "Recent deploys, dependency updates, and configuration changes are the top suspects when behavior diverges unexpectedly." ;
    oc:hasRationale "Most production bugs correlate with recent changes; temporal correlation is the strongest signal" .

oc:kn_6edc2dca a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When receiving or sharing error messages during debugging" ;
    oc:directiveContent "Never paraphrase or summarize error messages — share exact text. The exact wording matters for diagnosis." ;
    oc:hasRationale "Paraphrased errors lose critical details like line numbers, error codes, and specific identifiers that narrow the search space" ;
    oc:severityLevel "HIGH" .

oc:kn_84318d54 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When gathering initial information about a bug" ;
    oc:directiveContent "Context constraints like 'works in staging but not prod' or 'only affects large payloads' dramatically narrow the investigation. Always ask for and use them." ;
    oc:hasRationale "Environmental or input-dependent constraints immediately eliminate large swaths of potential causes" .

oc:kn_a0f41afb a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When connector integrations are available" ;
    oc:directiveContent "If monitoring connectors are available, pull logs, error rates, and metrics around the issue time. If source control is connected, identify recent commits on affected paths. If project tracker is connected, search for related known issues." ;
    oc:hasRationale "Connectors provide empirical data that replaces guesswork with evidence-based diagnosis" .

oc:kn_aa7af0e8 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any debugging session" ;
    oc:directiveContent "Before debugging, gather: error message or stack trace, steps to reproduce, recent changes, logs or screenshots, and expected vs actual behavior." ;
    oc:hasRationale "Incomplete information leads to incorrect hypotheses and wasted investigation time" .

oc:kn_edc9390d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "always — every debugging session follows this sequence" ;
    oc:directiveContent "1. REPRODUCE — understand expected vs actual behavior, identify exact reproduction steps, determine scope (when started, who affected) 2. ISOLATE — narrow down component/service/code path, check recent changes (deploys, config, dependencies), review logs and errors 3. DIAGNOSE — form and test hypotheses, trace code path, identify root cause (not symptoms) 4. FIX — propose fix with explanation, consider side effects and edge cases, suggest regression tests" ;
    oc:hasRationale "Systematic debugging prevents flailing and ensures root causes are found rather than symptoms treated" ;
    oc:stepOrder 1 .

_:ref_29edc14d496b34da a oc:WorkflowStep ;
    dcterms:description "**Mention what changed** — Recent deploys, dependency updates, and config changes are top suspects." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_cc519400d384935c a oc:WorkflowStep ;
    dcterms:description "**Include context** — \"This works in staging but not prod\" or \"Only affects large payloads\" narrows things fast." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_faccd6701285caeb a oc:WorkflowStep ;
    dcterms:description "**Share error messages exactly** — Don't paraphrase. The exact text matters." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_05bc7d6f6ef6155e a oc:WorkflowStep ;
    dcterms:description "Form and test hypotheses, trace the code path, identify the root cause (not just symptoms)" ;
    oc:expectedOutcome "Root cause identified with supporting evidence" ;
    oc:stepDependsOn _:ref_f0fa43ae0982a84b ;
    oc:stepId "diagnose" .

_:ref_9aaf1767dacc8afa a oc:WorkflowStep ;
    dcterms:description "Propose a fix with explanation, consider side effects and edge cases, suggest regression tests" ;
    oc:expectedOutcome "Fix proposed with code changes, rationale, and prevention measures" ;
    oc:stepDependsOn _:ref_05bc7d6f6ef6155e ;
    oc:stepId "fix" .

_:ref_a51a279b7effcc7d a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_29edc14d496b34da,
        _:ref_cc519400d384935c,
        _:ref_faccd6701285caeb ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_d1cdd96cae7931f2 a oc:WorkflowStep ;
    dcterms:description "Understand expected vs actual behavior, identify exact reproduction steps, determine scope (when it started, who is affected)" ;
    oc:expectedOutcome "Clear understanding of the bug's manifestation and reliable reproduction steps" ;
    oc:stepId "reproduce" .

_:ref_f0fa43ae0982a84b a oc:WorkflowStep ;
    dcterms:description "Narrow down the component, service, or code path. Check recent deploys, config changes, and dependency updates. Review logs and error messages." ;
    oc:expectedOutcome "Bug narrowed to a specific component or code path with correlated recent changes" ;
    oc:stepDependsOn _:ref_d1cdd96cae7931f2 ;
    oc:stepId "isolate" .

