@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_documentation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "documentation" ;
    skos:broader "Technical writing methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/documentation" ;
    oc:contentHash "b521c06296c3f0863e7b02bcf24193dc5113c8fbf398c92b014dfcb736f0676c" ;
    oc:differentia "provides structured templates and principles for creating and maintaining README, API docs, runbooks, architecture docs, and onboarding guides" ;
    oc:hasArgumentHint "document type and subject to document" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Write and maintain technical documentation. Trigger with \"write docs for\", \"document this\", \"create a README\", \"write a runbook\", \"onboarding guide\", or when the user needs help with any form of technical writing — API docs, architecture docs, or operational runbooks." ;
    oc:hasName "documentation" ;
    oc:impartsKnowledge oc:kn_53ab8242,
        oc:kn_95f1ff0d,
        oc:kn_9ce56613,
        oc:kn_bc7e20a0,
        oc:kn_c8fcf56b ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "create a README",
        "create an onboarding guide",
        "document architecture",
        "maintain existing documentation",
        "write API documentation",
        "write a runbook",
        "write technical documentation" .

oc:kn_53ab8242 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When maintaining documentation over time" ;
    oc:directiveContent "Never let documentation go stale — outdated docs are worse than no docs at all." ;
    oc:hasRationale "Outdated documentation actively misleads readers and erodes trust in all documentation." ;
    oc:severityLevel "CRITICAL" .

oc:kn_95f1ff0d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring any technical document, especially READMEs" ;
    oc:directiveContent "Start with the most useful information first and don't bury the key content — Quick start should achieve first success in under 5 minutes." ;
    oc:hasRationale "Readers have limited attention; leading with value increases the chance they find what they need." ;
    oc:severityLevel "HIGH" .

oc:kn_9ce56613 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting any technical documentation" ;
    oc:directiveContent "Write for the reader — identify who is reading and what they need before structuring the document." ;
    oc:hasRationale "Documentation that doesn't match its audience's knowledge level or needs fails to communicate effectively." ;
    oc:severityLevel "HIGH" .

oc:kn_bc7e20a0 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When content exists elsewhere in the documentation set" ;
    oc:directiveContent "Link to other documents instead of duplicating content — reference, don't copy." ;
    oc:hasRationale "Duplication creates maintenance burden and inconsistency when source material changes." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c8fcf56b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When explaining how something works or how to perform a task" ;
    oc:directiveContent "Show, don't tell — prefer code examples, commands, and screenshots over prose descriptions." ;
    oc:hasRationale "Concrete examples are faster to understand and less ambiguous than abstract descriptions." ;
    oc:severityLevel "MEDIUM" .

