    oc:yieldsState oc:DocumentCreated .

oc:kn_032e79da a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any technical documentation" ;
    oc:directiveContent "Show, don't tell — include code examples, commands, and screenshots rather than abstract descriptions." ;
    oc:hasRationale "Concrete examples are faster to understand and verify than prose descriptions." .

oc:kn_106f66ec a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When starting any documentation task" ;
    oc:directiveContent "1. Identify document type (README/API doc/runbook/architecture doc/onboarding guide) 2. Determine target audience and their needs 3. Structure content per the document type template 4. Include concrete examples (code, commands, screenshots) 5. Link to related docs instead of duplicating" ;
    oc:stepOrder 1 .

oc:kn_19fbdf35 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When maintaining long-lived documentation" ;
    oc:directiveContent "Outdated documentation is worse than no documentation — keep docs current or remove them." ;
    oc:hasRationale "Stale docs actively mislead readers and erode trust in all documentation." ;
    oc:severityLevel "HIGH" .

oc:kn_48076da9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documentation overlaps across files or sections" ;
    oc:directiveContent "Avoid duplicating content across documents — link to the canonical source instead." ;
    oc:hasRationale "Duplicated content diverges over time, creating inconsistency and confusion about which version is authoritative." ;
    oc:severityLevel "MEDIUM" .

oc:kn_69fe91be a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring READMEs and onboarding guides" ;
    oc:directiveContent "Start with the most useful information first — don't bury the lede. Quick start should get users to first success in under 5 minutes." ;
    oc:hasRationale "Readers scan documentation; leading with value reduces bounce and increases adoption." ;
    oc:severityLevel "HIGH" .

oc:kn_a5a03125 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any technical document" ;
    oc:directiveContent "Write for the reader — identify who is reading and what they need before structuring documentation." ;
    oc:hasRationale "Documentation that doesn't serve its audience fails regardless of technical accuracy." ;
    oc:severityLevel "HIGH" .

oc:kn_f4029408 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating any of the five supported document types" ;
    oc:directiveContent """## README
- What this is and why it exists
- Quick start (< 5 minutes to first success)
- Configuration and usage
- Contributing guide

## API Documentation
- Endpoint reference with request/response examples
- Authentication and error codes
- Rate limits and pagination
- SDK examples

## Runbook
- When to use this runbook
- Prerequisites and access needed
- Step-by-step procedure
- Rollback steps
- Escalation path

## Architecture Doc
- Context and goals
- High-level design with diagrams
- Key decisions and trade-offs
- Data flow and integration points

## Onboarding Guide
- Environment setup
- Key systems and how they connect
- Common tasks with walkthroughs
- Who to ask for what""" ;
    oc:templateVariables "content_sections",
        "document_type" .

