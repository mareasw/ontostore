_:ref_e162c577f50a539c a oc:WorkflowStep ;
    dcterms:description "**Keep it current** — Outdated docs are worse than no docs" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

