@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_recruiting_pipeline a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "recruiting-pipeline" ;
    skos:broader "Recruiting pipeline management framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/recruiting-pipeline" ;
    oc:contentHash "c1cad557ac91697ec7c845711787408554b48ae3896be519993435b7e22eb534" ;
    oc:differentia "that tracks candidate progression through six defined stages (Sourced → Screen → Interview → Debrief → Offer → Accepted) with quantitative metrics for velocity, conversion, and effectiveness" ;
    oc:handlesFailure oc:DataUnavailable,
        oc:InvalidInput ;
    oc:hasArgumentHint "role or req identifier (optional)" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Track and manage recruiting pipeline stages. Trigger with \"recruiting update\", \"candidate pipeline\", \"how many candidates\", \"hiring status\", or when the user discusses sourcing, screening, interviewing, or extending offers." ;
    oc:hasName "recruiting-pipeline" ;
    oc:impartsKnowledge oc:kn_1b2f15d0,
        oc:kn_2c3b1cdc,
        oc:kn_5ec8e3ab,
        oc:kn_90a9cc08,
        oc:kn_bc5c0422 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "analyze recruiting metrics",
        "manage candidate pipeline stages",
        "report hiring status",
        "track recruiting pipeline",
        "update candidate pipeline" ;
    oc:yieldsState oc:PipelineReported .

oc:kn_1b2f15d0 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When an applicant tracking system integration is available" ;
    oc:directiveContent "If an ATS is connected, pull candidate data automatically, update statuses, and track pipeline metrics in real time rather than relying on manual updates." ;
    oc:hasRationale "Automated ATS sync reduces data staleness, eliminates manual entry errors, and enables real-time pipeline visibility." .

oc:kn_2c3b1cdc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reporting on recruiting performance or diagnosing pipeline bottlenecks" ;
    oc:directiveContent "Track five core metrics: pipeline velocity (days per stage), conversion rates (stage-to-stage drop-off), source effectiveness, offer acceptance rate, and time to fill." ;
    oc:hasRationale "These five metrics provide a complete diagnostic view of pipeline health, from speed to quality to ROI of sourcing channels." .

oc:kn_5ec8e3ab a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating pipeline reports or snapshots" ;
    oc:directiveContent "Re-running a pipeline report or status update should produce the same result if no candidates have moved between stages." ;
    oc:hasRationale "Deterministic reporting ensures stakeholders can trust that unchanged data yields unchanged reports." .

oc:kn_90a9cc08 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining or reporting on recruiting pipelines" ;
    oc:directiveContent "The pipeline must cover the full lifecycle from sourcing through offer acceptance, not just a subset of stages." ;
    oc:hasRationale "Incomplete pipeline visibility leads to blind spots — e.g., tracking only interviews without sourcing data hides upstream funnel problems." .

oc:kn_bc5c0422 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When modeling or discussing any recruiting pipeline" ;
    oc:directiveContent "Structure the recruiting pipeline as six discrete stages: Sourced, Screen, Interview, Debrief, Offer, and Accepted, each with defined key actions." ;
    oc:hasRationale "Standardized stages enable consistent tracking, comparison, and benchmarking across roles and time periods." .

