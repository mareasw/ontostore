@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_knowledge_work_plugins_recruiting_pipeline a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "recruiting-pipeline" ;
    skos:broader "Recruiting pipeline management framework" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/recruiting-pipeline" ;
    oc:contentHash "c1cad557ac91697ec7c845711787408554b48ae3896be519993435b7e22eb534" ;
    oc:differentia "that tracks candidates through six stages from sourcing to offer acceptance with metrics and ATS integration" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "recruiting query, e.g. 'recruiting update', 'candidate pipeline', 'how many candidates', 'hiring status'" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Track and manage recruiting pipeline stages. Trigger with \"recruiting update\", \"candidate pipeline\", \"how many candidates\", \"hiring status\", or when the user discusses sourcing, screening, interviewing, or extending offers." ;
    oc:hasName "recruiting-pipeline" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: recruiting-pipeline
description: Track and manage recruiting pipeline stages. Trigger with "recruiting update", "candidate pipeline", "how many candidates", "hiring status", or when the user discusses sourcing, screening, interviewing, or extending offers.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Help manage the recruiting pipeline from sourcing through offer acceptance." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Time to fill**: Days from req open to offer accepted" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Source effectiveness**: Which channels produce hires" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Conversion rates**: Stage-to-stage drop-off" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Offer acceptance rate**: Offers extended vs. accepted" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Pipeline velocity**: Days per stage" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Metrics to Track" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Pull candidate data automatically, update statuses, and track pipeline metrics in real time." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "If ATS Connected" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 6 ;
                            oc:tableCaption "## Pipeline Stages" ;
                            oc:tableMarkdown """| Stage | Description | Key Actions |
|-------|-------------|-------------|
| Sourced | Identified and reached out | Personalized outreach |
| Screen | Phone/video screen | Evaluate basic fit |
| Interview | On-site or panel interviews | Structured evaluation |
| Debrief | Team decision | Calibrate feedback |
| Offer | Extending offer | Comp package, negotiation |
| Accepted | Offer accepted | Transition to onboarding |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Pipeline Stages" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Recruiting Pipeline" ] ;
    oc:impartsKnowledge oc:kn_46c9fdee,
        oc:kn_79fe3503,
        oc:kn_ac7a3391,
        oc:kn_bd8153ad,
        oc:kn_f5cd2b80 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "analyze recruiting metrics",
        "manage candidate pipeline",
        "monitor hiring status",
        "track recruiting pipeline stages",
        "update candidate stages" ;
    oc:yieldsState oc:PipelineTracked .

oc:kn_46c9fdee a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When ATS integration is available" ;
    oc:directiveContent "If an ATS is connected, pull candidate data automatically, update statuses, and track pipeline metrics in real time rather than relying on manual data entry." ;
    oc:hasRationale "Automated data sync reduces manual effort and ensures pipeline metrics reflect the current state accurately." ;
    oc:severityLevel "MEDIUM" .

oc:kn_79fe3503 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When tracking any candidate through the recruiting process" ;
    oc:directiveContent "Manage candidates through six sequential stages: Sourced → Screen → Interview → Debrief → Offer → Accepted, with specific key actions at each stage." ;
    oc:hasRationale "A standardized stage progression ensures consistent evaluation and prevents candidates from falling through gaps." ;
    oc:severityLevel "HIGH" .

oc:kn_ac7a3391 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When reporting on or analyzing recruiting pipeline health" ;
    oc:directiveContent "Track five core pipeline metrics: pipeline velocity (days per stage), conversion rates (stage-to-stage drop-off), source effectiveness (which channels produce hires), offer acceptance rate, and time to fill (days from req open to offer accepted)." ;
    oc:hasRationale "These five metrics provide a comprehensive view of pipeline efficiency, quality, and bottlenecks." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bd8153ad a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the recruiting process deviates from the standard six-stage model" ;
    oc:directiveContent "This skill assumes a linear six-stage pipeline model. Complex hiring processes with parallel tracks, multiple interview loops, or non-linear stage progressions may require adaptation." ;
    oc:hasRationale "Not all organizations follow the same pipeline structure; customization may be needed for specialized roles or workflows." ;
    oc:severityLevel "LOW" .

oc:kn_f5cd2b80 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining what actions to take at each stage" ;
    oc:directiveContent "Each pipeline stage has defined key actions: Sourced (personalized outreach), Screen (evaluate basic fit), Interview (structured evaluation), Debrief (calibrate feedback), Offer (comp package, negotiation), Accepted (transition to onboarding)." ;
    oc:hasRationale "Clear action definitions per stage ensure evaluators know what is expected and candidates receive consistent treatment." ;
    oc:severityLevel "LOW" .

