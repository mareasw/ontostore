@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_incident_response a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "incident-response" ;
    skos:broader "Incident management workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/incident-response" ;
    oc:contentHash "04a7f3722ad3ba067fd73c3c633f17c948032349614acf0ff23a572c8a37e225" ;
    oc:differentia "that guides an agent through triage, communication, mitigation, and blameless postmortem phases for production incidents" ;
    oc:handlesFailure oc:ConnectorUnavailable,
        oc:InvalidInput ;
    oc:hasArgumentHint "<incident description or alert>" ;
    oc:hasCategory "devops-automation" ;
    oc:hasDescription "Run an incident response workflow — triage, communicate, and write postmortem. Trigger with \"we have an incident\", \"production is down\", an alert that needs severity assessment, a status update mid-incident, or when writing a blameless postmortem after resolution." ;
    oc:hasName "incident-response" ;
    oc:impartsKnowledge oc:kn_011cb5d4,
        oc:kn_20bf96e6,
        oc:kn_3cda61c3,
        oc:kn_7ede9063,
        oc:kn_dab38dcf ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:IncidentDetected ;
    oc:resolvesIntent "coordinate incident response communication",
        "draft incident status updates",
        "manage a production incident",
        "triage an incident and assess severity",
        "write a blameless postmortem" ;
    oc:yieldsState oc:IncidentCommunicated,
        oc:IncidentMitigated,
        oc:IncidentTriaged,
        oc:PostmortemCompleted .

oc:kn_011cb5d4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Phase 4 postmortem root cause analysis" ;
    oc:directiveContent "Use the 5 Whys technique for root cause analysis in postmortems, tracing from symptom through causal chain to root cause." ;
    oc:hasRationale "The 5 Whys method systematically uncovers deeper systemic issues rather than stopping at surface-level symptoms." ;
    oc:severityLevel "MEDIUM" .

oc:kn_20bf96e6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or reviewing any postmortem document" ;
    oc:directiveContent "Postmortems must be blameless — focus on systems and processes, not individuals." ;
    oc:hasRationale "Blameless culture encourages honest reporting and systemic improvement rather than defensive behavior." ;
    oc:severityLevel "HIGH" .

oc:kn_3cda61c3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any incident communication or status update" ;
    oc:directiveContent "Status updates must be factual only: what we know, what we've done, what's next. No speculation." ;
    oc:hasRationale "Speculation in status updates can cause unnecessary panic, spread misinformation, and erode trust." ;
    oc:severityLevel "HIGH" .

oc:kn_7ede9063 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "At the start of any new incident, during Phase 1 triage" ;
    oc:directiveContent "Start writing the incident record immediately — don't wait for complete information. Update as you learn more." ;
    oc:hasRationale "Early documentation preserves the timeline and reduces information loss during chaotic incidents." ;
    oc:severityLevel "HIGH" .

oc:kn_dab38dcf a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When triaging any new incident or re-assessing severity" ;
    oc:directiveContent "Use the SEV1-4 severity classification consistently: SEV1 (all users, immediate), SEV2 (many users, 15 min), SEV3 (some users, 1 hour), SEV4 (low-impact, next business day)." ;
    oc:hasRationale "Consistent severity classification drives appropriate response urgency and resource allocation." ;
    oc:severityLevel "MEDIUM" .

