oc:kn_0dbc286f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When classifying incident severity" ;
    oc:directiveContent "Severity SEV1 requires immediate all-hands response; SEV2 within 15 min; SEV3 within 1 hour; SEV4 next business day" ;
    oc:hasRationale "Response time SLAs ensure appropriate urgency based on blast radius and user impact" ;
    oc:severityLevel "HIGH" .

oc:kn_20159224 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Full incident response lifecycle" ;
    oc:directiveContent "1. Assess severity (SEV1-4) and identify affected systems/users. 2. Assign roles (IC, comms, responders). 3. Draft and publish initial status update. 4. Document mitigation steps and timeline. 5. Confirm resolution. 6. Write blameless postmortem with 5-whys RCA and action items." ;
    oc:stepOrder 1 .

oc:kn_2f0993c5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any incident communication" ;
    oc:directiveContent "Never speculate in status updates — only state what is known, what has been done, and what happens next" ;
    oc:hasRationale "Speculation erodes trust and can cause panic or misinformation during high-stress incidents" ;
    oc:severityLevel "HIGH" .

oc:kn_5d837e65 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the postmortem document" ;
    oc:directiveContent "Postmortems must be blameless — focus on systems and processes, not individuals" ;
    oc:hasRationale "Blameless culture encourages honest reporting and prevents hiding of critical details, leading to better prevention" ;
    oc:severityLevel "CRITICAL" .

oc:kn_659d7824 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a new incident is detected" ;
    oc:directiveContent "Start writing the incident document immediately, even with incomplete information. Update incrementally as you learn more." ;
    oc:hasRationale "Delayed documentation loses critical timeline details and context that cannot be reconstructed later" ;
    oc:severityLevel "HIGH" .

oc:kn_6c62916a a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating postmortem after incident resolution" ;
    oc:directiveContent """## Postmortem: [Incident Title]
**Date:** [Date] | **Duration:** [X hours] | **Severity:** SEV[X]
**Authors:** [Names] | **Status:** Draft

### Summary / Impact / Timeline / Root Cause / 5 Whys / What Went Well / What Went Poorly / Action Items / Lessons Learned""" ;
    oc:templateVariables "5 Whys",
        "Action Items",
        "Authors",
        "Date",
        "Duration",
        "Impact",
        "Incident Title",
        "Lessons Learned",
        "Root Cause",
        "Severity",
        "Summary",
        "Timeline entries",
        "What Went Poorly",
        "What Went Well" .

oc:kn_76c1bb88 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating a status update mid-incident" ;
    oc:directiveContent """## Incident Update: [Title]
**Severity:** SEV[1-4] | **Status:** Investigating | Identified | Monitoring | Resolved
**Impact:** [Who/what is affected]
**Last Updated:** [Timestamp]

### Current Status
[What we know now]

### Actions Taken
- [Action]

### Next Steps
- [What's next and ETA]

### Timeline
| Time | Event |""" ;
    oc:templateVariables "Actions",
        "Current Status",
        "Impact",
        "Next Steps",
        "Severity",
        "Status",
        "Timeline entries",
        "Timestamp",
        "Title" .

oc:kn_c357a7c4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When invoking the skill in different modes" ;
    oc:codeLanguage "shell" ;
    oc:directiveContent """/incident-response new [description]     # Start a new incident
/incident-response update [status]       # Post a status update
/incident-response postmortem            # Generate postmortem from incident data""" .

oc:kn_f0f4ffd8 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting incident response" ;
    oc:directiveContent "Check if monitoring, incident management (PagerDuty/Opsgenie), and chat connectors are available to pull alert details, page responders, and post updates" ;
    oc:hasRationale "Connector availability determines whether the agent can automate alert pulling, responder paging, and channel communication" .

_:ref_41644a9cebb31f73 a oc:WorkflowStep ;
    dcterms:description "**Start writing immediately** — Don't wait for complete information. Update as you learn more." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_5d5ef2ac9b1be8fe a oc:WorkflowStep ;
    dcterms:description "**Postmortems are blameless** — Focus on systems and processes, not individuals." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_e4b83b1577f54986 a oc:WorkflowStep ;
    dcterms:description "**Keep updates factual** — What we know, what we've done, what's next. No speculation." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_78167a0167cdadc4 a oc:WorkflowStep ;
    dcterms:description "Draft internal status update, draft customer communication if needed, set up war room and cadence" ;
    oc:expectedOutcome "Initial status update published, war room established" ;
    oc:stepDependsOn _:ref_a09288483a786f4c ;
    oc:stepId "communicate" .

_:ref_8916574437bd178d a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_41644a9cebb31f73,
        _:ref_5d5ef2ac9b1be8fe,
        _:ref_e4b83b1577f54986 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_a09288483a786f4c a oc:WorkflowStep ;
    dcterms:description "Assess severity (SEV1-4), identify affected systems and users, assign roles (IC, comms, responders)" ;
    oc:expectedOutcome "Severity level assigned, affected scope identified, roles distributed" ;
    oc:stepId "triage" .

_:ref_da569fd7a6c31b06 a oc:WorkflowStep ;
    dcterms:description "Document mitigation steps, track timeline of events, confirm resolution" ;
    oc:expectedOutcome "Incident resolved, mitigation steps documented" ;
    oc:stepDependsOn _:ref_78167a0167cdadc4 ;
