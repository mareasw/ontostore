oc:kn_088c5c4b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating platform coverage" ;
    oc:directiveContent "If no primary file storage platforms (Google Drive, Microsoft 365, Box) are connected, warn the user that results may have significant gaps but proceed with available platforms." ;
    oc:hasRationale "Most brand documents live on file storage platforms; their absence reduces discovery quality substantially" .

oc:kn_5a9d775f a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When Phase 2 triage produces no authoritative sources" ;
    oc:directiveContent "When zero AUTHORITATIVE sources are found, apply adaptive scoring: elevate OPERATIONAL trust weight to 0.9, CONVERSATIONAL to 0.85, and boost inferred-explicitness scores from 0.2→0.5 and 0.4→0.6." ;
    oc:hasRationale "Without formal brand docs, conversational and operational sources become the primary evidence and must carry proportionally more weight" ;
    oc:severityLevel "HIGH" .

oc:kn_8a9dc3fd a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing search strategy" ;
    oc:directiveContent "Notion AI Search federates across connected sources (Google Drive, SharePoint, OneDrive, Slack, Jira, Teams), making it the broadest single search endpoint. Results from Notion may already cover other platforms." ;
    oc:hasRationale "Avoiding duplicate searches across federated platforms saves time and prevents double-counting in ranking" .

oc:kn_b22c8b03 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before launching discovery" ;
    oc:directiveContent "If zero document platforms (Notion, Confluence, Google Drive, Box, Microsoft 365) are connected, stop and inform the user. Gong/Granola/Slack alone cannot contain formal brand documents." ;
    oc:hasRationale "Brand guidelines and style guides almost always live on document storage platforms, not conversation platforms" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d36997e8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Phase 3 deep fetch" ;
    oc:directiveContent "Apply hard recency cutoffs at deep-fetch stage: OPERATIONAL/CONVERSATIONAL/CONTEXTUAL sources older than 12 months are excluded unless zero sources in that category fall within the window. STALE sources are excluded entirely from deep fetch." ;
    oc:hasRationale "Prevents outdated content from polluting the discovery analysis while preserving coverage" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e5d2093b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting discovery" ;
    oc:directiveContent "Read .claude/brand-voice.local.md if it exists to extract company name, enabled platforms, search depth preference, max sources limit, and known brand material locations." ;
    oc:hasRationale "User settings override defaults and reduce unnecessary search scope" .

oc:kn_ec9f1ba1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When ranking discovered sources during triage" ;
    oc:directiveContent "Source ranking uses a composite score: recency (30%) × explicitness (25%) × authority (20%) × specificity (15%) × consistency (10%), multiplied by category trust weight (AUTHORITATIVE=1.0, OPERATIONAL=0.8, CONVERSATIONAL=0.6, CONTEXTUAL=0.3, STALE=0.1)." ;
    oc:hasRationale "Weighted composite scoring ensures systematic, reproducible prioritization of brand evidence" .

oc:kn_f23f194b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When only one platform is connected" ;
    oc:directiveContent "Do not treat a single platform's results as definitive. Discovery works best with 2+ platforms for cross-source validation. Single-platform results have lower confidence scores." ;
    oc:hasRationale "Cross-source validation is a core part of the ranking algorithm (10% weight); single sources cannot be corroborated" ;
    oc:severityLevel "HIGH" .

_:ref_04e03f886f4c87e8 a oc:WorkflowStep ;
    dcterms:description "**Analyze** — I'll categorize and rank what I find, pull the best sources, and produce a discovery report with what I found, any conflicts, and open questions." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_137361efcc5c26a0 a oc:WorkflowStep ;
    dcterms:description "**Generate guidelines now** — chain to `/brand-voice:generate-guidelines` using discovery report as input" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_1e186fc09bd76f2f a oc:WorkflowStep ;
    dcterms:description "**Save report** — store the discovery report to Notion or as a local file" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_2646e85e5eb0d452 a oc:WorkflowStep ;
    dcterms:description "**Expand search** — search additional platforms or deeper if coverage is low" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_2e773df1f390fc86 a oc:WorkflowStep ;
    dcterms:description "**Save** — Guidelines are saved to `.claude/brand-voice-guidelines.md` in your working folder once you approve them. Nothing is written until that step." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_43d28c59f157a6a6 a oc:WorkflowStep ;
    dcterms:description "**If no Google Drive AND no Microsoft 365 AND no Box**: **Warn** (but proceed): \"None of your primary file storage platforms (Google Drive, SharePoint, Box) are connected. Brand documents frequently live on these platforms. Discovery will proceed with [connected platforms], but results may have significant gaps. Consider connecting Google Drive or SharePoint.\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_548d848c89583f6f a oc:WorkflowStep ;
    dcterms:description "**If zero document platforms are connected**: **Stop.** Tell the user: \"You don't have any document storage platforms connected (Google Drive, SharePoint, Notion, Confluence, or Box). Brand guidelines and style guides almost always live on one of these. Please connect at least one before running discovery. Gong/Granola/Slack transcripts are valuable supplements but unlikely to contain formal brand documents.\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_5ce8811070a6850c a oc:WorkflowStep ;
    dcterms:description "**Deep Fetch** — retrieve and extract from top sources" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_6ed05bd4cf80d191 a oc:WorkflowStep ;
    dcterms:description "**Generate guidelines** — Once you've reviewed the report, I can generate a structured brand voice guideline document from the results." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_8290bb4f6255d30b a oc:WorkflowStep ;
    dcterms:description "**Broad Discovery** — parallel searches across platforms" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_a79f76ffe370ded1 a oc:WorkflowStep ;
    dcterms:description "**Discovery Report** — structured output with open questions" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_bf1a1dd9181f8922 a oc:WorkflowStep ;
    dcterms:description "**Resolve open questions first** — work through high-priority questions before generating" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_e6b77dc7d28a4e7f a oc:WorkflowStep ;
    dcterms:description "**If only one platform total is connected**: **Warn** (but proceed): \"Only [platform] is connected. Discovery works best with 2+ platforms for cross-source validation. Results from a single platform will have lower confidence scores.\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_f0ea8e750f8595ff a oc:WorkflowStep ;
    dcterms:description "**Search** — I'll search your connected platforms (Notion, Google Drive, Slack, etc.) for brand-related materials: style guides, pitch decks, templates, transcripts, and more." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_f9464fe4b8cf98dc a oc:WorkflowStep ;
    dcterms:description "**Source Triage** — categorize and rank sources" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

