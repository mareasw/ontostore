oc:skill_anthropics_knowledge_work_plugins_discover_brand_search_strategies a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "search-strategies" ;
    skos:broader "search strategy reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/discover-brand" ;
    oc:contentHash "838bf1b62ac95b4e55cecbe3d64dce8535c66cc2c0f8063cb4ab9f91354cd450" ;
    oc:differentia "provides platform-specific query patterns and tips for discovering brand materials across enterprise tools (Notion, Confluence, Box, Google Drive, SharePoint, Slack, Gong, Granola, Figma)" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_discover_brand ;
    oc:hasArgumentHint "platform name or brand discovery context" ;
    oc:hasCategory "research" ;
    oc:impartsKnowledge oc:kn_004fb018,
        oc:kn_1e2034e6,
        oc:kn_29d36ed0,
        oc:kn_65763eaa,
        oc:kn_6dc25028 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "discover brand guidelines and assets in enterprise tools",
        "formulate effective search queries for brand discovery",
        "maximize brand material coverage across multiple platforms",
        "search for brand materials across platforms" .

oc:kn_004fb018 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When results appear from multiple platforms for the same content" ;
    oc:directiveContent "Track source URLs to detect the same document across platforms and prefer the most recently updated version when duplicates are found. Note when Notion federation returns results from other platforms to avoid double-searching." ;
    oc:hasRationale "Brand documents are often stored redundantly across platforms; deduplication prevents conflicting versions and wasted effort." .

oc:kn_1e2034e6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mining sales call transcripts for brand voice insights" ;
    oc:directiveContent "For Gong conversational intelligence, focus on closed-won calls from top performers to extract implicit brand voice patterns. Compare top performer language with average performer language and look for consistent opening lines and objection handling." ;
    oc:hasRationale "Successful calls by top performers represent the brand voice as it actually works in practice, revealing implicit brand patterns not captured in formal documentation." .

oc:kn_29d36ed0 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a platform search yields no results for brand-specific queries" ;
    oc:directiveContent "If a platform returns zero results, try broader queries like 'marketing' or 'sales'. Check if the platform is actually connected and authenticated. Note the gap in the discovery report — absence of content is itself useful information." ;
    oc:hasRationale "Zero results may indicate the platform is not connected, the content uses different terminology, or brand materials genuinely don't exist there — each scenario requires different handling." .

oc:kn_65763eaa a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating recency and relevance of discovered brand materials" ;
    oc:directiveContent "Focus on content from the last 12 months for operational, conversational, and contextual sources. Only search further back for explicit brand documents (style guides, brand books). Flag any non-AUTHORITATIVE source older than 12 months as potentially outdated." ;
    oc:hasRationale "Brand positioning evolves over time; older operational content may reflect outdated messaging while formal brand documents tend to remain authoritative longer." ;
    oc:severityLevel "HIGH" .

oc:kn_6dc25028 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When beginning brand material discovery across platforms" ;
    oc:directiveContent "Start with Notion AI Search as the primary discovery engine since it federates across connected sources (Google Drive, SharePoint, OneDrive, Slack, Jira, Teams), then follow up with Confluence, Google Drive, Box, SharePoint/OneDrive, Slack, Gong, Granola, and Figma in that order." ;
    oc:hasRationale "Notion AI Search provides the broadest single-query coverage via federation, reducing redundant searches. The ordered sequence ensures high-value sources are checked first." ;
    oc:severityLevel "HIGH" .

