                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Competitor analysis documents" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Background information that informs brand but doesn't define it directly." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Examples:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Signals:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "**Trust weight:** 0.3" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "CONTEXTUAL" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Source Categories" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Apply these five ranking factors in order of priority:" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Score 1.0**: Explicit brand instructions (\"Our voice is...\")" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Score 0.2**: Inferred from conversational patterns" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Score 0.4**: Implicit patterns in templates or examples" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Score 0.7**: Documented tone guidelines (\"Emails should be...\")" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Sources that explicitly define brand voice outrank those that merely demonstrate it." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 11 ;
                            oc:sectionTitle "2. Explicitness (Weight: 25%)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Detailed, actionable guidance outranks vague principles." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Score 0.4**: General principles (\"Be authentic\")" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Score 0.2**: Abstract values only (\"We believe in innovation\")" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Score 1.0**: Specific rules with examples (\"Use 'platform' not 'tool'\")" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Score 0.7**: Detailed guidelines (\"Tone should be warm but professional\")" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 13 ;
                            oc:sectionTitle "4. Specificity (Weight: 15%)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "When two sources conflict, the more recent one wins unless the older source is explicitly marked as the \"official\" guide." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "More recent sources are more likely to reflect current brand voice." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Score 0.4**: Updated within last 2 years" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Score 0.7**: Updated within last year" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Score 1.0**: Updated within last 6 months" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Score 0.1**: Older than 2 years" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "Always prefer the most recent version of any document. When multiple sources cover the same topic, weight the newest one heavily. Flag any non-AUTHORITATIVE source older than 12 months in the discovery report." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 9 ;
                            oc:sectionTitle "1. Recency (Weight: 30%)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**STALE sources**: Exclude entirely from deep fetch. Include in the discovery report for reference only." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**OPERATIONAL, CONVERSATIONAL, CONTEXTUAL sources**: Exclude from deep fetch if older than 12 months, with one exception: if zero sources in a category fall within the 12-month window, include the single most recent source from that category and flag it as potentially stale." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**AUTHORITATIVE sources**: No hard cutoff. Official brand guides remain valid regardless of age unless explicitly superseded by a newer version." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "These cutoffs apply at the deep-fetch stage (Phase 3). All sources are still collected during broad discovery (Phase 1) and triage (Phase 2) — the cutoffs filter what gets fully retrieved and analyzed." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "In addition to soft recency scoring, apply hard cutoffs to prevent stale content from polluting discovery:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 10 ;
                            oc:sectionTitle "Recency Cutoffs" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Higher organizational authority indicates more trustworthy brand definitions." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Score 1.0**: Official brand team or C-suite authored" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Score 0.4**: Team leads or senior ICs" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Score 0.7**: Marketing leadership authored" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Score 0.2**: Individual contributor or unknown author" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 12 ;
                            oc:sectionTitle "3. Authority (Weight: 20%)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Elements corroborated across multiple sources rank higher." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Score 0.1**: Contradicted by another source" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Score 0.4**: Appears in 1 source only" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Score 0.7**: Appears in 2 independent sources" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Score 1.0**: Appears in 3+ independent sources" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 14 ;
                            oc:sectionTitle "5. Cross-Source Consistency (Weight: 10%)" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Ranking Algorithm" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Source Ranking Algorithm" ] ;
    oc:impartsKnowledge oc:kn_299be458,
        oc:kn_5ac0cd97,
        oc:kn_684d5c00,
        oc:kn_6b7aa699,
        oc:kn_8e7cecc3,
        oc:kn_9508e3b3,
        oc:kn_dec84f5e,
        oc:kn_eb9ef8b5 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:SourcesDiscovered ;
    oc:resolvesIntent "categorize brand documents by authority level",
        "prioritize discovered brand materials for deep fetch",
        "rank brand sources by trustworthiness",
        "score sources for brand guideline extraction" ;
    oc:yieldsState oc:DeepFetchCandidatesIdentified,
        oc:SourcesRanked .

oc:kn_299be458 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When Phase 2 triage produces zero AUTHORITATIVE sources" ;
    oc:directiveContent "When zero AUTHORITATIVE sources are found, apply adaptive scoring: boost OPERATIONAL trust weight to 0.9, CONVERSATIONAL to 0.85, CONTEXTUAL to 0.4, and upgrade conversational implicit-pattern explicitness scores from 0.2→0.5 and template patterns from 0.4→0.6" ;
    oc:hasRationale "Without formal brand docs, operational templates and conversational transcripts become the primary brand evidence and must carry more weight to stay above the 0.5 deep-fetch threshold" ;
    oc:severityLevel "HIGH" .

oc:kn_5ac0cd97 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When ranking discovered brand sources" ;
    oc:directiveContent "1. Assign each source to a category (AUTHORITATIVE/OPERATIONAL/CONVERSATIONAL/CONTEXTUAL/STALE). 2. Score each source on recency, explicitness, authority, specificity, consistency. 3. Compute composite score with weighted formula. 4. Multiply by category trust weight. 5. Apply adaptive scoring if zero AUTHORITATIVE sources. 6. Apply recency cutoffs at deep-fetch stage. 7. Select top 5-15 sources with score > 0.5, all AUTHORITATIVE sources, at least one per category, and at least one per platform." ;
    oc:hasRationale "Ensures systematic, fair evaluation of all sources with appropriate safeguards" ;
    oc:severityLevel "HIGH" ;
    oc:stepOrder 1 .

oc:kn_684d5c00 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When categorizing any discovered brand source" ;
    oc:directiveContent "Source categories in descending trust: AUTHORITATIVE (1.0), OPERATIONAL (0.8), CONVERSATIONAL (0.6), CONTEXTUAL (0.3), STALE (0.1)" ;
    oc:hasRationale "Category trust weight multiplies the composite score, so a STALE source cannot outrank an AUTHORITATIVE one even with perfect sub-scores" ;
    oc:severityLevel "HIGH" .

oc:kn_6b7aa699 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when scoring sources" ;
    oc:directiveContent "The composite score formula is: final_score = (recency×0.30) + (explicitness×0.25) + (authority×0.20) + (specificity×0.15) + (consistency×0.10), then ranked_score = final_score × category_trust_weight" ;
    oc:hasRationale "Ensures consistent, reproducible ranking across all discovered brand sources" ;
    oc:severityLevel "CRITICAL" .

oc:kn_8e7cecc3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Phase 3 deep-fetch filtering" ;
    oc:directiveContent "Apply hard recency cutoffs at deep-fetch stage: OPERATIONAL/CONVERSATIONAL/CONTEXTUAL sources older than 12 months are excluded unless they are the only source in their category. STALE sources are always excluded from deep fetch." ;
    oc:hasRationale "Prevents stale content from polluting discovery while preserving at least one source per category as a safety net" ;
    oc:severityLevel "HIGH" .

oc:kn_9508e3b3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering outdated, superseded, or deprecated documents" ;
    oc:directiveContent "Never rely on STALE sources (trust weight 0.1). Flag them for review but exclude from deep fetch. Do not let them influence brand guideline generation." ;
    oc:hasRationale "Stale content reflects past brand identity and can inject outdated messaging into current guidelines" ;
    oc:severityLevel "CRITICAL" .

oc:kn_dec84f5e a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After completing source ranking" ;
    oc:directiveContent "Deep-fetch candidate list includes 5-15 sources with ranked_score > 0.5, covering all available categories and platforms, with conflicts flagged for review" ;
    oc:hasRationale "Ensures adequate breadth and quality of sources for downstream brand guideline generation" .

oc:kn_eb9ef8b5 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When two sources provide contradictory brand guidance" ;
    oc:directiveContent "When conflicting sources exist, the more recent source wins unless the older source is explicitly marked as the official guide. Flag all conflicts for review in the discovery report." ;
    oc:hasRationale "Recency is the strongest signal (30% weight) for resolving conflicts, but explicit official designation overrides it" ;
    oc:severityLevel "MEDIUM" .

