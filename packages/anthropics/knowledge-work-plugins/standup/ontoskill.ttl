    oc:impartsKnowledge oc:kn_29a5f437,
        oc:kn_4e5650f1,
        oc:kn_b406944f,
        oc:kn_c3664692,
        oc:kn_cec07c11 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "format work into yesterday today blockers",
        "generate standup update",
        "prepare for daily standup meeting",
        "summarize recent activity for standup" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_29a5f437 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When connected tools are detected" ;
    oc:directiveContent "If connectors are available, pull data from source control (commits, PRs), project tracker (ticket status changes), chat (discussions, decisions), and CI/CD (build/deploy status) to auto-populate the standup." ;
    oc:hasRationale "Auto-aggregation from multiple sources produces more complete and accurate standups than manual recall." .

oc:kn_4e5650f1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting standup output" ;
    oc:directiveContent "Output must follow the yesterday/today/blockers three-section format with concise, action-oriented bullet points." ;
    oc:hasRationale "This is the standard daily standup format teams expect; deviations reduce clarity and usefulness." ;
    oc:severityLevel "HIGH" .

oc:kn_b406944f a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no connectors are available" ;
    oc:directiveContent "If tools are not connected, accept free-text input from the user about what they worked on and structure it into the standup format." ;
    oc:hasRationale "The skill must remain useful even as a pure formatting/structuring tool without any integrations." .

oc:kn_c3664692 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating a standup update" ;
    oc:directiveContent "The skill operates in two modes: standalone (user provides notes, skill structures them) and supercharged (connected tools auto-pull commits, PRs, ticket changes, chat discussions, and CI/CD status)." ;
    oc:hasRationale "Ensures the skill always works even without connected tools, while providing richer output when integrations are available." .

oc:kn_cec07c11 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Daily routine" ;
    oc:directiveContent "Run the standup skill every morning to build a habit and avoid scrambling for notes before the meeting." ;
    oc:hasRationale "Consistent use reduces preparation stress and ensures no work items are missed." .

_:ref_880bbac91c6f133e a oc:WorkflowStep ;
    dcterms:description "**Share format** — Ask me to format for Slack, email, or your team's standup tool." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_d80d3400c63e0ed7 a oc:WorkflowStep ;
    dcterms:description "**Add context** — After I generate, add any nuance about blockers or priorities." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_edefc88cf22096ca a oc:WorkflowStep ;
    dcterms:description "**Run it every morning** — Build a habit and never scramble for standup notes." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_102cb5b16aa5b60a a oc:WorkflowStep ;
    dcterms:description "Sort activity into three categories: completed work (Yesterday), planned work (Today), and impediments (Blockers)." ;
    oc:expectedOutcome "Activity items categorized into yesterday/today/blockers buckets." ;
    oc:stepDependsOn _:ref_ee9c78981ee0529e ;
    oc:stepId "categorize-activity" .

_:ref_a94c63bc6ec14857 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_880bbac91c6f133e,
        _:ref_d80d3400c63e0ed7,
        _:ref_edefc88cf22096ca ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_ee9c78981ee0529e a oc:WorkflowStep ;
    dcterms:description "Determine data source: if connectors available, pull commits/PRs/ticket changes/chat/CI-CD; otherwise accept free-text notes from user." ;
    oc:expectedOutcome "Raw activity data collected from available sources." ;
    oc:stepId "gather-input" .

