@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_standup a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "standup" ;
    skos:broader "Daily status report generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/standup" ;
    oc:contentHash "6134ff29bcc05e74c22e424d0e7b3ab0c591a94a3d5670fa197cb1447ff435c9" ;
    oc:differentia "that aggregates recent activity from connected tools or manual input into a structured yesterday/today/blockers standup format" ;
    oc:handlesFailure oc:ConnectorUnavailable,
        oc:NoActivityFound ;
    oc:hasArgumentHint "[yesterday | today | blockers]" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Generate a standup update from recent activity. Use when preparing for daily standup, summarizing yesterday's commits and PRs and ticket moves, formatting work into yesterday/today/blockers, or structuring a few rough notes into a shareable update." ;
    oc:hasName "standup" ;
    oc:impartsKnowledge oc:kn_01d988a4,
        oc:kn_2009eca8,
        oc:kn_20abc683,
        oc:kn_8c974df3,
        oc:kn_d96ac763 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:resolvesIntent "format standup notes for sharing",
        "generate standup update",
        "prepare daily standup report",
        "summarize recent work activity" ;
    oc:yieldsState oc:StandupGenerated .

oc:kn_01d988a4 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When determining how to gather standup data" ;
    oc:directiveContent "The skill works standalone with manual user input but is supercharged when source control, project tracker, chat, or CI/CD connectors are available to auto-pull activity." ;
    oc:hasRationale "Allowing both manual and automated data gathering ensures the skill always produces output, while connected tools provide richer, more accurate activity summaries." .

oc:kn_2009eca8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Daily workflow" ;
    oc:directiveContent "Run standup generation every morning to build a consistent habit and avoid scrambling for notes before the meeting." ;
    oc:hasRationale "Consistent standup preparation reduces cognitive load and ensures no work items are forgotten." .

oc:kn_20abc683 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting any standup output" ;
    oc:directiveContent "Structure output into three sections: Yesterday (completed items), Today (planned items), and Blockers (impediments with context on who can help)." ;
    oc:hasRationale "The yesterday/today/blockers format is the industry-standard standup structure that teams expect for synchronous or asynchronous updates." .

oc:kn_8c974df3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Post-generation refinement" ;
    oc:directiveContent "After generating the standup, the user should add nuance about blockers or priorities, and can request alternative formats (Slack, email, standup tool)." ;
    oc:hasRationale "Automated output provides structure but human context about priorities and nuances makes the standup genuinely useful for the team." .

oc:kn_d96ac763 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After generating standup output" ;
    oc:directiveContent "A successful standup output includes ticket references where available, concise action-oriented items, and blockers with enough context for the team to act on." ;
    oc:hasRationale "Actionable standup updates with ticket references enable team coordination and accountability." .

