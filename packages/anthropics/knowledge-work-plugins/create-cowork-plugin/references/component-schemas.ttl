        oc:kn_bd8b488a,
        oc:kn_c3017692,
        oc:kn_d7b09177,
        oc:kn_ff613577 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "configure MCP servers for a plugin",
        "find frontmatter fields for skills or agents",
        "implement plugin components with correct format",
        "look up plugin component schema",
        "review component format specifications",
        "understand hook types and events",
        "write CONNECTORS.md for tool-agnostic plugins" .

oc:kn_029adb8c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between commands and skills format" ;
    oc:directiveContent "Do not use the legacy `commands/` format for new plugins. Use `skills/*/SKILL.md` instead. Commands are only appropriate when you specifically need `$ARGUMENTS`/`$1` substitution or inline bash execution." ;
    oc:hasRationale "The Cowork UI now presents commands and skills as a single concept; skills are the canonical format" ;
    oc:severityLevel "HIGH" .

oc:kn_2a49b9e5 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating CONNECTORS.md for tool-agnostic plugins" ;
    oc:directiveContent """## Connectors

### How tool references work
Plugin files use `~~category` as a placeholder...

### Connectors for this plugin
| Category | Placeholder | Included servers | Other options |
| --- | --- | --- | --- |""" ;
    oc:templateVariables "Category",
        "Included servers",
        "Other options",
        "Placeholder" .

oc:kn_2fa3f013 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing skill content of any length" ;
    oc:directiveContent "Keep SKILL.md body under 3,000 words (ideally 1,500-2,000). Move detailed content to `references/` directory. Use progressive disclosure: metadata (~100 words) → body (<5k words) → bundled resources (unlimited)." ;
    oc:hasRationale "Controls token usage while preserving deep knowledge on demand" ;
    oc:severityLevel "HIGH" .

oc:kn_3389d5fb a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing any plugin component in Phase 4" ;
    oc:directiveContent "1. Determine component type needed (skill, agent, hook, MCP server, command) → 2. Create file at correct location with required frontmatter fields → 3. Follow writing style rules (third-person description, imperative body) → 4. Add references/ and examples/ for deep content → 5. Validate all path references use ${CLAUDE_PLUGIN_ROOT}" ;
    oc:stepOrder 1 .

oc:kn_42b59e1b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building tool-agnostic plugins that may use different MCP backends" ;
    oc:directiveContent "Use `~~category` placeholders in plugin files (e.g., `~~chat`, `~~project tracker`) instead of specific tool names. Define the mapping in CONNECTORS.md with included servers and alternatives." ;
    oc:hasRationale "Enables plugin portability across organizations with different tool stacks" .

oc:kn_6c548306 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring stdio MCP servers in .mcp.json" ;
    oc:codeLanguage "json" ;
    oc:directiveContent """{
  "mcpServers": {
    "my-server": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/servers/server.js"],
      "env": { "API_KEY": "${API_KEY}" }
    }
  }
}""" .

oc:kn_89f43ba5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating agents/agent-name.md files" ;
    oc:directiveContent "Agent frontmatter must include `name` (3-50 chars, lowercase, hyphens, alphanumeric start/end), `description` with `<example>` blocks, `model` (inherit|sonnet|opus|haiku), and `color` (blue|cyan|green|yellow|magenta|red)." ;
    oc:hasRationale "Agent naming and metadata consistency is required for the Cowork UI to display and route correctly" ;
    oc:severityLevel "CRITICAL" .

oc:kn_99809589 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing SKILL.md frontmatter" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """---
name: api-design
description: >
  This skill should be used when the user asks to "design an API",
  "create API endpoints", "review API structure", or needs guidance
  on REST API best practices, endpoint naming, or request/response design.
metadata:
  version: "0.1.0"
---""" .

oc:kn_9b5a6b57 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any file path reference in plugin configuration" ;
    oc:directiveContent "Always use `${CLAUDE_PLUGIN_ROOT}` for referencing plugin directory paths in MCP configs, command scripts, and hook commands instead of hardcoded paths." ;
    oc:hasRationale "Ensures portability across different installation locations and environments" ;
    oc:severityLevel "CRITICAL" .

oc:kn_bd8b488a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing SKILL.md frontmatter for any plugin skill" ;
    oc:directiveContent "Skill frontmatter must include `name` (lowercase, hyphens, matches dir name) and `description` (third-person with trigger phrases in quotes). `metadata` is optional." ;
    oc:hasRationale "Ensures consistent skill discovery, triggering, and identification across the plugin ecosystem" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c3017692 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires understanding of the create-cowork-plugin parent skill and its phases; this is a Phase 4 reference document" .

oc:kn_d7b09177 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing hooks in hooks.json" ;
    oc:directiveContent "Choose hook type based on complexity: prompt-based hooks for complex logic requiring LLM judgment, command-based hooks for deterministic checks. Command hooks return JSON with decision (approve|block|ask_user)." ;
    oc:hasRationale "Prompt hooks leverage LLM reasoning for nuanced decisions; command hooks provide fast, deterministic validation" .

oc:kn_ff613577 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring hooks for tool use interception" ;
    oc:codeLanguage "json" ;
    oc:directiveContent """{
  "PreToolUse": [
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "prompt",
          "prompt": "Check that this file write follows project coding standards.",
          "timeout": 30
        }
      ]
    }
  ]
}""" .

