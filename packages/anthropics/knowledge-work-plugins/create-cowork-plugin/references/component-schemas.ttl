oc:skill_anthropics_knowledge_work_plugins_create_cowork_plugin_component_schemas a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "component-schemas" ;
    skos:broader "Reference specification" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/create-cowork-plugin" ;
    oc:contentHash "730109622d18337565504557086632ed08c877e766bcf11fa507a5929d50d0c6" ;
    oc:dependsOnSkill oc:skill_plugin_structure ;
    oc:differentia "that defines the exact format, field requirements, directory structure, and writing conventions for every plugin component type (skills, agents, hooks, MCP servers, commands, connectors, and README)" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_create_cowork_plugin ;
    oc:handlesFailure oc:InvalidFrontmatter,
        oc:SchemaValidationFailed ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_0d5c55a2,
        oc:kn_1bec60ea,
        oc:kn_394d91c9,
        oc:kn_65e0a9ca,
        oc:kn_cb3c6120 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:PluginStructurePlanned ;
    oc:resolvesIntent "configure MCP server connections and hooks",
        "implement plugin components with correct schema",
        "look up plugin component format specifications",
        "understand progressive disclosure levels for skills",
        "validate component frontmatter fields and structure" ;
    oc:yieldsState oc:ComponentSchemasAvailable .

oc:kn_0d5c55a2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between commands and skills for new plugin components" ;
    oc:directiveContent "Do not use the legacy commands/ format for new plugins. Prefer skills/*/SKILL.md instead. Commands are single-file with $ARGUMENTS substitution and inline bash — only use if you specifically need those features." ;
    oc:hasRationale "The Cowork UI now presents commands and skills as a unified 'Skills' concept; the SKILL.md format supports progressive disclosure and richer structure." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1bec60ea a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring MCP servers in .mcp.json or writing hook commands" ;
    oc:directiveContent "Use ${CLAUDE_PLUGIN_ROOT} for all file references in MCP configs, hooks, and commands to ensure portability. Document all required environment variables in the plugin README." ;
    oc:hasRationale "Hard-coded paths break when plugins are installed in different locations; environment variable substitution enables portable, user-configurable deployments." ;
    oc:severityLevel "HIGH" .

oc:kn_394d91c9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating agent files in agents/ directory" ;
    oc:directiveContent "Agent names must be 3-50 characters, lowercase letters/numbers/hyphens only, start and end with alphanumeric. Frontmatter requires name, description (with <example> blocks), model (inherit/sonnet/opus/haiku), and color fields." ;
    oc:hasRationale "Naming constraints ensure filesystem and UI compatibility across platforms; required fields ensure the agent system can properly route and display agents." ;
    oc:severityLevel "HIGH" .

oc:kn_65e0a9ca a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any SKILL.md file" ;
    oc:directiveContent "Skill descriptions must use third-person voice with specific trigger phrases in quotes; skill bodies must use imperative/infinitive form. Keep SKILL.md under 3,000 words (ideally 1,500-2,000) and move detailed content to references/." ;
    oc:hasRationale "Consistent voice and progressive disclosure keep the skill scannable at metadata level while allowing depth on demand, optimizing token usage during agent execution." ;
    oc:severityLevel "HIGH" .

oc:kn_cb3c6120 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring hooks in hooks/hooks.json" ;
    oc:directiveContent "Hook matchers use pipe-separated tool names (e.g., 'Write|Edit'). Prompt-based hooks support Stop, SubagentStop, UserPromptSubmit, PreToolUse events. Command hooks return JSON with decision: approve, block, or ask_user." ;
    oc:hasRationale "Event-type restrictions prevent runtime errors; the JSON output schema ensures deterministic hook evaluation with clear pass/fail semantics." ;
    oc:severityLevel "MEDIUM" .

