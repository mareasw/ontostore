oc:skill_anthropics_knowledge_work_plugins_create_cowork_plugin_example_plugins a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "example-plugins" ;
    skos:broader "Reference template collection" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/create-cowork-plugin" ;
    oc:contentHash "b7da48c779986eaec9a9d97e8b49654452b85d7b3874fb968fd03826e09ec52e" ;
    oc:differentia "Provides three complete Claude Cowork plugin structures at minimal, standard, and full-featured complexity levels to use as implementation guides during plugin creation" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_create_cowork_plugin ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_12b6d7af,
        oc:kn_8a21e451,
        oc:kn_ba240f8d,
        oc:kn_c6025763,
        oc:kn_f29f4637 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "find a plugin template to copy for implementation",
        "reference plugin structure templates",
        "see example plugins at different complexity levels" .

oc:kn_12b6d7af a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing skill or agent descriptions" ;
    oc:directiveContent "Skill frontmatter descriptions must include specific third-person trigger phrases that users would naturally say (e.g., 'review my changes', 'fix lint errors'). Agent descriptions must include `<example>` blocks with context, user message, assistant response, and commentary." ;
    oc:hasRationale "Specific trigger phrases enable the skill router to match user intent accurately; example blocks teach the agent when to delegate to sub-agents." ;
    oc:severityLevel "HIGH" .

oc:kn_8a21e451 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which template to base implementation on" ;
    oc:directiveContent "Use the minimal template (single skill, no MCP/agents/hooks) as the default starting point. Only escalate to standard or full-featured templates when the user explicitly needs external integrations, autonomous agents, or event-driven hooks." ;
    oc:hasRationale "Most useful plugins start with a single well-crafted skill; additional components add complexity that should be justified by clear requirements." ;
    oc:severityLevel "HIGH" .

oc:kn_ba240f8d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building plugins for external distribution or multi-tool environments" ;
    oc:directiveContent "Use `~~category` placeholders in skills and agents when the plugin is intended for distribution outside an organization. Include a CONNECTORS.md file explaining the placeholder system and listing available options per category." ;
    oc:hasRationale "Tool-agnostic placeholders make plugins portable across organizations that use different tools in the same category (e.g., Jira vs Linear vs Asana)." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c6025763 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning or implementing a new plugin" ;
    oc:directiveContent "Plugins follow a tiered complexity model: minimal (single skill), standard (multiple skills + MCP), and full-featured (skills + agents + hooks + MCP + connectors). Start at the minimal level and add components only as needed." ;
    oc:hasRationale "Starting small ensures each component is well-crafted and useful, avoiding over-engineering." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f29f4637 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating any plugin structure" ;
    oc:directiveContent "Every plugin must have a `.claude-plugin/plugin.json` manifest with at least a `name` field in kebab-case. Component directories (skills/, agents/, hooks/) go at the plugin root, not inside `.claude-plugin/`." ;
    oc:hasRationale "The manifest is the entry point for plugin discovery and validation; incorrect placement breaks plugin loading." ;
    oc:severityLevel "CRITICAL" .

