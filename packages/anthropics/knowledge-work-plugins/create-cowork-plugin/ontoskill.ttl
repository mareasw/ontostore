oc:kn_1baecf8e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Discovery — understand what the user wants to build and why. 2. Component Planning — determine which component types (skills, agents, hooks, MCP) are needed. 3. Design & Clarifying Questions — specify each component in detail, resolve ambiguities. 4. Implementation — create all plugin files following best practices. 5. Review & Package — validate, zip as .plugin, deliver to outputs." ;
    oc:stepOrder 1 .

oc:kn_29e00b2d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During all five phases of the guided workflow" ;
    oc:directiveContent "Do not expose implementation details like file paths, directory structures, or schema fields to the user during the guided conversation unless they ask." ;
    oc:hasRationale "Nontechnical users should interact in terms of what the plugin will do, not how it is structured" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3d5cd5e6 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Packaging the final plugin in Phase 5" ;
    oc:directiveContent "cd /path/to/plugin-dir && zip -r /tmp/plugin-name.plugin . -x \"*.DS_Store\" && cp /tmp/plugin-name.plugin /path/to/outputs/plugin-name.plugin" .

oc:kn_43213dab a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "Implementation order: 1. Create plugin directory structure 2. Create plugin.json manifest 3. Create each component (skills, agents, hooks, MCP) using references/component-schemas.md 4. Create README.md documenting the plugin" ;
    oc:stepOrder 2 .

oc:kn_4c01042b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When scaffolding new plugins" ;
    oc:directiveContent "Always use skills/*/SKILL.md format for new plugins. Do not create commands/ directory unless the user explicitly needs the legacy single-file format." ;
    oc:hasRationale "The Cowork UI presents commands and skills as a single 'Skills' concept; the skills format supports progressive disclosure via references/" ;
    oc:severityLevel "HIGH" .

oc:kn_4c829da8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to use tool-agnostic placeholders" ;
    oc:directiveContent "Do not introduce ~~ placeholders or CONNECTORS.md unless the user explicitly wants to share the plugin externally." ;
    oc:hasRationale "Over-engineering connectors adds complexity for internal-only plugins" ;
    oc:severityLevel "MEDIUM" .

oc:kn_5a77c1b5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing hook configurations, MCP server configs, or any intra-plugin file references" ;
    oc:directiveContent "Always use ${CLAUDE_PLUGIN_ROOT} for all intra-plugin path references in hooks and MCP configs. Never hardcode absolute paths." ;
    oc:hasRationale "Plugins must be portable across different user machines and installation locations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_695eb3e4 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Phase 5 review and packaging" ;
    oc:directiveContent "Before packaging, validate: .claude-plugin/plugin.json exists with valid JSON and name field in kebab-case; all referenced component directories exist with correct file formats; each skill subdirectory contains a SKILL.md." ;
    oc:hasRationale "Catching structural errors before packaging prevents broken plugin installations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7544afd0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring skill content" ;
    oc:directiveContent "Keep SKILL.md body under 3,000 words. Move detailed content to references/ directory for progressive disclosure." ;
    oc:hasRationale "Lean skill bodies minimize token usage when loaded; detailed references are loaded only when needed" .

oc:kn_8426feab a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any SKILL.md body content" ;
    oc:directiveContent "Write skill body content as instructions FOR Claude to follow (imperative/infinitive form), not documentation for the user to read." ;
    oc:hasRationale "Skills are loaded into Claude's context and executed by Claude; user-facing documentation belongs in README.md" ;
    oc:severityLevel "HIGH" .

oc:kn_a0b102c6 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Phase 2 component planning summary table" ;
    oc:directiveContent """| Component | Count | Purpose |
|-----------|-------|---------|
| Skills    | {n}   | {description} |
| Agents    | {n}   | {description} |
| Hooks     | {n}   | {description} |
| MCP       | {n}   | {description} |""" ;
    oc:templateVariables "Component",
        "Count",
        "Purpose" .

oc:kn_aa2d36c8 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Creating the minimal plugin.json manifest" ;
    oc:codeLanguage "json" ;
    oc:directiveContent """{
  "name": "plugin-name",
  "version": "0.1.0",
  "description": "Brief explanation of plugin purpose",
  "author": { "name": "Author Name" }
}""" .

oc:kn_bc9e0750 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning component scope" ;
    oc:directiveContent "Start with the minimum viable set of components. A plugin with one well-crafted skill is more useful than one with five half-baked components." ;
    oc:hasRationale "Smaller, focused plugins are easier to maintain, test, and iterate on" .

oc:kn_c65e7922 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming plugins, skills, agents, or any directory/file in the plugin" ;
    oc:directiveContent "Plugin names must be kebab-case (lowercase letters, numbers, and hyphens only). No spaces, underscores, or special characters." ;
    oc:hasRationale "Convention enforced by the plugin system for consistency and URL safety" ;
    oc:severityLevel "HIGH" .

oc:kn_dfbddd5f a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "During Phase 5 packaging step" ;
    oc:directiveContent "When packaging, always create the zip in /tmp/ first, then copy to the outputs folder. Writing directly to the outputs folder may fail due to permissions." ;
    oc:hasRationale "The outputs directory may have restrictive permissions that prevent direct zip creation" ;
    oc:severityLevel "HIGH" .

oc:req_20ac2fe5 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Plugin component schemas (skills, agents, hooks, MCP, commands)" .

oc:req_3d5f3bcf a oc:RequirementEnvVar ;
    oc:isOptional false ;
    oc:requirementValue "Cowork desktop app environment with access to outputs directory" .

_:ref_1383a583b1266e32 a oc:WorkflowStep ;
    dcterms:description "Run `claude plugin validate <path-to-plugin-json>` to check the plugin structure. If this command is unavailable (e.g., when running inside Cowork), verify the structure manually:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:Paragraph ;
            oc:blockType "paragraph" ;
            oc:contentOrder 2 ;
            oc:textContent "Fix any errors before proceeding." ],
        [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "The `name` field is kebab-case (lowercase letters, numbers, and hyphens only)" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 3 ;
                    oc:itemText "Any component directories referenced by the plugin (`commands/`, `skills/`, `agents/`, `hooks/`) actually exist and contain files in the expected formats — `.md` for commands/skills/agents, `.json` for hooks" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "`.claude-plugin/plugin.json` exists and contains valid JSON with at least a `name` field" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 4 ;
                    oc:itemText "Each skill subdirectory contains a `SKILL.md`" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 5 ;
                    oc:itemText "Report what passed and what didn't, the same way the CLI validator would" ] ] ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

