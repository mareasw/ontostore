@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_pipeline_review a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "pipeline-review" ;
    skos:broader "Sales pipeline analysis framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/pipeline-review" ;
    oc:contentHash "56a6db1a63952378f46dd94628d74d41aea524ea7c77aa134c98a3184548c0ff" ;
    oc:differentia "that scores pipeline health, prioritizes deals by weighted factors, flags risks like stale/stuck/single-threaded deals, audits data hygiene, and generates weekly action plans" ;
    oc:handlesFailure oc:DataNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "<segment or rep>" ;
    oc:hasCategory "sales" ;
    oc:hasDescription "Analyze pipeline health — prioritize deals, flag risks, get a weekly action plan. Use when running a weekly pipeline review, deciding which deals to focus on this week, spotting stale or stuck opportunities, auditing for hygiene issues like bad close dates, or identifying single-threaded deals." ;
    oc:hasName "pipeline-review" ;
    oc:impartsKnowledge oc:kn_0056d3f4,
        oc:kn_099ce885,
        oc:kn_33e4cbd6,
        oc:kn_6275c4c9,
        oc:kn_6f2ef611 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DataAvailable ;
    oc:resolvesIntent "analyze pipeline health",
        "audit pipeline hygiene",
        "flag at-risk deals",
        "generate weekly pipeline action plan",
        "prioritize sales deals",
        "review stale or stuck opportunities" ;
    oc:yieldsState oc:ActionPlanGenerated,
        oc:PipelineReviewed .

oc:kn_0056d3f4 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When advising user on review cadence" ;
    oc:directiveContent "Run pipeline reviews weekly — pipeline health decays rapidly and weekly cadence catches stale deals, hygiene issues, and shifting priorities before they compound." ;
    oc:hasRationale "Sales pipelines are dynamic; weekly reviews prevent stale data from corrupting forecasts and ensure timely intervention on at-risk deals" ;
    oc:severityLevel "LOW" .

oc:kn_099ce885 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing the overall pipeline health score" ;
    oc:directiveContent "Pipeline health is scored across four dimensions: Stage Progression (deals stuck 30+ days), Activity Recency (no activity 14+ days), Close Date Accuracy (past close dates), and Contact Coverage (single-threaded deals). Each dimension is worth 25 points for a total of 100." ;
    oc:hasRationale "A multi-dimensional score prevents a seemingly healthy pipeline from hiding critical weaknesses in any single area" ;
    oc:severityLevel "MEDIUM" .

oc:kn_33e4cbd6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When prioritizing which deals deserve the most attention this week" ;
    oc:directiveContent "Weight deals by Close Date (30%), Deal Size (25%), Stage (20%), Activity (15%), and Risk (10%) to prioritize pipeline focus. Users can override these weights." ;
    oc:hasRationale "This weighted framework balances urgency, value, progress, engagement, and probability to produce actionable prioritization rather than subjective judgment" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6275c4c9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying deals to remove from pipeline" ;
    oc:directiveContent "Never let stale deals inflate pipeline — deals with 60+ days of no activity or pushed 3+ times should be recommended for removal as closed-lost or qualified out." ;
    oc:hasRationale "Dead deals distort pipeline value, corrupt forecast accuracy, and consume mental bandwidth that should go to active opportunities" ;
    oc:severityLevel "HIGH" .

oc:kn_6f2ef611 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When receiving pipeline data from the user" ;
    oc:directiveContent "Accept three input modes: CSV upload from CRM, pasted deal list, or natural language description. The skill must work standalone with any of these inputs and become supercharged when CRM is connected." ;
    oc:hasRationale "Sales reps have varying levels of CRM maturity; supporting flexible input ensures the skill is useful regardless of tooling" ;
    oc:severityLevel "MEDIUM" .

