oc:kn_0678f710 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Every pipeline review output" ;
    oc:directiveContent """# Pipeline Review: {Date}
**Data Source:** {source} | **Deals Analyzed:** {count} | **Total Pipeline Value:** ${value}
## Pipeline Health Score: {score}/100
| Dimension | Score | Issue |
## Priority Actions This Week (top 3 with Why/Action/Impact)
## Deal Prioritization Matrix (Close This Week / Close This Month / Nurture)
## Risk Flags (Stale 14+ days / Stuck 30+ days / Past Close Date / Single-Threaded)
## Hygiene Issues (missing fields)
## Pipeline Shape (by Stage, Close Month, Deal Size)
## Recommendations (This Week / This Month)
## Deals to Consider Removing""" ;
    oc:hasRationale "Consistent format enables week-over-week comparison and quick scanning by sales leadership" ;
    oc:templateVariables "Date",
        "count",
        "score",
        "source",
        "value" .

oc:kn_3f670110 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying dead-weight deals" ;
    oc:directiveContent "Never let stale opportunities sit in pipeline — deals with 60+ days no activity and no response should be marked closed-lost; deals pushed 3+ times with no champion should be qualified out" ;
    oc:hasRationale "Stale deals inflate pipeline value and distort forecasting, giving false confidence" ;
    oc:severityLevel "HIGH" .

oc:kn_44e20c98 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating contact coverage" ;
    oc:directiveContent "Multi-thread every deal — if only one contact exists, the deal is at critical risk because champion departure kills the deal" ;
    oc:hasRationale "Single-threaded deals have a single point of failure; multi-threading reduces risk significantly" .

oc:kn_60869542 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When auditing close date accuracy" ;
    oc:directiveContent "Close dates must represent expected signature dates, not aspirational hopes. Past close dates are a hygiene failure that must be corrected immediately." ;
    oc:hasRationale "Inaccurate close dates undermine forecasting reliability and mask pipeline health problems" ;
    oc:severityLevel "HIGH" .

oc:kn_e86eedc9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When ranking deals for priority actions" ;
    oc:directiveContent "Weight prioritization toward close date (30%) and deal size (25%) by default, but allow user override — e.g., 'focus on big deals' or 'I need quick wins'" ;
    oc:hasRationale "Default weights balance urgency and impact, but different situations require different focus" .

oc:kn_ecc991f8 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Ongoing pipeline management" ;
    oc:directiveContent "Review pipeline weekly — pipeline health decays rapidly and weekly reviews catch stale deals, stuck opportunities, and hygiene issues before they compound" ;
    oc:hasRationale "Pipeline health is not static; without regular review, small issues become missed quarters" .

oc:kn_fe416433 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every pipeline review execution" ;
    oc:directiveContent "1. Collect pipeline data (CSV upload, pasted deals, or natural language description) 2. Compute Pipeline Health Score across 4 dimensions (Stage Progression 25pts, Activity Recency 25pts, Close Date Accuracy 25pts, Contact Coverage 25pts) 3. Apply prioritization framework (Close Date 30%, Deal Size 25%, Stage 20%, Activity 15%, Risk 10%) 4. Flag risks: stale deals (14+ days no activity), stuck deals (30+ days same stage), past close date, single-threaded 5. Audit hygiene: missing close dates, missing amounts, missing next steps, no primary contact 6. Generate weekly action plan with top 3 priority deals and specific next actions" ;
    oc:hasRationale "Structured analysis ensures no deals slip through cracks and focuses effort on highest-impact actions" ;
    oc:stepOrder 1 .

_:ref_0203086fde7a6b4d a oc:WorkflowStep ;
    dcterms:description "**Multi-thread everything** — If one person goes dark, you need a backup contact." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_4659f40ef662ead6 a oc:WorkflowStep ;
    dcterms:description "**Kill dead deals** — Stale opportunities inflate your pipeline and distort forecasts. Be ruthless." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_6ab191f3503b8116 a oc:WorkflowStep ;
    dcterms:description "**Close dates should mean something** — A close date is when you expect signature, not when you hope for one." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_b31f9aeea207b59d a oc:WorkflowStep ;
    dcterms:description "**Review weekly** — Pipeline health decays fast. Weekly reviews catch issues early." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_18c3d5d920a9ba9f a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_0203086fde7a6b4d,
