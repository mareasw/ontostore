    oc:contentHash "bc149ad6bc6e5925812aa5c65cb06c60d1abb41510b89d673664cf30559fe6ff" ;
    oc:differentia "that designs test plans balancing coverage, speed, and maintenance across component types" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "component or system description" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Design test strategies and test plans. Trigger with \"how should we test\", \"test strategy for\", \"write tests for\", \"test plan\", \"what tests do we need\", or when the user needs help with testing approaches, coverage, or test architecture." ;
    oc:hasName "testing-strategy" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: testing-strategy
description: Design test strategies and test plans. Trigger with "how should we test", "test strategy for", "write tests for", "test plan", "what tests do we need", or when the user needs help with testing approaches, coverage, or test architecture.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Design effective testing strategies balancing coverage, speed, and maintenance." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """        /  E2E  \\         Few, slow, high confidence
       / Integration \\     Some, medium speed
      /    Unit Tests  \\   Many, fast, focused
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 12-16" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Testing Pyramid" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**API endpoints**: Unit tests for business logic, integration tests for HTTP layer, contract tests for consumers" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Infrastructure**: Smoke tests, chaos engineering, load tests" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Data pipelines**: Input validation, transformation correctness, idempotency tests" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Frontend**: Component tests, interaction tests, visual regression, accessibility" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Strategy by Component Type" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Produce a test plan with: what to test, test type for each area, coverage targets, and example test cases. Identify gaps in existing coverage." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Focus on: business-critical paths, error handling, edge cases, security boundaries, data integrity." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Skip: trivial getters/setters, framework code, one-off scripts." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "What to Cover" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Testing Strategy" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Produce a comprehensive test plan for a given component or system." ;
            oc:hasStep _:ref_378e11d6b0060c27,
                _:ref_3d9e940f9c636b0e,
                _:ref_cdd0b472843bb93a,
                [ a oc:WorkflowStep ;
                    dcterms:description "Compile the full test plan document with what to test, test types, coverage targets, examples, and gap analysis." ;
                    oc:expectedOutcome "Actionable test plan document." ;
                    oc:stepDependsOn _:ref_3d9e940f9c636b0e,
                        _:ref_f7062c985ae61dac ;
                    oc:stepId "produce-plan" ],
                _:ref_e66997187388c579,
                _:ref_f7062c985ae61dac ;
            oc:workflowId "testing-strategy-design" ;
