oc:skill_anthropics_knowledge_work_plugins_testing_strategy a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "testing-strategy" ;
    skos:broader "Strategy framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/testing-strategy" ;
    oc:contentHash "bc149ad6bc6e5925812aa5c65cb06c60d1abb41510b89d673664cf30559fe6ff" ;
    oc:differentia "that designs test plans balancing coverage, speed, and maintenance across the testing pyramid" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "component or system description to test" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Design test strategies and test plans. Trigger with \"how should we test\", \"test strategy for\", \"write tests for\", \"test plan\", \"what tests do we need\", or when the user needs help with testing approaches, coverage, or test architecture." ;
    oc:hasName "testing-strategy" ;
    oc:impartsKnowledge oc:kn_03593a0d,
        oc:kn_04eae47f,
        oc:kn_b777f323,
        oc:kn_dbdd709f ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "assess test coverage gaps",
        "create test plan",
        "define what to test",
        "design test strategy",
        "determine testing approach" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_03593a0d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When selecting test types for a given component" ;
    oc:directiveContent "Tailor test strategy by component type: APIs need unit + integration + contract tests; data pipelines need input validation + transformation + idempotency tests; frontends need component + interaction + visual regression + accessibility tests; infrastructure needs smoke + chaos + load tests." ;
    oc:hasRationale "Different component types have distinct failure modes and quality attributes that require targeted testing approaches." ;
    oc:severityLevel "HIGH" .

oc:kn_04eae47f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any test strategy" ;
    oc:directiveContent "Follow the testing pyramid: many fast unit tests at the base, some integration tests in the middle, few slow E2E tests at the top." ;
    oc:hasRationale "The pyramid shape optimizes for fast feedback loops while still providing high-confidence end-to-end coverage where it matters." ;
    oc:severityLevel "HIGH" .

oc:kn_b777f323 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When producing test plan output" ;
    oc:directiveContent "A complete test plan includes: what to test, test type for each area, coverage targets, and example test cases. It should also identify gaps in existing coverage." ;
    oc:hasRationale "Structured test plans with concrete examples and gap analysis provide actionable guidance rather than vague directives." ;
    oc:severityLevel "MEDIUM" .

oc:kn_dbdd709f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When prioritizing what to test" ;
    oc:directiveContent "Focus testing effort on business-critical paths, error handling, edge cases, security boundaries, and data integrity. Skip trivial getters/setters, framework code, and one-off scripts." ;
    oc:hasRationale "Testing resources are finite; concentrating on high-risk and high-value areas maximizes defect detection ROI." ;
    oc:severityLevel "MEDIUM" .

