    oc:impartsKnowledge oc:kn_5e4256d8,
        oc:kn_682fd8ad,
        oc:kn_6a0d5798,
        oc:kn_81650677,
        oc:kn_8d16d095 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "assess test coverage gaps",
        "create test plan",
        "define testing architecture",
        "design test strategy",
        "determine testing approaches" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_5e4256d8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When producing test strategy output" ;
    oc:directiveContent "A test plan must include: what to test, test type for each area, coverage targets, and example test cases. It must also identify gaps in existing coverage." ;
    oc:hasRationale "Without these elements, a test plan lacks actionable specificity and cannot be executed or measured." ;
    oc:severityLevel "HIGH" .

oc:kn_682fd8ad a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any test strategy" ;
    oc:directiveContent "Follow the testing pyramid: many fast unit tests at the base, fewer integration tests in the middle, very few slow E2E tests at the top." ;
    oc:hasRationale "This balance optimizes for fast feedback loops while maintaining high confidence in system correctness." ;
    oc:severityLevel "HIGH" .

oc:kn_6a0d5798 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When making strategic testing decisions" ;
    oc:directiveContent "Balance three competing concerns: coverage (completeness), speed (feedback loop), and maintenance (test upkeep cost). Increasing one typically trades off against the others." ;
    oc:hasRationale "An imbalanced strategy leads to either slow CI pipelines, insufficient confidence, or unsustainable maintenance burden." .

oc:kn_81650677 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting test types for a specific component" ;
    oc:directiveContent "Tailor test types to component type: APIs need unit + integration + contract tests; data pipelines need input validation + transformation + idempotency tests; frontends need component + interaction + visual regression + accessibility tests; infrastructure needs smoke + chaos + load tests." ;
    oc:hasRationale "Different component types have different failure modes and quality attributes that require targeted testing approaches." .

oc:kn_8d16d095 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding what to test" ;
    oc:directiveContent "Do not write tests for trivial getters/setters, framework code, or one-off scripts — focus effort where it matters." ;
    oc:hasRationale "Testing trivial code wastes maintenance effort without increasing confidence; focus on business-critical paths, error handling, edge cases, security boundaries, and data integrity." ;
    oc:severityLevel "MEDIUM" .

_:ref_378e11d6b0060c27 a oc:WorkflowStep ;
    dcterms:description "Identify the component types in the system (API endpoints, data pipelines, frontend, infrastructure)." ;
    oc:expectedOutcome "Complete inventory of component types and their boundaries." ;
    oc:stepId "identify-components" .

_:ref_3d9e940f9c636b0e a oc:WorkflowStep ;
    dcterms:description "Write example test cases for each priority area to demonstrate the expected testing approach." ;
    oc:expectedOutcome "Representative test cases that serve as templates for the full test suite." ;
    oc:stepDependsOn _:ref_e66997187388c579 ;
    oc:stepId "write-example-tests" .

_:ref_cdd0b472843bb93a a oc:WorkflowStep ;
    dcterms:description "Map each component type to its appropriate test types using the testing pyramid as a guide." ;
    oc:expectedOutcome "Test type matrix: component → recommended test types with rationale." ;
    oc:stepDependsOn _:ref_378e11d6b0060c27 ;
    oc:stepId "map-test-types" .

_:ref_f7062c985ae61dac a oc:WorkflowStep ;
    dcterms:description "Analyze existing test coverage (if any) and identify gaps against the strategy." ;
    oc:expectedOutcome "Gap analysis with prioritized list of missing tests." ;
    oc:stepDependsOn _:ref_e66997187388c579 ;
    oc:stepId "identify-gaps" .

_:ref_e66997187388c579 a oc:WorkflowStep ;
    dcterms:description "Set coverage targets for each test type, focusing on business-critical paths, error handling, edge cases, security boundaries, and data integrity." ;
    oc:expectedOutcome "Coverage targets per test type with priority areas highlighted." ;
    oc:stepDependsOn _:ref_cdd0b472843bb93a ;
    oc:stepId "define-coverage-targets" .

