oc:kn_31cfa129 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When producing synthesized output" ;
    oc:directiveContent "Do not present uncertain information with the same confidence as well-supported facts. Do not omit source attribution. Do not summarize so aggressively that useful detail is lost." ;
    oc:hasRationale "Conflating confidence levels misleads the user; missing attribution breaks trust; over-summarization destroys information value" ;
    oc:severityLevel "HIGH" .

oc:kn_3b143a22 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing any multi-source result set" ;
    oc:directiveContent "Never list results source-by-source or present raw results without synthesis. Group by topic, not by source." ;
    oc:hasRationale "Source-by-source listing forces the reader to do the synthesis themselves, defeating the purpose of this skill" ;
    oc:severityLevel "HIGH" .

oc:kn_45e8b93c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to merge or keep separate during deduplication" ;
    oc:directiveContent "Keep items separate when: different conclusions exist, different viewpoints from different people, information evolved meaningfully between sources, or different time periods are represented." ;
    oc:hasRationale "Over-aggressive merging collapses important nuance and disagreements into false consensus" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6948cab1 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning the synthesis workflow" ;
    oc:directiveContent "Verify that search results from multiple sources are available before attempting synthesis. Single-source results need only attribution, not deduplication." ;
    oc:hasRationale "Synthesis requires multiple sources to add value over raw search; single-source results need simpler handling" .

oc:kn_7da79d2d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting any synthesized output" ;
    oc:directiveContent "Lead with the answer, not the search process. The user wants the conclusion first, not the methodology." ;
    oc:hasRationale "Inverted pyramid structure ensures the user gets value immediately rather than wading through process details" ;
    oc:severityLevel "HIGH" .

oc:kn_8a8c5d44 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When determining how confidently to present synthesized information" ;
    oc:directiveContent "Assess confidence using freshness × authority × agreement. Freshness matters more for status queries; authority matters more for policy/factual queries." ;
    oc:hasRationale "Mismatches between information type and confidence assessment lead to false certainty or unnecessary hedging" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9c216ed3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — source attribution is mandatory for every claim" ;
    oc:directiveContent "Every claim in the synthesized answer must be attributable to a source. Include source type, specific location, date/relative time, author, and document titles." ;
    oc:hasRationale "Attribution enables verification and builds trust in the synthesized answer" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c02d82e1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When merging duplicate information across multiple sources" ;
    oc:directiveContent "When deduplicating across sources, prefer: (1) most complete version, (2) most authoritative source (official doc > chat), (3) most recent version for evolving info." ;
    oc:hasRationale "This priority order maximizes information quality while respecting source reliability" ;
    oc:severityLevel "MEDIUM" .

oc:kn_db31af68 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sources provide contradictory information" ;
    oc:directiveContent "Never silently pick one version when sources conflict — always surface conflicts explicitly and explain the disagreement." ;
    oc:hasRationale "Silently resolving conflicts hides uncertainty that the user needs to know about to make informed decisions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ddfc1b89 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When formatting synthesized output based on result count" ;
    oc:directiveContent "Scale output detail to result set size: 1-5 results → present everything; 5-15 results → group by theme with top sources; 15+ results → high-level synthesis with drill-down offer." ;
    oc:hasRationale "Matching detail level to result volume prevents overwhelming the user with large sets or under-serving small ones" ;
    oc:severityLevel "MEDIUM" .

_:ref_07bc4e68f011e5fb a oc:WorkflowStep ;
    dcterms:description "Assess confidence — evaluate freshness × authority × source agreement for each claim" ;
    oc:expectedOutcome "Each claim tagged with confidence level and appropriate hedging language" ;
    oc:stepDependsOn _:ref_dce67777e7654568 ;
    oc:stepId "assess-confidence" .

_:ref_26e1299adb929ed7 a oc:WorkflowStep ;
    dcterms:description "Cluster — group related results by theme or topic across sources" ;
    oc:expectedOutcome "Results organized into thematic groups regardless of source origin" ;
    oc:stepDependsOn _:ref_7c381e4f7c90de3b ;
    oc:stepId "cluster" .

_:ref_7c381e4f7c90de3b a oc:WorkflowStep ;
    dcterms:description "Deduplicate — merge same information from different sources using completeness, authority, and recency priority" ;
    oc:expectedOutcome "Duplicate results merged into single items with all contributing sources cited" ;
    oc:stepId "deduplicate" .

_:ref_aa3654b7c012c144 a oc:WorkflowStep ;
    dcterms:description "Synthesize — produce narrative answer with inline source attribution and conflict surfacing" ;
    oc:expectedOutcome "Coherent narrative answer with all claims attributed to sources" ;
    oc:stepDependsOn _:ref_07bc4e68f011e5fb ;
    oc:stepId "synthesize" .

_:ref_dce67777e7654568 a oc:WorkflowStep ;
    dcterms:description "Rank — order clusters and individual items by relevance to the user's query" ;
    oc:expectedOutcome "Prioritized list of clusters and items most relevant to the query" ;
    oc:stepDependsOn _:ref_26e1299adb929ed7 ;
    oc:stepId "rank" .

