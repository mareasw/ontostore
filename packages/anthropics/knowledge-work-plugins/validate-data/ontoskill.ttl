_:ref_7b0328a40b6229fb a oc:WorkflowStep ;
    dcterms:description "Run Pre-Delivery QA Checklist: data quality checks (source, freshness, completeness, nulls, dedup, filters), calculation checks (aggregation, denominators, dates, joins), reasonableness checks, presentation checks" ;
