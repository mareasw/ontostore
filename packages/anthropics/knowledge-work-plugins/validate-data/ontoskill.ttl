@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_validate_data a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "validate-data" ;
    skos:broader "Analysis validation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/validate-data" ;
    oc:contentHash "d671e55cd48e731ac9955e2c458f7c737757f3bde533f3b8bfcf09910c4d7b20" ;
    oc:differentia "that systematically reviews data analyses for methodology soundness, calculation accuracy, common statistical pitfalls, and narrative integrity before stakeholder delivery, producing a tiered confidence assessment" ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput ;
    oc:hasArgumentHint "<analysis to review>" ;
    oc:hasCategory "research" ;
    oc:hasDescription "QA an analysis before sharing -- methodology, accuracy, and bias checks. Use when reviewing an analysis before a stakeholder presentation, spot-checking calculations and aggregation logic, verifying a SQL query's results look right, or assessing whether conclusions are actually supported by the data." ;
    oc:hasName "validate-data" ;
    oc:impartsKnowledge oc:kn_01428ba5,
        oc:kn_1bd8290f,
        oc:kn_20b295e4,
        oc:kn_24106fdc,
        oc:kn_47336fe0,
        oc:kn_4807e8c7,
        oc:kn_4b66607a,
        oc:kn_67a55ad9,
        oc:kn_b54c264d,
        oc:kn_f31e704a ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:AnalysisAvailable ;
    oc:resolvesIntent "assess visualizations for misleading presentation",
        "check analytical methodology and assumptions",
        "generate confidence assessment for stakeholder delivery",
        "identify analytical bias and statistical pitfalls",
        "review data analysis for errors",
        "spot-check calculations and aggregations",
        "validate analysis before sharing" ;
    oc:yieldsState oc:AnalysisValidated,
        oc:ConfidenceAssessmentGenerated .

oc:kn_01428ba5 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When asked to review or validate any data analysis before stakeholder delivery" ;
    oc:directiveContent "Validate analyses using a structured 8-step workflow: methodology review, QA checklist, pitfall catalog check, calculation verification, visualization assessment, narrative evaluation, improvement suggestions, and confidence rating." ;
    oc:hasRationale "Ad-hoc validation misses systematic issues; a structured checklist ensures consistent coverage of methodology, calculations, biases, and presentation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1bd8290f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing period-over-period comparisons (MoM, QoQ, YoY)" ;
    oc:directiveContent "Never compare a partial period to a full period — always filter to complete periods or compare same-number-of-days." ;
    oc:hasRationale "Partial period comparisons create artificial declines or growth that misleads stakeholders into acting on phantom trends." ;
    oc:severityLevel "CRITICAL" .

oc:kn_20b295e4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining cohorts, segments, or groups for comparative analysis" ;
    oc:directiveContent "Define segments based on pre-treatment characteristics, not on the outcome being measured, to avoid circular reasoning (selection bias)." ;
    oc:hasRationale "Segments defined by outcomes create tautological findings — 'users who completed onboarding have higher retention' is self-evident, not insightful." ;
    oc:severityLevel "HIGH" .

oc:kn_24106fdc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When producing the final validation output for any analysis review" ;
    oc:directiveContent "Rate analysis confidence on a 3-level scale — 'Ready to share', 'Share with noted caveats', or 'Needs revision' — to give stakeholders clear, actionable guidance." ;
    oc:hasRationale "Binary pass/fail is too coarse; a 3-level scale communicates nuance while remaining decision-ready for stakeholders who need to know whether to act on the analysis." ;
    oc:severityLevel "LOW" .

oc:kn_47336fe0 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "When performing calculation spot-checks as part of the validation workflow" ;
    oc:directiveContent "After validation, verify that subtotals sum to totals, percentages sum to ~100%, YoY/MoM comparisons use correct base periods, and filters are applied consistently across all metrics." ;
    oc:hasRationale "Inconsistencies in arithmetic and period alignment are the most common concrete errors in analyses and are easily caught by targeted spot-checks." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4807e8c7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing reasonableness and sanity checks on analysis results" ;
    oc:directiveContent "Investigate any metric that changed by more than 50% period-over-period without an obvious cause, exact round-number results, rates at exactly 0% or 100%, or results that perfectly confirm the hypothesis." ;
    oc:hasRationale "These red flags reliably indicate data quality issues, query errors, or methodological problems that would otherwise go undetected." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4b66607a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "At the start of every validation workflow, before reviewing methodology or calculations" ;
    oc:directiveContent "Before validating any analysis, confirm: data source correctness and freshness, null handling, deduplication status, and filter completeness." ;
    oc:hasRationale "Data quality issues at the source propagate through every downstream calculation, making even correct methodology produce wrong results." ;
    oc:severityLevel "HIGH" .

oc:kn_67a55ad9 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When reviewing any analysis involving time-series comparisons, segmentation, or rate calculations" ;
    oc:directiveContent "Survivorship bias, denominator shifting, timezone mismatches, and Simpson's paradox are the most commonly overlooked analytical pitfalls — check for them systematically." ;
    oc:hasRationale "These pitfalls are pernicious because they produce results that look reasonable on the surface but lead to fundamentally wrong conclusions." ;
    oc:severityLevel "HIGH" .

oc:kn_b54c264d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating aggregate metrics from segmented or grouped data" ;
    oc:directiveContent "Never average pre-computed averages when group sizes differ — always aggregate from raw data to avoid the 'average of averages' fallacy." ;
    oc:hasRationale "Averaging averages ignores the weight of each group, producing misleading results that can be dramatically wrong when group sizes are unequal." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f31e704a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing SQL queries with JOINs, especially across tables with uncertain cardinality" ;
    oc:directiveContent "Check row counts before and after JOINs to detect many-to-many join explosion that silently inflates counts and sums." ;
    oc:hasRationale "Many-to-many joins can multiply rows without any error or warning, producing inflated metrics that look plausible but are entirely wrong." ;
    oc:severityLevel "HIGH" .

