    oc:impartsKnowledge oc:kn_0816e21d,
        oc:kn_361e405c,
        oc:kn_432f0acd,
        oc:kn_b899e278,
        oc:kn_d2f05113,
        oc:kn_ec2551cf ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet ;
    oc:resolvesIntent "enrich decision-maker contacts with emails and phone numbers",
        "find leads matching ideal customer profile",
        "generate prospect list from ICP description",
        "rank leads by ICP fit score" ;
    oc:yieldsState oc:LeadTableGenerated,
        oc:LeadsEnriched .

oc:kn_0816e21d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting lead results (Step 6)" ;
    oc:directiveContent "Use a 4-criteria ICP Fit scoring system: title match, seniority match, company size match, industry match. Score Strong (4/4), Good (3/4), Partial (2/4)." ;
    oc:hasRationale "Standardized scoring lets users quickly prioritize high-fit leads without manual cross-referencing." ;
    oc:severityLevel "MEDIUM" .

oc:kn_361e405c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling apollo_people_bulk_match (Step 5)" ;
    oc:directiveContent "Bulk match enriches up to 10 leads per call. If more than 10 leads, batch into multiple sequential calls." ;
    oc:hasRationale "The Apollo API has a 10-lead limit per bulk match request; exceeding it will cause API errors." ;
    oc:severityLevel "HIGH" .

oc:kn_432f0acd a oc:KnowledgeNode,
        oc:RequiresHumanClarification ;
    oc:appliesToContext "When parsing user-provided ICP description (Step 1)" ;
    oc:directiveContent "If the ICP description is vague, ask 1-2 clarifying questions before proceeding. At minimum, a title/role AND an industry or company size are required." ;
    oc:hasRationale "Insufficient ICP filters produce irrelevant results and waste credits on low-quality leads." ;
    oc:severityLevel "HIGH" .

oc:kn_b899e278 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before calling apollo_people_bulk_match (Step 5)" ;
    oc:directiveContent "Never proceed with enrichment without first warning the user about exact credit consumption costs." ;
    oc:hasRationale "Apollo enrichment consumes credits per lead; failing to warn the user leads to unexpected costs and trust erosion." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d2f05113 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Throughout the pipeline, especially Steps 3 and 5" ;
    oc:directiveContent "Each enrichment call consumes Apollo credits. Steps 3 and 5 are the primary credit consumers." ;
    oc:hasRationale "Users need awareness of cumulative credit spend across company enrichment and people enrichment stages." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ec2551cf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finding decision makers (Step 4)" ;
    oc:directiveContent "Always scope person searches (Step 4) to the enriched company domains rather than searching broadly, to maximize relevance." ;
    oc:hasRationale "Domain-scoped searches ensure leads come from pre-qualified companies, improving result quality and reducing noise." ;
    oc:severityLevel "MEDIUM" .

_:ref_119f9a3030db4885 a oc:WorkflowStep ;
    dcterms:description "**Refine the search** — Adjust filters and re-run" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_13fdc61c7c46ab54 a oc:WorkflowStep ;
    dcterms:description "**Deep-dive a company** — Run `/apollo:company-intel` on any company from the list" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_983855ae61137a8d a oc:WorkflowStep ;
    dcterms:description "**Load into a sequence** — Ask which sequence and run the sequence-load flow for these contacts" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_a12a2b978dbf8320 a oc:WorkflowStep ;
    dcterms:description "**Save all to Apollo** — Bulk-create contacts via `mcp__claude_ai_Apollo_MCP__apollo_contacts_create` with `run_dedupe: true` for each lead" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_b8e0a06a949c2d3c a oc:WorkflowStep ;
    dcterms:description "**Export** — Format leads as a CSV-style table for easy copy-paste" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_50898a87b57f6968 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_119f9a3030db4885,
        _:ref_13fdc61c7c46ab54,
        _:ref_983855ae61137a8d,
        _:ref_a12a2b978dbf8320,
        _:ref_b8e0a06a949c2d3c ;
    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_8287e51cb4864da8 a oc:WorkflowStep ;
    dcterms:description "Bulk match up to 10 leads per call via apollo_people_bulk_match with reveal_personal_emails=true; batch if needed. Warn user about credit cost first." ;
    oc:expectedOutcome "Enriched lead contacts with emails and phone numbers" ;
    oc:stepDependsOn _:ref_bc80d9907a12928a ;
    oc:stepId "enrich-leads" .

_:ref_ae28c5a31f2f4483 a oc:WorkflowStep ;
    dcterms:description "Search Apollo for companies matching the parsed company filters using apollo_mixed_companies_search with per_page=25" ;
    oc:expectedOutcome "Up to 25 company results matching the ICP criteria" ;
    oc:stepDependsOn _:ref_eed6613c40a298d1 ;
    oc:stepId "search-companies" .

_:ref_ba3d8df8c70c6e9c a oc:WorkflowStep ;
    dcterms:description "Present results in a ranked table with Name, Title, Company, Employees, Revenue, Email, Phone, and ICP Fit (Strong/Good/Partial). Include summary with lead count and credits consumed." ;
    oc:expectedOutcome "Formatted lead table visible to user with ICP fit scores" ;
    oc:stepDependsOn _:ref_8287e51cb4864da8 ;
    oc:stepId "present-table" .

_:ref_bc80d9907a12928a a oc:WorkflowStep ;
    dcterms:description "Search for decision makers at enriched companies using apollo_mixed_people_api_search scoped to those domains with per_page=25" ;
    oc:expectedOutcome "Up to 25 person results matching the ICP role/seniority criteria at target companies" ;
    oc:stepDependsOn _:ref_f78c3a1ad6148aaa ;
    oc:stepId "find-people" .

_:ref_eed6613c40a298d1 a oc:WorkflowStep ;
    dcterms:description "Parse the natural language ICP description into structured company and person filters (title, seniority, industry, size, location, domains)" ;
    oc:expectedOutcome "Structured filter map with company filters (q_organization_keyword_tags, organization_num_employees_ranges, organization_locations, q_organization_domains_list) and person filters (person_titles, person_senorities, person_locations)" ;
    oc:stepId "parse-icp" .

_:ref_f78c3a1ad6148aaa a oc:WorkflowStep ;
    dcterms:description "Bulk enrich top 10 company domains using apollo_organizations_bulk_enrich to get revenue, funding, headcount, and firmographic data" ;
    oc:expectedOutcome "Enriched company profiles with revenue, funding, headcount data for ranking" ;
    oc:stepDependsOn _:ref_ae28c5a31f2f4483 ;
    oc:stepId "enrich-companies" .

