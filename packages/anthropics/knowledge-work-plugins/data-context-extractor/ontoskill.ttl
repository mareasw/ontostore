    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create a data analysis skill",
        "document database schemas and metrics",
        "extract tribal knowledge from analysts",
        "generate a data context skill for a warehouse",
        "improve an existing data analysis skill",
        "set up data analysis for a warehouse" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_12a5117b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before packaging and delivering any generated skill" ;
    oc:directiveContent "Validate generated skill: SKILL.md has frontmatter with name+description, no unfilled placeholders, entity disambiguation present, standard filters documented, 2-3 sample queries per domain, correct SQL dialect syntax, reference files linked from navigation" .

oc:kn_20a44279 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any data analysis skill" ;
    oc:directiveContent "Include SQL dialect-specific notes in every generated skill covering: table reference syntax, safe division, date functions, column exclusion, array handling, and JSON access patterns" ;
    oc:hasRationale "SQL dialect differences are a major source of query errors; dialect-specific guidance prevents syntax mistakes across warehouses" .

oc:kn_288f19fc a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Iteration mode - improving an existing data analysis skill" ;
    oc:directiveContent "1. Load existing skill (zip or folder) 2. Identify gap by asking what queries fail or produce wrong results 3. Explore relevant tables for the identified domain 4. Ask domain-specific questions (tables, metrics, filters, gotchas) 5. Generate new references/[domain].md using domain template 6. Update SKILL.md navigation section 7. Repackage" ;
    oc:hasRationale "Iterative improvement targets specific gaps rather than recreating everything, preserving existing validated content" ;
    oc:stepOrder 2 .

oc:kn_30efdb3a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating SKILL.md for any data skill" ;
    oc:directiveContent "Always include entity disambiguation section documenting what ambiguous terms (user, customer, account) mean in the specific business context with their tables and ID fields" ;
    oc:hasRationale "Ambiguous entity terms are the #1 source of incorrect queries; explicit disambiguation prevents costly misanalysis" ;
    oc:severityLevel "HIGH" .

oc:kn_7e235080 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Bootstrap mode - creating a new data analysis skill" ;
    oc:directiveContent "1. Identify database type (BigQuery/Snowflake/PostgreSQL/Databricks) 2. Explore schema: list datasets, identify 3-5 most-queried tables, pull schema details 3. Ask core questions conversationally: entity disambiguation, primary identifiers, key metrics, data hygiene, common gotchas 4. Generate skill using templates (SKILL.md, domain references, SQL dialect section) 5. Validate with quality checklist 6. Package as zip" ;
    oc:hasRationale "Ordered phases ensure complete knowledge extraction before skill generation, avoiding incomplete or generic output" ;
    oc:stepOrder 1 .

oc:kn_807dcc3f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before delivering any generated skill" ;
    oc:directiveContent "Never deliver a skill with unfilled placeholder text like [COMPANY], [PLACEHOLDER], or generic template variables" ;
    oc:hasRationale "Unfilled placeholders indicate incomplete extraction and produce a non-functional skill that confuses downstream agents" ;
    oc:severityLevel "CRITICAL" .

oc:kn_85c3a623 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating the output skill directory" ;
    oc:directiveContent """Generated skill structure:
[company]-data-analyst/
├── SKILL.md (frontmatter, dialect, entity disambiguation, terminology, filters, metrics, navigation, queries)
└── references/
    ├── entities.md (entity definitions and relationships)
    ├── metrics.md (KPI calculations and formulas)
    ├── tables/[domain].md (one per domain: revenue, users, product, etc.)
    └── dashboards.json (optional)""" ;
    oc:templateVariables "company",
        "domain" .

oc:kn_9a9b23e9 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When estimating engagement length" ;
    oc:directiveContent "Bootstrap mode requires multiple conversational turns (5-10) to extract all tribal knowledge; iteration mode requires fewer (2-4 turns) for targeted domain updates" ;
    oc:hasRationale "Sets expectations for analyst time commitment and helps plan the extraction session" .

oc:kn_c0724341 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running bootstrap mode" ;
    oc:directiveContent "Requires access to data warehouse MCP tools (schema exploration and query execution) or user-provided schema information" ;
    oc:hasRationale "Schema discovery depends on being able to inspect the actual warehouse structure" .

oc:kn_e5738447 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Phase 2 of bootstrap mode" ;
    oc:directiveContent "Ask the 5 core questions conversationally, not all at once: (1) Entity disambiguation, (2) Primary identifiers, (3) Key metrics with exact formulas, (4) Data hygiene filters, (5) Common gotchas new analysts make" ;
    oc:hasRationale "Conversational questioning yields richer, more accurate answers than overwhelming analysts with a form-like interview" .

oc:kn_f28b5e5e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating references/[domain].md files" ;
    oc:directiveContent "For domain reference files, start with the most-queried tables, include real query examples over abstract descriptions, and document gotchas prominently" ;
    oc:hasRationale "Real examples and prominent gotchas provide more actionable value than exhaustive but abstract documentation" .

oc:kn_f2b69586 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When packaging a generated skill into a distributable zip file" ;
    oc:codeLanguage "python" ;
    oc:directiveContent "python scripts/package_data_skill.py <skill-folder-path> [output-directory]" .

oc:payload_eec834c52b066624 a oc:ExecutionPayload ;
    oc:code "python scripts/package_data_skill.py <skill-folder-path> [output-directory]" ;
    oc:executor "python" ;
    oc:timeout 30000 .

