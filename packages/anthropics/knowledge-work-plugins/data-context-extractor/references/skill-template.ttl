@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_data_context_extractor_skill_template a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "skill-template" ;
    skos:broader "Template reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/data-context-extractor" ;
    oc:contentHash "0ceedd25de9a1e278832fc84e6124334af1bc6eaf7e4d3a29f31c23451cb3a71" ;
    oc:differentia "that defines the fill-in-the-blank structure for generating company-specific data analysis skills, including entity disambiguation, business terminology, standard filters, key metrics, data freshness, common query patterns, and troubleshooting sections" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_data_context_extractor ;
    oc:handlesFailure oc:PlaceholdersUnfilled ;
    oc:hasArgumentHint "company and warehouse metadata to fill placeholders" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_0d1ec19d,
        oc:kn_4ae88dd5,
        oc:kn_6056cd1c,
        oc:kn_658d4136,
        oc:kn_9258b9aa ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:CoreQuestionsAnswered,
        oc:SchemaDiscovered ;
    oc:resolvesIntent "create a data context skill template for a warehouse",
        "generate a company-specific data analysis skill",
        "structure a data analysis skill with SQL dialect, metrics, and entity definitions" ;
    oc:yieldsState oc:SkillTemplateReady .

oc:kn_0d1ec19d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling in the template's query patterns and metric definitions" ;
    oc:directiveContent "Prefer specific column names, table names, and actual SQL examples over generic advice. Include real query patterns with actual schema references." ;
    oc:hasRationale "Generic advice provides less value than concrete, runnable examples that the agent can adapt; specificity is what makes a generated skill superior to a generic one" .

oc:kn_4ae88dd5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When customizing the template for a specific company" ;
    oc:directiveContent "Remove unused sections rather than leaving them empty. If the company has no dashboards, omit the dashboards section entirely." ;
    oc:hasRationale "Empty sections create confusion and suggest incompleteness; a lean, relevant skill is more effective than a bloated one with unused sections" .

oc:kn_6056cd1c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating any company-specific data analysis skill" ;
    oc:directiveContent "Every generated skill must include: SQL dialect notes, entity disambiguation, business terminology table, standard filters with SQL, at least 2-3 key metrics with formulas, data freshness table, knowledge base navigation, and common query patterns." ;
    oc:hasRationale "These sections collectively ensure the agent has enough context to write correct queries, avoid common pitfalls, and understand the business domain" ;
    oc:severityLevel "HIGH" .

oc:kn_658d4136 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating a skill from the template" ;
    oc:directiveContent "All [PLACEHOLDER] values must be replaced with actual company-specific data before the generated skill is usable. No placeholder text should remain in the final output." ;
    oc:hasRationale "Leaving placeholders produces a non-functional skill that will confuse the agent when it tries to reference specific tables, columns, or metrics" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9258b9aa a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "After generating a skill from the template, before packaging and delivery" ;
    oc:directiveContent "Before delivering a generated skill, verify: complete frontmatter, clear entity disambiguation, defined terminology, documented standard filters, at least 2-3 sample queries per domain, correct SQL dialect syntax, and linked reference files." ;
    oc:hasRationale "Skipping validation can produce skills with broken SQL, missing sections, or incorrect dialect syntax that will fail in production use" ;
    oc:severityLevel "HIGH" .

