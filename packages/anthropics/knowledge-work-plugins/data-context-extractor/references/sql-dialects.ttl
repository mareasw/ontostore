        oc:kn_f0aaba6f ;
    oc:isUserInvocable false ;
    oc:nature "Reference" ;
    oc:requiresState oc:DataWarehouseIdentified ;
    oc:resolvesIntent "adapt SQL between BigQuery, Snowflake, PostgreSQL, Databricks, and MySQL",
        "find equivalent SQL functions across data warehouses",
        "reference SQL dialect syntax",
        "write dialect-specific SQL queries" ;
    oc:yieldsState oc:DialectReferenceReady .

oc:kn_1960a200 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing SELECT statements that exclude columns in PostgreSQL, Redshift, or MySQL" ;
    oc:directiveContent "PostgreSQL and MySQL do not support SELECT * EXCEPT/EXCLUDE — all columns must be listed explicitly when excluding columns." ;
    oc:hasRationale "Using EXCEPT/EXCLUDE on unsupported dialects will cause syntax errors" ;
    oc:severityLevel "HIGH" .

oc:kn_8a448c79 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating or embedding SQL dialect guidance into skills" ;
    oc:directiveContent "Include only the dialect section matching the user's data warehouse in generated skills, not all dialects at once." ;
    oc:hasRationale "Including irrelevant dialects adds noise and increases the chance of the agent using wrong syntax" .

oc:kn_d8c0f894 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating SQL for any data warehouse" ;
    oc:directiveContent "Each data warehouse has unique syntax for table references, safe division, date functions, array handling, JSON access, and string matching. Always use the dialect-specific syntax rather than generic SQL." ;
    oc:hasRationale "Using wrong dialect syntax causes query failures and confusion" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e5ae0c32 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing safe division logic" ;
    oc:directiveContent "Do not use PostgreSQL's NULLIF(b, 0) division guard pattern on BigQuery or Snowflake — use SAFE_DIVIDE() or DIV0()/DIV0NULL() respectively for cleaner, more idiomatic code." ;
    oc:hasRationale "Dialect-native safe division functions are clearer and less error-prone than manual NULLIF workarounds" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f0aaba6f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing cross-dialect SQL" ;
    oc:directiveContent "When uncertain about a function, check the common patterns table first — CONCAT, COALESCE, CASE WHEN, and COUNT(DISTINCT) are nearly universal across all dialects." ;
    oc:hasRationale "Leveraging universally supported functions reduces dialect-specific branching" .

