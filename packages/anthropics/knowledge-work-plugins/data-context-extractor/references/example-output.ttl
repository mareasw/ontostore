@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_data_context_extractor_example_output a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "example-output" ;
    skos:broader "Example artifact" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/data-context-extractor" ;
    oc:contentHash "b19e188ed03d9417ff1136187944a6f9125c7da40b6ecb22abe096edd985932e" ;
    oc:differentia "Demonstrates the expected structure and content of a generated data analysis skill after bootstrap completion, using a fictional e-commerce company as the reference model" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_data_context_extractor ;
    oc:hasCategory "research" ;
    oc:impartsKnowledge oc:kn_093b52a0,
        oc:kn_5e2a3900,
        oc:kn_6538453b,
        oc:kn_c607150a,
        oc:kn_f547d3c9 ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:requiresState oc:SkillGenerated ;
    oc:resolvesIntent "understand expected skill structure",
        "validate generated skill quality",
        "visualize generated skill output" ;
    oc:yieldsState oc:ExampleOutputReviewed .

oc:kn_093b52a0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When capturing tribal knowledge during the bootstrap process" ;
    oc:directiveContent "Always document entity disambiguation (e.g., 'Customer' vs 'User' vs 'Account') with the specific table and ID field for each meaning." ;
    oc:hasRationale "Ambiguous entity terms are the most common source of incorrect joins and misleading metrics in data analysis" ;
    oc:severityLevel "HIGH" .

oc:kn_5e2a3900 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When packaging and delivering a generated skill" ;
    oc:directiveContent "Never leave unfilled placeholders like [PLACEHOLDER] or [COMPANY] in the final generated skill output." ;
    oc:hasRationale "Unfilled placeholders indicate incomplete extraction and will confuse the agent using the skill, leading to generic or incorrect SQL" ;
    oc:severityLevel "CRITICAL" .

oc:kn_6538453b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating or validating a data analysis skill" ;
    oc:directiveContent "Generated skills must include complete frontmatter, dialect-specific SQL notes, entity disambiguation, terminology glossary, standard filters as runnable SQL, metric definitions with formulas, navigation to reference files, and real runnable query examples." ;
    oc:hasRationale "These components collectively ensure the generated skill provides enough company-specific context for accurate SQL generation and data analysis" ;
    oc:severityLevel "HIGH" .

oc:kn_c607150a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing sample queries for generated skills" ;
    oc:directiveContent "Sample queries must use real table and column names from the discovered schema, not generic placeholders like [TABLE_NAME]." ;
    oc:hasRationale "Generic queries are not actionable; real table references let analysts copy-paste and iterate directly" ;
    oc:severityLevel "CRITICAL" .

oc:kn_f547d3c9 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When documenting standard filters in generated skills" ;
    oc:directiveContent "Standard exclusion filters (test data, internal users, cancelled orders) should be documented as copy-paste SQL snippets that apply by default unless explicitly overridden." ;
    oc:hasRationale "Default filters prevent accidental inclusion of non-production data in analytics, which is the most common mistake new analysts make" ;
    oc:severityLevel "MEDIUM" .

