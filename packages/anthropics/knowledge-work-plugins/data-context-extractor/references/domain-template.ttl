@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_data_context_extractor_domain_template a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "domain-template" ;
    skos:broader "Reference template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/data-context-extractor" ;
    oc:contentHash "ad5658dba15bf15faae05ade116cdb9bc5c7cac2057a3dbd56a52556bf25faba" ;
    oc:differentia "that provides a structured markdown schema for documenting data domain tables, metrics, and query patterns" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_data_context_extractor ;
    oc:hasArgumentHint "domain-name (e.g., revenue, users, marketing)" ;
    oc:hasCategory "document" ;
    oc:impartsKnowledge oc:kn_16229617,
        oc:kn_17fb83c1,
        oc:kn_2b5fea8f,
        oc:kn_39582562,
        oc:kn_8d3ed95a ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "create domain reference documentation",
        "document data tables and metrics for a specific domain",
        "generate query pattern guides for data domains" .

oc:kn_16229617 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting entity definitions in domain reference files" ;
    oc:directiveContent "Never skip documenting ambiguous domain terms and entity clarification. Always explicitly map ambiguous terms to their table and ID field before querying." ;
    oc:hasRationale "Ambiguous terms (e.g., 'user', 'account', 'subscription') lead to wrong-table queries and incorrect metrics. Explicit disambiguation prevents costly analytical errors." ;
    oc:severityLevel "CRITICAL" .

oc:kn_17fb83c1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting table schemas and query patterns" ;
    oc:directiveContent "Document gotchas prominently with explicit wrong vs. right examples, and note nested/struct fields explicitly since they trip people up most frequently." ;
    oc:hasRationale "Gotchas and struct/nested fields are the highest-friction points for analysts. Prominent documentation with before/after examples reduces repeated mistakes across the team." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2b5fea8f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any domain reference file" ;
    oc:directiveContent "Start with the most-queried tables rather than attempting exhaustive documentation. Focus on high-value content that saves analysts the most time." ;
    oc:hasRationale "Prioritizing frequently-used tables maximizes the utility of the reference file and avoids bloated documentation that nobody reads." ;
    oc:severityLevel "HIGH" .

oc:kn_39582562 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining query conventions for any domain" ;
    oc:directiveContent "Always include standard filters that must be applied for the domain (e.g., status filters, date ranges, soft-delete exclusions) as a prominent section." ;
    oc:hasRationale "Missing standard filters is the most common cause of incorrect metrics. Surfacing these prominently prevents analysts from forgetting essential WHERE clauses." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8d3ed95a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing sample queries in domain reference files" ;
    oc:directiveContent "Include real, runnable SQL query examples with actual table and column names rather than abstract descriptions. Show, don't tell." ;
    oc:hasRationale "Real query examples are immediately actionable and reveal nuances like join patterns, filter conventions, and gotchas that abstract descriptions miss." ;
    oc:severityLevel "MEDIUM" .

