    oc:resolvesIntent "create domain reference file",
        "document data domain tables and metrics",
        "generate data analysis reference documentation" .

oc:kn_20b79287 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating a domain reference file" ;
    oc:directiveContent """# [DOMAIN_NAME] Tables
## Quick Reference — Business Context, Entity Clarification, Standard Filters
## Key Tables — Location, Description, Primary Key, Update Frequency, Partitioned By, Columns, Relationships, Nested Fields
## Key Metrics — Metric, Definition, Table, Formula, Notes
## Sample Queries — basic, intermediate, complex (CTE) patterns
## Common Gotchas — Wrong vs. Right patterns
## Related Dashboards — Dashboard, Link, Use For""" ;
    oc:hasRationale "This 7-section structure ensures comprehensive coverage of domain knowledge while remaining scannable" ;
    oc:templateVariables "DOMAIN_NAME",
        "GOTCHA_1",
        "METRIC_1",
        "TABLE_1_NAME" .

oc:kn_28398ebe a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing sample queries in domain files" ;
    oc:directiveContent "Real query examples are more valuable than abstract descriptions — show don't tell. Keep sample queries runnable using real table/column names." ;
    oc:hasRationale "Runnable queries let analysts copy-paste and verify immediately, reducing friction and errors" ;
    oc:severityLevel "MEDIUM" .

oc:kn_317d4d9f a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When documenting common pitfalls in domain files" ;
    oc:directiveContent "Document gotchas prominently — these save the most time. Include wrong vs. right patterns for each gotcha." ;
    oc:hasRationale "Gotchas capture tribal knowledge that prevents repeated mistakes and is otherwise hard to discover" ;
    oc:severityLevel "HIGH" .

oc:kn_374f3b47 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting tables with struct or nested columns" ;
    oc:directiveContent "Note nested/struct fields explicitly in table documentation. These trip people up the most in BigQuery and similar engines." ;
    oc:hasRationale "Nested fields require special syntax and are a common source of query failures for analysts unfamiliar with the schema" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d4ae46bf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating domain reference files" ;
    oc:directiveContent "Start with the most-queried tables — don't try to document everything. Include column-level detail only for important columns, skip obvious ones like created_at." ;
    oc:hasRationale "Prioritizing frequently-used tables maximizes the reference's utility while keeping it maintainable" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d79743a3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting entity clarification sections" ;
    oc:directiveContent "Always document ambiguous terms with their multiple meanings and corresponding tables before querying. Never assume which definition the user means." ;
    oc:hasRationale "Ambiguous domain terms (e.g., 'user', 'account', 'revenue') are the #1 source of incorrect query results" ;
    oc:severityLevel "HIGH" .

oc:kn_f43ea0fa a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a new domain reference file" ;
    oc:directiveContent "1. Identify the most-queried tables for the domain. 2. Document each table with location, keys, update frequency, critical columns, relationships, and nested fields. 3. Define key metrics with exact formulas and tables. 4. Write runnable sample queries covering basic, intermediate, and CTE patterns. 5. Document gotchas with wrong/right examples. 6. Link related dashboards." ;
    oc:stepOrder 1 .

