oc:skill_anthropics_knowledge_work_plugins_roadmap_update a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "roadmap-update" ;
    skos:broader "Product management workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/roadmap-update" ;
    oc:contentHash "ad43cf2cca8d442a0d900e703c843a87a13322cfc119089d6584f5f1ab328f24" ;
    oc:differentia "that updates, creates, or reprioritizes a product roadmap using structured frameworks for prioritization, dependency mapping, and capacity planning" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<update description>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Update, create, or reprioritize your product roadmap. Use when adding a new initiative and deciding what moves to make room, shifting priorities after new information comes in, moving timelines due to a dependency slip, or building a Now/Next/Later view from scratch." ;
    oc:hasName "roadmap-update" ;
    oc:hasRequirement oc:req_31eaa839,
        oc:req_61d063fa,
        oc:req_62275028 ;
    oc:impartsKnowledge oc:kn_006c3f81,
        oc:kn_13a1842c,
        oc:kn_1d552d1e,
        oc:kn_70f94554,
        oc:kn_8e1db1fe,
        oc:kn_d073a2a3,
        oc:kn_e35c9ce0,
        oc:kn_ee4d035c ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "apply prioritization frameworks to roadmap",
        "build Now/Next/Later roadmap view",
        "communicate roadmap changes",
        "create new roadmap",
        "reprioritize roadmap items",
        "shift roadmap timelines",
        "update product roadmap" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_006c3f81 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When allocating team capacity to roadmap items" ;
    oc:directiveContent "Maintain a healthy capacity allocation: 70% planned features, 20% technical health, 10% unplanned buffer. Adjust ratios based on team context." ;
    oc:hasRationale "Balanced allocation prevents tech debt accumulation and provides buffer for urgent issues, leading to sustainable delivery" .

oc:kn_13a1842c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating or updating any roadmap view" ;
    oc:directiveContent "A roadmap is a communication tool, not a project plan. Keep it at the right altitude — themes and outcomes, not tasks." ;
    oc:hasRationale "Overly granular roadmaps create false precision expectations and become maintenance burdens rather than strategic assets" ;
    oc:severityLevel "HIGH" .

oc:kn_1d552d1e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any roadmap workflow" ;
    oc:directiveContent "Before generating a roadmap update, confirm the operation type (add, update status, reprioritize, move timeline, or create new) and ensure current state data is available from a project tracker or user-provided input." ;
    oc:hasRationale "Misunderstanding the operation type or missing current state leads to irrelevant or incorrect roadmap outputs" ;
    oc:severityLevel "MEDIUM" .

oc:kn_70f94554 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When a user requests adding a new initiative to the roadmap" ;
    oc:directiveContent "When adding to the roadmap, always ask what comes off or moves. Roadmaps are zero-sum against capacity." ;
    oc:hasRationale "Adding without removing creates overcommitment, leading to missed deadlines and eroded stakeholder trust" ;
    oc:severityLevel "CRITICAL" .

oc:kn_8e1db1fe a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying and managing cross-team or technical dependencies" ;
    oc:directiveContent "Dependencies are the biggest risk to roadmaps. Surface them explicitly, assign owners, set 'need by' dates, and build buffer around them." ;
    oc:hasRationale "Unsurfaced dependencies are the primary cause of roadmap slippage and unexpected blockers" ;
    oc:severityLevel "HIGH" .

oc:kn_d073a2a3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reprioritizing roadmap items" ;
    oc:directiveContent "Do not change the roadmap for every piece of new information. Have a threshold for change and batch updates at natural cadences unless something is truly urgent." ;
    oc:hasRationale "Frequent unbatched changes cause roadmap whiplash, signaling unclear strategy rather than responsiveness" ;
    oc:severityLevel "HIGH" .

oc:kn_e35c9ce0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When estimating capacity and allocating roadmap items" ;
    oc:directiveContent "Do not solve capacity problems by pretending people can do more — solve by cutting scope. Engineers typically spend 60-70% of time on planned feature work." ;
    oc:hasRationale "Overestimating effective capacity is the most common cause of roadmap failure; honest scoping prevents overcommitment" ;
    oc:severityLevel "HIGH" .

oc:kn_ee4d035c a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When roadmap items are reprioritized, timelines shift, or items are cut" ;
    oc:directiveContent "When communicating roadmap changes: acknowledge the change, explain the reason, show the tradeoff, show the new plan, and acknowledge impact on affected stakeholders." ;
    oc:hasRationale "Transparent, structured communication preserves stakeholder trust and prevents misalignment after changes" ;
    oc:severityLevel "MEDIUM" .

oc:req_31eaa839 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Roadmap frameworks (Now/Next/Later, Quarterly Themes, OKR-Aligned, Timeline/Gantt)" .

oc:req_61d063fa a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "project tracker (optional)" .

oc:req_62275028 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Prioritization frameworks (RICE, MoSCoW, ICE, Value vs Effort)" .

