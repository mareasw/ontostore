oc:kn_13a1842c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any roadmap output" ;
    oc:directiveContent "A roadmap is a communication tool, not a project plan. Keep it at the right altitude — themes and outcomes, not tasks." ;
    oc:hasRationale "Roadmaps that descend into task-level detail lose their strategic value and create false precision expectations" ;
    oc:severityLevel "HIGH" .

oc:kn_44a3577c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user requests adding a new item to the roadmap" ;
    oc:directiveContent "When adding to the roadmap, always ask what comes off or moves. Roadmaps are zero-sum against capacity." ;
    oc:hasRationale "Adding without removing leads to overcommitment and missed expectations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4b730521 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to update the roadmap in response to new information" ;
    oc:directiveContent "Distinguish between roadmap change (strategic reprioritization) and scope adjustment (normal execution refinement). Batch updates at natural cadences unless truly urgent." ;
    oc:hasRationale "Prevents roadmap whiplash that signals unclear strategy and erodes stakeholder confidence" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6d1b2387 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """## Status Overview
{X} items in progress, {Y} completed, {Z} at risk

## Roadmap Items
| Name | Status | Target | Owner | Dependencies |
|------|--------|--------|-------|-------------|
| {item} | Done/On Track/At Risk/Blocked/Not Started | {timeframe} | {owner} | {deps} |

## Risks and Dependencies
- {blocked_or_at_risk_items}
- {cross_team_deps}
- {hard_deadline_items}

## Changes This Update
- Items added/removed/reprioritized
- Timeline shifts
- Status changes""" ;
    oc:templateVariables "X",
        "Y",
        "Z",
        "blocked_or_at_risk_items",
        "cross_team_deps",
        "deps",
        "hard_deadline_items",
        "item",
        "owner",
        "timeframe" .

oc:kn_7286e66e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When roadmap commitments exceed available team capacity" ;
    oc:directiveContent "Do not solve capacity problems by pretending people can do more — solve by cutting scope. Do not change the roadmap for every piece of new information." ;
    oc:hasRationale "Optimism bias and reactive reprioritization erode stakeholder trust and team morale" ;
    oc:severityLevel "HIGH" .

oc:kn_8663fca9 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When estimating team capacity for roadmap planning" ;
    oc:directiveContent "Use the 70/20/10 capacity allocation: 70% planned features, 20% technical health, 10% unplanned buffer. Adjust ratios based on product maturity and context." ;
    oc:hasRationale "This allocation balances strategic progress with system health and responsiveness to urgent needs" .

oc:kn_8e1db1fe a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying or managing cross-team or technical dependencies" ;
    oc:directiveContent "Dependencies are the biggest risk to roadmaps. Surface them explicitly, assign owners, set 'need by' dates, and build buffer around them." ;
    oc:hasRationale "Unmanaged dependencies are the most common cause of roadmap slips and blocked items" ;
    oc:severityLevel "HIGH" .

oc:kn_d7918719 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying quantitative prioritization frameworks" ;
    oc:codeLanguage "formula" ;
    oc:directiveContent """RICE = (Reach × Impact × Confidence) / Effort
ICE = Impact × Confidence × Ease""" .

oc:kn_e6d01f59 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every roadmap update invocation" ;
    oc:directiveContent "1. Understand current state (pull from tracker or ask user) → 2. Determine operation (add/update status/reprioritize/move timeline/create new) → 3. Generate roadmap summary (status overview, items, risks, changes) → 4. Follow up (format for audience, draft comms, update tracker)" ;
    oc:stepOrder 1 .

oc:kn_efcb93d5 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When generating roadmap change communications" ;
    oc:directiveContent "To communicate roadmap changes: 1. Acknowledge the change directly → 2. Explain the reason (new information) → 3. Show the tradeoff (what was deprioritized) → 4. Show the new plan → 5. Acknowledge impact on affected stakeholders" ;
    oc:stepOrder 2 .

_:ref_173d11f171b67dc0 a oc:WorkflowStep ;
    dcterms:description "**Acknowledge the change**: Be direct about what is changing and why" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_69a35db2abb2ea63 a oc:WorkflowStep ;
    dcterms:description "**Acknowledge impact**: Who is affected and how? Stakeholders who were expecting deprioritized items need to hear it directly." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_8d81bfad7c65a6c0 a oc:WorkflowStep ;
    dcterms:description "**Show the tradeoff**: What was deprioritized to make room? Or what is slipping?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_aab6aeb9f99bc8ef a oc:WorkflowStep ;
    dcterms:description "**Show the new plan**: Updated roadmap with the changes reflected" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_e671458648789db4 a oc:WorkflowStep ;
    dcterms:description "**Explain the reason**: What new information drove this decision?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_368b07ef17d84c4d a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_173d11f171b67dc0,
        _:ref_69a35db2abb2ea63,
        _:ref_8d81bfad7c65a6c0,
        _:ref_aab6aeb9f99bc8ef,
        _:ref_e671458648789db4 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_485232a2d9892dd7 a oc:WorkflowStep ;
    dcterms:description "Generate roadmap summary with status overview, item details, risks/dependencies, and change log" ;
    oc:stepDependsOn _:ref_d83b515c42a16560 ;
    oc:stepId "generate-summary" .

_:ref_4a5a4e8b1625266c a oc:WorkflowStep ;
    dcterms:description "Understand current roadmap state — pull items from connected project tracker or ask user to provide current roadmap" ;
    oc:expectedOutcome "Current roadmap items with statuses, assignees, dates, and risk items identified" ;
    oc:stepId "understand-state" .

_:ref_6eee335901abd438 a oc:WorkflowStep ;
    dcterms:description "Determine what operation the user wants: add item, update status, reprioritize, move timeline, or create new roadmap" ;
    oc:expectedOutcome "Clear understanding of the update type and required inputs for it" ;
    oc:stepDependsOn _:ref_4a5a4e8b1625266c ;
    oc:stepId "determine-operation" .

_:ref_d83b515c42a16560 a oc:WorkflowStep ;
    dcterms:description "Apply appropriate prioritization framework (RICE, MoSCoW, ICE, value-vs-effort) and roadmap format (Now/Next/Later, quarterly themes, OKR-aligned, timeline)" ;
    oc:expectedOutcome "Prioritized items positioned within the chosen roadmap framework" ;
    oc:stepDependsOn _:ref_6eee335901abd438 ;
    oc:stepId "apply-framework" .

