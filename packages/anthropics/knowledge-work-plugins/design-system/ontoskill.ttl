@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_design_system a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "design-system" ;
    skos:broader "Design system management workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/design-system" ;
    oc:contentHash "619b26e6bc25759db3b783c6cafb5646fb242286acfb23e196d57eb41f169dd6" ;
    oc:differentia "provides three operational modes — audit, document, and extend — for analyzing consistency, documenting component specifications, and designing new patterns within an existing UI design system" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "[audit | document | extend] <component or system>" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Audit, document, or extend your design system. Use when checking for naming inconsistencies or hardcoded values across components, writing documentation for a component's variants, states, and accessibility notes, or designing a new pattern that fits the existing system." ;
    oc:hasName "design-system" ;
    oc:impartsKnowledge oc:kn_00b10982,
        oc:kn_41e06c7c,
        oc:kn_67c4a935,
        oc:kn_782b2b92,
        oc:kn_9b6c9a8c,
        oc:kn_b71fc0b2 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "audit design system for naming inconsistencies and hardcoded values",
        "design a new component or pattern that fits the existing system",
        "document a component's variants, states, and accessibility notes",
        "generate component documentation with props, states, and accessibility details",
        "review design token coverage across a component library" ;
    oc:yieldsState oc:DocumentCreated,
        oc:SystemAudited .

oc:kn_00b10982 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When auditing token coverage or building new components" ;
    oc:directiveContent "Never hardcode design token values (colors, spacing, typography) directly in components; always reference defined tokens." ;
    oc:hasRationale "Hardcoded values bypass the system's abstraction layer, making global updates impossible and creating visual inconsistencies" ;
    oc:severityLevel "CRITICAL" .

oc:kn_41e06c7c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extending the design system with new components or documenting existing ones" ;
    oc:directiveContent "Every new component must include ARIA role, keyboard interaction behavior, and screen reader announcement specifications." ;
    oc:hasRationale "Accessibility is not optional — components without keyboard and screen reader support exclude users and create legal/compliance risk" ;
    oc:severityLevel "CRITICAL" .

oc:kn_67c4a935 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning any design system engagement" ;
    oc:directiveContent "Start with an audit before documenting or extending — know the current state of the system before deciding where to invest effort." ;
    oc:hasRationale "Auditing reveals the true scope of inconsistencies and gaps, preventing wasted effort on well-covered areas" ;
    oc:severityLevel "MEDIUM" .

oc:kn_782b2b92 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing new components via the extend mode" ;
    oc:directiveContent "Document components as you build them rather than retroactively — it's easier to capture variants, states, and behavior while the design is fresh." ;
    oc:hasRationale "Retroactive documentation loses design intent and edge-case decisions that were made during creation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9b6c9a8c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning documentation efforts" ;
    oc:directiveContent "Prioritize coverage over perfection — 80% of components documented beats 100% of 10 components." ;
    oc:hasRationale "Broad documentation coverage provides more value to more teams than deep documentation of a few components" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b71fc0b2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When auditing or extending any design system" ;
    oc:directiveContent "Prioritize consistency over creativity — the design system exists so teams don't reinvent the wheel with ad-hoc styles." ;
    oc:hasRationale "Consistency is the primary value proposition of a design system; deviations undermine the shared visual language" ;
    oc:severityLevel "HIGH" .

