oc:skill_knowledge_work_plugins_vendor_check a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "vendor-check" ;
    skos:broader "Cross-system agreement status checker" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/vendor-check" ;
    oc:contentHash "1efe8d63f56a8d46f37c11794316e2982962b40c0fa9eaefe930a9e1fe060e45" ;
    oc:differentia "Searches CLM, CRM, email, documents, and chat systems for vendor agreements, compiles status with gap analysis and upcoming deadline alerts" ;
    oc:handlesFailure oc:AmbiguousVendorName,
        oc:NoAgreementsFound,
        oc:SourceUnavailable ;
    oc:hasArgumentHint "[vendor name]" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Check the status of existing agreements with a vendor across all connected systems — CLM, CRM, email, and document storage — with gap analysis and upcoming deadlines. Use when onboarding or renewing a vendor, when you need a consolidated view of what's signed and what's missing (MSA, DPA, SOW), or when checking for approaching expirations and surviving obligations." ;
    oc:hasName "vendor-check" ;
    oc:hasRequirement oc:req_2db4e91a,
        oc:req_8d57911b,
        oc:req_bc9476f1,
        oc:req_d6873c35,
        oc:req_e3d28fe8 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: vendor-check
description: Check the status of existing agreements with a vendor across all connected systems — CLM, CRM, email, and document storage — with gap analysis and upcoming deadlines. Use when onboarding or renewing a vendor, when you need a consolidated view of what's signed and what's missing (MSA, DPA, SOW), or when checking for approaching expirations and surviving obligations.
argument-hint: "[vendor name]"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Check the status of existing agreements with a vendor across all connected systems. Provides a consolidated view of the legal relationship." ],
                [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**Important**: This command assists with legal workflows but does not provide legal advice. Agreement status reports should be verified against original documents by qualified legal professionals." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
