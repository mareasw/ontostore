    oc:resolvesIntent "audit vendor legal coverage",
        "check vendor agreement status",
        "consolidate vendor agreement information across systems",
        "find missing vendor agreements",
        "track vendor contract expirations" ;
    oc:yieldsState oc:GapsIdentified,
        oc:VendorAgreementsReported .

oc:kn_2ceff250 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When compiling agreement status and generating upcoming actions" ;
    oc:directiveContent "Flag agreements approaching expiration within 90 days prominently. Flag expired agreements that may have surviving obligations (confidentiality, indemnification)." ;
    oc:hasRationale "Missing renewal deadlines can cause lapses in coverage; surviving obligations can create ongoing liability even after expiration" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ce72e0e3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating the final consolidated report" ;
    oc:directiveContent "Always clearly state which sources were checked and which were not, so the user knows the completeness of the report." ;
    oc:hasRationale "Incomplete source coverage means the report may be missing agreements; transparency about source gaps lets the user judge reliability" ;
    oc:severityLevel "HIGH" .

oc:kn_d38c4d1f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing Step 2: Search Connected Systems" ;
    oc:directiveContent "Search connected systems in priority order: CLM first, then CRM, then Email, then Documents, then Chat. Each source may be unavailable if not connected via MCP." ;
    oc:hasRationale "CLM is the primary source of truth for executed agreements; CRM adds relationship context; email/chat provide supplementary context about negotiations" .

oc:kn_d7ea3297 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when presenting any vendor agreement status report" ;
    oc:directiveContent "This skill assists with legal workflows but does not provide legal advice. Agreement status reports must be verified against original documents by qualified legal professionals." ;
    oc:hasRationale "Agent-generated reports may miss nuances in contract language; only qualified legal professionals can confirm binding obligations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ea9408e1 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When search returns empty results across all systems" ;
    oc:directiveContent "If no agreements are found in any connected system, report clearly and ask the user if they have agreements stored elsewhere. For vendor groups with subsidiaries, ask whether to check a specific entity or the entire group." ;
    oc:hasRationale "Empty results may indicate the agreements exist but are stored in unconnected systems rather than that no agreements exist" ;
    oc:severityLevel "HIGH" .

oc:req_2db4e91a a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "Chat system (optional, via MCP)" .

oc:req_8d57911b a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "CRM system (optional, via MCP)" .

oc:req_bc9476f1 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "Document storage system (optional, via MCP)" .

oc:req_d6873c35 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "CLM system (optional, via MCP)" .

oc:req_e3d28fe8 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "Email system (optional, via MCP)" .

_:ref_1284d7e64d73c5be a oc:WorkflowStep ;
    dcterms:description "Accept vendor name and handle variations (legal name vs trade name, abbreviations, parent/subsidiary). Clarify ambiguity with user." ;
    oc:expectedOutcome "Vendor identity confirmed with full legal name" ;
    oc:stepId "identify-vendor" .

_:ref_3dbe9ddd4545fee6 a oc:WorkflowStep ;
    dcterms:description "For each agreement found, compile type, status, dates, auto-renewal terms, key terms, and amendments" ;
    oc:expectedOutcome "Structured agreement status entries for each found document" ;
    oc:stepDependsOn _:ref_82b381aad76955cb ;
    oc:stepId "compile-status" .

_:ref_82b381aad76955cb a oc:WorkflowStep ;
    dcterms:description "Search CLM, CRM, Email, Documents, and Chat systems in priority order for all agreements and mentions of the vendor" ;
    oc:expectedOutcome "Raw results from all connected systems collected" ;
    oc:stepDependsOn _:ref_1284d7e64d73c5be ;
    oc:stepId "search-systems" .

_:ref_884ebc114337530e a oc:WorkflowStep ;
    dcterms:description "Identify which agreement types exist (NDA, MSA, DPA, SOW, SLA, Insurance) and flag missing ones based on relationship type" ;
    oc:expectedOutcome "Gap analysis showing CHECK/MISSING for each agreement category" ;
    oc:stepDependsOn _:ref_3dbe9ddd4545fee6 ;
    oc:stepId "gap-analysis" .

_:ref_96285d116b73a8c9 a oc:WorkflowStep ;
    dcterms:description "Output consolidated report with relationship overview, agreement summary, gap analysis, upcoming actions, and notes" ;
    oc:expectedOutcome "Complete vendor agreement status report delivered to user" ;
    oc:stepDependsOn _:ref_884ebc114337530e ;
    oc:stepId "generate-report" .

