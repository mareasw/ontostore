@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_vendor_check a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "vendor-check" ;
    skos:broader "Vendor agreement status checker" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/vendor-check" ;
    oc:contentHash "1efe8d63f56a8d46f37c11794316e2982962b40c0fa9eaefe930a9e1fe060e45" ;
    oc:differentia "Searches across connected systems (CLM, CRM, email, document storage, chat) to compile a consolidated view of agreements, perform gap analysis, and flag upcoming deadlines" ;
    oc:handlesFailure oc:NoAgreementsFound,
        oc:SourceUnavailable,
        oc:VendorNotFound ;
    oc:hasAllowedTool "Read",
        "Search",
        "WebSearch" ;
    oc:hasArgumentHint "[vendor name]" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Check the status of existing agreements with a vendor across all connected systems — CLM, CRM, email, and document storage — with gap analysis and upcoming deadlines. Use when onboarding or renewing a vendor, when you need a consolidated view of what's signed and what's missing (MSA, DPA, SOW), or when checking for approaching expirations and surviving obligations." ;
    oc:hasName "vendor-check" ;
    oc:impartsKnowledge oc:kn_09522dff,
        oc:kn_12a82bf3,
        oc:kn_39662973,
        oc:kn_7c6197ab,
        oc:kn_92d36e34,
        oc:kn_acc97c4c,
        oc:kn_fb455f28 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "check vendor agreement expiration dates",
        "check vendor agreement status",
        "consolidate vendor legal relationship view",
        "find existing contracts with a vendor",
        "identify missing agreements with a vendor",
        "perform vendor agreement gap analysis" ;
    oc:yieldsState oc:GapAnalysisComplete,
        oc:VendorAgreementsCompiled .

oc:kn_09522dff a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When identifying the vendor in Step 1" ;
    oc:directiveContent "Handle vendor name variations including full legal name vs. trade name, abbreviations, and parent/subsidiary relationships. Ask the user to clarify ambiguous names." ;
    oc:hasRationale "Vendor names can appear differently across systems; failing to account for variations leads to incomplete search results." ;
    oc:severityLevel "MEDIUM" .

oc:kn_12a82bf3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the consolidated vendor report" ;
    oc:directiveContent "Always clearly state which sources were checked and which were not, so the user knows the completeness of the report." ;
    oc:hasRationale "Users must understand the coverage and limitations of the search to make informed decisions about whether manual follow-up is needed." ;
    oc:severityLevel "HIGH" .

oc:kn_39662973 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting any agreement analysis or gap findings" ;
    oc:directiveContent "Do not provide legal advice. Agreement status reports should be verified against original documents by qualified legal professionals." ;
    oc:hasRationale "AI-generated summaries may miss nuances in contract language; only qualified legal professionals can provide authoritative interpretations." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7c6197ab a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing the gap analysis in Step 4" ;
    oc:directiveContent "Contextualize gap analysis based on relationship type — e.g., flag a missing DPA when the vendor handles personal data." ;
    oc:hasRationale "Generic gap checks miss relationship-specific requirements; contextual flags ensure the analysis is actionable and relevant." ;
    oc:severityLevel "MEDIUM" .

oc:kn_92d36e34 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a required source system is unavailable" ;
    oc:directiveContent "If key systems (CLM, CRM, email, documents) are not connected via MCP, note the gap in the report and suggest manual alternatives." ;
    oc:hasRationale "Incomplete data from missing sources does not mean no agreements exist; users must be directed to check manually." ;
    oc:severityLevel "MEDIUM" .

oc:kn_acc97c4c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When compiling agreement status and generating the report" ;
    oc:directiveContent "Flag agreements approaching expiration within 90 days prominently in the report." ;
    oc:hasRationale "Early visibility into upcoming expirations allows proactive renewal negotiation and avoids lapses in coverage." ;
    oc:severityLevel "HIGH" .

oc:kn_fb455f28 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reporting expired agreements" ;
    oc:directiveContent "Flag agreements that are expired but may still have surviving obligations such as confidentiality or indemnification provisions." ;
    oc:hasRationale "Expired contracts often carry surviving clauses that remain legally binding; overlooking these creates compliance risk." ;
    oc:severityLevel "HIGH" .

