_:ref_4f29aad19ccfb997 a oc:WorkflowStep ;
    dcterms:description "**People:**" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "Create/update memory/people/{name}.md" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 3 ;
                    oc:itemText "**Capture nicknames** - critical for decoding" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "Add to CLAUDE.md Key People if important" ] ] ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

