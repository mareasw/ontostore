    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "decode workplace shorthand and acronyms",
        "look up internal language and codenames",
        "manage organizational memory and context",
        "remember people, projects, and terms" ;
    oc:yieldsState oc:ContextDecoded,
        oc:MemoryInitialized .

oc:kn_2fdfc7ab a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When user asks 'who is X' or 'what does X mean'" ;
    oc:directiveContent "1. Check CLAUDE.md first. 2. Check memory/ for full detail. 3. If not found, ask user and learn." ;
    oc:stepOrder 3 .

oc:kn_3f77e2ca a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting CLAUDE.md or glossary.md entries" ;
    oc:directiveContent "Use markdown tables with columns like | Who | Role |, | Term | Meaning |, | Codename | Project | for compact, scannable storage." ;
    oc:hasRationale "Tables provide structured, predictable lookup format that the agent can parse quickly." .

oc:kn_48a38c81 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When maintaining and refreshing memory over time" ;
    oc:directiveContent "Promote frequently-used terms and people to CLAUDE.md; demote stale or rarely-used entries to memory/ only." ;
    oc:hasRationale "Keeps the hot cache fresh and relevant while preserving all knowledge in deep storage for when it's needed again." .

oc:kn_5dac4b5d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding new people, projects, or terms to memory" ;
    oc:directiveContent "Always capture nicknames, alternate names, and codenames alongside canonical names. These are the primary lookup keys users actually say." ;
    oc:hasRationale "Users rarely say full canonical names. The entire value of the system depends on mapping informal references to their formal identities." .

oc:kn_7dabf44a a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When user says 'remember this' or 'X means Y'" ;
    oc:directiveContent "1. Add glossary items to memory/glossary.md (promote to CLAUDE.md if frequent). 2. Add people to memory/people/{name}.md + CLAUDE.md if top contact. 3. Add projects to memory/projects/{name}.md + CLAUDE.md if active. 4. Add preferences to CLAUDE.md." ;
    oc:stepOrder 2 .

oc:kn_8144908b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing any user request that contains shorthand or internal language" ;
    oc:directiveContent "Never skip the decoding step before acting on a request. Always resolve nicknames, acronyms, and codenames to their full meaning first." ;
    oc:hasRationale "Acting on unresolved shorthand leads to mistakes — emailing the wrong person, referencing the wrong project, or misunderstanding intent." ;
    oc:severityLevel "CRITICAL" .

oc:kn_995b7aff a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When formatting CLAUDE.md working memory" ;
    oc:directiveContent """## Me
[Name], [Role] on [Team]
## People
| Who | Role |
## Terms
| Term | Meaning |
## Projects
| Name | What |
## Preferences
- [preference items]""" ;
    oc:templateVariables "Meaning",
        "Name",
        "Preferences",
        "Project",
        "Role",
        "Team",
        "Term",
        "What",
        "Who" .

oc:kn_af25a488 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Whenever decoding shorthand, acronyms, or nicknames from user input" ;
    oc:directiveContent "Use tiered lookup: (1) CLAUDE.md hot cache first, (2) memory/glossary.md for full glossary, (3) memory/people/ and memory/projects/ for rich detail, (4) ask user if still unknown." ;
    oc:hasRationale "This progressive disclosure approach covers 90% of daily needs from the hot cache while supporting unlimited scale in the deep memory layer." .

oc:kn_db062cf1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or updating CLAUDE.md working memory" ;
    oc:directiveContent "Keep CLAUDE.md under ~100 lines (the 'hot 30' rule). Only top ~30 people, ~30 terms, and active projects go in the hot cache." ;
    oc:hasRationale "A lean hot cache ensures fast lookup and stays relevant to daily work. Overloading it defeats the tiered architecture." ;
    oc:severityLevel "HIGH" .

oc:kn_f30b399a a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When processing any user request" ;
    oc:directiveContent "1. Decode shorthand via tiered lookup (CLAUDE.md → glossary.md → memory/ → ask user). 2. Act with full context. 3. Learn unknown terms by asking user and persisting to memory." ;
    oc:stepOrder 1 .

_:ref_0f96d88a5e3a85ab a oc:WorkflowStep ;
    dcterms:description "Check memory/ for full detail" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_136e819c5dccf2bd a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
    oc:itemText "Create/update memory/projects/{name}.md" .

