@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_memory_management a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "memory-management" ;
    skos:broader "knowledge management system" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/memory-management" ;
    oc:contentHash "1c04a313d9ae9d1f52ba7d80b383deaea4db31cab2ccec109ed9b653a5f2dba6" ;
    oc:dependsOnSkill oc:skill_start ;
    oc:differentia "implements a two-tier memory architecture with a hot cache (CLAUDE.md) for frequently accessed workplace shorthand and a deep memory directory (memory/) for comprehensive glossary, people profiles, project details, and company context, enabling shorthand decoding through tiered lookup" ;
    oc:handlesFailure oc:FileNotFound,
        oc:PermissionDenied ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Two-tier memory system that makes Claude a true workplace collaborator. Decodes shorthand, acronyms, nicknames, and internal language so Claude understands requests like a colleague would. CLAUDE.md for working memory, memory/ directory for the full knowledge base." ;
    oc:hasName "memory-management" ;
    oc:impartsKnowledge oc:kn_5d1e521d,
        oc:kn_607eed33,
        oc:kn_98c20947,
        oc:kn_e99d7b5a,
        oc:kn_faffbe66 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:DirectoryWritable,
        oc:EnvironmentReady ;
    oc:resolvesIntent "add new memories for people, terms, projects, and preferences",
        "decode workplace shorthand and acronyms into full context",
        "manage a two-tier memory system for people, projects, and terms",
        "promote frequently used items to hot cache and demote stale items",
        "remember and recall people, projects, and internal terminology" ;
    oc:yieldsState oc:MemoryInitialized .

oc:kn_5d1e521d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When managing memory entries over time" ;
    oc:directiveContent "Promote frequently used terms and people to CLAUDE.md and demote stale or rarely-used entries to memory/ only to keep the hot cache fresh." ;
    oc:hasRationale "Active promotion/demotion keeps the hot cache relevant and prevents staleness without losing information." ;
    oc:severityLevel "MEDIUM" .

oc:kn_607eed33 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When formatting memory files" ;
    oc:directiveContent "Use markdown tables for compactness in both CLAUDE.md and glossary.md. Use lowercase hyphenated filenames for people and project files (e.g., todd-martinez.md)." ;
    oc:hasRationale "Consistent formatting ensures reliable parsing and scanning across both memory tiers." ;
    oc:severityLevel "MEDIUM" .

oc:kn_98c20947 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When decoding any user request containing shorthand, nicknames, or ambiguous terms" ;
    oc:directiveContent "Always perform tiered lookup: check CLAUDE.md first, then memory/glossary.md, then memory/people/ and memory/projects/ for detail, and finally ask the user if still unresolved." ;
    oc:hasRationale "Tiered lookup balances speed (hot cache) against completeness (deep memory) while gracefully handling unknowns." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e99d7b5a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding new people or projects to memory" ;
    oc:directiveContent "Always capture nicknames, alternate names, and codenames for people and projects — these are the primary lookup keys users will employ." ;
    oc:hasRationale "Users naturally use informal names and shorthand; without capturing all variants, decoding will fail." ;
    oc:severityLevel "HIGH" .

oc:kn_faffbe66 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or updating CLAUDE.md working memory" ;
    oc:directiveContent "Keep CLAUDE.md under ~100 lines (~30 people, ~30 terms, active projects only) to maintain it as an effective hot cache that covers 90% of daily decoding needs." ;
    oc:hasRationale "A lean hot cache ensures fast lookup and prevents information overload; the deep memory directory handles unlimited scale." ;
    oc:severityLevel "HIGH" .

