@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_tech_debt a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "tech-debt" ;
    skos:broader "assessment framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/tech-debt" ;
    oc:contentHash "722fffbbb199ebd6d7c1db2d9d91285acb21fee91c2e88cab47b7f93c8a39aee" ;
    oc:differentia "that identifies, categorizes, and prioritizes technical debt items using a quantitative scoring model and phased remediation planning" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "codebase or project path to audit" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Identify, categorize, and prioritize technical debt. Trigger with \"tech debt\", \"technical debt audit\", \"what should we refactor\", \"code health\", or when the user asks about code quality, refactoring priorities, or maintenance backlog." ;
    oc:hasName "tech-debt" ;
    oc:impartsKnowledge oc:kn_48af6cb1,
        oc:kn_56a7cced,
        oc:kn_987dbc8a,
        oc:kn_bcc432c1,
        oc:kn_fd2cdc15 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady,
        oc:FileExists ;
    oc:resolvesIntent "audit code health",
        "categorize maintenance backlog",
        "create technical debt remediation plan",
        "identify technical debt",
        "prioritize refactoring work" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_48af6cb1 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When categorizing and scoring dependency-related debt" ;
    oc:directiveContent "Dependency debt (outdated libraries, unmaintained dependencies) carries security vulnerability risk and should be flagged prominently in any tech debt audit." ;
    oc:hasRationale "Unmaintained dependencies are a primary attack vector and can introduce critical security vulnerabilities into the codebase" ;
    oc:severityLevel "CRITICAL" .

oc:kn_56a7cced a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When prioritizing technical debt items" ;
    oc:directiveContent "Score each tech debt item using the formula: Priority = (Impact + Risk) × (6 - Effort), where Impact and Risk are 1-5 and Effort is inverted so lower effort yields higher priority." ;
    oc:hasRationale "Provides a quantitative, consistent way to rank debt items by balancing business urgency against implementation cost" ;
    oc:severityLevel "HIGH" .

oc:kn_987dbc8a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting individual tech debt items in the output" ;
    oc:directiveContent "Each debt item must include estimated effort, a business justification, and a priority score to be actionable." ;
    oc:hasRationale "Without business justification and effort estimates, debt items cannot be meaningfully prioritized or communicated to stakeholders" ;
    oc:severityLevel "MEDIUM" .

oc:kn_bcc432c1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying and cataloging technical debt" ;
    oc:directiveContent "Classify technical debt into six categories: code debt, architecture debt, test debt, dependency debt, documentation debt, and infrastructure debt to ensure comprehensive coverage." ;
    oc:hasRationale "Categorization ensures no class of debt is overlooked and enables targeted remediation strategies per domain" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fd2cdc15 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When delivering tech debt audit results" ;
    oc:directiveContent "Always produce a phased remediation plan that can be executed alongside feature work rather than requiring dedicated debt-sprint time." ;
    oc:hasRationale "Phased plans integrated into regular work are more likely to get stakeholder buy-in and actually get executed" ;
    oc:severityLevel "HIGH" .

