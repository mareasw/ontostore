@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_knowledge_work_plugins_tech_debt a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "tech-debt" ;
    skos:broader "Analysis framework" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/tech-debt" ;
    oc:contentHash "722fffbbb199ebd6d7c1db2d9d91285acb21fee91c2e88cab47b7f93c8a39aee" ;
    oc:differentia "that systematically identifies, categorizes, and prioritizes technical debt using a scored prioritization model across six debt categories" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Identify, categorize, and prioritize technical debt. Trigger with \"tech debt\", \"technical debt audit\", \"what should we refactor\", \"code health\", or when the user asks about code quality, refactoring priorities, or maintenance backlog." ;
    oc:hasName "tech-debt" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: tech-debt
description: Identify, categorize, and prioritize technical debt. Trigger with "tech debt", "technical debt audit", "what should we refactor", "code health", or when the user asks about code quality, refactoring priorities, or maintenance backlog.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Systematically identify, categorize, and prioritize technical debt." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Produce a prioritized list with estimated effort, business justification for each item, and a phased remediation plan that can be done alongside feature work." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 6 ;
                            oc:tableCaption "## Categories" ;
                            oc:tableMarkdown """| Type | Examples | Risk |
|------|----------|------|
| **Code debt** | Duplicated logic, poor abstractions, magic numbers | Bugs, slow development |
| **Architecture debt** | Monolith that should be split, wrong data store | Scaling limits |
| **Test debt** | Low coverage, flaky tests, missing integration tests | Regressions ship |
| **Dependency debt** | Outdated libraries, unmaintained dependencies | Security vulns |
| **Documentation debt** | Missing runbooks, outdated READMEs, tribal knowledge | Onboarding pain |
| **Infrastructure debt** | Manual deploys, no monitoring, no IaC | Incidents, slow recovery |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Categories" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Priority = (Impact + Risk) x (6 - Effort)" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Score each item on:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Effort**: How hard is the fix? (1-5, inverted — lower effort = higher priority)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Impact**: How much does it slow the team down? (1-5)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Risk**: What happens if we don't fix it? (1-5)" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Prioritization Framework" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Tech Debt Management" ] ;
    oc:impartsKnowledge oc:kn_43f07d1c,
        oc:kn_89662115,
        oc:kn_ab29981d,
        oc:kn_bb76abbc,
        oc:kn_c6921053 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "audit technical debt",
        "categorize code quality issues",
        "identify technical debt",
        "plan remediation alongside feature work",
        "prioritize refactoring work" .

oc:kn_43f07d1c a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When creating the remediation plan output" ;
    oc:directiveContent "Produce a phased remediation plan that can be executed alongside feature work rather than requiring dedicated debt-only sprints." ;
    oc:hasRationale "Stopping feature development to address debt is rarely politically feasible; interleaving remediation maximizes adoption" .

oc:kn_89662115 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When producing the final output" ;
    oc:directiveContent "Every prioritized debt item must include estimated effort and business justification alongside its priority score." ;
    oc:hasRationale "Business justification is essential for securing stakeholder buy-in and budget allocation for debt remediation" .

oc:kn_ab29981d a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When categorizing items into the Dependency debt category" ;
    oc:directiveContent "Dependency debt (outdated libraries, unmaintained dependencies) directly maps to security vulnerability risk and should be flagged accordingly." ;
    oc:hasRationale "Security vulns from outdated dependencies can have immediate production impact and may require escalation beyond normal prioritization" ;
    oc:severityLevel "HIGH" .

oc:kn_bb76abbc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying and cataloging technical debt items" ;
    oc:directiveContent "Classify all technical debt into exactly six categories: Code, Architecture, Test, Dependency, Documentation, and Infrastructure debt." ;
    oc:hasRationale "Consistent categorization enables pattern detection across debt types and prevents blind spots in audits" .

oc:kn_c6921053 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When prioritizing technical debt items" ;
    oc:directiveContent "Each debt item must be scored on three dimensions: Impact (1-5), Risk (1-5), and Effort (1-5, inverted). Priority = (Impact + Risk) × (6 - Effort)." ;
    oc:hasRationale "A quantitative formula ensures objective comparison and prevents gut-feeling prioritization that overlooks high-risk low-effort fixes" ;
    oc:severityLevel "HIGH" .

