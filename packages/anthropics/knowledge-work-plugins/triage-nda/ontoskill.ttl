                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 10 ;
                                                    oc:itemText "Definition of confidential information is reasonably scoped" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "No residuals clause, or residuals clause is narrowly scoped" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
