                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 8 ;
                                                    oc:itemText "Permitted disclosures include employees, contractors, and advisors" ] ] ;
                                    oc:sectionLevel 4 ;
