oc:kn_039e9057 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When triaging any NDA" ;
    oc:directiveContent "1. Accept the NDA (file upload, URL, or pasted text) → 2. Load NDA playbook from local settings or apply market-standard defaults → 3. Screen against 10 criteria (structure, definition scope, obligations, carveouts, permitted disclosures, term, return/destruction, remedies, problematic provisions, governing law) → 4. Classify as GREEN/YELLOW/RED → 5. Generate structured triage report → 6. Provide routing suggestion" ;
    oc:stepOrder 1 .

oc:kn_171e5282 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating the triage report in Step 5" ;
    oc:directiveContent """## NDA Triage Report
**Classification**: [GREEN / YELLOW / RED]
**Parties**: [party names]
**Type**: [Mutual / Unilateral]
**Term**: [duration]
**Governing Law**: [jurisdiction]
**Review Basis**: [Playbook / Default Standards]

## Screening Results
| Criterion | Status | Notes |

## Issues Found
### [Issue -- YELLOW/RED]
**What** | **Risk** | **Suggested Fix**

## Recommendation
## Next Steps""" ;
    oc:templateVariables "Classification",
        "Criterion",
        "Governing Law",
        "Issue",
        "Next Steps",
        "Notes",
        "Parties",
        "Recommendation",
        "Review Basis",
        "Risk",
        "Status",
        "Suggested Fix",
        "Term",
        "Type" .

oc:kn_2347a416 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning classification in Step 4" ;
    oc:directiveContent "Classify as GREEN only when ALL criteria pass. Classify as YELLOW when one or more issues are present but not fundamentally problematic. Classify as RED when any critical issue is present (missing carveouts, non-solicits, non-competes, IP grants, perpetual terms without justification)." ;
    oc:hasRationale "A conservative default-upgrade approach prevents risky NDAs from being auto-approved" .

oc:kn_2cd51128 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When classification is RED" ;
    oc:directiveContent "RED-classified NDAs must not be signed. Route to full legal review with counterproposal using the organization's standard form NDA." ;
    oc:hasRationale "Signing a RED-classified NDA could expose the organization to non-compete liability, IP loss, perpetual obligations, or jurisdictional disadvantage" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4d23560e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, in every triage output" ;
    oc:directiveContent "This skill assists with legal workflows but does not provide legal advice. All analysis must be reviewed by qualified legal professionals before being relied upon." ;
    oc:hasRationale "NDAs are legally binding instruments; AI screening cannot replace professional legal judgment" ;
    oc:severityLevel "CRITICAL" .

oc:kn_50dca784 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no organization-specific playbook exists" ;
    oc:directiveContent "If no NDA playbook is configured in local settings, proceed with market-standard defaults: mutual obligations, 2-3 year term (up to 5 for trade secrets), standard carveouts, no non-solicits/non-competes, no residuals, reasonable commercial jurisdiction." ;
    oc:hasRationale "Screening should not be blocked by missing configuration; defaults should be clearly noted in the output" .

oc:kn_8a06f8a3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating carveouts in Step 3 section 4" ;
    oc:directiveContent "All five standard carveouts must be present: public knowledge, prior possession, independent development, third-party receipt, and legal compulsion." ;
    oc:hasRationale "Missing carveouts—especially independent development or legal compulsion—can create liability for internally-developed work or legally required disclosures" ;
    oc:severityLevel "HIGH" .

oc:kn_996cb950 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When screening any NDA document" ;
    oc:directiveContent "If the document is labeled as an NDA but contains substantive commercial terms, exclusivity, or other obligations beyond confidentiality, flag it immediately as RED and recommend full contract review instead." ;
    oc:hasRationale "Misleadingly labeled documents can expose the organization to unintended commercial obligations" ;
    oc:severityLevel "HIGH" .

_:ref_00c1424233867acc a oc:WorkflowStep ;
    dcterms:description "Evaluate the NDA against 10 screening criteria: agreement structure, definition scope, receiving party obligations, standard carveouts, permitted disclosures, term/duration, return/destruction, remedies, problematic provisions, governing law." ;
    oc:expectedOutcome "Each criterion marked PASS/FLAG/FAIL" ;
    oc:stepDependsOn _:ref_e11930360bc091e5 ;
    oc:stepId "quick-screen" .

_:ref_2969830768bf5fcf a oc:WorkflowStep ;
    dcterms:description "Assign GREEN (all criteria pass), YELLOW (minor issues), or RED (significant issues) classification based on screening results." ;
    oc:expectedOutcome "Classification assigned with justification" ;
    oc:stepDependsOn _:ref_00c1424233867acc ;
    oc:stepId "classify" .

_:ref_a15e8d68cedbd159 a oc:WorkflowStep ;
    dcterms:description "Accept the NDA via file upload, URL, or pasted text. Prompt user if none provided." ;
    oc:expectedOutcome "NDA content available for analysis" ;
    oc:stepId "accept-nda" .

_:ref_e11930360bc091e5 a oc:WorkflowStep ;
    dcterms:description "Load NDA screening playbook from local settings (legal.local.md) or apply market-standard defaults." ;
    oc:expectedOutcome "Screening criteria loaded for evaluation" ;
    oc:stepDependsOn _:ref_a15e8d68cedbd159 ;
    oc:stepId "load-playbook" .

_:ref_f76efa523de9bd73 a oc:WorkflowStep ;
    dcterms:description "Generate structured triage report with classification, screening results table, issues found, and recommendation." ;
    oc:expectedOutcome "Complete triage report output" ;
    oc:stepDependsOn _:ref_2969830768bf5fcf ;
    oc:stepId "generate-report" .

