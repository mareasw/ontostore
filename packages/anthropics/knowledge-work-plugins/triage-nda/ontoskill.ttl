                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Unilateral when mutual is required** (or wrong direction for the relationship)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
