oc:skill_knowledge_work_plugins_analyze a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "analyze" ;
    skos:broader "Data analysis workflow" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/analyze" ;
    oc:contentHash "72e6e1d9fb31f5b7ab6c52abe87eb57238766eb174db086281798bc105a1cb0d" ;
