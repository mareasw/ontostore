@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_analyze a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "analyze" ;
    skos:broader "Data analysis workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/analyze" ;
    oc:contentHash "72e6e1d9fb31f5b7ab6c52abe87eb57238766eb174db086281798bc105a1cb0d" ;
    oc:dependsOnSkill oc:skill_data_visualization,
        oc:skill_sql_queries ;
    oc:differentia "that answers natural language data questions across complexity levels from quick lookups to formal reports, with schema exploration, SQL execution, validation, and visualization" ;
    oc:handlesFailure oc:DataQualityIssue,
        oc:InvalidInput,
        oc:QueryExecutionFailed ;
    oc:hasArgumentHint "<question>" ;
    oc:hasCategory "data-analysis" ;
    oc:hasDescription "Answer data questions -- from quick lookups to full analyses. Use when looking up a single metric, investigating what's driving a trend or drop, comparing segments over time, or preparing a formal data report for stakeholders." ;
    oc:hasName "analyze" ;
    oc:impartsKnowledge oc:kn_22d5d670,
        oc:kn_5bc582aa,
        oc:kn_94c00a10,
        oc:kn_a17e1cd4,
        oc:kn_d2437055 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "analyze data quality",
        "answer data questions",
        "compare segments over time",
        "investigate trends or drops in data",
        "look up a single metric",
        "prepare formal data reports for stakeholders" ;
    oc:yieldsState oc:AnalysisComplete,
        oc:DataValidated .

oc:kn_22d5d670 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "Always, after analysis and before presenting findings" ;
    oc:directiveContent "Before presenting results, validate with five checks: row count sanity, null checks for unexpected nulls, magnitude checks for reasonable ranges, trend continuity for time series gaps, and aggregation logic verification that subtotals sum to totals." ;
    oc:hasRationale "Validation catches data quality issues, logic errors, and misleading results before they reach stakeholders." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5bc582aa a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting any analysis results" ;
    oc:directiveContent "Match presentation format to complexity level: quick answers get direct answers with query reproducibility; full analyses lead with key findings supported by tables/charts; formal reports include executive summary, methodology, detailed findings, caveats, and recommendations." ;
    oc:hasRationale "Appropriate presentation format ensures the audience gets the right level of detail without being overwhelmed or underserved." .

oc:kn_94c00a10 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When receiving any data question, before writing queries" ;
    oc:directiveContent "Classify the question complexity before starting: quick answer (single metric lookup), full analysis (multi-dimensional exploration), or formal report (comprehensive investigation with methodology). Each level dictates different output depth and validation rigor." ;
    oc:hasRationale "Proper complexity classification prevents over-engineering simple lookups and under-delivering on complex analyses." .

oc:kn_a17e1cd4 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On query execution failure or suspicious results" ;
    oc:directiveContent "If a SQL query fails, debug and retry by checking column names, table references, and dialect-specific syntax. If results look unexpected, run sanity checks before proceeding with analysis." ;
    oc:hasRationale "Query failures are common due to schema mismatches and dialect differences; systematic debugging saves time over starting from scratch." .

oc:kn_d2437055 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Always, before executing any data retrieval" ;
    oc:directiveContent "Before querying, explore the schema to find relevant tables and columns. If no data warehouse MCP server is connected, ask the user to provide data via pasted results, CSV/Excel upload, or schema description." ;
    oc:hasRationale "Schema exploration prevents incorrect table/column references and ensures the analysis uses the right data sources." .

