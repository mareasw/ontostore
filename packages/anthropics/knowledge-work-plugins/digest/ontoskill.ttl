@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_digest a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "digest" ;
    skos:broader "Activity summarization tool" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/digest" ;
    oc:contentHash "02951fe09cf0a730540289fb7f1be680b91b2640834e861aafacebd46e2b3760" ;
    oc:differentia "aggregates recent activity across multiple connected MCP sources into a structured daily or weekly digest grouped by topic with prioritized action items" ;
    oc:handlesFailure oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "[--daily | --weekly | --since <date>]" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Generate a daily or weekly digest of activity across all connected sources. Use when catching up after time away, starting the day and wanting a summary of mentions and action items, or reviewing a week's decisions and document updates grouped by project." ;
    oc:hasName "digest" ;
    oc:impartsKnowledge oc:kn_3f36a93f,
        oc:kn_43d6e9a3,
        oc:kn_45130ecc,
        oc:kn_592ab68f,
        oc:kn_5e7d9986,
        oc:kn_6229b10b,
        oc:kn_7296fe1a ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "catch up after time away",
        "generate daily digest of activity",
        "generate weekly digest of activity",
        "review decisions and document updates grouped by project",
        "summarize mentions and action items across sources" ;
    oc:yieldsState oc:DigestGenerated .

oc:kn_3f36a93f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating weekly (7-day) digests" ;
    oc:directiveContent "For weekly digests, prioritize significance over completeness — highlight what matters, skip noise." ;
    oc:hasRationale "Weekly volumes can be overwhelming; surfacing only meaningful items prevents information fatigue and maintains trust." ;
    oc:severityLevel "MEDIUM" .

oc:kn_43d6e9a3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting the final digest output" ;
    oc:directiveContent "Group digest output by topic or project, not by source — users care about what happened, not where it happened." ;
    oc:hasRationale "Cross-source grouping reduces cognitive load and reveals connected activity that would be invisible when siloed by source." ;
    oc:severityLevel "HIGH" .

oc:kn_45130ecc a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When merging activity from multiple sources during grouping" ;
    oc:directiveContent "Deduplicate cross-source activity — the same decision mentioned in chat and email should appear as a single entry." ;
    oc:hasRationale "Duplicate entries inflate the digest and confuse the reader about whether they represent separate or identical events." ;
    oc:severityLevel "HIGH" .

oc:kn_592ab68f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When any MCP source is unreachable or returns an error" ;
    oc:directiveContent "Do not let one failed source prevent the entire digest from being generated. Produce the best digest possible from available sources." ;
    oc:hasRationale "Partial digests are still valuable; failing silently or completely on one source erodes user trust in the tool." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5e7d9986 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting the digest generation process" ;
    oc:directiveContent "Check that at least one MCP source is connected before attempting to gather activity. If none are connected, guide the user to connect sources." ;
    oc:hasRationale "A digest with zero sources produces no useful output; early detection avoids wasted effort and provides clear remediation steps." ;
    oc:severityLevel "HIGH" .

oc:kn_6229b10b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing each digest line item" ;
    oc:directiveContent "Include enough context in each digest item so the user can decide whether to dig deeper without needing to click through to the source." ;
    oc:hasRationale "The digest should be self-contained enough for triage; forcing source navigation defeats the purpose of a summary." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7296fe1a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When structuring the digest output format" ;
    oc:directiveContent "Always list action items first in the digest — they are the most actionable part and should be immediately visible." ;
    oc:hasRationale "Action items are time-sensitive and require user response; burying them reduces the digest's utility." ;
    oc:severityLevel "HIGH" .

