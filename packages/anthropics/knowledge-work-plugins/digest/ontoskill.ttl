oc:kn_06024fa4 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a connected source is unavailable during gathering" ;
    oc:directiveContent "If any source fails or is unreachable, produce the best digest possible from available sources. Do not let one failed source block the entire digest." ;
    oc:hasRationale "Partial digests are still valuable; blocking on a single source would defeat the purpose of a multi-source aggregation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_060d8940 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting digest output" ;
    oc:directiveContent "Action items must always be listed first in the digest output, before decisions, topics, mentions, and updates." ;
    oc:hasRationale "Action items are the most actionable and time-sensitive part of a digest; they require immediate attention." ;
    oc:severityLevel "HIGH" .

oc:kn_1916f9c9 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning digest generation" ;
    oc:directiveContent "Verify at least one MCP source is connected before attempting to gather activity. If none connected, guide the user to configure sources." ;
    oc:hasRationale "A digest with zero sources produces no output and confuses the user; early detection enables a helpful setup message." .

oc:kn_19a59630 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing digest output" ;
    oc:directiveContent "Group digest by topic/project rather than by source — users care about what happened, not where it happened." ;
    oc:hasRationale "Cross-source grouping reduces cognitive load by showing related activity together regardless of originating platform." ;
    oc:severityLevel "HIGH" .

oc:kn_3f16670f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing individual digest entries" ;
    oc:directiveContent "Include enough context in each digest item that the user can decide whether to dig deeper without clicking through to the source." ;
    oc:hasRationale "The digest should be self-contained enough for triage; requiring click-throughs defeats the purpose of summarization." .

oc:kn_3f36a93f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating weekly digests" ;
    oc:directiveContent "For weekly digests, prioritize significance over completeness — highlight what matters, skip noise." ;
    oc:hasRationale "A week of activity can be overwhelming; surfacing only significant events makes the digest useful rather than exhaustive." .

oc:kn_5434e051 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting activity items that reference people or projects" ;
    oc:directiveContent "If the user has a memory system (CLAUDE.md), use it to decode people names and project references for contextual relevance." ;
    oc:hasRationale "Memory systems contain user-specific context that maps shorthand references to meaningful identities." .

oc:kn_75760705 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When merging activity from multiple sources" ;
    oc:directiveContent "Deduplicate cross-source activity — the same decision mentioned in chat and email should appear as one entry." ;
    oc:hasRationale "Duplicate entries inflate the digest and create confusion about whether events are distinct or repeated." .

_:ref_039c3369c15e3a43 a oc:WorkflowStep ;
    dcterms:description "Determine time window from user flags: --daily (24h default), --weekly (7d), or --since <date> for custom range." ;
    oc:expectedOutcome "Time window defined with start and end timestamps." ;
    oc:stepId "parse-flags" .

_:ref_05b8dca89bd36072 a oc:WorkflowStep ;
    dcterms:description "Query each available source for activity within the time window: mentions, messages, documents, tasks, opportunities, wiki updates." ;
    oc:expectedOutcome "Raw activity items from each connected source with timestamps and metadata." ;
    oc:stepDependsOn _:ref_d631419b492e181f ;
    oc:stepId "gather-activity" .

