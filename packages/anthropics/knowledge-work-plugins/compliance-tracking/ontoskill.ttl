oc:skill_knowledge_work_plugins_compliance_tracking a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "compliance-tracking" ;
    skos:broader "Compliance management framework" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/compliance-tracking" ;
    oc:contentHash "fbb4cda9701a51eace699862af49c7ec27a3c80c57c0c584f49fb897122c9bc0" ;
    oc:differentia "Tracks regulatory requirements, audit readiness, evidence collection, and gap analysis across multiple compliance frameworks" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "framework or compliance topic (e.g., 'SOC 2', 'ISO 27001', 'GDPR', 'HIPAA', 'PCI DSS')" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Track compliance requirements and audit readiness. Trigger with \"compliance\", \"audit prep\", \"SOC 2\", \"ISO 27001\", \"GDPR\", \"regulatory requirement\", or when the user needs help tracking, preparing for, or documenting compliance activities." ;
    oc:hasName "compliance-tracking" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: compliance-tracking
description: Track compliance requirements and audit readiness. Trigger with "compliance", "audit prep", "SOC 2", "ISO 27001", "GDPR", "regulatory requirement", or when the user needs help tracking, preparing for, or documenting compliance activities.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Help track compliance requirements, prepare for audits, and maintain regulatory readiness." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 5 ;
                            oc:tableCaption "## Common Frameworks" ;
                            oc:tableMarkdown """| Framework | Focus | Key Requirements |
|-----------|-------|-----------------|
| SOC 2 | Service organizations | Security, availability, processing integrity, confidentiality, privacy |
| ISO 27001 | Information security | Risk assessment, security controls, continuous improvement |
| GDPR | Data privacy (EU) | Consent, data rights, breach notification, DPO |
| HIPAA | Healthcare data (US) | PHI protection, access controls, audit trails |
| PCI DSS | Payment card data | Encryption, access control, vulnerability management |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Common Frameworks" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Produce compliance status dashboards, gap analyses, audit prep checklists, and evidence collection plans." ] ;
