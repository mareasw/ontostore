@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_compliance_tracking a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "compliance-tracking" ;
    skos:broader "compliance management framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/compliance-tracking" ;
    oc:contentHash "fbb4cda9701a51eace699862af49c7ec27a3c80c57c0c584f49fb897122c9bc0" ;
    oc:differentia "tracks regulatory requirements, audit readiness, and evidence across multiple compliance frameworks (SOC 2, ISO 27001, GDPR, HIPAA, PCI DSS)" ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput ;
    oc:hasArgumentHint "framework name or compliance topic (e.g., 'SOC 2', 'GDPR', 'audit prep')" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Track compliance requirements and audit readiness. Trigger with \"compliance\", \"audit prep\", \"SOC 2\", \"ISO 27001\", \"GDPR\", \"regulatory requirement\", or when the user needs help tracking, preparing for, or documenting compliance activities." ;
    oc:hasName "compliance-tracking" ;
    oc:impartsKnowledge oc:kn_3f41fc09,
        oc:kn_6383b97e,
        oc:kn_a7dc6c2e,
        oc:kn_d1b9375f,
        oc:kn_f0026653 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "conduct gap analysis against regulatory frameworks",
        "generate audit readiness checklists",
        "manage compliance evidence collection",
        "prepare for audits",
        "produce compliance status dashboards",
        "track compliance requirements" ;
    oc:yieldsState oc:ComplianceStatusAssessed,
        oc:GapAnalysisCompleted .

oc:kn_3f41fc09 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing compliance evidence" ;
    oc:directiveContent "Do not treat evidence collection as a one-time activity; evidence must be continuously collected, dated, and stored in a known location for each control." ;
    oc:hasRationale "Stale or missing evidence is one of the most common audit failures; continuous evidence management ensures audit readiness at all times." ;
    oc:severityLevel "HIGH" .

oc:kn_6383b97e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building or maintaining a control inventory for any compliance framework" ;
    oc:directiveContent "Map every control explicitly to its corresponding framework requirement, document the control owner, and maintain current evidence artifacts." ;
    oc:hasRationale "Unmapped or undocumented controls create audit findings and make it impossible to demonstrate compliance to auditors." ;
    oc:severityLevel "HIGH" .

oc:kn_a7dc6c2e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When conducting gap analysis between current state and framework requirements" ;
    oc:directiveContent "Prioritize gap analysis remediation by risk severity and deadline proximity: address high-risk gaps and near-term audit deadlines first." ;
    oc:hasRationale "Limited resources mean not all gaps can be addressed simultaneously; risk-based prioritization maximizes compliance posture improvement per unit of effort." .

oc:kn_d1b9375f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning audit preparation activities" ;
    oc:directiveContent "Maintain an audit calendar with upcoming audit dates, evidence collection timelines, and remediation deadlines to ensure no compliance deadlines are missed." ;
    oc:hasRationale "Proactive calendar management prevents last-minute evidence scrambles and ensures remediation work is completed before auditors arrive." .

oc:kn_f0026653 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working across multiple compliance frameworks (SOC 2, ISO 27001, GDPR, HIPAA, PCI DSS)" ;
    oc:directiveContent "Each compliance framework has distinct and non-interchangeable requirements; never assume satisfying one framework automatically satisfies another." ;
    oc:hasRationale "Frameworks overlap but are not identical; assuming equivalence leads to gaps that auditors will flag as findings." ;
    oc:severityLevel "CRITICAL" .

