oc:kn_1ab59dee a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting compliance tracking" ;
    oc:directiveContent "Identify the target compliance framework(s) before beginning any tracking activity, as requirements differ significantly across SOC 2, ISO 27001, GDPR, HIPAA, and PCI DSS." ;
    oc:hasRationale "Framework selection determines control mapping, evidence requirements, and audit cadence." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3fc6af80 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building a control inventory" ;
    oc:directiveContent "Each control must be mapped to specific framework requirements, with a documented owner and supporting evidence." ;
    oc:hasRationale "Unmapped or ownerless controls fail audit review and create compliance gaps." ;
    oc:severityLevel "HIGH" .

oc:kn_53230b1d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing gap analysis" ;
    oc:directiveContent "Prioritize gap remediation by risk severity and audit deadline proximity." ;
    oc:hasRationale "Limited resources require triage; the highest-impact gaps closest to audit dates should be addressed first." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8c169fa2 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When managing compliance evidence" ;
    oc:directiveContent "Maintain an evidence lifecycle: document what evidence is needed per control, where it is stored, and when it was last collected." ;
    oc:hasRationale "Stale or missing evidence is the most common cause of audit findings." ;
    oc:severityLevel "HIGH" .

oc:kn_d6a6e565 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any compliance tracking workflow" ;
    oc:directiveContent "Track four core components: Control Inventory, Audit Calendar, Evidence Management, and Gap Analysis as an integrated system." ;
    oc:hasRationale "These four components form the minimum viable structure for sustained audit readiness." .

_:ref_0799103a8cfa3c76 a oc:WorkflowStep ;
    dcterms:description "Establish audit dates, evidence collection deadlines, and remediation milestones." ;
    oc:expectedOutcome "Audit calendar with key dates and deadlines." ;
    oc:stepDependsOn _:ref_ef7d24625a52ad05 ;
    oc:stepId "build-audit-calendar" .

_:ref_10cd62edd0e64fef a oc:WorkflowStep ;
    dcterms:description "Identify the target compliance framework(s) and their specific requirements." ;
    oc:expectedOutcome "Clear list of applicable framework requirements." ;
    oc:stepId "identify-framework" .

_:ref_1bf5b7b9019266bc a oc:WorkflowStep ;
    dcterms:description "Identify what evidence is needed per control, where it is stored, and when it was last collected." ;
    oc:expectedOutcome "Evidence inventory with collection status and storage locations." ;
    oc:stepDependsOn _:ref_5b4d38b3c535a36a ;
    oc:stepId "collect-evidence" .

_:ref_5b4d38b3c535a36a a oc:WorkflowStep ;
    dcterms:description "Build or review the control inventory — map controls to framework requirements, document owners and evidence." ;
    oc:expectedOutcome "Complete control inventory with ownership assignments." ;
    oc:stepDependsOn _:ref_10cd62edd0e64fef ;
    oc:stepId "inventory-controls" .

_:ref_ef7d24625a52ad05 a oc:WorkflowStep ;
    dcterms:description "Compare requirements against current state, identify gaps, and prioritize remediation." ;
    oc:expectedOutcome "Gap analysis with prioritized remediation plan and timeline." ;
    oc:stepDependsOn _:ref_1bf5b7b9019266bc ;
    oc:stepId "conduct-gap-analysis" .

