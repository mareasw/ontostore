_:ref_b56f97ae2f330664 a oc:WorkflowStep ;
    dcterms:description "**Include rollback criteria** — Decide when to roll back before you deploy, not during." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
