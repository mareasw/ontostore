@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_deploy_checklist a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "deploy-checklist" ;
    skos:broader "verification checklist" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/deploy-checklist" ;
    oc:contentHash "15df3107f2283da5cd3d91ae72b8d35462f8e91ca0480843f7869f8e2d27d87b" ;
    oc:differentia "structured pre-deployment readiness verification with pre-deploy, deploy, post-deploy, and rollback trigger sections" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "[service or release name]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Pre-deployment verification checklist. Use when about to ship a release, deploying a change with database migrations or feature flags, verifying CI status and approvals before going to production, or documenting rollback triggers ahead of time." ;
    oc:hasName "deploy-checklist" ;
    oc:impartsKnowledge oc:kn_03aa319e,
        oc:kn_0b9e43e0,
        oc:kn_54508975,
        oc:kn_958c7278,
        oc:kn_b1a514ed ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "customize pre-deployment verification for specific stack",
        "document rollback triggers",
        "generate deploy checklist",
        "verify release readiness" ;
    oc:yieldsState oc:DeployChecklistGenerated .

oc:kn_03aa319e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating rollback triggers section" ;
    oc:directiveContent "Define rollback criteria (error rate thresholds, latency limits, critical flow failures) before deploying, not during an incident." ;
    oc:hasRationale "Pre-committing to rollback thresholds prevents emotional or pressure-driven decisions during active incidents." ;
    oc:severityLevel "HIGH" .

oc:kn_0b9e43e0 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When connectors for source control, CI/CD, or monitoring are available" ;
    oc:directiveContent "Leverage connected integrations (source control, CI/CD, monitoring) to auto-fill checklist items like PR approval status, pipeline health, and metric baselines." ;
    oc:hasRationale "Automated verification reduces human error and ensures checklist items reflect real-time system state rather than assumptions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_54508975 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Pre-deploy phase of the checklist" ;
    oc:directiveContent "Verify CI builds are green, code reviews are approved, no critical bugs are known, migrations are tested, and feature flags are configured before proceeding to deploy." ;
    oc:hasRationale "Catching issues before deployment is orders of magnitude cheaper than catching them in production." ;
    oc:severityLevel "CRITICAL" .

oc:kn_958c7278 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before any release or deployment" ;
    oc:directiveContent "Run the deploy checklist before every deployment, including routine ones, to prevent omission of critical verification steps." ;
    oc:hasRationale "Checklists prevent the 'I forgot to...' pattern that causes preventable deployment failures." ;
    oc:severityLevel "HIGH" .

oc:kn_b1a514ed a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When establishing a team's deployment workflow" ;
    oc:directiveContent "Customize the checklist once for your stack and reuse it — tell the agent your stack details so it can remember your deploy process." ;
    oc:hasRationale "Stack-specific customization turns a generic checklist into a reliable, repeatable process tailored to the team's actual infrastructure." ;
    oc:severityLevel "MEDIUM" .

