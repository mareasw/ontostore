_:ref_44f3872225bbd2be a oc:WorkflowStep ;
    dcterms:description "Check for connected source control, CI/CD, and monitoring integrations to pre-fill checklist items" ;
    oc:expectedOutcome "List of available connector data: release diffs, CI status, metric baselines" ;
    oc:stepDependsOn _:ref_31d4afba55a63486 ;
