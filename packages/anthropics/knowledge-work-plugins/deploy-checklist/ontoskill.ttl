oc:kn_0a9bbbcb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining rollback triggers" ;
    oc:directiveContent "Decide rollback criteria before deploying, not during an incident. Define concrete thresholds like error rate percentage and latency bounds." ;
    oc:hasRationale "Under pressure during a deploy failure, judgment is impaired; pre-committing to thresholds enables objective go/no-go decisions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4894726a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — pre-deploy phase" ;
    oc:directiveContent "Verify CI is green and all PRs are approved before proceeding to deploy stage. Block deploy if checks fail." ;
    oc:hasRationale "Deploying untested or unreviewed code bypasses the safety gates that prevent regressions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7bf89cc7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When first setting up deployment workflows" ;
    oc:directiveContent "Customize the checklist once for your stack, then reuse it. Tell the skill your specific tools and it will remember your deploy process." ;
    oc:hasRationale "Stack-specific checklists catch stack-specific failure modes that generic checklists miss" .

oc:kn_7c9f4e69 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before every deployment" ;
    oc:directiveContent "Run a deployment checklist before every deploy, even routine ones. Checklists prevent omission errors." ;
    oc:hasRationale "Routine deploys are where complacency causes the most preventable failures" ;
    oc:severityLevel "HIGH" .

oc:kn_b0af0471 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When monitoring integration is connected" ;
    oc:directiveContent "Pre-fill rollback trigger thresholds from current monitoring baselines when monitoring connectors are available." ;
    oc:hasRationale "Using current baselines ensures rollback thresholds are grounded in actual system behavior rather than guesses" .

