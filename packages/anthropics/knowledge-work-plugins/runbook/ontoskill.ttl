oc:skill_knowledge_work_plugins_runbook a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "runbook" ;
    skos:broader "document generator" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/runbook" ;
    oc:contentHash "fe910a6b5e9cdc43d84ac690eef3d7ac7f2e831a3cc484b44f9b14c7ef6a1010" ;
    oc:differentia "that produces step-by-step operational procedures with failure modes, rollback, and escalation paths for recurring ops tasks" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<process or task name>" ;
    oc:hasCategory "documentation" ;
    oc:hasDescription "Create or update an operational runbook for a recurring task or procedure. Use when documenting a task that on-call or ops needs to run repeatably, turning tribal knowledge into exact step-by-step commands, adding troubleshooting and rollback steps to an existing procedure, or writing escalation paths for when things go wrong." ;
    oc:hasName "runbook" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: runbook
description: Create or update an operational runbook for a recurring task or procedure. Use when documenting a task that on-call or ops needs to run repeatably, turning tribal knowledge into exact step-by-step commands, adding troubleshooting and rollback steps to an existing procedure, or writing escalation paths for when things go wrong.
argument-hint: "<process or task name>"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Create a step-by-step operational runbook for a recurring task or procedure." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Publish the completed runbook to your ops wiki" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Search for existing runbooks to update rather than create from scratch" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "If **~~ITSM** is connected:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Link the runbook to related incident types and change requests" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Auto-populate escalation contacts from on-call schedules" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "If **~~knowledge base** is connected:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "If Connectors Available" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/runbook $ARGUMENTS
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 15-17" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Usage" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_21226fb0176f7c59 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Tips" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "[Exact command, action, or instruction]" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """## Runbook: [Task Name]
**Owner:** [Team/Person] | **Frequency:** [Daily/Weekly/Monthly/As Needed]
**Last Updated:** [Date] | **Last Run:** [Date]

### Purpose
[What this runbook accomplishes and when to use it]

### Prerequisites
- [ ] [Access or permission needed]
- [ ] [Tool or system required]
- [ ] [Data or input needed]

### Procedure

#### Step 1: [Name]
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 21-37" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "[Exact command, action, or instruction]" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """**Expected result:** [What should happen]
**If it fails:** [What to do]

### Verification
- [ ] [How to confirm the task completed successfully]
- [ ] [What to check]

### Troubleshooting
| Symptom | Likely Cause | Fix |
|---------|-------------|-----|
| [What you see] | [Why] | [What to do] |

### Rollback
[How to undo this if something goes wrong]

### Escalation
| Situation | Contact | Method |
|-----------|---------|--------|
| [When to escalate] | [Who] | [How to reach them] |

### History
| Date | Run By | Notes |
|------|--------|-------|
| [Date] | [Person] | [Any issues or observations] |
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 5 ;
                            oc:sourceLocation "lines 46-71" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """**Expected result:** [What should happen]
**If it fails:** [What to do]

#### Step 2: [Name]
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 39-44" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Output" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "/runbook" ] ;
    oc:hasWorkflow _:ref_21226fb0176f7c59,
        [ a oc:Workflow ;
            dcterms:description "Generate a complete operational runbook with all required sections for a recurring task or procedure" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Publish completed runbook to ops wiki if knowledge base connector is available" ;
                    oc:expectedOutcome "Runbook is discoverable and accessible to the team" ;
                    oc:stepDependsOn _:ref_9729d3167fb9f5b9 ;
                    oc:stepId "publish" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "If knowledge base connector available, search for existing runbooks to update rather than create from scratch" ;
                    oc:expectedOutcome "Decision to create new or update existing runbook" ;
                    oc:stepDependsOn _:ref_393e3423b9fd7f38 ;
                    oc:stepId "search-existing" ],
                _:ref_393e3423b9fd7f38,
                _:ref_7e28fe632ce272fe,
                _:ref_9729d3167fb9f5b9,
                _:ref_d11a32fed07ea550,
                _:ref_ea4d434b103917e2 ;
            oc:workflowId "runbook-creation" ;
            oc:workflowName "Create Operational Runbook" ] ;
    oc:impartsKnowledge oc:kn_9c10e9db,
        oc:kn_a162ecf1,
        oc:kn_c0391a0b,
        oc:kn_d4b88211,
        oc:kn_de9b70c3,
        oc:kn_e8875094,
        oc:kn_f5f0b9a7 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "add troubleshooting and rollback to existing procedure",
        "create operational runbook",
        "document recurring ops procedure",
        "update existing runbook",
        "write escalation paths for on-call tasks" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_9c10e9db a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When knowledge base connector is available" ;
    oc:directiveContent "Search for existing runbooks to update before creating from scratch. Publish completed runbooks to ops wiki when knowledge base is connected." ;
    oc:hasRationale "Avoiding duplication and ensuring discoverability of operational documentation" .

oc:kn_a162ecf1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After drafting a new runbook" ;
    oc:directiveContent "Test the runbook by having someone unfamiliar with the process follow it; fix where they get stuck." ;
    oc:hasRationale "Tribal knowledge gaps only surface when an outsider attempts to follow the instructions" .

oc:kn_c0391a0b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing each procedure step" ;
    oc:directiveContent "Include failure modes at every step — document what can go wrong and what to do about it." ;
    oc:hasRationale "On-call personnel need immediate recovery paths rather than guessing under pressure" ;
    oc:severityLevel "HIGH" .

oc:kn_d4b88211 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When ITSM connector is available" ;
    oc:directiveContent "Link runbooks to related incident types and change requests; auto-populate escalation contacts from on-call schedules when ITSM is connected." ;
    oc:hasRationale "Integration with incident management ensures runbooks are surfaced at the right time with accurate contact info" .

oc:kn_de9b70c3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring the Procedure section of any runbook" ;
    oc:directiveContent "Each procedure step must include: the exact command/action, expected result, and failure recovery instruction." ;
    oc:hasRationale "Three-part steps ensure repeatability regardless of operator experience level" .

oc:kn_e8875094 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing every procedure step" ;
    oc:directiveContent "Be painfully specific — 'Run the script' is not a step. 'Run python sync.py --prod --dry-run from the ops server' is." ;
    oc:hasRationale "Vague instructions defeat the purpose of a runbook; exact commands reduce human error during stressful on-call situations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_f5f0b9a7 a oc:KnowledgeNode,
        oc:RollbackProcedure ;
    oc:appliesToContext "When creating any runbook" ;
    oc:directiveContent "Every runbook must include a rollback section explaining how to undo the procedure if something goes wrong." ;
    oc:hasRationale "Without rollback instructions, failed procedures can leave systems in an inconsistent state" ;
    oc:severityLevel "HIGH" .

_:ref_0301cd4b6d570823 a oc:WorkflowStep ;
    dcterms:description "**Be painfully specific** — \"Run the script\" is not a step. \"Run `python sync.py --prod --dry-run` from the ops server\" is." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_257660dfc2e9fc7e a oc:WorkflowStep ;
    dcterms:description "**Test the runbook** — Have someone unfamiliar with the process follow it. Fix where they get stuck." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_b83674f255586814 a oc:WorkflowStep ;
    dcterms:description "**Include failure modes** — What can go wrong at each step and what to do about it." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_21226fb0176f7c59 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_0301cd4b6d570823,
        _:ref_257660dfc2e9fc7e,
        _:ref_b83674f255586814 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_7e28fe632ce272fe a oc:WorkflowStep ;
    dcterms:description "Write each step with exact commands, expected results, and failure recovery instructions" ;
    oc:expectedOutcome "Numbered procedure steps that are painfully specific and include failure modes" ;
    oc:stepDependsOn _:ref_d11a32fed07ea550 ;
    oc:stepId "write-procedure-steps" .

_:ref_9729d3167fb9f5b9 a oc:WorkflowStep ;
    dcterms:description "If ITSM connector available, auto-populate escalation contacts from on-call schedules; link to incident types" ;
    oc:expectedOutcome "Accurate escalation table with current contacts" ;
    oc:stepDependsOn _:ref_ea4d434b103917e2 ;
    oc:stepId "populate-escalation" .

_:ref_d11a32fed07ea550 a oc:WorkflowStep ;
    dcterms:description "List all required access, permissions, tools, systems, and data inputs" ;
    oc:expectedOutcome "Complete prerequisites checklist" ;
    oc:stepDependsOn _:ref_393e3423b9fd7f38 ;
    oc:stepId "define-prerequisites" .

_:ref_ea4d434b103917e2 a oc:WorkflowStep ;
    dcterms:description "Add troubleshooting table (symptom/cause/fix), rollback procedure, and escalation paths" ;
    oc:expectedOutcome "Complete safety-net sections that help operators recover from failures" ;
    oc:stepDependsOn _:ref_7e28fe632ce272fe ;
    oc:stepId "add-troubleshooting-rollback" .

_:ref_393e3423b9fd7f38 a oc:WorkflowStep ;
    dcterms:description "Identify the process/task name, gather existing documentation or tribal knowledge about the procedure" ;
    oc:expectedOutcome "Clear understanding of the task to document, including who owns it and how frequently it runs" ;
    oc:stepId "gather-context" .

