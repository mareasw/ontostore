@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_runbook a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "runbook" ;
    skos:broader "document generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/runbook" ;
    oc:contentHash "fe910a6b5e9cdc43d84ac690eef3d7ac7f2e831a3cc484b44f9b14c7ef6a1010" ;
    oc:differentia "that produces structured operational runbooks with step-by-step procedures, failure modes, rollback instructions, and escalation paths for recurring tasks" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<process or task name>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Create or update an operational runbook for a recurring task or procedure. Use when documenting a task that on-call or ops needs to run repeatably, turning tribal knowledge into exact step-by-step commands, adding troubleshooting and rollback steps to an existing procedure, or writing escalation paths for when things go wrong." ;
    oc:hasName "runbook" ;
    oc:impartsKnowledge oc:kn_02a84cc0,
        oc:kn_0ddb1640,
        oc:kn_1e868736,
        oc:kn_651b1296,
        oc:kn_daa230e0 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "add troubleshooting steps to procedure",
        "create operational runbook",
        "document recurring procedure",
        "update existing runbook",
        "write escalation paths for on-call tasks" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_02a84cc0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After drafting or updating a runbook" ;
    oc:directiveContent "Test the runbook by having someone unfamiliar with the process follow it — fix wherever they get stuck." ;
    oc:hasRationale "The author's implicit knowledge fills gaps that a new reader will hit; fresh-eye testing reveals these assumptions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_0ddb1640 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any runbook output" ;
    oc:directiveContent "Every runbook must contain: Owner, Frequency, Prerequisites, Procedure with expected results, Verification checklist, Troubleshooting table, Rollback steps, Escalation contacts, and History log." ;
    oc:hasRationale "These sections ensure the runbook is self-contained and usable by anyone without needing to ask questions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1e868736 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing the Procedure section of a runbook" ;
    oc:directiveContent "Include failure modes at every step — document what can go wrong and what to do about it alongside each expected result." ;
    oc:hasRationale "Failure mode documentation enables on-call operators to self-recover without escalation, reducing incident resolution time." ;
    oc:severityLevel "HIGH" .

oc:kn_651b1296 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a knowledge base connector is available" ;
    oc:directiveContent "Never create a runbook from scratch if an existing one may already exist — search the knowledge base first." ;
    oc:hasRationale "Duplicate runbooks create confusion about which is canonical and can lead to inconsistent procedures." ;
    oc:severityLevel "MEDIUM" .

oc:kn_daa230e0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any procedural step in a runbook" ;
    oc:directiveContent "Be painfully specific — every step must include the exact command, tool, server, or action, not vague instructions like 'run the script'." ;
    oc:hasRationale "Vague steps lead to errors when someone unfamiliar with the process follows the runbook, which defeats the purpose of documentation." ;
    oc:severityLevel "HIGH" .

