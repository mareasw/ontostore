oc:kn_03976d29 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before drafting a new KB article" ;
    oc:directiveContent "Before creating a new article, check if a similar article already exists in the knowledge base. Decide whether to update existing content or create new based on the gap analysis." ;
    oc:hasRationale "Avoids duplication and ensures existing content stays current rather than fragmenting across multiple articles." .

oc:kn_22f34cc6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any KB article" ;
    oc:directiveContent "Every KB article must include: title, overview, structured body, related articles, and metadata (category, tags, audience, last updated date)." ;
    oc:hasRationale "These universal elements ensure consistency, searchability, and maintainability across the knowledge base." ;
    oc:severityLevel "HIGH" .

oc:kn_4512dfae a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding article type and scope" ;
    oc:directiveContent "A wrong article is worse than no article — maintain aggressively. If an answer needs a walkthrough, make it a how-to not an FAQ. If the article covers two topics, split it." ;
    oc:hasRationale "Incorrect or overly broad articles erode customer trust and increase support load rather than reducing it." ;
    oc:severityLevel "MEDIUM" .

oc:kn_550acbea a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing article titles, overviews, and content" ;
    oc:directiveContent "Write for the customer who is frustrated and searching — use customer language, not internal jargon. Include exact error messages, common synonyms, and alternate phrasings." ;
    oc:hasRationale "Articles are useless if customers can't find them through search using their own words." ;
    oc:severityLevel "HIGH" .

oc:kn_60397e76 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When classifying source material" ;
    oc:directiveContent "Choose the article type based on the source material: How-to for step-by-step tasks, Troubleshooting for diagnosing problems, FAQ for quick answers, Known Issue for bugs with workarounds, Reference for detailed technical info." ;
    oc:hasRationale "Using the right article type ensures the content structure matches what customers expect and how they search." .

oc:kn_bcf59533 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After drafting but before publishing" ;
    oc:directiveContent "Follow the steps yourself or have someone unfamiliar with the topic follow them to verify accuracy before publishing." ;
    oc:hasRationale "Untested articles may contain incorrect steps that mislead customers and generate more support tickets." .

oc:kn_c4c684f7 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When the input is a ticket number or reference" ;
    oc:directiveContent "If a ticket reference is provided, look up full context from the support platform (ticket thread, resolution, internal notes), knowledge base (existing articles), and project tracker (related bugs/features)." ;
    oc:hasRationale "Full context from connected systems produces more accurate and complete articles than relying on a ticket number alone." .

oc:kn_fdcaddf1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing titles and linking articles" ;
    oc:directiveContent "Never use internal jargon in titles, write vague titles like 'SSO Setup' or 'Dashboard Issue', or create circular links between articles." ;
    oc:hasRationale "Vague titles and circular links reduce searchability and frustrate customers trying to find answers." ;
    oc:severityLevel "MEDIUM" .

