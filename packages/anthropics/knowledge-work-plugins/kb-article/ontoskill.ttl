@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_kb_article a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "kb-article" ;
    skos:broader "Document generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/kb-article" ;
    oc:contentHash "1b69742fbf6bdd5e1affb4b7fb19237853eadbf34097bd01762dde3547370c50" ;
    oc:differentia "that produces publish-ready knowledge base articles from resolved support issues, common questions, or documented workarounds, optimized for searchability and self-service" ;
    oc:handlesFailure oc:DuplicateArticle,
        oc:InsufficientContext ;
    oc:hasArgumentHint "<resolved issue or ticket>" ;
    oc:hasCategory "documentation" ;
    oc:hasDescription "Draft a knowledge base article from a resolved issue or common question. Use when a ticket resolution is worth documenting for self-service, the same question keeps coming up, a workaround needs to be published, or a known issue should be communicated to customers." ;
    oc:hasName "kb-article" ;
    oc:impartsKnowledge oc:kn_2e46c7e1,
        oc:kn_68dbe714,
        oc:kn_76c5c0b8,
        oc:kn_be194901,
        oc:kn_c3e3251b,
        oc:kn_c6c21409,
        oc:kn_e64e2094 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:IssueResolved ;
    oc:resolvesIntent "create troubleshooting article from ticket",
        "document resolved issue for self-service",
        "draft knowledge base article",
        "publish known issue article with workaround",
        "write FAQ article for common question" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_2e46c7e1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any KB article title, overview, or body content" ;
    oc:directiveContent "Write every article for the frustrated customer searching for an answer — use their language, not internal jargon. Include exact error messages since customers copy-paste them into search." ;
    oc:hasRationale "Articles are useless if customers can't find them; searchability depends on matching customer vocabulary and exact error text" ;
    oc:severityLevel "HIGH" .

oc:kn_68dbe714 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting the KB article creation workflow" ;
    oc:directiveContent "Before creating a new article, always check if a similar article already exists in the knowledge base. Prefer updating an existing article when the change is a detail, product update, or better workaround." ;
    oc:hasRationale "Duplicate articles fragment search results and create maintenance burden; updating existing content preserves SEO and link equity" ;
    oc:severityLevel "MEDIUM" .

oc:kn_76c5c0b8 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When classifying and structuring a new KB article" ;
    oc:directiveContent "Match the article type to the problem: use 'How-to' for step-by-step tasks, 'Troubleshooting' for diagnosing problems (lead with symptoms), 'FAQ' for quick answers (keep under 3 sentences), and 'Known Issue' for bugs with workarounds." ;
    oc:hasRationale "Using the correct article type template ensures the content structure matches customer expectations and search behavior for that problem category" ;
    oc:severityLevel "MEDIUM" .

oc:kn_be194901 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing article titles" ;
    oc:directiveContent "Never title articles with vague internal jargon like 'SSO Setup' or 'Dashboard Issue'. Instead use specific, customer-facing language like 'How to configure SSO with Okta' or 'Fix: Dashboard shows blank page'." ;
    oc:hasRationale "Vague titles prevent customers from finding articles through search, defeating the self-service purpose of the KB" ;
    oc:severityLevel "HIGH" .

oc:kn_c3e3251b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When maintaining published KB articles" ;
    oc:directiveContent "A wrong or outdated article is worse than no article. Flag articles not updated in 6+ months for review, update known issue statuses weekly, and audit top-traffic articles quarterly." ;
    oc:hasRationale "Stale or inaccurate content erodes customer trust and increases support volume rather than reducing it" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c6c21409 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating any knowledge base article" ;
    oc:directiveContent "Every KB article must include: clear searchable title, 1-2 sentence overview, structured body (per article type), related articles links, and metadata (category, tags, audience, last updated)." ;
    oc:hasRationale "Consistent structure ensures findability, scannability, and maintainability across the knowledge base" ;
    oc:severityLevel "HIGH" .

oc:kn_e64e2094 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting or reviewing article content" ;
    oc:directiveContent "Keep articles focused on one problem and one solution. If an article grows too long or covers multiple topics, split it into separate articles and cross-link them." ;
    oc:hasRationale "Focused articles are easier to find, maintain, and update; long multi-topic articles confuse readers and dilute search relevance" ;
    oc:severityLevel "LOW" .

