        oc:kn_fab0e318 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:GuidelinesGenerated ;
    oc:resolvesIntent "assess reliability of generated guideline sections",
        "calculate aggregate guideline confidence",
        "score confidence of brand guidelines" ;
    oc:yieldsState oc:ConfidenceScored .

oc:kn_2fc21626 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoring section confidence" ;
    oc:directiveContent "Do not assign High confidence to sections derived from a single source or a single observation, regardless of how authoritative that source appears." ;
    oc:hasRationale "Single-source evidence cannot demonstrate consistency or corroboration, which are essential for High confidence" ;
    oc:severityLevel "HIGH" .

oc:kn_38ff5714 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no authoritative brand documents are available" ;
    oc:directiveContent "When guidelines derive primarily from conversational sources with no AUTHORITATIVE documents, cap maximum confidence at Medium for Voice Attributes and Messaging Framework, and increase Language Patterns weight from 10% to 20% (reducing Voice Attributes by 10%)." ;
    oc:hasRationale "Conversational sources alone lack the formality and comprehensiveness of official materials, so confidence must be capped and transcript-derived patterns weighted more heavily" ;
    oc:severityLevel "MEDIUM" .

oc:kn_583422f1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoring any guideline section" ;
    oc:directiveContent "High confidence requires meeting at least 3 of 5 criteria: 3+ sources, explicit authoritative guidance, cross-analysis consistency, actionable instructions, no unresolved conflicts. Medium requires 2+, Low requires 2+ of its own criteria." ;
    oc:hasRationale "Multi-criteria thresholds prevent inflated confidence from a single strong signal" ;
    oc:severityLevel "HIGH" .

oc:kn_59e427e3 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When calculating and presenting confidence scores" ;
    oc:directiveContent "1. Score each section (Voice, Messaging, Tone, Terminology, Language Patterns) as High/Medium/Low using section-specific criteria. 2. Convert to numeric (High=1.0, Medium=0.6, Low=0.3). 3. Apply weights: Voice 30%, Messaging 25%, Tone 20%, Terminology 15%, Language 10%. 4. Sum weighted scores for aggregate. 5. Map aggregate: 0.85-1.0=High, 0.60-0.84=Medium, <0.60=Low. 6. Present confidence alongside each section header; add explanatory notes for Medium/Low. 7. Generate open questions for low-confidence sections." ;
    oc:stepOrder 1 .

oc:kn_625d8209 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When relating confidence scores to open questions" ;
    oc:directiveContent "Low confidence + conflict = High Priority open question. Low confidence + gap = Medium Priority open question. Medium confidence + minor inconsistency = Low Priority open question. Every open question should include a recommendation that, if confirmed, would raise confidence." ;
    oc:hasRationale "Prioritizes team review effort toward the most uncertain and conflicted areas" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fab0e318 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When presenting scored guideline sections" ;
    oc:directiveContent """## {Section Name} (Confidence: {High|Medium|Low})
[content]
For Medium/Low: include a brief note explaining why confidence is limited and what would raise it.""" ;
    oc:templateVariables "High|Medium|Low",
        "Section Name",
        "content" .

