@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_guideline_generation_confidence_scoring a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "confidence-scoring" ;
    skos:broader "Scoring methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/guideline-generation" ;
    oc:contentHash "b3103f815d405db6c952321181c3618739de22d9c2d078c7f93548000d7bef20" ;
    oc:differentia "that assigns and interprets confidence levels for generated brand guidelines based on source corroboration, consistency, and specificity" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_guideline_generation ;
    oc:handlesFailure oc:InsufficientSources ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_17b2fb59,
        oc:kn_243a792e,
        oc:kn_46679513,
        oc:kn_9a2b3776,
        oc:kn_c2a1ef53,
        oc:kn_dee8f365 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:GuidelinesGenerated ;
    oc:resolvesIntent "assess brand guideline reliability",
        "calculate aggregate confidence for guidelines",
        "determine confidence levels for guideline sections",
        "score guideline confidence" ;
    oc:yieldsState oc:GuidelinesScored .

oc:kn_17b2fb59 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When computing the overall guideline confidence score after section-level scoring is complete" ;
    oc:directiveContent "Calculate aggregate confidence as a weighted average across five sections: Voice Attributes (30%), Messaging Framework (25%), Tone Matrix (20%), Terminology (15%), Language Patterns (10%). Convert High=1.0, Medium=0.6, Low=0.3. Overall thresholds: 0.85+=High, 0.60-0.84=Medium, <0.60=Low." ;
    oc:hasRationale "Weighted averaging reflects that some guideline dimensions carry more brand significance than others, and numeric thresholds provide clear, consistent categorization" .

oc:kn_243a792e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finalizing confidence scores and preparing guideline output for stakeholders" ;
    oc:directiveContent "Low confidence sections must generate corresponding open questions: Low+conflict = High Priority, Low+gap = Medium Priority, Medium+minor inconsistency = Low Priority. Each open question must include a recommendation that, if confirmed, would raise the section's confidence." ;
    oc:hasRationale "Linking low confidence to actionable open questions ensures gaps are surfaced for team resolution rather than silently accepted, creating a quality improvement feedback loop" ;
    oc:severityLevel "HIGH" .

oc:kn_46679513 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When presenting or formatting the final brand guidelines output" ;
    oc:directiveContent "Present the confidence level alongside each section header in the format '## Section Name (Confidence: Level)'. For Medium and Low confidence sections, include a brief note explaining why confidence is limited and what evidence would raise it." ;
    oc:hasRationale "Transparent confidence labeling gives stakeholders immediate visibility into which sections need review, preventing uncritical adoption of low-confidence recommendations" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9a2b3776 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating individual guideline sections for confidence scoring" ;
    oc:directiveContent "High confidence requires meeting at least 3 of 5 criteria (3+ sources, authoritative explicit guidance, cross-document consistency, actionable specificity, no unresolved conflicts). Medium requires at least 2 criteria. Low also requires at least 2 but with significant interpretation or single-source limitations." ;
    oc:hasRationale "Tiered minimum criteria prevent inflated confidence from superficial evidence and ensure each level is meaningfully distinguishable" .

oc:kn_c2a1ef53 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning any confidence level to a guideline section" ;
    oc:directiveContent "Confidence scores must be based on objective criteria: number of corroborating sources, presence of explicit guidance in authoritative sources, cross-source consistency, actionability, and absence of unresolved conflicts." ;
    oc:hasRationale "Objective, multi-criteria scoring prevents subjective bias and ensures reliability assessments are reproducible across analysts" ;
    oc:severityLevel "HIGH" .

oc:kn_dee8f365 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When no AUTHORITATIVE brand documents are available and guidelines rely on transcript/conversation sources" ;
    oc:directiveContent "When guidelines are generated primarily from conversational sources with no authoritative documents, cap transcript-derived voice attributes at Medium even with 5+ transcripts, increase Language Patterns weight from 10% to 20% (subtracting from Voice Attributes), and add a metadata note recommending team review to formalize." ;
    oc:hasRationale "Conversational sources are inherently less authoritative than formal brand documents; adjusting weights and capping scores prevents overconfidence in informal evidence" ;
    oc:severityLevel "MEDIUM" .

