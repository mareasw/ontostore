oc:kn_0fd1c8a4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling any section of the template" ;
    oc:directiveContent "Omit sections with no data rather than including empty placeholders. Every included section must have substantive content." ;
    oc:hasRationale "Empty placeholders reduce credibility and make the guidelines look incomplete rather than intentionally scoped" ;
    oc:severityLevel "HIGH" .

oc:kn_3b17dbe1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining which sections to include" ;
    oc:directiveContent "If transcript data is unavailable, omit the 'Language That Works' and 'Language to Avoid' sections entirely. If only documents are available (no transcripts), note this in metadata." ;
    oc:hasRationale "Language effectiveness analysis requires conversation data; inventing it from documents alone produces misleading guidance" ;
    oc:severityLevel "HIGH" .

oc:kn_50772b33 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When expanding the 'We Are' attributes into detailed descriptions" ;
    oc:directiveContent "Each voice attribute should include: what it means, how it shows up in content, what to avoid, evidence with citation, and confidence level." ;
    oc:hasRationale "Partial attribute descriptions lead to inconsistent application; evidence-based attributes are more actionable" ;
    oc:severityLevel "MEDIUM" .

oc:kn_bb365d9d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating the tone-by-context matrix" ;
    oc:directiveContent "Voice is constant across all contexts. Tone flexes by context along three dimensions: formality, energy, and technical depth." ;
    oc:hasRationale "This voice/tone separation is the foundational principle that prevents contradictory guidance across channels" ;
    oc:severityLevel "HIGH" .

oc:kn_c827ca5e a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing examples and open questions sections" ;
    oc:directiveContent "All examples must have source attribution. Every open question must include an agent recommendation." ;
    oc:hasRationale "Unattributed examples cannot be verified; open questions without recommendations leave the team without a starting point for resolution" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e382adbd a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When populating the identity anchor and tone-by-context sections" ;
    oc:directiveContent "The 'We Are / We Are Not' table should have minimum 4 rows, ideally 5-7. Tone matrix should cover at minimum: cold outreach, proposals, social media." ;
    oc:hasRationale "Fewer than 4 identity attributes lacks sufficient guidance; tone matrix must cover the most common business communication contexts" ;
    oc:severityLevel "MEDIUM" .

_:ref_0f4d3bc4bee5da55 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 4 ;
    oc:itemText "Frequency in conversations: [X]% (if transcript data available)" .

_:ref_2299975ca2e73137 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
