@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_guideline_generation_guideline_template a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "guideline-template" ;
    skos:broader "brand guidelines document template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/guideline-generation" ;
    oc:contentHash "df479f9fd101efd058ebf95f8f745ab7103cedd3539c3a970506f5cc0cf212d8" ;
    oc:differentia "that defines the complete structured output format for generated brand voice guidelines with sections for voice attributes, messaging framework, tone matrix, terminology, language patterns, and confidence scoring" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_guideline_generation ;
    oc:hasArgumentHint "discovered brand materials and analysis data" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_8f6c0230,
        oc:kn_9c183dc7,
        oc:kn_b7661664,
        oc:kn_bcd93f19,
        oc:kn_f30c8441 ;
    oc:isUserInvocable false ;
    oc:nature "concept" ;
    oc:resolvesIntent "create brand style guide from source materials",
        "generate brand voice guidelines",
        "produce brand voice documentation",
        "structure brand guidelines document" .

oc:kn_8f6c0230 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When data sources are limited to documents without conversation transcripts" ;
    oc:directiveContent "If transcript data is unavailable, omit 'Language That Works' and 'Language to Avoid' sections. If only documents are available, note this limitation in metadata." ;
    oc:hasRationale "Language effectiveness patterns require conversational evidence; fabricating them from documents alone produces misleading guidance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9c183dc7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating the voice attributes section" ;
    oc:directiveContent "The 'We Are / We Are Not' table must have a minimum of 4 rows, ideally 5-7, to establish a well-rounded brand identity anchor." ;
    oc:hasRationale "Too few attributes fail to capture brand distinctiveness; too many dilute clarity. 4-7 is the effective range for memorable brand identity." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b7661664 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the tone matrix section" ;
    oc:directiveContent "The tone-by-context matrix must cover at minimum cold outreach, proposals, and social media contexts. Voice is constant but tone flexes along formality, energy, and technical depth dimensions." ;
    oc:hasRationale "These three contexts represent the most common brand touchpoints and the minimum needed for actionable tone guidance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bcd93f19 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling the template with discovered brand data" ;
    oc:directiveContent "Omit sections with no data rather than including empty placeholders — an empty section is worse than an absent one." ;
    oc:hasRationale "Empty placeholders erode trust and suggest the guidelines cover areas they don't; omission signals honesty about coverage gaps." ;
    oc:severityLevel "HIGH" .

oc:kn_f30c8441 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling examples and open questions sections" ;
    oc:directiveContent "Every example must have source attribution and every open question must include an agent recommendation — no unsupported assertions." ;
    oc:hasRationale "Source attribution ensures traceability and trust; agent recommendations on open questions prevent analysis paralysis by giving stakeholders a starting point for decisions." ;
    oc:severityLevel "HIGH" .

