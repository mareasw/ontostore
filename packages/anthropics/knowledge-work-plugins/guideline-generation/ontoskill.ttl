@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_guideline_generation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "guideline-generation" ;
    skos:broader "Brand voice guideline generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/guideline-generation" ;
    oc:contentHash "9326fb8b7fd454e2a2a6306848091bb1dd2b7bfaf4ceee88d927776d15217ffa" ;
    oc:dependsOnSkill oc:skill_discover_brand ;
    oc:differentia "Synthesizes multi-source brand materials into structured, confidence-scored, LLM-ready guidelines with a \"We Are / We Are Not\" identity anchor and tone-by-context matrix" ;
    oc:extends oc:skill_brand_voice_enforcement ;
    oc:handlesFailure oc:InsufficientSources,
        oc:WorkingFolderNotSet ;
    oc:hasArgumentHint "brand documents, transcripts, discovery reports, or direct brand descriptions" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "This skill generates, creates, or builds brand voice guidelines from source materials. It should be used when the user asks to \"generate brand guidelines\", \"create a style guide\", \"extract brand voice\", \"create guidelines from calls\", \"consolidate brand materials\", \"analyze my sales calls for brand voice\", \"build a brand playbook from documents\", \"synthesize a voice and tone guide\", or uploads brand documents, transcripts, or meeting recordings for brand analysis. Also triggers when the user has a discovery report and wants to convert it into actionable guidelines." ;
    oc:hasName "guideline-generation" ;
    oc:impartsKnowledge oc:kn_17a5985e,
        oc:kn_2047389f,
        oc:kn_3484a9dd,
        oc:kn_4495cd1d,
        oc:kn_5d555834,
        oc:kn_a9e614fb,
        oc:kn_c1c3c6b7,
        oc:kn_da542c90,
        oc:kn_f029c920 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:SourceMaterialsAvailable ;
    oc:resolvesIntent "build a brand playbook from discovery reports",
        "consolidate brand materials into a unified guide",
        "create a style guide from source materials",
        "create guidelines from sales calls",
        "extract brand voice from transcripts and documents",
        "generate brand voice guidelines",
        "synthesize a voice and tone guide" ;
    oc:yieldsState oc:GuidelinesGenerated,
        oc:GuidelinesSaved .

oc:kn_17a5985e a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When scoring all generated guideline sections" ;
    oc:directiveContent "Assign confidence scores to every section using weighted methodology: Voice Attributes 30%, Messaging 25%, Tone Matrix 20%, Terminology 15%, Language Patterns 10%. Convert High=1.0, Medium=0.6, Low=0.3." ;
    oc:hasRationale "Weighted scoring provides transparency about which sections are well-supported vs. inferred, enabling teams to prioritize review effort." ;
    oc:severityLevel "HIGH" .

oc:kn_2047389f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the core brand identity anchor table" ;
    oc:directiveContent "The 'We Are / We Are Not' table must have at minimum 4 rows (ideally 5-7), and each row must have supporting evidence from sources with source attribution." ;
    oc:hasRationale "Fewer than 4 attribute pairs provides insufficient guidance for content creation and makes the brand identity too vague." ;
    oc:severityLevel "HIGH" .

oc:kn_3484a9dd a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling the guideline template" ;
    oc:directiveContent "Omit sections with no data rather than including empty placeholders. If transcript data is unavailable, omit 'Language That Works' and 'Language to Avoid' sections entirely." ;
    oc:hasRationale "Empty placeholders signal completeness where none exists and mislead content creators into thinking all areas are covered." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4495cd1d a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When saving guidelines and a previous version already exists" ;
    oc:directiveContent "If existing guidelines are found at the save path, archive them by renaming to brand-voice-guidelines-YYYY-MM-DD.md before writing the new version." ;
    oc:hasRationale "Archiving prevents accidental loss of previous guideline versions that teams may need to reference or roll back to." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5d555834 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing brand identity attributes from any source" ;
    oc:directiveContent "Distinguish between Voice (constant personality, values, 'We Are / We Are Not') and Tone (formality, energy, technical depth that flexes by context). Voice never changes; tone adapts." ;
    oc:hasRationale "Conflating voice and tone leads to inconsistent brand expression — some contexts need formal tone but the personality must remain intact." ;
    oc:severityLevel "HIGH" .

oc:kn_a9e614fb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When surfacing unresolved ambiguities in generated guidelines" ;
    oc:directiveContent "Never leave an open question as a dead end. Every open question must include an agent recommendation that turns ambiguity into 'confirm or override'." ;
    oc:hasRationale "Open questions without recommendations burden the user with open-ended decisions and reduce guideline usability." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c1c3c6b7 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When both a discovery report and raw sources are available" ;
    oc:directiveContent "When a discovery report is provided, use it as the primary input — sources are already triaged and ranked. Supplement with additional analysis only as needed rather than re-processing from scratch." ;
    oc:hasRationale "Discovery reports encode significant prior analysis effort; re-processing raw sources wastes compute and may introduce inconsistencies." ;
    oc:severityLevel "LOW" .

oc:kn_da542c90 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When saving generated guidelines to .claude/brand-voice-guidelines.md" ;
    oc:directiveContent "Before saving guidelines, confirm the user's working folder path. The agent's working directory may differ from the user's project root (especially in Cowork). If no working folder is set, skip file save and notify the user." ;
    oc:hasRationale "Saving to the wrong directory makes guidelines invisible to subsequent sessions and the enforce-voice skill." ;
    oc:severityLevel "HIGH" .

oc:kn_f029c920 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When processing source materials containing real conversations or customer data" ;
    oc:directiveContent "Redact customer names and contact information from all examples throughout the entire generation workflow, not only at output time. Anonymize company names in transcript excerpts if requested." ;
    oc:hasRationale "Brand guidelines derived from real sales calls or documents may contain PII that must not surface in the output artifact." ;
    oc:severityLevel "CRITICAL" .

