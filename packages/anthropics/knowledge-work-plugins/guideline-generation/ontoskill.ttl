                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**\"We Are / We Are Not\" Table** — The core brand identity anchor:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "**Voice Constants vs. Tone Flexes** — Clarify what stays fixed and what adapts:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "Derive attributes from the most consistent patterns across sources. Each row should have supporting evidence." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Merge all findings into a unified guideline document following the template in `references/guideline-template.md`. Key sections:" ],
