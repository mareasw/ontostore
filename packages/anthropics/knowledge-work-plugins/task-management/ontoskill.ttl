    oc:isUserInvocable false ;
    oc:nature "Tool" ;
    oc:requiresState oc:DirectoryWritable ;
    oc:resolvesIntent "add task",
        "complete task",
        "extract tasks from conversations",
        "manage commitments",
        "track waiting items",
        "view tasks" ;
    oc:yieldsState oc:TaskTracked .

oc:kn_03f20629 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When adding or formatting any task" ;
    oc:directiveContent "Bold the task title, include 'for [person]' for commitments, 'due [date]' for deadlines, and 'since [date]' for waiting items." ;
    oc:hasRationale "Scannability and accountability — bold titles make tasks visually distinct, metadata enables filtering and prioritization." .

oc:kn_195e4eda a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "On first interaction with tasks" ;
    oc:directiveContent "1. Check if TASKS.md exists → read it; if not → create from template with Active/Waiting On/Someday/Done sections. 2. Check if dashboard.html exists → if not, copy from plugin root. 3. Inform user about dashboard setup." ;
    oc:stepOrder 1 .

oc:kn_20e90c26 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating a new TASKS.md file" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """# Tasks

## Active

## Waiting On

## Someday

## Done""" .

oc:kn_3ca8a158 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During routine task file maintenance" ;
    oc:directiveContent "Keep the Done section for approximately 1 week, then clear old completed items." ;
    oc:hasRationale "Retaining recently completed items provides a sense of progress while preventing the file from growing indefinitely." .

oc:kn_4ff9336b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting tasks from conversations or summaries" ;
    oc:directiveContent "Never auto-add tasks without user confirmation, especially when extracting from meetings or conversations." ;
    oc:hasRationale "Auto-adding tasks without consent clutters the task list and may include items the user doesn't actually want to track." ;
    oc:severityLevel "HIGH" .

oc:kn_877032e4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when reading or writing tasks" ;
    oc:directiveContent "Always use TASKS.md in the current working directory — never use alternative filenames or paths." ;
    oc:hasRationale "Ensures single source of truth for both agent and user edits." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a818747e a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Current working directory must be writable to create TASKS.md and dashboard.html." .

oc:kn_cdb6bf7d a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When adding a new task to Active or Waiting On sections" ;
    oc:directiveContent """- [ ] **{Task title}** - {context}, for {person}, due {date}
  - {sub-bullet details}""" ;
    oc:templateVariables "Task title",
        "context",
        "date",
        "person",
        "sub-bullet details" .

oc:kn_cdfee3fb a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When user says they completed a task" ;
    oc:directiveContent "1. Find the task in TASKS.md. 2. Change `[ ]` to `[x]`. 3. Wrap title in strikethrough `~~task~~`. 4. Add completion date. 5. Move to Done section." ;
    oc:stepOrder 2 .

_:ref_58f249e2d22621d8 a oc:WorkflowStep ;
    dcterms:description "Inform the user: \"I've added the dashboard. Run `/productivity:start` to set up the full system.\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_731f1c204fd7b7e5 a oc:WorkflowStep ;
    dcterms:description "If not, copy it from `${CLAUDE_PLUGIN_ROOT}/skills/dashboard.html` to the current working directory" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_7bbdc1ca7b391a06 a oc:WorkflowStep ;
    dcterms:description "Check if `dashboard.html` exists in the current working directory" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_1c0cf3f8469c1af6 a oc:WorkflowStep ;
    dcterms:description "Change checkbox from [ ] to [x], wrap title in ~~strikethrough~~, add completion date." ;
    oc:expectedOutcome "Task line updated with completion formatting." ;
    oc:stepId "mark-complete" .

_:ref_577e0a1bbfe26a96 a oc:WorkflowStep ;
    dcterms:description "Check if dashboard.html exists in CWD; if not, copy from plugin root skills directory." ;
    oc:expectedOutcome "dashboard.html exists in current working directory." ;
    oc:stepDependsOn _:ref_89400ea009227494 ;
    oc:stepId "check-dashboard" .

_:ref_89400ea009227494 a oc:WorkflowStep ;
    dcterms:description "Check if TASKS.md exists in CWD; if not, create it with the standard 4-section template." ;
    oc:expectedOutcome "TASKS.md exists with Active, Waiting On, Someday, Done sections." ;
    oc:stepId "check-tasks-md" .

_:ref_968b5ad3d2471a70 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_58f249e2d22621d8,
        _:ref_731f1c204fd7b7e5,
        _:ref_7bbdc1ca7b391a06 ;
    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

