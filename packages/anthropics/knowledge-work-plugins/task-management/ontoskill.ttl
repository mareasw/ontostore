@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_task_management a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "task-management" ;
    skos:broader "task tracking system" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/task-management" ;
    oc:contentHash "a81f5b75358b800ecf9ac87e7fd64805ff966140e80ca783f90d9cbef1b3221e" ;
    oc:differentia "uses a shared Markdown file for lightweight task management with status sections and conventions" ;
    oc:extends oc:skill_start ;
    oc:handlesFailure oc:FileNotFound,
        oc:PermissionDenied ;
    oc:hasArgumentHint "task description or query about current tasks" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Simple task management using a shared TASKS.md file. Reference this when the user asks about their tasks, wants to add/complete tasks, or needs help tracking commitments." ;
    oc:hasName "task-management" ;
    oc:impartsKnowledge oc:kn_03f20629,
        oc:kn_5fbca571,
        oc:kn_9ae1ae38,
        oc:kn_9fc94be6,
        oc:kn_c8e42ca4,
        oc:kn_cac39cc2 ;
    oc:isUserInvocable false ;
    oc:nature "concept" ;
    oc:requiresState oc:DirectoryWritable ;
    oc:resolvesIntent "add tasks to a task list",
        "complete and mark tasks as done",
        "extract action items from conversations",
        "review what tasks are active or waiting",
        "track tasks and commitments" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_03f20629 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When adding or formatting any task entry" ;
    oc:directiveContent "Bold the task title, include 'for [person]' for commitments, 'due [date]' for deadlines, and 'since [date]' for waiting items." ;
    oc:hasRationale "Structured conventions make the task list scannable and surfaces critical metadata at a glance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5fbca571 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When summarizing meetings or conversations and identifying action items" ;
    oc:directiveContent "Never auto-add tasks extracted from conversations without user confirmation." ;
    oc:hasRationale "Auto-adding tasks without consent clutters the task list and may not reflect the user's actual priorities." ;
    oc:severityLevel "HIGH" .

oc:kn_9ae1ae38 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When TASKS.md does not exist and must be created" ;
    oc:directiveContent "Use the exact template with sections: Active, Waiting On, Someday, Done when creating a new TASKS.md." ;
    oc:hasRationale "A consistent structure enables reliable parsing and scannability across sessions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9fc94be6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading or writing tasks" ;
    oc:directiveContent "Always use TASKS.md in the current working directory — never use a custom path or different filename." ;
    oc:hasRationale "Ensures consistency so both the agent and user always find tasks in the same predictable location." ;
    oc:severityLevel "HIGH" .

oc:kn_c8e42ca4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During periodic task maintenance or when the Done section grows large" ;
    oc:directiveContent "Clear completed items from the Done section after approximately one week." ;
    oc:hasRationale "Keeps the file manageable while preserving recent history for reference." ;
    oc:severityLevel "LOW" .

oc:kn_cac39cc2 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When task management is first invoked in a new working directory" ;
    oc:directiveContent "On first interaction with tasks, check if dashboard.html exists locally; if not, copy it from the plugin skill directory and inform the user to run the full system setup." ;
    oc:hasRationale "Provides a visual task board interface that syncs with the same TASKS.md file, enhancing usability." ;
    oc:severityLevel "MEDIUM" .

