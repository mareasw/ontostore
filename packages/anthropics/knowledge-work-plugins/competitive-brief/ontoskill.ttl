@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_competitive_brief a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "competitive-brief" ;
    skos:broader "competitive analysis framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/competitive-brief" ;
    oc:contentHash "ab467ce890a01c6e2169aaca9af71c7e66c744326199d25ebd25406010d86d3d" ;
    oc:differentia "generates structured positioning and messaging comparisons with content gap analysis, threat assessment, and battlecard creation from multi-source competitor research" ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasAlias "competitive-analysis",
        "competitor-brief",
        "competitor-research",
        "market-comparison" ;
    oc:hasArgumentHint "<competitor or market segment>" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Research competitors and generate a positioning and messaging comparison with content gaps, opportunities, and threats. Use when building sales battlecards, when finding positioning gaps and messaging angles competitors haven't claimed, or when a competitor makes a move and you need to assess the impact." ;
    oc:hasName "competitive-brief" ;
    oc:hasRequirement oc:req_692b50d3,
        oc:req_dc55f4a0,
        oc:req_f206f19b ;
    oc:impartsKnowledge oc:kn_2d7cb5ad,
        oc:kn_2eb91cf6,
        oc:kn_7b6fa89f,
        oc:kn_8dfc26fa,
        oc:kn_9daa07f2,
        oc:kn_eae48726 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "analyze competitor content strategy and find content gaps",
        "assess competitive threats and opportunities from competitor moves",
        "generate competitive battlecards for sales teams",
        "identify positioning gaps and messaging angles competitors haven't claimed",
        "research competitors and compare positioning" ;
    oc:yieldsState oc:CompetitiveBriefGenerated,
        oc:CompetitorResearched,
        oc:ContentGapsIdentified .

oc:kn_2d7cb5ad a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing competitive brief generation" ;
    oc:directiveContent "Before starting research, confirm competitor names are provided (required) and ideally gather the user's own company context, positioning, and focus areas to enable meaningful comparison." ;
    oc:hasRationale "Without user company context, the brief can only describe competitors but cannot provide meaningful positioning comparisons or exploit gaps." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2eb91cf6 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing competitive brief generation" ;
    oc:directiveContent "Include the date of research in the output so users know data freshness, and offer follow-up actions: battlecard creation, gap-exploiting messaging, deeper competitor dive, or monitoring plan setup." ;
    oc:hasRationale "Competitive intelligence has a short shelf life; dating the research sets expectations and follow-up offers turn analysis into action." ;
    oc:severityLevel "LOW" .

oc:kn_7b6fa89f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing competitor messaging and positioning" ;
    oc:directiveContent "Use the Value Proposition Comparison framework (Promise, Evidence, Mechanism, Uniqueness) and Narrative Analysis (Villain, Hero, Transformation, Stakes) to systematically decompose each competitor's messaging strategy." ;
    oc:hasRationale "Structured frameworks ensure consistent, comparable analysis across competitors and prevent superficial or biased assessments." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8dfc26fa a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When conducting competitive research" ;
    oc:directiveContent "Follow a structured research process: gather from primary sources (competitor website, blog, social media, press releases, job postings) then secondary sources (G2, analyst reports, news coverage, community forums) for each competitor." ;
    oc:hasRationale "Primary sources reveal intended positioning; secondary sources reveal market perception and customer sentiment, providing a complete competitive picture." ;
    oc:severityLevel "HIGH" .

oc:kn_9daa07f2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When developing positioning strategy" ;
    oc:directiveContent "Avoid positioning pitfalls: don't position against a competitor instead of for a customer need, don't claim too many differentiators (pick 1-2), don't use category jargon customers don't use, don't position on features rather than outcomes, and don't change positioning too frequently." ;
    oc:hasRationale "These pitfalls confuse the market, dilute differentiation, and make messaging generic or inconsistent." ;
    oc:severityLevel "HIGH" .

oc:kn_eae48726 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When setting up ongoing competitive monitoring" ;
    oc:directiveContent "Maintain competitive intelligence with a structured cadence: deep analysis quarterly, monitoring monthly, and real-time alerts for competitor brand mentions, press, and job postings." ;
    oc:hasRationale "Competitive landscapes shift constantly; a cadenced approach ensures intelligence stays current without overwhelming the team." ;
    oc:severityLevel "MEDIUM" .

oc:req_692b50d3 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "understanding of positioning and messaging frameworks" .

oc:req_dc55f4a0 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "familiarity with competitive analysis methodologies" .

oc:req_f206f19b a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "web search" .

