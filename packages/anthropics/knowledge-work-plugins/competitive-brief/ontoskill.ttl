oc:skill_knowledge_work_plugins_competitive_brief a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "competitive-brief" ;
    skos:broader "Competitive analysis framework" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/competitive-brief" ;
    oc:contentHash "ab467ce890a01c6e2169aaca9af71c7e66c744326199d25ebd25406010d86d3d" ;
    oc:differentia "Produces structured positioning and messaging comparison with content gaps, opportunities, threats, and battlecard-ready intelligence from web research" ;
    oc:extends oc:skill_ontoskills_competitive_analysis ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasAllowedTool "Edit",
        "Read",
        "Write",
        "web-search" ;
    oc:hasArgumentHint "<competitor or market segment>" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Research competitors and generate a positioning and messaging comparison with content gaps, opportunities, and threats. Use when building sales battlecards, when finding positioning gaps and messaging angles competitors haven't claimed, or when a competitor makes a move and you need to assess the impact." ;
    oc:hasName "competitive-brief" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Research competitors and generate a structured competitive analysis comparing positioning, messaging, content strategy, and market presence." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "\"Would you like me to:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Create a battlecard for your sales team based on this analysis?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Set up a competitive monitoring plan?\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Draft messaging that exploits the positioning gaps identified?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Dive deeper into any specific competitor?" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "After the brief, ask:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Present the full competitive brief with clear formatting. Note the date of the research so the user knows the freshness of the data." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 50 ;
                    oc:sectionTitle "Output" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_242f15609a9f3d1f,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "For each competitor, research using web search:" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Competitive monitoring**: monthly (scan for new announcements, content, messaging changes)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Real-time alerts**: ongoing (set up alerts for competitor brand mentions, press, job postings)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Deep competitive analysis**: quarterly (full research across all sources)" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 8 ;
                            oc:sectionTitle "Research Cadence" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Gather intelligence from these categories of sources:" ] ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "**Product demos and free trials**: UX, features, onboarding experience" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 6 ;
                                                    oc:itemText "**Press releases and newsroom**: announcements, partnerships, milestones" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "**Webinars and events**: topics, speakers, audience engagement" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Website**: homepage, product pages, pricing, about page, careers" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "**Social media profiles**: messaging, engagement, content strategy" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Blog and resource center**: content themes, publishing frequency, depth" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 7 ;
                                                    oc:itemText "**Job postings**: hiring signals that reveal strategic priorities (e.g., hiring for a new product line or market)" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 6 ;
                                    oc:sectionTitle "Primary Sources (Direct from Competitor)" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 6 ;
                                                    oc:itemText "**Financial filings**: revenue, growth rate, investment areas (for public companies)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "**News coverage**: TechCrunch, industry publications — funding, partnerships, narrative" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Analyst reports**: Gartner, Forrester, IDC — market positioning and category placement" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "**SEO tools**: keyword rankings, organic traffic estimates, content gaps" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 7 ;
                                                    oc:itemText "**Community forums**: community forums (e.g. Reddit, Discourse), industry chat groups (e.g. Slack communities) — user sentiment" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Review sites**: G2, Capterra, TrustRadius, Product Hunt — customer sentiment themes" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "**Social listening**: mentions, sentiment, share of voice across social platforms" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 7 ;
                                    oc:sectionTitle "Secondary Sources (Third-Party)" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Research Sources" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Research Process" ],
