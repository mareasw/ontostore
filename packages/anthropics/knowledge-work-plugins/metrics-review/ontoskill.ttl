@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_metrics_review a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "metrics-review" ;
    skos:broader "product analytics framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/metrics-review" ;
    oc:contentHash "d372163eb0685e2cb75982849fe4561c753307fbd8d6448c319f669f480d6b55" ;
    oc:differentia "structures metric data into hierarchical scorecards with trend analysis, goal comparison, and actionable recommendations across configurable time cadences" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<time period or metric focus>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Review and analyze product metrics with trend analysis and actionable insights. Use when running a weekly, monthly, or quarterly metrics review, investigating a sudden spike or drop, comparing performance against targets, or turning raw numbers into a scorecard with recommended actions." ;
    oc:hasName "metrics-review" ;
    oc:impartsKnowledge oc:kn_104ad91a,
        oc:kn_2b0e979c,
        oc:kn_2c0e7909,
        oc:kn_4761d933,
        oc:kn_6cabb815,
        oc:kn_6d748027,
        oc:kn_7ffb989d,
        oc:kn_b97f5a35,
        oc:kn_c9d1ba1a,
        oc:kn_cc689ea7 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "analyze metric trends",
        "compare performance against targets",
        "generate metrics scorecard",
        "investigate metric spikes or drops",
        "review product metrics",
        "run weekly monthly or quarterly metrics review" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_104ad91a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When beginning a metrics review session" ;
    oc:directiveContent "Before starting the review, confirm: time period to analyze, which metrics to focus on, any specific targets to compare against, and known events that might explain changes (launches, outages, seasonality)." ;
    oc:hasRationale "Missing context at the start leads to incomplete or misleading analysis; gathering these inputs ensures the review is scoped correctly and avoids false conclusions." ;
    oc:severityLevel "HIGH" .

oc:kn_2b0e979c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing any product metrics review" ;
    oc:directiveContent "Structure metrics using a hierarchy: North Star metric at the top, L1 health indicators (acquisition, activation, engagement, retention, monetization, satisfaction), and L2 diagnostic metrics for drill-down." ;
    oc:hasRationale "A clear hierarchy ensures the review tells a coherent story from high-level health to specific diagnostic details, rather than presenting an overwhelming list of numbers." ;
    oc:severityLevel "HIGH" .

oc:kn_2c0e7909 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When completing a metrics review output" ;
    oc:directiveContent "Every metrics review must lead to at least one recommended action. If the review does not drive a decision, it was not useful." ;
    oc:hasRationale "Metrics reviews are only valuable when they change behavior; a review that merely reports numbers without recommendations is wasted effort." ;
    oc:severityLevel "HIGH" .

oc:kn_4761d933 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any metric scorecard or trend analysis" ;
    oc:directiveContent "Never present raw numbers without context — always show comparisons (vs previous period, vs target, vs benchmark) alongside current values." ;
    oc:hasRationale "Absolute numbers without context are meaningless; a metric value only becomes meaningful when compared to a baseline, target, or trend." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6cabb815 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When analyzing trends that appear flat or unremarkable at the aggregate level" ;
    oc:directiveContent "Segment analysis often reveals that an aggregate metric masks important differences. Always check whether a flat or changing aggregate is driven by specific cohorts." ;
    oc:hasRationale "Aggregates can hide one segment growing while another shrinks, leading to missed opportunities or unseen risks." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6d748027 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When helping users set metric targets or OKRs" ;
    oc:directiveContent "Set OKRs that are ambitious but achievable — 70% completion is the target for stretch OKRs. If you are confident you will hit all of them, they are not ambitious enough." ;
    oc:hasRationale "Comfortable goals do not drive growth; stretch goals that achieve 70% completion balance ambition with realism." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7ffb989d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting metrics for scorecards and dashboards" ;
    oc:directiveContent "Avoid vanity metrics (total signups ever, total page views), output metrics (tickets closed, PRs merged), and dashboards with more than 10 metrics." ;
    oc:hasRationale "Vanity metrics always go up but do not indicate health; output metrics measure team activity not outcomes; too many metrics dilute focus and prevent quick decision-making." ;
    oc:severityLevel "HIGH" .

oc:kn_b97f5a35 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring metric monitoring alerts" ;
    oc:directiveContent "Do not set up alerts for metrics that have no clear owner or no actionable response. Every alert should be actionable and have a defined severity level." ;
    oc:hasRationale "Too many non-actionable alerts leads to alert fatigue where all alerts are ignored, including genuine critical ones." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c9d1ba1a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing why a metric changed" ;
    oc:directiveContent "Be careful about attribution — correlation is not causation. If a metric moved, acknowledge uncertainty about why and recommend further investigation rather than asserting a cause." ;
    oc:hasRationale "False attribution leads to incorrect strategic decisions; honest uncertainty preserves credibility and drives better follow-up investigation." ;
    oc:severityLevel "HIGH" .

oc:kn_cc689ea7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the review summary section" ;
    oc:directiveContent "Start with the 'so what' — lead with the most important finding in the review summary so the reader gets the essential story in 30 seconds." ;
    oc:hasRationale "Decision-makers scan reviews quickly; burying the key insight reduces the likelihood that it drives action." ;
    oc:severityLevel "MEDIUM" .

