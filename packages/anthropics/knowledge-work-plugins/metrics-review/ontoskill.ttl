oc:kn_11a2f9b3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing dashboards or selecting metrics for review" ;
    oc:directiveContent "Avoid vanity metrics (total signups ever, total page views), dashboards with too many metrics, measuring team output (tickets closed) instead of user/business outcomes, and one-size-fits-all dashboards." ;
    oc:hasRationale "Vanity metrics create false confidence; cluttered dashboards obscure signal; output metrics misdirect focus from user value." ;
    oc:severityLevel "MEDIUM" .

oc:kn_310e9f60 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing any metrics review" ;
    oc:directiveContent "Structure metrics using a hierarchy: North Star metric at top, L1 health indicators (acquisition, activation, engagement, retention, monetization, satisfaction) in the middle, L2 diagnostic metrics for drill-down." ;
    oc:hasRationale "A clear hierarchy ensures the review tells a coherent story and connects diagnostic details to overall product health." .

oc:kn_3209c35f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating scorecards or trend analysis" ;
    oc:directiveContent "Never present raw metric values without context — always show comparisons (vs previous period, vs target, vs benchmark) and trend direction." ;
    oc:hasRationale "Absolute numbers without context are meaningless; comparison is what turns data into insight." ;
    oc:severityLevel "HIGH" .

oc:kn_6ea59527 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing a metrics review" ;
    oc:directiveContent "1. Gather metrics data from analytics tools or user-provided data. 2. Organize metrics using North Star / L1 / L2 hierarchy. 3. Analyze trends (current value, trend direction, vs target, rate of change, anomalies, correlations). 4. Generate review with summary, scorecard, trend analysis, bright spots, concerns, recommended actions, and caveats. 5. Follow up with offers for deeper investigation, dashboard specs, or experiment proposals." ;
    oc:stepOrder 1 .

oc:kn_9873cf2b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When investigating trends or anomalies" ;
    oc:directiveContent "Segment analysis often reveals that an aggregate metric masks important differences — a flat overall number may hide one segment growing while another shrinks." ;
    oc:hasRationale "Aggregate metrics can be misleading; segment breakdowns surface the real dynamics driving change." .

oc:kn_b1a0a1fc a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating the metrics review output" ;
    oc:directiveContent """## Summary (2-3 sentences)

## Metric Scorecard
| Metric | Current | Previous | Change | Target | Status |
|--------|---------|----------|--------|--------|--------|
| {metric} | {value} | {value} | {change_pct} | {target} | {On track/At risk/Miss} |

## Trend Analysis (per metric: what happened, why, sustained or one-time)
## Bright Spots (metrics beating targets, positive trends)
## Areas of Concern (misses, early warnings, visibility gaps)
## Recommended Actions (investigations, experiments, investments, alerts)
## Context and Caveats (data quality, comparability issues, missing metrics)""" ;
    oc:templateVariables "On track/At risk/Miss",
        "change_pct",
        "metric",
        "target",
        "value" .

oc:kn_b29f2ec7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the review output" ;
    oc:directiveContent "Lead with the 'so what' — the most important finding should be the first thing the reader sees. Keep the summary to 2-3 sentences." ;
    oc:hasRationale "Metrics reviews are only useful if they drive decisions. The essential story should be absorbable in 30 seconds." .

oc:kn_b7a286a6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing dashboards or selecting metrics" ;
    oc:directiveContent "Every metric on a dashboard should be actionable. If the team cannot influence it, it does not belong on the product dashboard. Focus on 5-10 metrics that matter." ;
    oc:hasRationale "Actionability ensures the review drives real decisions rather than passive observation." .

oc:kn_ce13d6d3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When setting metric targets or OKRs" ;
    oc:directiveContent "For metric targets, establish baseline, benchmark against comparable products, account for current trajectory, factor in investment level, and set both commit (high confidence) and stretch (ambitious) targets." ;
    oc:hasRationale "Well-calibrated targets grounded in data and context are more useful and credible than arbitrary goals." .

oc:kn_e11a9361 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing trends and attributing causes to metric changes" ;
    oc:directiveContent "Be careful about attribution — correlation is not causation. If a metric moved, acknowledge uncertainty about why rather than asserting a cause." ;
    oc:hasRationale "False attribution leads to wrong decisions and erodes trust in the metrics review process." ;
    oc:severityLevel "HIGH" .

_:ref_00313920e6b1dca9 a oc:WorkflowStep ;
    dcterms:description "**Context over numbers**. A number without context is meaningless. Always show: current value, comparison (previous period, target, benchmark), trend direction." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_100c43b0d1e0e0dc a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 2 ;
            oc:itemText "Yellow: needs attention or flat" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 1 ;
            oc:itemText "Green: on track or improving" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 3 ;
            oc:itemText "Red: off track or declining" ] .

_:ref_1cbdb840d3e6bb2f a oc:WorkflowStep ;
    dcterms:description "**Consistent time periods**. Use the same time period for all metrics on a dashboard. Mixing daily and monthly metrics creates confusion." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_3890adb99d05e9b1 a oc:WorkflowStep ;
    dcterms:description "**Hierarchy of information**. The most important metric should be the most visually prominent. North Star at the top, L1 metrics next, L2 metrics available on drill-down." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_682e06dbfa5b29da a oc:WorkflowStep ;
    dcterms:description "**Visual status indicators**. Use color to indicate health at a glance:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild _:ref_100c43b0d1e0e0dc ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_70429b7e25d732c9 a oc:WorkflowStep ;
    dcterms:description "**Start with the question, not the data**. What decisions does this dashboard support? Design backwards from the decision." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_78419da3fa230d96 a oc:WorkflowStep ;
    dcterms:description "**Fewer metrics, more insight**. A dashboard with 50 metrics helps no one. Focus on 5-10 that matter. Put everything else in a detailed report." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_f386017c435e3ea8 a oc:WorkflowStep ;
    dcterms:description "**Actionability**. Every metric on the dashboard should be something the team can influence. If you cannot act on it, it does not belong on the product dashboard." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_7" ;
    oc:stepOrder 7 .

_:ref_4c65082838703e90 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 3 ;
    oc:hasStep _:ref_00313920e6b1dca9,
