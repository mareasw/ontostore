@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_slack_messaging a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "slack-messaging" ;
    skos:broader "formatting and communication guidance" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/slack-messaging" ;
    oc:contentHash "d5e21527d96020c0e00d90a6b29b6e2c349d271dea6143f18bdb83653f6edefb" ;
    oc:differentia "that uses Slack's mrkdwn syntax instead of standard Markdown for composing effective messages" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "message content or description of what to communicate" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Guidance for composing well-formatted, effective Slack messages using mrkdwn syntax" ;
    oc:hasName "slack-messaging" ;
    oc:impartsKnowledge oc:kn_2744ebb4,
        oc:kn_46f9afad,
        oc:kn_56a8afbf,
        oc:kn_86af1cb4,
        oc:kn_9f6a6bb0 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "compose slack messages",
        "draft slack announcements",
        "format slack messages with mrkdwn",
        "write effective slack messages" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_2744ebb4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the message content exceeds 3 paragraphs" ;
    oc:directiveContent "Keep messages to 1-3 short paragraphs. If the content is longer, suggest using a Canvas instead of a direct message." ;
    oc:hasRationale "Walls of text are hard to read in Slack's narrow message width; Canvas provides better formatting for longer content." ;
    oc:severityLevel "MEDIUM" .

oc:kn_46f9afad a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing any Slack message" ;
    oc:directiveContent "Never use standard Markdown syntax (double asterisks for bold, hash headers, bracket-parenthesis links, horizontal rules) in Slack messages — Slack uses its own mrkdwn format." ;
    oc:hasRationale "Standard Markdown will render as raw text or incorrect formatting in Slack, making messages look broken and unprofessional." ;
    oc:severityLevel "CRITICAL" .

oc:kn_56a8afbf a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When deciding whether to post in a thread or the main channel" ;
    oc:directiveContent "Reply in threads when responding to a specific message to keep the main channel clean. Only use reply_broadcast when everyone needs to see the reply." ;
    oc:hasRationale "Threaded replies prevent channel noise and help maintain organized conversations; broadcasting every reply clutters the channel." ;
    oc:severityLevel "MEDIUM" .

oc:kn_86af1cb4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting message content for scannability" ;
    oc:directiveContent "Use *bold* for names, dates, deadlines, and action items; use bullet points for any list of 3+ items; separate distinct thoughts with blank lines." ;
    oc:hasRationale "Slack messages are often scanned quickly; visual emphasis on key information ensures critical details aren't missed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9f6a6bb0 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When structuring any Slack message" ;
    oc:directiveContent "Always lead with the most important information in the first line, as many users read Slack on mobile or in notifications where only the first line is visible." ;
    oc:hasRationale "Slack notifications and mobile previews only show the first line; burying key info reduces readability and response rates." ;
    oc:severityLevel "HIGH" .

