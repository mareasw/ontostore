@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_knowledge_work_plugins_slack_messaging a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "slack-messaging" ;
    skos:broader "Formatting guide" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/slack-messaging" ;
    oc:contentHash "d5e21527d96020c0e00d90a6b29b6e2c349d271dea6143f18bdb83653f6edefb" ;
    oc:differentia "that provides mrkdwn syntax rules and messaging conventions for composing effective Slack messages" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Guidance for composing well-formatted, effective Slack messages using mrkdwn syntax" ;
    oc:hasName "slack-messaging" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "This skill provides guidance for composing well-formatted, effective Slack messages." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Use line breaks generously.** Walls of text are hard to read. Separate distinct thoughts with blank lines." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Bold key information.** Use `*bold*` for names, dates, deadlines, and action items so they stand out when scanning." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Use bullet points for lists.** Anything with 3+ items should be a list, not a run-on sentence." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Keep it short.** Aim for 1-3 short paragraphs. If the message is long, consider using a Canvas instead." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Lead with the point.** Put the most important information in the first line. Many people read Slack on mobile or in notifications where only the first line shows." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Message Structure Guidelines" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Match the tone to the channel — `#general` is usually more formal than `#random`." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "When writing announcements, use a clear structure: context, key info, call to action." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Use emoji reactions instead of reply messages for simple acknowledgments (though note: the MCP tools can't add reactions, so suggest the user do this manually if appropriate)." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Tone and Audience" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 11 ;
                            oc:tableCaption "Slack uses its own markup syntax called **mrkdwn**, which differs from standard Markdown. Always use mrkdwn when composing Slack messages" ;
                            oc:tableMarkdown """| Format | Syntax | Notes |
|--------|--------|-------|
| Bold | `*text*` | Single asterisks, NOT double |
| Italic | `_text_` | Underscores |
| Strikethrough | `~text~` | Tildes |
| Code (inline) | `` `code` `` | Backticks |
| Code block | `` ```code``` `` | Triple backticks |
| Quote | `> text` | Angle bracket |
| Link | `<url\\|display text>` | Pipe-separated in angle brackets |
| User mention | `<@U123456>` | User ID in angle brackets |
| Channel mention | `<#C123456>` | Channel ID in angle brackets |
| Bulleted list | `- item` or `• item` | Dash or bullet character |
| Numbered list | `1. item` | Number followed by period |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Slack uses its own markup syntax called **mrkdwn**, which differs from standard Markdown. Always use mrkdwn when composing Slack messages:" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Do NOT use `## headers` — Slack does not support Markdown headers. Use `*bold text*` on its own line instead." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Do NOT use `**bold**` (double asterisks) — Slack uses `*bold*` (single asterisks)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Do NOT use `---` for horizontal rules — Slack does not render these" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Do NOT use `[text](url)` for links — Slack uses `<url|text>` format" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Common Mistakes to Avoid" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Slack Formatting (mrkdwn)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Don't start a new thread** to continue an existing conversation — find and reply to the original message." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Post in the channel** (not a thread) when starting a new topic, making an announcement, or asking a question to the whole group." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Use `reply_broadcast`** (also post to channel) only when the reply contains information everyone needs to see." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Reply in threads** when responding to a specific message to keep the main channel clean." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Thread vs. Channel Etiquette" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Apply this skill whenever composing, drafting, or helping the user write a Slack message — including when using `slack_send_message`, `slack_send_message_draft`, or `slack_create_canvas`." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "When to Use" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Slack Messaging Best Practices" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: slack-messaging
description: Guidance for composing well-formatted, effective Slack messages using mrkdwn syntax
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:impartsKnowledge oc:kn_1f6598e0,
        oc:kn_30ae8e3b,
        oc:kn_c37c9f63,
        oc:kn_c92f78d0,
        oc:kn_f8585a18 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "compose slack message",
        "draft slack message",
        "format slack message",
        "write slack announcement" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_1f6598e0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when composing any Slack message" ;
    oc:directiveContent "Do NOT use standard Markdown syntax in Slack messages: no **bold** (use *bold*), no ## headers (use *bold text* on its own line), no [text](url) links (use <url|text>), no --- horizontal rules." ;
    oc:hasRationale "Slack uses mrkdwn, not standard Markdown. Using standard Markdown syntax results in unformatted or broken messages." ;
    oc:severityLevel "CRITICAL" .

oc:kn_30ae8e3b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When composing any Slack message" ;
    oc:directiveContent "Lead with the point — put the most important information in the first line, as many people read Slack on mobile or in notifications where only the first line is visible." ;
    oc:hasRationale "Mobile and notification views truncate messages after the first line, burying critical information." ;
    oc:severityLevel "HIGH" .

oc:kn_c37c9f63 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing Slack messages" ;
    oc:directiveContent "Keep messages to 1-3 short paragraphs. If longer, use a Canvas instead. Separate distinct thoughts with blank lines and use bullet points for 3+ items." ;
    oc:hasRationale "Walls of text are hard to read in Slack's chat interface; brevity and whitespace improve scannability." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c92f78d0 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When deciding where to post a Slack message" ;
    oc:directiveContent "Reply in threads for specific responses; post in channel for new topics, announcements, or group questions; use reply_broadcast only when everyone needs to see the reply." ;
    oc:hasRationale "Proper threading keeps channels clean and reduces noise for all members." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f8585a18 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting message tone and structure" ;
    oc:directiveContent "Match tone to the channel (more formal in #general, casual in #random). Use emoji reactions for simple acknowledgments. Structure announcements as: context, key info, call to action." ;
    oc:hasRationale "Tone-matching and clear structure increase message effectiveness and reduce miscommunication." ;
    oc:severityLevel "LOW" .

