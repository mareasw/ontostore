@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_contact_research_contact_signals_guide a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "contact-signals-guide" ;
    skos:broader "Reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/contact-research" ;
    oc:contentHash "ab364d6f20c2e90f8caf2ea6911a5a92a34f3a1bd145ff1d9bf2cd763deae5c9" ;
    oc:dependsOnSkill oc:skill_contact_research ;
    oc:differentia "that maps contact activity signals to interpretations, persona classifications, and conversation strategies for sales and customer engagement" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_contact_research ;
    oc:handlesFailure oc:ContactNotFound,
        oc:InsufficientData ;
    oc:hasArgumentHint "contact_name or signal_type" ;
    oc:hasCategory "research" ;
    oc:impartsKnowledge oc:kn_11e938bd,
        oc:kn_a148837d,
        oc:kn_cdbcfc0c,
        oc:kn_eaed76e2,
        oc:kn_f796f785 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "assess relationship health from activity patterns",
        "classify contact personas",
        "craft conversation starters based on signals",
        "interpret contact signals" ;
    oc:yieldsState oc:ContactSignalsInterpreted,
        oc:PersonaClassified .

oc:kn_11e938bd a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When reviewing any contact's activity history" ;
    oc:directiveContent "Interpret activity signals by type: email replies indicate higher intent than opens, community posts signal high engagement, support tickets indicate friction and empathy opportunities, and product logins indicate active usage." ;
    oc:hasRationale "Signal type determines the appropriate follow-up tone and urgency — a support ticket requires empathy while a community post is a proactive engagement opening" ;
    oc:severityLevel "HIGH" .

oc:kn_a148837d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When professional change signals are detected for a contact" ;
    oc:directiveContent "Job change signals create warm intro opportunities at the new company and relationship risk at the old one; promotions increase a contact's strategic value; title changes to decision-maker roles should trigger a relationship strategy upgrade." ;
    oc:hasRationale "Professional transitions are among the highest-value engagement windows in sales and customer success" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cdbcfc0c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any outreach to a contact based on their signals" ;
    oc:directiveContent "Effective conversation starters must reference something specific, show homework, open a door without forcing one, and connect to value for the contact." ;
    oc:hasRationale "Generic outreach gets ignored; signal-specific messages demonstrate relevance and dramatically increase response rates" ;
    oc:severityLevel "MEDIUM" .

oc:kn_eaed76e2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing contact activity timelines" ;
    oc:directiveContent "Do not ignore relationship cooling signals — no activity in 30+ days means the relationship is cooling and a gentle check-in is needed; 90+ days means dormant and requires a different re-engagement angle." ;
    oc:hasRationale "Letting relationships go dormant without intervention leads to churn and lost expansion opportunities" ;
    oc:severityLevel "HIGH" .

oc:kn_f796f785 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing a contact's role and behavior pattern" ;
    oc:directiveContent "Classify contacts into one of five Spark personas — Champion, Economic Buyer, Technical Evaluator, End User, or Gatekeeper — to tailor engagement strategy appropriately." ;
    oc:hasRationale "Persona classification determines the right messaging, timing, and escalation path for engagement" ;
    oc:severityLevel "MEDIUM" .

