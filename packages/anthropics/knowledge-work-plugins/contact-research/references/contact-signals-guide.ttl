@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_knowledge_work_plugins_contact_research_contact_signals_guide a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "contact-signals-guide" ;
    skos:broader "Reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/contact-research" ;
    oc:contentHash "ab364d6f20c2e90f8caf2ea6911a5a92a34f3a1bd145ff1d9bf2cd763deae5c9" ;
    oc:differentia "interprets contact activity, relationship, and professional signals to classify personas and guide engagement strategies" ;
    oc:extends oc:skill_knowledge_work_plugins_contact_research ;
    oc:hasCategory "research" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "*Champion* — daily user, advocates internally" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "*End User* — primary product user, influences renewal through NPS/feedback" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "*Economic Buyer* — holds budget authority, may not use product directly" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "*Technical Evaluator* — evaluates fit and integration, influences technical decisions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "*Gatekeeper* — controls access, must be navigated carefully" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Spark Persona Classification" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 7 ;
                                    oc:tableCaption "### Activity Signals" ;
                                    oc:tableMarkdown """| Signal | Interpretation |
|--------|---------------|
| Email open / reply | Actively aware of your org; replied = higher intent |
| Meeting attended | Relationship established; note meeting type (demo, QBR, etc.) |
| Community post or reply | Has a question, problem, or idea — high engagement signal |
| Support ticket opened | Experiencing friction — empathy opportunity |
| Documentation page visited | Researching a specific area — note which pages |
| Product login | Active user — check frequency and recency |
| Event registered/attended | Strong engagement and intent signal |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Activity Signals" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Job / Professional Signals" ;
                                    oc:tableMarkdown """| Signal | Interpretation |
|--------|---------------|
| Recent job change (new company) | Warm intro opportunity at new company; relationship may shift at old one |
| Promotion at same company | Growing influence — relationship becomes more valuable |
| Title change to decision-maker role | Upgrade the relationship strategy |
| Company expansion (new hires in their team) | Budget may be available; expansion opportunity |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Job / Professional Signals" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Relationship Signals" ;
                                    oc:tableMarkdown """| Signal | Interpretation |
|--------|---------------|
| No activity in 30+ days | Relationship cooling — gentle check-in appropriate |
| No activity in 90+ days | Dormant — may need re-engagement from a different angle |
| Consistent activity across multiple channels | Champion or highly engaged user — high-value contact |
| Activity spike after dormancy | Something changed — investigate why |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Relationship Signals" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Contact Signal Types" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "A strong starter references something specific, shows homework, opens a door without forcing one, and connects to value." ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\"I saw your question in the community about [topic] — we just released a feature that addresses exactly that. Would it be useful to walk through it?\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\"Your team's usage of [feature] jumped last month — curious if you're running into [common blocker] at that stage.\"" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Conversation Starters" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Contact Signals — Interpretation Guide" ] ;
    oc:impartsKnowledge oc:kn_07d930cd,
        oc:kn_0bcb0783,
        oc:kn_129a3b62,
        oc:kn_13f1c2b7,
        oc:kn_414d5af3,
        oc:kn_f704593d ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "assess relationship health",
        "classify contact persona",
        "generate conversation starters from signals",
        "interpret contact signals" .

oc:kn_07d930cd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating which contacts to engage first" ;
    oc:directiveContent "Prioritize signals by intent strength: replies and community posts indicate higher intent than passive views; meeting attendance and event registration signal strongest engagement." ;
    oc:hasRationale "Not all signals carry equal weight — focusing on high-intent signals yields better outreach outcomes" .

oc:kn_0bcb0783 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When drafting outreach based on contact signals" ;
    oc:directiveContent "Craft conversation starters that reference something specific, show homework done, open a door without forcing one, and connect to value." ;
    oc:hasRationale "Generic outreach gets ignored; signal-specific starters demonstrate attentiveness and increase response rates" .

oc:kn_129a3b62 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When detecting activity spike after dormancy" ;
    oc:directiveContent "Investigate the cause when a dormant contact shows a sudden activity spike — something in their environment changed and represents an opportunity." ;
    oc:hasRationale "Dormancy-breaking spikes often correlate with triggering events (new project, budget cycle, competitor dissatisfaction)" .

oc:kn_13f1c2b7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building outreach or account strategy" ;
    oc:directiveContent "Classify contacts into Champion, Economic Buyer, Technical Evaluator, End User, or Gatekeeper personas to tailor engagement strategy appropriately." ;
    oc:hasRationale "Different personas require different relationship approaches — a champion needs empowerment while an economic buyer needs ROI evidence" .

oc:kn_414d5af3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing contact activity" ;
    oc:directiveContent "Do not ignore support tickets as signals — they indicate friction and are empathy opportunities, not negative signals to avoid." ;
    oc:hasRationale "Support tickets reveal active problems that outreach can solve, converting frustration into loyalty" .

oc:kn_f704593d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When assessing relationship health" ;
    oc:directiveContent "Use signal timing thresholds: 30+ days without activity means relationship is cooling (gentle check-in); 90+ days means dormant (re-engage from a different angle)." ;
    oc:hasRationale "Recency of engagement is the strongest predictor of receptiveness to outreach" .

