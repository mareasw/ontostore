@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_contact_research a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "contact-research" ;
    skos:broader "contact research agent" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/contact-research" ;
    oc:contentHash "1ed230d51e5193da8ebab5549dc2d17a8e3a3fd40a7d56e0641da9613dd78af5" ;
    oc:differentia "that retrieves and synthesizes enriched contact profiles from Common Room using multi-method lookup, Spark enrichment, and account context to surface actionable conversation angles" ;
    oc:handlesFailure oc:AmbiguousMatch,
        oc:ContactNotFound,
        oc:PermissionDenied ;
    oc:hasAllowedTool "Common Room" ;
    oc:hasArgumentHint "contact identifier (email, social handle, or name + company)" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Research a specific person using Common Room data. Triggers on 'who is [name]', 'look up [email]', 'research [contact]', 'is [name] a warm lead', or any contact-level question." ;
    oc:hasName "contact-research" ;
    oc:impartsKnowledge oc:kn_0843cec7,
        oc:kn_1eb9c4f2,
        oc:kn_606c3dc4,
        oc:kn_aab97bc9,
        oc:kn_ee67e988,
        oc:kn_f2a4c468 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:APIKeySet,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "assess lead warmth and persona classification",
        "find conversation starters for outreach",
        "get account context for a contact's company",
        "look up a person's profile and engagement history",
        "research a contact by name, email, or social handle" ;
    oc:yieldsState oc:ContactProfileRetrieved .

oc:kn_0843cec7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When contact lookup returns no results" ;
    oc:directiveContent "If no match is found in Common Room, respond that no record exists. Do not speculate or fabricate profile data." ;
    oc:hasRationale "Fabricating contact data violates data integrity and can lead to misguided sales actions based on false information" ;
    oc:severityLevel "CRITICAL" .

oc:kn_1eb9c4f2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When Spark data is null or missing for a contact" ;
    oc:directiveContent "Never fabricate persona classifications from title alone — if Spark is unavailable and no activity data exists, classify persona as Unknown." ;
    oc:hasRationale "Guessing personas from job titles without behavioral signals leads to inaccurate outreach strategies and damaged credibility" ;
    oc:severityLevel "CRITICAL" .

oc:kn_606c3dc4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a lookup method based on user-provided input" ;
    oc:directiveContent "Use email lookup as the primary method when available — it is the most reliable identifier. For name-only lookups, present multiple matches and ask the user to confirm rather than guessing." ;
    oc:hasRationale "Email is a unique identifier; names alone produce ambiguous results that require disambiguation to avoid researching the wrong person" ;
    oc:severityLevel "HIGH" .

oc:kn_aab97bc9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting the output profile for any contact" ;
    oc:directiveContent "Omit sections with no data rather than filling them with guesses. For sparse data profiles, present only returned fields and offer web search as an alternative." ;
    oc:hasRationale "Honest sparse output maintains trust; padding with fabricated content undermines decision-making and violates data integrity" ;
    oc:severityLevel "HIGH" .

oc:kn_ee67e988 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When presenting contact scores and activity data" ;
    oc:directiveContent "Always return scores as raw values or percentiles, never as labels. Use Contact Initiated activity (last 60 days) as the primary engagement signal." ;
    oc:hasRationale "Raw values and percentiles preserve precision and allow recipients to draw their own conclusions; labels obscure the underlying data. Contact Initiated actions represent genuine engagement vs. passive or team-driven signals" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f2a4c468 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building a comprehensive contact profile or assessing engagement freshness" ;
    oc:directiveContent "Retrieve all Sparks (not just the most recent) when tracking engagement evolution over time. Flag any contact where the most recent activity is older than 30 days." ;
    oc:hasRationale "Spark history reveals engagement trajectory; recency flags help prioritize outreach to contacts whose interest may be cooling" ;
    oc:severityLevel "MEDIUM" .

