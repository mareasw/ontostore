    oc:stepOrder 2 .

_:ref_460d07f87f099d4c a oc:WorkflowStep ;
    dcterms:description "**Deal context**: Any relevant business context? (e.g., deal size, strategic importance, existing relationship)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_4f0d82d739ffe5a1 a oc:WorkflowStep ;
    dcterms:description "**Be balanced**: Propose language that is firm on critical points but commercially reasonable. Overly aggressive redlines slow negotiations." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_59ee8f4b18b1b5bc a oc:WorkflowStep ;
    dcterms:description "**Provide fallback positions**: For YELLOW items, include a fallback position if the primary ask is rejected." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_6147cde510f463c5 a oc:WorkflowStep ;
    dcterms:description "**Explain the rationale**: Include a brief, professional rationale suitable for sharing with the counterparty's counsel." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_8bffd4cf226dd42f a oc:WorkflowStep ;
    dcterms:description "**Be specific**: Provide exact language, not vague guidance. The redline should be ready to insert." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_b8ba40800b3267ce a oc:WorkflowStep ;
    dcterms:description "**Which side are you on?** (vendor/supplier, customer/buyer, licensor, licensee, partner -- or other)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_bc3e20e7a1cf4086 a oc:WorkflowStep ;
    dcterms:description "**Consider the relationship**: Adjust tone and approach based on whether this is a new vendor, strategic partner, or commodity supplier." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_bed73706973a803b a oc:WorkflowStep ;
    dcterms:description "**Read the entire contract** before flagging issues. Clauses interact with each other (e.g., an uncapped indemnity may be partially mitigated by a broad limitation of liability)." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_d58345b625d8e01d a oc:WorkflowStep ;
    dcterms:description "**Determine the user's side**: Vendor, customer, licensor, licensee, partner. This fundamentally changes the analysis (e.g., limitation of liability protections favor different parties)." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_dc230bb812f46770 a oc:WorkflowStep ;
    dcterms:description "**Identify the contract type**: SaaS agreement, professional services, license, partnership, procurement, etc. The contract type affects which clauses are most material." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_e40fb66c71cb1c79 a oc:WorkflowStep ;
    dcterms:description "**Focus areas**: Any specific concerns? (e.g., \"data protection is critical\", \"we need flexibility on term\", \"IP ownership is the key issue\")" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_e8e0851e71089715 a oc:WorkflowStep ;
    dcterms:description "**Prioritize**: Not all redlines are equal. Indicate which are must-haves and which are nice-to-haves." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_01cab99b6dd53627 a oc:WorkflowStep ;
    dcterms:description "Classify each deviation as GREEN (acceptable), YELLOW (negotiate), or RED (escalate) with specific rationale." ;
    oc:expectedOutcome "Each clause has a traffic-light classification with justification" ;
    oc:stepDependsOn _:ref_c6b983e2e638345c ;
    oc:stepId "flag-deviations" .

_:ref_022e5e28a96fd013 a oc:WorkflowStep ;
    dcterms:description "Gather user context: side (vendor/customer), deadline, focus areas, deal context. Proceed with partial info and note assumptions." ;
    oc:expectedOutcome "Review context established with user's side and priorities" ;
    oc:stepDependsOn _:ref_8e229f20b59133d9 ;
    oc:stepId "gather-context" .

_:ref_2dbae9170939fb4c a oc:WorkflowStep ;
    dcterms:description "Summarize overall risk assessment, top 3 issues, negotiation strategy with tier priorities, and timeline considerations." ;
    oc:expectedOutcome "Negotiation strategy document with prioritized action plan" ;
    oc:stepDependsOn _:ref_ee3844e51755d110 ;
    oc:stepId "business-impact" .

_:ref_395376855b45952f a oc:WorkflowStep ;
    dcterms:description "Load organization's contract review playbook from local settings. If absent, offer to help set up or proceed with generic commercial standards." ;
    oc:expectedOutcome "Playbook loaded OR explicit acknowledgment of generic review basis" ;
    oc:stepDependsOn _:ref_022e5e28a96fd013 ;
    oc:stepId "load-playbook" .

_:ref_8e229f20b59133d9 a oc:WorkflowStep ;
    dcterms:description "Accept the contract in any format (PDF, DOCX, URL, pasted text). Prompt user if none provided." ;
    oc:expectedOutcome "Contract text available for analysis" ;
    oc:stepId "accept-contract" .

