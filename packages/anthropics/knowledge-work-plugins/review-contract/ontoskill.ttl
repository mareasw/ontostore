@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_review_contract a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "review-contract" ;
    skos:broader "Contract review workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/review-contract" ;
    oc:contentHash "ff2c741cf678001551e8802a26521643ea6dbd63d1a096b59602cf7af1ed4c3d" ;
    oc:differentia "that performs clause-by-clause analysis against an organizational playbook using a GREEN/YELLOW/RED deviation classification system and generates prioritized redline suggestions with fallback positions" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput,
        oc:PlaybookNotFound ;
    oc:hasArgumentHint "<contract file or text>" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Review a contract against your organization's negotiation playbook — flag deviations, generate redlines, provide business impact analysis. Use when reviewing vendor or customer agreements, when you need clause-by-clause analysis against standard positions, or when preparing a negotiation strategy with prioritized redlines and fallback positions." ;
    oc:hasName "review-contract" ;
    oc:impartsKnowledge oc:kn_0bbb0dfc,
        oc:kn_19fbd8bb,
        oc:kn_22d64bff,
        oc:kn_3c917ec9,
        oc:kn_70147dab,
        oc:kn_c3077ebf,
        oc:kn_e78d88b8,
        oc:kn_f26410b3 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady,
        oc:FileExists ;
    oc:resolvesIntent "analyze a contract clause-by-clause for risk",
        "assess business impact of contract clauses",
        "flag deviations in a contract from standard positions",
        "generate redline suggestions for contract negotiation",
        "prepare a negotiation strategy with prioritized redlines",
        "review a contract against a negotiation playbook" ;
    oc:yieldsState oc:ContractReviewed,
        oc:RedlinesGenerated .

oc:kn_0bbb0dfc a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading the playbook (Step 3) and no local configuration is found" ;
    oc:directiveContent "If no organizational playbook is configured, inform the user and offer either to help set one up or proceed with generic review based on widely-accepted commercial standards, clearly noting the basis of review." ;
    oc:hasRationale "Absent a playbook, the review must still be useful while being transparent about its basis — generic standards are a fallback, not a replacement." ;
    oc:severityLevel "MEDIUM" .

oc:kn_19fbd8bb a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning clause analysis (Step 2)" ;
    oc:directiveContent "Gather user context before analysis: which side they are on, deadline, focus areas, and deal context. Proceed with partial context and note assumptions if incomplete." ;
    oc:hasRationale "The user's side fundamentally changes the analysis (e.g., liability protections favor different parties), and deadline affects issue prioritization." ;
    oc:severityLevel "HIGH" .

oc:kn_22d64bff a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When CLM integration is available (Step 8)" ;
    oc:directiveContent "If a CLM system is connected via MCP, the skill may recommend approval workflows and routing paths based on contract type and risk level." ;
    oc:hasRationale "CLM routing automates downstream workflow but creates external state changes in the contract management system that should be intentional." ;
    oc:severityLevel "LOW" .

oc:kn_3c917ec9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting negotiation strategy (Step 7)" ;
    oc:directiveContent "Lead with Tier 1 must-haves in negotiation, trade Tier 3 nice-to-haves to secure Tier 2 should-haves, and never concede on Tier 1 without escalation." ;
    oc:hasRationale "Prioritized negotiation prevents wasting leverage on low-value items and ensures critical risks are addressed first within timeline constraints." ;
    oc:severityLevel "HIGH" .

oc:kn_70147dab a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, throughout every contract review" ;
    oc:directiveContent "Never provide legal advice — all analysis must be reviewed by qualified legal professionals before being relied upon." ;
    oc:hasRationale "AI-assisted contract review is a workflow tool, not a substitute for legal counsel; relying on it without legal review creates liability exposure." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c3077ebf a oc:AmbiguityTolerance,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering very long or non-English contracts" ;
    oc:directiveContent "For contracts over 50 pages, offer to focus on the most material sections first before doing a complete review. For non-English contracts, ask about language preference." ;
    oc:hasRationale "Long contracts create information overload risk; non-English contracts may require translation expertise — managing scope improves quality." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e78d88b8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When flagging deviations from the playbook (Step 5)" ;
    oc:directiveContent "Classify every deviation using the three-tier GREEN/YELLOW/RED system — GREEN (acceptable), YELLOW (negotiate), RED (escalate) — to ensure consistent risk communication." ;
    oc:hasRationale "A standardized severity taxonomy enables stakeholders to quickly understand risk levels and take appropriate action without reading the full analysis." ;
    oc:severityLevel "HIGH" .

oc:kn_f26410b3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During clause-by-clause analysis (Step 4)" ;
    oc:directiveContent "Always read the entire contract before flagging issues — clauses interact with each other (e.g., an uncapped indemnity may be partially mitigated by a broad limitation of liability)." ;
    oc:hasRationale "Isolating clauses without holistic context leads to inaccurate risk assessments; cross-clause interactions can amplify or mitigate individual clause risks." ;
    oc:severityLevel "CRITICAL" .

