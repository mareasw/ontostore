oc:kn_063c8d24 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Always — final output format for all content types" ;
    oc:directiveContent """## {Content Title}
{Draft body per content type template}
---
**Voice/Tone applied**: {voice description}
**SEO Recommendations**: {keyword, meta description, linking, alt text}
**Next steps**: {review suggestions}

Would you like me to revise any section, adjust the tone, or create a variation for a different channel?""" ;
    oc:templateVariables "Content Title",
        "alt text",
        "keyword",
        "linking",
        "meta description",
        "review suggestions",
        "voice description" .

oc:kn_1c3e588e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating blog posts and email newsletters" ;
    oc:directiveContent "Always provide 2-3 headline or subject line options to give the user editorial choice rather than a single option." ;
    oc:hasRationale "Headlines and subject lines have outsized impact on engagement; offering options lets users A/B test or select the best fit for their audience." .

oc:kn_2c16a3ef a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When brand voice is not found in local settings" ;
    oc:directiveContent "If no brand voice is configured, ask the user for guidelines. If none provided, default to a neutral professional tone and inform the user." ;
    oc:hasRationale "Prevents generating content with an unintended voice that could misalign with the user's brand." .

oc:kn_2d6e77ba a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every draft-content invocation" ;
    oc:directiveContent "1. Gather inputs (content type, topic, audience, key messages, tone, length) — ask for any missing before proceeding. 2. Apply brand voice from local settings if configured; otherwise prompt user or use neutral professional tone. 3. Generate draft using channel-specific template (blog, social, email, landing page, press release, case study). 4. Add SEO recommendations for web-facing content (keyword, meta description, linking, alt text). 5. Present draft with voice/tone note, SEO recs, and next-step suggestions. 6. Ask user if revisions, tone adjustments, or cross-channel variations are needed." ;
    oc:stepOrder 1 .

oc:kn_2ff35d54 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating any draft" ;
    oc:directiveContent "Verify all 6 required inputs are gathered before generating content: content type, topic, target audience, key messages, tone (optional if brand voice configured), and length." ;
    oc:hasRationale "Missing inputs lead to generic content that doesn't match user needs." .

oc:kn_5e967d08 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating SEO elements and social media content" ;
    oc:directiveContent "Meta descriptions must be under 160 characters. Twitter/X posts must fit within character limits. Social media hashtags should be 3-5 relevant tags." ;
    oc:hasRationale "Platform and SEO constraints are hard limits that affect visibility and usability." ;
    oc:severityLevel "HIGH" .

oc:kn_f24da572 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any content draft" ;
    oc:directiveContent "Each content type has a distinct structural template — never use a one-size-fits-all format. Blog posts need hooks and subheadings; social posts need platform-specific length/emoji rules; press releases need datelines and boilerplates." ;
    oc:hasRationale "Content that follows channel conventions performs better and appears more professional to its intended audience." .

oc:kn_f412dda5 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating blog posts and landing page copy" ;
    oc:directiveContent "For web content (blog posts, landing pages), always include: primary keyword suggestion, keyword placement guidance, internal/external linking opportunities, meta description under 160 chars, and image alt text opportunities." ;
    oc:hasRationale "SEO best practices ensure content is discoverable and ranks well in search engines." .

