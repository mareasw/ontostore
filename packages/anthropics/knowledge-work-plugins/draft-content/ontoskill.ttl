@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_draft_content a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "draft-content" ;
    skos:broader "Content generation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/draft-content" ;
    oc:contentHash "283a71b13dbca12e398575d1c252bcc11331335e7fe8bae11906ae7e35c8752e" ;
    oc:differentia "Produces channel-specific marketing content drafts with brand voice alignment and SEO recommendations across six content types (blog posts, social media, email newsletters, landing pages, press releases, case studies)" ;
    oc:handlesFailure oc:BrandVoiceNotFound,
        oc:InsufficientInput ;
    oc:hasArgumentHint "<content type and topic>" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Draft blog posts, social media, email newsletters, landing pages, press releases, and case studies with channel-specific formatting and SEO recommendations. Use when writing any marketing content, when you need headline or subject line options, or when adapting a message for a specific platform, audience, and brand voice." ;
    oc:hasName "draft-content" ;
    oc:impartsKnowledge oc:kn_085be1d7,
        oc:kn_524d8f26,
        oc:kn_5515365d,
        oc:kn_760fc18d,
        oc:kn_e38cf070 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:resolvesIntent "adapt content for specific platforms",
        "compose email newsletters",
        "create social media posts",
        "draft marketing content",
        "draft press releases",
        "generate headline options",
        "write blog posts",
        "write case studies",
        "write landing page copy" ;
    oc:yieldsState oc:ContentDraftCreated .

oc:kn_085be1d7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When initiating content generation" ;
    oc:directiveContent "Gather six required inputs before drafting: content type, topic, target audience, key messages (2-4), tone, and length. Content type must be one of the six supported types." ;
    oc:hasRationale "Insufficient inputs lead to generic content that misses the target audience and fails to communicate intended messages." ;
    oc:severityLevel "MEDIUM" .

oc:kn_524d8f26 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting blog posts, landing pages, or other web-facing content" ;
    oc:directiveContent "For web-facing content (blog posts, landing pages), always include SEO considerations: suggest a primary keyword, recommend keyword placement in headline/first paragraph/subheadings, provide a meta description under 160 characters, and note internal/external linking and image alt text opportunities." ;
    oc:hasRationale "SEO-aware content has significantly higher discoverability and organic reach potential." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5515365d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any marketing content draft" ;
    oc:directiveContent "Every content draft must be tailored to its specific channel type — blog, social media, email newsletter, landing page, press release, or case study — each has distinct structural requirements and formatting conventions." ;
    oc:hasRationale "Channel-appropriate formatting ensures content performs optimally on its target platform and meets audience expectations." ;
    oc:severityLevel "HIGH" .

oc:kn_760fc18d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before generating any content draft" ;
    oc:directiveContent "Always check for a configured brand voice in the user's local settings file before drafting. If found, apply it automatically and inform the user. If not found, ask the user for guidelines or default to neutral professional tone." ;
    oc:hasRationale "Consistent brand voice application prevents tonal inconsistency and ensures content aligns with organizational identity." ;
    oc:severityLevel "HIGH" .

oc:kn_e38cf070 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "After completing any content draft" ;
    oc:directiveContent "After presenting a draft, always include notes on brand voice applied, SEO recommendations, next-step suggestions, and prompt the user with revision options: adjust tone, revise sections, or create channel variations." ;
    oc:hasRationale "Post-draft guidance helps users iterate efficiently and extends the content's utility across channels." ;
    oc:severityLevel "LOW" .

