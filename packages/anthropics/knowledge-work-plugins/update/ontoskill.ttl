    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady,
        oc:FileExists ;
    oc:resolvesIntent "fill memory gaps for unknown people or projects",
        "refresh memory from current activity",
        "scan activity for missed todos",
        "sync tasks from external tools",
        "triage stale or overdue tasks" ;
    oc:yieldsState oc:GapsFilled,
        oc:MemoryRefreshed,
        oc:TasksSynced .

oc:kn_0fd86ce5 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When enrichment or gap-filling occurs" ;
    oc:directiveContent "Updates TASKS.md (adds/completes/triages tasks), modifies memory/ files (people/, projects/, glossary.md), and may update CLAUDE.md (demoting completed items)." ;
    oc:hasRationale "Agents and users must be aware of which files are modified to prevent conflicts." ;
    oc:severityLevel "HIGH" .

oc:kn_7669255a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing task lists during sync" ;
    oc:directiveContent "Do not skip the gap detection step even if most tasks decode successfully. Incomplete entity resolution means the agent cannot reason about those items." ;
    oc:hasRationale "Unresolved entities (people, projects, acronyms) reduce the agent's ability to provide context-aware assistance." ;
    oc:severityLevel "HIGH" .

oc:kn_8eed2960 a oc:KnowledgeNode,
        oc:RequiresHumanClarification ;
    oc:appliesToContext "When running --comprehensive flag" ;
    oc:directiveContent "Comprehensive mode always runs interactively. Present findings grouped by confidence — high-confidence items offered to add directly, low-confidence items require confirmation." ;
    oc:hasRationale "Deep scanning surfaces noisy results; confidence-tiered presentation reduces user fatigue while maintaining accuracy." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a0b95bac a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "Safe to run frequently — only updates when there's new info. Re-running with no changes produces no side effects." ;
    oc:hasRationale "Encourages frequent syncing without risk of data corruption or duplication." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b2bae79d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When comparing external task sources with local task list" ;
    oc:directiveContent "Use fuzzy matching on task titles when comparing external tasks against TASKS.md to handle minor wording differences." ;
    oc:hasRationale "Exact matching would miss tasks that exist but with slightly different wording, leading to duplicates." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b3c7ddda a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing default mode sync" ;
    oc:directiveContent "Verify TASKS.md and memory/ directory exist before proceeding. If missing, suggest running /productivity:start first." ;
    oc:hasRationale "The update workflow depends on the task and memory infrastructure being initialized." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e24770ae a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When syncing tasks or updating memory files" ;
    oc:directiveContent "Never auto-add tasks or memories without user confirmation. Always present changes as a diff and let the user decide." ;
    oc:hasRationale "Prevents unwanted data proliferation and ensures user maintains control over their task list and memory." ;
    oc:severityLevel "CRITICAL" .

_:ref_01b8c00375b26972 a oc:WorkflowStep ;
    dcterms:description "Review Active tasks and flag overdue (past due date), stale (30+ days), and context-less (no person/project) items for triage." ;
    oc:expectedOutcome "Stale tasks identified and presented for resolution" ;
    oc:stepDependsOn _:ref_6192f770740288a7 ;
    oc:stepId "triage-stale" .

_:ref_8f5a9d13952f710d a oc:WorkflowStep ;
    dcterms:description "Present unknown terms grouped to user. Add confirmed answers to appropriate memory files (people/, projects/, glossary.md)." ;
    oc:expectedOutcome "Memory gaps filled for unknown entities" ;
    oc:stepDependsOn _:ref_b0f0cfec702226d8 ;
    oc:stepId "fill-gaps" .

_:ref_b1a6f021b1c4c8f9 a oc:WorkflowStep ;
    dcterms:description "Fetch tasks from external sources (project tracker, GitHub Issues). Compare against TASKS.md using fuzzy matching. Present diff for user decision." ;
    oc:expectedOutcome "External tasks reconciled with local task list" ;
    oc:stepDependsOn _:ref_6192f770740288a7 ;
    oc:stepId "sync-external" .

_:ref_df001091d5b034d9 a oc:WorkflowStep ;
    dcterms:description "Extract links, status changes, relationships, and deadlines from tasks. Update project/people files accordingly." ;
    oc:expectedOutcome "Memory files enriched with contextual data from tasks" ;
    oc:stepDependsOn _:ref_b0f0cfec702226d8 ;
    oc:stepId "capture-enrichment" .

_:ref_ffe5c17d74240bb0 a oc:WorkflowStep ;
    dcterms:description "Execute complete default mode workflow first." ;
    oc:expectedOutcome "Tasks synced, stale items triaged, memory gaps filled" ;
    oc:stepId "run-default" .

_:ref_43e252b2ade59e53 a oc:WorkflowStep ;
    dcterms:description "Gather recent data from MCP sources: chat messages, sent email, recently touched docs, recent and upcoming calendar events." ;
    oc:expectedOutcome "Activity data collected from all connected sources" ;
    oc:stepDependsOn _:ref_ffe5c17d74240bb0 ;
    oc:stepId "scan-activity" .

_:ref_b0f0cfec702226d8 a oc:WorkflowStep ;
    dcterms:description "Decode all entities in tasks (people, projects, acronyms, tools, links). Track what resolves vs. what has gaps in memory." ;
    oc:expectedOutcome "Unresolved entities identified for each task" ;
    oc:stepDependsOn _:ref_6192f770740288a7 ;
    oc:stepId "decode-gaps" .

_:ref_6192f770740288a7 a oc:WorkflowStep ;
    dcterms:description "Read TASKS.md and memory/ directory. If missing, suggest /productivity:start." ;
    oc:expectedOutcome "Current task list and memory state loaded" ;
    oc:stepId "load-state" .

