                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "For each line item, calculate and flag material variances." ] ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent _:ref_134c515a84038f73,
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "For each material variance:" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 11 ;
                                    oc:sectionTitle "Investigation and Narrative" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Dollar variance:** Current period - Prior period (or current period - budget)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "**Basis point change:** For margins and ratios, express change in basis points (1 bp = 0.01%)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Percentage variance:** (Current - Prior) / |Prior| x 100" ] ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "For each line item, calculate:" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 8 ;
                                    oc:sectionTitle "Variance Calculation" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "Break down total variance into component drivers:" ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "**One-time/non-recurring items:** Items that are not expected to repeat" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 6 ;
                                                    oc:itemText "**Timing effect:** Items shifting between periods (not a true change in run rate)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "**New/discontinued items:** Items present in one period but not the other" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "**Mix effect:** Shift in composition between items with different rates/margins" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Volume/quantity effect:** Change in volume at prior period rates" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 7 ;
                                                    oc:itemText "**Currency effect:** Impact of FX rate changes on translated results" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Rate/price effect:** Change in rate/price at current period volume" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 10 ;
                                    oc:sectionTitle "Variance Decomposition" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 3 ;
                                            oc:textContent "*Example thresholds (adjust for your organization):*" ],
                                        [ a oc:Table ;
                                            oc:blockType "table" ;
                                            oc:contentOrder 4 ;
                                            oc:rowCount 3 ;
                                            oc:tableCaption "*Example thresholds (adjust for your organization):*" ;
                                            oc:tableMarkdown """| Line Item Size | Dollar Threshold | Percentage Threshold |
|---------------|-----------------|---------------------|
| > $10M        | $500K           | 5%                  |
| $1M - $10M    | $100K           | 10%                 |
| < $1M         | $50K            | 15%                 |
""" ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "**Scaled:** Different thresholds for different line items based on their size and volatility" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "**Combined:** Either the dollar OR percentage threshold is exceeded" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Percentage threshold:** Variances exceeding a set percentage (e.g., 10%, 15%)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Fixed dollar threshold:** Variances exceeding a set dollar amount (e.g., $50K, $100K)" ] ],
                                        [ a oc:Paragraph ;
