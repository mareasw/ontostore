@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_weekly_prep_brief_briefing_guide a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "briefing-guide" ;
    skos:broader "Structural guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/weekly-prep-brief" ;
    oc:contentHash "af5c591296c5478a8d6e17c35992af91ae11b5c588b231b1177f5ba35abc8012" ;
    oc:differentia "that calibrates research depth and prioritization for weekly sales prep briefings across account types and edge cases" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_weekly_prep_brief ;
    oc:hasCategory "productivity" ;
    oc:impartsKnowledge oc:kn_4f9e15c4,
        oc:kn_8a6d6005,
        oc:kn_98664424,
        oc:kn_9a2aff02,
        oc:kn_9a611847,
        oc:kn_c2e22ff7 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "calibrate briefing depth by account type",
        "handle edge cases in weekly prep briefs",
        "prioritize week overview signals for sales calls" .

oc:kn_4f9e15c4 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When primary data source is missing for an account" ;
    oc:directiveContent "When Common Room data is unavailable, explicitly note the gap, run external web research as fallback, and recommend the rep check with their team for offline context." ;
    oc:hasRationale "Transparent gap acknowledgment prevents false confidence and ensures the rep still gets actionable prep from available sources." ;
    oc:severityLevel "HIGH" .

oc:kn_8a6d6005 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assembling the week overview section of the briefing" ;
    oc:directiveContent "Flag high-priority situations prominently at the top of the brief: trials expiring within 7 days, renewals due within 30 days, churn risk signals, critical support tickets, executive stakeholders attending, champion job changes, competitive signals, and notable company milestones." ;
    oc:hasRationale "Time-sensitive risks and opportunities must be surfaced immediately so the rep can act on them during the call rather than discovering them buried in the brief." ;
    oc:severityLevel "CRITICAL" .

oc:kn_98664424 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any weekly prep brief" ;
    oc:directiveContent "Calibrate research depth based on account type: full research for strategic accounts, active opportunities, upcoming renewals, and new prospects; standard for mid-market routine calls; minimal for small account check-ins." ;
    oc:hasRationale "Ensures research effort is proportional to account value and meeting stakes, avoiding over-investment on low-stakes calls while ensuring strategic accounts get thorough preparation." ;
    oc:severityLevel "HIGH" .

oc:kn_9a2aff02 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a meeting is scheduled for today and time is limited" ;
    oc:directiveContent "For same-day meetings, skip confirmation and produce a compressed version with company snapshot + top signals + 1-2 talking points, marked as '[Quick Prep]'." ;
    oc:hasRationale "Same-day meetings require speed over completeness; the compressed format still provides value without delaying the rep." ;
    oc:severityLevel "LOW" .

oc:kn_9a611847 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When weekly meeting load is heavy" ;
    oc:directiveContent "For 7+ meetings in a week, ask whether to prioritize full research for specific accounts or run abbreviated prep for all; default to full research for strategic accounts." ;
    oc:hasRationale "Prevents burnout and ensures the most important calls get thorough preparation when time constraints make full prep for all meetings infeasible." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c2e22ff7 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When the same account appears in multiple meetings in a week" ;
    oc:directiveContent "For multiple meetings with the same company, research the account once and share across meetings, differentiating only by attendees and objectives per meeting." ;
    oc:hasRationale "Avoids redundant research effort while still providing meeting-specific context for each interaction." ;
    oc:severityLevel "MEDIUM" .

