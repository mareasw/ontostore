@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_knowledge_work_plugins_weekly_prep_brief_briefing_guide a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "briefing-guide" ;
    skos:broader "Reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/weekly-prep-brief" ;
    oc:contentHash "af5c591296c5478a8d6e17c35992af91ae11b5c588b231b1177f5ba35abc8012" ;
    oc:dependsOnSkill oc:skill_ontoskills_weekly_prep_brief ;
    oc:differentia "that calibrates weekly prep briefing depth and handles edge cases for sales meeting preparation" ;
    oc:extends oc:skill_knowledge_work_plugins_weekly_prep_brief ;
    oc:handlesFailure oc:InsufficientAccountData,
        oc:MeetingStatusUnclear ;
    oc:hasCategory "productivity" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Trial expiring within 7 days, renewal due within 30 days, or churn risk signals detected" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Champion recently changed jobs or competitive signals in the account" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Open critical support tickets or unresolved escalations" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Expansion signals worth raising in the call" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Executive stakeholder or new champion attending" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "Recent company funding, product milestone, or strong community advocacy (use as opener)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Flag these situations prominently at the top of the brief:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Week Overview Priorities" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**7+ meetings in a week:** Ask whether to prioritize full research for specific accounts or run abbreviated prep for all; default to full for strategic." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**No Common Room data:** Note it explicitly, run external web research, recommend the rep check with their team for offline context." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Same-day meeting:** Skip confirmation, produce compressed version (company snapshot + top signals + 1-2 talking points), mark as \"[Quick Prep]\"." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Cancelled meetings:** Exclude silently; if status is unclear, include with \"[Status unclear — confirm this meeting is still on.]\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Multiple meetings with the same company:** Research the account once, share across meetings, differentiate by attendees and objectives." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Edge Cases" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Calibrate research depth based on account type:" ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 6 ;
                            oc:tableCaption "Calibrate research depth based on account type" ;
                            oc:tableMarkdown """| Account Type | Depth |
|-------------|-------|
| Strategic account (large, high ARR) | Full — account + all attendees |
| Active opportunity (open deal) | Full — with emphasis on deal signals |
| Renewal within 90 days | Full — with emphasis on risk/health signals |
| Mid-market customer, routine call | Standard — abbreviated account + key attendee |
| Small account, quick check-in | Minimal — 3-4 bullets, single attendee |
| Brand new prospect (first meeting) | Full contact + account — first impressions matter |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Briefing Depth Guidelines" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Weekly Prep Brief — Structure and Edge Cases" ] ;
    oc:impartsKnowledge oc:kn_233f283d,
        oc:kn_7f991b35,
        oc:kn_a8987386,
        oc:kn_c27a6f8f,
        oc:kn_def8fa57 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:AccountDataAvailable,
        oc:MeetingsIdentified ;
    oc:resolvesIntent "calibrate briefing research depth",
        "handle prep brief edge cases",
        "prioritize week overview flags" ;
    oc:yieldsState oc:BriefingDepthCalibrated,
        oc:EdgeCasesHandled .

oc:kn_233f283d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining how much research to conduct for each meeting" ;
    oc:directiveContent "Calibrate research depth by account type: Full for strategic accounts, active opportunities, renewals within 90 days, and new prospects; Standard for mid-market routine calls; Minimal (3-4 bullets) for small account check-ins." ;
    oc:hasRationale "Prevents over-investing research time on low-stakes calls while ensuring high-value accounts get thorough preparation." ;
    oc:severityLevel "HIGH" .

oc:kn_7f991b35 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When the weekly meeting count exceeds seven" ;
    oc:directiveContent "For 7+ meetings in a week: ask whether to prioritize full research for specific accounts or run abbreviated prep for all; default to full for strategic accounts." ;
    oc:hasRationale "Prevents research bottlenecks and ensures the most important accounts always get adequate preparation." .

oc:kn_a8987386 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When assembling the week overview section of the briefing" ;
    oc:directiveContent "Flag at the top of the brief: trial expiring within 7 days, renewals due within 30 days, churn risk signals, critical support tickets, escalations, expansion signals, executive stakeholders attending, champion job changes, competitive signals, recent funding/milestones/advocacy." ;
    oc:hasRationale "These high-signal items are the most actionable intelligence a rep needs before walking into a call." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c27a6f8f a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When data enrichment sources return no results for an account" ;
    oc:directiveContent "If no Common Room data exists: note it explicitly, run external web research, and recommend the rep check with their team for offline context." ;
    oc:hasRationale "Transparently surfacing data gaps prevents false confidence and gives the rep alternative paths to context." ;
    oc:severityLevel "HIGH" .

oc:kn_def8fa57 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When handling time-constrained or ambiguous meeting statuses" ;
    oc:directiveContent "For same-day meetings: skip confirmation, produce a compressed version (company snapshot + top signals + 1-2 talking points), and mark as '[Quick Prep]'. For cancelled meetings: exclude silently; if status is unclear, include with '[Status unclear — confirm this meeting is still on.]'" ;
    oc:hasRationale "Same-day meetings have no time for full research — compressed prep is better than no prep. Unclear statuses should be surfaced rather than silently dropped." .

