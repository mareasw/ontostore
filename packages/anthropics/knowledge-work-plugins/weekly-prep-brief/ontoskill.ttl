oc:skill_knowledge_work_plugins_weekly_prep_brief a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "weekly-prep-brief" ;
    skos:broader "briefing generator" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/weekly-prep-brief" ;
    oc:contentHash "265b0885c3a00de1efceb3000fc05a0f966b6cc922d000f8c6389fc52d4bed4c" ;
    oc:dependsOnSkill oc:skill_ontoskills_account_research,
        oc:skill_ontoskills_contact_research ;
    oc:differentia "that researches all external meetings for the upcoming week and compiles them into a single prioritized prep document" ;
    oc:handlesFailure oc:CalendarUnavailable,
        oc:InsufficientData,
        oc:ResearchTimeout ;
    oc:hasArgumentHint "optional date range or week specification (defaults to next 7 days)" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Generate a comprehensive weekly briefing for all external calls in the next 7 days. Triggers on 'weekly prep brief', 'prepare my week', 'what calls do I have this week', 'Monday prep', or any weekly planning request." ;
    oc:hasName "weekly-prep-brief" ;
    oc:hasRequirement oc:req_022725dd,
        oc:req_553d1294,
        oc:req_d12dde09 ;
