oc:kn_0ba58430 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During Step 3 research phase" ;
    oc:directiveContent "Run account research and contact research in parallel for each confirmed meeting. Research shared accounts once and share findings across multiple meetings with the same company." ;
    oc:hasRationale "Parallel execution reduces total briefing generation time; deduplication avoids redundant research" ;
    oc:severityLevel "MEDIUM" .

oc:kn_32f547ee a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a meeting is happening today and there's no time for full research" ;
    oc:directiveContent "For same-day meetings, skip the confirmation step and produce a compressed version (company snapshot + top signals + 1-2 talking points), marked as [Quick Prep]." ;
    oc:hasRationale "Provides some value immediately rather than none at all" ;
    oc:severityLevel "LOW" .

oc:kn_4864d24b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the meeting list exceeds 7 external calls" ;
    oc:directiveContent "For 7+ meetings in a week, ask the user whether to prioritize full research for specific accounts or run abbreviated prep for all; default to full for strategic accounts." ;
    oc:hasRationale "Prevents briefs from becoming unwieldy and ensures the most important meetings get proper attention" ;
    oc:severityLevel "MEDIUM" .

oc:kn_488e83ef a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing and formatting the final brief" ;
    oc:directiveContent "Total brief should be readable in 10-15 minutes for a week with 4-6 meetings. Keep each section scannable — reps read these in the morning, often on mobile." ;
    oc:hasRationale "Briefs that are too long won't be read and defeat the purpose of the prep" ;
    oc:severityLevel "MEDIUM" .

oc:kn_4f59893c a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When Common Room returns no data for an account" ;
    oc:directiveContent "When there is no Common Room data, note it explicitly, run external web research, and recommend the rep check with their team for offline context." ;
    oc:hasRationale "Transparency about data gaps prevents false confidence and guides reps to alternative sources" ;
    oc:severityLevel "MEDIUM" .

oc:kn_60eb720b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When research returns limited data for an account or contact" ;
    oc:directiveContent "Never fabricate meeting prep content when Common Room returns sparse data — use the compressed sparse-data format instead of filling the full template with guesses." ;
    oc:hasRationale "Invented deal context or signals mislead reps and erode trust in the briefing" ;
    oc:severityLevel "CRITICAL" .

oc:kn_6d6a0a5b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After fetching meetings, before running account/contact research" ;
    oc:directiveContent "Present the meeting list to the user for confirmation before beginning research — this prevents wasted effort on cancelled or incorrect meetings." ;
    oc:hasRationale "Research is expensive; confirmation avoids wasted API calls and time" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7c266088 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining how much research to produce per meeting" ;
    oc:directiveContent "Calibrate research depth by account type: full depth for strategic accounts, active opportunities, renewals within 90 days, and new prospects; abbreviated (3-4 bullets) for mid-market routine calls and small account check-ins." ;
    oc:hasRationale "Optimizes research effort toward high-impact meetings while keeping the brief scannable" ;
    oc:severityLevel "HIGH" .

oc:kn_868c6833 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when generating any part of the briefing" ;
    oc:directiveContent "Every fact in the brief must originate from a tool call — no invented deal context, activity, or signals." ;
    oc:hasRationale "Ensures factual accuracy and prevents hallucinated deal intelligence" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a687e095 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before Step 1 meeting retrieval" ;
    oc:directiveContent "Verify calendar connectivity before attempting meeting fetch. If no calendar is connected, prepare to prompt the user for manual meeting input." ;
    oc:hasRationale "Graceful degradation ensures the skill works even without calendar integration" ;
    oc:severityLevel "MEDIUM" .

oc:req_022725dd a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Common Room (via account-research and contact-research skills)" .

oc:req_553d1294 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "Calendar connector (~~calendar)" .

oc:req_d12dde09 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Web search capability for recency checks" .

_:ref_01bf07f078718dda a oc:WorkflowStep ;
    dcterms:description "**Contact research** — profile for each external attendee using the contact-research skill" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
