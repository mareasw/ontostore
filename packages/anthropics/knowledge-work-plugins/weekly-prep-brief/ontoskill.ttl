_:ref_7c5647d6c84d0461 a oc:WorkflowStep ;
    dcterms:description "**Account research** — full account snapshot using the account-research skill" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_4f9f50f535ac3905 a oc:WorkflowStep ;
    dcterms:description "Run account-research and contact-research in parallel for each confirmed meeting. Run web recency checks as supplementary." ;
    oc:expectedOutcome "Per-meeting research packets with account snapshots, attendee profiles, and signals" ;
    oc:stepDependsOn _:ref_62e7ac6352cf3217 ;
    oc:stepId "research-accounts-contacts" .

_:ref_62e7ac6352cf3217 a oc:WorkflowStep ;
    dcterms:description "Present the filtered meeting list to the user for confirmation before research." ;
    oc:expectedOutcome "User-confirmed list of meetings to research" ;
    oc:stepDependsOn _:ref_819e29460ee39c48 ;
    oc:stepId "confirm-list" .

_:ref_819e29460ee39c48 a oc:WorkflowStep ;
    dcterms:description "Fetch all meetings for next 7 days via calendar connector (or ask user for manual input), filter to external-only meetings." ;
    oc:expectedOutcome "Structured list of external meetings with company name, date/time, and attendee info" ;
    oc:stepId "fetch-meetings" .

_:ref_e4b53adf4072c81a a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_01bf07f078718dda,
