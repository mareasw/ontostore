@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_weekly_prep_brief a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "weekly-prep-brief" ;
    skos:broader "Briefing generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/weekly-prep-brief" ;
    oc:contentHash "265b0885c3a00de1efceb3000fc05a0f966b6cc922d000f8c6389fc52d4bed4c" ;
    oc:dependsOnSkill oc:skill_account_research,
        oc:skill_contact_research ;
    oc:differentia "that synthesizes per-meeting account and contact research into a single weekly document for all upcoming external calls" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasAllowedTool "Common Room",
        "calendar",
        "web search" ;
    oc:hasArgumentHint "optional date range or week specification (defaults to next 7 days)" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Generate a comprehensive weekly briefing for all external calls in the next 7 days. Triggers on 'weekly prep brief', 'prepare my week', 'what calls do I have this week', 'Monday prep', or any weekly planning request." ;
    oc:hasName "weekly-prep-brief" ;
    oc:impartsKnowledge oc:kn_0cb812d2,
        oc:kn_16e948b9,
        oc:kn_2dccae32,
        oc:kn_691557eb,
        oc:kn_a37d776a,
        oc:kn_a7132123 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "generate weekly prep brief",
        "get a weekly meeting overview",
        "plan weekly meetings",
        "prepare for upcoming external calls",
        "research accounts and contacts before calls" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0cb812d2 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When Common Room returns sparse or no data for an account or contact" ;
    oc:directiveContent "When a company has no Common Room data, note it explicitly, run external web research instead, and recommend the rep check with their team for offline context. For 7+ meetings, ask the user whether to prioritize specific accounts or run abbreviated prep for all." ;
    oc:hasRationale "Transparency about data gaps prevents false confidence and helps reps seek alternative context sources before their call." ;
    oc:severityLevel "MEDIUM" .

oc:kn_16e948b9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining how much research to produce per meeting" ;
    oc:directiveContent "Calibrate research depth by account type: full depth for strategic accounts, active opportunities, renewals within 90 days, and first meetings with new prospects; abbreviated 3-4 bullet snapshots for lower-priority or routine check-ins." ;
    oc:hasRationale "Prevents information overload while ensuring high-stakes calls get thorough preparation, optimizing both research time and rep reading time." ;
    oc:severityLevel "HIGH" .

oc:kn_2dccae32 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing any meeting prep section" ;
    oc:directiveContent "Every fact in the brief must come from a tool call — never invent deal context, activity, or signals. When Common Room returns limited data, use the compressed sparse-data format rather than fabricating a full section." ;
    oc:hasRationale "Fabricated context wastes the rep's time and can cause embarrassing errors in live customer calls, undermining trust in the briefing tool." ;
    oc:severityLevel "CRITICAL" .

oc:kn_691557eb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting and assembling the final weekly brief output" ;
    oc:directiveContent "Keep each meeting section scannable — reps read these in the morning, often on mobile. Flag urgent situations (risk, trial expiration, open opps) prominently at the top of the week overview, not buried in individual sections. Total brief should be readable in 10-15 minutes for 4-6 meetings." ;
    oc:hasRationale "Briefings are consumed under time pressure; scannability and prominent flagging directly determine whether the prep is actually useful." ;
    oc:severityLevel "HIGH" .

oc:kn_a37d776a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "After fetching calendar meetings but before beginning account/contact research" ;
    oc:directiveContent "Always confirm the identified meeting list with the user before starting research. Present each meeting as Company/Day/Time/Attendees and ask for corrections." ;
    oc:hasRationale "Prevents wasted research effort on cancelled, rescheduled, or incorrectly identified meetings." ;
    oc:severityLevel "HIGH" .

oc:kn_a7132123 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running the recency/news check for each account" ;
    oc:directiveContent "Do not pad the brief with generic news. Only include genuinely noteworthy findings such as funding rounds, leadership changes, or major press coverage from the last 7 days." ;
    oc:hasRationale "Generic news clutters the brief and makes it harder for reps to find actionable signals, defeating the purpose of a scannable prep document." ;
    oc:severityLevel "MEDIUM" .

