oc:skill_knowledge_work_plugins_email_sequence a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "email-sequence" ;
    skos:broader "Email sequence generator" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/email-sequence" ;
    oc:contentHash "e9899a095cf66e1ac8614f5f3f5a0e7f918323f613d2622822316729bc3b3255" ;
    oc:differentia "Produces complete multi-email drip campaigns with branching logic, timing, exit conditions, performance benchmarks, and A/B test suggestions across 8 lifecycle types" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "[sequence type]" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Design and draft multi-email sequences with full copy, timing, branching logic, exit conditions, and performance benchmarks. Use when building onboarding, lead nurture, re-engagement, win-back, or product launch flows, when you need a complete drip campaign with A/B test suggestions, or when mapping a sequence end-to-end with a flow diagram." ;
    oc:hasName "email-sequence" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Design and draft complete email sequences with full copy, timing, branching logic, and performance benchmarks for any lifecycle or campaign use case." ],
                [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "User runs `/email-sequence` or asks to create, design, build, or draft an email sequence, drip campaign, nurture flow, or onboarding series." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Trigger" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
