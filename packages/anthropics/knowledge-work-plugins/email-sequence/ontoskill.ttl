@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_email_sequence a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "email-sequence" ;
    skos:broader "Campaign design workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/email-sequence" ;
    oc:contentHash "e9899a095cf66e1ac8614f5f3f5a0e7f918323f613d2622822316729bc3b3255" ;
    oc:differentia "Produces multi-email lifecycle sequences with branching logic, performance benchmarks, and platform-specific deployment guidance" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "[sequence type]" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Design and draft multi-email sequences with full copy, timing, branching logic, exit conditions, and performance benchmarks. Use when building onboarding, lead nurture, re-engagement, win-back, or product launch flows, when you need a complete drip campaign with A/B test suggestions, or when mapping a sequence end-to-end with a flow diagram." ;
    oc:hasName "email-sequence" ;
    oc:impartsKnowledge oc:kn_3de9fac0,
        oc:kn_46414f74,
        oc:kn_4fbcb52d,
        oc:kn_4ff2d9d2,
        oc:kn_78a6718b,
        oc:kn_7fcce07d,
        oc:kn_fafa466c ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build nurture flow",
        "create email sequence",
        "create re-engagement campaign",
        "design drip campaign",
        "draft onboarding email series",
        "plan email sequence with branching logic" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_3de9fac0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When recommending sequence length and cadence" ;
    oc:directiveContent "Use the provided sequence type templates as starting frameworks (e.g., Onboarding: 5-7 emails over 14-21 days; Lead Nurture: 4-6 emails over 3-4 weeks) and adapt based on the user's specific goal and audience." ;
    oc:hasRationale "These templates encode proven patterns for each sequence type, ensuring appropriate pacing and content progression without requiring the user to start from scratch." ;
    oc:severityLevel "MEDIUM" .

oc:kn_46414f74 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing sequence logic and flow control" ;
    oc:directiveContent "Always define suppression rules: do not send if the recipient is in another active sequence, has unsubscribed, or has contacted support recently. Also define re-entry rules explicitly." ;
    oc:hasRationale "Without suppression and re-entry rules, recipients may receive conflicting messages, be spammed across sequences, or be permanently excluded when they should be eligible again." ;
    oc:severityLevel "HIGH" .

oc:kn_4fbcb52d a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no email marketing or CRM tools are available" ;
    oc:directiveContent "If no email marketing tools are connected, deliver all email content in copy-paste-ready format with a 5-step setup checklist for any platform." ;
    oc:hasRationale "The skill should provide value regardless of tool connectivity by ensuring the output is immediately actionable in any email platform." ;
    oc:severityLevel "LOW" .

oc:kn_4ff2d9d2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, at the start of every email sequence design" ;
    oc:directiveContent "Define the overall sequence architecture (narrative arc, journey mapping, escalation logic, success definition) before drafting any individual emails." ;
    oc:hasRationale "Starting with individual emails without a cohesive strategy leads to disjointed sequences that lack progression and fail to move recipients through a journey." ;
    oc:severityLevel "CRITICAL" .

oc:kn_78a6718b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting individual email body copy and CTAs" ;
    oc:directiveContent "Each email must have exactly one primary CTA. A secondary CTA is only acceptable if appropriate for the specific sequence stage." ;
    oc:hasRationale "Multiple competing CTAs dilute focus and reduce conversion rates by creating decision paralysis." ;
    oc:severityLevel "HIGH" .

oc:kn_7fcce07d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing preview text for each email" ;
    oc:directiveContent "Do not repeat the subject line content in the preview text. Preview text (40-90 characters) should complement the subject line by adding context or intrigue." ;
    oc:hasRationale "Repeating subject line content wastes the additional real estate that preview text provides in the inbox, missing an opportunity to increase open rates." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fafa466c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing subject lines for each email in the sequence" ;
    oc:directiveContent "Provide 2-3 subject line options per email varying approaches (curiosity, benefit-driven, urgency, personalization, question-based) and keep them under 50 characters where possible." ;
    oc:hasRationale "Subject lines under 50 characters avoid truncation on mobile devices, and varying approaches enables A/B testing to discover what resonates with the audience." ;
    oc:severityLevel "MEDIUM" .

