""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 22 ;
                            oc:sectionTitle "Sequence Overview Table" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 21 ;
                    oc:sectionTitle "Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Ask: \"Would you like me to:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Add a branching path for a specific scenario?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
