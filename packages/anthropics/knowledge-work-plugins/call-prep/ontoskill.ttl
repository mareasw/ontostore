@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_call_prep a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "call-prep" ;
    skos:broader "Sales preparation workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/call-prep" ;
    oc:contentHash "857146621907d34e6deeeb1235fb9fdb8ba2868417f4eda3d537333133985d5b" ;
    oc:dependsOnSkill oc:skill_account_research ;
    oc:differentia "that synthesizes account context, attendee research, news intelligence, and meeting-type-specific agendas into a structured call prep brief" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasArgumentHint "company name and meeting type (e.g., \"prep me for my call with Acme Corp, discovery call\")" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Prepare for a sales call with account context, attendee research, and suggested agenda. Works standalone with user input and web research, supercharged when you connect your CRM, email, chat, or transcripts. Trigger with \"prep me for my call with [company]\", \"I'm meeting with [company] prep me\", \"call prep [company]\", or \"get me ready for [meeting]\"." ;
    oc:hasName "call-prep" ;
    oc:impartsKnowledge oc:kn_1465f05f,
        oc:kn_57e91c44,
        oc:kn_600c76d9,
        oc:kn_69db8fe4,
        oc:kn_73a4eec9 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "anticipate objections before meeting",
        "create discovery questions for sales call",
        "generate call agenda",
        "prepare for sales call",
        "research meeting attendees" ;
    oc:yieldsState oc:CallPrepBriefGenerated .

oc:kn_1465f05f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — design all execution paths to degrade gracefully" ;
    oc:directiveContent "The skill must work standalone with just user input and web research, but gets significantly better when CRM, email, chat, or transcript connectors are available." ;
    oc:hasRationale "Not all users have connected tools; the skill must deliver value at every level of data availability" ;
    oc:severityLevel "HIGH" .

oc:kn_57e91c44 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Step 2 of every call prep execution" ;
    oc:directiveContent "Always run web research (news, funding, leadership changes, industry trends, attendee LinkedIn) regardless of connector availability — this supplements but does not replace connector data." ;
    oc:hasRationale "Web research fills gaps that internal systems cannot and provides current-market context that CRM data lacks" ;
    oc:severityLevel "MEDIUM" .

oc:kn_600c76d9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When connectors are available and gathering context from email/chat" ;
    oc:directiveContent "When querying email and chat connectors, limit searches to the last 30 days to balance relevance with information overload." ;
    oc:hasRationale "Beyond 30 days, retrieved data becomes noisy and less actionable for upcoming meeting preparation" ;
    oc:severityLevel "LOW" .

oc:kn_69db8fe4 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating the prep brief after gathering all context" ;
    oc:directiveContent "Tailor the agenda, discovery questions, and objection handling to the specific meeting type: discovery calls prioritize questions over talking, demos focus on use cases, negotiations address concerns, check-ins review wins." ;
    oc:hasRationale "A one-size-fits-all agenda fails to address the distinct goals and dynamics of different meeting types" ;
    oc:severityLevel "HIGH" .

oc:kn_73a4eec9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no connectors are available or as supplementary input" ;
    oc:directiveContent "More context input from the user (pasted emails, notes, attendee names/titles, stated goals, flagged concerns) directly improves the quality and specificity of the prep brief." ;
    oc:hasRationale "The skill's output quality is bounded by input richness; prompting users for more detail yields exponentially better results" ;
    oc:severityLevel "MEDIUM" .

