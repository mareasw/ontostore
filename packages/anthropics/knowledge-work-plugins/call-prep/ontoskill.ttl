    oc:contentHash "857146621907d34e6deeeb1235fb9fdb8ba2868417f4eda3d537333133985d5b" ;
    oc:differentia "that synthesizes account context, attendee research, and web intelligence into a structured call prep brief with tailored agenda, discovery questions, and objection handling" ;
    oc:extends oc:skill_ontoskills_account_research ;
