@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_brand_review a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "brand-review" ;
    skos:broader "Content review framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/brand-review" ;
    oc:contentHash "6ab887493f7ff057ee40ab4189b72b2435210b16046b82905259d741414e640a" ;
    oc:differentia "that evaluates marketing content against brand voice, style guidelines, messaging pillars, and legal/compliance standards with severity-rated findings and before/after fixes" ;
    oc:handlesFailure oc:ContentNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "<content to review>" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Review content against your brand voice, style guide, and messaging pillars, flagging deviations by severity with specific before/after fixes. Use when checking a draft before it ships, when auditing copy for voice consistency and terminology, or when screening for unsubstantiated claims, missing disclaimers, and other legal flags." ;
    oc:hasName "brand-review" ;
    oc:impartsKnowledge oc:kn_9844d6e7,
        oc:kn_ab30a7d2,
        oc:kn_c82e1bc7,
        oc:kn_d0fef916,
        oc:kn_d427743b,
        oc:kn_e1b910ab ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ContentProvided ;
    oc:resolvesIntent "audit copy for brand voice consistency",
        "check terminology and style guide compliance",
        "flag legal and compliance issues in marketing content",
        "review content against brand guidelines",
        "review content for clarity and professionalism without brand guidelines" ;
    oc:yieldsState oc:BrandReviewCompleted,
        oc:ComplianceFlagsGenerated .

oc:kn_9844d6e7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting review findings" ;
    oc:directiveContent "Do not flag issues without providing a specific before/after suggestion — every finding must include the location, severity rating, and a concrete revision." ;
    oc:hasRationale "Vague feedback ('this doesn't sound right') is not actionable; specific before/after fixes let the content creator immediately improve the content." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ab30a7d2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When classifying all review findings" ;
    oc:directiveContent "Severity ratings must follow a strict three-tier system: High (contradicts brand voice, compliance risk, or significantly undermines messaging), Medium (inconsistent with guidelines but not damaging), Low (minor style or preference issue)." ;
    oc:hasRationale "Inconsistent severity rating makes it impossible to prioritize fixes and undermines trust in the review process." ;
    oc:severityLevel "HIGH" .

oc:kn_c82e1bc7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "During every brand review execution" ;
    oc:directiveContent "Always check legal and compliance flags regardless of whether brand guidelines are configured — this includes unsubstantiated claims, missing disclaimers, comparative claims, regulatory language, testimonial issues, and copyright concerns." ;
    oc:hasRationale "Legal and compliance issues carry real-world risk (regulatory fines, lawsuits) and must never be skipped even in generic reviews without configured brand guidelines." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d0fef916 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When brand guidelines are configured and available" ;
    oc:directiveContent "Review content across five dimensions: voice and tone, terminology and language, messaging pillars, style guide compliance, and legal/compliance flags — each with specific evaluation criteria." ;
    oc:hasRationale "A comprehensive multi-dimensional review catches issues that a single-lens review would miss; skipping dimensions leads to inconsistent brand experiences." ;
    oc:severityLevel "HIGH" .

oc:kn_d427743b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting a brand review without configured guidelines" ;
    oc:directiveContent "If no brand guidelines are configured, ask the user for their guide and offer a generic review for clarity, consistency, and professionalism as a fallback." ;
    oc:hasRationale "Forcing users to have a formal brand guide excludes smaller teams; offering a meaningful generic review ensures the skill is always useful while encouraging documentation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e1b910ab a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating tone appropriateness across different content types" ;
    oc:directiveContent "Brand voice stays consistent while tone adapts to context — voice attributes are fixed but their intensity dials up or down based on channel (blog, social, email) and situation (launch, incident, onboarding)." ;
    oc:hasRationale "Confusing voice consistency with tone rigidity leads to content that feels either robotic (same tone everywhere) or off-brand (different voices per channel)." ;
    oc:severityLevel "HIGH" .

