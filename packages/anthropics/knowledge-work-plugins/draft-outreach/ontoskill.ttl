@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_draft_outreach a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "draft-outreach" ;
    skos:broader "outreach composition skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/draft-outreach" ;
    oc:contentHash "a349f81bc7c0c1d277810dcb2b4dba377b7cfb67e8b7b0f7be6125b0ac0119a9" ;
    oc:differentia "researches a prospect first then drafts personalized outreach messages across email and LinkedIn channels with configurable company settings" ;
    oc:handlesFailure oc:InsufficientResearchData,
        oc:ProspectNotFound ;
    oc:hasArgumentHint "person or company name, e.g. \"draft outreach to John Smith at Acme\", \"write cold email to Acme's CTO\", \"reach out to sarah@acme.com\"" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Research a prospect then draft personalized outreach. Uses web research by default, supercharged with enrichment and CRM. Trigger with \"draft outreach to [person/company]\", \"write cold email to [prospect]\", \"reach out to [name]\"." ;
    oc:hasName "draft-outreach" ;
    oc:impartsKnowledge oc:kn_0494db37,
        oc:kn_177b1a22,
        oc:kn_3a4e5ebf,
        oc:kn_4f9a4aa5,
        oc:kn_896c072c,
        oc:kn_b5b66283,
        oc:kn_f648fe76 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "create LinkedIn connection message for outreach",
        "draft follow-up sequence for outreach",
        "draft personalized outreach to a prospect",
        "research prospect and compose outreach message",
        "write cold email to a person or company" ;
    oc:yieldsState oc:OutreachDraftCreated .

oc:kn_0494db37 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When deciding the delivery channel for outreach" ;
    oc:directiveContent "Select channel based on available contact info: prefer email if verified email is available, fall back to LinkedIn connection request if no email, suggest mutual connection outreach first if a warm intro is possible." ;
    oc:hasRationale "Email has higher response rates for direct outreach; LinkedIn works when email is unavailable; warm intros through mutual connections are the strongest approach" .

oc:kn_177b1a22 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring the email body for any outreach scenario" ;
    oc:directiveContent "Use AIDA structure for emails: Attention (personal hook), Interest (their problem/opportunity), Desire (proof point), Action (clear low-friction CTA). One value prop, one ask." ;
    oc:hasRationale "AIDA is a proven framework for persuasive writing; single value prop and CTA reduce cognitive load and increase response rates" .

oc:kn_3a4e5ebf a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting email body content" ;
    oc:directiveContent "Never use markdown formatting (asterisks, bold, italic, headers) in email drafts. Write plain text that renders naturally in any email client." ;
    oc:hasRationale "Markdown formatting does not render in most email clients and appears as raw asterisks, making the email look unprofessional" ;
    oc:severityLevel "HIGH" .

oc:kn_4f9a4aa5 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before drafting any outreach message" ;
    oc:directiveContent "Always research the prospect before drafting any outreach message. Never send generic outreach." ;
    oc:hasRationale "Personalized outreach based on research dramatically improves response rates compared to generic messages" ;
    oc:severityLevel "CRITICAL" .

oc:kn_896c072c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing the opening of any outreach message" ;
    oc:directiveContent "Never use generic openers like 'I hope this email finds you well', 'I'm reaching out because...', or 'I wanted to introduce myself'. Avoid fake personalization like 'I noticed you work at [Company]' without deeper context." ;
    oc:hasRationale "Generic and fake-personalized openers signal mass outreach and immediately reduce credibility with the recipient" ;
    oc:severityLevel "HIGH" .

oc:kn_b5b66283 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying the personalization angle for outreach" ;
    oc:directiveContent "Prioritize hooks in this order: (1) Trigger event, (2) Mutual connection, (3) Their content, (4) Company initiative, (5) Role-based pain point. Use the highest-priority hook available from research." ;
    oc:hasRationale "Trigger events are most timely and relevant; role-based pain points are least personal but still viable when no better hook exists" .

oc:kn_f648fe76 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting subject lines, LinkedIn messages, and email body paragraphs" ;
    oc:directiveContent "Email subjects must be under 50 characters with no spam-trigger words. LinkedIn connection requests must be under 300 characters. Email paragraphs must be 2-3 sentences max." ;
    oc:hasRationale "Short subjects avoid spam filters and increase open rates; LinkedIn limits connection requests to 300 chars; short paragraphs respect busy readers' attention" ;
    oc:severityLevel "MEDIUM" .

