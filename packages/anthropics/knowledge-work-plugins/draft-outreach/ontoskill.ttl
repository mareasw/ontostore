        oc:KnowledgeNode ;
    oc:appliesToContext "When composing email drafts" ;
    oc:directiveContent "Follow AIDA structure for emails: Attention (personal hook), Interest (their problem/opportunity), Desire (proof point from similar company), Action (clear low-friction CTA). Subject lines must be under 50 characters with no spam words." ;
    oc:hasRationale "AIDA is a proven framework for outreach; short subject lines avoid spam filters and increase open rates" .

oc:kn_9bb8219e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying the personalization angle for outreach" ;
    oc:directiveContent "Prioritize hooks in this order: (1) Trigger event (funding, hiring, news), (2) Mutual connection, (3) Their content (post, article, talk), (4) Company initiative, (5) Role-based pain point." ;
    oc:hasRationale "Trigger events are most timely and relevant; role-based pain points are least personal but still work as fallback" .

oc:kn_9d94c603 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When choosing outreach channel" ;
    oc:directiveContent "Channel selection: if verified email is available, prefer email (higher response rate) with LinkedIn backup. If no email, use LinkedIn connection request + follow-up template. If warm intro is possible, suggest mutual connection outreach first." ;
    oc:hasRationale "Email has higher response rates but requires a verified address; warm intros through mutual connections have the highest conversion" .

oc:kn_9daad691 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any outreach message" ;
    oc:directiveContent "Research must always happen before drafting. Never draft generic outreach — every message must be grounded in prospect-specific research findings." ;
    oc:hasRationale "Generic outreach has extremely low response rates; personalization from research is the core value of this skill" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b2fed057 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing email body text" ;
    oc:directiveContent "Never use markdown formatting (asterisks, bold, italic, headers) in email drafts. Write plain text only that renders naturally in any email client." ;
    oc:hasRationale "Email clients do not render markdown; asterisks and formatting symbols appear as raw text and look unprofessional" ;
    oc:severityLevel "HIGH" .

oc:kn_be9111e5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any outreach message opening" ;
    oc:directiveContent "Avoid generic openers: 'I hope this email finds you well', 'I'm reaching out because...', 'I wanted to introduce myself'. Also avoid feature dumps, multiple value props at once, and fake personalization like 'I noticed you work at [Company]'." ;
    oc:hasRationale "These patterns signal mass-sent spam and immediately reduce credibility and response rates" ;
    oc:severityLevel "HIGH" .

oc:kn_f35d3eeb a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no tool connectors are configured" ;
    oc:directiveContent "If no connectors (Enrichment, CRM, Email) are available, fall back to web research only. Output the email text for the user to copy manually." ;
    oc:hasRationale "The skill must remain useful even without integrations; web research alone provides enough for personalization" .

_:ref_3ec0eb4ea409f405 a oc:WorkflowStep ;
    dcterms:description "**Simple lists** — If listing items, use plain dashes. No fancy formatting." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_4827a6bc6663ba54 a oc:WorkflowStep ;
    dcterms:description "**Be concise but informative** — Get to the point quickly. Busy people skim." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_d82ef3a0e8d7110d a oc:WorkflowStep ;
    dcterms:description "**No markdown formatting** — Never use asterisks, bold (**text**), or other markdown. Write plain text that looks natural in any email client." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_fe37c4ffef6e504d a oc:WorkflowStep ;
    dcterms:description "**Short paragraphs** — 2-3 sentences max per paragraph. White space is your friend." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_636602d3a1af63da a oc:WorkflowStep ;
    dcterms:description "Parse user request to identify target prospect (person name, company, role, email, or LinkedIn URL)" ;
    oc:expectedOutcome "Target prospect identified with available identifiers" ;
    oc:stepId "parse-request" .

