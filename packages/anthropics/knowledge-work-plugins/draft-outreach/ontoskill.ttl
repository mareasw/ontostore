oc:kn_5da432c4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting LinkedIn outreach" ;
    oc:directiveContent "LinkedIn connection requests must be under 300 characters. Do not include a pitch in the connection request." ;
    oc:hasRationale "LinkedIn enforces the 300-char limit; pitching before connection is established reduces acceptance rates" ;
    oc:severityLevel "HIGH" .

