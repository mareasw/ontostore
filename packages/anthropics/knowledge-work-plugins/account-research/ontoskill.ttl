@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_account_research a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "account-research" ;
    skos:broader "Research methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/account-research" ;
    oc:contentHash "29702c22dcd010d0697e36eafb28a043adef14cd79c1269e8c41a44be648940e" ;
    oc:differentia "that aggregates company and person intelligence from web search, enrichment APIs, and CRM data into actionable sales insights" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "\"company or person name (e.g., 'Research Stripe', 'Look up John Smith at Acme')\"" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Research a company or person and get actionable sales intel. Works standalone with web search, supercharged when you connect enrichment tools or your CRM. Trigger with \"research [company]\", \"look up [person]\", \"intel on [prospect]\", \"who is [name] at [company]\", or \"tell me about [company]\"." ;
    oc:hasName "account-research" ;
    oc:impartsKnowledge oc:kn_492bcf67,
        oc:kn_55665371,
        oc:kn_7822b9a5,
        oc:kn_787d709e,
        oc:kn_c439999e ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "find company overview and hiring signals",
        "get sales intel on a prospect",
        "identify qualification signals for outreach",
        "look up a person",
        "research a company",
        "research before a sales call" ;
    oc:yieldsState oc:AccountResearched .

oc:kn_492bcf67 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When executing Step 2 (web search phase) for any company research" ;
    oc:directiveContent "Run 7 specific web searches in sequence: homepage/about, news, funding, careers, LinkedIn profiles, product, and customers to build comprehensive coverage." ;
    oc:hasRationale "These 7 search angles cover the key intelligence dimensions needed for sales preparation: company identity, momentum, investment, growth, people, offering, and market." ;
    oc:severityLevel "MEDIUM" .

oc:kn_55665371 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning web searches" ;
    oc:directiveContent "Parse the request to identify the research type (company, person, role-based, or domain-based) before executing searches, to avoid wasted queries." ;
    oc:hasRationale "Correctly identifying the target type determines which of the 7 search queries are relevant and avoids unnecessary API calls." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7822b9a5 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always, during execution" ;
    oc:directiveContent "Executing this skill triggers multiple web searches and optionally calls enrichment APIs and CRM systems, consuming API credits and generating network traffic." ;
    oc:hasRationale "Agents should be aware this is a resource-intensive operation that may consume rate-limited API calls." ;
    oc:severityLevel "LOW" .

oc:kn_787d709e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing any research request" ;
    oc:directiveContent "Always run web searches as the baseline; enrichment and CRM data are optional layers that enhance but are never required." ;
    oc:hasRationale "The skill must work standalone with web search alone, ensuring value delivery without external dependencies." ;
    oc:severityLevel "HIGH" .

oc:kn_c439999e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Step 5 synthesis when multiple data sources are available" ;
    oc:directiveContent "Prioritize enrichment data over web search results when synthesizing, as enrichment data is more accurate and verified." ;
    oc:hasRationale "Enrichment APIs provide verified, structured data that is more reliable than scraped web information." ;
    oc:severityLevel "MEDIUM" .

