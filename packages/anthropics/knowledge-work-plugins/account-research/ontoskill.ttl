oc:kn_0eb7bc9a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When executing any account research request" ;
    oc:directiveContent "Always run web searches first (7-query pattern: company homepage, news, funding, careers, person LinkedIn, product, customers). Then conditionally layer enrichment and CRM data if connectors are available." ;
    oc:hasRationale "Web search is the universal baseline that always works; enrichment and CRM are additive layers that improve quality but are not required." ;
    oc:severityLevel "HIGH" .

oc:kn_3483e1ff a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting news and announcements from web search results" ;
    oc:directiveContent "Recent news should be limited to the last 90 days to ensure relevance and actionability." ;
    oc:hasRationale "Older news is less likely to represent current strategic priorities or trigger events for outreach." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6741367e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When receiving a research request" ;
    oc:directiveContent "Parse the request type before searching: company-only → company research, person + company → person + company research, role-based → role-based search, domain-only → domain lookup." ;
    oc:hasRationale "Different request types require different search strategies and output emphasis to produce the most relevant intel." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a708bd78 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When estimating resource usage for a research request" ;
    oc:directiveContent "This skill consumes multiple web search queries (typically 7 per company) and may call enrichment APIs and CRM systems if connected." ;
    oc:hasRationale "Accounting for API calls helps manage rate limits and cost expectations, especially for batch research." ;
    oc:severityLevel "LOW" .

oc:kn_c9dd341e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing research from multiple sources" ;
    oc:directiveContent "Prioritize enrichment data over web search results when both are available — enrichment sources are more accurate for firmographics, contact info, and tech stack." ;
    oc:hasRationale "Enrichment APIs provide verified, structured data while web search results can be outdated or inconsistent." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ca3cc865 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formulating or refining a research request" ;
    oc:directiveContent "Include the domain for precision, specify the person by full name and title, state your goal, and ask for specifics after initial research to get the best results." ;
    oc:hasRationale "Precise inputs yield more targeted and actionable research outputs, reducing noise and irrelevant data." ;
    oc:severityLevel "LOW" .

oc:kn_f8bcf632 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When validating research completeness before delivering to user" ;
    oc:directiveContent "A successful research output includes: Quick Take (2-3 sentence summary), Company Profile table, Recent News with outreach relevance, Hiring Signals, Key People with talking points, Qualification Signals (positive/concerns/unknowns), and Recommended Approach with discovery questions." ;
    oc:hasRationale "This structure ensures all critical sales intelligence dimensions are covered and the output is immediately actionable." ;
    oc:severityLevel "HIGH" .

