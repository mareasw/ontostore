@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_risk_assessment a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "risk-assessment" ;
    skos:broader "Assessment methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/risk-assessment" ;
    oc:contentHash "a3948309b9b003102e7d6d184653552d8cefc774e6a6e30bb67e6ed382ff2b1f" ;
    oc:differentia "that systematically identifies, categorizes, and prioritizes operational risks with likelihood-impact scoring and actionable mitigations" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "project, process, vendor, or decision context to assess risks for" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Identify, assess, and mitigate operational risks. Trigger with \"what are the risks\", \"risk assessment\", \"risk register\", \"what could go wrong\", or when the user is evaluating risks associated with a project, vendor, process, or decision." ;
    oc:hasName "risk-assessment" ;
    oc:impartsKnowledge oc:kn_0e1d1efa,
        oc:kn_7f9f0093,
        oc:kn_887518fc,
        oc:kn_b89cd776,
        oc:kn_f5de8cec ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "assess operational risks",
        "create risk register",
        "evaluate project risks",
        "identify risks",
        "mitigate risks",
        "perform risk assessment" ;
    oc:yieldsState oc:RiskRegisterCreated .

oc:kn_0e1d1efa a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying and cataloging risks" ;
    oc:directiveContent "Categorize risks into at least one of six domains: Operational, Financial, Compliance, Strategic, Reputational, or Security." ;
    oc:hasRationale "Structured categorization prevents blind spots and ensures comprehensive coverage across all material risk domains." .

oc:kn_7f9f0093 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoring individual risks" ;
    oc:directiveContent "Risks are rated on a three-point scale (High / Medium / Low) for both likelihood and impact — do not use numeric or five-point scales." ;
    oc:hasRationale "The skill's matrix is defined for a 3x3 grid; using different scales would produce undefined risk levels and inconsistent prioritization." ;
    oc:severityLevel "HIGH" .

oc:kn_887518fc a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When assessing any risk" ;
    oc:directiveContent "Use the 3x3 likelihood-impact matrix to classify each risk as Critical, High, Medium, or Low — always derive the risk level from the intersection of independent likelihood and impact ratings." ;
    oc:hasRationale "A consistent scoring framework ensures risks are comparable and prioritized objectively rather than by gut feel." ;
    oc:severityLevel "HIGH" .

oc:kn_b89cd776 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When documenting any risk in the register" ;
    oc:directiveContent "Every risk entry must include: description, likelihood, impact, risk level, mitigation strategy, owner, and status (Open / Mitigated / Accepted / Closed)." ;
    oc:hasRationale "Complete entries ensure accountability and trackability, enabling ongoing risk management rather than a one-time snapshot." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f5de8cec a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When producing the final prioritized risk register" ;
    oc:directiveContent "Focus the risk register on risks that are both controllable and material — avoid listing trivial or purely theoretical risks." ;
    oc:hasRationale "Bloated registers dilute attention from actionable risks and reduce the utility of the assessment for decision-makers." ;
    oc:severityLevel "MEDIUM" .

