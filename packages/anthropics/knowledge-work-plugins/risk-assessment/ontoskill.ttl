@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_knowledge_work_plugins_risk_assessment a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "risk-assessment" ;
    skos:broader "Assessment framework" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/risk-assessment" ;
    oc:contentHash "a3948309b9b003102e7d6d184653552d8cefc774e6a6e30bb67e6ed382ff2b1f" ;
    oc:differentia "that systematically identifies, evaluates, and plans mitigations for operational risks using a likelihood-impact matrix" ;
    oc:handlesFailure oc:InsufficientContext ;
    oc:hasArgumentHint "project, process, vendor, or decision to assess risks for" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Identify, assess, and mitigate operational risks. Trigger with \"what are the risks\", \"risk assessment\", \"risk register\", \"what could go wrong\", or when the user is evaluating risks associated with a project, vendor, process, or decision." ;
    oc:hasName "risk-assessment" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: risk-assessment
description: Identify, assess, and mitigate operational risks. Trigger with "what are the risks", "risk assessment", "risk register", "what could go wrong", or when the user is evaluating risks associated with a project, vendor, process, or decision.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Systematically identify, assess, and plan mitigations for operational risks." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "For each risk, document:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Likelihood**: High / Medium / Low" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Owner**: Who is responsible for managing this risk" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Mitigation**: What we're doing to reduce likelihood or impact" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Impact**: High / Medium / Low" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Description**: What could happen" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "**Status**: Open / Mitigated / Accepted / Closed" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Risk Level**: Critical / High / Medium / Low" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Risk Register Format" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 3 ;
                            oc:tableCaption "## Risk Assessment Matrix" ;
                            oc:tableMarkdown """| | Low Impact | Medium Impact | High Impact |
|---|-----------|---------------|-------------|
| **High Likelihood** | Medium | High | Critical |
| **Medium Likelihood** | Low | Medium | High |
| **Low Likelihood** | Low | Low | Medium |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Risk Assessment Matrix" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Produce a prioritized risk register with specific, actionable mitigations. Focus on risks that are controllable and material." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Strategic**: Market changes, competitive threats, technology shifts" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Financial**: Budget overruns, vendor cost increases, revenue impact" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Security**: Data breaches, access control failures, third-party vulnerabilities" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Compliance**: Regulatory violations, audit findings, policy breaches" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Reputational**: Customer impact, public perception, partner relationships" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Operational**: Process failures, staffing gaps, system outages" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Risk Categories" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Risk Assessment" ] ;
    oc:impartsKnowledge oc:kn_427b31ce,
        oc:kn_5eee3bed,
        oc:kn_650c712f,
        oc:kn_8b384294,
        oc:kn_b65668f2,
        oc:kn_e7d13dea ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ContextDefined ;
    oc:resolvesIntent "assess operational risks",
        "create a risk register",
        "evaluate risk severity and mitigations",
        "identify risks in a project or decision",
        "mitigate operational risks" ;
    oc:yieldsState oc:RiskRegisterCreated .

oc:kn_427b31ce a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting risks in the register" ;
    oc:directiveContent "Every risk entry must include: Description, Likelihood, Impact, Risk Level, Mitigation, Owner, and Status" ;
    oc:hasRationale "Incomplete risk records reduce traceability and accountability, making mitigations untrackable" ;
    oc:severityLevel "HIGH" .

oc:kn_5eee3bed a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When prioritizing the risk register" ;
    oc:directiveContent "Focus on risks that are both controllable and material — deprioritize low-impact accepted risks and uncontrollable externalities" ;
    oc:hasRationale "Attention and resources are finite; concentrate effort where mitigation actions can actually reduce exposure" .

oc:kn_650c712f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing mitigation plans for any risk" ;
    oc:directiveContent "Mitigations must be specific and actionable — avoid vague statements like 'monitor the situation' or 'be careful'" ;
    oc:hasRationale "Vague mitigations provide false confidence and cannot be verified or assigned" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8b384294 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When classifying any identified risk" ;
    oc:directiveContent "Risk Level = Matrix[likelihood][impact] where likelihood ∈ {High, Medium, Low} and impact ∈ {High, Medium, Low}. Combinations: (High×Low=Medium), (High×Med=High), (High×High=Critical), (Med×Low=Low), (Med×Med=Medium), (Med×High=High), (Low×Low=Low), (Low×Med=Low), (Low×High=Medium)" ;
    oc:hasRationale "Provides a consistent, repeatable severity classification that avoids subjective bias" .

oc:kn_b65668f2 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When producing the final risk assessment output" ;
    oc:directiveContent """## Risk Register
For each risk:
- **Description**: {what could happen}
- **Likelihood**: High / Medium / Low
- **Impact**: High / Medium / Low
- **Risk Level**: Critical / High / Medium / Low
- **Mitigation**: {action to reduce likelihood or impact}
- **Owner**: {responsible party}
- **Status**: Open / Mitigated / Accepted / Closed""" ;
    oc:templateVariables "Description",
        "Impact",
        "Likelihood",
        "Mitigation",
        "Owner",
        "Risk Level",
        "Status" .

oc:kn_e7d13dea a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When brainstorming or cataloging risks" ;
    oc:directiveContent "Always cover all six risk categories: Operational, Financial, Compliance, Strategic, Reputational, and Security" ;
    oc:hasRationale "Ensures comprehensive coverage and prevents blind spots from category tunnel vision" .

