                                            oc:itemOrder 3 ;
                                            oc:itemText "Conversion channels (search, retargeting) will always look bad in first-touch models" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
