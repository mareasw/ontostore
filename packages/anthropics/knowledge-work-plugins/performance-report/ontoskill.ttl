                        [ a oc:Section ;
                            oc:hasContent _:ref_01e105e23ff159bd,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "When analyzing performance data, look for:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 27 ;
                            oc:sectionTitle "Trend Identification" ],
