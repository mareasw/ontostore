                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Scenario modeling**: create best case, expected case, and worst case projections" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Moving average**: smooth out noise by averaging the last 3-6 periods" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Linear projection**: extend the current trend line forward (useful for stable metrics)" ] ] ;
