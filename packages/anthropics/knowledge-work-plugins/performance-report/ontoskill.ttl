@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_performance_report a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "performance-report" ;
    skos:broader "Report generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/performance-report" ;
    oc:contentHash "ace8e35fae33b2678c85771492c2b3b936c96c0db696d18d3f265853a8577845" ;
    oc:differentia "Builds marketing performance reports with metrics dashboards, trend analysis, wins/misses, and prioritized optimization recommendations across channels and cadences" ;
    oc:handlesFailure oc:DataNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "<time period or campaign>" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Build a marketing performance report with key metrics, trend analysis, wins and misses, and prioritized optimization recommendations. Use when wrapping a campaign, when preparing weekly, monthly, or quarterly channel summaries for stakeholders, or when you need data translated into an executive summary with next-period priorities." ;
    oc:hasName "performance-report" ;
    oc:impartsKnowledge oc:kn_06f8090a,
        oc:kn_182e03d6,
        oc:kn_68a987c7,
        oc:kn_7bce3a77,
        oc:kn_8f15696d,
        oc:kn_90adce00,
        oc:kn_b46eb7aa ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DataAvailable ;
    oc:resolvesIntent "analyze campaign results",
        "analyze marketing trends and provide optimization recommendations",
        "build channel performance summary",
        "create weekly monthly or quarterly marketing report",
        "generate marketing performance report",
        "produce executive marketing metrics dashboard" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_06f8090a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating optimization recommendations" ;
    oc:directiveContent "Use the 2x2 impact-vs-effort matrix to prioritize recommendations: high-impact/low-effort first, high-impact/high-effort next sprint, low-impact/low-effort if time allows, low-impact/high-effort deprioritize." ;
    oc:hasRationale "Systematic prioritization ensures the team acts on the most valuable improvements first rather than spreading effort thinly" ;
    oc:severityLevel "MEDIUM" .

oc:kn_182e03d6 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any performance report generation" ;
    oc:directiveContent "Determine report type (campaign, channel, content, overall, custom), time period, data source availability, comparison period, and stakeholder audience before generating the report." ;
    oc:hasRationale "Missing any of these inputs produces a report that doesn't match stakeholder needs or lacks necessary context for meaningful analysis" ;
    oc:severityLevel "HIGH" .

oc:kn_68a987c7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making optimization recommendations based on attribution data" ;
    oc:directiveContent "Do not optimize one channel in isolation based on single-touch attribution. Awareness channels always look bad in last-touch models and conversion channels look bad in first-touch models." ;
    oc:hasRationale "Single-touch attribution gives a distorted view of channel effectiveness, leading to budget misallocation and strategic errors" ;
    oc:severityLevel "HIGH" .

oc:kn_7bce3a77 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When recommending A/B tests or experiments" ;
    oc:directiveContent "Test one variable at a time, define success metrics before launching, calculate required sample size, run tests for a minimum of one full business cycle, and document all results regardless of outcome." ;
    oc:hasRationale "Rigorous testing methodology produces reliable results; ending tests early or testing multiple variables produces unreliable conclusions" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8f15696d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing trend analysis and forecasting" ;
    oc:directiveContent "Forecasts based on fewer than 12 data points should be flagged as low confidence. Always present forecasts as ranges, not exact numbers. Short-term forecasts (1-3 months) are more reliable than long-term." ;
    oc:hasRationale "Insufficient data points produce unreliable trend extrapolation; presenting exact numbers creates false precision that misleads stakeholders" ;
    oc:severityLevel "MEDIUM" .

oc:kn_90adce00 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any metrics dashboard or executive summary" ;
    oc:directiveContent "Lead with metrics that map to business objectives, not vanity metrics. Show trends over time with comparison context (prior period, target, benchmark)." ;
    oc:hasRationale "Vanity metrics mislead stakeholders; business-aligned metrics drive actionable decisions and accountability" ;
    oc:severityLevel "HIGH" .

oc:kn_b46eb7aa a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When analyzing what needs improvement and making recommendations" ;
    oc:directiveContent "Follow the 7-step optimization process: Identify underperforming metrics, Diagnose funnel location, Hypothesize causes, Prioritize fixes by impact/effort, Test with one variable at a time, Measure results, Scale or iterate." ;
    oc:hasRationale "Structured optimization prevents knee-jerk reactions and ensures changes are data-validated before scaling" ;
    oc:severityLevel "MEDIUM" .

