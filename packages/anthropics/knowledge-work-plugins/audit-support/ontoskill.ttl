oc:skill_anthropics_knowledge_work_plugins_audit_support a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "audit-support" ;
    skos:broader "SOX 404 compliance methodology framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/audit-support" ;
    oc:contentHash "2f2d42fb50b50d5f0081326612616a96a4c127030102de06e26c79f6294139a1" ;
    oc:differentia "provides control testing methodology, sample selection approaches, documentation standards, and deficiency classification for internal audit support" ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Support SOX 404 compliance with control testing methodology, sample selection, and documentation standards. Use when generating testing workpapers, selecting audit samples, classifying control deficiencies, or preparing for internal or external audits." ;
    oc:hasName "audit-support" ;
    oc:hasRequirement oc:req_1bfd0750,
        oc:req_6abf679b,
        oc:req_a03d65b6,
        oc:req_fd92f2f1 ;
    oc:impartsKnowledge oc:kn_139fe59a,
        oc:kn_1f190cb2,
        oc:kn_26fc6eb7,
        oc:kn_6eb1f998,
        oc:kn_cc649419,
        oc:kn_e0aebd68,
        oc:kn_e555d75f ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "classify control deficiencies",
        "document control testing results",
        "evaluate design and operating effectiveness of controls",
        "generate testing workpapers",
        "plan SOX 404 compliance scoping and risk assessment",
        "prepare for internal or external audits",
        "select audit samples" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_139fe59a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, before any output is treated as authoritative audit guidance" ;
    oc:directiveContent "This skill does not provide audit or legal advice. All testing workpapers and assessments must be reviewed by qualified financial professionals before reliance." ;
    oc:hasRationale "AI-generated audit documentation carries professional liability risk and must be validated by credentialed professionals to meet regulatory standards." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1f190cb2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating and classifying control deficiencies" ;
    oc:directiveContent "Aggregate individually minor deficiencies within the same process or affecting the same assertion to evaluate whether their combined effect constitutes a significant deficiency or material weakness. Consider whether deficiencies in compensating controls exacerbate other deficiencies." ;
    oc:hasRationale "Individual deficiencies may appear inconsequential in isolation but could represent a material control failure when viewed holistically, as required by auditing standards." ;
    oc:severityLevel "HIGH" .

oc:kn_26fc6eb7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When testing automated or IT-dependent manual controls" ;
    oc:directiveContent "For automated controls, if system configuration has not changed, one test is typically sufficient for the period, supplemented by ITGC testing of change management. For IT-dependent manual controls, test both the manual control and the completeness and accuracy of the underlying system-generated data (IPE)." ;
    oc:hasRationale "Automated controls don't vary per transaction if configuration is stable, so re-testing each instance is redundant. IT-dependent controls are only as reliable as the data they consume, so IPE testing is essential." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6eb1f998 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating evidence for control testing" ;
    oc:directiveContent "Never accept verbal confirmations alone, undated documents, evidence without identifiable performer/approver, generic system reports without timestamps, or 'per discussion with [name]' without corroboration as sufficient audit evidence." ;
    oc:hasRationale "Insufficient evidence undermines the reliability of the control test conclusion and will not withstand external auditor scrutiny or regulatory review." ;
    oc:severityLevel "HIGH" .

oc:kn_cc649419 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoping significant accounts for SOX 404 testing" ;
    oc:directiveContent "An account is significant if there is more than a remote likelihood it could contain a misstatement that is material individually or in aggregate. Evaluate both quantitative factors (balance exceeding 3-5% of a key benchmark, high transaction volume, significant estimates) and qualitative factors (complex accounting, fraud susceptibility, prior misstatements, management judgment)." ;
    oc:hasRationale "Proper scoping ensures testing effort is focused on accounts where control failures could result in material misstatements, avoiding both over-testing and under-testing." ;
    oc:severityLevel "HIGH" .

oc:kn_e0aebd68 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting audit samples for control testing" ;
    oc:directiveContent "Use random selection as the default for transaction-level controls with large populations. Use targeted selection to supplement for risk-based items (high-dollar, unusual, period-end, related-party, manual override, new vendors/customers). Use systematic selection for even period coverage. Increase sample sizes for higher inherent risk, sole controls addressing significant risks, prior deficiencies, new controls, or external auditor reliance." ;
    oc:hasRationale "Appropriate sample selection balances statistical defensibility with risk-focused efficiency, ensuring conclusions about control effectiveness are well-supported." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e555d75f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When documenting any control test" ;
    oc:directiveContent "Every control test workpaper must include: control identification (ID, description, type, frequency, risk/assertion), test design (objective, procedures, expected evidence, sample methodology), test execution (population description, sample details, pass/fail results per item, exceptions), conclusion (overall assessment, basis, impact, compensating controls), and sign-off (tester and reviewer with dates)." ;
    oc:hasRationale "Complete documentation is required for regulatory compliance, supports external auditor reliance on management testing, and provides defensible evidence of control effectiveness." ;
    oc:severityLevel "HIGH" .

oc:req_1bfd0750 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "COSO internal control framework" .

oc:req_6abf679b a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Audit sampling methodology" .

oc:req_a03d65b6 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Internal controls over financial reporting (ICFR) concepts" .

oc:req_fd92f2f1 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "SOX Section 404 compliance requirements" .

