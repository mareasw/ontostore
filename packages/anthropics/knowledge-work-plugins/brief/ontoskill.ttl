@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_brief a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "brief" ;
    skos:broader "Briefing generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/brief" ;
    oc:contentHash "9375883fd027589eb0201c1c9d76dbc2bbc274fe3dca47604bf866e6def48d59" ;
    oc:differentia "that synthesizes legal-relevant information from multiple connected enterprise sources (email, calendar, chat, CLM, CRM) into structured daily, topic, or incident briefings" ;
    oc:extends oc:skill_search ;
    oc:handlesFailure oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "[daily | topic <query> | incident <topic>]" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Generate contextual briefings for legal work — daily summary, topic research, or incident response. Use when starting your day and need a scan of legal-relevant items across email, calendar, and contracts, when researching a specific legal question across internal sources, or when a developing situation (data breach, litigation threat, regulatory inquiry) needs rapid context." ;
    oc:hasName "brief" ;
    oc:impartsKnowledge oc:kn_122db4a5,
        oc:kn_1736fe3b,
        oc:kn_2a570fbb,
        oc:kn_345f454a,
        oc:kn_365066c3,
        oc:kn_6b8e316a,
        oc:kn_9c4dc051,
        oc:kn_b3393dc1,
        oc:kn_c4eb401c ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "brief on a legal incident or developing situation",
        "generate daily legal briefing",
        "prepare morning legal summary",
        "research a legal topic across internal sources",
        "scan legal-relevant items across email calendar and contracts" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_122db4a5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a topic brief requires current legal authority or case law" ;
    oc:directiveContent "For topic briefs requiring current legal authority or case law, recommend the user consult a legal research platform (Westlaw, Lexis) or outside counsel rather than relying solely on internal sources." ;
    oc:hasRationale "Internal sources do not contain up-to-date case law or statutes; formal legal research requires specialized platforms to ensure accuracy and currency." ;
    oc:severityLevel "HIGH" .

oc:kn_1736fe3b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any briefing output" ;
    oc:directiveContent "Keep briefs concise. Link to source materials rather than reproducing them in full." ;
    oc:hasRationale "Legal professionals are time-constrained and need to scan quickly. Reproducing full source content wastes space and makes the briefing harder to act on." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2a570fbb a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always during source scanning phase" ;
    oc:directiveContent "The skill scans across multiple connected enterprise sources (email, calendar, chat, CLM, CRM) which may trigger notifications or logging in those systems." ;
    oc:hasRationale "Enterprise systems may log access patterns; repeated automated scanning could trigger security alerts or audit logs." ;
    oc:severityLevel "LOW" .

oc:kn_345f454a a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When producing topic briefs" ;
    oc:directiveContent "Topic briefs synthesize what is available in connected sources but do not substitute for formal legal research. Always note the limitations of the sources searched." ;
    oc:hasRationale "Connected enterprise sources may have incomplete coverage, and formal legal research requires specialized databases and methodologies beyond what this skill provides." ;
    oc:severityLevel "MEDIUM" .

oc:kn_365066c3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When any connected source fails or is unavailable" ;
    oc:directiveContent "If sources are unavailable, note the gaps prominently so the user knows what was not checked." ;
    oc:hasRationale "Users may make incorrect assumptions about completeness if gaps are not surfaced. Hidden gaps in source coverage can lead to missed critical items." ;
    oc:severityLevel "HIGH" .

oc:kn_6b8e316a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, for all brief modes" ;
    oc:directiveContent "This skill assists with legal workflows but does not provide legal advice. Briefings should be reviewed by qualified legal professionals before being relied upon." ;
    oc:hasRationale "AI-generated briefings are not a substitute for professional legal judgment and could lead to liability if relied upon without review." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9c4dc051 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any briefing output" ;
    oc:directiveContent "Briefs should be actionable: every item should have a clear next step or reason for inclusion." ;
    oc:hasRationale "Legal professionals need to know what to do with each item, not just what happened. Unactionable items waste time and reduce trust in the briefing." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b3393dc1 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When generating incident briefs, especially for data breaches, litigation threats, or regulatory inquiries" ;
    oc:directiveContent "For incident briefs involving potential litigation, flag litigation hold and preservation obligations immediately. Mark the brief as attorney-client privileged / work product if appropriate." ;
    oc:hasRationale "Failure to flag preservation obligations can result in spoliation of evidence. Privilege designations protect the confidentiality of legal communications." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c4eb401c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating incident briefs for developing legal situations" ;
    oc:directiveContent "For incident briefs, speed matters. Produce the brief quickly with available information rather than waiting for complete information." ;
    oc:hasRationale "Legal incidents like data breaches have regulatory notification deadlines (e.g., 72 hours for GDPR). Delayed briefings can result in missed deadlines and increased liability." ;
    oc:severityLevel "HIGH" .

