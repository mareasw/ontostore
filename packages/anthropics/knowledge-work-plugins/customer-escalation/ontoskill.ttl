    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "assess business impact of a support issue",
        "create an escalation brief",
        "escalate a customer issue",
        "escalate to leadership for high-impact issue",
        "package a bug report for engineering" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_13cf2fd9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After an escalation has been submitted" ;
    oc:directiveContent "Follow up proactively after escalation based on severity: Critical every 2 hours, High every 4 hours, Medium daily. Update the customer even when there is no new information." ;
    oc:hasRationale "Escalate-and-forget erodes customer trust; proactive updates maintain ownership of the customer relationship and prevent duplicate escalations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1d893f3c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing any escalation brief" ;
    oc:directiveContent "Never escalate without quantifying impact — vague escalations get deprioritized by receiving teams." ;
    oc:hasRationale "Engineering and leadership teams triage by severity; without concrete numbers, the escalation loses priority to better-documented ones." ;
    oc:severityLevel "HIGH" .

oc:kn_2ea353ca a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the 'What's Needed' section of an escalation brief" ;
    oc:directiveContent "Be explicit about what you need: 'investigate' vs. 'fix' vs. 'decide' are different asks. Always set and communicate a deadline — urgency without a deadline is ambiguous." ;
    oc:hasRationale "Clear asks with deadlines enable the receiving team to prioritize and schedule work; ambiguous requests get deprioritized." ;
    oc:severityLevel "HIGH" .

oc:kn_302571ef a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When an escalation no longer warrants elevated attention" ;
    oc:directiveContent "De-escalate when the root cause is support-resolvable, a workaround is found, the issue resolves itself, or new information changes severity. Always notify the receiving team, update the ticket, inform the customer, and document learnings." ;
    oc:hasRationale "Failure to de-escalate wastes engineering/leadership time and signals poor judgment in future escalations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_642665ee a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "Before initiating any escalation" ;
    oc:directiveContent "Do not escalate issues that have documented solutions, known workarounds, are configuration/setup issues, require only guidance/training, or are known limitations with documented alternatives." ;
    oc:hasRationale "Premature escalation wastes specialized resources and damages credibility for future escalations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6c2d83e7 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When a security-related issue is identified in a support context" ;
    oc:directiveContent "Escalations involving potential data exposure, unauthorized access, or compliance concerns must include: what was observed, who/what is affected, containment steps already taken, and urgency assessment." ;
    oc:hasRationale "Incomplete security escalations delay containment and increase breach scope." ;
    oc:severityLevel "CRITICAL" .

oc:kn_80a1de9f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When potential data exposure, unauthorized access, vulnerability, or compliance concern is identified" ;
    oc:directiveContent "Security escalations bypass normal tier progression — escalate immediately regardless of current support level." ;
    oc:hasRationale "Security incidents have compounding risk; delays in notification can increase breach scope and regulatory liability." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a4198aeb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring reproduction steps for any bug escalation" ;
    oc:directiveContent "Reproduction steps are the single most valuable element in a bug escalation — they must start from a clean state, include exact values, note the environment, capture frequency, and document what has been ruled out." ;
    oc:hasRationale "Engineering cannot efficiently investigate without precise repro steps; vague steps lead to back-and-forth and delayed resolution." ;
    oc:severityLevel "HIGH" .

