oc:skill_anthropics_knowledge_work_plugins_customer_escalation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "customer-escalation" ;
    skos:broader "escalation packaging workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/customer-escalation" ;
    oc:contentHash "bcc5ed9f32ad4897ca87b0470e9df0b72a57dd9b7ad18722977e73413245f50f" ;
    oc:differentia "that structures support issues into severity-assessed briefs with business impact, reproduction steps, and tiered routing to engineering, product, security, or leadership" ;
    oc:hasArgumentHint "\"<issue summary> [customer name]\"" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Package an escalation for engineering, product, or leadership with full context. Use when a bug needs engineering attention beyond normal support, multiple customers report the same issue, a customer is threatening to churn, or an issue has sat unresolved past its SLA." ;
    oc:hasName "customer-escalation" ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:resolvesIntent "assess issue severity and impact",
        "create escalation brief",
        "escalate customer issue",
        "escalate to leadership",
        "package escalation for engineering",
        "route support escalation to correct team" .

