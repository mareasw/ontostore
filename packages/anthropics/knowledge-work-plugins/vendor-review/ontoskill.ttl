@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_vendor_review a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "vendor-review" ;
    skos:broader "Vendor evaluation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/vendor-review" ;
    oc:contentHash "1aaa63395f5b6aa09f437ea3e9ec703fdc1fc895e50a0189e74359b6d593906c" ;
    oc:differentia "that produces structured cost analysis, risk assessment, and procurement recommendations with negotiation points" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "Glob",
        "Grep",
        "Read",
        "WebSearch" ;
    oc:hasArgumentHint "<vendor name or proposal>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Evaluate a vendor — cost analysis, risk assessment, and recommendation. Use when reviewing a new vendor proposal, deciding whether to renew or replace a contract, comparing two vendors side-by-side, or building a TCO breakdown and negotiation points before procurement sign-off." ;
    oc:hasName "vendor-review" ;
    oc:impartsKnowledge oc:kn_2d0b6045,
        oc:kn_32f6d87c,
        oc:kn_a151de54,
        oc:kn_aba5fbf6,
        oc:kn_d11c19dc ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "assess vendor total cost of ownership",
        "build negotiation points for procurement",
        "compare vendors side-by-side",
        "evaluate a vendor proposal",
        "review vendor contract for renewal" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_2d0b6045 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any vendor cost analysis" ;
    oc:directiveContent "Always analyze Total Cost of Ownership (TCO), not just license fees — include implementation, migration, training, ongoing support, maintenance, and exit costs." ;
    oc:hasRationale "Focusing only on license fees understates the true financial commitment and leads to poor procurement decisions." ;
    oc:severityLevel "HIGH" .

oc:kn_32f6d87c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When evaluating multiple vendors against each other" ;
    oc:directiveContent "Produce a side-by-side comparison matrix covering pricing, features, integrations, security, support, contract terms, and references when comparing vendors." ;
    oc:hasRationale "Structured comparison ensures all evaluation dimensions are consistently addressed and decision-makers can quickly identify trade-offs." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a151de54 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When connectors (knowledge base, procurement) are available" ;
    oc:directiveContent "Leverage connected knowledge base and procurement tools to pull existing contracts, spend history, performance reviews, and procurement policies before generating recommendations." ;
    oc:hasRationale "Historical data and organizational policies provide critical context that improves the accuracy and relevance of the vendor evaluation." .

oc:kn_aba5fbf6 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any vendor review" ;
    oc:directiveContent "Confirm vendor name, evaluation context (new/renewal/comparison), and available details (contract terms, pricing, proposal documents, performance data) before starting analysis." ;
    oc:hasRationale "Incomplete inputs lead to generic evaluations that lack the specificity needed for actionable procurement decisions." .

oc:kn_d11c19dc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating any new vendor contract" ;
    oc:directiveContent "Do not skip exit cost analysis — data migration out and contract termination fees must be quantified before signing." ;
    oc:hasRationale "Ignoring exit costs creates vendor lock-in risk and can make future transitions prohibitively expensive." ;
    oc:severityLevel "HIGH" .

