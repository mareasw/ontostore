oc:kn_21c94629 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When comparing two or more vendors" ;
    oc:directiveContent "Use a side-by-side comparison matrix covering pricing, features, integrations, security, support, contract terms, and references when comparing multiple vendors." ;
    oc:hasRationale "Structured comparison eliminates subjective bias and ensures all evaluation criteria are consistently applied" .

oc:kn_40d3a614 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating a vendor renewal" ;
    oc:directiveContent "For renewal decisions, include current spend data to properly evaluate price changes and negotiate from an informed position." ;
    oc:hasRationale "Without baseline spend data, renewal negotiations lack leverage and price increases go unchallenged" .

oc:kn_6f4c1539 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing cost analysis for any vendor evaluation" ;
    oc:directiveContent "Evaluate vendors on Total Cost of Ownership (TCO), not just license fees — include implementation, migration, training, support, maintenance, and exit costs." ;
    oc:hasRationale "Hidden costs beyond licensing often dominate the true expense and determine ROI accuracy" .

oc:kn_8fc1701e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, during any vendor risk assessment" ;
    oc:directiveContent "Risk assessment must cover at minimum: vendor financial stability, security/compliance posture, concentration risk, contract lock-in/exit terms, and business continuity/disaster recovery." ;
    oc:hasRationale "Incomplete risk assessment leads to vendor decisions that expose the organization to operational, financial, or compliance failures" ;
    oc:severityLevel "HIGH" .

oc:kn_f3f5bbe7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any vendor review" ;
    oc:directiveContent "Gather vendor name, evaluation context (new/renewal/comparison), and available details (contract terms, pricing, proposal document, performance data) before starting the evaluation." ;
    oc:hasRationale "Incomplete input leads to superficial analysis and unreliable recommendations" .

oc:kn_fa3e585f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating total cost of ownership" ;
    oc:directiveContent "Do not ignore exit costs (data migration, contract termination fees) when evaluating a vendor — these create hidden lock-in and future switching costs." ;
    oc:hasRationale "Ignoring exit costs leads to vendor lock-in and makes future transitions prohibitively expensive" ;
    oc:severityLevel "MEDIUM" .

_:ref_77666c61720a38de a oc:WorkflowStep ;
    dcterms:description "**Include current spend** — For renewals, knowing what you pay now helps evaluate price changes." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_b79a7759dfaac861 a oc:WorkflowStep ;
    dcterms:description "**Upload the proposal** — I can extract pricing, terms, and SLAs from vendor documents." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_e9a53467faf5d6e4 a oc:WorkflowStep ;
    dcterms:description "**Compare vendors** — \"Compare Vendor A vs Vendor B\" gets you a side-by-side analysis." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_3d017ee235907a0f a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_77666c61720a38de,
        _:ref_b79a7759dfaac861,
        _:ref_e9a53467faf5d6e4 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_87a9f36e2db7e19f a oc:WorkflowStep ;
    dcterms:description "Perform Total Cost of Ownership analysis including license, implementation, migration, training, support, maintenance, and exit costs" ;
    oc:expectedOutcome "Complete TCO breakdown with annualized costs over 1-year and 3-year horizons" ;
    oc:stepDependsOn _:ref_4cd8e2a834d0722b ;
    oc:stepId "cost-analysis" .

_:ref_a09d8ff1246a0718 a oc:WorkflowStep ;
    dcterms:description "Assess SLA compliance, support response times, uptime/reliability, feature delivery cadence, and customer satisfaction" ;
    oc:expectedOutcome "Performance metrics summary with benchmarks" ;
    oc:stepDependsOn _:ref_4cd8e2a834d0722b ;
    oc:stepId "performance-review" .

_:ref_b389e3c3dfc10fab a oc:WorkflowStep ;
    dcterms:description "Evaluate vendor risks: financial stability, security/compliance, concentration risk, lock-in/exit terms, and business continuity" ;
    oc:expectedOutcome "Risk matrix with likelihood, impact, and mitigation strategies" ;
    oc:stepDependsOn _:ref_4cd8e2a834d0722b ;
    oc:stepId "risk-assessment" .

_:ref_4cd8e2a834d0722b a oc:WorkflowStep ;
    dcterms:description "Collect vendor name, evaluation context (new/renewal/comparison), and available details (contract terms, pricing, proposal documents, performance data)" ;
    oc:expectedOutcome "All available vendor information is assembled for analysis" ;
    oc:stepId "gather-input" .

