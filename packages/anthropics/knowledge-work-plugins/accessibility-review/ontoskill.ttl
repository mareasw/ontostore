oc:kn_405b5157 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When evaluating Figma-based designs with connector access" ;
    oc:directiveContent "If a design tool connector is available, inspect color values, font sizes, and touch targets directly from Figma specs for more accurate measurements." ;
    oc:hasRationale "Direct design tool inspection provides precise values rather than estimates from screenshots or descriptions" .

oc:kn_50def05c a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "During the final stage of the audit" ;
    oc:directiveContent "Zoom the page to 200% and verify the layout does not break — this is a baseline robustness check." ;
    oc:hasRationale "WCAG requires content remain functional at 200% zoom; layout breakage at this level is a common accessibility failure" .

oc:kn_7e5ea9e3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "After completing the automated and checklist-based audit" ;
    oc:directiveContent "Test with real assistive technology (VoiceOver, NVDA) in addition to the audit — manual testing catches issues the audit cannot." ;
    oc:hasRationale "Assistive technology testing reveals real-world usage barriers that checklist-based audits cannot predict" ;
    oc:severityLevel "MEDIUM" .

oc:kn_874a92f2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning an accessibility audit" ;
    oc:directiveContent "Start with contrast and keyboard testing — these catch the most common and impactful accessibility issues first." ;
    oc:hasRationale "Contrast and keyboard issues are the most frequently encountered barriers and affect the largest number of users" ;
    oc:severityLevel "MEDIUM" .

oc:kn_96caf90b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting the accessibility audit" ;
    oc:directiveContent "Verify the design or page is accessible for inspection — either via Figma URL, live URL, or sufficient description of elements to audit." ;
    oc:hasRationale "Without access to the actual design or page, the audit cannot evaluate real contrast ratios, dimensions, or interactive behavior" ;
    oc:severityLevel "HIGH" .

oc:kn_d06be110 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating any design or page against WCAG 2.1 AA" ;
    oc:directiveContent "WCAG 2.1 AA requires: contrast ratio ≥ 4.5:1 for normal text, ≥ 3:1 for large text and non-text UI components; touch targets ≥ 44x44 CSS pixels; all functionality keyboard-operable; visible focus indicators; logical focus order." ;
    oc:hasRationale "These are hard pass/fail thresholds defined by the WCAG 2.1 AA standard" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e2e7e390 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When triaging accessibility findings" ;
    oc:directiveContent "Prioritize fixes by user impact — fix issues that completely block users first (critical), then those that significantly degrade experience (major), then polish items (minor)." ;
    oc:hasRationale "Blocking issues prevent users from completing tasks entirely, while minor issues are quality-of-life improvements" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ff41a76c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any accessibility audit" ;
    oc:directiveContent "Relying solely on automated scans for accessibility auditing — they only catch ~30% of issues. Always supplement with keyboard navigation, screen reader testing, and manual contrast verification." ;
    oc:hasRationale "Automated tools miss most accessibility issues including keyboard traps, semantic structure problems, and screen reader behavior" ;
    oc:severityLevel "HIGH" .

