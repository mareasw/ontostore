@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_accessibility_review a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "accessibility-review" ;
    skos:broader "Accessibility audit methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/accessibility-review" ;
    oc:contentHash "d7a31a408e79b7c8fa03b237ad684c6bff387ef906bcd16ee347c894daac7e19" ;
    oc:differentia "that evaluates designs and pages against WCAG 2.1 AA standards with structured severity-based findings across perceivable, operable, understandable, and robust categories" ;
    oc:handlesFailure oc:DesignOrPageNotFound,
        oc:InsufficientAccessToDesign ;
    oc:hasArgumentHint "<Figma URL, URL, or description>" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Run a WCAG 2.1 AA accessibility audit on a design or page. Trigger with \"audit accessibility\", \"check a11y\", \"is this accessible?\", or when reviewing a design for color contrast, keyboard navigation, touch target size, or screen reader behavior before handoff." ;
    oc:hasName "accessibility-review" ;
    oc:impartsKnowledge oc:kn_44ac46ce,
        oc:kn_486f3797,
        oc:kn_5f3cccc7,
        oc:kn_69398575,
        oc:kn_a92173b3,
        oc:kn_c5726079 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DesignOrPageAvailable ;
    oc:resolvesIntent "audit accessibility of a design or page",
        "check WCAG 2.1 AA compliance",
        "generate accessibility audit report with severity ratings",
        "identify accessibility issues before design handoff",
        "review color contrast and keyboard navigation" ;
    oc:yieldsState oc:AccessibilityAuditComplete,
        oc:AccessibilityIssuesDocumented .

oc:kn_44ac46ce a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning any accessibility audit" ;
    oc:directiveContent "Start with contrast and keyboard testing — these catch the most common and impactful accessibility issues." ;
    oc:hasRationale "Contrast and keyboard issues affect the largest number of users and are the most frequently violated WCAG criteria, making them the highest-value starting point." ;
    oc:severityLevel "HIGH" .

oc:kn_486f3797 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When performing any accessibility audit" ;
    oc:directiveContent "Evaluate against all four WCAG 2.1 AA principles: Perceivable (contrast, alt text, semantics), Operable (keyboard, focus, touch targets), Understandable (predictable behavior, error identification, labels), and Robust (name/role/value for UI components)." ;
    oc:hasRationale "WCAG 2.1 AA is structured around these four principles to ensure comprehensive coverage of accessibility concerns across all user disability types." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5f3cccc7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When conducting accessibility audits" ;
    oc:directiveContent "Do not rely solely on automated scans — manual testing with real assistive technology (VoiceOver, NVDA) is required to catch issues automated tools miss." ;
    oc:hasRationale "Automated tools catch only ~30% of issues; many critical problems like focus traps, illogical tab order, and missing ARIA roles require human or screen reader testing." ;
    oc:severityLevel "MEDIUM" .

oc:kn_69398575 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning the testing approach for an accessibility audit" ;
    oc:directiveContent "Automated scanning only catches approximately 30% of accessibility issues; manual testing with keyboard navigation, screen readers (VoiceOver, NVDA), and color contrast verification is essential." ;
    oc:hasRationale "Automated tools cannot detect many accessibility problems (e.g., logical focus order, meaningful alt text, ARIA landmark correctness), so relying solely on them gives a false sense of compliance." ;
    oc:severityLevel "HIGH" .

oc:kn_a92173b3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting accessibility audit results and remediation recommendations" ;
    oc:directiveContent "Prioritize findings by user impact — fix issues that block users first (critical), then those that degrade experience (major), then polish items (minor)." ;
    oc:hasRationale "Not all accessibility issues are equal; severity-based prioritization ensures the most harmful barriers are removed first, maximizing the impact of limited remediation resources." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c5726079 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting an accessibility audit" ;
    oc:directiveContent "Before auditing, verify that you have access to color values, font sizes, touch target dimensions, and component structure — either from Figma/design tool or from the live page." ;
    oc:hasRationale "Accurate accessibility evaluation requires precise measurements (e.g., contrast ratios need exact foreground/background colors, touch targets need pixel dimensions) that cannot be reliably estimated visually." ;
    oc:severityLevel "MEDIUM" .

