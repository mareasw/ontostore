@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_compliance_check a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "compliance-check" ;
    skos:broader "Compliance assessment framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/compliance-check" ;
    oc:contentHash "55b26fab97c3be566391eba2dc842c8a9a5522724e27bc6e2f250563106dc11e" ;
    oc:differentia "surfaces applicable regulations, required approvals, and risk areas for proposed actions, product features, and business initiatives" ;
    oc:handlesFailure oc:InsufficientContext,
        oc:InvalidInput ;
    oc:hasArgumentHint "<action or initiative to check>" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Run a compliance check on a proposed action, product feature, or business initiative, surfacing applicable regulations, required approvals, and risk areas. Use when launching a feature that touches personal data, when marketing or product proposes something with regulatory implications, or when you need to know which approvals and jurisdictional requirements apply before proceeding." ;
    oc:hasName "compliance-check" ;
    oc:impartsKnowledge oc:kn_0ad45286,
        oc:kn_13ddb62f,
        oc:kn_4ff6deb1,
        oc:kn_5e54dcad,
        oc:kn_9f6daf86 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "assess regulatory risk for a product feature",
        "check compliance of a proposed action",
        "determine approvals needed for data processing activities",
        "identify applicable regulations for a business initiative",
        "review compliance requirements before launching a campaign" ;
    oc:yieldsState oc:ComplianceAssessed .

oc:kn_0ad45286 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When gathering input from the user before running a compliance check" ;
    oc:directiveContent "Provide specific descriptions including the geography and personal data types involved. 'We want to email all our EU users' is better than 'marketing campaign.'" ;
    oc:hasRationale "Compliance requirements are driven by jurisdiction and data types. Vague descriptions lead to incomplete or inaccurate regulatory assessments." ;
    oc:severityLevel "HIGH" .

oc:kn_13ddb62f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating compliance check output" ;
    oc:directiveContent "Structure output as: Summary assessment, Applicable Regulations table, Requirements table, Risk Areas table, Recommended Actions, Approvals Needed, and Further Review sections." ;
    oc:hasRationale "Structured tabular output enables stakeholders to quickly identify regulatory obligations, risks, and next steps in a standardized format." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4ff6deb1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When producing compliance assessment results" ;
    oc:directiveContent "Do not treat the compliance check output as final approval. Always flag areas requiring specialist or outside counsel review in the 'Further Review Recommended' section." ;
    oc:hasRationale "Complex regulatory environments require domain-specific expertise. Omitting escalation recommendations can create false confidence and legal exposure." ;
    oc:severityLevel "HIGH" .

oc:kn_5e54dcad a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any compliance check" ;
    oc:directiveContent "Before running the check, identify the jurisdictions involved, the types of personal data at issue, and the nature of the proposed action. These three inputs drive regulatory applicability." ;
    oc:hasRationale "Without jurisdiction, data type, and action specificity, the compliance check cannot correctly determine which regulations apply (GDPR, CCPA/CPRA, LGPD, PIPL, etc.)." ;
    oc:severityLevel "HIGH" .

oc:kn_9f6daf86 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when presenting any compliance check output" ;
    oc:directiveContent "This skill assists with legal workflows but does not provide legal advice. Compliance assessments must be reviewed by qualified legal professionals." ;
    oc:hasRationale "AI-generated compliance analysis is not a substitute for professional legal counsel; regulatory requirements change frequently and require expert verification." ;
    oc:severityLevel "CRITICAL" .

