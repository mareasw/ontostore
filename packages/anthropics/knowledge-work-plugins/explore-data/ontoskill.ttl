oc:kn_1355d487 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When recommending dimensions and metrics for slicing data" ;
    oc:directiveContent "Best dimension columns have 3-50 distinct values. Best metric columns have meaningful numeric distributions. Best time columns have continuous coverage without gaps." ;
    oc:hasRationale "Cardinality in the 3-50 range balances granularity with interpretability for grouping/filtering" .

oc:kn_450ccef8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When profiling large datasets" ;
    oc:directiveContent "For very large tables (100M+ rows), use sampling for profiling queries rather than full table scans. Mention when counts are approximate vs exact." ;
    oc:hasRationale "Full scans on large tables are prohibitively expensive; sampling provides statistically valid profiles at lower cost" ;
    oc:severityLevel "MEDIUM" .

oc:kn_67cd6783 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When generating the final output" ;
    oc:directiveContent "A successful profile includes: overview stats (rows, columns, date range), column details summary table, data quality issues flagged with severity, and 3-5 recommended follow-up analyses." ;
    oc:hasRationale "Consistent output format ensures the profile is immediately actionable and covers all critical dimensions" .

oc:kn_9bb69a9e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When first encountering any new dataset" ;
    oc:directiveContent "Never assume data quality is good — always profile before analyzing. Watch for: placeholder values (0, -1, 999999, 'N/A', 'TBD', 'test'), mixed case in categoricals, trailing whitespace, numbers stored as strings, and round number bias." ;
    oc:hasRationale "Hidden data quality issues silently corrupt downstream analyses and lead to incorrect conclusions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a4ff5a02 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When exploring schema in a PostgreSQL data warehouse" ;
    oc:codeLanguage "sql" ;
    oc:directiveContent """-- List all tables in a schema (PostgreSQL)
SELECT table_name, table_type FROM information_schema.tables WHERE table_schema = 'public' ORDER BY table_name;

-- Column details
SELECT column_name, data_type, is_nullable, column_default FROM information_schema.columns WHERE table_name = 'my_table' ORDER BY ordinal_position;

-- Table sizes
SELECT relname, pg_size_pretty(pg_total_relation_size(relid)) FROM pg_catalog.pg_statio_user_tables ORDER BY pg_total_relation_size(relid) DESC;""" .

oc:kn_df9f4b83 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When understanding dataset structure" ;
    oc:directiveContent "Classify every column into one of 7 types: Identifier, Dimension, Metric, Temporal, Text, Boolean, or Structural. This classification drives all downstream profiling logic." ;
    oc:hasRationale "Column classification determines which profiling checks apply (numeric stats vs string patterns vs date ranges)" .

oc:kn_fc782097 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When profiling any new dataset" ;
    oc:directiveContent "1. Access data (warehouse query or file load) → 2. Understand structure (rows, grain, PK, column classification) → 3. Generate data profile (null rates, distinct counts, distributions per column type) → 4. Identify data quality issues (nulls, cardinality surprises, suspicious values, duplicates, skew) → 5. Discover relationships and patterns (FKs, hierarchies, correlations, derived columns) → 6. Suggest dimensions and metrics → 7. Recommend 3-5 follow-up analyses" ;
    oc:stepOrder 1 .

oc:kn_fd2bdd6f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assessing column completeness" ;
    oc:directiveContent "Columns with >5% nulls should be flagged as warn; >20% nulls flagged as alert. Completeness tiers: Green (>99%), Yellow (95-99%), Orange (80-95%), Red (<80%)." ;
    oc:hasRationale "Null rate thresholds provide a standardized quality benchmark for deciding whether a column is usable for analysis" ;
    oc:severityLevel "HIGH" .

