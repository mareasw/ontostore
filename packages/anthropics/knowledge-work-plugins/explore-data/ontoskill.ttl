                                _:ref_91bd62af50e631f4,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "**If neither:**" ] ;
                            oc:sectionLevel 3 ;
