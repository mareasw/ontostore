                            oc:sectionTitle "1. Access the Data" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Workflow" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "The quality flags are heuristic -- not every flag is a real problem, but each is worth a quick look" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "For very large tables (100M+ rows), profiling queries use sampling by default -- mention if you need exact counts" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
