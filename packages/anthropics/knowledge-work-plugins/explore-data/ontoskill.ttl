oc:skill_knowledge_work_plugins_explore_data a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "explore-data" ;
    skos:broader "Data profiling tool" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/explore-data" ;
    oc:contentHash "b035a3b2645c231bd80006d32053fc0fc05c5dc90213b8ad5a69706b0bb4a101" ;
    oc:differentia "generates comprehensive quality, structure, and pattern analysis of datasets before deeper analysis" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "<table or file>" ;
    oc:hasCategory "data-analysis" ;
    oc:hasDescription "Profile and explore a dataset to understand its shape, quality, and patterns. Use when encountering a new table or file, checking null rates and column distributions, spotting data quality issues like duplicates or suspicious values, or deciding which dimensions and metrics to analyze." ;
    oc:hasName "explore-data" ;
    oc:hasRequirement oc:req_03f281e8,
        oc:req_96d88b72,
        oc:req_f847b958 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Generate a comprehensive data profile for a table or uploaded file. Understand its shape, quality, and patterns before diving into analysis." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Looking for segments with significantly different behavior" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Testing whether segments are homogeneous or contain sub-segments" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Finding categorical columns with 3-20 distinct values" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Comparing metric distributions across segment values" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Identify natural segments by:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 20 ;
                            oc:sectionTitle "Segmentation Discovery" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "For time series data, look for:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "**Anomalies**: Individual data points that break the pattern" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Day-of-week effects**: Weekday vs. weekend differences" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Change points**: Sudden shifts in level or trend" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Holiday effects**: Drops or spikes around known holidays" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Seasonality**: Repeating patterns (weekly, monthly, quarterly, annual)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Trend**: Sustained upward or downward movement" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 19 ;
                            oc:sectionTitle "Temporal Patterns" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Normal**: Mean and median are close, bell-shaped" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Skewed right**: Long tail of high values (common for revenue, session duration)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "**Uniform**: Roughly equal frequency across range (often synthetic or random)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Skewed left**: Long tail of low values (less common)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Bimodal**: Two peaks (suggests two distinct populations)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Power law**: Few very large values, many small ones (common for user activity)" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "For numeric columns, characterize the distribution:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 18 ;
                            oc:sectionTitle "Distribution Analysis" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Between numeric columns:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Flag strong correlations (|r| > 0.7) for investigation" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Check for non-linear relationships (e.g., quadratic, logarithmic)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Compute correlation matrix for all metric pairs" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Note: Correlation does not imply causation -- flag this explicitly" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 21 ;
                            oc:sectionTitle "Correlation Exploration" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 17 ;
                    oc:sectionTitle "Pattern Discovery Techniques" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "When connected to a data warehouse, use these patterns to discover schema:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """-- List all tables in a schema (PostgreSQL)
SELECT table_name, table_type
FROM information_schema.tables
WHERE table_schema = 'public'
ORDER BY table_name;

-- Column details (PostgreSQL)
SELECT column_name, data_type, is_nullable, column_default
FROM information_schema.columns
WHERE table_name = 'my_table'
ORDER BY ordinal_position;

-- Table sizes (PostgreSQL)
SELECT relname, pg_size_pretty(pg_total_relation_size(relid))
FROM pg_catalog.pg_statio_user_tables
ORDER BY pg_total_relation_size(relid) DESC;

-- Row counts for all tables (general pattern)
-- Run per-table: SELECT COUNT(*) FROM table_name
""" ;
                                    oc:codeLanguage "sql" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 289-309" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 24 ;
                            oc:sectionTitle "Schema Exploration Queries" ],
                        [ a oc:Section ;
                            oc:hasContent _:ref_001d354f0650c9f7,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "When exploring an unfamiliar data environment:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 25 ;
                            oc:sectionTitle "Lineage and Dependencies" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "When documenting a dataset for team use:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """## Table: [schema.table_name]

**Description**: [What this table represents]
**Grain**: [One row per...]
**Primary Key**: [column(s)]
**Row Count**: [approximate, with date]
**Update Frequency**: [real-time / hourly / daily / weekly]
**Owner**: [team or person responsible]

### Key Columns

| Column | Type | Description | Example Values | Notes |
|--------|------|-------------|----------------|-------|
| user_id | STRING | Unique user identifier | "usr_abc123" | FK to users.id |
| event_type | STRING | Type of event | "click", "view", "purchase" | 15 distinct values |
| revenue | DECIMAL | Transaction revenue in USD | 29.99, 149.00 | Null for non-purchase events |
| created_at | TIMESTAMP | When the event occurred | 2024-01-15 14:23:01 | Partitioned on this column |

### Relationships
- Joins to `users` on `user_id`
- Joins to `products` on `product_id`
- Parent of `event_details` (1:many on event_id)

### Known Issues
- [List any known data quality issues]
- [Note any gotchas for analysts]

### Common Query Patterns
- [Typical use cases for this table]
""" ;
                                    oc:codeLanguage "markdown" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 253-283" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 23 ;
                            oc:sectionTitle "Schema Documentation Template" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 22 ;
                    oc:sectionTitle "Schema Understanding and Documentation" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Type inconsistency**: Numbers stored as strings, dates in various formats" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Referential integrity**: Foreign keys that don't match any parent record" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Value format inconsistency**: Same concept represented differently (\"USA\", \"US\", \"United States\", \"us\")" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Cross-column consistency**: Status = \"completed\" but completed_at is null" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Business rule violations**: Negative quantities, end dates before start dates, percentages > 100" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Look for:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 14 ;
                            oc:sectionTitle "Consistency Checks" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Default values**: Suspiciously high frequency of a single value" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Impossible values**: Ages > 150, dates in the far future, negative durations" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Round number bias**: All values ending in 0 or 5 (suggests estimation, not measurement)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Stale data**: Updated_at shows no recent changes in an active system" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Placeholder values**: 0, -1, 999999, \"N/A\", \"TBD\", \"test\", \"xxx\"" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Red flags that suggest accuracy issues:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 15 ;
                            oc:sectionTitle "Accuracy Indicators" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Incomplete** (80-95%): Orange -- understand why and whether it matters" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Mostly complete** (95-99%): Yellow -- investigate the nulls" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Sparse** (<80%): Red -- may not be usable without imputation" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Complete** (>99% non-null): Green" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Rate each column:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 13 ;
                            oc:sectionTitle "Completeness Score" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Is there a lag between event time and load time?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "What is the expected update frequency?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "When was the table last updated?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Are there gaps in the time series?" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 16 ;
                            oc:sectionTitle "Timeliness Assessment" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 12 ;
                    oc:sectionTitle "Quality Assessment Framework" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "\"Correlation analysis between [metric_a] and [metric_b]\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "\"Data quality investigation on [problematic_column]\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "\"Cohort analysis using [date_column] and [status_column]\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "\"Trend analysis on [metric] by [time_column] grouped by [dimension]\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "\"Distribution deep-dive on [skewed_column] to understand outliers\"" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Suggest 3-5 specific analyses the user could run next:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 10 ;
                            oc:sectionTitle "7. Recommend Follow-Up Analyses" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 5 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "**Boolean**: True/false flags" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Metric**: Quantitative values for measurement (revenue, count, duration, score)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Text**: Free-form text fields (description, notes, name)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "**Structural**: JSON, arrays, nested structures" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Temporal**: Dates and timestamps (created_at, updated_at, event_date)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Identifier**: Unique keys, foreign keys, entity IDs" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Dimension**: Categorical attributes for grouping/filtering (status, type, region, category)" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Before analyzing any data, understand its structure:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "When was the data last updated?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "What is the primary key? Is it unique?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "How many rows and columns?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "How far back does the data go?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "What is the grain (one row per what)?" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Table-level questions:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Column classification** — categorize each column as one of:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "2. Understand Structure" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 10 ;
                                    oc:textContent "**Date/timestamp columns:**" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """min length, max length, avg length
empty string count
pattern analysis (do values follow a format?)
case consistency (all upper, all lower, mixed?)
leading/trailing whitespace count
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 9 ;
                                    oc:sourceLocation "lines 85-91" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 12 ;
                                    oc:textContent "**Boolean columns:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "**Numeric columns (metrics):**" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """min, max, mean, median (p50)
standard deviation
percentiles: p1, p5, p25, p75, p95, p99
zero count
negative count (if unexpected)
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 7 ;
                                    oc:sourceLocation "lines 76-82" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Table-level metrics:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Run the following profiling checks:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """true count, false count, null count
true rate
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 13 ;
                                    oc:sourceLocation "lines 103-106" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 14 ;
                                    oc:textContent "**Present the profile as a clean summary table**, grouped by column type (dimensions, metrics, dates, IDs)." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**All columns:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 8 ;
                                    oc:textContent "**String columns (dimensions, text):**" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """min date, max date
null dates
future dates (if unexpected)
distribution by month/week
gaps in time series
""" ;
                                    oc:codeLanguage "" ;
