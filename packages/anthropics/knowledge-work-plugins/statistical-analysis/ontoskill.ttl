    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "analyze distributions and compute descriptive statistics",
        "analyze trends and forecast metrics",
        "compute correlations and assess statistical claims",
        "detect outliers and anomalies in data",
        "perform hypothesis testing and interpret significance" .

oc:kn_0697ed29 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When analyzing aggregated metrics across heterogeneous groups" ;
    oc:directiveContent "Beware of Simpson's Paradox: a trend in aggregated data can reverse when segmented. Always check whether conclusions hold across key segments." ;
    oc:hasRationale "Aggregate trends can be entirely misleading when group composition differs" ;
    oc:severityLevel "HIGH" .

oc:kn_186828f2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting hypothesis test results" ;
    oc:directiveContent "Always report effect size, confidence interval, and business impact alongside p-values. Statistical significance without practical significance is meaningless, especially with large samples." ;
    oc:hasRationale "Large samples can produce statistically significant but practically trivial differences" ;
    oc:severityLevel "HIGH" .

oc:kn_645f6b8b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reporting correlation or association results" ;
    oc:directiveContent "Do not claim causation from correlation. When finding a correlation, explicitly consider reverse causation, confounding variables, and coincidence. State 'X has 30% higher retention' not 'X causes 30% higher retention' without controlled evidence." ;
    oc:hasRationale "Causal claims from observational data are one of the most common statistical errors and can lead to misguided business decisions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_94da596a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a hypothesis test" ;
    oc:directiveContent "Use the right test for the data: t-test for two group means with normal data, z-test for proportions, paired t-test for before/after on same entities, ANOVA for 3+ groups, Mann-Whitney U for non-normal data, Chi-squared for categorical associations." ;
    oc:hasRationale "Using the wrong test invalidates results and can lead to incorrect conclusions" ;
    oc:severityLevel "HIGH" .

oc:kn_a4d19a17 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When computing descriptive statistics for any business metric" ;
    oc:directiveContent "Always report mean and median together for business metrics. If they diverge significantly, the data is skewed and the mean alone is misleading." ;
    oc:hasRationale "Skewed distributions are common in business data and reporting only the mean hides important information about the data's shape" ;
    oc:severityLevel "HIGH" .

oc:kn_a9d273ab a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When detecting time series anomalies" ;
    oc:directiveContent "1. Compute expected value via moving average or same-period-last-year 2. Compute deviation from expected 3. Flag deviations beyond 2-3 std devs of residuals 4. Distinguish point anomalies from change points" ;
    oc:stepOrder 2 .

oc:kn_bf00034c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting forecasts or statistical estimates" ;
    oc:directiveContent "Always communicate uncertainty as ranges, not point estimates. Say 'We expect 10K-12K signups' not 'We will get exactly 11,234 signups'. Round appropriately — 'about 5%' is more honest than '4.73%'." ;
    oc:hasRationale "False precision creates overconfidence and undermines credibility when predictions miss exact figures" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c09bb398 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When running multiple hypothesis tests or examining many segments" ;
    oc:directiveContent "Address the multiple comparisons problem: testing 20 metrics at p=0.05 means ~1 will be falsely significant. Use Bonferroni correction or report how many tests were run." ;
    oc:hasRationale "Without correction, the false positive rate scales with the number of tests performed" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c173f7d2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing time series data for trends" ;
    oc:directiveContent "For seasonality detection: 1) Plot raw time series visually, 2) Compute day-of-week averages, 3) Compute month-of-year averages, 4) Always use YoY or same-period comparisons to avoid conflating trend with seasonality." ;
    oc:hasRationale "Seasonal patterns can masquerade as trends and lead to incorrect conclusions about growth or decline" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c39014a2 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing descriptive statistical analysis" ;
    oc:directiveContent "1. Characterize distribution shape (normal, skewed, bimodal) 2. Report center (mean + median) 3. Report spread (std dev or IQR) 4. Identify outliers and bounds 5. Apply appropriate outlier detection method (Z-score for normal, IQR for non-normal, percentile as simplest)" ;
    oc:stepOrder 1 .

oc:kn_d2c43a63 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When analyzing retrospective data about users, companies, or entities" ;
    oc:directiveContent "Account for survivorship bias: you can only analyze entities that survived to be in the dataset. Always ask 'Who is missing from this dataset, and would their inclusion change the conclusion?'" ;
    oc:hasRationale "Survivorship bias systematically excludes failures, making outcomes appear better than reality" ;
    oc:severityLevel "HIGH" .

oc:kn_d8f97e20 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When conducting hypothesis testing" ;
    oc:directiveContent "1. State null hypothesis (H0: no difference) 2. State alternative hypothesis 3. Choose alpha (typically 0.05) 4. Compute test statistic and p-value 5. Interpret: if p < alpha, reject H0 6. Report effect size, confidence interval, and business impact" ;
    oc:stepOrder 3 .

oc:kn_fcbb3480 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When detecting outliers in any dataset" ;
    oc:directiveContent "Never automatically remove outliers. Investigate first: classify as data error, genuine extreme, or different population. Data errors should be fixed/removed; genuine extremes should be kept with robust statistics; different populations should be segmented out." ;
    oc:hasRationale "Blind removal of outliers destroys genuine signal and can introduce bias into analysis" ;
    oc:severityLevel "CRITICAL" .

_:ref_01adac961ed6a0c5 a oc:WorkflowStep ;
    dcterms:description "**Compute test statistic and p-value**" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

