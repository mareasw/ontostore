    dcterms:description "Compute deviation from expected" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_1da61008331d7134 a oc:WorkflowStep ;
    dcterms:description "**Data errors**: Fix or remove (e.g., negative ages, timestamps in year 1970)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_333f76b0daf6da3c a oc:WorkflowStep ;
    dcterms:description "Compute day-of-week averages: is there a clear weekly pattern?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_3a0c3da7fdca8764 a oc:WorkflowStep ;
    dcterms:description "Compute expected value (moving average or same-period-last-year)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_3dd348480644f408 a oc:WorkflowStep ;
    dcterms:description "Flag deviations beyond a threshold (typically 2-3 standard deviations of the residuals)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_3e06462787afe1e1 a oc:WorkflowStep ;
    dcterms:description "**Alternative hypothesis (H1)**: There is a difference" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_4aca884edc1600e2 a oc:WorkflowStep ;
    dcterms:description "**Choose significance level (alpha)**: Typically 0.05 (5% chance of false positive)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_4b08d7ccb7ecf721 a oc:WorkflowStep ;
    dcterms:description "**Investigate**: Is this a data error, a genuine extreme value, or a different population?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_57f602d055b963cf a oc:WorkflowStep ;
    dcterms:description "When comparing periods, always use YoY or same-period comparisons to avoid conflating trend with seasonality" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_7f4111fd0fa7f71a a oc:WorkflowStep ;
    dcterms:description "Plot the raw time series -- visual inspection first" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_918603f43ef6275f a oc:WorkflowStep ;
    dcterms:description "**Null hypothesis (H0)**: There is no difference (the default assumption)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_9aa76f10e3c1022d a oc:WorkflowStep ;
    dcterms:description "**Different population**: Segment them out for separate analysis (e.g., enterprise vs. SMB customers)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_b7edcb53d7bf5116 a oc:WorkflowStep ;
    dcterms:description "Distinguish between point anomalies (single unusual value) and change points (sustained shift)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_d381b2d866b2a876 a oc:WorkflowStep ;
    dcterms:description "Compute month-of-year averages: is there an annual cycle?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_db3e280b53c25538 a oc:WorkflowStep ;
    dcterms:description "**Genuine extremes**: Keep them but consider using robust statistics (median instead of mean)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_ea7441c4446d3959 a oc:WorkflowStep ;
    dcterms:description "**Interpret**: If p < alpha, reject H0 (evidence of a real difference)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

