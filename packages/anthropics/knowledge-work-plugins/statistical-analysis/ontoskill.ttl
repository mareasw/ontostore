oc:skill_anthropics_knowledge_work_plugins_statistical_analysis a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "statistical-analysis" ;
    skos:broader "analytical methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/statistical-analysis" ;
    oc:contentHash "bd256eafd1a0415e227ea09a62cbb3fa941a53d162514b60b42779cc2bfef258" ;
    oc:differentia "that applies statistical methods including descriptive statistics, trend analysis, outlier detection, and hypothesis testing while guarding against common statistical fallacies" ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidDistribution ;
    oc:hasCategory "research" ;
    oc:hasDescription "Apply statistical methods including descriptive stats, trend analysis, outlier detection, and hypothesis testing. Use when analyzing distributions, testing for significance, detecting anomalies, computing correlations, or interpreting statistical results." ;
    oc:hasName "statistical-analysis" ;
    oc:impartsKnowledge oc:kn_01583ac1,
        oc:kn_3bff5e4c,
        oc:kn_7fea268d,
        oc:kn_84ee1f18,
        oc:kn_b3f6f72e,
        oc:kn_bd0e50c5,
        oc:kn_d55f65fa,
        oc:kn_d8182c40 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:DataLoaded ;
    oc:resolvesIntent "analyze data distributions and compute descriptive statistics",
        "analyze trends and forecast future values",
        "detect outliers and anomalies in datasets",
        "identify correlations and assess statistical claims",
        "perform hypothesis testing and interpret statistical significance" ;
    oc:yieldsState oc:StatisticalAnalysisComplete .

oc:kn_01583ac1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When detecting and handling outliers in any dataset" ;
    oc:directiveContent "Do NOT automatically remove outliers. Always investigate whether each outlier is a data error, a genuine extreme value, or represents a different population before deciding how to handle it." ;
    oc:hasRationale "Blind removal of outliers can hide important patterns, distort the true distribution, and introduce selection bias that invalidates conclusions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3bff5e4c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting forecasts, predictions, or any forward-looking statistical estimates" ;
    oc:directiveContent "Always communicate uncertainty as a range, not a point estimate. Say 'We expect 10K-12K signups' not 'We will get exactly 11,234 signups'. Round appropriately and avoid false precision." ;
    oc:hasRationale "Point estimates create false confidence and mislead stakeholders about the reliability of projections. Ranges convey the inherent uncertainty in statistical forecasts." ;
    oc:severityLevel "HIGH" .

oc:kn_7fea268d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reporting correlations or observational findings" ;
    oc:directiveContent "Never claim causation from observational correlation. When you find a correlation, explicitly consider reverse causation, confounding variables, and coincidence. Use language like 'associated with' rather than 'causes'." ;
    oc:hasRationale "Causal claims from correlational data are a leading source of flawed business decisions. Correlation does not establish the direction or mechanism of the relationship." ;
    oc:severityLevel "CRITICAL" .

oc:kn_84ee1f18 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which statistical test or outlier detection method to apply" ;
    oc:directiveContent "Choose the appropriate statistical test based on data characteristics: t-test for comparing two normal group means, Mann-Whitney U for non-normal data, Chi-squared for categorical associations, ANOVA for 3+ groups. For outlier detection, use Z-score for normal data and IQR method for non-normal distributions." ;
    oc:hasRationale "Using the wrong test for the data distribution produces invalid p-values and unreliable conclusions. The choice of method must match the data's properties." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b3f6f72e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing and reporting descriptive statistics for any business metric" ;
    oc:directiveContent "Always report mean and median together for business metrics. If they diverge significantly, the data is skewed and the mean alone is misleading. Also report key percentiles (p5, p25, p50, p75, p95) to tell a richer story." ;
    oc:hasRationale "Mean alone can be heavily distorted by outliers and skewness, leading to incorrect business decisions when used as a summary statistic." ;
    oc:severityLevel "HIGH" .

oc:kn_bd0e50c5 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When running multiple statistical tests or analyzing segmented data" ;
    oc:directiveContent "Beware of the multiple comparisons problem: testing 20 hypotheses at p=0.05 means ~1 will be falsely significant by chance. Also check for Simpson's Paradox where aggregate trends reverse when data is segmented, and survivorship bias where only successful entities remain in the dataset." ;
    oc:hasRationale "These statistical fallacies are common in business analytics and can lead to confidently wrong conclusions if not actively checked." ;
    oc:severityLevel "HIGH" .

oc:kn_d55f65fa a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Always, before computing any statistical test or summary" ;
    oc:directiveContent "Before running statistical analysis, characterize every numeric distribution by its shape (normal, skewed, bimodal), center (mean and median gap), spread (SD or IQR), outliers (count and extremity), and bounds (natural floors or ceilings)." ;
    oc:hasRationale "Understanding the distribution is essential for choosing correct methods and interpreting results accurately. Skipping this step leads to applying inappropriate techniques." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d8182c40 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting hypothesis test results, especially A/B tests and comparisons" ;
    oc:directiveContent "Distinguish between statistical significance and practical significance. A statistically significant result can be practically meaningless (common with large samples). Always report effect size, confidence interval, and business impact alongside p-values." ;
    oc:hasRationale "Overreliance on p-values alone leads to detecting trivial differences that have no real business value while consuming resources to act on them." ;
    oc:severityLevel "CRITICAL" .

