    oc:yieldsState oc:SearchResultsReturned .

oc:kn_425dc093 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When ordering search results" ;
    oc:directiveContent "Rank results by: relevance to query intent, freshness (recency for status/decision queries), authority (official docs > wiki > chat for facts; conversations > docs for discussions), and completeness of context." ;
    oc:hasRationale "Multi-factor ranking surfaces the most useful result first without requiring the user to sift through results" .

oc:kn_72af6467 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parsing user queries with explicit filters" ;
    oc:directiveContent "Supported filter syntax: from: (sender/author), in: (channel/folder/location), after:/before: (date range), type: (message, email, doc, thread, file). These must be translated to each source's native syntax." ;
    oc:hasRationale "Consistent filter syntax across sources gives users predictable control without learning each source's API" .

oc:kn_82673aa8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing parallel searches" ;
    oc:directiveContent "Never let one source's failure block results from other sources. Capture errors per-source and continue." ;
    oc:hasRationale "Partial results are better than no results; a single source outage should not halt the entire search" ;
    oc:severityLevel "HIGH" .

oc:kn_afea417f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting search results to the user" ;
    oc:directiveContent "Synthesize results into answers, never present raw lists of search results. Group related results, deduplicate across sources, and prefer the most authoritative version." ;
    oc:hasRationale "Users want actionable answers, not an unprocessed dump from multiple sources" .

oc:kn_b5d3c943 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When running any multi-source search" ;
    oc:directiveContent "Always execute searches across multiple sources in parallel, never sequentially." ;
    oc:hasRationale "Parallel execution minimizes latency and provides results faster to the user" ;
    oc:severityLevel "HIGH" .

_:ref_6b4b287af02523af a oc:WorkflowStep ;
    dcterms:description "Run all sub-queries simultaneously across available sources, capturing results with metadata and isolating failures" ;
    oc:expectedOutcome "Raw results from all sources with timestamps, authors, links, and source types" ;
    oc:stepDependsOn _:ref_7ac1d9b6887df026 ;
    oc:stepId "execute-parallel" .

_:ref_6c421e9b1b1c6739 a oc:WorkflowStep ;
    dcterms:description "Determine which MCP sources are available from the connected tool list" ;
    oc:expectedOutcome "List of available sources identified, or user prompted to connect sources if none available" ;
    oc:stepId "check-sources" .

_:ref_7ac1d9b6887df026 a oc:WorkflowStep ;
    dcterms:description "For each available source, create a targeted sub-query using that source's native search syntax" ;
    oc:expectedOutcome "One translated sub-query per available source" ;
    oc:stepDependsOn _:ref_8d4c83b53900ab34 ;
    oc:stepId "decompose-queries" .

_:ref_7cca7494f3d51ac1 a oc:WorkflowStep ;
    dcterms:description "Deduplicate across sources and rank results by relevance, freshness, authority, and completeness" ;
    oc:expectedOutcome "Ordered, deduplicated result set" ;
