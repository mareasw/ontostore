@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_build_dashboard a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "build-dashboard" ;
    skos:broader "HTML dashboard generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/build-dashboard" ;
    oc:contentHash "24fdc018c0dada6cb1631bd52376ccdf1408eb99fd699febaf1489dc92602d80" ;
    oc:differentia "produces self-contained, browser-openable interactive dashboards with charts, filters, KPI cards, and data tables using Chart.js, requiring no server or external dependencies" ;
    oc:handlesFailure oc:DataNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "Bash",
        "Write" ;
    oc:hasArgumentHint "\"<description> [data source]\"" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Build an interactive HTML dashboard with charts, filters, and tables. Use when creating an executive overview with KPI cards, turning query results into a shareable self-contained report, building a team monitoring snapshot, or needing multiple charts with filters in one browser-openable file." ;
    oc:hasName "build-dashboard" ;
    oc:impartsKnowledge oc:kn_0d29e2bd,
        oc:kn_4ce16f97,
        oc:kn_955d033d,
        oc:kn_bfcbdf5e,
        oc:kn_c2aed237 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DataAvailable ;
    oc:resolvesIntent "build executive overview with KPI cards",
        "create interactive dashboard",
        "generate shareable self-contained HTML report",
        "turn query results into an interactive dashboard",
        "visualize data with charts and filters" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0d29e2bd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing dashboard layout" ;
    oc:directiveContent "Follow the standard layout pattern: 2-4 KPI cards at top, 1-3 charts in middle, optional detail table at bottom, filters in header. Adapt proportions to content type." ;
    oc:hasRationale "This layout provides a consistent information hierarchy — headline numbers first, trends second, details third — that matches how executives consume data." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4ce16f97 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when building any dashboard" ;
    oc:directiveContent "Every dashboard must be a single self-contained HTML file with all data embedded as JSON, all CSS inline, and Chart.js loaded via CDN — no external data fetches required." ;
    oc:hasRationale "Self-containment ensures the dashboard works offline, is shareable as a single file, and requires no server infrastructure." ;
    oc:severityLevel "CRITICAL" .

oc:kn_955d033d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting dashboard construction" ;
    oc:directiveContent "Before building, determine: purpose (executive/operational/deep-dive), audience, key metrics, filterable dimensions, and data source (live query, pasted data, CSV, or sample data). If no data is provided, create a realistic sample dataset and clearly note it uses sample data." ;
    oc:hasRationale "Clarifying requirements upfront prevents rework and ensures the dashboard addresses the actual analytical need rather than producing generic output." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bfcbdf5e a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When implementing charts for performance" ;
    oc:directiveContent "Limit line charts to <500 data points per series, bar charts to <50 categories, scatter plots to 1,000 points. Disable animations with `animation: false` for dashboards with many charts. Use `Chart.update('none')` for filter-triggered updates." ;
    oc:hasRationale "Chart.js rendering performance degrades significantly beyond these thresholds, causing sluggish filter interactions and poor user experience." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c2aed237 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working with large datasets" ;
    oc:directiveContent "Never embed more than 10,000 raw data rows directly in HTML. For datasets over 1,000 rows, pre-aggregate before embedding. Datasets over 100,000 rows are not suitable for client-side dashboards at all." ;
    oc:hasRationale "Large embedded datasets cause slow page loads, high memory usage, and poor browser performance. Pre-aggregation reduces data volume while preserving analytical value." ;
    oc:severityLevel "HIGH" .

