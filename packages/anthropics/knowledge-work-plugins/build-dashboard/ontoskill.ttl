oc:kn_11c16788 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring dashboard JavaScript" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent "Use a Dashboard class pattern with constructor(data), init(), applyFilters(), renderKPIs(), renderCharts(), renderTable(), and updateCharts() methods. Store raw data, filtered data, and chart references as instance properties." ;
    oc:hasRationale "Class-based pattern encapsulates state and ensures filter changes propagate to all components consistently" .

oc:kn_2352ba38 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When implementing Chart.js visualizations" ;
    oc:directiveContent "Limit line charts to <500 points per series, bar charts to <50 categories, scatter plots to 1,000 points. Disable animations with `animation: false` for many-chart dashboards. Use `Chart.update('none')` for filter-triggered updates." ;
    oc:hasRationale "Excessive data points cause rendering lag and poor user experience" .

oc:kn_78339301 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling datasets with >10K rows" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent "const CHART_DATA = { monthly_revenue: [...], top_products: [...], kpis: { total_revenue, total_orders, avg_order_value } }; — pre-aggregate data before embedding rather than embedding raw rows." ;
    oc:hasRationale "Pre-aggregation reduces HTML file size and client-side computation dramatically" .

oc:kn_885b63d0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing interactivity and filtering" ;
    oc:directiveContent "Do not rebuild the entire DOM on filter change. Update only changed elements. Limit visible table rows to 100-200 and add pagination for more." ;
    oc:hasRationale "Full DOM rebuilds on every filter change cause significant performance degradation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8b63b0ec a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing dashboard layout" ;
    oc:directiveContent "Follow the standard layout: 2-4 KPI cards at top, 1-3 charts in middle, optional sortable detail table at bottom, filters in header. Use CSS Grid with auto-fit for responsive layout." ;
    oc:hasRationale "Consistent layout pattern ensures scannability and professional appearance across different dashboard types" .

oc:kn_8efbc370 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up the HTML template" ;
    oc:directiveContent "Use Chart.js v4.5.1 loaded via CDN with SRI integrity checks. Include chartjs-adapter-date-fns@3.0.0 for time-series support." ;
    oc:hasRationale "CDN-loaded Chart.js provides interactive charts without bundling, and SRI ensures script integrity" .

oc:kn_a1c762f0 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When determining data embedding strategy based on dataset size" ;
    oc:directiveContent "For <1K rows embed directly. For 1K-10K rows embed but pre-aggregate for charts. For 10K-100K rows pre-aggregate and embed only aggregated data. For >100K rows do not use client-side dashboards — use a BI tool instead." ;
    oc:hasRationale "Client-side JavaScript has limited performance for large datasets; embedding raw data causes browser slowdowns" ;
    oc:severityLevel "HIGH" .

oc:kn_c89a7d1d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any dashboard" ;
    oc:directiveContent "All data must be embedded as JSON directly in the HTML file. No external data fetches. The dashboard must work completely offline." ;
    oc:hasRationale "Self-containment is the core design principle — dashboards are shareable point-in-time snapshots that must render without network access" ;
    oc:severityLevel "CRITICAL" .

