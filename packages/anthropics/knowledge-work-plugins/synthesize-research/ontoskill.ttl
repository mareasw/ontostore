oc:skill_anthropics_knowledge_work_plugins_synthesize_research a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "synthesize-research" ;
    skos:broader "Research synthesis methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/synthesize-research" ;
    oc:contentHash "c0e73fcb11259e60fd5a5aab5b2b299f8a20c8a2410d2600fe835d03a2f6198d" ;
    oc:differentia "that transforms raw qualitative and quantitative user research data from interviews, surveys, and feedback into structured themes, findings, and actionable recommendations using thematic analysis, affinity mapping, and triangulation techniques" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<research topic or question>" ;
    oc:hasCategory "research" ;
    oc:hasDescription "Synthesize user research from interviews, surveys, and feedback into structured insights. Use when you have a pile of interview notes, survey responses, or support tickets to make sense of, need to extract themes and rank findings by frequency and impact, or want to turn raw feedback into roadmap recommendations." ;
    oc:hasName "synthesize-research" ;
    oc:hasRequirement oc:req_5fa44549,
        oc:req_c0687870,
        oc:req_d505682b,
        oc:req_e67e09d2 ;
    oc:impartsKnowledge oc:kn_09279831,
        oc:kn_3b843033,
        oc:kn_664460ff,
        oc:kn_6e52f872,
        oc:kn_9e35c28b,
        oc:kn_aace3e28,
        oc:kn_b76c7857,
        oc:kn_cb73218d,
        oc:kn_ce5f7942,
        oc:kn_f0964728 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "analyze qualitative and quantitative feedback",
        "build evidence-based personas from research data",
        "extract themes and patterns from research data",
        "generate structured research findings and recommendations",
        "prioritize research findings by frequency and impact",
        "synthesize user research from interviews and surveys" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_09279831 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "After completing the initial synthesis output" ;
    oc:directiveContent "The synthesis workflow is iterative: after generating the synthesis, offer to extend with persona documents, opportunity maps, research presentations, follow-up research plans, and product roadmap implications." ;
    oc:hasRationale "Research synthesis is rarely complete in one pass. Stakeholders often need different artifacts from the same research, and extending the synthesis increases its organizational value." ;
    oc:severityLevel "LOW" .

oc:kn_3b843033 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing quantitative survey data" ;
    oc:directiveContent "Never report survey averages without distributions, ignore non-response bias, over-interpret small differences, treat Likert scales as interval data, or confuse correlation with causation in cross-tabulations." ;
    oc:hasRationale "These common mistakes lead to flawed conclusions that can misdirect product decisions. A bimodal distribution tells a fundamentally different story than a normal distribution with the same average." ;
    oc:severityLevel "CRITICAL" .

oc:kn_664460ff a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying themes and generating synthesis" ;
    oc:directiveContent "Let the data speak. Do not force findings into a predetermined narrative. 5-8 strong findings are better than 20 weak ones." ;
    oc:hasRationale "Forcing a narrative introduces bias and can cause the agent to miss unexpected but important insights that emerge organically from the data." ;
    oc:severityLevel "HIGH" .

oc:kn_6e52f872 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building evidence-based personas from research" ;
    oc:directiveContent "Avoid defining personas by demographics instead of behavior, creating more than 3-5 personas, inventing fictional personas without research data, or creating personas that do not change any product decisions." ;
    oc:hasRationale "Behavior predicts product needs better than demographics. Too many personas become unactionable, and personas without data or implications are fiction that can actively mislead." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9e35c28b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "At the start of every synthesis engagement" ;
    oc:directiveContent "Before synthesizing, clarify: what type of research, how many sources/participants, is there a specific question or hypothesis, and what decisions will this research inform?" ;
    oc:hasRationale "Understanding scope, research question, and decision context ensures the synthesis is focused and actionable rather than generic and unfocused." ;
    oc:severityLevel "HIGH" .

oc:kn_aace3e28 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When qualitative and quantitative data tell different stories" ;
    oc:directiveContent "When sources disagree, do not choose one source. Report the disagreement honestly and investigate whether it is due to different populations, stated vs. actual behavior, or question framing issues." ;
    oc:hasRationale "Disagreements between data sources often reveal distinct user segments or contexts, which are valuable insights that would be lost by arbitrarily selecting one source over another." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b76c7857 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "During affinity mapping and thematic clustering" ;
    oc:directiveContent "If a cluster in affinity mapping gets too large, it probably contains multiple themes — split it. Outliers are interesting and should not be forced into clusters. Move notes between clusters freely as understanding evolves." ;
    oc:hasRationale "Oversized clusters mask nuance and conflate distinct themes. The first grouping is rarely the best; iterative refinement produces more accurate synthesis." ;
    oc:severityLevel "LOW" .

oc:kn_cb73218d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting insights from interview notes and survey responses" ;
    oc:directiveContent "Distinguish between what users say and what they do. Behavioral data is stronger evidence than stated preferences. If a participant says they want feature X but their workflow shows they never use similar features, note the contradiction." ;
    oc:hasRationale "Revealed preferences through actual behavior are more predictive of future behavior than stated desires, which may be aspirational or socially influenced." .

oc:kn_ce5f7942 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When combining qualitative and quantitative insights" ;
    oc:directiveContent "Strengthen findings by triangulating across multiple data sources: methodological triangulation (same question, different methods), source triangulation (same method, different participants), and temporal triangulation (same observation at different times)." ;
    oc:hasRationale "A finding supported by multiple sources and methods is much stronger than one supported by a single source. When sources disagree, that disagreement is signal, not error." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f0964728 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting findings and opportunity sizing" ;
    oc:directiveContent "Be explicit about confidence levels. A finding from 2 interviews is a hypothesis, not a conclusion. Use ranges rather than false precision when sizing opportunities." ;
    oc:hasRationale "Overstating confidence from limited data undermines credibility and can lead to misguided decisions. Transparency about evidence strength enables appropriate decision-making." ;
    oc:severityLevel "HIGH" .

oc:req_5fa44549 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Affinity mapping techniques" .

