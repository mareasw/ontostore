_:ref_04bcdfc3797cd63b a oc:WorkflowStep ;
    dcterms:description "**Validate with data**: Can you size each persona segment using quantitative data?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_2e590693ac429e2e a oc:WorkflowStep ;
    dcterms:description "**Define distinguishing variables**: What dimensions differentiate one cluster from another? (e.g., company size, technical skill, usage frequency, primary use case)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_2f7c41dc60f29ed7 a oc:WorkflowStep ;
    dcterms:description "**Capture observations**: Write each distinct observation, quote, or data point as a separate note" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_3411650695b66877 a oc:WorkflowStep ;
    dcterms:description "**Report**: Write up the themes as findings with supporting evidence." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_39944b8c34854901 a oc:WorkflowStep ;
    dcterms:description "**Familiarization**: Read through all the data. Get a feel for the overall landscape before coding anything." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_45082c91456fbfd8 a oc:WorkflowStep ;
    dcterms:description "**Cluster**: Group related notes together based on similarity. Do not pre-define categories — let them emerge from the data." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_6cd3b3a35285496a a oc:WorkflowStep ;
