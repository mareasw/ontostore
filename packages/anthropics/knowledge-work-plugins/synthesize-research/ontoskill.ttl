@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_knowledge_work_plugins_synthesize_research a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "synthesize-research" ;
    skos:broader "Research synthesis framework" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/synthesize-research" ;
    oc:contentHash "c0e73fcb11259e60fd5a5aab5b2b299f8a20c8a2410d2600fe835d03a2f6198d" ;
    oc:differentia "applies thematic analysis, affinity mapping, and triangulation to transform raw user research data from interviews, surveys, and feedback into structured insights with prioritized findings and actionable recommendations" ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput ;
    oc:hasArgumentHint "<research topic or question>" ;
    oc:hasCategory "research" ;
    oc:hasDescription "Synthesize user research from interviews, surveys, and feedback into structured insights. Use when you have a pile of interview notes, survey responses, or support tickets to make sense of, need to extract themes and rank findings by frequency and impact, or want to turn raw feedback into roadmap recommendations." ;
    oc:hasName "synthesize-research" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Synthesize user research from multiple sources into structured insights and recommendations." ],
                [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use clear headers and structured formatting. Each finding should stand on its own — a reader should be able to read any single finding and understand it without reading the rest." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 38 ;
                    oc:sectionTitle "Output Format" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Distinguish between what users say and what they do. Behavioral data is stronger than stated preferences." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Be explicit about confidence levels. A finding from 2 interviews is a hypothesis, not a conclusion." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "Recommendations should be specific enough to act on. \"Improve onboarding\" is not actionable. \"Add a progress indicator to the setup flow\" is." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Let the data speak. Do not force findings into a predetermined narrative." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Contradictions in the data are interesting, not inconvenient. They often reveal distinct user segments." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Quotes are powerful evidence. Include them generously, with attribution to participant type (not name)." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "Resist the temptation to synthesize too many themes. 5-8 strong findings are better than 20 weak ones." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 39 ;
                    oc:sectionTitle "Tips" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Methodological triangulation**: Same question, different methods (interviews + survey + analytics)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Source triangulation**: Same method, different participants or segments" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Temporal triangulation**: Same observation at different points in time" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "A finding supported by multiple sources and methods is much stronger than one supported by a single source. When sources disagree, that is interesting — it may reveal different user segments or contexts." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Strengthen findings by combining multiple data sources:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 18 ;
                            oc:sectionTitle "Triangulation" ],
                        [ a oc:Section ;
                            oc:hasContent _:ref_91cde472fd3b0baa,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "The core method for synthesizing qualitative research:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 16 ;
                            oc:sectionTitle "Thematic Analysis" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "If a cluster gets too large, it probably contains multiple themes. Split it." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Outliers are interesting. Do not force every observation into a cluster." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "The process of grouping is as valuable as the output. It builds shared understanding." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "One observation per note. Do not combine multiple insights." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Move notes between clusters freely. The first grouping is rarely the best." ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "A collaborative method for grouping observations:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Tips for affinity mapping**:" ],
                                _:ref_f905c450b1aa2e7a ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 17 ;
                            oc:sectionTitle "Affinity Mapping" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 15 ;
                    oc:sectionTitle "Research Synthesis Methodology" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/synthesize-research $ARGUMENTS
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 15-17" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Usage" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Produce a structured research synthesis:" ] ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "Timeframe: when the research was conducted" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Research question(s): what we set out to learn" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Methodology: what types of research, how many participants/sources" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 8 ;
                                    oc:sectionTitle "Research Overview" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "Based on the findings, identify opportunity areas:" ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Where do current solutions fall short" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "What new capabilities would unlock value" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "Prioritized by potential impact" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "What user needs are unmet or underserved" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 11 ;
                                    oc:sectionTitle "Opportunity Areas" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "For each major finding (aim for 5-8):" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 3 ;
                                            oc:textContent "Order findings by priority (frequency x impact)." ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Finding statement**: One clear sentence describing the insight" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Evidence**: Supporting quotes, data points, or observations (with source attribution)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "**Frequency**: How many participants/sources support this finding" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "**Confidence level**: High (strong evidence), Medium (suggestive), Low (early signal)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "**Impact**: How significantly this affects the user experience or business" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 9 ;
                                    oc:sectionTitle "Key Findings" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "Suggested follow-up research methods" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Gaps in understanding" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Areas needing further investigation" ] ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "What the research did not answer:" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 13 ;
                                    oc:sectionTitle "Open Questions" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Tied back to specific findings" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "Prioritized by impact and feasibility" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "What to build, change, or investigate further" ] ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "Specific, actionable recommendations:" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 12 ;
                                    oc:sectionTitle "Recommendations" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "If the research reveals distinct user segments:" ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Segment name and description" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "Unique needs and pain points" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "Size estimate if data is available" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Key characteristics and behaviors" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 10 ;
                                    oc:sectionTitle "User Segments / Personas" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 7 ;
                            oc:sectionTitle "4. Generate the Synthesis" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Low frequency + High impact**: Important for specific segments" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Low frequency + Low impact**: Note but deprioritize" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**High frequency + Low impact**: Quality-of-life improvements" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**High frequency + High impact**: Top priority findings" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Create a priority matrix:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Apply thematic analysis — see **Research Synthesis Methodology** below for detailed guidance on thematic analysis, affinity mapping, and triangulation techniques." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "Group observations into themes, count frequency across participants, and assess impact severity. Note contradictions and surprises." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "3. Identify Themes and Patterns" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Accept research from any combination of:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "What type of research? (interviews, surveys, usability tests, analytics, support tickets, sales call notes)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "What decisions will this research inform?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "How many sources / participants?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Is there a specific question or hypothesis they are investigating?" ] ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**~~knowledge base** (if connected): Search for research documents, interview notes, survey results" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**~~product analytics** (if connected): Pull usage data, funnel metrics, behavioral data" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Uploaded files**: Research documents, spreadsheets, recordings summaries" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Pasted text**: Interview notes, transcripts, survey responses, feedback" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "**~~meeting transcription** (if connected): Pull interview recordings, meeting summaries, and discussion notes" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**~~user feedback** (if connected): Pull recent support tickets, feature requests, bug reports" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Ask the user what they have:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "1. Gather Research Inputs" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "For each source, extract:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Positive signals**: What works well, moments of delight" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Pain points**: Frustrations, workarounds, and unmet needs" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Quotes**: Verbatim quotes that illustrate important points" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "**Context**: User segment, use case, experience level" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Behaviors**: What users actually did (vs what they said they do)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Key observations**: What did users say, do, or experience?" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "2. Process the Research" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "After generating the synthesis:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Offer to create follow-up research plans for open questions" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Offer to draft product implications (how findings should influence the roadmap)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Offer to generate specific artifacts: persona documents, opportunity maps, research presentations" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Ask if any findings need more detail or different framing" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 14 ;
                            oc:sectionTitle "5. Review and Extend" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Workflow" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Score opportunities on a simple matrix:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Evidence strength**: How confident are we in the finding? (Multiple sources > single source, behavioral data > stated preferences)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Impact**: (Users affected) x (Frequency) x (Severity) = impact score" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Feasibility**: Can we realistically address this? (Technical feasibility, resource availability, time to impact)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Strategic alignment**: Does this opportunity align with company strategy and product vision?" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 36 ;
                            oc:sectionTitle "Opportunity Scoring" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Compare opportunities against each other to create a relative ranking, not just absolute scores" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Show the math: \"Based on support ticket volume, approximately 2,000 users per month encounter this issue. Interview data suggests 60% of them consider it a significant blocker.\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Use ranges rather than false precision: \"This affects 1,500-2,500 users monthly\" not \"This affects 2,137 users monthly\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Be transparent about assumptions and confidence levels" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 37 ;
                            oc:sectionTitle "Presenting Opportunity Sizing" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Willingness to pay**: Would addressing this drive upgrades, retention, or new customer acquisition?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Addressable users**: How many users could benefit from addressing this? Use product analytics, survey data, or market data to estimate." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Severity**: How much does this issue impact users when it occurs? (Blocker, significant friction, minor annoyance)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Frequency**: How often do affected users encounter this issue? (Daily, weekly, monthly, one-time)" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "For each research finding or opportunity area, estimate:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 35 ;
                            oc:sectionTitle "Estimating Opportunity Size" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 34 ;
                    oc:sectionTitle "Opportunity Sizing" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Code each response with themes" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Count frequency of themes across responses" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Look for themes that appear in open-ended responses but not in structured questions — these are things you did not think to ask about" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Treat open-ended responses like mini interview notes" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Pull representative quotes for each theme" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 24 ;
                            oc:sectionTitle "Open-Ended Survey Response Analysis" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Distribution**: Look at the shape of responses, not just averages. A bimodal distribution (lots of 1s and 5s) tells a different story than a normal distribution (lots of 3s)." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Segmentation**: Break down responses by user segment. Aggregates can mask important differences." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Statistical significance**: For small samples, be cautious about drawing conclusions from small differences." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Response rate**: How representative is the sample? Low response rates may introduce bias." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Benchmark comparison**: How do scores compare to industry benchmarks or previous surveys?" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 23 ;
                            oc:sectionTitle "Quantitative Survey Analysis" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Confusing correlation with causation in cross-tabulations." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Treating Likert scales as interval data. The difference between \"Strongly Agree\" and \"Agree\" is not necessarily the same as between \"Agree\" and \"Neutral.\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Ignoring non-response bias. The people who did not respond may be systematically different." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Reporting averages without distributions. A 3.5 average could mean everyone is lukewarm or half love it and half hate it." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Over-interpreting small differences. A 0.1 point change in NPS is noise, not signal." ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 25 ;
                            oc:sectionTitle "Common Survey Analysis Mistakes" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 22 ;
                    oc:sectionTitle "Survey Data Interpretation" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Personas should emerge from research data, not imagination:" ],
                                _:ref_e0d4152d966206b9 ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 31 ;
                            oc:sectionTitle "Building Evidence-Based Personas" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """[Persona Name] — [One-line description]

Who they are:
- Role, company type/size, experience level
- How they found/started using the product

What they are trying to accomplish:
- Primary goals and jobs to be done
- How they measure success

How they use the product:
- Frequency and depth of usage
- Key workflows and features used
- Tools they use alongside this product

Key pain points:
- Top 3 frustrations or unmet needs
- Workarounds they have developed

What they value:
- What matters most in a solution
- What would make them switch or churn

Representative quotes:
- 2-3 verbatim quotes that capture this persona's perspective
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 241-267" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 32 ;
                            oc:sectionTitle "Persona Template" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Personas without implications: a persona that does not change any product decisions is not useful." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Fictional personas: made up based on assumptions rather than research data." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Too many personas: 3-5 is the sweet spot. More than that and they are not actionable." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Demographic personas: defining by age/gender/location instead of behavior. Behavior predicts product needs better than demographics." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Static personas: never updated as the product and market evolve." ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 33 ;
                            oc:sectionTitle "Common Persona Mistakes" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 30 ;
                    oc:sectionTitle "Persona Development from Research" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Quantitative validation**: Surveys and analytics reveal HOW MUCH and HOW MANY. They test hypotheses at scale." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Qualitative first**: Interviews and observation reveal WHAT is happening and WHY. They generate hypotheses." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Qualitative deep-dive**: Return to qualitative methods to understand unexpected quantitative findings." ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 27 ;
                            oc:sectionTitle "The Qual-Quant Feedback Loop" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Use quantitative data to prioritize qualitative findings. A theme from interviews is more important if usage data shows it affects many users." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Present combined evidence: \"47% of surveyed users report difficulty with X (survey), and interviews reveal this is because Y (qualitative finding).\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Use qualitative data to explain quantitative anomalies. A drop in retention is a number; interviews reveal it is because of a confusing onboarding change." ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 28 ;
                            oc:sectionTitle "Integration Strategies" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Quantitative and qualitative sources may tell different stories. This is signal, not error." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Check if stated preferences (survey) differ from actual behavior (analytics)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Report the disagreement honestly and investigate further rather than choosing one source" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Check if the disagreement is due to different populations being measured" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Check if the quantitative question captured what you think it captured" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 29 ;
                            oc:sectionTitle "When Sources Disagree" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 26 ;
                    oc:sectionTitle "Combining Qualitative and Quantitative Insights" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "For each interview, identify:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 7 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Look for revealed preferences through actual behavior" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Behavioral observations are stronger evidence than stated preferences" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "If a participant says \"I want feature X\" but their workflow shows they never use similar features, note the contradiction" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 8 ;
                                    oc:textContent "**Signals of intensity**: How much does this matter to the participant?" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Observations**: What did the participant describe doing, experiencing, or feeling?" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "**Behaviors vs stated preferences**: What people DO often differs from what they SAY they want" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Note context: when, where, with whom, how often" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Flag workarounds — these are unmet needs in disguise" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Distinguish between behaviors (what they do) and attitudes (what they think/feel)" ] ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 5 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "A quote is evidence, not a finding. The finding is your interpretation of what the quote means." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Attribute to participant type, not name: \"Enterprise admin, 200-person team\" not \"Sarah\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Good quotes are specific and vivid, not generic" ] ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 9 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Frequency: how often do they encounter this issue" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Impact: what is the consequence when things go wrong" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Emotional language: frustration, excitement, resignation" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Workarounds: how much effort do they expend working around the problem" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Direct quotes**: Verbatim statements that powerfully illustrate a point" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 20 ;
                            oc:sectionTitle "Extracting Insights from Interview Notes" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Surface contradictions: where do participants disagree? This often reveals meaningful segments." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Note frequency: how many participants mentioned each theme?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Find surprises: what challenged your prior assumptions?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Identify segments: do different types of users have different patterns?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Look for patterns: which observations appear across multiple participants?" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "After processing individual interviews:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 21 ;
                            oc:sectionTitle "Cross-Interview Analysis" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 19 ;
                    oc:sectionTitle "Interview Note Analysis" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Synthesize Research" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: synthesize-research
description: Synthesize user research from interviews, surveys, and feedback into structured insights. Use when you have a pile of interview notes, survey responses, or support tickets to make sense of, need to extract themes and rank findings by frequency and impact, or want to turn raw feedback into roadmap recommendations.
argument-hint: "<research topic or question>"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
