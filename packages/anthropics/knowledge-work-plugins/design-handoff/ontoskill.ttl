        "generate developer handoff specs from design",
        "specify responsive breakpoints and interaction states" ;
    oc:yieldsState oc:HandoffSpecGenerated .

oc:kn_06bd4c2d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any handoff documentation" ;
    oc:directiveContent "Never leave visual or interaction properties unspecified — if it's not in the spec, developers will guess." ;
    oc:hasRationale "Unspecified properties lead to implementation drift, inconsistent UI, and costly revision cycles." ;
    oc:severityLevel "CRITICAL" .

oc:kn_26c31333 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When describing responsive behavior, layout changes, or interaction patterns" ;
    oc:directiveContent "Include the reasoning behind design decisions (the 'why') alongside specifications so developers can make good judgment calls during implementation." ;
    oc:hasRationale "Contextual rationale empowers developers to make reasonable decisions when encountering unspecified edge cases during implementation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5529cfae a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting any design measurement or value" ;
    oc:directiveContent "Reference design tokens (e.g., spacing-md) instead of raw pixel values (e.g., 16px) in all specifications." ;
    oc:hasRationale "Token references ensure consistency across the codebase and tie back to the design system, making future updates single-source-of-truth." ;
    oc:severityLevel "HIGH" .

oc:kn_8b0e3808 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting handoff generation" ;
    oc:directiveContent "Verify the design source is accessible (Figma link valid or description/screenshots provided) before generating handoff specs." ;
    oc:hasRationale "Incomplete design source material leads to incomplete or inaccurate specifications." .

oc:kn_c66cfeb4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying any interactive component" ;
    oc:directiveContent "Document all component states: default, hover, active, disabled, loading, error, and empty." ;
    oc:hasRationale "Complete state coverage prevents developers from inventing behaviors and ensures a consistent user experience across all conditions." ;
    oc:severityLevel "HIGH" .

oc:kn_f24554f5 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When project tracker integration is connected" ;
    oc:directiveContent "If a project tracker connector is available, the skill may create sub-tasks linked to implementation tickets for each spec section." ;
    oc:hasRationale "Awareness of external system changes prevents duplicate work and ensures traceability." .

_:ref_289542359d8ea456 a oc:WorkflowStep ;
    dcterms:description "**Share the Figma link** — I can pull exact measurements, tokens, and component info." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_6c8a26ccf4121335 a oc:WorkflowStep ;
    dcterms:description "**Mention edge cases** — \"What happens with 100 items?\" helps me spec boundary conditions." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_a899ae789645a2b2 a oc:WorkflowStep ;
    dcterms:description "**Use tokens, not values** — Reference `spacing-md` not `16px`." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_b9a359f97a9b01b4 a oc:WorkflowStep ;
    dcterms:description "**Specify the tech stack** — \"We use React + Tailwind\" helps me give relevant implementation notes." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_d591b66647091624 a oc:WorkflowStep ;
    dcterms:description "**Show all states** — Default, hover, active, disabled, loading, error, empty." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_e1611448055a9496 a oc:WorkflowStep ;
    dcterms:description "**Describe the why** — \"This collapses on mobile because users primarily use one-handed\" helps developers make good judgment calls." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_e76a204c9989e7a5 a oc:WorkflowStep ;
    dcterms:description "**Don't assume** — If it's not specified, the developer will guess. Specify everything." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_1baea8b24c991f95 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_a899ae789645a2b2,
        _:ref_d591b66647091624,
        _:ref_e1611448055a9496,
        _:ref_e76a204c9989e7a5 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_274af4042fd93946 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_289542359d8ea456,
        _:ref_6c8a26ccf4121335,
        _:ref_b9a359f97a9b01b4 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_317f919dcc40840d a oc:WorkflowStep ;
    dcterms:description "Produce the structured markdown handoff document following the output template" ;
    oc:expectedOutcome "Complete handoff spec document ready for developer consumption" ;
    oc:stepDependsOn _:ref_9cef92234275d899,
        _:ref_fa7f11da23a24a71 ;
    oc:stepId "generate-handoff-doc" .

_:ref_65fdd5ded8b18a8b a oc:WorkflowStep ;
    dcterms:description "Retrieve design from Figma URL or work from provided description/screenshots" ;
    oc:expectedOutcome "Design assets and measurements are available for analysis" ;
    oc:stepId "source-design" .

_:ref_fa7f11da23a24a71 a oc:WorkflowStep ;
    dcterms:description "Identify and document edge cases: min/max content, international text, slow connections, missing data, empty/loading/error states" ;
    oc:expectedOutcome "Edge case specifications are complete" ;
    oc:stepDependsOn _:ref_9cef92234275d899 ;
    oc:stepId "document-edge-cases" .

_:ref_9cef92234275d899 a oc:WorkflowStep ;
    dcterms:description "Extract visual specs (measurements, tokens, breakpoints), interaction specs (states, animations, gestures), content specs (limits, truncation), and accessibility requirements" ;
    oc:expectedOutcome "All design properties are catalogued with token references" ;
    oc:stepDependsOn _:ref_65fdd5ded8b18a8b ;
    oc:stepId "extract-specs" .

