@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_design_handoff a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "design-handoff" ;
    skos:broader "Document generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/design-handoff" ;
    oc:contentHash "1f3b6478683aeb2e27c101bca6690f5c1af39e2037f8ab2eab1b7aabea310a08" ;
    oc:differentia "produces developer handoff specifications from designs including layout tokens, component props, interaction states, responsive breakpoints, edge cases, and accessibility details" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<Figma URL or design description>" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Generate developer handoff specs from a design. Use when a design is ready for engineering and needs a spec sheet covering layout, design tokens, component props, interaction states, responsive breakpoints, edge cases, and animation details." ;
    oc:hasName "design-handoff" ;
    oc:impartsKnowledge oc:kn_549827de,
        oc:kn_5ae3eb76,
        oc:kn_85057e45,
        oc:kn_e5d083c7,
        oc:kn_edd2770f ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignAvailable ;
    oc:resolvesIntent "convert design to engineering spec",
        "create developer handoff documentation",
        "generate design handoff spec",
        "specify design implementation details" ;
    oc:yieldsState oc:HandoffSpecGenerated .

oc:kn_549827de a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying measurements, colors, typography, or spacing in handoff documentation" ;
    oc:directiveContent "Use design token references (e.g., spacing-md) instead of raw pixel values in handoff specs to maintain consistency and enable theming." ;
    oc:hasRationale "Tokens provide a single source of truth and make design updates propagate automatically across the codebase." ;
    oc:severityLevel "HIGH" .

oc:kn_5ae3eb76 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any section of the handoff spec" ;
    oc:directiveContent "Never assume or leave design decisions unspecified in the handoff; any gap will be filled by developer guessing." ;
    oc:hasRationale "Incomplete specs lead to implementation divergence from the intended design, increasing revision cycles." ;
    oc:severityLevel "HIGH" .

oc:kn_85057e45 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When describing responsive behavior or interaction changes" ;
    oc:directiveContent "Explain the design rationale — e.g., 'this collapses on mobile because users primarily use one-handed' — rather than just stating what happens." ;
    oc:hasRationale "Contextual rationale helps developers make good judgment calls when encountering unspecified situations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e5d083c7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When documenting component interactions and states" ;
    oc:directiveContent "Specify every visual state including default, hover, active, disabled, loading, error, and empty states for all interactive components." ;
    oc:hasRationale "If a state is not specified, developers will guess, leading to inconsistent or missing UI behavior." ;
    oc:severityLevel "HIGH" .

oc:kn_edd2770f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating the handoff spec" ;
    oc:directiveContent "Provide the Figma link or design description and mention the tech stack (e.g., React + Tailwind) so the spec can include relevant implementation notes." ;
    oc:hasRationale "Exact design sources yield precise measurements and tokens; knowing the tech stack enables stack-specific implementation guidance." ;
    oc:severityLevel "MEDIUM" .

