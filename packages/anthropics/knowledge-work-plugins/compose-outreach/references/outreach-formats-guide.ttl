oc:skill_knowledge_work_plugins_compose_outreach_outreach_formats_guide a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "outreach-formats-guide" ;
    skos:broader "Communication guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/compose-outreach" ;
    oc:contentHash "726b86819ada5565f387fcb37d5c89edb0c81315534e0b5642722511a7969d73" ;
    oc:differentia "provides structure, constraints, and examples for email, call script, and LinkedIn outreach formats with tone calibration" ;
    oc:extends oc:skill_knowledge_work_plugins_compose_outreach ;
    oc:hasCategory "marketing" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Value Bridge (20-30 seconds):** Explain why this is worth their time *right now*, tied to a concrete outcome." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**Ask (10 seconds):** Single, specific, low-friction — e.g., \"Do you have 15 minutes to explore if that's relevant?\"" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Three parts — a guide, not a word-for-word read:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Opening (10-15 seconds):** State your name and company, then reference the specific hook immediately." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Call Script" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Personal acknowledgment (what you noticed about them)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Soft invitation to connect or respond" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "One brief sentence on why you reached out" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Structure" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "No pitch — just open a door" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**300 characters maximum** (platform limit is 400 — we target 300 to prevent overruns)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "No attachments, no links in the first message" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Constraints" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BlockQuote ;
                                    oc:blockType "blockquote" ;
                                    oc:contentOrder 1 ;
                                    oc:quoteContent "Saw your post about [topic] in [community] — our team has been thinking about the same problem. Would love to share what we've learned. Open to a quick chat?" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Example" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "LinkedIn Message" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 5 ;
                            oc:tableCaption "## Tone Calibration by Context" ;
                            oc:tableMarkdown """| Context | Tone | Approach |
|---------|------|----------|
| Inbound / trial / active community member | Warm, helpful, collaborative | Lead with their activity, offer help |
| Cold outreach (no prior relationship) | Professional, respectful, brief | Lead with signal, be direct about why now |
| Re-engagement (went dark) | Casual, low-pressure | Short, acknowledge the gap, easy ask |
| Executive outreach | Formal, concise, outcome-focused | Lead with business impact, not product |
| Champion job change | Warm, congratulatory | Celebrate them, then gently explore new opportunity |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Tone Calibration by Context" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Starting with filler (\"I hope this email finds you well\") or defensive language (\"I know you're busy but...\")" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Vague subject lines like \"Following up\" or \"Quick question\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Fabricated familiarity (\"I've been following your company for a while...\")" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Multi-paragraph messages with multiple asks" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "What to Avoid (All Channels)" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Ask:** Single, specific, low-friction next step." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Value Bridge:** 1-2 sentences connecting their signal to something you can help with. Be concrete." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Subject line:** 4-8 words, specific and curiosity-inducing. Reference the hook directly." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Opening:** Acknowledge the specific signal. Start with \"You\", \"Your team\", \"Saw that\", \"Noticed\" — not \"I\"." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Total length:** 3-5 sentences max. No paragraphs." ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Structure" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BlockQuote ;
                                    oc:blockType "blockquote" ;
                                    oc:contentOrder 1 ;
                                    oc:quoteContent """Subject: Question about your [feature] usage

Noticed your team has been deep in [feature] recently — you've hit [usage metric] in the last two weeks. That usually means teams are running into [common blocker] around this stage. Happy to walk through how [similar company] handled it if useful. 15 minutes this week?""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Example" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Email" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Outreach Formats — Guidelines and Examples" ] ;
    oc:impartsKnowledge oc:kn_1d605fe4,
