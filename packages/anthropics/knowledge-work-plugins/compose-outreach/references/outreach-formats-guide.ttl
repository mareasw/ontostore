oc:skill_anthropics_knowledge_work_plugins_compose_outreach_outreach_formats_guide a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "outreach-formats-guide" ;
    skos:broader "format guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/compose-outreach" ;
    oc:contentHash "726b86819ada5565f387fcb37d5c89edb0c81315534e0b5642722511a7969d73" ;
    oc:differentia "provides channel-specific templates, tone calibration, and anti-patterns for composing outreach messages across email, call scripts, and LinkedIn" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_compose_outreach ;
    oc:hasArgumentHint "channel type (email, call, linkedin) or context" ;
    oc:hasCategory "marketing" ;
    oc:hasRequirement oc:req_61cc24cf ;
    oc:impartsKnowledge oc:kn_3b6ac822,
        oc:kn_48414682,
        oc:kn_9a27e21d,
        oc:kn_ce293a5b,
        oc:kn_fba7c4eb ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "avoid common outreach mistakes",
        "calibrate outreach tone by context",
        "compose LinkedIn outreach messages",
        "format outreach messages for email",
        "write cold call scripts" .

oc:kn_3b6ac822 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing LinkedIn outreach messages" ;
    oc:directiveContent "LinkedIn messages must be 300 characters maximum (targeting below the 400 platform limit to prevent overruns), with no attachments or links in the first message." ;
    oc:hasRationale "Platform limits are hard constraints; targeting 300 characters provides a safety buffer and forces brevity, while links/attachments in first messages reduce response rates." ;
    oc:severityLevel "CRITICAL" .

oc:kn_48414682 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting tone and approach for outreach based on relationship context" ;
    oc:directiveContent "Calibrate tone by context: warm/collaborative for inbound, professional/brief for cold, casual/low-pressure for re-engagement, formal/concise for executives, and warm/congratulatory for champion job changes." ;
    oc:hasRationale "Context-appropriate tone builds trust; mismatched tone (e.g., overly casual with executives, or pushy with re-engagement) causes immediate disengagement." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9a27e21d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing any outreach message across all channels" ;
    oc:directiveContent "Every outreach message must have three parts: a hook (specific signal reference), a value bridge (concrete connection to what you can help with), and a single low-friction ask." ;
    oc:hasRationale "The hook-value bridge-ask structure ensures messages are relevant, valuable, and actionable without overwhelming the recipient." ;
    oc:severityLevel "HIGH" .

oc:kn_ce293a5b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing outreach on any channel" ;
    oc:directiveContent "Never open with filler ('I hope this email finds you well'), defensive language ('I know you're busy but...'), vague subject lines ('Following up'), fabricated familiarity, or multiple asks in a single message." ;
    oc:hasRationale "These patterns signal inauthenticity, waste the recipient's attention, and dramatically reduce response rates across all channels." ;
    oc:severityLevel "HIGH" .

oc:kn_fba7c4eb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing email outreach messages" ;
    oc:directiveContent "Email outreach must be 3-5 sentences max with no paragraphs. Subject lines must be 4-8 words, specific and curiosity-inducing." ;
    oc:hasRationale "Brevity drives response rates; short messages respect the recipient's time and force clarity of purpose." ;
    oc:severityLevel "HIGH" .

oc:req_61cc24cf a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of outreach channels (email, phone, LinkedIn) and their constraints" .

