        oc:kn_6c5ef9a2,
        oc:kn_b351ea92 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "choose tone by outreach context",
        "format outreach messages",
        "structure LinkedIn connection messages",
        "write concise cold outreach",
        "write outreach email subject lines and body" .

oc:kn_1d605fe4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "All outreach channels" ;
    oc:directiveContent "All outreach follows a 3-part structure: (1) Acknowledge a specific signal about the recipient, (2) Bridge that signal to value you can provide, (3) Make a single, specific, low-friction ask." ;
    oc:hasRationale "Consistent structure ensures every message is personalized, value-driven, and has a clear next step without overwhelming the recipient." ;
    oc:severityLevel "HIGH" .

oc:kn_29ff9a53 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Email and LinkedIn outreach openings" ;
    oc:directiveContent "Open with second-person or observational language ('You', 'Your team', 'Saw that', 'Noticed') — never first-person ('I') as the opening word." ;
    oc:hasRationale "Leading with the recipient (not yourself) immediately signals personalization and relevance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3315a262 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting tone for outreach" ;
    oc:directiveContent "Tone must be calibrated by context: warm/collaborative for inbound, professional/brief for cold, casual/low-pressure for re-engagement, formal/concise for executives, congratulatory for champion job changes." ;
    oc:hasRationale "One-size-fits-all tone mismatches the recipient's relationship stage and reduces trust." ;
    oc:severityLevel "MEDIUM" .

oc:kn_34f252c3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "All outreach channels" ;
    oc:directiveContent "Never start with filler phrases ('I hope this email finds you well'), defensive language ('I know you're busy but...'), fabricated familiarity ('I've been following your company'), vague subject lines ('Following up', 'Quick question'), or multi-paragraph messages with multiple asks." ;
    oc:hasRationale "These patterns signal low-confidence or generic outreach, reducing credibility and response rates." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6c5ef9a2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Email outreach" ;
    oc:directiveContent "Email outreach must be 3-5 sentences max with no paragraphs. Subject lines must be 4-8 words, specific and curiosity-inducing, referencing the hook directly." ;
    oc:hasRationale "Long emails get skimmed or ignored. Short, specific messages respect the reader's time and drive higher response rates." ;
    oc:severityLevel "HIGH" .

oc:kn_b351ea92 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "LinkedIn outreach" ;
    oc:directiveContent "LinkedIn messages must be 300 characters maximum (platform limit is 400, target 300 to prevent overruns). No attachments, no links in first message, no pitch." ;
    oc:hasRationale "LinkedIn imposes character limits and algorithmic penalties for links. First messages should only open a door, not sell." ;
    oc:severityLevel "HIGH" .

