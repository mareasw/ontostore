@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_compose_outreach a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "compose-outreach" ;
    skos:broader "Outreach generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/compose-outreach" ;
    oc:contentHash "e32698ccc49496cde5a463febd97b1c15a96580644d6a6f9caf53546495a8f80" ;
    oc:differentia "Produces personalized email, call script, and LinkedIn message formats grounded in Common Room signals and web research" ;
    oc:handlesFailure oc:ContactNotFound,
        oc:InsufficientData ;
    oc:hasArgumentHint "person name or company name" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Generate personalized outreach messages using Common Room signals. Triggers on 'draft outreach to [person]', 'write an email to [name]', 'compose a message for [contact]', or any outreach drafting request." ;
    oc:hasName "compose-outreach" ;
    oc:impartsKnowledge oc:kn_101d1ce4,
        oc:kn_2b832935,
        oc:kn_69cd040f,
        oc:kn_73f48230,
        oc:kn_d3eb26ee ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:SystemAuthenticated ;
    oc:resolvesIntent "compose LinkedIn message for prospect",
        "create call script for sales outreach",
        "draft outreach to person",
        "generate multi-channel outreach messages",
        "write cold outreach with signal-based personalization",
        "write personalized email to contact" ;
    oc:yieldsState oc:OutreachDrafted .

oc:kn_101d1ce4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating outreach output" ;
    oc:directiveContent "Always produce all three outreach formats (email, call script, LinkedIn message) clearly labeled, and annotate choices with 2-4 sentences explaining which signals were used and why." ;
    oc:hasRationale "Multi-format output lets the user choose the best channel for their relationship stage and context" ;
    oc:severityLevel "MEDIUM" .

oc:kn_2b832935 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating outreach formats" ;
    oc:directiveContent "LinkedIn messages must be under 300 characters — no exceptions. Emails must be 3-5 sentences max. Subject lines must be 4-8 words." ;
    oc:hasRationale "Platform limits and attention constraints make brevity essential for engagement" ;
    oc:severityLevel "HIGH" .

oc:kn_69cd040f a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When signal data is sparse or minimal" ;
    oc:directiveContent "If Common Room signals are thin, run web search for external hooks (funding, announcements, recent news). If web search also returns little, present available data honestly and ask the user for context rather than fabricating." ;
    oc:hasRationale "Honest disclosure of data gaps maintains trust and invites user collaboration for better results" ;
    oc:severityLevel "HIGH" .

oc:kn_73f48230 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any outreach message" ;
    oc:directiveContent "Never fabricate signals or personalization hooks — only reference data retrieved from Common Room or web search. Outreach grounded in fabricated signals is worse than no outreach." ;
    oc:hasRationale "Fabricated signals undermine trust and produce spam-like messages that damage brand credibility" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d3eb26ee a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which signals to use for personalization" ;
    oc:directiveContent "Rank personalization hooks by recency (last 7-14 days), specificity (concrete action taken), and relevance (connects to product value). Good hooks: posted a question, just hired engineers, trial nearing expiration. Bad hooks: 'I noticed you're a customer' or generic trends." ;
    oc:hasRationale "Strong hooks produce outreach that feels timely and relevant rather than generic and mass-produced" .

