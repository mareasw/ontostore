                                    oc:itemText "Provide a clear action plan with timeline" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Take ownership (no deflecting or excuse-making)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Offer a meeting or call if appropriate for the severity" ],
