@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_draft_response a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "draft-response" ;
    skos:broader "Customer communication drafting skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/draft-response" ;
    oc:contentHash "e4e3c0552e3ff9d47734e0c4ab4f04553eaf844240502a71a9c1c6cc3861d460" ;
    oc:differentia "that produces professional, situation-tailored responses across multiple channels (email, chat, tickets) with empathy-first tone calibration, quality gates, and iterative refinement" ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "<situation description>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Draft a professional customer-facing response tailored to the situation and relationship. Use when answering a product question, responding to an escalation or outage, delivering bad news like a delay or won't-fix, declining a feature request, or replying to a billing issue." ;
    oc:hasName "draft-response" ;
    oc:impartsKnowledge oc:kn_2685233a,
        oc:kn_ac7319df,
        oc:kn_cbabb367,
        oc:kn_e3bf8a66,
        oc:kn_f83aac02,
        oc:kn_fd9fc923 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "communicate during outage or incident",
        "decline a feature request professionally",
        "deliver bad news to customer",
        "draft customer-facing email response",
        "follow up with customer after silence",
        "reply to billing or account issue",
        "respond to customer escalation" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_2685233a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating any draft response" ;
    oc:directiveContent "Before drafting, gather context from all available sources: previous email threads, internal chat discussions, CRM account details, support ticket history, and knowledge base articles. Verify facts and prior commitments." ;
    oc:hasRationale "Context-aware responses demonstrate professionalism and prevent contradictions with previous communications, which would damage credibility" ;
    oc:severityLevel "HIGH" .

oc:kn_ac7319df a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When structuring any customer communication" ;
    oc:directiveContent "Follow the 4-part response structure: (1) Acknowledgment/Context, (2) Core Message, (3) Next Steps with specific owners and dates, (4) Warm closing. Always include a clear next step or call to action." ;
    oc:hasRationale "Consistent structure ensures completeness, scannability, and clear expectations — reducing back-and-forth and customer anxiety" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cbabb367 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any customer-facing communication" ;
    oc:directiveContent "Lead every response with empathy — acknowledge the customer's situation before jumping to solutions. Match their energy: be empathetic when frustrated, enthusiastic when they're excited." ;
    oc:hasRationale "Empathy-first communication builds trust and de-escalates tension, which is the foundation of effective customer relationships" ;
    oc:severityLevel "HIGH" .

oc:kn_e3bf8a66 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any customer response text" ;
    oc:directiveContent "Never use passive voice to avoid ownership, corporate jargon, or deflect blame to other teams/systems. Always use active voice and take responsibility with 'we' not 'the system'." ;
    oc:hasRationale "Passive voice and jargon erode trust and signal lack of accountability, which worsens customer sentiment" ;
    oc:severityLevel "HIGH" .

oc:kn_f83aac02 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Quality check phase before presenting any draft response" ;
    oc:directiveContent "Do not make commitments beyond what is authorized, do not share unapproved product roadmap details, and do not include unnecessary caveats that undermine confidence." ;
    oc:hasRationale "Unauthorized commitments create legal and operational risk; leaked roadmap info damages product strategy; excessive hedging signals incompetence" ;
    oc:severityLevel "CRITICAL" .

oc:kn_fd9fc923 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining appropriate response length for the communication channel" ;
    oc:directiveContent "Adjust response length by channel: 1-4 sentences for chat/IM, 1-3 paragraphs for support tickets, 3-5 paragraphs for email, thorough with headers for escalations, 2-3 paragraphs max for executives." ;
    oc:hasRationale "Channel-appropriate length respects the customer's time and attention, increasing the likelihood the message is read and understood" ;
    oc:severityLevel "MEDIUM" .

