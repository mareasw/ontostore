                            oc:contentOrder 11 ;
                            oc:textContent "**Declining a request (feature request, discount, exception):**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent "**Delivering bad news (feature sunset, delay, can't-fix):**" ],
                        [ a oc:BulletList ;
