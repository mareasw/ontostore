oc:kn_35d71e35 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any journal entry" ;
    oc:directiveContent "Debits MUST equal credits before any journal entry is finalized. This is a non-negotiable accounting rule." ;
    oc:hasRationale "Imbalanced entries violate double-entry bookkeeping principles and cannot be posted to the GL." ;
    oc:severityLevel "CRITICAL" .

oc:kn_409a726c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During the review checklist step" ;
    oc:directiveContent "Always compare the current period entry to the prior period entry of the same type. Flag any unusual or out-of-pattern amounts for investigation." ;
    oc:hasRationale "Period-over-period comparison catches calculation errors, missed items, and anomalies before posting." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5dc9fe4c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finalizing any journal entry" ;
    oc:directiveContent "Do not post entries without supporting detail, clear memos, and references to source documentation. Avoid entries inconsistent with prior period treatment." ;
    oc:hasRationale "Entries without supporting documentation fail audit review and create compliance risk." ;
    oc:severityLevel "HIGH" .

oc:kn_a451ac51 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When preparing accrual-type journal entries" ;
    oc:directiveContent "Accrual entries (AP accruals, payroll accruals) should be flagged for auto-reversal in the subsequent period." ;
    oc:hasRationale "Auto-reversal prevents double-counting expenses when the actual invoice or payment is recorded in the next period." ;
    oc:severityLevel "HIGH" .

oc:kn_f7dd66b0 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — this is a universal constraint" ;
    oc:directiveContent "This skill assists with journal entry preparation but does not provide financial advice. All entries must be reviewed by qualified financial professionals before posting." ;
    oc:hasRationale "AI-generated financial entries carry risk of material misstatement and require human expert review." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fd78f9f0 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no data source is connected" ;
    oc:directiveContent "If no ERP or data warehouse is connected, prompt the user to paste trial balance data, upload a spreadsheet, or manually provide GL balances and subledger detail." ;
    oc:hasRationale "The workflow must still function without automated data connectors by accepting manual input." ;
    oc:severityLevel "MEDIUM" .

