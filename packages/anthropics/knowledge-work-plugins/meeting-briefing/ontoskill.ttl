@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_meeting_briefing a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "meeting-briefing" ;
    skos:broader "Meeting preparation assistant" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/meeting-briefing" ;
    oc:contentHash "9c74e45d66e2e1606249f9d49f253e2e0df9c2faccbc537b67d70e1b1492fc0d" ;
    oc:differentia "Synthesizes multi-source context into structured legal briefings with action item tracking" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "meeting topic, participant names, or meeting type (e.g., 'deal review with Acme Corp', 'board meeting prep')" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Prepare structured briefings for meetings with legal relevance and track resulting action items. Use when preparing for contract negotiations, board meetings, compliance reviews, or any meeting where legal context, background research, or action tracking is needed." ;
    oc:hasName "meeting-briefing" ;
    oc:impartsKnowledge oc:kn_3cf69360,
        oc:kn_3dcc2ecb,
        oc:kn_51c0b6e0,
        oc:kn_cc54dc5c,
        oc:kn_d0d314e5 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create legal meeting brief",
        "generate meeting prep document",
        "prepare for board meeting",
        "prepare for contract negotiation",
        "prepare for regulatory meeting",
        "prepare meeting briefing",
        "track meeting action items" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_3cf69360 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When capturing action items during or after meetings" ;
    oc:directiveContent "Never assign action items to teams or groups — every action item must have exactly one individual owner, a specific deadline date, and a concrete description." ;
    oc:hasRationale "Vague ownership and deadlines are the primary reason action items fall through the cracks; specificity drives accountability" ;
    oc:severityLevel "HIGH" .

oc:kn_3dcc2ecb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing the final briefing document" ;
    oc:directiveContent "Always flag preparation gaps — sources that were unavailable, information that appears outdated, unanswered questions, or documents that could not be located." ;
    oc:hasRationale "Transparent gap identification prevents over-reliance on incomplete briefings and surfaces risks before the meeting" ;
    oc:severityLevel "HIGH" .

oc:kn_51c0b6e0 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning the briefing preparation workflow" ;
    oc:directiveContent "Verify connected data sources (calendar, email, chat, documents, CLM, CRM) are accessible before starting context gathering, and note which sources are unavailable." ;
    oc:hasRationale "Knowing source availability upfront shapes the research strategy and sets expectations about briefing completeness" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cc54dc5c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — this is a hard boundary for all outputs" ;
    oc:directiveContent "Assist with legal workflows but do not provide legal advice. Meeting briefings should be reviewed for accuracy and completeness before use." ;
    oc:hasRationale "The agent is not a licensed attorney; providing legal advice could expose the organization to liability and create privileged communication risks" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d0d314e5 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When determining which briefing template sections to include" ;
    oc:directiveContent "Tailor briefing depth and sections to meeting type: add deal summary and counterparty dynamics for deal reviews; risk register highlights and regulatory updates for board meetings; privilege considerations for regulatory meetings." ;
    oc:hasRationale "Different meeting types have fundamentally different information needs; a one-size-fits-all briefing wastes preparation time and misses critical context" ;
    oc:severityLevel "MEDIUM" .

