        oc:kn_3f2798ac,
        oc:kn_7b213daa,
        oc:kn_9e877f94,
        oc:kn_a011b177,
        oc:kn_a142a6ef,
        oc:kn_a3e87bf5 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:SystemAuthenticated ;
    oc:resolvesIntent "brief for legal meeting",
        "prepare for board meeting",
        "prepare for contract negotiation",
        "prepare for regulatory meeting",
        "prepare for vendor call",
        "prepare meeting briefing",
        "track meeting action items" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_061f9f10 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing ongoing action item tracking" ;
    oc:directiveContent "Track action items by priority cadence: high priority daily, medium at weekly review, low at monthly review. Overdue items escalate to owner and their manager." ;
    oc:hasRationale "Priority-based cadence prevents both neglect of urgent items and overhead on low-priority ones." .

oc:kn_32cf1cfd a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing action items" ;
    oc:directiveContent "Action items should be specific (e.g., 'Send redline of Section 4.2 to counterparty counsel'), assigned to a single owner, given a concrete deadline, and categorized by type (legal team / business team / external / follow-up meeting)." ;
    oc:hasRationale "Specific, owned, dated, typed action items are far more likely to be completed correctly and on time." .

oc:kn_3f2798ac a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any briefing output" ;
    oc:directiveContent "Assist with legal workflows but do not provide legal advice. Meeting briefings must be reviewed for accuracy and completeness before use." ;
    oc:hasRationale "AI-generated legal content carries risk of inaccuracy; human review ensures professional responsibility is maintained." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7b213daa a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining what to include in a briefing" ;
    oc:directiveContent "Tailor briefing depth and sections to meeting type: deal reviews need contract status and counterparty dynamics; board meetings need risk highlights and regulatory updates; regulatory meetings need privilege considerations and compliance posture." ;
    oc:hasRationale "Different meeting types have fundamentally different information needs; a one-size-fits-all briefing wastes preparation time and misses critical context." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9e877f94 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When preparing any meeting briefing" ;
    oc:directiveContent "1. Identify meeting (title, type, participants, agenda, role, prep time) → 2. Assess prep needs by meeting type → 3. Gather context from all connected sources (calendar, email, chat, docs, CLM, CRM) → 4. Synthesize into structured briefing → 5. Identify and flag preparation gaps" ;
    oc:hasRationale "Sequential methodology ensures comprehensive coverage without missing critical context from any source." ;
    oc:stepOrder 1 .

oc:kn_a011b177 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing any briefing" ;
    oc:directiveContent "Identify preparation gaps — flag sources that were unavailable, information that appears outdated, questions that remain unanswered, and documents that could not be located." ;
    oc:hasRationale "Incomplete briefings are worse than no briefings if the gaps are invisible; surfacing gaps allows the user to fill them manually." ;
    oc:severityLevel "HIGH" .

oc:kn_a142a6ef a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When capturing meeting action items" ;
    oc:directiveContent "Never assign action items to teams or groups — every action item must have exactly one individual owner. Never use vague deadlines like 'soon' or 'ASAP'." ;
    oc:hasRationale "Shared ownership means no ownership; vague deadlines mean missed deadlines." ;
    oc:severityLevel "HIGH" .

oc:kn_a3e87bf5 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When wrapping up after a meeting" ;
    oc:directiveContent "After meeting: 1. Distribute action items → 2. Set calendar reminders for deadlines → 3. Update systems (CLM, matter management, risk register) → 4. File meeting notes → 5. Flag urgent items" ;
    oc:hasRationale "Systematic post-meeting follow-up ensures nothing falls through the cracks and institutional knowledge is captured." ;
    oc:stepOrder 2 .

