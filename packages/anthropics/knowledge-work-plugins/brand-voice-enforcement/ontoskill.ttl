            oc:blockType "paragraph" ;
            oc:contentOrder 2 ;
            oc:textContent "Wait for the user to provide guidelines before proceeding." ] ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_c9c18ca21170dfd6 a oc:WorkflowStep ;
    dcterms:description "Offer options: follow guidelines strictly, adapt for context, or override" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
