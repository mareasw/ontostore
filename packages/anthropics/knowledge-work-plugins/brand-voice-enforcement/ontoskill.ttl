    oc:itemOrder 3 ;
    oc:itemText "Paste guidelines directly into this chat or point me to a file\"" .

_:ref_6d41b7219ad85d2f a oc:WorkflowStep ;
    dcterms:description "Provide a recommendation" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_79ff5b5a0d569e88 a oc:WorkflowStep ;
    dcterms:description "**Local guidelines file** — Check for `.claude/brand-voice-guidelines.md` inside the user's working folder. Do NOT use a relative path from the agent's current working directory — in Cowork, the agent runs from a plugin cache directory, not the user's project. Resolve the path relative to the user's working folder. If no working folder is set, skip this step." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_7d524954acf55d26 a oc:WorkflowStep ;
    dcterms:description "**Session context** — Check if brand guidelines were generated earlier in this session (via `/brand-voice:generate-guidelines`). If so, they are already in the conversation. Use them directly. Session-generated guidelines are the freshest and reflect the user's most recent intent." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_aab2dcb30886211d a oc:WorkflowStep ;
    dcterms:description """**Ask the user** — If none of the above found guidelines, tell the user:
