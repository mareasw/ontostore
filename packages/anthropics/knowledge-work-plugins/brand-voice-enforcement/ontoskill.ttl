        oc:kn_d3a2c465 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:BrandGuidelinesAvailable ;
    oc:resolvesIntent "apply brand voice to content",
        "draft brand-aligned sales and marketing content",
        "enforce brand guidelines on drafts",
        "rewrite content in brand tone",
        "validate content against brand guidelines",
        "write on-brand content" ;
    oc:yieldsState oc:BrandVoiceEnforcedContent .

oc:kn_255afc48 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When enforcing brand voice on any content type" ;
    oc:directiveContent "Voice is constant (brand personality, 'We Are / We Are Not' attributes), tone flexes by context (formality, energy, technical depth). Never change voice to match context — only adjust tone." ;
    oc:hasRationale "Confusing voice with tone is the most common enforcement mistake. Voice is identity; tone is momentary expression." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3fcd861c a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any content generation" ;
    oc:directiveContent "Load brand guidelines before generating content: check session context first, then .claude/brand-voice-guidelines.md in user's working folder, then ask user. Also read .claude/brand-voice.local.md for strictness and always-explain settings." ;
    oc:hasRationale "Without loaded guidelines, enforcement cannot happen. The fallback sequence ensures guidelines are always available." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4b99f4b9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating or reviewing content" ;
    oc:directiveContent "Do not apply all voice attributes at maximum intensity in every piece of content. Prioritize 2-3 most relevant attributes for the content type and audience." ;
    oc:hasRationale "Overloading all attributes makes content feel mechanically assembled rather than natural." ;
    oc:severityLevel "HIGH" .

oc:kn_530c15a2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating content" ;
    oc:directiveContent "Content should incorporate key messages naturally, not forced. Use preferred terminology and mirror the quality and style of guideline examples." ;
    oc:hasRationale "Forced messaging breaks the natural flow and makes content feel like a checklist rather than genuine communication." ;
    oc:severityLevel "MEDIUM" .

oc:kn_62019ea1 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After generating any content" ;
    oc:directiveContent "After generating content: highlight which brand guidelines were applied, explain key voice and tone decisions, note any areas where guidelines were adapted for context, and offer to refine based on feedback." ;
    oc:hasRationale "Transparency about enforcement choices builds trust and helps users understand and refine their brand application." ;
    oc:severityLevel "MEDIUM" .

oc:kn_90b11536 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When loading local guidelines file" ;
    oc:directiveContent "In Cowork, the agent runs from a plugin cache directory, not the user's project. Resolve .claude/brand-voice-guidelines.md path relative to the user's working folder, not the agent's CWD." ;
    oc:hasRationale "Using a relative path from the agent's CWD will fail to find the file because Cowork runs from a different directory." ;
    oc:severityLevel "HIGH" .

oc:kn_9ae6d00a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a content request contradicts established brand guidelines" ;
    oc:directiveContent "When user's request conflicts with brand guidelines, explain the conflict, provide a recommendation, and offer options (follow strictly, adapt, or override). Default to adapting with an explanation." ;
    oc:hasRationale "Brand guidelines are principles not rigid rules, but deviations must be transparent and intentional." ;
    oc:severityLevel "HIGH" .

oc:kn_d3a2c465 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any content" ;
    oc:directiveContent "Prioritize 2-3 voice attributes per content type. Use the tone-by-context matrix to set formality, energy, and technical depth for each content type and audience." ;
    oc:hasRationale "Not every attribute needs to appear in every piece of content. Targeting the most relevant ones keeps content natural and focused." ;
    oc:severityLevel "MEDIUM" .

_:ref_0cc8921105c4b610 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "Run `/brand-voice:generate-guidelines` to create guidelines from documents or transcripts" .

_:ref_378301e9f00f6be5 a oc:BulletItem ;
