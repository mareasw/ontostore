                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Before (Generic)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Voice: Data-driven** — concrete numbers (23%, 18%, $12M) replace vague \"more productive\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Tone: Formality MEDIUM** — professional but conversational" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "**Tone: Technical depth LOW** — outcomes and impact, not feature descriptions" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "**Terminology**: \"buying signals\" and \"pipeline\" (industry-specific but accessible to VP Sales)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Tone: Energy HIGH** — active language, short sentences, urgency" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Voice: Confident** — leads with a bold claim and specific data (not \"I think our product could be\")" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Voice: Direct** — gets to the point immediately, no \"I wanted to reach out\"" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "What Changed" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """Subject: [Company] is leaving pipeline on the table

Hi [Name],

Your team closed $12M last quarter — impressive. But our data shows
mid-market SaaS teams like yours typically lose 23% of qualified pipeline
to slow follow-ups.

[Product] fixes that. We help sales teams respond to buying signals in
real time, not hours later. [Customer X] saw their win rate jump 18%
in the first quarter.

Worth 15 minutes to see if the numbers apply to [Company]?

[Sender]
""" ;
