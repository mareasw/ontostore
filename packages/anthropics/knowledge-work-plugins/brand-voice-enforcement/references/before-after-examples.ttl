oc:skill_anthropics_knowledge_work_plugins_brand_voice_enforcement_before_after_examples a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "before-after-examples" ;
    skos:broader "Reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/brand-voice-enforcement" ;
    oc:contentHash "09e406f700118ab9bfb9b4cf624df8b8740b700a152190971651779a4c00b18a" ;
    oc:differentia "provides concrete before/after content examples demonstrating how brand voice enforcement transforms generic text into on-brand output across multiple content types" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_brand_voice_enforcement ;
    oc:handlesFailure oc:BrandGuidelinesMissing ;
    oc:hasArgumentHint "content-type (e.g., cold-email, follow-up, proposal, linkedin, slack)" ;
    oc:hasCategory "document" ;
    oc:impartsKnowledge oc:kn_3b602bf8,
        oc:kn_503af8b9,
        oc:kn_7a88fd3e,
        oc:kn_db468c77,
        oc:kn_fff875ce ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:BrandGuidelinesAvailable ;
    oc:resolvesIntent "calibrate content rewriting against brand standards",
        "learn brand voice transformation patterns by content type",
        "see brand voice enforcement examples",
        "understand how to apply brand voice to content" ;
    oc:yieldsState oc:BrandVoiceExamplesLoaded .

oc:kn_3b602bf8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using these examples to enforce brand voice on new content" ;
    oc:directiveContent "Every brand voice transformation must annotate what changed and why — identifying specific voice attributes (confident, data-driven, direct), tone settings (energy, formality, technical depth), and terminology choices that were applied." ;
    oc:hasRationale "Annotations create a teachable pattern that helps the agent learn which voice dimensions to activate for each content type, rather than blindly copying surface patterns." ;
    oc:severityLevel "HIGH" .

oc:kn_503af8b9 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When rewriting follow-up emails or any repeated-touch content" ;
    oc:directiveContent "Key principle: 'Add new value each touch' — no empty follow-ups. Every piece of content must deliver concrete information (data, benchmarks, insights) rather than vague filler." ;
    oc:hasRationale "The data-driven voice attribute demands that every communication carries substantive, specific information rather than restating the ask without new context." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7a88fd3e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when using these examples as templates or patterns" ;
    oc:directiveContent "The examples use a fictional B2B SaaS company for illustration. During actual enforcement, all specifics (data points, product names, metrics) must be replaced with data from the user's actual brand guidelines and context." ;
    oc:hasRationale "Copying the fictional data verbatim would produce inauthentic, inaccurate content that undermines brand credibility." ;
    oc:severityLevel "CRITICAL" .

oc:kn_db468c77 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any brand-enforced content, especially LinkedIn posts and outreach" ;
    oc:directiveContent "Avoid prohibited terms like 'revolutionary', 'game-changing', 'excited to announce', 'comprehensive solution', and vague filler like 'I think our product could be a great fit'." ;
    oc:hasRationale "These terms signal generic marketing hype that contradicts the confident, data-driven, direct voice the brand requires." ;
    oc:severityLevel "HIGH" .

oc:kn_fff875ce a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When enforcing brand voice on any new piece of content" ;
    oc:directiveContent "Match the content type to the closest example, note which voice attributes are most active for that type, apply the tone settings, check 'We Are Not' boundaries, and verify terminology compliance." ;
    oc:hasRationale "This 5-step calibration process ensures consistent enforcement across content types while respecting the distinct voice profiles appropriate to each channel." ;
    oc:severityLevel "HIGH" .

