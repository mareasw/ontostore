@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_brand_voice_enforcement_voice_constant_tone_flexes a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "voice-constant-tone-flexes" ;
    skos:broader "Brand communication framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/brand-voice-enforcement" ;
    oc:contentHash "35c95637a30dc3d35dd2dce428972f13840be75860ccd021419cbc7ceb3c6f73" ;
    oc:differentia "that separates immutable brand voice identity from context-adaptive tone dimensions for consistent yet flexible content enforcement" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_brand_voice_enforcement ;
    oc:hasArgumentHint "content-type and context" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_200f9ddd,
        oc:kn_ab0f3581,
        oc:kn_bed40325,
        oc:kn_eff5e8d9,
        oc:kn_f51b0f0a ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "adjust tone for different contexts",
        "apply brand voice to content",
        "configure tone for content type",
        "distinguish voice from tone",
        "enforce brand consistency" .

oc:kn_200f9ddd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user requests a specific communication style" ;
    oc:directiveContent "Never confuse voice with tone. If the user asks for 'casual' content, adjust TONE (lower formality, higher energy). Do NOT change VOICE — the brand's personality stays the same." ;
    oc:hasRationale "Confusing voice with tone is the most common enforcement mistake and directly undermines brand consistency." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ab0f3581 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When enforcing brand voice on a specific piece of content" ;
    oc:directiveContent "For each piece of content, prioritize 2-3 voice attributes from the 'We Are' column that are most relevant to the content type and audience. Not every attribute needs to appear in every piece of content." ;
    oc:hasRationale "Applying all voice attributes at maximum intensity makes content feel mechanically assembled rather than natural." ;
    oc:severityLevel "HIGH" .

oc:kn_bed40325 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During content enforcement and review" ;
    oc:directiveContent "For every piece of content, check each 'We Are' attribute (does the content reflect this?) and each 'We Are Not' boundary (does the content avoid crossing it?). If a boundary is crossed, revise the specific passage. If an attribute is missing, find a natural place to express it." ;
    oc:hasRationale "The 'We Are / We Are Not' table is the anchor of brand voice — it defines the brand's personality in paired attributes with explicit boundaries." ;
    oc:severityLevel "HIGH" .

oc:kn_eff5e8d9 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When determining how a brand should sound for a specific content type or audience" ;
    oc:directiveContent "Tone adjusts along three independent dimensions: Formality (high/medium/low), Energy (high/medium/warm/low), and Technical Depth (high/medium/low). Combine these three dimensions based on the content context using the tone-by-context matrix." ;
    oc:hasRationale "These three dimensions are sufficient to capture the meaningful variation in how a brand communicates across contexts, while keeping voice constant." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f51b0f0a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying brand guidelines to any content" ;
    oc:directiveContent "Voice is constant (WHO the brand is — personality, values, identity) and never changes. Tone flexes by context (HOW the brand speaks in a given moment). Never alter voice attributes when adjusting for context — only adjust tone." ;
    oc:hasRationale "This distinction is the foundational mental model. Confusing voice with tone leads to inconsistent brand identity — making the brand sound like different companies depending on the channel." ;
    oc:severityLevel "CRITICAL" .

