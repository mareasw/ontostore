oc:skill_knowledge_work_plugins_brand_voice_enforcement_voice_constant_tone_flexes a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "voice-constant-tone-flexes" ;
    skos:broader "Brand voice enforcement framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/brand-voice-enforcement" ;
    oc:contentHash "35c95637a30dc3d35dd2dce428972f13840be75860ccd021419cbc7ceb3c6f73" ;
    oc:differentia "that separates immutable voice identity from adaptive tone dimensions, enabling context-sensitive content enforcement" ;
    oc:extends oc:skill_knowledge_work_plugins_brand_voice_enforcement ;
    oc:hasCategory "brand-voice-enforcement" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "The core mental model for brand voice enforcement: voice is constant, tone flexes by context." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 8 ;
                            oc:tableCaption "Combine the three dimensions for each content type" ;
                            oc:tableMarkdown """| Context | Formality | Energy | Technical Depth | Key Principle |
|---------|-----------|--------|-----------------|---------------|
| Cold outreach | Medium | High | Low | Hook fast, earn attention |
| Discovery calls | Medium | Medium-High | Medium | Ask more than tell |
| Demo / presentation | Medium-High | High | High | Show, don't just describe |
| Enterprise proposal | High | Medium | High | ROI and precision |
| Follow-up email | Medium | Medium | Low-Medium | Add new value each touch |
| Social media | Low-Medium | High | Low | Brevity and personality |
| Customer success | Medium | Warm | Medium | Empathy and competence |
| Internal comms | Low | Medium | Varies | Authentic, less polished |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Combine the three dimensions for each content type:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Tone-by-Context Matrix" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Tone adjusts along three independent dimensions:" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "How much enthusiasm, urgency, or dynamism the content conveys." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "How much enthusiasm, urgency, or dynamism the content conveys." ;
                                    oc:tableMarkdown """| Level | Signals | When |
|-------|---------|------|
| High | Active verbs, short sentences, exclamation-worthy excitement | Product launches, cold outreach hooks, social media |
| Medium | Steady pace, balanced between informative and engaging | Discovery content, follow-ups, case studies |
| Warm | Empathetic, supportive, understanding | Customer success, objection handling, bad news |
| Low | Measured, thoughtful, deliberate | Legal language, policy docs, sensitive topics |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "2. Energy" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "How formal or casual the language is." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "How formal or casual the language is." ;
                                    oc:tableMarkdown """| Level | Signals | When |
|-------|---------|------|
| High | Complete sentences, industry terminology, structured format | Proposals, RFPs, enterprise comms |
| Medium | Clear and professional but conversational | Most emails, presentations, blog posts |
| Low | Casual language, contractions, personality shows through | Social media, internal comms, Slack |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "1. Formality" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "How much domain expertise or technical detail is included." ;
                                    oc:tableMarkdown """| Level | Signals | When |
|-------|---------|------|
| High | Technical terminology, architecture details, specs | Technical audience, implementation proposals, API docs |
| Medium | Industry terms explained when needed, features described clearly | Mixed audience, product demos, mid-funnel content |
| Low | Outcome-focused, benefits over features, no jargon | Executive audience, cold outreach, social media |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "How much domain expertise or technical detail is included." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "3. Technical Depth" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Tone Flexes: The Three Dimensions" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Tone** is HOW the brand speaks in a given moment — formality, energy, technical depth. It adapts to context the way a person adjusts their tone when speaking to a friend vs. a CEO vs. a large audience." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Voice** is WHO the brand is — personality, values, identity. It never changes regardless of channel, audience, or content type. Think of it as the brand's character." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "The Distinction" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The \"We Are / We Are Not\" table is the anchor of brand voice. It defines the brand's personality in paired attributes — what the brand IS and the boundary it should never cross." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "The table below is an illustrative example. During enforcement, use the \"We Are / We Are Not\" table from the user's own brand guidelines." ;
                                    oc:tableMarkdown """| We Are | We Are Not |
|--------|------------|
| **Confident** — we know our product and stand behind it | **Arrogant** — we never talk down to prospects or dismiss alternatives |
| **Approachable** — we make complex topics feel manageable | **Casual or sloppy** — approachable doesn't mean unprofessional |
| **Direct** — we get to the point quickly and clearly | **Blunt or aggressive** — directness includes empathy |
| **Data-driven** — we support claims with evidence | **Dry or academic** — data tells stories, not lectures |
| **Innovative** — we push boundaries and challenge status quo | **Hype-driven** — innovation is real, not buzzwords |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "The table below is an illustrative example. During enforcement, use the \"We Are / We Are Not\" table from the user's own brand guidelines." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Structure" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Not every attribute needs to appear in every piece of content. Prioritize the 2-3 most relevant attributes for the content type and audience." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "For every piece of content:" ],
                                _:ref_ef23943d32da6d76 ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "How to Use During Enforcement" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Voice Constants: \"We Are / We Are Not\"" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Voice constants active:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 5 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Formality: Medium (professional but not stiff)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Energy: High (earn attention quickly)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Technical Depth: Low (outcomes, not features)" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 10 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Formality: High (structured, complete sentences)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Energy: Medium (measured, not breathless)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Technical Depth: High (detailed implementation, specs)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "**Example: Enterprise proposal**" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 8 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Data-driven** — every claim has supporting evidence" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Confident** — strong positioning without hedging" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Innovative** — show forward-thinking approach" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent "Voice constants active:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Approachable** — don't sound like a robot" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Confident** — lead with a strong value claim" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Direct** — get to the point in sentence one" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Example: Cold outreach email**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 9 ;
                            oc:textContent "Tone settings:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "Tone settings:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Applying Voice + Tone Together" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_2d7439f227fff3bc ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Common Enforcement Mistakes" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Voice Constant, Tone Flexes" ] ;
    oc:hasWorkflow _:ref_2d7439f227fff3bc,
        _:ref_ef23943d32da6d76 ;
    oc:impartsKnowledge oc:kn_b045801a,
        oc:kn_be342b67,
        oc:kn_bf310160,
        oc:kn_c86476a7,
        oc:kn_ce61fd59,
        oc:kn_d1b94acb,
        oc:kn_e5c3806c,
        oc:kn_f888240d ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "adjust tone for different content types and audiences",
        "audit content against voice constants and tone settings",
        "enforce brand voice consistently across contexts",
        "generate content that reflects brand personality while adapting to context" .

oc:kn_b045801a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or enforcing content against brand guidelines" ;
    oc:directiveContent "Avoid rigid enforcement over natural flow. Guidelines are principles, not a checklist. Content should feel natural, not mechanically assembled. Ignore the audience at your peril — tone must flex for CTO vs. VP of Sales." ;
    oc:hasRationale "Over-mechanical enforcement destroys authenticity and readability." .

oc:kn_be342b67 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating or reviewing content for a specific context" ;
    oc:directiveContent "1. Identify content type and audience. 2. Look up Tone-by-Context Matrix for dimension settings. 3. Select 2-3 most relevant voice attributes. 4. Apply voice constants + tone settings together — voice provides personality, tone provides calibration." ;
    oc:stepOrder 2 .

oc:kn_bf310160 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When enforcing brand voice on any piece of content" ;
    oc:directiveContent "1. Check each 'We Are' attribute — does the content reflect this? 2. Check each 'We Are Not' boundary — does the content avoid crossing it? 3. If a boundary is crossed, revise the specific passage. 4. If an attribute is missing, find a natural place to express it." ;
    oc:stepOrder 1 .

oc:kn_c86476a7 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When determining tone settings for a specific content type or audience" ;
    oc:directiveContent "Combine three independent tone dimensions (Formality, Energy, Technical Depth) to configure tone for each content type. Use the Tone-by-Context Matrix as reference for common combinations." ;
    oc:hasRationale "Three dimensions provide enough expressiveness without overwhelming the enforcement process." .

oc:kn_ce61fd59 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When enforcing brand voice on any content" ;
    oc:directiveContent "Use the 'We Are / We Are Not' table from the user's own brand guidelines during enforcement, not generic examples. Every piece of content must reflect 'We Are' attributes and avoid crossing 'We Are Not' boundaries." ;
    oc:hasRationale "Generic attributes don't capture the unique personality boundaries of a specific brand." ;
    oc:severityLevel "HIGH" .

oc:kn_d1b94acb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Whenever creating, reviewing, or enforcing brand content" ;
    oc:directiveContent "Voice is constant (WHO the brand is — personality, values, identity) and never changes. Tone is adaptive (HOW the brand speaks in a given moment — formality, energy, technical depth) and flexes by context." ;
    oc:hasRationale "Confusing voice with tone leads to inconsistent brand personality or inappropriately rigid messaging across channels." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e5c3806c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When enforcing voice on content" ;
    oc:directiveContent "Not every voice attribute needs to appear in every piece of content. Prioritize the 2-3 most relevant attributes for the content type and audience." ;
    oc:hasRationale "Applying all attributes at maximum intensity creates mechanical, unnatural content." ;
    oc:severityLevel "HIGH" .

oc:kn_f888240d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adapting content for different channels or audiences" ;
    oc:directiveContent "Do not confuse voice with tone. If a user asks for 'casual' content, adjust TONE (lower formality, higher energy) — do not change VOICE (brand personality stays the same)." ;
    oc:hasRationale "Mixing voice and tone adjustments leads to brand identity drift." ;
    oc:severityLevel "HIGH" .

_:ref_06d7f436cf409021 a oc:WorkflowStep ;
    dcterms:description "**Applying all voice attributes at maximum intensity** — Not every attribute needs to shine in every sentence. Let 2-3 lead for the content type." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_13b9664ba0343cd2 a oc:WorkflowStep ;
    dcterms:description "If an attribute is missing, find a natural place to express it" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_14442a26eda77e9b a oc:WorkflowStep ;
    dcterms:description "**Confusing voice with tone** — If the user asks for \"casual\" content, adjust TONE (lower formality, higher energy). Don't change VOICE (the brand's personality stays the same)." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_20aec897dd5bd307 a oc:WorkflowStep ;
    dcterms:description "**Rigid enforcement over natural flow** — Guidelines are principles, not a checklist. Content should feel natural, not mechanically assembled." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_2dfc082491a782ee a oc:WorkflowStep ;
    dcterms:description "Check each \"We Are Not\" boundary — does the content avoid crossing it?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_480cf93552ac6310 a oc:WorkflowStep ;
    dcterms:description "If a boundary is crossed, revise the specific passage" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_4ab2dd52192b24ad a oc:WorkflowStep ;
    dcterms:description "Check each \"We Are\" attribute — does the content reflect this?" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_a481d92a60555fd4 a oc:WorkflowStep ;
    dcterms:description "**Ignoring the audience** — The same voice can sound very different to a CTO vs. a VP of Sales. Tone flexes handle this." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

