_:ref_8b94d2e2fd0d57a7 a oc:WorkflowStep ;
    dcterms:description "Identify at-risk deals based on stale close dates, lack of activity, or stage-close date mismatch" ;
    oc:expectedOutcome "Risk flags table with recommendations" ;
    oc:stepDependsOn _:ref_0e2994c31e1fbfde ;
    oc:stepId "flag-risks" .

_:ref_e943f0d99a467107 a oc:WorkflowStep ;
    dcterms:description "Calculate gap to quota and generate options to close it (accelerate deals, revive stalled, new pipeline needed)" ;
    oc:expectedOutcome "Gap amount and prioritized action options" ;
    oc:stepDependsOn _:ref_2c1b1bbaa81fb6f2,
        _:ref_500456f4f8ce1cde ;
    oc:stepId "gap-analysis" .

_:ref_0e2994c31e1fbfde a oc:WorkflowStep ;
