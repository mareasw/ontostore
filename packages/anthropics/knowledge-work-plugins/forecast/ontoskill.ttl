oc:kn_12058789 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating forecast output" ;
    oc:directiveContent "Always present three scenarios (best/likely/worst) with explicit assumptions for each. The likely case should use stage-weighted probabilities; worst case should assume only commit deals close." ;
    oc:hasRationale "Three-scenario framing gives leadership realistic range expectations and surfaces upside/downside risk" .

oc:kn_51113f09 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When receiving pipeline data from user" ;
    oc:directiveContent "Minimum required data fields: deal/opportunity name, amount, stage, close date. Without these four fields, a meaningful forecast cannot be generated." ;
    oc:hasRationale "Stage and amount are essential for weighting; close date determines period eligibility" ;
    oc:severityLevel "CRITICAL" .

oc:kn_5df3e56f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before forecast generation" ;
    oc:directiveContent "Before generating forecast, verify: (1) pipeline data contains required fields (name, amount, stage, close date), (2) quota and timeline are specified, (3) already-closed amount is known. Ask for missing items." ;
    oc:hasRationale "Incomplete data leads to inaccurate forecasts that mislead decision-making" ;
    oc:severityLevel "HIGH" .

oc:kn_5fdab0bf a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When classifying deals as commit vs upside" ;
    oc:directiveContent "Do not commit deals you wouldn't bet on. Stale close dates and lack of recent activity are accuracy killers — push out deals that won't close in time rather than inflating the forecast." ;
    oc:hasRationale "Over-committing erodes forecast credibility and leads to surprise misses" ;
    oc:severityLevel "HIGH" .

oc:kn_706be8ce a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When scoring deal risk" ;
    oc:directiveContent "Activity recency is a stronger risk signal than stage alone. Deals with no activity in 14+ days should be flagged and potentially downgraded regardless of stage." ;
    oc:hasRationale "Silent deals statistically close at much lower rates than stage probability suggests" ;
    oc:severityLevel "MEDIUM" .

oc:kn_795a1ef4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating pipeline coverage ratio" ;
    oc:directiveContent "Use 3x pipeline coverage as a healthy benchmark; below 2x is risky. Weight deals by stage probability to get a realistic forecast." ;
    oc:hasRationale "Coverage ratio is the primary predictor of whether a rep will make their number" ;
    oc:severityLevel "HIGH" .

_:ref_57478e1fb9ec2a2d a oc:WorkflowStep ;
    dcterms:description "**Be honest about commit** — Only commit deals you'd bet on. Upside is for everything else." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_72f2903898cf4864 a oc:WorkflowStep ;
    dcterms:description "**Coverage matters** — 3x pipeline coverage is healthy. Below 2x is risky." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_a6eb4e18cf2b56d9 a oc:WorkflowStep ;
    dcterms:description "**Update close dates** — Stale close dates kill forecast accuracy. Push out deals that won't close in time." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_ac285884f104c5bf a oc:WorkflowStep ;
    dcterms:description "**Activity = signal** — Deals with no recent activity are at higher risk than stage suggests." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_2c1b1bbaa81fb6f2 a oc:WorkflowStep ;
    dcterms:description "Classify deals into commit (high confidence) vs upside (lower confidence) categories with rationale" ;
    oc:expectedOutcome "Commit and Upside deal tables with justification" ;
    oc:stepDependsOn _:ref_0e2994c31e1fbfde ;
    oc:stepId "classify-commit-upside" .

_:ref_2d183f2bd0f8b576 a oc:WorkflowStep ;
    dcterms:description "Collect pipeline data from user (CSV upload, pasted deals, or territory description)" ;
    oc:expectedOutcome "Pipeline data with deal names, amounts, stages, and close dates" ;
    oc:stepId "collect-pipeline" .

_:ref_500456f4f8ce1cde a oc:WorkflowStep ;
    dcterms:description "Build best/likely/worst case scenarios with explicit assumptions" ;
    oc:expectedOutcome "Three-scenario comparison table" ;
    oc:stepDependsOn _:ref_0e2994c31e1fbfde ;
    oc:stepId "generate-scenarios" .

_:ref_714ad4a489b3c546 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_57478e1fb9ec2a2d,
