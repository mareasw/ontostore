oc:kn_33259b72 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the question bank" ;
    oc:directiveContent "For each competency, provide 2-3 behavioral questions ('Tell me about a time...'), 1-2 situational questions ('How would you handle...'), and follow-up probes." ;
    oc:hasRationale "Behavioral questions reveal past performance; situational questions reveal problem-solving approach; probes dig deeper into evidence." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8437793a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating candidates" ;
    oc:directiveContent "Never rely on gut feelings or unstructured impressions for hiring decisions." ;
    oc:hasRationale "Unstructured evaluations are prone to cognitive biases and have low predictive validity for job performance." ;
    oc:severityLevel "HIGH" .

oc:kn_8ddd2879 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating the scoring rubric" ;
    oc:directiveContent "Rate each competency on a consistent scale (1-4) with clear descriptions of what each level looks like." ;
    oc:hasRationale "Anchored rating scales reduce subjectivity and make scores comparable across interviewers and candidates." ;
    oc:severityLevel "HIGH" .

oc:kn_927d4c03 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any interview plan" ;
    oc:directiveContent "Use the same structured questions for all candidates in a given role to ensure fair, consistent evaluation." ;
    oc:hasRationale "Structured interviews significantly reduce bias and improve predictive validity compared to unstructured interviews." ;
    oc:severityLevel "HIGH" .

oc:kn_e74f4a55 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning panel members" ;
    oc:directiveContent "Include a diverse interview panel with multiple perspectives to reduce individual bias." ;
    oc:hasRationale "Diverse panels catch different signals and counteract individual interviewer blind spots." .

oc:kn_f5f3140d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the question bank" ;
    oc:directiveContent "Map every interview question to a specific competency (4-6 key competencies per role)." ;
    oc:hasRationale "Competency-based mapping ensures coverage of all relevant skills and prevents over-indexing on any single trait." .

