@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_interview_prep a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "interview-prep" ;
    skos:broader "Interview planning framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/interview-prep" ;
    oc:contentHash "bcb566ddab03cfac5a24f9b63b75c75b8536e9f55b5654c91e565ab453edbe05" ;
    oc:differentia "that generates structured competency-based question banks, scoring rubrics, and debrief templates for consistent candidate evaluation" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "role or position title" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Create structured interview plans with competency-based questions and scorecards. Trigger with \"interview plan for\", \"interview questions for\", \"how should we interview\", \"scorecard for\", or when the user is preparing to interview candidates." ;
    oc:hasName "interview-prep" ;
    oc:impartsKnowledge oc:kn_06ed0e4d,
        oc:kn_6bc1f1ab,
        oc:kn_9d21bf81,
        oc:kn_d485a85f,
        oc:kn_e3a13ea8 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create interview plan",
        "design structured interview process",
        "generate interview questions",
        "prepare scorecard for interviewing" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_06ed0e4d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any interview plan" ;
    oc:directiveContent "All candidates for the same role must receive the same set of structured questions to ensure fair and consistent evaluation." ;
    oc:hasRationale "Structured interviews significantly reduce bias and improve predictive validity compared to unstructured conversations." ;
    oc:severityLevel "HIGH" .

oc:kn_6bc1f1ab a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning panel members to interviews" ;
    oc:directiveContent "Use a diverse interview panel with multiple perspectives to reduce individual bias in candidate assessment." ;
    oc:hasRationale "Multiple evaluators counteract individual biases and provide a more balanced view of the candidate." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9d21bf81 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building the question bank" ;
    oc:directiveContent "Define exactly 4-6 key competencies per role, with 2-3 behavioral questions and 1-2 situational questions per competency, plus follow-up probes." ;
    oc:hasRationale "This range provides comprehensive coverage without overwhelming interviewers, and mixing behavioral and situational questions captures both past performance and future-oriented thinking." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d485a85f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoring candidate responses" ;
    oc:directiveContent "Rate competencies using a defined rubric scale (1-4) with clear behavioral descriptions for each level, never relying on gut feelings." ;
    oc:hasRationale "Rubric-based scoring creates measurable, defensible hiring decisions and enables meaningful calibration across interviewers." ;
    oc:severityLevel "HIGH" .

oc:kn_e3a13ea8 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When validating the output of this skill" ;
    oc:directiveContent "A complete interview kit must include: panel assignment, question bank organized by competency, scoring rubric, and debrief template." ;
    oc:hasRationale "All four components are necessary for a structured, fair, and actionable interview process." ;
    oc:severityLevel "MEDIUM" .

