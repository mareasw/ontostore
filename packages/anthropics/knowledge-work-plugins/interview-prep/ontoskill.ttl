                    oc:contentOrder 1 ;
                    oc:textContent "Create structured interview plans to evaluate candidates consistently and fairly." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
