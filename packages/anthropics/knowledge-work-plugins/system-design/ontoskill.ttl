@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_system_design a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "system-design" ;
    skos:broader "Architectural design framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/system-design" ;
    oc:contentHash "a250b1400058a1eb3110e42b5f5f5a53fa93921a3100f50a160cc0f7a9a801a0" ;
    oc:differentia "guides structured system design through requirements gathering, high-level design, deep dive, scalability analysis, and trade-off evaluation to produce clear design documents" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "system description or architectural question" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Design systems, services, and architectures. Trigger with \"design a system for\", \"how should we architect\", \"system design for\", \"what's the right architecture for\", or when the user needs help with API design, data modeling, or service boundaries." ;
    oc:hasName "system-design" ;
    oc:hasRequirement oc:req_37893e40,
        oc:req_8b547b63,
        oc:req_b23a7048 ;
    oc:impartsKnowledge oc:kn_148d40e8,
        oc:kn_7cda4f2d,
        oc:kn_8a55d1aa,
        oc:kn_95a5d729,
        oc:kn_9c35ef11 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "analyze system trade-offs",
        "define service boundaries",
        "design APIs and data models",
        "design a system architecture",
        "evaluate architectural decisions" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_148d40e8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When producing final design output" ;
    oc:directiveContent "Design documents must always identify what would need to be revisited as the system grows." ;
    oc:hasRationale "Systems evolve; documenting growth inflection points upfront prevents costly re-architecture later." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7cda4f2d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When approaching any system design problem" ;
    oc:directiveContent "Structure system design in five sequential phases: requirements gathering, high-level design, deep dive, scale/reliability analysis, and trade-off analysis." ;
    oc:hasRationale "This phased approach ensures nothing critical is missed — from functional needs to operational concerns — before committing to implementation details." ;
    oc:severityLevel "HIGH" .

oc:kn_8a55d1aa a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "At the start of every system design engagement" ;
    oc:directiveContent "Gather non-functional requirements (scale, latency, availability, cost) alongside functional requirements and real-world constraints (team size, timeline, tech stack) before designing." ;
    oc:hasRationale "Non-functional requirements and constraints fundamentally shape architecture; designing without them leads to systems that work in theory but fail in production." ;
    oc:severityLevel "CRITICAL" .

oc:kn_95a5d729 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making any system design decision" ;
    oc:directiveContent "Every architectural decision must include explicit trade-off analysis across dimensions of complexity, cost, team familiarity, time to market, and maintainability." ;
    oc:hasRationale "Hidden trade-offs lead to technical debt and misaligned expectations; making them explicit enables informed stakeholder decisions." ;
    oc:severityLevel "HIGH" .

oc:kn_9c35ef11 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When producing any design deliverable" ;
    oc:directiveContent "Output should include structured design documents with diagrams (ASCII or described), explicit assumptions, and trade-off analysis." ;
    oc:hasRationale "Structured output with visual diagrams and documented assumptions ensures the design is reviewable, communicable, and actionable by engineering teams." ;
    oc:severityLevel "MEDIUM" .

oc:req_37893e40 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Distributed systems concepts (scaling, caching, failover)" .

oc:req_8b547b63 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "API design patterns (REST, GraphQL, gRPC)" .

oc:req_b23a7048 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Data modeling principles" .

