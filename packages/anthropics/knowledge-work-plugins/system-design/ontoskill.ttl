                _:ref_55f18a6de7667a97,
                _:ref_c5fa100f6e25757d,
                [ a oc:WorkflowStep ;
                    dcterms:description "Make all trade-offs explicit across complexity, cost, team familiarity, time to market, and maintainability. Identify decisions to revisit as system grows." ;
