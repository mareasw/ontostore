                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Create Day 1 calendar events and Week 1 meeting invites automatically" ] ],
                        [ a oc:Paragraph ;
