_:ref_cfc0d7cf63e19249 a oc:WorkflowStep ;
    dcterms:description "**Customize for the role** — An engineer's onboarding looks different from a designer's." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_014342f8a8b41b65 a oc:WorkflowStep ;
    dcterms:description "Check for available connectors (HRIS, knowledge base, calendar) to enrich the plan" ;
    oc:expectedOutcome "Connector availability determined; auto-populate where possible" ;
    oc:stepDependsOn _:ref_0bbd942179cb4e11 ;
    oc:stepId "check-connectors" .

_:ref_cfe0a6659a7afc7f a oc:WorkflowStep ;
    dcterms:description "Generate full onboarding plan: pre-start checklist, Day 1 schedule, Week 1 tasks, 30/60/90-day goals, key contacts, tools access" ;
    oc:expectedOutcome "Complete structured onboarding plan in markdown" ;
    oc:stepDependsOn _:ref_014342f8a8b41b65,
        _:ref_0bbd942179cb4e11 ;
    oc:stepId "generate-plan" .

_:ref_deb57adaad6a5997 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_1e6f570e7bf2f49e,
        _:ref_9fa69a8c2658692f,
