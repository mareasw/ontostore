@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_onboarding a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "onboarding" ;
    skos:broader "Plan generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/onboarding" ;
    oc:contentHash "31e99f6fec9d99aacb4eeea10a63b53e71b4db873fa3c0a7c8b7872a111bada0" ;
    oc:differentia "that produces a structured onboarding checklist and first-week schedule for new hires with pre-start tasks, Day 1 agenda, Week 1 milestones, and 30/60/90-day goals" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "HRIS",
        "calendar",
        "knowledge base" ;
    oc:hasArgumentHint "<new hire name and role>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Generate an onboarding checklist and first-week plan for a new hire. Use when someone has a start date coming up, building the pre-start task list (accounts, equipment, buddy), scheduling Day 1 and Week 1, or setting 30/60/90-day goals for a new team member." ;
    oc:hasName "onboarding" ;
    oc:impartsKnowledge oc:kn_08c315b2,
        oc:kn_51bc5399,
        oc:kn_86a92e63,
        oc:kn_8f93edf1,
        oc:kn_91222de7 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build first-week schedule",
        "create new hire checklist",
        "generate onboarding plan",
        "set 30/60/90-day goals for new team member" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_08c315b2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any onboarding plan" ;
    oc:directiveContent "Customize the onboarding plan for the specific role — an engineer's onboarding looks different from a designer's." ;
    oc:hasRationale "Role-specific onboarding ensures the new hire gets relevant tools, documentation, and goals from day one rather than a generic experience." ;
    oc:severityLevel "HIGH" .

oc:kn_51bc5399 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before generating the onboarding plan" ;
    oc:directiveContent "Requires five key inputs to generate a complete plan: new hire name, role, team, start date, and manager." ;
    oc:hasRationale "Without all five inputs, the generated plan will have placeholder gaps that reduce its usefulness and require manual follow-up." ;
    oc:severityLevel "MEDIUM" .

oc:kn_86a92e63 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scheduling Day 1 activities" ;
    oc:directiveContent "Don't overload Day 1 — focus on setup and relationships. Deep work starts Week 2." ;
    oc:hasRationale "New hires are overwhelmed with information on their first day; keeping it light on deep work prevents burnout and improves retention of orientation material." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8f93edf1 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running the skill" ;
    oc:directiveContent "Running this skill multiple times for the same hire generates a fresh plan each time without side effects — it does not modify external systems unless connectors are active." ;
    oc:hasRationale "The skill is primarily a document generator; re-running simply produces a new plan without duplicating calendar events or HRIS entries unless explicit connector actions are taken." ;
    oc:severityLevel "LOW" .

oc:kn_91222de7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the pre-start checklist" ;
    oc:directiveContent "Always assign an onboarding buddy who is not the new hire's manager." ;
    oc:hasRationale "Having a go-to person who isn't the manager provides a safe channel for questions about culture and navigation, dramatically improving new hire experience." ;
    oc:severityLevel "HIGH" .

