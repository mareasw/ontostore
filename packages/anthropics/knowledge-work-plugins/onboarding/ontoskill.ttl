oc:kn_08c315b2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any onboarding plan" ;
    oc:directiveContent "Customize the onboarding plan for the specific role — an engineer's onboarding looks different from a designer's." ;
    oc:hasRationale "Role-specific onboarding ensures new hires get relevant tools, documentation, and goals from day one." .

oc:kn_4422a8a2 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building the onboarding plan" ;
    oc:directiveContent "Always assign an onboarding buddy who is not the manager — a peer go-to person for questions, culture, and navigation." ;
    oc:hasRationale "A buddy provides psychological safety and informal knowledge transfer that managers can't provide." .

oc:kn_86a92e63 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scheduling Day 1 activities" ;
    oc:directiveContent "Don't overload Day 1 — focus on setup and relationships. Deep work starts Week 2." ;
    oc:hasRationale "Information overload on the first day reduces retention and increases new hire anxiety." ;
    oc:severityLevel "MEDIUM" .

oc:kn_970cda91 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before generating the onboarding plan" ;
    oc:directiveContent "Requires five inputs: new hire name, role, team, start date, and manager name to generate a complete plan." ;
    oc:hasRationale "Missing any of these inputs produces an incomplete or generic plan that lacks personalization." .

oc:kn_d36e9ba7 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When connectors are detected as available" ;
    oc:directiveContent "If HRIS, knowledge base, or calendar connectors are available, use them to auto-populate details: pull hire data, link onboarding docs, and create calendar events." ;
    oc:hasRationale "Connector integration reduces manual entry and ensures data consistency across systems." .

_:ref_1e6f570e7bf2f49e a oc:WorkflowStep ;
    dcterms:description "**Assign a buddy** — Having a go-to person who isn't their manager makes a huge difference." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_9fa69a8c2658692f a oc:WorkflowStep ;
    dcterms:description "**Don't overload Day 1** — Focus on setup and relationships. Deep work starts Week 2." ;
    oc:blockType "workflow_step" ;
