@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_data_visualization a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "data-visualization" ;
    skos:broader "Data visualization methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/data-visualization" ;
    oc:contentHash "81828469a6ae8c962838878855c43afdb43f5fa70a2b2e6b39bdbb98bd483fa0" ;
    oc:differentia "provides chart selection guidance, Python code patterns (matplotlib, seaborn, plotly), and design/accessibility principles for creating effective publication-quality figures" ;
    oc:extends oc:skill_create_viz ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "python" ;
    oc:hasArgumentHint "dataset and visualization goal (e.g., \"show trend over time\", \"compare categories\", \"show correlation\")" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Create effective data visualizations with Python (matplotlib, seaborn, plotly). Use when building charts, choosing the right chart type for a dataset, creating publication-quality figures, or applying design principles like accessibility and color theory." ;
    oc:hasName "data-visualization" ;
    oc:impartsKnowledge oc:kn_0c7c406b,
        oc:kn_49926027,
        oc:kn_608bacc1,
        oc:kn_ce504bef,
        oc:kn_d01098d3,
        oc:kn_e0c55416 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "apply design principles like color theory and accessibility to visualizations",
        "build interactive charts with plotly",
        "choose the right chart type for a dataset",
        "create charts and data visualizations",
        "generate publication-quality figures with Python" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0c7c406b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any visualization" ;
    oc:directiveContent "Never use pie charts (>6 categories), 3D charts, or dual-axis charts without extreme caution. Avoid donut charts except for single KPI display." ;
    oc:hasRationale "Humans are poor at comparing angles (pie), 3D distorts perception and adds no information, dual-axis implies false correlation" ;
    oc:severityLevel "HIGH" .

oc:kn_49926027 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When annotating and styling any chart" ;
    oc:directiveContent "Titles should state the insight ('Revenue grew 23% YoY' not 'Revenue by Month'), subtitles add context (date range, filters, source), and reduce chart junk by removing gridlines/borders/backgrounds that don't carry information." ;
    oc:hasRationale "Insight-driven titles immediately communicate the takeaway; removing chart junk focuses attention on data rather than decoration" ;
    oc:severityLevel "MEDIUM" .

oc:kn_608bacc1 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing any visualization for sharing" ;
    oc:directiveContent "Before sharing a visualization, verify: chart works without color (patterns/labels differentiate series), text is readable, title describes the insight not just data, axes are labeled with units, legend is clear, and data source/date range are noted." ;
    oc:hasRationale "Accessibility and completeness checks prevent miscommunication and ensure the visualization is usable by all audiences" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ce504bef a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting axis ranges and scales" ;
    oc:directiveContent "Bar charts must always start at zero. Line charts can have non-zero baselines when the range of variation is meaningful. Use consistent scales across comparison panels and always label axes with units." ;
    oc:hasRationale "Truncating bar chart baselines exaggerates differences and misleads; inconsistent scales across panels create false comparisons" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d01098d3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a chart type for any dataset" ;
    oc:directiveContent "Match chart type to data relationship: line for trends, bar for comparisons, scatter for correlation, histogram for distribution, heatmap for correlation matrices, small multiples for multi-KPI views." ;
    oc:hasRationale "Using the wrong chart type obscures the story and misleads the audience; matching chart to data relationship maximizes clarity" ;
    oc:severityLevel "HIGH" .

oc:kn_e0c55416 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing colors for any chart" ;
    oc:directiveContent "Use color purposefully to encode data, not decorate. Highlight the key insight with a bright accent color and grey everything else. Use blue/orange as primary pair instead of red/green to accommodate colorblindness." ;
    oc:hasRationale "8% of men are red-green colorblind; purposeful color directs attention to the data story rather than creating visual noise" ;
    oc:severityLevel "MEDIUM" .

