        oc:kn_3d877c02,
        oc:kn_8bce62f4,
        oc:kn_c402fe93,
        oc:kn_e2d9a681,
        oc:kn_f7d5fc29 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "apply accessible design principles to data visualizations",
        "build publication-quality figures with Python",
        "choose the right chart type for data",
        "create charts and visualizations",
        "create interactive charts with Plotly" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_05d35842 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying color to any visualization" ;
    oc:directiveContent "Use color purposefully to encode data, not decorate. Highlight the key insight with a bright accent color and grey everything else. For categorical data, use distinct hues with a maximum of 6-8 categories." ;
    oc:hasRationale "Purposeful color use directs attention to the story in the data rather than creating visual noise." ;
    oc:severityLevel "HIGH" .

oc:kn_1e42aed9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing accessible visualizations" ;
    oc:directiveContent "Never rely on color alone to distinguish data series. Always add pattern fills, different line styles (solid, dashed, dotted), or direct labels. Use blue/orange as primary pair instead of red/green (8% of men are red-green colorblind)." ;
    oc:hasRationale "Colorblind users cannot distinguish red/green pairs; multi-channel encoding ensures accessibility." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3c28ab10 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating bar charts" ;
    oc:directiveContent "Bar charts must always start at zero. A bar from 95 to 100 exaggerates a 5% difference." ;
    oc:hasRationale "Non-zero baselines in bar charts create misleading visual comparisons that exaggerate small differences." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3d877c02 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When validating a completed visualization" ;
    oc:directiveContent "A successful visualization has: a clear insight in the title, appropriately chosen chart type matching the data relationship, accessible color encoding, labeled axes with units, and minimal chart junk." ;
    oc:hasRationale "These indicators confirm the visualization communicates effectively and accessibly." ;
    oc:severityLevel "LOW" .

oc:kn_8bce62f4 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing any visualization" ;
    oc:directiveContent "Before sharing a visualization, verify: chart works without color, text is readable at standard zoom, title describes the insight, axes are labeled with units, legend is clear, and data source/date range are noted." ;
    oc:hasRationale "This checklist catches common accessibility and clarity issues before the visualization reaches its audience." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c402fe93 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing color palettes for data encoding" ;
    oc:directiveContent "Use sequential single-hue gradients for ordered data, diverging two-hue gradients with neutral midpoint for data with a meaningful center, and distinct hues for categorical data." ;
    oc:hasRationale "Matching palette type to data type ensures the color encoding accurately represents the underlying data relationships." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e2d9a681 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting chart type for any visualization" ;
    oc:directiveContent "Never use 3D charts — they distort perception and add no information. Avoid pie charts unless there are fewer than 6 categories. Avoid dual-axis charts as they mislead by implying correlation." ;
    oc:hasRationale "These chart types introduce perceptual distortion, making data harder to interpret accurately and potentially misleading the audience." ;
    oc:severityLevel "HIGH" .

oc:kn_f7d5fc29 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When labeling and styling charts" ;
    oc:directiveContent "Title should state the insight (e.g., 'Revenue grew 23% YoY') rather than just describe the data ('Revenue by Month'). Sort categories by value unless there's a natural order. Remove gridlines, borders, and backgrounds that don't carry information." ;
    oc:hasRationale "Insight-driven titles and minimal decoration make the visualization's message immediately clear." ;
    oc:severityLevel "MEDIUM" .

