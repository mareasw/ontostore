oc:skill_knowledge_work_plugins_design_critique a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "design-critique" ;
    skos:broader "Design evaluation methodology" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/design-critique" ;
    oc:contentHash "38b725d63feea4f9b0517e5d82c5b0d4dedf9d8fef841d0e56a2d8573277ba91" ;
    oc:differentia "applies a structured multi-dimensional critique framework covering first impression, usability, visual hierarchy, consistency, and accessibility" ;
    oc:handlesFailure oc:DesignInputMissing,
        oc:FigmaAccessDenied ;
    oc:hasArgumentHint "<Figma URL, screenshot, or description>" ;
    oc:hasCategory "design" ;
    oc:hasDescription "Get structured design feedback on usability, hierarchy, and consistency. Trigger with \"review this design\", \"critique this mockup\", \"what do you think of this screen?\", or when sharing a Figma link or screenshot for feedback at any stage from exploration to final polish." ;
    oc:hasName "design-critique" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Get structured design feedback across multiple dimensions." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Explain why**: Connect feedback to design principles or user needs" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Acknowledge what works**: Good feedback includes positive observations" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Suggest alternatives**: Don't just identify problems, propose solutions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Match the stage**: Early exploration gets different feedback than final polish" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Be specific**: \"The CTA competes with the navigation\" not \"the layout is confusing\"" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "How to Give Feedback" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Are interactive elements obvious?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Are there unnecessary steps?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Can the user accomplish their goal?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Is the navigation intuitive?" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "2. Usability" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Touch target sizes" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Color contrast ratios" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Alternative text for images" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Text readability" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "5. Accessibility" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Does it follow the design system?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Do similar elements behave similarly?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Are spacing, colors, and typography consistent?" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "4. Consistency" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Is there a clear reading order?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Is typography creating the right hierarchy?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Is whitespace used effectively?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Are the right elements emphasized?" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "3. Visual Hierarchy" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "What's the emotional reaction?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "What draws the eye first? Is that correct?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Is the purpose immediately clear?" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "1. First Impression (2 seconds)" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Critique Framework" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Review the design: @$1" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "If a Figma URL is provided, pull the design from Figma. If a file is referenced, read it. Otherwise, ask the user to describe or share their design." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/design-critique $ARGUMENTS
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 15-17" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Usage" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """## Design Critique: [Design Name]

### Overall Impression
[1-2 sentence first reaction — what works, what's the biggest opportunity]

### Usability
| Finding | Severity | Recommendation |
|---------|----------|----------------|
| [Issue] | 🔴 Critical / 🟡 Moderate / 🟢 Minor | [Fix] |

### Visual Hierarchy
- **What draws the eye first**: [Element] — [Is this correct?]
- **Reading flow**: [How does the eye move through the layout?]
- **Emphasis**: [Are the right things emphasized?]

### Consistency
| Element | Issue | Recommendation |
|---------|-------|----------------|
| [Typography/spacing/color] | [Inconsistency] | [Fix] |

### Accessibility
- **Color contrast**: [Pass/fail for key text]
- **Touch targets**: [Adequate size?]
- **Text readability**: [Font size, line height]

### What Works Well
- [Positive observation 1]
- [Positive observation 2]

### Priority Recommendations
1. **[Most impactful change]** — [Why and how]
2. **[Second priority]** — [Why and how]
3. **[Third priority]** — [Why and how]
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 69-103" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Cross-reference design decisions with recent user feedback and support tickets" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Compare against the existing design system for consistency" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Pull the design directly from Figma and inspect components, tokens, and layers" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "If **~~user feedback** is connected:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "If **~~design tool** is connected:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "If Connectors Available" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_f58137b41aae08c6 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Tips" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Focus** (optional): \"Focus on mobile\" or \"Focus on the onboarding flow\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Context**: What is this? Who is it for? What stage (exploration, refinement, final)?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**The design**: Figma URL, screenshot, or detailed description" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "What I Need From You" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "/design-critique" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: design-critique
description: Get structured design feedback on usability, hierarchy, and consistency. Trigger with "review this design", "critique this mockup", "what do you think of this screen?", or when sharing a Figma link or screenshot for feedback at any stage from exploration to final polish.
argument-hint: "<Figma URL, screenshot, or description>"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow _:ref_f58137b41aae08c6 ;
    oc:impartsKnowledge oc:kn_222500a7,
        oc:kn_2ba821bd,
        oc:kn_5b445ec9,
        oc:kn_761c1f40,
        oc:kn_7ca59d7b ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DesignInputAvailable ;
    oc:resolvesIntent "assess visual hierarchy and usability",
        "critique a mockup or screenshot",
        "evaluate UI/UX quality",
        "get structured design feedback",
        "review a design" ;
    oc:yieldsState oc:DesignCritiqueGenerated .

oc:kn_222500a7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning the critique" ;
    oc:directiveContent "Determine the input type (Figma URL → pull design, file reference → read it, neither → ask user to describe or share). Gather context: what the design is, who it's for, what stage it's at, and any focus areas." ;
    oc:hasRationale "Context determines relevance and depth of feedback" .

oc:kn_2ba821bd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any critique finding" ;
    oc:directiveContent "Never give vague feedback like 'the layout is confusing' — always be specific: identify the element, explain why it's problematic, and propose a concrete fix." ;
    oc:hasRationale "Vague feedback cannot be acted upon and frustrates designers" ;
    oc:severityLevel "MEDIUM" .

oc:kn_5b445ec9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When critiquing any design" ;
    oc:directiveContent "Evaluate designs across 5 dimensions in order: First Impression (2-second test), Usability, Visual Hierarchy, Consistency, Accessibility." ;
    oc:hasRationale "Ensures comprehensive, structured feedback rather than ad-hoc opinions" ;
    oc:severityLevel "HIGH" .

oc:kn_761c1f40 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the final critique output" ;
    oc:directiveContent "Always include what works well alongside problems — good feedback acknowledges strengths, not just weaknesses." ;
    oc:hasRationale "Purely negative feedback is demoralizing and ignores patterns worth preserving" .

oc:kn_7ca59d7b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user specifies their design stage" ;
    oc:directiveContent "Match feedback depth and tone to the design stage — early exploration gets directional feedback, final polish gets pixel-level precision." ;
    oc:hasRationale "Over-critiquing early work kills exploration; under-critiquing final work ships bugs" .

_:ref_096bd915fef2e2d2 a oc:WorkflowStep ;
    dcterms:description "**Ask me to focus** — \"Just look at the navigation\" gives you more depth on one area." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_db8d1c4a0e6bc9ee a oc:WorkflowStep ;
    dcterms:description "**Specify your stage** — Early exploration gets different feedback than final polish." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_ec676b1dc89acfd6 a oc:WorkflowStep ;
    dcterms:description "**Share the context** — \"This is a checkout flow for a B2B SaaS\" helps me give relevant feedback." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_f58137b41aae08c6 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_096bd915fef2e2d2,
        _:ref_db8d1c4a0e6bc9ee,
