@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_design_critique a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "design-critique" ;
    skos:broader "Design evaluation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/design-critique" ;
    oc:contentHash "38b725d63feea4f9b0517e5d82c5b0d4dedf9d8fef841d0e56a2d8573277ba91" ;
    oc:differentia "Provides structured multi-dimensional critique of visual designs across usability, hierarchy, consistency, and accessibility with severity-rated findings and prioritized recommendations" ;
    oc:handlesFailure oc:DesignNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "Read",
        "WebFetch" ;
    oc:hasArgumentHint "<Figma URL, screenshot, or description>" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Get structured design feedback on usability, hierarchy, and consistency. Trigger with \"review this design\", \"critique this mockup\", \"what do you think of this screen?\", or when sharing a Figma link or screenshot for feedback at any stage from exploration to final polish." ;
    oc:hasName "design-critique" ;
    oc:impartsKnowledge oc:kn_12edf753,
        oc:kn_3d32785d,
        oc:kn_7aa93dec,
        oc:kn_b6905412,
        oc:kn_bf10e98b ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DesignInputProvided ;
    oc:resolvesIntent "assess design accessibility",
        "check design consistency",
        "critique mockup",
        "evaluate visual hierarchy",
        "get design feedback",
        "review design" ;
    oc:yieldsState oc:DesignCritiqueGenerated .

oc:kn_12edf753 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When verifying critique output completeness" ;
    oc:directiveContent "A complete critique includes: severity-rated usability findings in a table, documented visual hierarchy reading flow, consistency audit with specific elements, accessibility pass/fail checks, positive observations, and exactly 3 priority-ranked recommendations." ;
    oc:hasRationale "The structured output format ensures feedback is actionable, comparable across critiques, and not missing any critical section." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3d32785d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user specifies or implies the design stage" ;
    oc:directiveContent "Calibrate feedback intensity to the design stage: early exploration gets broad directional feedback, final polish gets pixel-level precision feedback." ;
    oc:hasRationale "Over-critiquing early explorations stifles creativity, while under-critiquing final polish ships quality issues." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7aa93dec a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any design critique" ;
    oc:directiveContent "Before starting critique, ensure you have: the design itself (Figma URL, screenshot, or description), context about what the product is and who it's for, and ideally the design stage." ;
    oc:hasRationale "Without context and stage information, feedback will be generic and may be inappropriate for the design's current maturity level." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b6905412 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any design critique" ;
    oc:directiveContent "Always structure design feedback across five dimensions: First Impression, Usability, Visual Hierarchy, Consistency, and Accessibility — in that order." ;
    oc:hasRationale "A systematic multi-dimensional framework ensures no critical aspect of the design is overlooked and feedback is comprehensive rather than ad-hoc." ;
    oc:severityLevel "HIGH" .

oc:kn_bf10e98b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any critique finding or recommendation" ;
    oc:directiveContent "Never give vague feedback like 'the layout is confusing'. Instead, be specific: identify the exact element, explain why it's problematic, connect it to a design principle, and propose a concrete fix." ;
    oc:hasRationale "Vague feedback is unactionable and frustrates designers. Specific, principled feedback with alternatives drives actual improvement." ;
    oc:severityLevel "HIGH" .

