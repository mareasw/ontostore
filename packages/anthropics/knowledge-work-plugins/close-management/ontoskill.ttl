oc:kn_0f352f96 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "Daily Close Standup (15 min): 1. Review status board and flag behind tasks 2. Identify blockers 3. Reassign or escalate 4. Update timeline if at risk." ;
    oc:stepOrder 7 .

oc:kn_110cab1f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sequencing any close activities" ;
    oc:directiveContent "Close tasks must follow the 5-level dependency map: Level 1 (no dependencies) → Level 2 (needs Level 1) → Level 3 (needs Level 2) → Level 4 (needs Level 3) → Level 5 (needs Level 4). No task can begin until all its prerequisite level is complete." ;
    oc:hasRationale "Violating dependency order causes rework — e.g., running tax provisions before all JEs are posted requires recalculation" ;
    oc:severityLevel "CRITICAL" .

oc:kn_3c5e7134 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "A 3-day accelerated close requires: automated recurring JEs, continuous reconciliation during the month, automated intercompany elimination, pre-close activities completed before month-end, empowered team with minimal handoffs, real-time sub-system integration." .

oc:kn_8693b207 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During close process planning and execution" ;
    oc:directiveContent "Do not start reconciliations from scratch each month, prepare recurring JEs manually, or scramble for supporting documents at close time." ;
    oc:hasRationale "These are the top 3 bottlenecks identified in close processes — they waste time and introduce errors" ;
    oc:severityLevel "HIGH" .

oc:kn_8e3362d5 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "T+3: Complete BS reconciliations, post adjusting JEs, intercompany reconciliation/elimination, preliminary trial balance, preliminary flux analysis, resolve material variances." ;
    oc:stepOrder 4 .

oc:kn_955989a6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When establishing close performance baselines" ;
    oc:directiveContent "Track 5 key metrics over time: close duration (business days), adjusting entries after soft close, late tasks, reconciliation exceptions, and restatements/corrections. Target zero for late tasks and restatements." ;
    oc:hasRationale "Measurable metrics enable continuous improvement and accountability across close cycles" .

oc:kn_97ca1ddd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying bottlenecks or prioritizing tasks" ;
    oc:directiveContent "The critical path is: Cash/AP/AR entries → Subledger reconciliations → Balance sheet recs → Tax provision → Draft financials → Management review → Hard close. Any delay on this path extends the entire close." ;
    oc:hasRationale "The critical path determines minimum close duration; shortening it requires automating or parallelizing its components" ;
    oc:severityLevel "HIGH" .

oc:kn_9ccac6fa a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "Pre-Close (last 2-3 business days): Send calendar, confirm cut-offs, verify sub-systems, preliminary bank rec, review POs for accruals, confirm payroll schedule, collect unusual transaction info." ;
    oc:stepOrder 1 .

oc:kn_9ee61a06 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the close takes longer than 5 business days" ;
    oc:directiveContent "To accelerate close: automate Level 1 entries (depreciation, amortization, standard accruals), pre-reconcile accounts during the month, parallel-process independent reconciliations, set clear deadlines with consequences, and use standardized templates." ;
    oc:hasRationale "A 3-day close requires automated recurring JEs, continuous reconciliation, automated intercompany elimination, and pre-close completion before month-end" .

oc:kn_a61f54ba a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "T+4: Tax provisions, equity roll-forward, soft close (finalize JEs), draft financial statements, detailed flux analysis, management review." ;
    oc:stepOrder 5 .

oc:kn_b6920743 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "T+5: Post final adjustments from review, hard close, lock period, distribute reporting package, update forecasts, conduct retrospective." ;
    oc:stepOrder 6 .

oc:kn_c4ed31a4 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "T+1: Confirm sub-ledger processing, run AP accruals, post payroll, record cash entries, post intercompany, complete bank rec, run depreciation, post prepaid amortization." ;
    oc:stepOrder 2 .

oc:kn_eb9376bb a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "T+2: Revenue recognition, remaining accrual JEs, AR/AP subledger reconciliations, inventory adjustments, FX revaluation, begin BS reconciliations." ;
    oc:stepOrder 3 .

oc:kn_f4bf593b a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """Task Status Tracking: | Task | Owner | Deadline | Status | Blocker | Notes |
Status values: Not Started / In Progress / Complete / Blocked / At Risk""" ;
    oc:templateVariables "Blocker",
        "Deadline",
        "Notes",
        "Owner",
        "Status",
        "Task" .

