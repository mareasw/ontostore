                            oc:sectionTitle "Close Day 1 (T+1: First Business Day After Month-End)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
