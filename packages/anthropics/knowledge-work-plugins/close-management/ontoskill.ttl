oc:skill_anthropics_knowledge_work_plugins_close_management a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "close-management" ;
    skos:broader "Financial process management framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/close-management" ;
    oc:contentHash "5b1a63158352623366bba6e2e88a5b70eddb3f3537b005126ab8d87776bd4652" ;
    oc:differentia "that structures the month-end accounting close with task sequencing, dependency mapping, status tracking, and day-by-day activity scheduling" ;
    oc:handlesFailure oc:InvalidInput,
        oc:MissingDependencyData ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Manage the month-end close process with task sequencing, dependencies, and status tracking. Use when planning the close calendar, tracking close progress, identifying blockers, or sequencing close activities by day." ;
    oc:hasName "close-management" ;
    oc:impartsKnowledge oc:kn_1f5d4bff,
        oc:kn_44cdd0d1,
        oc:kn_ab43e408,
        oc:kn_bdb1cd14,
        oc:kn_cd7e3f4f,
        oc:kn_e86dcd0c ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:SystemAuthenticated ;
    oc:resolvesIntent "accelerate the close process",
        "identify close blockers and dependencies",
        "improve close process efficiency",
        "plan month-end close calendar",
        "sequence close activities by day",
        "track close task progress and status" ;
    oc:yieldsState oc:CloseBlockersIdentified,
        oc:ClosePlanCreated,
        oc:CloseProgressTracked .

oc:kn_1f5d4bff a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying process improvement opportunities in the close" ;
    oc:directiveContent "Avoid starting reconciliations from scratch each month, waiting for counterparty confirmation on intercompany entries, and preparing recurring journal entries manually — these are the top bottlenecks that extend close duration." ;
    oc:hasRationale "These six common bottlenecks (late AP accruals, manual JEs, slow reconciliations, intercompany delays, management review changes, missing documentation) account for most close delays and are solvable with systematic approaches" ;
    oc:severityLevel "HIGH" .

oc:kn_44cdd0d1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning or sequencing any month-end close" ;
    oc:directiveContent "Structure the close as a 5-level dependency map where tasks at each level must complete before dependent tasks at the next level can begin. The critical path runs through Cash/AP/AR entries → Subledger reconciliations → Balance sheet recs → Tax provision → Draft financials → Management review → Hard close." ;
    oc:hasRationale "Explicit dependency management prevents wasted effort on tasks whose inputs aren't ready and identifies the critical path that determines minimum close duration" ;
    oc:severityLevel "HIGH" .

oc:kn_ab43e408 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After each close cycle completes, during retrospective" ;
    oc:directiveContent "Track close metrics over time: close duration (target: reduce), number of adjusting entries after soft close (target: minimize), number of late tasks (target: zero), reconciliation exceptions (target: reduce), and restatements/corrections (target: zero)." ;
    oc:hasRationale "Quantitative metrics enable objective assessment of close process improvement and surface degradation before it becomes critical" ;
    oc:severityLevel "MEDIUM" .

oc:kn_bdb1cd14 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During the active close period (T+1 through T+5)" ;
    oc:directiveContent "Hold a brief 15-minute daily standup during the close period to review the status board, identify blockers, reassign or escalate issues, and update the timeline if any tasks are at risk." ;
    oc:hasRationale "Daily synchronization prevents small blockers from cascading into multi-day delays and maintains accountability across the close team" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cd7e3f4f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the organization targets a faster close cycle" ;
    oc:directiveContent "To accelerate the close from 5 days to 3 days, automate Level 1 recurring entries (depreciation, amortization, standard accruals), implement continuous reconciliation during the month, and complete pre-close activities before month-end." ;
    oc:hasRationale "Front-loading work and automating routine entries compresses the critical path without sacrificing accuracy" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e86dcd0c a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "During the pre-close phase (last 2-3 business days of the month)" ;
    oc:directiveContent "Before the close begins, verify: close calendar sent to contributors, cut-off procedures confirmed with AP/AR/payroll/treasury, all sub-systems processing normally, preliminary bank reconciliation complete, open POs reviewed for accrual needs, and payroll schedule aligned with close timeline." ;
    oc:hasRationale "Pre-close readiness directly determines whether Day 1 tasks can begin on schedule; incomplete pre-close is the most common cause of close delays" ;
    oc:severityLevel "CRITICAL" .

