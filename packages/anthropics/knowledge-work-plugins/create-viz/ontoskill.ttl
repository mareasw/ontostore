oc:kn_0784828e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing chart aesthetics and formatting" ;
    oc:directiveContent "Avoid pie charts unless fewer than 6 categories. Never use color decoratively — use it meaningfully. Never start a bar chart Y-axis at a non-zero value without clear notation. Avoid rotated 90-degree axis labels." ;
    oc:hasRationale "Pie charts become unreadable with many slices; decorative color adds noise; non-zero bar baselines mislead; rotated labels reduce readability." ;
    oc:severityLevel "HIGH" .

oc:kn_129e91c7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When formatting axis labels, annotations, and color choices" ;
    oc:directiveContent "Format numbers for readability: percentages as '45.2%' not '0.452', currency as '$1.2M' not '1200000', large numbers as '2.3K' or '1.5M'. Use colorblind-friendly palettes. Highlight key data points with contrasting color; grey out reference data." ;
    oc:hasRationale "Human-readable number formatting and accessible color choices ensure the chart communicates effectively to all audiences." .

oc:kn_79f5c86f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any chart" ;
    oc:directiveContent "Chart titles should state the insight, not just the metric (e.g., 'Revenue grew 23% YoY' not 'Revenue by Month'). Use clear axis labels, remove top and right spines, and apply tight_layout." ;
    oc:hasRationale "Descriptive titles communicate the key takeaway directly; removing chart junk improves signal-to-noise ratio." ;
    oc:severityLevel "HIGH" .

oc:kn_7bd0cb2d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any matplotlib/seaborn chart — this is the standard boilerplate template" ;
    oc:codeLanguage "python" ;
    oc:directiveContent """import matplotlib.pyplot as plt
import seaborn as sns
import pandas as pd

plt.style.use('seaborn-v0_8-whitegrid')
sns.set_palette("husl")
fig, ax = plt.subplots(figsize=(10, 6))

ax.set_title('Clear, Descriptive Title', fontsize=14, fontweight='bold')
ax.set_xlabel('X-Axis Label', fontsize=11)
ax.set_ylabel('Y-Axis Label', fontsize=11)
ax.spines['top'].set_visible(False)
ax.spines['right'].set_visible(False)

plt.tight_layout()
plt.savefig('chart_name.png', dpi=150, bbox_inches='tight')
plt.show()""" .

oc:kn_b33b2ba6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a visualization library" ;
    oc:directiveContent "Use matplotlib+seaborn for static publication-quality charts (default). Use plotly only when interactivity (hover, zoom, filter) is explicitly requested or beneficial." ;
    oc:hasRationale "matplotlib/seaborn produces consistent, print-ready output; plotly adds interactivity overhead better suited to exploratory or dashboard contexts." .

oc:kn_b374fdda a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing the full visualization workflow" ;
    oc:directiveContent "1. Understand request (data source, chart type, purpose, audience) 2. Get data into pandas DataFrame (query, parse, or reference existing) 3. Select chart type based on data relationship if not specified 4. Generate visualization with professional styling 5. Apply design best practices (color, typography, layout, accuracy) 6. Save as PNG, display, provide code, suggest variations" ;
    oc:hasRationale "This structured workflow ensures no step is missed from data acquisition through final delivery." ;
    oc:stepOrder 1 .

oc:kn_d719e581 a oc:KnowledgeNode,
