@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_create_viz a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "create-viz" ;
    skos:broader "Data visualization skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/create-viz" ;
    oc:contentHash "b9c64db702786313b4b3f478005b955bcd0bb2db3e052b23d41a96b34cee5450" ;
    oc:differentia "generates publication-quality charts from data using Python (matplotlib/seaborn/plotly) with design best practices and intelligent chart type selection" ;
    oc:handlesFailure oc:DataNotFound,
        oc:InvalidInput ;
    oc:hasAllowedTool "Bash",
        "Read",
        "Write",
        "python" ;
    oc:hasArgumentHint "<data source> [chart type]" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Create publication-quality visualizations with Python. Use when turning query results or a DataFrame into a chart, selecting the right chart type for a trend or comparison, generating a plot for a report or presentation, or needing an interactive chart with hover and zoom." ;
    oc:hasName "create-viz" ;
    oc:impartsKnowledge oc:kn_414687da,
        oc:kn_855c5762,
        oc:kn_8ddf80d5,
        oc:kn_a32082a6,
        oc:kn_c439600f,
        oc:kn_d862d8fb ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DataAvailable ;
    oc:resolvesIntent "create chart from data",
        "create interactive chart with hover and zoom",
        "generate plot for report or presentation",
        "select appropriate chart type for data",
        "visualize query results or DataFrame" ;
    oc:yieldsState oc:FileSaved,
        oc:VisualizationCreated .

oc:kn_414687da a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When applying design polish to any chart" ;
    oc:directiveContent "Always use descriptive titles that state the insight (e.g., 'Revenue grew 23% YoY') rather than just the metric name (e.g., 'Revenue by Month'). Use colorblind-friendly palettes and remove chart junk (top/right spines)." ;
    oc:hasRationale "Titles that convey insight make charts self-explanatory; colorblind palettes ensure accessibility; removing chart junk reduces cognitive load." ;
    oc:severityLevel "HIGH" .

oc:kn_855c5762 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a visualization library" ;
    oc:directiveContent "Use matplotlib+seaborn for static publication-quality charts (default), and plotly only when interactivity (hover, zoom, filter) is explicitly requested." ;
    oc:hasRationale "Ensures consistent output format and avoids unnecessary complexity for static use cases like reports and presentations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8ddf80d5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring chart axes" ;
    oc:directiveContent "Bar chart Y-axes must start at zero. No misleading axis breaks without clear notation. Consistent scales when comparing panels." ;
    oc:hasRationale "Truncated axes distort visual proportions and misrepresent the magnitude of differences, violating data integrity." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a32082a6 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any visualization task" ;
    oc:directiveContent "Before generating the chart, determine: the data source (query, pasted data, file, or existing DataFrame), whether chart type is specified or needs recommendation, the purpose (exploration, presentation, report), and the audience (technical, executive, external)." ;
    oc:hasRationale "Understanding context prevents rework and ensures the visualization matches the communication need." ;
    oc:severityLevel "HIGH" .

oc:kn_c439600f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When laying out bar charts and categorical comparisons" ;
    oc:directiveContent "Sort categorical data by value rather than alphabetically unless there is a natural order. Use horizontal bar charts when there are many categories." ;
    oc:hasRationale "Value-sorted bars make ranking immediately visible; horizontal orientation prevents label overlap with many categories." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d862d8fb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting chart type for part-to-whole relationships" ;
    oc:directiveContent "Avoid pie charts unless there are fewer than 6 categories; use stacked bar or area charts instead for part-to-whole composition." ;
    oc:hasRationale "Pie charts become unreadable with many categories due to small slice sizes and difficulty comparing angles." ;
    oc:severityLevel "MEDIUM" .

