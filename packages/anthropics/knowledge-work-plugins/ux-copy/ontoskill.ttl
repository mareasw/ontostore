    dcterms:description "Apply the appropriate copy pattern (CTA, error message, empty state, confirmation dialog, tooltip, loading state, or onboarding) with tone adapted to user's emotional state" ;
    oc:expectedOutcome "Draft UX copy following structured patterns with correct tone" ;
