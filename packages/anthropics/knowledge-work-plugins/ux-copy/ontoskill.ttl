_:ref_60f6411349df4901 a oc:WorkflowStep ;
    dcterms:description "Gather context: screen/flow, user state, tone requirements, character limits, and platform guidelines" ;
    oc:expectedOutcome "Complete understanding of the interface context and constraints" ;
    oc:stepId "gather-context" .

_:ref_7a0289df589c7852 a oc:WorkflowStep ;
