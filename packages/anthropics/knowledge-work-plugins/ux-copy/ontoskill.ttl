""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 15-17" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Usage" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_8c516d34a15f6d7b ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Tips" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Describe consequences: \"This can't be undone\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Label buttons with the action: \"Delete files\" / \"Keep files\" not \"OK\" / \"Cancel\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Make the action clear: \"Delete 3 files?\" not \"Are you sure?\"" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Confirmation Dialogs" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Set expectations, reduce anxiety" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "Loading States" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Structure: What this is + Why it's empty + How to start" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "\"No projects yet. Create your first project to start collaborating with your team.\"" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Empty States" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Start with a verb: \"Start free trial\", \"Save changes\", \"Download report\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Match the outcome to the label" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Be specific: \"Create account\" not \"Submit\"" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "CTAs" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Concise, helpful, never obvious" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Tooltips" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Structure: What happened + Why + How to fix" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
