@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_ux_copy a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ux-copy" ;
    skos:broader "Writing methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/ux-copy" ;
    oc:contentHash "00ecac9250194c3081bdbdb8b47a6da265263ba43641f041de784bd5be073c7d" ;
    oc:differentia "that crafts and reviews user interface text including microcopy, error messages, empty states, CTAs, and onboarding copy using structured patterns and context-aware tone adaptation" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<context or copy to review>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Write or review UX copy — microcopy, error messages, empty states, CTAs. Trigger with \"write copy for\", \"what should this button say?\", \"review this error message\", or when naming a CTA, wording a confirmation dialog, filling an empty state, or writing onboarding text." ;
    oc:hasName "ux-copy" ;
    oc:impartsKnowledge oc:kn_0fbf9a54,
        oc:kn_35cd6e7a,
        oc:kn_46cb5011,
        oc:kn_91d8a1cf,
        oc:kn_929cfa32,
        oc:kn_a128dc30 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "review and improve existing UX copy",
        "write CTA button labels",
        "write UX copy for interface elements",
        "write confirmation dialogs",
        "write empty state copy",
        "write error messages",
        "write onboarding text",
        "write tooltips and loading states" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0fbf9a54 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting voice and tone for any UX copy" ;
    oc:directiveContent "Adapt tone to user's emotional context: celebratory (but not over the top) for success, empathetic and helpful for errors, clear and actionable for warnings, informative and concise for neutral states." ;
    oc:hasRationale "Matching tone to emotional context builds trust — users need empathy when things go wrong and clarity when they need to act." .

oc:kn_35cd6e7a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing error messages for any interface context" ;
    oc:directiveContent "Error messages must follow the structure: What happened + Why it happened + How to fix it. Example: 'Payment declined. Your card was declined by your bank. Try a different card or contact your bank.'" ;
    oc:hasRationale "Structured error messages reduce user frustration by providing understanding and a clear path forward." ;
    oc:severityLevel "HIGH" .

oc:kn_46cb5011 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing empty state screens" ;
    oc:directiveContent "Empty state copy must follow the structure: What this is + Why it's empty + How to start. Include a clear action the user can take to move forward." ;
    oc:hasRationale "Empty states are critical onboarding moments — users need to understand what belongs there and how to populate it." .

oc:kn_91d8a1cf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or reviewing any UX copy" ;
    oc:directiveContent "UX copy must be Clear, Concise, Consistent, Useful, and Human — say what you mean in the fewest words, use consistent terminology, and write like a helpful person not a robot." ;
    oc:hasRationale "These five principles form the foundation of effective UX writing that reduces cognitive load and helps users accomplish their goals." ;
    oc:severityLevel "HIGH" .

oc:kn_929cfa32 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing confirmation dialogs" ;
    oc:directiveContent "Never use vague confirmation dialogs like 'Are you sure?' with generic 'OK'/'Cancel' buttons. Instead, clearly state the action ('Delete 3 files?'), describe consequences ('This can't be undone'), and label buttons with the specific action." ;
    oc:hasRationale "Generic confirmations create ambiguity about what action will be taken, leading to accidental destructive actions or user anxiety." ;
    oc:severityLevel "HIGH" .

oc:kn_a128dc30 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing call-to-action button labels" ;
    oc:directiveContent "CTAs must start with a verb, be specific about the outcome, and match the action label to the result — use 'Create account' not 'Submit'." ;
    oc:hasRationale "Specific verb-led CTAs set clear expectations and reduce user hesitation about what happens next." .

