oc:kn_060b11e9 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing error messages" ;
    oc:directiveContent "Error Messages: What happened + Why + How to fix. Example: 'Payment declined. Your card was declined by your bank. Try a different card or contact your bank.'" ;
    oc:hasRationale "Three-part structure gives users complete understanding and a clear path forward" .

oc:kn_3290c648 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or reviewing any UX copy" ;
    oc:directiveContent "UX copy must be Clear, Concise, Consistent, Useful, and Human. Say exactly what you mean, use fewest words, maintain consistent terminology, help users accomplish goals, and write like a helpful person." ;
    oc:hasRationale "These five principles form the foundational quality standard for all interface text" ;
    oc:severityLevel "HIGH" .

oc:kn_6e416121 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing CTA button copy" ;
    oc:directiveContent "CTAs must start with a verb and match the outcome to the label. Be specific: 'Create account' not 'Submit'." ;
    oc:hasRationale "Verb-first CTAs set clear expectations about the action's outcome" ;
    oc:severityLevel "MEDIUM" .

oc:kn_71a52291 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing empty state copy" ;
    oc:directiveContent "Empty States: What this is + Why it's empty + How to start. Example: 'No projects yet. Create your first project to start collaborating with your team.'" ;
    oc:hasRationale "Three-part structure turns a blank screen into an actionable moment" .

oc:kn_7febcefa a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting voice and tone for any UX copy" ;
    oc:directiveContent "Adapt tone to user's emotional context: Success = celebratory but not over the top; Error = empathetic and helpful; Warning = clear and actionable; Neutral = informative and concise." ;
    oc:hasRationale "Tone mismatch (e.g., celebratory during an error) undermines trust and usability" .

oc:kn_c9757b42 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating any UX copy" ;
    oc:directiveContent "Gather context before writing: screen/flow/feature, user state and intent, desired tone, and any character limits or platform guidelines." ;
    oc:hasRationale "Without sufficient context, copy will be generic and likely require revision" .

oc:kn_e2d4e5b6 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When connectors are available" ;
    oc:directiveContent "If a knowledge base connector is available, pull brand voice guidelines and content style guide first. If a design tool connector is available, check screen context and layout constraints." ;
    oc:hasRationale "Connectors provide essential brand and design context that dramatically improves copy quality" .

oc:kn_e36f881f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing CTAs and confirmation dialog buttons" ;
    oc:directiveContent "Never use generic labels like 'Submit', 'OK', or 'Cancel' on CTAs and confirmation dialogs. Always label buttons with the specific action: 'Create account', 'Delete files', 'Keep files'." ;
    oc:hasRationale "Generic labels create ambiguity about what action will be taken, increasing cognitive load and error risk" ;
    oc:severityLevel "HIGH" .

_:ref_1c91fc7749684db5 a oc:WorkflowStep ;
    dcterms:description "**Human**: Write like a helpful person, not a robot." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_1d7c7c18769aff1e a oc:WorkflowStep ;
    dcterms:description "**Share your brand voice** — \"We're professional but warm\" helps me match your tone." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_597624072d9910b1 a oc:WorkflowStep ;
    dcterms:description "**Consistent**: Same terms for the same things everywhere." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_89722c9a126efa30 a oc:WorkflowStep ;
    dcterms:description "**Be specific about context** — \"Error message when payment fails\" is better than \"error message.\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_95049b731b01afe5 a oc:WorkflowStep ;
    dcterms:description "**Consider the user's emotional state** — Error messages need empathy. Success messages can celebrate." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_c030708392600d94 a oc:WorkflowStep ;
    dcterms:description "**Clear**: Say exactly what you mean. No jargon, no ambiguity." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_c25a1d8354f16e9a a oc:WorkflowStep ;
    dcterms:description "**Useful**: Every word should help the user accomplish their goal." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_ce4fb41828a1fda6 a oc:WorkflowStep ;
    dcterms:description "**Concise**: Use the fewest words that convey the full meaning." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_3505077740d8f43a a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
