@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_user_research a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "user-research" ;
    skos:broader "research methodology framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/user-research" ;
    oc:contentHash "801f25c27133a81886155c9a4f953c9b646f794efc2108c49470bb879f29792f" ;
    oc:differentia "that guides the planning, execution, and synthesis of user research studies across multiple methods (interviews, usability tests, surveys, card sorting, diary studies, A/B testing)" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "research topic or question (e.g., \"user research plan for onboarding flow\", \"interview guide for enterprise users\")" ;
    oc:hasCategory "research" ;
    oc:hasDescription "Plan, conduct, and synthesize user research. Trigger with \"user research plan\", \"interview guide\", \"usability test\", \"survey design\", \"research questions\", or when the user needs help with any aspect of understanding their users through research." ;
    oc:hasName "user-research" ;
    oc:impartsKnowledge oc:kn_901b173c,
        oc:kn_9177f312,
        oc:kn_ba1a068d,
        oc:kn_e5b2475a,
        oc:kn_f4b8daba ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create interview guides",
        "create surveys",
        "design usability tests",
        "generate research questions",
        "plan user research studies",
        "synthesize user research findings" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_901b173c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a research method for a user research study" ;
    oc:directiveContent "Match the research method to the research goal: interviews for deep understanding (5-8 participants, 2-4 weeks), usability testing for evaluating designs (5-8 participants, 1-2 weeks), surveys for quantifying attitudes (100+ participants, 1-2 weeks), card sorting for IA decisions (15-30 participants, 1 week), diary studies for longitudinal behavior (10-15 participants, 2-8 weeks), and A/B testing for comparing design choices (statistical significance, 1-4 weeks)." ;
    oc:hasRationale "Each method has distinct strengths, sample size requirements, and timelines that determine the quality and type of insight produced" ;
    oc:severityLevel "HIGH" .

oc:kn_9177f312 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When synthesizing raw research data into actionable insights" ;
    oc:directiveContent "Use four analysis frameworks in combination: affinity mapping to group observations into themes, impact/effort matrix to prioritize findings, journey mapping to visualize the user experience over time, and Jobs to Be Done to understand what users are hiring the product to do." ;
    oc:hasRationale "Multiple complementary frameworks ensure both breadth (covering user experience holistically) and depth (prioritizing actionable findings) in synthesis" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ba1a068d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When starting any user research initiative" ;
    oc:directiveContent "Before conducting research, ensure you have a complete research plan with defined objectives, selected methods, a realistic timeline, and identified participants." ;
    oc:hasRationale "A well-defined research plan prevents scope creep, ensures methodological rigor, and aligns stakeholders on expectations before resources are committed" ;
    oc:severityLevel "HIGH" .

oc:kn_e5b2475a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating any user interview guide" ;
    oc:directiveContent "Structure interview guides in five phases: warm-up (5 min for rapport), context (10 min for current workflow), deep dive (20 min for the specific topic), reaction (10 min for concepts/prototypes), and wrap-up (5 min for closing)." ;
    oc:hasRationale "This phased structure ensures rapport is built before deep questioning, maintains participant engagement, and systematically covers all necessary research angles within a typical 50-minute session" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f4b8daba a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "When wrapping up a user research study" ;
    oc:directiveContent "Validate completed research by producing four deliverables: a research plan (objectives, methods, timeline, participants), an interview guide (questions, probes, activities), a synthesis report (themes, insights, recommendations), and a highlight reel (key quotes and observations)." ;
    oc:hasRationale "These four deliverables provide complete documentation that serves different audiences: the plan for stakeholders, the guide for researchers, the synthesis for decision-makers, and the highlight reel for quick executive consumption" ;
    oc:severityLevel "LOW" .

