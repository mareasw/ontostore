oc:kn_1ddeffde a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When connectors are detected" ;
    oc:directiveContent "If HRIS connector is available, pull live employee data for headcount, tenure, department, and level to avoid manual CSV uploads. If chat connector is available, offer to share report summaries in relevant channels." ;
    oc:hasRationale "Live HRIS data is more current and complete than manual uploads; sharing via chat increases report visibility" .

oc:kn_2e9c1015 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting report output" ;
    oc:directiveContent "Always include methodology section explaining how numbers were calculated and any caveats. Present findings with context, not raw data." ;
    oc:hasRationale "People analytics reports influence high-stakes decisions; transparency about methodology builds trust and prevents misinterpretation" .

oc:kn_7705e882 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting report type" ;
    oc:directiveContent "Report type must be one of: headcount, attrition, diversity, or org health. Each type requires different data fields and metrics." ;
    oc:hasRationale "Each report type has distinct analytical frameworks and data requirements" ;
    oc:severityLevel "HIGH" .

oc:kn_8aa763e3 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When formatting final report output" ;
    oc:directiveContent """## People Report: [Type] — [Date]

### Executive Summary
[2-3 key takeaways]

### Key Metrics
| Metric | Value | Trend |
|--------|-------|-------|
| [Metric] | [Value] | [up/down/flat] |

### Detailed Analysis
[Charts, tables, and narrative for the specific report type]

### Recommendations
- [Data-driven recommendation]
- [Action item]

### Methodology
[How the numbers were calculated, any caveats]""" ;
    oc:templateVariables "Date",
        "Metric",
        "Type",
        "Value" .

oc:kn_956ad2a8 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Always when generating any people report" ;
    oc:directiveContent "1. Understand what question they're trying to answer 2. Identify the right data (upload, paste, or pull from HRIS) 3. Analyze with appropriate statistical methods 4. Present findings with context and caveats 5. Recommend specific actions based on data" ;
    oc:hasRationale "Ensures reports are question-driven, data-validated, and actionable rather than generic" ;
    oc:stepOrder 1 .

oc:kn_9e76f6bc a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before generating any people report" ;
    oc:directiveContent "Requires workforce data — CSV upload, pasted data, or live HRIS connection. Helpful fields: Employee name/ID, department, team, title, level, location, start/end dates, manager, compensation, demographics" ;
    oc:hasRationale "People analytics requires structured employee data to produce meaningful metrics" .

oc:kn_e2c124e5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing diversity or attrition data" ;
    oc:directiveContent "Do not present diversity or attrition metrics without context about data completeness, demographic coverage, and statistical significance. Raw percentages without caveats can be misleading." ;
    oc:hasRationale "Small sample sizes or incomplete demographic data can produce misleading metrics that drive poor decisions" ;
    oc:severityLevel "HIGH" .

