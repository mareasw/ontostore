@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_people_report a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "people-report" ;
    skos:broader "Report generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/people-report" ;
    oc:contentHash "df718938ce65e9cdc53256d92d463c699df139b7a35a57e3cf8a8dda61aaf6a2" ;
    oc:differentia "that analyzes workforce data to produce headcount, attrition, diversity, or organizational health reports with metrics and recommendations" ;
    oc:handlesFailure oc:DataNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "<report type — headcount, attrition, diversity, org health>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Generate headcount, attrition, diversity, or org health reports. Use when pulling a headcount snapshot for leadership, analyzing turnover trends by team, preparing diversity representation metrics, or assessing span of control and flight risk across the org." ;
    oc:hasName "people-report" ;
    oc:impartsKnowledge oc:kn_2e8fd33d,
        oc:kn_5017f866,
        oc:kn_a79bb0c5,
        oc:kn_bc2d0fd0,
        oc:kn_d81d0bef ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DataAvailable ;
    oc:resolvesIntent "analyze attrition and turnover trends",
        "assess org health including span of control and flight risk",
        "generate headcount report",
        "generate people analytics reports from HR data",
        "produce diversity representation metrics" ;
    oc:yieldsState oc:ReportGenerated .

oc:kn_2e8fd33d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating diversity report type" ;
    oc:directiveContent "Diversity reports require demographic data which may not be available; explicitly note when representation metrics cannot be calculated." ;
    oc:hasRationale "Incomplete demographic data leads to biased or misleading diversity metrics; transparency about gaps is essential." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5017f866 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting a people report workflow" ;
    oc:directiveContent "Identify the right data source first (uploaded CSV, pasted data, or HRIS connector), then apply appropriate statistical methods for the report type." ;
    oc:hasRationale "Data quality and source selection directly determine the reliability and depth of the analysis." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a79bb0c5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When completing the analysis and presenting recommendations" ;
    oc:directiveContent "Recommend specific actions based on data findings rather than presenting raw metrics alone." ;
    oc:hasRationale "Reports without actionable recommendations leave stakeholders without a clear path forward, reducing the value of the analysis." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bc2d0fd0 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When presenting any people report output" ;
    oc:directiveContent "Include methodology and caveats section in every report explaining how numbers were calculated and any data limitations." ;
    oc:hasRationale "People analytics often involves sensitive data and statistical nuance; transparency about methodology builds trust and prevents misinterpretation." ;
    oc:severityLevel "HIGH" .

oc:kn_d81d0bef a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before beginning any people report analysis" ;
    oc:directiveContent "Always understand the underlying question the user is trying to answer before selecting data and analysis methods." ;
    oc:hasRationale "Users may request a report type that doesn't best serve their actual question; proper scoping ensures relevant and actionable output." ;
    oc:severityLevel "HIGH" .

