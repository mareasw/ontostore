@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_sox_testing a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "sox-testing" ;
    skos:broader "Compliance testing generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/sox-testing" ;
    oc:contentHash "01982833a9681e38ae2672512647cd4f9a90678c747dcc231c920eb0173c5566" ;
    oc:differentia "produces SOX 404 sample selections, testing workpapers, and control deficiency assessments for internal controls over financial reporting" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<control-area> [period]" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Generate SOX sample selections, testing workpapers, and control assessments. Use when planning quarterly or annual SOX 404 testing, pulling a sample for a control (revenue, P2P, ITGC, close), building a testing workpaper template, or evaluating and classifying a control deficiency." ;
    oc:hasName "sox-testing" ;
    oc:impartsKnowledge oc:kn_07aba6e4,
        oc:kn_0ac4c40c,
        oc:kn_49afcd91,
        oc:kn_a0c4b3d4,
        oc:kn_bc098eb6 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create testing workpapers",
        "document control assessments",
        "evaluate control deficiencies",
        "generate SOX sample selections",
        "plan SOX 404 testing" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_07aba6e4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining sample size for any SOX control test" ;
    oc:directiveContent "Sample sizes must be calibrated based on control frequency and risk level: annual controls test 1 instance, daily controls require 20-40 samples, and per-transaction controls require 25-60 samples." ;
    oc:hasRationale "Statistical validity of testing conclusions depends on appropriate sample sizing relative to population size and control risk" ;
    oc:severityLevel "HIGH" .

oc:kn_0ac4c40c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating and documenting control exceptions" ;
    oc:directiveContent "Classify deficiencies using the three-tier framework: Deficiency (control did not operate effectively), Significant Deficiency (important enough for oversight attention), Material Weakness (reasonable possibility of undetected material misstatement)." ;
    oc:hasRationale "Proper deficiency classification drives correct escalation, remediation priority, and financial reporting disclosure requirements under SOX 404" ;
    oc:severityLevel "CRITICAL" .

oc:kn_49afcd91 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When selecting samples from a control population" ;
    oc:directiveContent "Always use random selection as the default method for transaction-level controls; systematic selection for periodic controls; and targeted selection only as a supplement for risk-based testing with documented rationale." ;
    oc:hasRationale "Random selection provides the most defensible basis for projecting test results to the full population; targeted selections must be clearly justified" ;
    oc:severityLevel "HIGH" .

oc:kn_a0c4b3d4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, as a blanket disclaimer on all outputs" ;
    oc:directiveContent "This skill does not provide audit or legal advice. All testing workpapers and assessments must be reviewed by qualified financial professionals before use in audit documentation." ;
    oc:hasRationale "SOX compliance has legal and regulatory implications; unqualified outputs could be misused as formal audit documentation without proper review" ;
    oc:severityLevel "CRITICAL" .

oc:kn_bc098eb6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adjusting sample size beyond base recommendations" ;
    oc:directiveContent "Increase sample sizes when controls had prior year deficiencies, when risk level is high, or when external auditors rely on the control being tested." ;
    oc:hasRationale "Prior deficiencies indicate control instability; higher risk demands more evidence; auditor reliance requires more rigorous testing to support their opinion" ;
    oc:severityLevel "MEDIUM" .

