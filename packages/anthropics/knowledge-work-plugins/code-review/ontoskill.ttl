oc:kn_13b626cb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing performance-sensitive code or data access layers" ;
    oc:directiveContent "Watch for N+1 queries, unbounded loops, O(n²) complexity in hot paths, missing database indexes, and resource leaks." ;
    oc:hasRationale "Performance issues are hard to fix after deployment and degrade user experience at scale" ;
    oc:severityLevel "HIGH" .

oc:kn_44373633 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any code review" ;
    oc:directiveContent "Review code across four dimensions: security, performance, correctness, and maintainability. Each dimension has specific checklists to ensure comprehensive coverage." ;
    oc:hasRationale "Structured multi-dimensional review catches issues that ad-hoc reviewing misses" ;
    oc:severityLevel "HIGH" .

oc:kn_d5cc4ec9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing any code that handles user input, network requests, or data persistence" ;
    oc:directiveContent "Never approve code without checking for OWASP Top 10 vulnerabilities: SQL injection, XSS, CSRF, insecure deserialization, path traversal, and SSRF." ;
    oc:hasRationale "Security vulnerabilities in production code can lead to data breaches and system compromise" ;
    oc:severityLevel "CRITICAL" .

oc:kn_de61a094 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When reviewing business logic, data transformations, or concurrent code" ;
    oc:directiveContent "Common correctness pitfalls include: edge cases (empty input, null, overflow), race conditions, improper error propagation, off-by-one errors, and type safety violations." ;
    oc:hasRationale "Correctness bugs often only surface in production under edge conditions" ;
    oc:severityLevel "HIGH" .

oc:kn_e020f169 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user provides additional context or specifies review focus areas" ;
    oc:directiveContent "If the user provides context like 'this is a hot path' or 'this handles PII', focus the review accordingly. If they specify concerns like 'focus on security', narrow scope." ;
    oc:hasRationale "Targeted reviews based on domain knowledge are more effective than unfocused checks" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ef8d6039 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When finalizing a code review" ;
    oc:directiveContent "A complete code review produces a structured report with: summary, critical issues table (file, line, issue, severity), suggestions table (file, line, suggestion, category), positive observations, and a verdict (Approve / Request Changes / Needs Discussion)." ;
    oc:hasRationale "Structured output ensures nothing is missed and findings are actionable" ;
    oc:severityLevel "MEDIUM" .

_:ref_068676ffa3bcbc29 a oc:WorkflowStep ;
    dcterms:description "**Specify concerns** — \"Focus on security\" narrows the review." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_ef595ba32598aa99 a oc:WorkflowStep ;
    dcterms:description "**Include tests** — I'll check test coverage and quality too." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_f1323372f2b3ee1f a oc:WorkflowStep ;
    dcterms:description "**Provide context** — \"This is a hot path\" or \"This handles PII\" helps me focus." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_048b22bfe698dc0d a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_068676ffa3bcbc29,
        _:ref_ef595ba32598aa99,
        _:ref_f1323372f2b3ee1f ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_48d5555b3cfa6fa3 a oc:WorkflowStep ;
    dcterms:description "Analyze code for correctness: edge cases, race conditions, error handling, off-by-one errors, type safety." ;
    oc:expectedOutcome "Correctness issues and missing edge case handling identified" ;
    oc:stepDependsOn _:ref_9d2fece4d2447020 ;
    oc:stepId "correctness-review" .

_:ref_a403fbc557a99a47 a oc:WorkflowStep ;
    dcterms:description "Analyze code for security vulnerabilities: SQL injection, XSS, CSRF, auth flaws, secrets in code, insecure deserialization, path traversal, SSRF." ;
    oc:expectedOutcome "Security issues identified and categorized by severity" ;
    oc:stepDependsOn _:ref_9d2fece4d2447020 ;
    oc:stepId "security-review" .

_:ref_acdc6fafbef5c66f a oc:WorkflowStep ;
    dcterms:description "Analyze code for performance issues: N+1 queries, unnecessary allocations, algorithmic complexity, missing indexes, unbounded queries, resource leaks." ;
    oc:expectedOutcome "Performance issues identified with context on impact" ;
    oc:stepDependsOn _:ref_9d2fece4d2447020 ;
    oc:stepId "performance-review" .

_:ref_ad8c3a258178be37 a oc:WorkflowStep ;
    dcterms:description "Analyze code for maintainability: naming clarity, single responsibility, duplication, test coverage, documentation." ;
    oc:expectedOutcome "Maintainability concerns and improvement suggestions identified" ;
    oc:stepDependsOn _:ref_9d2fece4d2447020 ;
    oc:stepId "maintainability-review" .

_:ref_9d2fece4d2447020 a oc:WorkflowStep ;
    dcterms:description "Gather the code to review from PR URL, diff, or file path. If no input provided, ask the user what to review." ;
    oc:expectedOutcome "Code changes are loaded and ready for analysis" ;
    oc:stepId "gather-input" .

