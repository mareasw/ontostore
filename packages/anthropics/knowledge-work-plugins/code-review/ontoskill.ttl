@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_code_review a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "code-review" ;
    skos:broader "Code analysis routine" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/code-review" ;
    oc:contentHash "3dc27667528a91e20f93c06ef702fc64a878805c0f84016bf873300877e8dec4" ;
    oc:differentia "Reviews code changes across security, performance, correctness, and maintainability dimensions with structured output and severity ratings" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "<PR URL, diff, or file path>" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Review code changes for security, performance, and correctness. Trigger with a PR URL or diff, \"review this before I merge\", \"is this code safe?\", or when checking a change for N+1 queries, injection risks, missing edge cases, or error handling gaps." ;
    oc:hasName "code-review" ;
    oc:impartsKnowledge oc:kn_11b6ddef,
        oc:kn_22fe5cb2,
        oc:kn_6166a5c0,
        oc:kn_c637a48a,
        oc:kn_eb227f83 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:CodeChangesAvailable ;
    oc:resolvesIntent "analyze code diffs for performance issues like N+1 queries and memory leaks",
        "check code correctness for edge cases and error handling",
        "evaluate code maintainability and style",
        "perform pre-merge code review on pull requests",
        "review code changes for security vulnerabilities" ;
    oc:yieldsState oc:CodeReviewCompleted .

oc:kn_11b6ddef a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When executing any code review" ;
    oc:directiveContent "Always review code across four dimensions: security, performance, correctness, and maintainability — never skip a dimension even if the user only asks about one." ;
    oc:hasRationale "A holistic review catches cross-cutting issues that a narrow focus would miss, such as a performance optimization that introduces a security vulnerability." ;
    oc:severityLevel "HIGH" .

oc:kn_22fe5cb2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing the security dimension" ;
    oc:directiveContent "Security findings must be checked against OWASP Top 10 categories: injection, XSS, CSRF, broken auth, insecure deserialization, path traversal, and SSRF." ;
    oc:hasRationale "The OWASP Top 10 represents the most critical web application security risks and provides a proven systematic checklist." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6166a5c0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user provides context about the code being reviewed" ;
    oc:directiveContent "If the user provides context like 'this is a hot path' or 'this handles PII', adjust review focus to prioritize performance or security respectively rather than treating all dimensions equally." ;
    oc:hasRationale "Context-aware reviews deliver higher-value findings by concentrating effort where it matters most for the specific code." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c637a48a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting review output" ;
    oc:directiveContent "Do not provide vague feedback like 'this could be better' — every finding must include the file, line number, severity, and an actionable suggestion with code examples." ;
    oc:hasRationale "Actionable feedback with specific locations reduces back-and-forth and makes it easy for developers to address issues directly." ;
    oc:severityLevel "HIGH" .

oc:kn_eb227f83 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When external tool connectors are configured" ;
    oc:directiveContent "When connectors (source control, project tracker, knowledge base) are available, leverage them to automatically pull diffs, link findings to tickets, and validate against team standards rather than relying solely on manual input." ;
    oc:hasRationale "Integration with existing tools reduces manual effort, enriches review context, and ensures alignment with team coding standards." ;
    oc:severityLevel "MEDIUM" .

