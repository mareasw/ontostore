        oc:kn_dedbe793 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DirectoryWritable,
        oc:EnvironmentReady ;
    oc:resolvesIntent "bootstrap working memory",
        "decode workplace shorthand and nicknames",
        "first-time plugin setup",
        "initialize productivity system",
        "open dashboard",
        "set up task management" ;
    oc:yieldsState oc:DocumentCreated,
        oc:SystemInitialized .

oc:kn_1e300d32 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During memory bootstrap when analyzing task items" ;
    oc:directiveContent "Never skip asking the user to clarify unfamiliar terms — always decode nicknames, acronyms, and codenames interactively rather than guessing" ;
    oc:hasRationale "Incorrect assumptions about shorthand lead to persistent misunderstandings in the memory system" ;
    oc:severityLevel "HIGH" .

oc:kn_2a596c86 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Check for existing files (TASKS.md, CLAUDE.md, memory/, dashboard.html) → 2. Create missing files from templates → 3. Tell user to open dashboard → 4. Orient user if already initialized, else bootstrap memory → 5. Ask user for task source → 6. Decode shorthand interactively → 7. Optional comprehensive scan from MCP sources → 8. Write CLAUDE.md and memory/ files → 9. Report results" ;
    oc:stepOrder 1 .

oc:kn_49e730b0 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Final status report after initialization completes" ;
    oc:directiveContent """Productivity system ready:
- Tasks: TASKS.md (X items)
- Memory: X people, X terms, X projects
- Dashboard: open in browser

Use /productivity:update to keep things current (add --comprehensive for a deep scan).""" ;
    oc:templateVariables "X items",
        "X people",
        "X projects",
        "X terms" .

oc:kn_5ffe2028 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "During optional comprehensive scan in step 6" ;
    oc:directiveContent "If an MCP source (chat, email, docs, calendar) isn't available during comprehensive scan, skip it gracefully and note the gap for later" ;
    oc:hasRationale "Not all users have all sources connected; graceful degradation ensures the bootstrap still completes" .

oc:kn_6b37b263 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing sources for memory bootstrap" ;
    oc:directiveContent "The best source of workplace language is the user's actual task list — real tasks contain real shorthand used in daily work" ;
    oc:hasRationale "Task lists contain authentic, current workplace terminology rather than formal/staged language" .

oc:kn_6d02a707 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When TASKS.md, CLAUDE.md, memory/, and dashboard.html already exist" ;
    oc:directiveContent "This skill is idempotent — if memory is already initialized, it just opens the dashboard without re-running bootstrap" ;
    oc:hasRationale "Prevents redundant bootstrap on repeated invocations" ;
    oc:severityLevel "MEDIUM" .

oc:kn_754936ef a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When opening the dashboard in step 3" ;
    oc:directiveContent "Do NOT use `open` or `xdg-open` to open the dashboard — in Cowork the agent runs in a VM and shell open commands won't reach the user's browser. Instead, tell the user to open dashboard.html from their file browser." ;
    oc:hasRationale "The agent runs in a VM environment where shell-level open commands cannot reach the host browser" ;
    oc:severityLevel "CRITICAL" .

oc:kn_78b1b95d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating CLAUDE.md working memory file during bootstrap" ;
    oc:codeLanguage "markdown" ;
    oc:directiveContent """# Memory

## Me
[Name], [Role] on [Team].

## People
| Who | Role |
|-----|------|
| **[Nickname]** | [Full Name], [role] |

## Terms
| Term | Meaning |
|------|---------|
| [acronym] | [expansion] |

## Projects
| Name | What |
|------|------|
| **[Codename]** | [description] |

## Preferences
- [preferences discovered]""" .

oc:kn_a80d80bd a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires a writable working directory and access to ${CLAUDE_PLUGIN_ROOT}/skills/dashboard.html template" .

oc:kn_dedbe793 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting findings from comprehensive MCP scan" ;
    oc:directiveContent "Present scan findings grouped by confidence level: high-confidence items ready to add directly, items needing clarification asked of the user, and low-frequency/unclear items noted for later" ;
    oc:hasRationale "Confidence-tiered presentation reduces user fatigue while ensuring accuracy of high-stakes memory entries" .

