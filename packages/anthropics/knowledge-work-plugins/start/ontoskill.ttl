oc:skill_knowledge_work_plugins_start a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "start" ;
    skos:broader "System initialization command" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/start" ;
    oc:contentHash "2e0dec7859c0cf7db8ced86bb87edce5a9c4cdf19bf6e7c21f0d77065a39083a" ;
    oc:dependsOnSkill oc:skill_ontoskills_task_management,
        oc:skill_ontoskills_update ;
    oc:differentia "Bootstraps task management files, working memory, and dashboard UI while interactively decoding user workplace shorthand from task lists and connected sources" ;
    oc:handlesFailure oc:FileNotFound,
        oc:PermissionDenied ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Initialize the productivity system and open the dashboard. Use when setting up the plugin for the first time, bootstrapping working memory from your existing task list, or decoding the shorthand (nicknames, acronyms, project codenames) you use in your todos." ;
    oc:hasName "start" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Initialize the task and memory systems, then open the unified dashboard." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Check the working directory for:" ],
