                            oc:sectionTitle "3. Discover Schema (If Warehouse Connected)" ],
                        [ a oc:Section ;
                            oc:hasContent _:ref_2a97094bc54afaf9,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Provide:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
