                                    oc:itemOrder 1 ;
                                    oc:itemText "Mention your SQL dialect upfront to get the right syntax immediately" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "If you know the table names, include them -- otherwise Claude will help you find them" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Specify if you need the query to be idempotent (safe to re-run) or one-time" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "For recurring queries, mention if it should be parameterized for date ranges" ] ] ;
