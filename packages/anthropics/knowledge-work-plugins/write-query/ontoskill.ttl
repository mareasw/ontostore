                                            oc:itemOrder 7 ;
                                            oc:itemText "**SQL Server** (Microsoft)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**BigQuery** (Google Cloud)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "**MySQL** (including Aurora MySQL, PlanetScale)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Snowflake**" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
