oc:kn_08da68f0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reconciling items remain outstanding across multiple periods" ;
    oc:directiveContent "Do not carry reconciling items forward indefinitely without investigation. Track open items to resolution and perform root cause analysis on recurring items." ;
    oc:hasRationale "Perpetual carry-forward masks underlying process failures and can conceal material misstatements." ;
    oc:severityLevel "HIGH" .

oc:kn_0b9c2bea a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing reconciliation calculations" ;
    oc:directiveContent "Confirm the difference between adjusted balances is $0.00. If not zero, the period cannot be closed — the difference must be resolved or formally documented." ;
    oc:hasRationale "A non-zero difference indicates incomplete reconciliation and unresolved discrepancies." ;
    oc:severityLevel "CRITICAL" .

oc:kn_160bb889 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning reconciliation work" ;
    oc:directiveContent "Verify GL data and subledger/bank statement data are available for the same period-end date before starting reconciliation." ;
    oc:severityLevel "HIGH" .

oc:kn_1634f93d a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """Balance per bank statement:         $XX,XXX
Add: Deposits in transit            $X,XXX
Less: Outstanding checks           ($X,XXX)
Add/Less: Bank errors               $X,XXX
Adjusted bank balance:              $XX,XXX

Balance per general ledger:         $XX,XXX
Add: Interest/credits not recorded  $X,XXX
Less: Bank fees not recorded       ($X,XXX)
Add/Less: GL errors                 $X,XXX
Adjusted GL balance:                $XX,XXX

Difference:                         $0.00""" ;
    oc:templateVariables "bank_errors",
        "bank_fees",
        "bank_statement_balance",
        "deposits_in_transit",
        "gl_balance",
        "gl_errors",
        "interest_credits",
        "outstanding_checks" .

oc:kn_322ce539 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent "| Item # | Description | Amount | Date Originated | Age (Days) | Category | Status | Owner |" ;
    oc:templateVariables "Age (Days)",
        "Amount",
        "Category",
        "Date Originated",
        "Description",
        "Item #",
        "Owner",
        "Status" .

oc:kn_42674b4d a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When reconciliation does not balance to zero" ;
    oc:directiveContent "For unreconciled differences at any amount: cannot close the period — must resolve the difference or formally document with management approval." ;
    oc:hasRationale "Unresolved differences may represent material misstatements that affect financial statement integrity." ;
    oc:severityLevel "CRITICAL" .

oc:kn_563d9099 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting reconciliation work" ;
    oc:directiveContent "Every reconciliation must include preparer, reviewer, date, and clear explanation of all reconciling items. Use consistent templates across all accounts." ;
    oc:hasRationale "Complete documentation provides audit trail and supports SOX compliance and external audit review." ;
    oc:severityLevel "MEDIUM" .

oc:kn_83d47494 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "always" ;
    oc:directiveContent "All reconciliations must be reviewed by qualified financial professionals before sign-off. This skill does not provide financial advice." ;
    oc:hasRationale "Reconciliation outputs carry financial reporting risk and require professional judgment for final approval." ;
    oc:severityLevel "HIGH" .

oc:kn_863c7c27 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning reconciliation preparers" ;
    oc:directiveContent "The person who reconciles should not be the same person who processes transactions in that account (segregation of duties)." ;
    oc:hasRationale "Segregation of duties is a fundamental internal control to prevent and detect fraud or errors." ;
    oc:severityLevel "CRITICAL" .

oc:kn_93b69bd5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating escalation thresholds" ;
    oc:directiveContent "Escalate individual items > $10,000 to supervisor, > $50,000 to controller. Items aged > 60 days require supervisor follow-up, > 90 days require controller review. Growing trends over 3+ consecutive periods trigger process improvement investigation." ;
    oc:hasRationale "Tiered escalation ensures material items receive appropriate oversight while preventing low-value noise from overwhelming reviewers." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d8085f9c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scheduling reconciliation work" ;
    oc:directiveContent "Complete reconciliations within T+3 to T+5 business days after period end. Reconcile material accounts monthly, immaterial accounts quarterly." ;
    oc:hasRationale "Timeliness ensures discrepancies are caught before they compound and supports the close calendar." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f0a3d83e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing any account reconciliation" ;
    oc:directiveContent "1. Pull GL balance for the control account as of period end 2. Pull subledger/bank statement balance as of the same date 3. Compare totals 4. Identify and categorize differences (timing, adjustments required, investigation needed) 5. Prepare adjusting entries for Category 2 items 6. Investigate Category 3 items and escalate if unresolved 7. Generate aging analysis for outstanding items 8. Document preparer, reviewer, date, and explanations" ;
    oc:stepOrder 1 .

_:ref_0be0078e7e2b2727 a oc:WorkflowStep ;
    dcterms:description "**Completeness:** Reconcile all balance sheet accounts on a defined frequency (monthly for material accounts, quarterly for immaterial)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_101410f995b24703 a oc:WorkflowStep ;
    dcterms:description "Confirm all intercompany transactions have been recorded on both sides" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_110a7ff61cca877b a oc:WorkflowStep ;
    dcterms:description "Compare totals — they should match if posting is real-time" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_14a232691ffc0814 a oc:WorkflowStep ;
    dcterms:description "**Root cause analysis:** For recurring reconciling items, investigate and fix the underlying process issue" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_287eb79630652b46 a oc:WorkflowStep ;
    dcterms:description "**Retention:** Maintain reconciliations and supporting detail per your organization's document retention policy" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_8" ;
    oc:stepOrder 8 .

_:ref_32fd8b5b0d9030be a oc:WorkflowStep ;
    dcterms:description "Reconcile both sides to an adjusted balance" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

