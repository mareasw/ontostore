@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_reconciliation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "reconciliation" ;
    skos:broader "Financial control methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/reconciliation" ;
    oc:contentHash "4c2040317832a902ab08ae29055a76d1c768afe1cafef6f4ac4bc88c265e6e2d" ;
    oc:dependsOnSkill oc:skill_journal_entry ;
    oc:differentia "that compares GL balances to subledgers, bank statements, or third-party data to identify and categorize reconciling items with aging analysis and escalation" ;
    oc:handlesFailure oc:DataNotAvailable,
        oc:UnreconciledDifference ;
    oc:hasArgumentHint "<account> [period]" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Reconcile accounts by comparing GL balances to subledgers, bank statements, or third-party data. Use when performing bank reconciliations, GL-to-subledger recs, intercompany reconciliations, or identifying and categorizing reconciling items." ;
    oc:hasName "reconciliation" ;
    oc:impartsKnowledge oc:kn_22c4e86c,
        oc:kn_29d0ef3a,
        oc:kn_7034e2fe,
        oc:kn_73e3ec08,
        oc:kn_80edcbcb,
        oc:kn_a9da7f99,
        oc:kn_bccdee97 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:GLBalanceAvailable,
        oc:PeriodClosed ;
    oc:resolvesIntent "categorize reconciling items",
        "compare GL to subledger",
        "identify reconciliation differences",
        "perform bank reconciliation",
        "reconcile accounts",
        "reconcile intercompany balances",
        "track reconciling item aging" ;
    oc:yieldsState oc:AccountsReconciled,
        oc:ReconcilingItemsCategorized .

oc:kn_22c4e86c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When trending analysis reveals recurring or growing reconciling item patterns" ;
    oc:directiveContent "Investigate recurring reconciling items for root cause rather than adjusting each period. If same-type differences appear 3+ consecutive periods, initiate process improvement investigation." ;
    oc:hasRationale "Recurring differences signal underlying process or system issues that periodic adjustments cannot fix permanently." ;
    oc:severityLevel "MEDIUM" .

oc:kn_29d0ef3a a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When categorizing and resolving reconciling items" ;
    oc:directiveContent "Reconciling items categorized as 'Adjustments Required' will result in journal entries that modify GL or subledger balances." ;
    oc:hasRationale "Adjusting entries change financial balances and must be properly authorized and documented." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7034e2fe a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning reconciliation work for any account" ;
    oc:directiveContent "The person who reconciles an account must not be the same person who processes transactions in that account (segregation of duties)." ;
    oc:hasRationale "Segregation of duties prevents fraud and ensures independent verification of account balances." ;
    oc:severityLevel "CRITICAL" .

oc:kn_73e3ec08 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing period-end reconciliation" ;
    oc:directiveContent "Reconciliations must be completed within the close calendar deadline, typically T+3 to T+5 business days after period end." ;
    oc:hasRationale "Timely reconciliations ensure differences are caught while supporting detail is still accessible and before the next period's transactions complicate investigation." ;
    oc:severityLevel "HIGH" .

oc:kn_80edcbcb a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When completing any reconciliation" ;
    oc:directiveContent "Every reconciliation must include preparer, reviewer, date, and clear explanation of all reconciling items. Reconcile all material balance sheet accounts monthly." ;
    oc:hasRationale "Complete documentation supports audit trail requirements and ensures accountability for review and sign-off." ;
    oc:severityLevel "HIGH" .

oc:kn_a9da7f99 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing outstanding reconciling items across periods" ;
    oc:directiveContent "Do not carry reconciling items forward indefinitely without investigation. Track every open item to resolution." ;
    oc:hasRationale "Indefinitely carried items may indicate process failures, fraud, or material misstatements that worsen over time." ;
    oc:severityLevel "HIGH" .

oc:kn_bccdee97 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing aging analysis on reconciling items" ;
    oc:directiveContent "Items aged 90+ days are stale and should be escalated to management for potential write-off or adjustment. Items 61-90 days are overdue and require supervisor notification." ;
    oc:hasRationale "Aging thresholds prevent stale items from accumulating and ensure management visibility into unresolved differences that may represent real financial exposure." ;
    oc:severityLevel "MEDIUM" .

