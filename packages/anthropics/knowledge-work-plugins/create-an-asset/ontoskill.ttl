oc:skill_knowledge_work_plugins_create_an_asset a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "create-an-asset" ;
    skos:broader "Sales asset generator" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/create-an-asset" ;
    oc:contentHash "9e1ae0a903f9b89ae2d588d3d1e871c5a1d1594ec596bf5dc99333ee2972916d" ;
    oc:differentia "that researches prospects, gathers deal context, and produces branded self-contained HTML deliverables (landing pages, decks, one-pagers, workflow demos) tailored to audience and deal stage" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasAlias "/create-an-asset",
        "build a demo",
        "make a landing page",
        "mock up a workflow" ;
    oc:hasArgumentHint "[CompanyName] and optional deal context (audience, purpose, format)" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Generate tailored sales assets (landing pages, decks, one-pagers, workflow demos) from your deal context. Describe your prospect, audience, and goal — get a polished, branded asset ready to share with customers." ;
    oc:hasName "create-an-asset" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Generate custom sales assets tailored to your prospect, audience, and goals. Supports interactive landing pages, presentation decks, executive one-pagers, and workflow/architecture demos." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 7 ;
                            oc:tableCaption "For workflow demos, use these icon mappings" ;
                            oc:tableMarkdown """| Type | Icon | Example |
|------|------|---------|
| human | 👤 or person SVG | User, Analyst, Admin |
| document | 📄 or file SVG | PDF, Contract, Report |
| ai | 🤖 or brain SVG | Claude, AI Agent |
| database | 🗄️ or cylinder SVG | Snowflake, Postgres |
| api | 🔌 or plug SVG | REST API, GraphQL |
| middleware | ⚡ or hub SVG | Workato, MCP Server |
| output | 📊 or screen SVG | Dashboard, Report |
""" ],
                        [ a oc:Paragraph ;
