@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_create_an_asset a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "create-an-asset" ;
    skos:broader "Sales asset generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/create-an-asset" ;
    oc:contentHash "9e1ae0a903f9b89ae2d588d3d1e871c5a1d1594ec596bf5dc99333ee2972916d" ;
    oc:differentia "Produces tailored, branded, self-contained HTML deliverables (landing pages, decks, one-pagers, workflow demos) from prospect/audience/purpose context through a multi-phase research-and-build pipeline" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasAlias "build demo",
        "create asset",
        "create-an-asset",
        "make landing page",
        "mock up workflow" ;
    oc:hasArgumentHint "[CompanyName] or description of prospect, audience, and asset format" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Generate tailored sales assets (landing pages, decks, one-pagers, workflow demos) from your deal context. Describe your prospect, audience, and goal — get a polished, branded asset ready to share with customers." ;
    oc:hasName "create-an-asset" ;
    oc:impartsKnowledge oc:kn_01aa7fc0,
        oc:kn_12df0aea,
        oc:kn_2dfaab0c,
        oc:kn_2f902d6d,
        oc:kn_3e0ad22b,
        oc:kn_d7b1d1c0,
        oc:kn_f0e4dd21,
        oc:kn_ffde4a8b ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "build landing page for prospect",
        "build workflow demo",
        "create architecture diagram for prospect",
        "create executive one-pager",
        "create sales asset",
        "generate customer-facing sales deliverable",
        "generate presentation deck" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_01aa7fc0 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During Phase 5 clarifying questions" ;
    oc:directiveContent "Cap clarifying questions at 2 rounds maximum. If still ambiguous after 2 rounds, make a reasonable default choice and note it for the user." ;
    oc:hasRationale "Excessive back-and-forth frustrates users who want quick results; better to produce a strong draft and iterate than to over-question" ;
    oc:severityLevel "MEDIUM" .

oc:kn_12df0aea a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "During Phase 1 research" ;
    oc:directiveContent "Research depth should adapt to context richness: light research for rich context (transcripts provided), medium for moderate context, deep full research pass for sparse context (just company name)." ;
    oc:hasRationale "Adaptive research avoids wasting time on redundant research when context is already rich, while ensuring quality when context is sparse" ;
    oc:severityLevel "MEDIUM" .

oc:kn_2dfaab0c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before entering Phase 6 (Build & Deliver)" ;
    oc:directiveContent "Always ask clarifying questions (Phase 5) before building any asset. Confirm understanding of prospect, audience, purpose, and key themes before generating output." ;
    oc:hasRationale "Clarifying questions prevent wasted effort on misaligned assets and ensure the first draft closely matches the seller's intent" ;
    oc:severityLevel "CRITICAL" .

oc:kn_2f902d6d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before final delivery in Phase 6" ;
    oc:directiveContent "Never deliver an asset with placeholder text, incorrect leadership names, or unsourced proof points. Run the quality checklist before delivery." ;
    oc:hasRationale "Placeholders or inaccurate data undermine credibility and make the seller appear unprepared" ;
    oc:severityLevel "CRITICAL" .

oc:kn_3e0ad22b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Transition from Phase 5 to Phase 6" ;
    oc:directiveContent "Before building, verify: prospect company name is correct, deal stage is defined, audience type is specified, format is selected, and research is complete." ;
    oc:hasRationale "Missing required inputs lead to generic or inaccurate assets that require extensive revision" ;
    oc:severityLevel "HIGH" .

oc:kn_d7b1d1c0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying visual design in Phase 4" ;
    oc:directiveContent "All assets must use the prospect's brand colors by default, not the seller's. Switch to seller brand or neutral palette only on explicit request after initial build." ;
    oc:hasRationale "Prospects feel the asset is truly custom-built for them when their brand colors are used, increasing engagement and perceived professionalism" ;
    oc:severityLevel "HIGH" .

oc:kn_f0e4dd21 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating content in Phase 3" ;
    oc:directiveContent "Use the prospect's exact language, terminology, and stated priorities from conversations or transcripts. Map seller product features directly to prospect pain points explicitly." ;
    oc:hasRationale "Tailored content using the prospect's own words demonstrates listening and understanding, making the asset feel custom rather than templated" ;
    oc:severityLevel "HIGH" .

oc:kn_ffde4a8b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building and delivering the final asset" ;
    oc:directiveContent "All output must be a single self-contained HTML file with inline CSS and JS, no external dependencies except Google Fonts." ;
    oc:hasRationale "Single-file HTML ensures easy sharing via email, static hosting, or direct file transfer without deployment complexity" ;
    oc:severityLevel "HIGH" .

