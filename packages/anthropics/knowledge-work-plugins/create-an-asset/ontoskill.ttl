oc:kn_18523c92 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Phase 0 Step 0.1 — always" ;
    oc:directiveContent "Persists seller context to knowledge base for future sessions. On subsequent invocations, confirms stored context with user." ;
    oc:hasRationale "Avoids re-collecting the same seller information across multiple asset creation sessions." .

oc:kn_40a49c76 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Phase 1: Research (Adaptive)" ;
    oc:directiveContent "Adapt research depth to context richness: light research when transcripts/detailed context provided, medium for some context, deep full research pass when only company name is known." ;
    oc:hasRationale "Avoids wasted effort on already-rich context while ensuring sparse inputs get thorough research to fill gaps." .

oc:kn_a49df0aa a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before Phase 6: Build & Deliver" ;
    oc:directiveContent "Never build the asset without first asking clarifying questions. Phase 5 (Clarifying Questions) is REQUIRED before any build." ;
    oc:hasRationale "Skipping alignment confirmation leads to wasted effort rebuilding assets that don't match the seller's vision." ;
    oc:severityLevel "HIGH" .

oc:kn_aab49ac9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Phase 3: Content Generation — always" ;
    oc:directiveContent "All content must use the prospect's own language and terminology, reference specific pain points from input/transcripts, map seller's product to prospect's needs explicitly, and feel tailored not templated." ;
    oc:hasRationale "Generic content undermines credibility; prospects disengage when assets feel copy-pasted rather than personalized." .

oc:kn_dbdafaad a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Quality checklist — before delivery" ;
    oc:directiveContent "Before delivering, verify: prospect company name spelled correctly, leadership names current, pain points match input, no placeholder text, brand colors applied, all interactive elements functional, and tone matches audience." ;
    oc:hasRationale "Errors in customer-facing assets damage credibility and can lose deals." .

oc:kn_de451805 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Phase 6: Output format — always" ;
    oc:directiveContent "All output must be a self-contained single HTML file with all CSS/JS inline, no external dependencies except Google Fonts." ;
    oc:hasRationale "Self-contained files enable easy sharing via email, static hosting, or direct delivery without deployment complexity." .

oc:kn_f22d6991 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When brand color extraction fails" ;
    oc:directiveContent "If brand colors cannot be extracted from the prospect's website or brand guidelines, use industry-based fallback colors (Technology=#2563eb, Finance=#0f172a, Healthcare=#0891b2, Manufacturing=#ea580c, Retail=#db2777, Energy=#16a34a, Default=#3b82f6)." ;
    oc:hasRationale "Ensures the asset always has a professional appearance even when brand information is unavailable." .

oc:kn_f7e529de a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Phase 5: Clarifying Questions" ;
    oc:directiveContent "Limit clarifying questions to max 2 rounds. If still ambiguous after that, make a reasonable choice and note it to the user." ;
    oc:hasRationale "Extended back-and-forth frustrates users; reasonable defaults with transparency are better than indefinite questioning." ;
    oc:severityLevel "MEDIUM" .

