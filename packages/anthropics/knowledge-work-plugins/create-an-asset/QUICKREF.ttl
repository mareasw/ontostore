oc:skill_anthropics_knowledge_work_plugins_create_an_asset_quickref a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "quickref" ;
    skos:broader "Reference card" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/create-an-asset" ;
    oc:contentHash "7f2983058ae91e9f4f1fe9c7cd7f86ae18dbe9c78d9f6aeb8716077f33a876e7" ;
    oc:differentia "provides a condensed lookup table for the create-an-asset skill's invocation patterns, input parameters, format selection guide, sample prompts, post-build iteration commands, and output specifications" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_create_an_asset ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "[CompanyName]" ;
    oc:hasCategory "sales" ;
    oc:impartsKnowledge oc:kn_60ef75ad,
        oc:kn_65a8521c,
        oc:kn_7bc7403c,
        oc:kn_c53c4279,
        oc:kn_ce4e7e36 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:SkillActivated ;
    oc:resolvesIntent "find sample prompts for sales asset generation",
        "identify which asset format to choose",
        "lookup create-an-asset invocation syntax",
        "understand post-build iteration options" ;
    oc:yieldsState oc:ContextGathered .

oc:kn_60ef75ad a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "After asset generation completes" ;
    oc:directiveContent "The output is a self-contained HTML file that works offline and can be hosted on any static hosting platform (Netlify, Vercel, GitHub Pages)." ;
    oc:hasRationale "Understanding the output format helps users plan sharing and deployment strategies" ;
    oc:severityLevel "LOW" .

oc:kn_65a8521c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using this sub-skill as the sole source of information" ;
    oc:directiveContent "The quickref does not contain the full build instructions, research methodology, or visual design specifications — it is a summary reference only." ;
    oc:hasRationale "Attempting to execute the full workflow from the quickref alone will miss critical phases (research, clarifying questions, visual design, quality checklist) documented in SKILL.md" ;
    oc:severityLevel "HIGH" .

oc:kn_7bc7403c a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During post-build iteration phase" ;
    oc:directiveContent "After the asset is built, iterate using natural language commands: change colors, add sections, shorten content, fix details, or request PDF export." ;
    oc:hasRationale "Users can rapidly refine assets without restarting the entire generation process" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c53c4279 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when invoking or preparing context for create-an-asset" ;
    oc:directiveContent "Provide four key inputs for best results: (a) prospect details, (b) audience type and concerns, (c) purpose/goal, (d) desired format." ;
    oc:hasRationale "Complete inputs across all four dimensions yield tailored, professional assets rather than generic templates" ;
    oc:severityLevel "HIGH" .

oc:kn_ce4e7e36 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting an asset format during the create-an-asset workflow" ;
    oc:directiveContent "Match format to use case: interactive landing page for multi-tab experiences, deck-style for meeting presentations, one-pager for leave-behind summaries, workflow demo for system integration visuals." ;
    oc:hasRationale "Choosing the right format ensures the asset serves its intended purpose and resonates with the target audience" ;
    oc:severityLevel "MEDIUM" .

