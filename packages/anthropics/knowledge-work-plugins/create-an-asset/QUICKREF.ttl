oc:kn_193d3994 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every asset creation workflow" ;
    oc:directiveContent "1. Provide context (prospect, audience, purpose, format) → 2. Answer agent questions → 3. Receive generated asset → 4. Iterate via natural language commands" ;
    oc:hasRationale "Structured input yields higher quality assets with fewer revision cycles" ;
    oc:stepOrder 1 .

oc:kn_6cab2a4e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing to create any sales asset" ;
    oc:directiveContent "Four key inputs drive asset quality: (a) Prospect info — company, contacts, deal stage, pain points, transcripts; (b) Audience — Exec/Technical/Ops/Mixed and their priorities; (c) Purpose — Intro/Follow-up/Deep-dive/Alignment/POC/Close; (d) Format — Landing page/Deck/One-pager/Workflow demo" ;
    oc:hasRationale "Rich context produces more targeted and persuasive assets" .

oc:kn_87ce3336 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing asset format" ;
    oc:directiveContent "Use Interactive landing page for impressive multi-tab experience, Deck-style for meeting presentations, One-pager for leave-behind summaries, Workflow demo for system integration visuals" ;
    oc:hasRationale "Matching format to use case maximizes prospect engagement and deal progression" .

oc:kn_be4e4c7a a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "All asset generation outputs" ;
    oc:directiveContent "Self-contained HTML file. Works offline. Host anywhere (Netlify, Vercel, GitHub Pages). Password-protect via hosting provider." ;
    oc:hasRationale "HTML output ensures universal compatibility and offline usability for sales teams" .

