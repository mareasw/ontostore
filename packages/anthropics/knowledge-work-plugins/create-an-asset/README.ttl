@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_create_an_asset_readme a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "readme" ;
    skos:broader "Sales asset generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/create-an-asset" ;
    oc:contentHash "5dabd844c0910ac1fc06e326bfa7a65ac3681e13140098bf9675fe6d67e57cd0" ;
    oc:differentia "Produces tailored, branded, customer-facing HTML deliverables (landing pages, decks, one-pagers, workflow demos) from prospect context through research, content generation, and visual design phases" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_create_an_asset ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasAllowedTool "Edit",
        "Read",
        "WebSearch",
        "Write" ;
    oc:hasArgumentHint "CompanyName or deal context (prospect, audience, purpose, format)" ;
    oc:hasCategory "marketing" ;
    oc:hasRequirement oc:req_145c3403,
        oc:req_5c3efadf,
        oc:req_882ee933,
        oc:req_883dcb03,
        oc:req_b78be7f8 ;
    oc:impartsKnowledge oc:kn_30ef69b8,
        oc:kn_4372f993,
        oc:kn_544a0b6d,
        oc:kn_550b2146,
        oc:kn_70928a83,
        oc:kn_85bd25de,
        oc:kn_9bf08244,
        oc:kn_fed195d2 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady,
        oc:NetworkAvailable ;
    oc:resolvesIntent "build presentation deck",
        "create customer-facing deliverable",
        "create one-pager summary",
        "create sales asset",
        "design workflow demo",
        "generate branded asset for deal",
        "generate landing page for prospect" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_30ef69b8 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "Before delivery, as a final quality gate (Phase 6)" ;
    oc:directiveContent "A successful asset passes the quality checklist: correct prospect spelling, current leadership names, accurate pain point reflection, no placeholders, readable contrast, working interactive elements, appropriate tone for audience, and feels tailored not templated." ;
    oc:hasRationale "Professional quality is critical in sales — errors in company names, outdated leadership, or broken features undermine the seller's credibility" ;
    oc:severityLevel "HIGH" .

oc:kn_4372f993 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "During Phase 0 context detection, after identifying seller company/product" ;
    oc:directiveContent "The skill persists seller context to the knowledge base for future sessions, and will confirm stored context on subsequent invocations." ;
    oc:hasRationale "Saves time on repeated asset creation by not requiring the seller to re-enter their company/product context each time" ;
    oc:severityLevel "LOW" .

oc:kn_544a0b6d a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When brand color extraction fails during research phase" ;
    oc:directiveContent "If brand colors cannot be extracted from the prospect's website, fall back to industry-specific default colors (Technology: blue/purple, Finance: navy/blue, Healthcare: teal, Manufacturing: orange, etc.)." ;
    oc:hasRationale "Ensures a polished look even when brand data is unavailable, while still being thematically appropriate" ;
    oc:severityLevel "LOW" .

oc:kn_550b2146 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "During content generation (Phase 3) for all formats" ;
    oc:directiveContent "All content must use the prospect's language, terminology, and stated priorities — never generic or templated language. Map the seller's product explicitly to the prospect's stated pain points." ;
    oc:hasRationale "Tailored content demonstrates understanding and builds trust; generic content undermines credibility and wastes the research investment" ;
    oc:severityLevel "HIGH" .

oc:kn_70928a83 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "After research (Phase 1) and structure decision (Phase 2), before building" ;
    oc:directiveContent "Before building any asset, always ask clarifying questions (Phase 5) and confirm direction with the user. Maximum 2 rounds of questions — if still ambiguous, make reasonable choices and note them." ;
    oc:hasRationale "Prevents wasted effort on misaligned assets and ensures the deliverable matches the seller's intent and the prospect's context" ;
    oc:severityLevel "CRITICAL" .

oc:kn_85bd25de a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During Phase 1 research when determining how much investigation to perform" ;
    oc:directiveContent "Adapt research depth based on context richness: rich context (transcripts uploaded) needs only gap-filling; moderate context needs company + industry research; sparse context (just company name) needs a full deep research pass." ;
    oc:hasRationale "Prevents over-researching when transcripts already contain needed details, and ensures sufficient context when starting from scratch" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9bf08244 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During visual design (Phase 4) color system selection" ;
    oc:directiveContent "Default to the prospect's brand colors (extracted from their website/brand guidelines) for the initial build. Seller can switch to their own brand or neutral palette after delivery." ;
    oc:hasRationale "Using the prospect's brand colors makes the asset feel custom-built for them, increasing engagement and perceived effort" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fed195d2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During build and delivery (Phase 6)" ;
    oc:directiveContent "All output must be a single self-contained HTML file with all CSS in <style> tags and all JS in <script> tags. No external dependencies except Google Fonts. No placeholder text remaining." ;
    oc:hasRationale "Self-contained HTML ensures easy sharing via email, static hosting, or direct file transfer without dependency issues or broken resources" ;
    oc:severityLevel "HIGH" .

oc:req_145c3403 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "WebSearch" .

oc:req_5c3efadf a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Read" .

oc:req_882ee933 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Sales methodology and deal stages" .

oc:req_883dcb03 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Write" .

oc:req_b78be7f8 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "HTML/CSS/JS for self-contained asset generation" .

