oc:kn_48867461 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling any generated HTML asset" ;
    oc:codeLanguage "css" ;
    oc:directiveContent """/* Color System */
:root {
  --brand-primary: #[from research];
  --brand-secondary: #[from research];
  --bg-primary: #0a0d14;
  --bg-elevated: #0f131c;
  --bg-surface: #161b28;
  --text-primary: #ffffff;
  --text-secondary: rgba(255, 255, 255, 0.7);
  --accent: var(--brand-primary);
  --success: #10b981; --warning: #f59e0b; --error: #ef4444;
}
/* Typography */
font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
/* Cards */
card: bg-surface, border rgba(255,255,255,0.1), radius 12px, hover glow
/* Buttons */
primary: accent bg, white text; secondary: transparent, accent border""" .

oc:kn_6bc74b95 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the final deliverable" ;
    oc:directiveContent "All output must be a single self-contained HTML file with all CSS inline or in <style> tags and all JS inline or in <script> tags. No external dependencies except Google Fonts. File naming: [ProspectName]-[format]-[date].html" ;
    oc:hasRationale "Self-contained files enable easy sharing via email, static hosting, or direct delivery without build steps or server requirements" ;
    oc:severityLevel "CRITICAL" .

oc:kn_76e4d6bb a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before final delivery in Phase 6" ;
    oc:directiveContent "Before delivering, verify: correct spelling of prospect company name, current leadership names, accurate pain point reflection, no placeholder text remaining, all interactive elements functional, proper contrast/readability, and clear CTA." ;
    oc:hasRationale "Errors in customer-facing materials damage credibility; a quality checklist prevents embarrassing mistakes in front of prospects" ;
    oc:severityLevel "HIGH" .

oc:kn_8112fedc a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During Phase 4 visual design" ;
    oc:directiveContent "Use a dark theme with prospect brand colors as accents. Extract colors from prospect website/brand guidelines; fallback to industry-specific defaults if unavailable. Default to prospect branding, allow switch to seller branding on iteration." ;
    oc:hasRationale "Dark theme with prospect branding creates a premium feel and shows attention to detail; using prospect colors builds rapport" .

oc:kn_84d38aae a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before skill execution" ;
    oc:directiveContent "Requires ability to write HTML files to disk and perform web searches for prospect research (company info, leadership, brand colors, industry context)" .

oc:kn_88d65d02 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any content section across all formats" ;
    oc:directiveContent "All content must use the prospect's language and terminology, reference specific pain points from input or transcripts, and map the seller's product to the prospect's needs explicitly. Content should feel tailored, not templated." ;
    oc:hasRationale "Tailored content builds trust and demonstrates understanding; generic content undermines credibility with enterprise buyers" ;
    oc:severityLevel "HIGH" .

oc:kn_8d78eccf a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building workflow/architecture demo format" ;
    oc:codeLanguage "yaml" ;
    oc:directiveContent """component:
  id: "snowflake"
  label: "Snowflake Data Warehouse"
  type: "database"  # database | api | ai | middleware | human | document | output
  icon: "database"
  description: "Financial performance data"
  brand_color: "#29B5E8"

step:
  number: 1
  from: "human"
  to: "claude"
  action: "Initiates performance review"
  description: "Sarah, a Brand Analyst at [Prospect], kicks off the quarterly review..."
  data_example: "Review request: Nike brand, Q4 2025"
  value_note: "No manual data gathering required\"""" .

oc:kn_b385304f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Phase 1 research" ;
    oc:directiveContent "Adapt research depth to context richness: light research when transcripts and detailed context are provided, medium for partial context, and deep full research when only a company name is given. Always research prospect basics, leadership, and brand colors." ;
    oc:hasRationale "Avoids redundant research when context is already rich, while ensuring sufficient depth when starting from scratch" .

oc:kn_be8b8243 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Detect seller context from email domain and store. 2. Collect prospect context (company, contacts, deal stage, pain points). 3. Collect audience context (type, roles, primary concern). 4. Collect purpose context (goal, desired action). 5. Select format (landing page, deck, one-pager, workflow demo). 6. Gather format-specific inputs. 7. Research prospect (adaptive depth). 8. Determine structure. 9. Ask clarifying questions (max 2 rounds). 10. Build self-contained HTML asset. 11. Deliver with deployment options. 12. Support iteration." ;
    oc:stepOrder 1 .

oc:kn_c714ec37 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """## ✓ Asset Created: {ProspectName}

[View your asset](file:///path/to/file.html)

---
**Summary**
- **Format**: {format}
- **Audience**: {audience}
- **Purpose**: {goal} → {desired_action}
- **Sections/Steps**: {count} — {list}

---
**Deployment Options**: Static hosting / Password protection / Direct share / Embed
**Customization**: Colors, sections, messaging, flow, interactive elements, PDF export""" ;
    oc:templateVariables "ProspectName",
        "audience",
        "count",
        "desired_action",
        "format",
        "goal",
        "list" .

oc:kn_cf1db1ea a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before building any asset" ;
    oc:directiveContent "Never skip the clarifying questions phase (Phase 5). Always summarize understanding and ask 2-4 targeted questions before building. Maximum 2 rounds of questions — if still ambiguous, make a reasonable choice and note it." ;
    oc:hasRationale "Skipping clarification leads to misaligned assets and wasted rebuild cycles; capping at 2 rounds prevents analysis paralysis" ;
    oc:severityLevel "HIGH" .

oc:kn_d04da545 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When delivering the completed asset" ;
    oc:directiveContent """## Asset Delivery Message
- Summary with format, audience, purpose, sections
- Deployment options: static hosting (Netlify/Vercel/GitHub Pages), password protection, direct HTML share, iframe embed
- Customization invitation: colors, sections, messaging, flow, interactive elements, PDF export""" .

