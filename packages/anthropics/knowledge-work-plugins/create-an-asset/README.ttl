                            oc:blockType "code_block" ;
                            oc:codeContent """1. You provide context (prospect, audience, purpose)
          ↓
2. Skill researches the prospect company
          ↓
3. Skill asks 3-4 clarifying questions
          ↓
4. You confirm direction
          ↓
5. Skill builds the asset
          ↓
6. You iterate as needed
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 90-102" ] ;
                    oc:sectionLevel 2 ;
