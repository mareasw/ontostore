    oc:resolvesIntent "decompose search queries across multiple sources",
        "handle ambiguous search queries",
        "orchestrate parallel multi-source search",
        "rank and deduplicate search results",
        "translate queries into source-specific syntax" ;
    oc:yieldsState oc:QueryDecomposed,
        oc:SearchResultsRanked .

oc:kn_035bd708 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a source fails or returns no results" ;
    oc:directiveContent "For unavailable sources: skip and note the gap. For no results: broaden query. For all sources empty: suggest query modifications. For rate limits: return available results and suggest retry." ;
    oc:hasRationale "Graceful degradation ensures partial results are still useful rather than failing entirely" .

oc:kn_08fa88ca a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When executing multi-source searches" ;
    oc:directiveContent "Always execute searches across sources in parallel, never sequentially. Total search time should equal the slowest single source, not the sum of all sources." ;
    oc:hasRationale "Parallel execution minimizes latency and provides faster results to the user" ;
    oc:severityLevel "HIGH" .

oc:kn_16d92b1a a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """For each source: [source_name]: [query_string] ([search_type]) + [filters]
Synthesized answer combining ranked, deduplicated results across all sources.""" ;
    oc:templateVariables "filters",
        "query_string",
        "search_type",
        "source_name" .

oc:kn_19c46391 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When initial queries return too few results" ;
    oc:directiveContent "When broadening queries, remove constraints in order: 1) date filters, 2) source/location filters, 3) less important keywords, 4) keep only core entity/topic terms." ;
    oc:hasRationale "Systematic constraint removal maximizes the chance of finding relevant results while preserving core intent" .

oc:kn_23196e63 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing search mode per source" ;
    oc:directiveContent "Prefer semantic search for conceptual/exploratory queries where exact keywords are unknown. Prefer keyword search for known terms, project names, acronyms, and filter-heavy queries." ;
    oc:hasRationale "Matching search mode to query type yields more relevant results" .

oc:kn_3bad0246 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering ambiguous queries" ;
    oc:directiveContent "Only ask for clarification when there are genuinely distinct interpretations producing very different results. Do NOT ask when the query is clear enough or minor ambiguity can be resolved by returning results from multiple interpretations." ;
    oc:hasRationale "Excessive clarification requests degrade user experience; prefer returning broad results over interrupting" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3dd22d27 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When ranking search results" ;
    oc:directiveContent "Score results using weighted factors: keyword match, freshness, authority, completeness. Weight authority highest for factual queries (0.4), freshness highest for status queries (0.4), keyword match highest for document queries (0.4)." ;
    oc:hasRationale "Query-type-aware weighting surfaces the most relevant results for each information need" .

oc:kn_41965d3c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating sub-queries per source" ;
    oc:directiveContent "Generate multiple query variants when a topic might be referred to differently (e.g., 'Kubernetes' → 'Kubernetes', 'k8s', 'cluster', 'container orchestration')." ;
    oc:hasRationale "Synonyms and abbreviations cause relevant results to be missed if only one variant is searched" .

oc:kn_a5fbcb46 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When processing any natural language search query" ;
    oc:directiveContent "1. Classify query type (Decision/Status/Document/Person/Factual/Temporal/Exploratory) 2. Extract keywords, entities, intent signals, constraints, negations 3. Generate sub-queries per source using semantic or keyword search 4. Execute all source searches in parallel 5. Merge, rank, deduplicate results 6. Synthesize into coherent answer" ;
    oc:stepOrder 1 .

