@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_status_report a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "status-report" ;
    skos:broader "Report generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/status-report" ;
    oc:contentHash "8f5a029303d9977d35e1c38f18165b1f3c94b604fd7319fdac3fbc818804d2c0" ;
    oc:differentia "Produces structured status reports with KPIs, risks, and action items for leadership stakeholders" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "Read",
        "Write" ;
    oc:hasArgumentHint "[weekly | monthly | quarterly] [project or team]" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Generate a status report with KPIs, risks, and action items. Use when writing a weekly or monthly update for leadership, summarizing project health with green/yellow/red status, surfacing risks and decisions that need stakeholder attention, or turning a pile of project tracker activity into a readable narrative." ;
    oc:hasName "status-report" ;
    oc:impartsKnowledge oc:kn_0366b6e9,
        oc:kn_05c39d8d,
        oc:kn_3495c7d7,
        oc:kn_3806be47,
        oc:kn_5c866d78 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create weekly update for leadership",
        "generate status report",
        "summarize project health with traffic light status",
        "surface risks and decisions needing stakeholder attention",
        "turn project tracker activity into readable narrative" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0366b6e9 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When connectors (project tracker, chat, calendar) are available" ;
    oc:directiveContent "Use connected data sources (project tracker, chat, calendar) to auto-populate report sections — pull completed items from trackers, scan chat for blockers, and reference calendar for key decisions." ;
    oc:hasRationale "Leveraging connected data sources reduces manual effort, improves accuracy, and ensures no important activity is missed in the report." ;
    oc:severityLevel "MEDIUM" .

oc:kn_05c39d8d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When populating the Risks and Issues section of a status report" ;
    oc:directiveContent "Be honest about risks — surface issues early and transparently. Surprises erode stakeholder trust." ;
    oc:hasRationale "Early risk surfacing builds trust and enables proactive mitigation; hiding problems until they escalate damages credibility and project outcomes." ;
    oc:severityLevel "HIGH" .

oc:kn_3495c7d7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating the Decisions Needed section of a status report" ;
    oc:directiveContent "For each decision needed, provide full context and a recommended action to make it easy for stakeholders to act." ;
    oc:hasRationale "Leaders make faster, better decisions when presented with context and a clear recommendation rather than open-ended questions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3806be47 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When validating a completed status report before delivery" ;
    oc:directiveContent "A well-structured status report uses traffic-light indicators (🟢/🟡/🔴) for overall status and each metric, includes quantified KPIs with targets vs actuals and trends, and surfaces actionable decisions with deadlines." ;
    oc:hasRationale "Consistent traffic-light status signaling enables rapid stakeholder comprehension, while quantified metrics provide objective grounding." ;
    oc:severityLevel "LOW" .

oc:kn_5c866d78 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the executive summary section of any status report" ;
    oc:directiveContent "Lead with the headline — busy leaders read the first 3 lines. The executive summary must convey what's on track, what needs attention, and key wins." ;
    oc:hasRationale "Stakeholders often only read the top of the report; the first 3 lines must communicate the most critical information to drive decisions." ;
    oc:severityLevel "HIGH" .

