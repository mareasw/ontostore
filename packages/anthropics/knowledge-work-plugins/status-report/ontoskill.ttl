@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_knowledge_work_plugins_status_report a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "status-report" ;
    skos:broader "Report generator" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/status-report" ;
    oc:contentHash "8f5a029303d9977d35e1c38f18165b1f3c94b604fd7319fdac3fbc818804d2c0" ;
    oc:dependsOnSkill oc:skill_ontoskills_risk_assessment ;
    oc:differentia "produces leadership status updates with KPIs, risks, and decision items using green/yellow/red health indicators" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "[weekly | monthly | quarterly] [project or team]" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Generate a status report with KPIs, risks, and action items. Use when writing a weekly or monthly update for leadership, summarizing project health with green/yellow/red status, surfacing risks and decisions that need stakeholder attention, or turning a pile of project tracker activity into a readable narrative." ;
    oc:hasName "status-report" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: status-report
description: Generate a status report with KPIs, risks, and action items. Use when writing a weekly or monthly update for leadership, summarizing project health with green/yellow/red status, surfacing risks and decisions that need stakeholder attention, or turning a pile of project tracker activity into a readable narrative.
argument-hint: "[weekly | monthly | quarterly] [project or team]"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Generate a polished status report for leadership or stakeholders. See the **risk-assessment** skill for risk matrix frameworks and severity definitions." ],
                [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent _:ref_3378a1f8bfcecb89 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Tips" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """## Status Report: [Project/Team] — [Period]
**Author:** [Name] | **Date:** [Date]

### Executive Summary
[3-4 sentence overview — what's on track, what needs attention, key wins]

### Overall Status: 🟢 On Track / 🟡 At Risk / 🔴 Off Track

### Key Metrics
| Metric | Target | Actual | Trend | Status |
|--------|--------|--------|-------|--------|
| [KPI] | [Target] | [Actual] | [up/down/flat] | 🟢/🟡/🔴 |

### Accomplishments This Period
- [Win 1]
- [Win 2]

### In Progress
| Item | Owner | Status | ETA | Notes |
|------|-------|--------|-----|-------|
| [Item] | [Person] | [Status] | [Date] | [Context] |

### Risks and Issues
| Risk/Issue | Impact | Mitigation | Owner |
|------------|--------|------------|-------|
| [Risk] | [Impact] | [What we're doing] | [Who] |

### Decisions Needed
| Decision | Context | Deadline | Recommended Action |
|----------|---------|----------|--------------------|
| [Decision] | [Why it matters] | [When] | [What I recommend] |

### Next Period Priorities
1. [Priority 1]
2. [Priority 2]
3. [Priority 3]
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 21-58" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/status-report $ARGUMENTS
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 15-17" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Usage" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "If **~~project tracker** is connected:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "If **~~chat** is connected:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "If **~~calendar** is connected:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Scan recent team discussions for decisions and blockers to include" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Offer to post the finished report to a channel" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 6 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Reference key meetings and decisions from the reporting period" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Pull project status, completed items, and upcoming milestones automatically" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Identify at-risk items and overdue tasks" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "If Connectors Available" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "/status-report" ] ;
    oc:hasWorkflow _:ref_3378a1f8bfcecb89,
        [ a oc:Workflow ;
            dcterms:description "Produce a polished status report from project data, connector sources, and stakeholder needs" ;
            oc:hasStep _:ref_883adc336ae84459,
                _:ref_a6c6475b72e94da1,
                [ a oc:WorkflowStep ;
                    dcterms:description "Fill in the report template: executive summary, key metrics, accomplishments, in-progress items, risks, decisions needed, and next priorities" ;
                    oc:expectedOutcome "Complete status report document ready for stakeholder review" ;
                    oc:stepDependsOn _:ref_a6c6475b72e94da1 ;
                    oc:stepId "compile-report" ] ;
            oc:workflowId "status-report-generation" ;
            oc:workflowName "Generate Status Report" ] ;
    oc:impartsKnowledge oc:kn_0dc6bfea,
        oc:kn_508cd1f6,
        oc:kn_52f3ecd9,
        oc:kn_7af9e1b0,
        oc:kn_80babfc0 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create monthly status report with KPIs",
        "generate status report",
        "summarize project health",
        "surface risks and decisions for stakeholders",
        "write weekly update for leadership" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0dc6bfea a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning status to KPIs or overall project health" ;
    oc:directiveContent "Use only 🟢 On Track / 🟡 At Risk / 🔴 Off Track as status indicators for overall health and individual metrics." ;
    oc:hasRationale "Standardized traffic-light indicators enable quick scanning and consistency across reports" .

oc:kn_508cd1f6 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When populating the Decisions Needed table" ;
    oc:directiveContent "For each decision needed, provide context and a recommended action. Never list a decision without a recommendation." ;
    oc:hasRationale "Leaders want actionable recommendations, not open questions" .

oc:kn_52f3ecd9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the executive summary section" ;
    oc:directiveContent "Lead with the headline — the first 3 lines are what busy leaders read. Make them count with a clear executive summary." ;
    oc:hasRationale "Leaders scan reports quickly; the opening determines whether they read further" .

oc:kn_7af9e1b0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling out the Risks and Issues section" ;
    oc:directiveContent "Be honest about risks — surface issues early to build trust. Surprises erode stakeholder confidence." ;
    oc:hasRationale "Early risk disclosure enables proactive mitigation and maintains credibility" .

oc:kn_80babfc0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When connectors (project tracker, chat, calendar) are connected" ;
    oc:directiveContent "Use connector data when available: pull from project tracker for status and milestones, chat for blockers and decisions, calendar for key meetings." ;
    oc:hasRationale "Connector-enriched reports are more accurate and require less manual input" .

_:ref_0d73adf43f2cbdb9 a oc:WorkflowStep ;
    dcterms:description "**Make decisions easy** — For each decision needed, provide context and a recommendation." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_baf211283b2e34a8 a oc:WorkflowStep ;
    dcterms:description "**Be honest about risks** — Surfacing issues early builds trust. Surprises erode it." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_f293075cbb2d207c a oc:WorkflowStep ;
    dcterms:description "**Lead with the headline** — Busy leaders read the first 3 lines. Make them count." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_3378a1f8bfcecb89 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_0d73adf43f2cbdb9,
        _:ref_baf211283b2e34a8,
        _:ref_f293075cbb2d207c ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_883adc336ae84459 a oc:WorkflowStep ;
    dcterms:description "Pull data from connected sources: project tracker (status, milestones), chat (blockers, decisions), calendar (key meetings)" ;
    oc:expectedOutcome "Raw project activity and contextual data collected" ;
    oc:stepId "gather-data" .

_:ref_a6c6475b72e94da1 a oc:WorkflowStep ;
    dcterms:description "Evaluate overall project health as 🟢/🟡/🔴 and assign status to each KPI with targets, actuals, and trends" ;
    oc:expectedOutcome "Health assessment with traffic-light indicators completed" ;
    oc:stepDependsOn _:ref_883adc336ae84459 ;
    oc:stepId "assess-health" .

