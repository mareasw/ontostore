    dcterms:description "**Source documents:** Reference to the underlying transactions or events (PO numbers, invoice numbers, contract references, payroll register)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_0f5f43d4ff729068 a oc:WorkflowStep ;
    dcterms:description "**Wrong sign:** Debit entered as credit or vice versa" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_10ac4799172f39e4 a oc:WorkflowStep ;
    dcterms:description "**Stale accruals:** Recurring accruals not updated for changed circumstances" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_7" ;
    oc:stepOrder 7 .

_:ref_25fdad1259c6be5b a oc:WorkflowStep ;
    dcterms:description "**Duplicate entries:** Same transaction recorded twice (check for duplicates before posting)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_3706cbb45634334d a oc:WorkflowStep ;
    dcterms:description "**Entry description/memo:** Clear, specific description of what the entry records and why" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_3e39b532f69fdd04 a oc:WorkflowStep ;
    dcterms:description "**Wrong account:** Entry posted to incorrect GL account (especially similar account codes)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_4cbad238daca3dfc a oc:WorkflowStep ;
    dcterms:description "**Incorrect FX rates:** Foreign currency entries using wrong exchange rate or date" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_9" ;
    oc:stepOrder 9 .

_:ref_828d1c953a01288d a oc:WorkflowStep ;
    dcterms:description "**Missing intercompany elimination:** Entries between entities without corresponding elimination" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_10" ;
    oc:stepOrder 10 .

_:ref_9cee130b77bfa5de a oc:WorkflowStep ;
    dcterms:description "**Capitalization errors:** Expenses that should be capitalized, or capitalized items that should be expensed" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_11" ;
    oc:stepOrder 11 .

_:ref_9d2b4fe1959d50bb a oc:WorkflowStep ;
    dcterms:description "**Wrong period:** Entry posted to an incorrect or already-closed period" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_bb274d81881a7004 a oc:WorkflowStep ;
    dcterms:description "**Period:** The accounting period the entry applies to" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_bfce27ca04ebbe73 a oc:WorkflowStep ;
