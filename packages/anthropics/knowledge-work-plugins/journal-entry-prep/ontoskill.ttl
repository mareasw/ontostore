@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_journal_entry_prep a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "journal-entry-prep" ;
    skos:broader "Accounting workflow guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/journal-entry-prep" ;
    oc:contentHash "f2d436c4ea00d05583fe9902223644f682ec5bbcfe64384ae2571bb3b2779633" ;
    oc:dependsOnSkill oc:skill_close_management ;
    oc:differentia "that codifies journal entry preparation standards including accrual types, debit/credit conventions, documentation requirements, and review/approval workflows for month-end close" ;
    oc:handlesFailure oc:InvalidPeriod,
        oc:MissingApproval,
        oc:UnbalancedEntry ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Prepare journal entries with proper debits, credits, and supporting documentation for month-end close. Use when booking accruals, prepaid amortization, fixed asset depreciation, payroll entries, revenue recognition, or any manual journal entry." ;
    oc:hasName "journal-entry-prep" ;
    oc:impartsKnowledge oc:kn_0fda3f99,
        oc:kn_1deeddb7,
        oc:kn_35d59752,
        oc:kn_4d8a8ae2,
        oc:kn_aa58d2fe,
        oc:kn_cac0fb8f,
        oc:kn_cb5cbb9f,
        oc:kn_d5bfbb4f ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:DataAvailable,
        oc:PeriodEnded ;
    oc:resolvesIntent "book accruals with proper debits and credits",
        "document journal entry supporting calculations",
        "identify common journal entry errors",
        "prepare journal entries for month-end close",
        "review journal entries before approval" ;
    oc:yieldsState oc:DocumentationComplete,
        oc:JournalEntryPrepared .

oc:kn_0fda3f99 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing revenue recognition journal entries" ;
    oc:directiveContent "For revenue recognition entries, follow the ASC 606 five-step framework: identify the contract, identify performance obligations, determine transaction price, allocate price to obligations, and recognize revenue as obligations are satisfied." ;
    oc:hasRationale "ASC 606 is the governing standard for revenue recognition and non-compliance creates material audit and regulatory risk." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1deeddb7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When calculating accrual amounts for AP, payroll, bonuses, or other recurring estimates" ;
    oc:directiveContent "Use consistent estimation methodology period over period for accruals, and track actual vs accrual to refine future estimates." ;
    oc:hasRationale "Consistency ensures comparability across periods and reduces audit scrutiny; tracking variance improves accuracy over time." ;
    oc:severityLevel "MEDIUM" .

oc:kn_35d59752 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining who must approve a journal entry before posting" ;
    oc:directiveContent "Follow the approval matrix: standard recurring entries require accounting manager approval; non-recurring entries above $50K require Controller approval; above $250K require CFO/VP Finance approval; top-side and out-of-period adjustments always require Controller or above." ;
    oc:hasRationale "Tiered approval ensures appropriate oversight proportional to the financial impact and risk of the entry." ;
    oc:severityLevel "HIGH" .

oc:kn_4d8a8ae2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing or reviewing any manual journal entry" ;
    oc:directiveContent "Avoid round-number estimates that do not reflect actual calculations, and always verify entries are not duplicates of existing posted entries." ;
    oc:hasRationale "Round numbers signal estimation without proper support; duplicates overstate balances and are a common audit finding." ;
    oc:severityLevel "HIGH" .

oc:kn_aa58d2fe a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Always, as the final step before submitting a journal entry for approval" ;
    oc:directiveContent "Before posting, verify: debits equal credits, correct accounting period (not closed), account codes exist and are appropriate, amounts are mathematically supported, auto-reversal is set for accruals, no duplicates exist, and department/cost center coding is correct." ;
    oc:hasRationale "Systematic pre-posting verification catches the 12 most common journal entry errors before they reach the ledger." ;
    oc:severityLevel "CRITICAL" .

oc:kn_cac0fb8f a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "Whenever assisting with journal entry preparation" ;
    oc:directiveContent "This skill provides accounting guidance but does not provide financial advice — all entries must be reviewed by qualified financial professionals before posting." ;
    oc:hasRationale "AI-generated journal entries require human professional review to ensure accuracy, compliance, and appropriate authorization." ;
    oc:severityLevel "HIGH" .

oc:kn_cb5cbb9f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When booking accrual entries (AP accruals, payroll accruals, etc.)" ;
    oc:directiveContent "Never post accruals without setting auto-reversal — missing reversals cause double-counting in subsequent periods." ;
    oc:hasRationale "Accrual entries that are not reversed will overstate expenses or liabilities in the following period." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d5bfbb4f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing any journal entry" ;
    oc:directiveContent "Every journal entry must include: description/memo, calculation support, source documents, accounting period, preparer identification, approval evidence, and reversal indicator." ;
    oc:hasRationale "Incomplete documentation fails audit requirements and makes entries unverifiable by reviewers or auditors." ;
    oc:severityLevel "CRITICAL" .

