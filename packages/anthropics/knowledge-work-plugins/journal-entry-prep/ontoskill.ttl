oc:kn_1b149a2d a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When validating a journal entry before submission for approval" ;
    oc:directiveContent "A properly prepared journal entry has: balanced debits/credits, correct period, appropriate account codes, documented calculation support, clear description, correct cost center coding, and complete supporting documentation." ;
    oc:hasRationale "These are the 12-point review checklist items that must all pass for an entry to be considered complete and audit-ready." .

oc:kn_2593fdae a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating recurring accruals (AP, payroll, prepaid amortization)" ;
    oc:directiveContent "Use consistent estimation methodology period over period for recurring accruals, and track actual vs accrual to refine future estimates." ;
    oc:hasRationale "Consistency enables trend analysis and reduces period-over-period variance that would require explanation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_302ada7d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing any journal entry" ;
    oc:directiveContent "All journal entries must balance: total debits must equal total credits before posting." ;
    oc:hasRationale "Double-entry accounting requires balanced entries; unbalanced entries violate fundamental accounting principles." ;
    oc:severityLevel "CRITICAL" .

oc:kn_30d83238 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating accrual amounts" ;
    oc:directiveContent "Avoid round-number estimates without documented calculation support; suspiciously round amounts indicate insufficient estimation rigor." ;
    oc:hasRationale "Auditors flag round-number estimates as high-risk indicators of management bias or lazy estimation." ;
    oc:severityLevel "HIGH" .

oc:kn_3c6a6f3d a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When reviewing journal entries before posting" ;
    oc:directiveContent "Common journal entry errors include wrong period posting, wrong sign (debit/credit swap), duplicate entries, stale accruals, incorrect FX rates, missing intercompany eliminations, and cut-off errors." ;
    oc:hasRationale "These are the most frequent errors found during close processes and audit reviews; checking for them proactively prevents rework." ;
    oc:severityLevel "HIGH" .

oc:kn_6648f528 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When recognizing revenue from customer contracts" ;
    oc:directiveContent "Follow ASC 606 five-step framework for revenue recognition: identify contracts, identify performance obligations, determine transaction price, allocate price to obligations, recognize revenue as obligations are satisfied." ;
    oc:hasRationale "ASC 606 is the governing standard; non-compliance creates material misstatement risk and audit deficiency findings." ;
    oc:severityLevel "CRITICAL" .

oc:kn_68a0af6d a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before finalizing any journal entry" ;
    oc:directiveContent "All journal entries should be reviewed by qualified financial professionals before posting to the general ledger." ;
    oc:hasRationale "This skill does not provide financial advice; professional review ensures compliance with accounting standards and internal controls." ;
    oc:severityLevel "CRITICAL" .

oc:kn_caac166d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing accrual journal entries" ;
    oc:directiveContent "Never post accrual entries without setting auto-reversal; missing reversals cause double-counting in the following period." ;
    oc:hasRationale "Double-counting overstated expenses or liabilities is a common audit finding that can materially misstate financials." ;
    oc:severityLevel "CRITICAL" .

