                    oc:expectedOutcome "Entry routed to appropriate approver (accounting manager, controller, or CFO)" ;
                    oc:stepId "submit-approval" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Attach supporting documentation: description/memo, calculation support, source documents, reversal indicator, and preparer identification" ;
                    oc:expectedOutcome "Complete documentation package attached to the entry" ;
                    oc:stepId "document-support" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Construct the journal entry with correct debit/credit pairs, account codes, cost centers, and period" ;
                    oc:expectedOutcome "Balanced entry with proper account coding and period assignment" ;
                    oc:stepId "construct-entry" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Calculate entry amounts from source data (POs, contracts, schedules, fixed asset register, payroll data)" ;
                    oc:expectedOutcome "Mathematically accurate amounts with documented calculation support" ;
                    oc:stepId "calculate-amounts" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Identify the journal entry type (AP accrual, depreciation, prepaid amortization, payroll accrual, revenue recognition, or other manual entry)" ;
                    oc:expectedOutcome "Entry type classified and appropriate debit/credit structure determined" ;
                    oc:stepId "identify-entry-type" ] ;
            oc:workflowId "journal-entry-prep-workflow" ;
            oc:workflowName "Journal Entry Preparation" ] ;
