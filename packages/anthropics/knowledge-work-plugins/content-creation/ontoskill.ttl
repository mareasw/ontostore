oc:skill_anthropics_knowledge_work_plugins_content_creation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "content-creation" ;
    skos:broader "Marketing content creation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/content-creation" ;
    oc:contentHash "185b383e7cd3514d75a5bbb3e371e55105a15392fcadeddd66c611532a39af19" ;
    oc:differentia "provides channel-specific templates, SEO guidelines, headline/hook formulas, and CTA best practices for blog posts, social media, email newsletters, landing pages, press releases, and case studies" ;
    oc:hasArgumentHint "content type (blog, social media, email, landing page, press release, case study) and topic" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Draft marketing content across channels — blog posts, social media, email newsletters, landing pages, press releases, and case studies. Use when writing any marketing content, when you need channel-specific formatting, SEO-optimized copy, headline options, or calls to action." ;
    oc:hasName "content-creation" ;
    oc:impartsKnowledge oc:kn_02e714e1,
        oc:kn_058789f3,
        oc:kn_22506c55,
        oc:kn_3fb8c7f1,
        oc:kn_889b64b8,
        oc:kn_8a45673a,
        oc:kn_958c369e ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "create blog posts with SEO optimization",
        "create case studies",
        "create landing page copy",
        "draft social media posts for multiple platforms",
        "generate headline options",
        "optimize content for SEO",
        "write calls to action",
        "write email newsletters with effective CTAs",
        "write press releases" .

oc:kn_02e714e1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any marketing content" ;
    oc:directiveContent "Never keyword-stuff content. Write for humans first, using keywords only where they fit naturally." ;
    oc:hasRationale "Keyword stuffing penalizes search rankings and degrades reader experience" ;
    oc:severityLevel "HIGH" .

oc:kn_058789f3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating any SEO-targeted content" ;
    oc:directiveContent "Always include one primary keyword in the headline, first paragraph, one subheading, meta description, and URL slug. Use 2-3 secondary keywords naturally in body copy." ;
    oc:hasRationale "Proper keyword placement signals relevance to search engines without compromising readability" ;
    oc:severityLevel "HIGH" .

oc:kn_22506c55 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing web copy, landing pages, and product pages" ;
    oc:directiveContent "Lead with benefits, not features. Every section should answer 'so what?' from the reader's perspective. Use 'you' language to speak directly to the reader." ;
    oc:hasRationale "Readers self-select based on outcomes, not capabilities — benefits create emotional connection that drives action" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3fb8c7f1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing blog posts and long-form content" ;
    oc:directiveContent "Use the 8th-grade reading level for broad audiences (adjust up for technical). Use short paragraphs (2-4 sentences), subheadings every 200-300 words, and front-load key information." ;
    oc:hasRationale "Accessible writing maximizes reach; scannable formatting respects reader attention patterns online" ;
    oc:severityLevel "MEDIUM" .

oc:kn_889b64b8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing landing pages, emails, or any conversion-focused content" ;
    oc:directiveContent "Limit to one primary CTA per page or email — multiple competing CTAs reduce conversions." ;
    oc:hasRationale "The paradox of choice: too many options cause decision paralysis and lower conversion rates" ;
    oc:severityLevel "HIGH" .

oc:kn_8a45673a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When creating social media content" ;
    oc:directiveContent "Adapt tone, length, and structure per platform: LinkedIn favors professional storytelling (1,300 char sweet spot), Twitter/X demands punchy conciseness, Instagram is visual-first with storytelling hooks, Facebook works best with conversational tone and questions." ;
    oc:hasRationale "Each platform has distinct algorithmic preferences and audience expectations that determine content performance" ;
    oc:severityLevel "MEDIUM" .

oc:kn_958c369e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before publishing any web content" ;
    oc:directiveContent "Before publishing any content, verify: title tag under 60 characters, meta description under 160 characters, URL slug includes primary keyword, one H1 per page, image alt text present, 2-3 internal links and 1-2 external links." ;
    oc:hasRationale "On-page SEO checklist ensures content is discoverable and meets search engine quality signals" ;
    oc:severityLevel "MEDIUM" .

