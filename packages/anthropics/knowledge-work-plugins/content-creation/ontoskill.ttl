                                            oc:itemOrder 5 ;
                                            oc:itemText "One primary CTA per page or email — too many choices reduce conversions" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Be specific about what happens next: \"Start your free trial\" is better than \"Submit\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
