@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_research_synthesis a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "research-synthesis" ;
    skos:broader "Analysis framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/research-synthesis" ;
    oc:contentHash "799a53d5407d4eb1fa4e2ea7a0e13ad4e393adb4db858f94016155cbc1f2071d" ;
    oc:differentia "that distills raw user research data into structured themes, insights, user segments, and prioritized recommendations" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<research data, transcripts, or survey results>" ;
    oc:hasCategory "research" ;
    oc:hasDescription "Synthesize user research into themes, insights, and recommendations. Use when you have interview transcripts, survey results, usability test notes, support tickets, or NPS responses that need to be distilled into patterns, user segments, and prioritized next steps." ;
    oc:hasName "research-synthesis" ;
    oc:impartsKnowledge oc:kn_029be5cd,
        oc:kn_64b6e48a,
        oc:kn_68cafeb2,
        oc:kn_850672b3,
        oc:kn_b935bfb3 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:FileExists ;
    oc:resolvesIntent "analyze interview transcripts",
        "distill usability test findings",
        "extract themes from survey results",
        "generate research recommendations",
        "identify user segments from research data",
        "synthesize user research" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_029be5cd a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When product analytics connector is available" ;
    oc:directiveContent "Cross-reference qualitative themes with quantitative product analytics data when available to validate findings and quantify the impact of identified pain points." ;
    oc:hasRationale "Triangulating qualitative insights with behavioral metrics strengthens conclusions and helps estimate the business impact of issues." ;
    oc:severityLevel "MEDIUM" .

oc:kn_64b6e48a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing any user research data" ;
    oc:directiveContent "Always include direct participant quotes to make insights credible and memorable. Raw evidence grounds recommendations in real user voices." ;
    oc:hasRationale "Quotes serve as primary evidence that stakeholders can connect with, increasing the persuasiveness of findings and preventing interpretation drift." ;
    oc:severityLevel "HIGH" .

oc:kn_68cafeb2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting themes and insights in the synthesis output" ;
    oc:directiveContent "Separate observations from interpretations. '5 of 8 users clicked the wrong button' is an observation; 'the button placement is confusing' is an interpretation." ;
    oc:hasRationale "Conflating observations with interpretations introduces bias and reduces the credibility of research findings with stakeholders." ;
    oc:severityLevel "HIGH" .

oc:kn_850672b3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When describing prevalence of themes or patterns in the output" ;
    oc:directiveContent "Quantify findings wherever possible. Replace 'most users' with '7 of 10 users' to provide specific, defensible evidence." ;
    oc:hasRationale "Vague quantification undermines the rigor of qualitative research and makes it harder to prioritize actions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b935bfb3 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When completing the synthesis report" ;
    oc:directiveContent "Document methodology notes including limitations and potential biases in the synthesis output to maintain research transparency." ;
    oc:hasRationale "Every research method has biases; transparency about limitations prevents overgeneralization and helps stakeholders weigh findings appropriately." ;
    oc:severityLevel "MEDIUM" .

