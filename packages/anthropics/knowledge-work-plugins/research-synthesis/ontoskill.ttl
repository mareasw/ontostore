oc:skill_knowledge_work_plugins_research_synthesis a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "research-synthesis" ;
    skos:broader "Synthesis framework" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/research-synthesis" ;
    oc:contentHash "799a53d5407d4eb1fa4e2ea7a0e13ad4e393adb4db858f94016155cbc1f2071d" ;
    oc:differentia "that distills raw user research data into structured themes, insights, user segments, and prioritized recommendations" ;
    oc:extends oc:skill_ontoskills_user_research ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput ;
    oc:hasArgumentHint "<research data, transcripts, or survey results>" ;
    oc:hasCategory "research" ;
    oc:hasDescription "Synthesize user research into themes, insights, and recommendations. Use when you have interview transcripts, survey results, usability test notes, support tickets, or NPS responses that need to be distilled into patterns, user segments, and prioritized next steps." ;
    oc:hasName "research-synthesis" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: research-synthesis
description: Synthesize user research into themes, insights, and recommendations. Use when you have interview transcripts, survey results, usability test notes, support tickets, or NPS responses that need to be distilled into patterns, user segments, and prioritized next steps.
argument-hint: "<research data, transcripts, or survey results>"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Synthesize user research data into actionable insights. See the **user-research** skill for research methods, interview guides, and analysis frameworks." ],
                [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Support tickets or feedback" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Usability test recordings or notes" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Interview transcripts or notes" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "NPS/CSAT responses" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "App store reviews" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Survey results (CSV, pasted data)" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "What I Accept" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_8986b57d89f9d68a ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Tips" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/research-synthesis $ARGUMENTS
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 15-17" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Usage" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """## Research Synthesis: [Study Name]
**Method:** [Interviews / Survey / Usability Test] | **Participants:** [X]
**Date:** [Date range] | **Researcher:** [Name]

### Executive Summary
[3-4 sentence overview of key findings]

### Key Themes

#### Theme 1: [Name]
**Prevalence:** [X of Y participants]
**Summary:** [What this theme is about]
**Supporting Evidence:**
- "[Quote]" — P[X]
- "[Quote]" — P[X]
**Implication:** [What this means for the product]

#### Theme 2: [Name]
[Same format]

### Insights → Opportunities

| Insight | Opportunity | Impact | Effort |
|---------|-------------|--------|--------|
| [What we learned] | [What we could do] | High/Med/Low | High/Med/Low |

### User Segments Identified
| Segment | Characteristics | Needs | Size |
|---------|----------------|-------|------|
| [Name] | [Description] | [Key needs] | [Rough %] |

### Recommendations
1. **[High priority]** — [Why, based on which findings]
2. **[Medium priority]** — [Why]
3. **[Lower priority]** — [Why]

### Questions for Further Research
- [What we still don't know]

### Methodology Notes
[How the research was conducted, any limitations or biases to note]
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 30-72" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Quantify the impact of identified pain points" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Validate qualitative findings with usage data and behavioral metrics" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 6 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Publish the synthesis to your research repository" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Search for prior research studies and findings to compare against" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "If **~~knowledge base** is connected:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "If **~~product analytics** is connected:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "If **~~user feedback** is connected:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Pull support tickets, feature requests, and NPS responses to supplement research data" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Cross-reference themes with real user complaints and requests" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "If Connectors Available" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "/research-synthesis" ] ;
    oc:hasWorkflow _:ref_8986b57d89f9d68a,
        [ a oc:Workflow ;
            dcterms:description "Transform raw user research data into a structured synthesis report with themes, insights, segments, and recommendations" ;
            oc:hasStep _:ref_20250c6f07837769,
                _:ref_33ff7c81da5bf470,
                _:ref_811598217dff4da7,
                [ a oc:WorkflowStep ;
                    dcterms:description "If connectors are available, cross-reference with support tickets, product analytics, and prior research" ;
                    oc:expectedOutcome "Synthesis enriched with quantitative validation or supplemental data" ;
                    oc:stepDependsOn _:ref_20250c6f07837769 ;
                    oc:stepId "enrich-connectors" ],
                _:ref_a0462e6f30046c1b ;
            oc:workflowId "research-synthesis-main" ;
            oc:workflowName "Research Synthesis Pipeline" ] ;
    oc:impartsKnowledge oc:kn_16ca7f4e,
        oc:kn_284f8468,
        oc:kn_31c19d21,
        oc:kn_829650e3,
        oc:kn_fd58c994 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DataAvailable ;
    oc:resolvesIntent "create user segments from research data",
        "extract insights from survey results",
        "generate research recommendations",
        "identify themes from interviews",
        "synthesize user research data" ;
    oc:yieldsState oc:ResearchSynthesized .

oc:kn_16ca7f4e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting themes and supporting evidence" ;
    oc:directiveContent "Always include direct participant quotes alongside insights — raw quotes make findings credible and memorable." ;
    oc:hasRationale "Quotes ground abstract insights in real user voices, increasing stakeholder empathy and buy-in" ;
    oc:severityLevel "MEDIUM" .

oc:kn_284f8468 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When describing prevalence, impact, or patterns in research data" ;
    oc:directiveContent "Quantify findings wherever possible: '7 of 10 users' is specific; 'most users' is vague and untrustworthy." ;
    oc:hasRationale "Specific numbers enable stakeholders to weigh the significance of findings and make informed tradeoff decisions" ;
    oc:severityLevel "MEDIUM" .

oc:kn_31c19d21 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing and writing up research findings" ;
    oc:directiveContent "Never conflate observations with interpretations. '5 of 8 users clicked the wrong button' is an observation; 'the button placement is confusing' is an interpretation." ;
    oc:hasRationale "Mixing observations with interpretations undermines credibility and prevents stakeholders from drawing their own conclusions" ;
    oc:severityLevel "HIGH" .

oc:kn_829650e3 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When connectors are configured and available" ;
    oc:directiveContent "If product analytics connectors are available, qualitative findings will be cross-referenced with behavioral metrics; if user feedback connectors are available, support tickets will supplement the research data." ;
    oc:hasRationale "Connector integration enriches synthesis but introduces external data dependencies" ;
    oc:severityLevel "LOW" .

oc:kn_fd58c994 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When producing the final synthesis document" ;
    oc:directiveContent "Structure output as themes → insights → opportunities → recommendations with impact/effort prioritization." ;
    oc:hasRationale "This funnel structure moves from evidence to action, ensuring every recommendation is traceable to data" ;
    oc:severityLevel "MEDIUM" .

_:ref_31ab4dbe78c75c54 a oc:WorkflowStep ;
    dcterms:description "**Include raw quotes** — Direct participant quotes make insights credible and memorable." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_49ed9e452cf5b0fd a oc:WorkflowStep ;
    dcterms:description "**Quantify where possible** — \"Most users\" is vague. \"7 of 10 users\" is specific." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_eb5e467389b52224 a oc:WorkflowStep ;
    dcterms:description "**Separate observations from interpretations** — \"5 of 8 users clicked the wrong button\" is an observation. \"The button placement is confusing\" is an interpretation." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_20250c6f07837769 a oc:WorkflowStep ;
    dcterms:description "Generate prioritized recommendations (high/medium/low) tied to specific findings, plus questions for further research" ;
    oc:expectedOutcome "Ranked recommendations with rationale and open questions documented" ;
    oc:stepDependsOn _:ref_33ff7c81da5bf470 ;
    oc:stepId "prioritize-recommendations" .

_:ref_33ff7c81da5bf470 a oc:WorkflowStep ;
    dcterms:description "Map themes to insights and opportunities with impact/effort assessment; identify user segments with characteristics, needs, and size" ;
    oc:expectedOutcome "Insight-opportunity table and user segment table populated" ;
    oc:stepDependsOn _:ref_811598217dff4da7 ;
    oc:stepId "derive-insights" .

_:ref_811598217dff4da7 a oc:WorkflowStep ;
    dcterms:description "Identify recurring patterns and themes across participants/data points with prevalence counts and supporting quotes" ;
    oc:expectedOutcome "Key themes documented with prevalence metrics and direct evidence" ;
    oc:stepDependsOn _:ref_a0462e6f30046c1b ;
    oc:stepId "identify-themes" .

_:ref_8986b57d89f9d68a a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_31ab4dbe78c75c54,
        _:ref_49ed9e452cf5b0fd,
        _:ref_eb5e467389b52224 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_a0462e6f30046c1b a oc:WorkflowStep ;
    dcterms:description "Ingest raw research data (transcripts, survey results, usability notes, support tickets, NPS responses, app reviews)" ;
    oc:expectedOutcome "All input data parsed and ready for analysis" ;
    oc:stepId "ingest" .

