oc:kn_0576307b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting stakeholder messages or communication plan entries" ;
    oc:directiveContent "Explain the 'why' before the 'what' in all change communications. Acknowledge what is being lost, not just what is being gained." ;
    oc:hasRationale "People process change through loss before gain; acknowledging losses builds trust and reduces resistance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3f204937 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting any change request" ;
    oc:directiveContent "Never submit a change request without a rollback plan, even when confident in success." ;
    oc:hasRationale "Unanticipated failures without rollback plans lead to extended outages and organizational distrust." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4677d5a2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling out the impact analysis table" ;
    oc:directiveContent "Be specific about impact — 'Everyone' is not a valid impact assessment. '200 users in the billing team' is." ;
    oc:hasRationale "Vague impact assessments fail to prepare stakeholders and cannot be used for prioritization or resource planning." ;
    oc:severityLevel "HIGH" .

oc:kn_b1e482ef a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any change request" ;
    oc:directiveContent "Apply the assess-plan-execute-sustain framework when building any change request: first assess what/who/significance/resistance, then plan communications/training/support/timeline, then execute with announcement/training/monitoring, then sustain with measurement/reinforcement/documentation." ;
    oc:hasRationale "A structured framework ensures no critical change management phase is skipped, reducing failed rollouts and resistance." ;
    oc:severityLevel "HIGH" .

oc:kn_b7036014 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning stakeholder communications for a change" ;
    oc:directiveContent "Communicate early and often — surprises create resistance, previews create buy-in." ;
    oc:hasRationale "Early communication reduces resistance and builds organizational support before implementation begins." ;
    oc:severityLevel "MEDIUM" .

_:ref_11818e14a31cbcb9 a oc:WorkflowStep ;
    dcterms:description "**Always have a rollback plan** — Even if you're confident, plan for failure." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_9db89f6384756dfd a oc:WorkflowStep ;
    dcterms:description "**Communicate early** — Surprises create resistance. Previews create buy-in." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_fe85c5849ef9eae3 a oc:WorkflowStep ;
    dcterms:description "**Be specific about impact** — \"Everyone\" is not an impact assessment. \"200 users in the billing team\" is." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_06dc530b431d0660 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_11818e14a31cbcb9,
        _:ref_9db89f6384756dfd,
        _:ref_fe85c5849ef9eae3 ;
