    oc:workflowName "Ordered Procedure" .

_:ref_c7e50347066c0a98 a oc:WorkflowStep ;
    dcterms:description "Execute the change: announce the 'why', train and support users, monitor adoption, address resistance." ;
    oc:expectedOutcome "Change deployed with stakeholder awareness and support" ;
    oc:stepDependsOn _:ref_03d49cfc03762dac ;
    oc:stepId "execute" .

_:ref_e7878a83bfd5e9c4 a oc:WorkflowStep ;
    dcterms:description "Generate the structured change request document with description, business justification, impact analysis, risk assessment, implementation plan, communication plan, rollback plan, and approvals table." ;
    oc:expectedOutcome "Complete change request document ready for submission" ;
    oc:stepDependsOn _:ref_03d49cfc03762dac,
        _:ref_10ce177607a6dceb ;
    oc:stepId "generate-document" .

_:ref_03d49cfc03762dac a oc:WorkflowStep ;
    dcterms:description "Plan the change: create communication plan, training plan, support plan, and timeline with milestones." ;
    oc:expectedOutcome "Detailed implementation and communication plans" ;
    oc:stepDependsOn _:ref_10ce177607a6dceb ;
    oc:stepId "plan" .

_:ref_10ce177607a6dceb a oc:WorkflowStep ;
    dcterms:description "Assess the change: identify what is changing, who is affected, significance level (Low/Medium/High), and expected resistance." ;
    oc:expectedOutcome "Clear understanding of change scope and stakeholder impact" ;
    oc:stepId "assess" .

