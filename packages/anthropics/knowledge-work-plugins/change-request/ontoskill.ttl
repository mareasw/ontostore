@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_change_request a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "change-request" ;
    skos:broader "Change management framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/change-request" ;
    oc:contentHash "bb2c66f7285bf0acd87ac5d3eafb582eb3947c609d6ea4787231e2482a40060a" ;
    oc:differentia "that produces structured change requests with impact analysis, risk assessment, and rollback plans for organizational approval processes" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<change description>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Create a change management request with impact analysis and rollback plan. Use when proposing a system or process change that needs approval, preparing a change record for CAB review, documenting risk and rollback steps before a deployment, or planning stakeholder communications for a rollout." ;
    oc:hasName "change-request" ;
    oc:impartsKnowledge oc:kn_130bfa88,
        oc:kn_21e56a21,
        oc:kn_23e2ec76,
        oc:kn_f22765d0,
        oc:kn_fec93c50 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "assess impact of proposed system or process change",
        "create change request",
        "document risk and rollback steps before deployment",
        "plan stakeholder communications for rollout",
        "prepare change record for CAB review" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_130bfa88 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling in the impact analysis section of a change request" ;
    oc:directiveContent "Never use vague impact assessments like 'Everyone is affected.' Always be specific, e.g., '200 users in the billing team.'" ;
    oc:hasRationale "Vague impact assessments make it impossible to plan targeted communications, training, or rollback steps, leading to resistance and failed changes." ;
    oc:severityLevel "HIGH" .

oc:kn_21e56a21 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any change management request" ;
    oc:directiveContent "Apply the assess-plan-execute-sustain framework when building any change request: assess impact, plan communications and training, execute with monitoring, and sustain through measurement and reinforcement." ;
    oc:hasRationale "A structured framework ensures all dimensions of change are addressed, reducing the risk of overlooked impacts or stakeholder resistance." ;
    oc:severityLevel "HIGH" .

oc:kn_23e2ec76 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When filling in the risk assessment section of a change request" ;
    oc:directiveContent "Include risk assessments with likelihood and impact ratings plus specific mitigation strategies for each identified risk." ;
    oc:hasRationale "Quantified risk assessments enable informed approval decisions and demonstrate due diligence to change advisory boards." ;
    oc:severityLevel "HIGH" .

oc:kn_f22765d0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When completing the rollback plan section of any change request" ;
    oc:directiveContent "Always include a rollback plan with explicit trigger conditions, step-by-step reversal instructions, and verification procedures — even when confidence is high." ;
    oc:hasRationale "Unplanned failures without rollback procedures can cause extended outages and loss of stakeholder trust." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fec93c50 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the communication plan for a change request" ;
    oc:directiveContent "Communicate early and often, explain the 'why' before the 'what', use multiple channels, and acknowledge what is being lost — not just what is being gained." ;
    oc:hasRationale "Early communication creates buy-in and reduces resistance; surprises create opposition." ;
    oc:severityLevel "MEDIUM" .

