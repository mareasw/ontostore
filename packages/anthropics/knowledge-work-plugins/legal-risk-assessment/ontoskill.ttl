oc:kn_00bb4274 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When reviewing a completed risk assessment for completeness" ;
    oc:directiveContent "A complete risk assessment includes: severity rating with rationale, likelihood rating with rationale, risk score and color classification, contributing and mitigating factors, recommended mitigation options with effectiveness/cost table, residual risk assessment, monitoring plan with trigger events, and next steps with owners and deadlines." ;
    oc:hasRationale "Incomplete assessments may miss critical factors or fail to provide actionable guidance" .

oc:kn_22fe8b39 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assessing the Severity dimension of a financial/legal risk" ;
    oc:directiveContent "Use the financial exposure thresholds as anchors: Negligible = no material impact, Low = <1% of deal value, Moderate = 1-5%, High = 5-25%, Critical = >25%." ;
    oc:hasRationale "Anchoring severity to concrete financial percentages reduces subjectivity and improves cross-risk comparability" .

oc:kn_386a5cc5 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When a risk involves potential outside counsel engagement" ;
    oc:directiveContent "Before engaging outside counsel, verify whether the matter falls into mandatory engagement triggers: active litigation, government investigation, criminal exposure, securities issues, or board-level matters." ;
    oc:hasRationale "Mandatory triggers carry legal and regulatory obligations where failure to engage counsel promptly can worsen outcomes significantly" ;
    oc:severityLevel "HIGH" .

oc:kn_783464bc a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, before any risk assessment output" ;
    oc:directiveContent "This skill assists with legal workflows but does NOT provide legal advice. All risk assessments must be reviewed by qualified legal professionals." ;
    oc:hasRationale "Unqualified AI legal advice could be relied upon inappropriately, creating liability exposure for both the user and the organization" ;
    oc:severityLevel "CRITICAL" .

oc:kn_78d098db a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When calculating and classifying any legal risk" ;
    oc:directiveContent "Risk Score = Severity (1-5) × Likelihood (1-5). Score ranges map to: 1-4 GREEN (Low), 5-9 YELLOW (Medium), 10-15 ORANGE (High), 16-25 RED (Critical)." ;
    oc:hasRationale "Consistent scoring enables comparison across risks, prioritization of response efforts, and clear escalation triggers" ;
    oc:severityLevel "HIGH" .

oc:kn_e6312d55 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a risk scores ORANGE (10-15) or RED (16-25)" ;
    oc:directiveContent "Never skip the escalation step for ORANGE or RED risks. ORANGE requires escalation to senior counsel; RED requires immediate escalation to General Counsel, C-suite, and/or Board." ;
    oc:hasRationale "Failure to escalate high-severity risks can result in uninformed leadership, delayed response, and compounded damage" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e6886da1 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When conducting any formal legal risk assessment" ;
    oc:directiveContent "1. Describe the risk clearly 2. Assess Severity (1-5) with rationale 3. Assess Likelihood (1-5) with rationale 4. Calculate Risk Score (Severity × Likelihood) 5. Classify as GREEN/YELLOW/ORANGE/RED 6. Identify contributing and mitigating factors 7. Recommend mitigation options 8. Assess residual risk after mitigation 9. Document using the Risk Assessment Memo format" ;
    oc:stepOrder 1 .

oc:kn_fe4307e4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When initially adopting or periodically reviewing the framework" ;
    oc:directiveContent "Organizations should customize the severity and likelihood thresholds to their specific risk appetite, industry context, and financial materiality standards." ;
    oc:hasRationale "A generic framework may under- or over-state risks that are material to a specific business context" .

_:ref_19b4d798b2974471 a oc:WorkflowStep ;
    dcterms:description "Assess Likelihood (1-5) using precedent analysis and triggering events" ;
    oc:expectedOutcome "Likelihood rating 1-5 with label and documented rationale" ;
    oc:stepDependsOn _:ref_e92f2cd5ab1e3ff6 ;
    oc:stepId "score-likelihood" .

_:ref_7569fea60eff0195 a oc:WorkflowStep ;
    dcterms:description "Execute escalation based on risk level: GREEN=no escalation, YELLOW=brief stakeholders, ORANGE=escalate to senior counsel, RED=immediate executive escalation" ;
    oc:expectedOutcome "Appropriate parties notified per escalation criteria" ;
    oc:stepDependsOn _:ref_eab5511d7c4606f4 ;
    oc:stepId "escalate" .

_:ref_91a6748a2cb60fcf a oc:WorkflowStep ;
    dcterms:description "Identify contributing factors (risk amplifiers) and mitigating factors (risk reducers)" ;
    oc:expectedOutcome "Documented list of contributing and mitigating factors" ;
    oc:stepDependsOn _:ref_eab5511d7c4606f4 ;
    oc:stepId "analyze-factors" .

_:ref_befa21dd401eedf7 a oc:WorkflowStep ;
    dcterms:description "Assess Severity (1-5) using the financial exposure thresholds and impact criteria" ;
    oc:expectedOutcome "Severity rating 1-5 with label and documented rationale" ;
    oc:stepDependsOn _:ref_e92f2cd5ab1e3ff6 ;
    oc:stepId "score-severity" .

_:ref_e6ea9f5e5760789b a oc:WorkflowStep ;
    dcterms:description "Propose mitigation options with effectiveness and cost assessment; recommend approach" ;
    oc:expectedOutcome "Mitigation options table with recommended course of action" ;
    oc:stepDependsOn _:ref_91a6748a2cb60fcf ;
    oc:stepId "recommend-mitigations" .

_:ref_e92f2cd5ab1e3ff6 a oc:WorkflowStep ;
    dcterms:description "Identify and clearly describe the legal risk matter" ;
    oc:expectedOutcome "Clear risk description with relevant facts and business context" ;
    oc:stepId "describe-risk" .

_:ref_eab5511d7c4606f4 a oc:WorkflowStep ;
    dcterms:description "Calculate Risk Score (Severity × Likelihood) and classify as GREEN/YELLOW/ORANGE/RED" ;
    oc:expectedOutcome "Risk score and color-coded risk level" ;
    oc:stepDependsOn _:ref_19b4d798b2974471,
        _:ref_befa21dd401eedf7 ;
    oc:stepId "calculate-classify" .

