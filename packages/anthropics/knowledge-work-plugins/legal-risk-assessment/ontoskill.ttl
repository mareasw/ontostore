@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_legal_risk_assessment a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "legal-risk-assessment" ;
    skos:broader "Risk assessment framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/legal-risk-assessment" ;
    oc:contentHash "0ec73b8791538c7e315f1d2dc10c0fc44d3f2d4df964d0c3f4f51884590e44b4" ;
    oc:differentia "that classifies legal risks using a severity-by-likelihood matrix with escalation criteria and documentation standards" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "description of the legal matter or risk to assess" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Assess and classify legal risks using a severity-by-likelihood framework with escalation criteria. Use when evaluating contract risk, assessing deal exposure, classifying issues by severity, or determining whether a matter needs senior counsel or outside legal review." ;
    oc:hasName "legal-risk-assessment" ;
    oc:impartsKnowledge oc:kn_053447ab,
        oc:kn_5068e4f8,
        oc:kn_8f45fbf4,
        oc:kn_de3b78ec,
        oc:kn_e8bb0120 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "assess deal exposure",
        "assess legal risk",
        "classify legal issues by severity and likelihood",
        "determine whether a matter needs senior counsel or outside legal review",
        "evaluate contract risk",
        "generate risk assessment documentation" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_053447ab a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining whether to recommend outside counsel engagement" ;
    oc:directiveContent "Mandatory outside counsel engagement is required for active litigation, government investigations, criminal exposure, securities issues, and board-level matters. Strongly recommended for novel legal issues, jurisdictional complexity, material financial exposure, and specialized expertise needs." ;
    oc:hasRationale "Certain legal matters require specialized expertise, privilege protection, or regulatory knowledge that exceeds in-house capabilities." ;
    oc:severityLevel "HIGH" .

oc:kn_5068e4f8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When producing a formal risk assessment output" ;
    oc:directiveContent "Document every formal risk assessment using the standardized memo format including risk description, severity/likelihood rationale, contributing and mitigating factors, mitigation options table, recommended approach, residual risk, and monitoring plan." ;
    oc:hasRationale "Structured documentation ensures consistency, supports audit trails, and enables informed decision-making by stakeholders." ;
    oc:severityLevel "HIGH" .

oc:kn_8f45fbf4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when presenting assessment results" ;
    oc:directiveContent "This skill assists with legal workflows but does not provide legal advice. All risk assessments should be reviewed by qualified legal professionals." ;
    oc:hasRationale "Non-lawyer risk assessments carry no legal privilege and may be inaccurate without professional review; the framework is a starting point to be customized per organization." ;
    oc:severityLevel "CRITICAL" .

oc:kn_de3b78ec a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assessment yields a High or Critical risk score" ;
    oc:directiveContent "Never skip the escalation step for ORANGE (score 10-15) or RED (score 16-25) risks. ORANGE requires escalation to senior counsel; RED requires immediate escalation to General Counsel, C-suite, and/or Board." ;
    oc:hasRationale "Failure to escalate significant risks can result in missed mitigation opportunities and personal liability exposure for those responsible." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e8bb0120 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When performing any legal risk assessment" ;
    oc:directiveContent "Always calculate the risk score as Severity × Likelihood (range 1-25) and map to the four-level color system: GREEN (1-4), YELLOW (5-9), ORANGE (10-15), RED (16-25)." ;
    oc:hasRationale "A consistent scoring methodology ensures comparability across assessments and appropriate escalation decisions." ;
    oc:severityLevel "HIGH" .

