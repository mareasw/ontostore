oc:kn_05372b4c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting utilization targets for any role" ;
    oc:directiveContent "Never plan to 100% utilization — always leave buffer for reactive work, surprises, and context-switching costs." ;
    oc:hasRationale "100% utilization leaves zero room for unexpected work, meetings, or creative thinking, leading to burnout and missed deadlines." ;
    oc:severityLevel "CRITICAL" .

oc:kn_65434ba9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting utilization targets per role type" ;
    oc:directiveContent "Target utilization varies by role: IC/Specialist 75-80%, Manager 60-70%, On-call/Support 50-60%." ;
    oc:hasRationale "Different roles have different overhead profiles — managers have meeting load, support roles deal with unpredictable interrupts." ;
    oc:severityLevel "HIGH" .

oc:kn_a0c6305a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When allocating hours across work types" ;
    oc:directiveContent "Treat different types of work as unequal — creative/strategic work requires different capacity considerations than admin or reactive work." ;
    oc:hasRationale "An hour of deep creative work and an hour of admin work have fundamentally different cognitive costs and throughput." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a26c8d82 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating individual capacity" ;
    oc:directiveContent "Do not ignore meeting load, vacation, holidays, sick time, or context-switching costs when calculating available hours." ;
    oc:hasRationale "These hidden time sinks can consume 20-40% of a person's week, making nominal capacity estimates wildly inaccurate." ;
    oc:severityLevel "HIGH" .

oc:kn_b42614eb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the capacity model" ;
    oc:directiveContent "Include ALL work categories — BAU, projects, support, meetings — not just project work, when calculating allocation." ;
    oc:hasRationale "People are never 100% available for project work; omitting non-project activities produces inflated capacity estimates." ;
    oc:severityLevel "HIGH" .

oc:kn_c50c082f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "After creating an initial capacity plan" ;
    oc:directiveContent "Review and update capacity plans monthly — they go stale quickly as priorities shift and new work emerges." ;
    oc:hasRationale "Capacity plans degrade rapidly as team composition, project scope, and priorities change." ;
    oc:severityLevel "MEDIUM" .

_:ref_29c020388df5cd0e a oc:WorkflowStep ;
    dcterms:description "**Update regularly** — Capacity plans go stale fast. Review monthly." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_2f371ff273d1ab95 a oc:WorkflowStep ;
    dcterms:description "**Plan for buffer** — Target 80% utilization. 100% means no room for surprises." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_b33fcb8a79252ff5 a oc:WorkflowStep ;
    dcterms:description "**Include all work** — BAU, projects, support, meetings. People aren't 100% available for project work." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_1708a646f976db09 a oc:WorkflowStep ;
    dcterms:description "Map upcoming projects/initiatives against available capacity, identifying resource gaps by role and time period" ;
    oc:expectedOutcome "Demand forecast table with start/end dates, FTEs needed, and gap/covered status" ;
    oc:stepDependsOn _:ref_5850b42190a84995 ;
    oc:stepId "forecast-demand" .

_:ref_5850b42190a84995 a oc:WorkflowStep ;
    dcterms:description "Calculate current utilization per person/role using target benchmarks (IC 75-80%, Manager 60-70%, Support 50-60%), factoring in PTO, meetings, and non-project work" ;
    oc:expectedOutcome "Utilization table showing capacity, allocated, available hours and % per person" ;
    oc:stepDependsOn _:ref_ba4bc3a2ac38171a ;
    oc:stepId "calculate-utilization" .

_:ref_85711d815de6fad1 a oc:WorkflowStep ;
    dcterms:description "Surface oversubscribed skills/roles and crunch time periods where demand exceeds capacity" ;
    oc:expectedOutcome "List of bottleneck areas requiring action" ;
    oc:stepDependsOn _:ref_1708a646f976db09 ;
    oc:stepId "identify-bottlenecks" .

_:ref_ba4bc3a2ac38171a a oc:WorkflowStep ;
    dcterms:description "Collect team size, roles, current workload (from project tracker or description), upcoming work, and constraints (budget, hiring timeline, skills)" ;
    oc:expectedOutcome "Complete picture of team composition, current allocations, and planned demand" ;
    oc:stepId "gather-inputs" .

_:ref_bb65007a0b890b27 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_29c020388df5cd0e,
