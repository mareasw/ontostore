@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_capacity_plan a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "capacity-plan" ;
    skos:broader "Resource planning framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/capacity-plan" ;
    oc:contentHash "2ee29867933188e34db0e77802f4722f75631510acd7607bb8fb9aa60944cb02" ;
    oc:differentia "that analyzes team workload, utilization rates, and upcoming demand to produce actionable capacity plans with scenario modeling" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<team or project scope>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Plan resource capacity — workload analysis and utilization forecasting. Use when heading into quarterly planning, the team feels overallocated and you need the numbers, deciding whether to hire or deprioritize, or stress-testing whether upcoming projects fit the people you have." ;
    oc:hasName "capacity-plan" ;
    oc:impartsKnowledge oc:kn_05372b4c,
        oc:kn_57fb2bc4,
        oc:kn_5ffd5ae4,
        oc:kn_64d2dc66,
        oc:kn_e9374695 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "analyze team utilization",
        "decide whether to hire or deprioritize",
        "forecast workload allocation",
        "identify capacity bottlenecks",
        "plan resource capacity",
        "stress-test project fit against available people" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_05372b4c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating available capacity for any team or role" ;
    oc:directiveContent "Never plan to 100% utilization — always leave buffer for reactive work, surprises, and context-switching costs." ;
    oc:hasRationale "100% utilization leaves zero room for unplanned work, emergencies, or creative thinking, inevitably causing missed deadlines and burnout." ;
    oc:severityLevel "CRITICAL" .

oc:kn_57fb2bc4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating capacity plan recommendations" ;
    oc:directiveContent "Produce scenario comparisons (do nothing, hire, deprioritize) so stakeholders can make informed trade-off decisions rather than receiving a single point estimate." ;
    oc:hasRationale "Capacity decisions involve trade-offs between cost, timeline, and scope; scenario modeling makes these trade-offs explicit and actionable." .

oc:kn_5ffd5ae4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting utilization targets for capacity planning" ;
    oc:directiveContent "Target utilization varies by role type: IC/Specialist at 75-80%, Manager at 60-70%, On-call/Support at 50-60%." ;
    oc:hasRationale "Different roles have different overhead profiles — management duties, interrupt-driven work, and creative work all require different buffer levels." .

oc:kn_64d2dc66 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "After generating a capacity plan" ;
    oc:directiveContent "Capacity plans go stale quickly and should be reviewed monthly at minimum." ;
    oc:hasRationale "Teams, priorities, and workloads change constantly; a plan older than a few weeks may no longer reflect reality and lead to bad staffing decisions." .

oc:kn_e9374695 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When collecting workload data for capacity analysis" ;
    oc:directiveContent "Include ALL work categories — BAU (business as usual), projects, support, and meetings — when calculating allocation. People are never 100% available for project work alone." ;
    oc:hasRationale "Undercounting non-project work (meetings, admin, support rotations) is the most common source of capacity planning errors." .

