    oc:nature "Concept" ;
    oc:requiresState oc:BudgetAndActualDataLoaded,
        oc:FinancialDataAvailable ;
    oc:resolvesIntent "analyze budget vs actual variances",
        "compare actual vs forecast vs budget",
        "create waterfall analysis",
        "decompose financial variances into drivers",
        "explain period-over-period financial changes",
        "generate variance commentary for leadership" ;
    oc:yieldsState oc:VarianceAnalysisComplete,
        oc:VarianceNarrativesProduced,
        oc:WaterfallChartGenerated .

oc:kn_0dad4ca6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When multiple variances exceed materiality thresholds" ;
    oc:directiveContent "Investigation priority: (1) largest absolute dollar variance, (2) largest percentage variance, (3) unexpected direction, (4) new variance not previously flagged, (5) cumulative/trending variance growing each period." ;
    oc:hasRationale "Prioritizing by impact and anomaly detection ensures the most strategically important variances get attention first" .

oc:kn_0fa4eb90 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing variance narratives" ;
    oc:directiveContent "Avoid circular explanations ('Revenue was higher due to higher revenue'), vague attribution ('expenses were elevated'), and unqualified 'timing' or 'one-time' labels without specifying details and normalization expectations." ;
    oc:hasRationale "These anti-patterns fail to provide actionable insight and erode management confidence in the analysis" ;
    oc:severityLevel "HIGH" .

oc:kn_2b7c1c56 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating waterfall or bridge visualizations" ;
    oc:directiveContent "Waterfall charts should use 5-8 drivers maximum (aggregate smaller items into 'Other'), order drivers from largest positive to largest negative, and always include verification that start + drivers = end." ;
    oc:hasRationale "Too many drivers create visual noise; reconciliation ensures mathematical integrity" .

oc:kn_3e4fee51 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any variance analysis" ;
    oc:directiveContent "Before analysis, confirm: (1) Actual and comparison data are for the same period/entity scope, (2) Chart of accounts mapping is consistent between periods, (3) Data includes both dollar amounts and unit/volume metrics where applicable." ;
    oc:hasRationale "Mismatched periods, inconsistent mappings, or missing unit data produce misleading decomposition results" .

oc:kn_5fc78a8a a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating variance narratives for each line item" ;
    oc:directiveContent """[Line Item]: [Favorable/Unfavorable] variance of $[amount] ([percentage]%) vs [comparison basis] for [period]

Driver: [Primary driver description]
[2-3 sentences with specific quantification of contributing factors]

Outlook: [One-time / Expected to continue / Improving / Deteriorating]
Action: [None required / Monitor / Investigate further / Update forecast]""" ;
    oc:hasRationale "A structured narrative format ensures consistency, completeness, and actionability across all variance explanations" ;
    oc:templateVariables "Line Item",
        "action",
        "amount",
        "comparison basis",
        "contributing factors",
        "driver description",
        "outlook",
        "percentage",
        "period" .

oc:kn_9f10700b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a decomposition technique for a variance" ;
    oc:directiveContent "Use Price/Volume decomposition for revenue and COGS, Rate/Mix for blended margins, Headcount/Compensation for payroll, and Spend Category decomposition for OpEx. Select the technique that matches the metric's unit economics." ;
    oc:hasRationale "Using the wrong decomposition technique produces meaningless driver breakdowns that don't map to real business levers" .

oc:kn_c0e1a49e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any variance decomposition" ;
    oc:directiveContent "Always verify decomposition arithmetic: Volume Effect + Price Effect + Mix Effect must equal Total Variance. If they don't reconcile, the decomposition is incorrect." ;
    oc:hasRationale "Unreconciled decompositions undermine credibility and may lead to incorrect management conclusions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d9225ec5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining which variances require investigation and narrative" ;
    oc:directiveContent "Set materiality thresholds before investigation: typically 10% for Actual vs Budget, 5% for Actual vs Forecast, 15% for Actual vs Prior Period, and 20% for sequential MoM. Dollar thresholds should be 0.5-1% of revenue." ;
    oc:hasRationale "Without predefined thresholds, investigation effort is either wasted on immaterial items or insufficient on material ones" .

oc:kn_e7c5f01f a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When analyzing variance trends over multiple periods" ;
    oc:directiveContent "When variance trending shows consistently favorable results, investigate for sandbagging (overly conservative budgets). When consistently unfavorable, check for aggressive targets or execution issues. Growing unfavorable trends require immediate forecast updates." ;
    oc:hasRationale "Systematic bias in one direction signals either planning process issues or real performance problems that need escalation" .

