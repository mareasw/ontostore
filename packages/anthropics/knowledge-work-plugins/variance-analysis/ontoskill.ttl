@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_variance_analysis a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "variance-analysis" ;
    skos:broader "Financial analysis methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/variance-analysis" ;
    oc:contentHash "34010d26bcf0d93f30b96a72a05e774053f82e186f9593bf053f96c364418424" ;
    oc:differentia "Decomposes variances into constituent drivers with narrative explanations, materiality thresholds, waterfall visualization, and multi-basis comparison frameworks for budget-vs-actual-vs-forecast analysis" ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidComparison ;
    oc:hasArgumentHint "\"<line item> <period> vs <comparison>\"" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Decompose financial variances into drivers with narrative explanations and waterfall analysis. Use when analyzing budget vs. actual, period-over-period changes, revenue or expense variances, or preparing variance commentary for leadership." ;
    oc:hasName "variance-analysis" ;
    oc:impartsKnowledge oc:kn_2276edfb,
        oc:kn_98bb4154,
        oc:kn_c67c20a4,
        oc:kn_dc9f26c9,
        oc:kn_ddc32bf2,
        oc:kn_f01039be,
        oc:kn_f7dc03cd ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:FinancialDataAvailable ;
    oc:resolvesIntent "analyze budget vs actual variances",
        "compare actual vs budget vs forecast",
        "create waterfall analysis",
        "decompose financial variances into drivers",
        "generate variance commentary for leadership",
        "identify material variances requiring investigation",
        "prepare variance narrative explanations" ;
    oc:yieldsState oc:VarianceAnalysisComplete,
        oc:WaterfallGenerated .

oc:kn_2276edfb a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Always, after completing any variance decomposition or waterfall analysis" ;
    oc:directiveContent "Verify that all variance decompositions reconcile: Volume Effect + Price Effect (+ Mix Effect) must equal Total Variance. For waterfalls, Starting value + Sum of all drivers must equal Ending value." ;
    oc:hasRationale "Non-reconciling decompositions indicate computational errors and undermine trust in the entire analysis." ;
    oc:severityLevel "CRITICAL" .

oc:kn_98bb4154 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining which variances require investigation and narrative explanation" ;
    oc:directiveContent "Set materiality thresholds using dual criteria: both dollar and percentage triggers. Use tighter thresholds for Actual vs Forecast (5%) than Actual vs Budget (10%) since forecasts are more recent expectations." ;
    oc:hasRationale "Dual thresholds prevent both large-percentage-small-dollar noise and small-percentage-large-dollar misses from being overlooked. Forecast comparisons should be tighter because forecasts incorporate recent information." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c67c20a4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing waterfall visualizations or text-based waterfall bridges" ;
    oc:directiveContent "Keep waterfall charts to 5-8 drivers maximum — aggregate smaller items into 'Other'. Order drivers from largest positive to largest negative or in logical business sequence." ;
    oc:hasRationale "Too many drivers make the waterfall unreadable and dilute the key messages; aggregation of immaterial items focuses attention on what matters." ;
    oc:severityLevel "MEDIUM" .

oc:kn_dc9f26c9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating variance narratives for any line item" ;
    oc:directiveContent "Never write circular variance explanations like 'Revenue was higher than budget due to higher revenue' or use vague phrases like 'expenses were elevated' without naming the specific driver and quantifying its impact." ;
    oc:hasRationale "Circular or vague explanations fail to inform decision-making and erode credibility with leadership who need to understand root causes." ;
    oc:severityLevel "HIGH" .

oc:kn_ddc32bf2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting the comparison basis for variance analysis" ;
    oc:directiveContent "Use appropriate comparison basis for the context: Actual vs Budget for annual performance and board reporting, Actual vs Forecast for operational management, Actual vs Prior Year for growth analysis, and Actual vs Prior Period for sequential trends." ;
    oc:hasRationale "Each comparison basis serves a different management purpose and the wrong basis can lead to incorrect conclusions about business performance." ;
    oc:severityLevel "HIGH" .

oc:kn_f01039be a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When multiple variances exceed materiality thresholds and time is limited" ;
    oc:directiveContent "Prioritize investigation of variances by: (1) largest absolute dollar impact, (2) largest percentage variance, (3) unexpected direction opposite to trend, (4) new variances that were previously on track, (5) cumulative/trending variances growing each period." ;
    oc:hasRationale "This prioritization ensures the most business-critical and actionable variances get attention first, while systematic emerging issues are caught early." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f7dc03cd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing variance commentary for any material line item" ;
    oc:directiveContent "All variance narratives must include: specific driver identification, dollar and percentage quantification of each driver, causal explanation (WHY not WHAT), forward-looking outlook (one-time vs continuing), and required action (none/monitor/investigate/update forecast)." ;
    oc:hasRationale "Incomplete narratives force readers to follow up with additional questions and slow decision-making. The five-element structure ensures narratives are self-contained and actionable." ;
    oc:severityLevel "HIGH" .

