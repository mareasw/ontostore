    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_3ec7f6889534e8b7 a oc:WorkflowStep ;
    dcterms:description "Metrics: share any early data or feedback" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_4afd1149da843c2e a oc:WorkflowStep ;
    dcterms:description "**Quantify the impact**: \"If this happens, the consequence is [impact]\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_6771af8e38af6ea1 a oc:WorkflowStep ;
    dcterms:description "Commitment: select items from the backlog that fit capacity and priorities" ;
    oc:blockType "workflow_step" ;
