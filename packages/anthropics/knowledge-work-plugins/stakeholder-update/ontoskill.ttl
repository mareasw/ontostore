_:ref_2f5e495217094167 a oc:WorkflowStep ;
    dcterms:description "**State the risk clearly**: \"There is a risk that [thing] happens because [reason]\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_31f3f6f039a830f8 a oc:WorkflowStep ;
