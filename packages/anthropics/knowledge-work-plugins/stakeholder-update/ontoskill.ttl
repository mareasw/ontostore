                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Ad-hoc**: One-off update for a specific situation (escalation, pivot, major decision)" ],
                                        [ a oc:BulletItem ;
