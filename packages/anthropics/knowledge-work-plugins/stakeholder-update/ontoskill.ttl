                                            oc:itemText "Pull sprint or iteration progress" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Pull status of roadmap items and milestones" ],
