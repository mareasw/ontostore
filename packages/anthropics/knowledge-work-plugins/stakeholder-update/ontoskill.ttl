                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Board**: Metrics-driven, strategic, risk-focused, very concise" ] ] ;
                            oc:sectionLevel 3 ;
