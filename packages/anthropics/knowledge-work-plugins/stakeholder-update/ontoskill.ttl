@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_stakeholder_update a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "stakeholder-update" ;
    skos:broader "communication generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/stakeholder-update" ;
    oc:contentHash "efb1e13c685bb54a3f11590b7b52c692be00a4117f96fee8b6cc51b1ed2cc768" ;
    oc:differentia "tailors stakeholder updates to audience type and cadence using structured templates, risk frameworks, and connected tool data" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "\"<update type and audience>\"" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Generate a stakeholder update tailored to audience and cadence. Use when writing a weekly or monthly status for leadership, announcing a launch, escalating a risk or blocker, or translating the same progress into exec-brief, engineering-detail, or customer-facing versions." ;
    oc:hasName "stakeholder-update" ;
    oc:impartsKnowledge oc:kn_01f4bada,
        oc:kn_0835295e,
        oc:kn_1e14eb12,
        oc:kn_278004a8,
        oc:kn_ce99f1c4,
        oc:kn_f6a72cb6 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create executive briefing",
        "draft team progress update",
        "escalate risks and blockers",
        "format update for different audiences",
        "generate stakeholder update",
        "prepare launch announcement",
        "write status report for leadership" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_01f4bada a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting to generate any update" ;
    oc:directiveContent "Pull context from connected tools (project tracker, chat, meeting transcriptions, knowledge base) before writing. Only fall back to manual user input if no tools are connected." ;
    oc:hasRationale "Data-driven updates are more accurate and save the user from manually recounting information already available in their tools" .

oc:kn_0835295e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning status color to any update" ;
    oc:directiveContent "Status colors (Green/Yellow/Red) should reflect genuine reality, not optimism. Move to Yellow at the FIRST sign of risk, not when things are confirmed bad. Yellow is not a failure — it is good risk management." ;
    oc:hasRationale "Early risk flagging preserves options; late escalation limits response flexibility and erodes stakeholder trust" .

oc:kn_1e14eb12 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting risks or making requests in updates" ;
    oc:directiveContent "Every risk communicated must include a mitigation plan or clear next step. Asks must be specific and actionable with deadlines: 'Decision on X by Friday' not 'support needed.'" ;
    oc:hasRationale "Vague risks without plans create anxiety without action; specific asks enable stakeholders to act decisively" ;
    oc:severityLevel "HIGH" .

oc:kn_278004a8 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When preparing risk sections of any update" ;
    oc:directiveContent "Use the ROAM framework (Resolved, Owned, Accepted, Mitigated) to classify and communicate risk status, and the G/Y/R framework to communicate project health at a glance." ;
    oc:hasRationale "Structured risk classification ensures consistent communication and prevents risks from falling through cracks" .

oc:kn_ce99f1c4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring an update for a specific audience type" ;
    oc:directiveContent "Match update depth and length to audience: executives get under 300 words with outcome framing, engineering gets detailed links and technical context, customers get benefit-focused language with no internal jargon." ;
    oc:hasRationale "Each audience has different information needs and attention spans; a one-size-fits-all update fails to serve any audience well" .

oc:kn_f6a72cb6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any stakeholder update" ;
    oc:directiveContent "Never bury the lead or hide bad news after good news. Start with the most important thing, and if there is bad news, lead with it." ;
    oc:hasRationale "Stakeholders skim updates; burying critical information reduces trust and delays action on issues that need attention" ;
    oc:severityLevel "HIGH" .

