            oc:sectionTitle "/performance-review" ] ;
    oc:hasWorkflow _:ref_7665aaf614d0151c,
        [ a oc:Workflow ;
            dcterms:description "Determine review type, optionally enrich with connector data, then generate the appropriate template" ;
            oc:hasStep _:ref_24d81bb953b60978,
                [ a oc:WorkflowStep ;
                    dcterms:description "Review generated content for specificity, behavioral focus, balance, and actionability per the four feedback tips." ;
                    oc:expectedOutcome "Feedback is specific, balanced, behavioral, and actionable" ;
                    oc:stepDependsOn _:ref_977b64403e1bb85d ;
                    oc:stepId "apply-tips" ],
                _:ref_977b64403e1bb85d,
                _:ref_d00b515486f82326 ;
            oc:workflowId "performance-review-generation" ;
            oc:workflowName "Generate Performance Review" ] ;
    oc:impartsKnowledge oc:kn_161c2875,
        oc:kn_198c0189,
        oc:kn_2d96cc58,
        oc:kn_4f22dec9,
        oc:kn_5a170510 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create self-assessment template",
        "generate rating distribution analysis",
        "prepare calibration document",
        "structure feedback with behavioral examples",
        "write manager performance review" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_161c2875 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating development plans or areas for growth" ;
    oc:directiveContent "Make development items actionable with concrete next steps. Replace 'Improve communication' with 'Present at the next team all-hands.'" ;
    oc:hasRationale "Actionable development items give the employee a clear path forward rather than an abstract goal." ;
    oc:severityLevel "MEDIUM" .

oc:kn_198c0189 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any performance review content" ;
    oc:directiveContent "Feedback must be specific and behavioral: cite measurable outcomes (e.g., 'reduced deploy time 40%') rather than vague praise ('great job')." ;
    oc:hasRationale "Specific feedback drives behavior change; vague feedback is unactionable and demotivating." ;
    oc:severityLevel "HIGH" .

oc:kn_2d96cc58 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any feedback or development areas" ;
    oc:directiveContent "Never reference personality traits in reviews. Say 'Your documentation has been incomplete' not 'You're careless.'" ;
    oc:hasRationale "Personality-based feedback feels personal rather than professional and can expose the organization to legal risk." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4f22dec9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When skill is invoked without arguments" ;
    oc:directiveContent "If no mode is specified (self-assessment, manager, calibration), ask the user what type of review they need before generating." ;
    oc:hasRationale "The three output templates serve entirely different audiences and purposes; generating the wrong one wastes time." ;
    oc:severityLevel "HIGH" .

oc:kn_5a170510 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting manager reviews or self-assessments" ;
    oc:directiveContent "Balance positive and constructive feedback equally. Neither should be a surprise to the recipient." ;
    oc:hasRationale "Surprise feedback erodes trust; balanced feedback maintains credibility and psychological safety." ;
    oc:severityLevel "MEDIUM" .

_:ref_050c1e3c1048dfda a oc:WorkflowStep ;
    dcterms:description "**Make development actionable** — \"Improve communication\" is vague. \"Present at the next team all-hands\" is actionable." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_35ef41577cc52fdd a oc:WorkflowStep ;
    dcterms:description "**Balance positive and constructive** — Both are essential. Neither should be a surprise." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_e4953f19a3cb6692 a oc:WorkflowStep ;
    dcterms:description "**Be specific** — \"Great job\" isn't feedback. \"You reduced deploy time 40% by implementing the new CI pipeline\" is." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_faeb2026f615a157 a oc:WorkflowStep ;
    dcterms:description "**Focus on behaviors, not personality** — \"Your documentation has been incomplete\" vs. \"You're careless.\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_24d81bb953b60978 a oc:WorkflowStep ;
    dcterms:description "If HRIS connector is available, pull prior reviews and role info. If project tracker is available, pull completed work and milestones." ;
    oc:expectedOutcome "Employee details and contribution evidence are gathered" ;
    oc:stepDependsOn _:ref_d00b515486f82326 ;
    oc:stepId "enrich-data" .

_:ref_7665aaf614d0151c a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_050c1e3c1048dfda,
        _:ref_35ef41577cc52fdd,
        _:ref_e4953f19a3cb6692,
        _:ref_faeb2026f615a157 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_977b64403e1bb85d a oc:WorkflowStep ;
    dcterms:description "Generate the appropriate template (self-assessment, manager review, or calibration) pre-populated with any enriched data." ;
    oc:expectedOutcome "Complete review document is generated in markdown" ;
    oc:stepDependsOn _:ref_24d81bb953b60978 ;
    oc:stepId "generate-template" .

_:ref_d00b515486f82326 a oc:WorkflowStep ;
    dcterms:description "Parse argument to determine mode: self-assessment, manager [employee], or calibration. If no mode, ask user." ;
    oc:expectedOutcome "Mode is identified and confirmed with user" ;
    oc:stepId "determine-mode" .

