@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_performance_review a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "performance-review" ;
    skos:broader "Human resources workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/performance-review" ;
    oc:contentHash "25bb2338c72cd5141d14e534ad8071da442c8d078cc585d1a7f321dc7ba8df54" ;
    oc:differentia "that structures performance review processes across self-assessment, manager evaluation, and calibration stages with templated outputs" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<employee name or review cycle>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Structure a performance review with self-assessment, manager template, and calibration prep. Use when review season kicks off and you need a self-assessment template, writing a manager review for a direct report, prepping rating distributions and promotion cases for calibration, or turning vague feedback into specific behavioral examples." ;
    oc:hasName "performance-review" ;
    oc:impartsKnowledge oc:kn_9b25b0da,
        oc:kn_c4f2d22a,
        oc:kn_e8872e7c,
        oc:kn_f0b561c6,
        oc:kn_f3e9f96b ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ReviewCycleActive ;
    oc:resolvesIntent "generate self-assessment template",
        "plan performance review cycle",
        "prepare calibration document",
        "structure behavioral feedback",
        "write manager performance review" ;
    oc:yieldsState oc:PerformanceReviewGenerated .

oc:kn_9b25b0da a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting manager reviews and self-assessments" ;
    oc:directiveContent "Balance positive and constructive feedback so neither is a surprise to the employee." ;
    oc:hasRationale "Imbalanced feedback erodes trust and fails to provide a complete picture of performance." .

oc:kn_c4f2d22a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing calibration documents" ;
    oc:directiveContent "Calibration rating distributions should roughly follow company targets: ~15-20% Exceeds, ~60-70% Meets, ~10-15% Below Expectations." ;
    oc:hasRationale "Forced distribution ensures consistency across teams and prevents grade inflation or deflation." .

oc:kn_e8872e7c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing development plans or growth areas" ;
    oc:directiveContent "Make development goals actionable — replace vague goals like 'improve communication' with specific actions like 'present at the next team all-hands'." ;
    oc:hasRationale "Actionable goals create clear next steps and make progress measurable." .

oc:kn_f0b561c6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When describing areas for development or challenges" ;
    oc:directiveContent "Never reference personality traits or character — focus on observable behaviors and outcomes instead." ;
    oc:hasRationale "Personality-based feedback can feel personal attacks and may introduce bias; behavioral feedback is objective and actionable." ;
    oc:severityLevel "HIGH" .

oc:kn_f3e9f96b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any performance review content" ;
    oc:directiveContent "Feedback must be specific and behavioral — cite measurable results and concrete examples rather than vague praise like 'great job'." ;
    oc:hasRationale "Specific feedback drives behavior change; vague feedback is unactionable and can feel dismissive." ;
    oc:severityLevel "HIGH" .

