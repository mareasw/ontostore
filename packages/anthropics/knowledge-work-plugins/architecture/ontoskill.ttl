@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_architecture a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "architecture" ;
    skos:broader "Decision documentation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/architecture" ;
    oc:contentHash "c3e5a564627f332dfbd5bb7a5a14dd9ba82d311532267c61da8d93609f277675" ;
    oc:differentia "structures architecture decisions as formal ADRs with trade-off analysis, option evaluation, and consequence tracking" ;
    oc:extends oc:skill_system_design ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<decision or system to design>" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Create or evaluate an architecture decision record (ADR). Use when choosing between technologies (e.g., Kafka vs SQS), documenting a design decision with trade-offs and consequences, reviewing a system design proposal, or designing a new component from requirements and constraints." ;
    oc:hasName "architecture" ;
    oc:impartsKnowledge oc:kn_25a14093,
        oc:kn_5d943c9b,
        oc:kn_a21de5d7,
        oc:kn_b8c9e5e3,
        oc:kn_cd508bff ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create architecture decision record",
        "design new system component from requirements",
        "document technology selection with trade-offs",
        "evaluate system design proposal" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_25a14093 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When finalizing an ADR document" ;
    oc:directiveContent "Verify the ADR status field matches the decision lifecycle stage (Proposed → Accepted → Deprecated → Superseded)." ;
    oc:hasRationale "Incorrect status signaling can lead teams to act on unapproved decisions or ignore accepted ones." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5d943c9b a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When connectors are available and beginning ADR creation" ;
    oc:directiveContent "If a knowledge base connector is available, search for prior ADRs and design docs to maintain consistency and avoid repeating past decisions." ;
    oc:hasRationale "Prior ADRs contain organizational context and precedent that prevent contradictory decisions and reduce rework." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a21de5d7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating an ADR with Options Considered section" ;
    oc:directiveContent "Always name explicit alternatives even when leaning toward one option, to produce a balanced analysis with comparable evaluations." ;
    oc:hasRationale "Explicit alternatives surface trade-offs that might otherwise be overlooked and provide documented justification for the chosen path." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b8c9e5e3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating options in an ADR or system design" ;
    oc:directiveContent "Include non-functional requirements (latency, cost, team expertise, maintenance burden) alongside functional requirements when evaluating architecture options." ;
    oc:hasRationale "Non-functional requirements often determine long-term success more than feature fit, and neglecting them leads to architectures that are technically correct but operationally unsustainable." ;
    oc:severityLevel "HIGH" .

oc:kn_cd508bff a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating an ADR or evaluating any architecture decision" ;
    oc:directiveContent "State constraints upfront (time, throughput, budget) before evaluating options, as constraints fundamentally shape the analysis and recommendation." ;
    oc:hasRationale "Constraints like 'ship in 2 weeks' or 'must handle 10K rps' eliminate entire categories of solutions and focus the trade-off analysis on viable options." ;
    oc:severityLevel "HIGH" .

