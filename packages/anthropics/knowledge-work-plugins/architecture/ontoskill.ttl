oc:skill_knowledge_work_plugins_architecture a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "architecture" ;
    skos:broader "Document generator" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/architecture" ;
    oc:contentHash "c3e5a564627f332dfbd5bb7a5a14dd9ba82d311532267c61da8d93609f277675" ;
    oc:differentia "that produces Architecture Decision Records (ADRs) with structured trade-off analysis across multiple technology options" ;
    oc:extends oc:skill_ontoskills_system_design ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<decision or system to design>" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Create or evaluate an architecture decision record (ADR). Use when choosing between technologies (e.g., Kafka vs SQS), documenting a design decision with trade-offs and consequences, reviewing a system design proposal, or designing a new component from requirements and constraints." ;
    oc:hasName "architecture" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: architecture
description: Create or evaluate an architecture decision record (ADR). Use when choosing between technologies (e.g., Kafka vs SQS), documenting a design decision with trade-offs and consequences, reviewing a system design proposal, or designing a new component from requirements and constraints.
argument-hint: "<decision or system to design>"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Create an Architecture Decision Record (ADR) or evaluate a system design." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# ADR-[number]: [Title]

**Status:** Proposed | Accepted | Deprecated | Superseded
**Date:** [Date]
**Deciders:** [Who needs to sign off]

## Context
[What is the situation? What forces are at play?]

## Decision
[What is the change we're proposing?]

## Options Considered

### Option A: [Name]
| Dimension | Assessment |
|-----------|------------|
| Complexity | [Low/Med/High] |
| Cost | [Assessment] |
| Scalability | [Assessment] |
| Team familiarity | [Assessment] |

**Pros:** [List]
**Cons:** [List]

### Option B: [Name]
[Same format]

## Trade-off Analysis
[Key trade-offs between options with clear reasoning]

## Consequences
- [What becomes easier]
- [What becomes harder]
- [What we'll need to revisit]

## Action Items
1. [ ] [Implementation step]
2. [ ] [Follow-up]
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 29-69" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Output — ADR Format" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/architecture $ARGUMENTS
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 15-17" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Usage" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Create implementation tasks" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Link to related epics and tickets" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Find relevant technical context" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Search for prior ADRs and design docs" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "If **~~project tracker** is connected:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "If **~~knowledge base** is connected:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "If Connectors Available" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "See the **system-design** skill for detailed frameworks on requirements gathering, scalability analysis, and trade-off evaluation." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Create an ADR**: "Should we use Kafka or SQS for our event bus?"
**Evaluate a design**: "Review this microservices proposal"
**System design**: "Design the notification system for our app\"""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Modes" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_48569b42f1c99d61 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Tips" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "/architecture" ] ;
    oc:hasWorkflow _:ref_48569b42f1c99d61,
        [ a oc:Workflow ;
            dcterms:description "Create a structured Architecture Decision Record from a user's decision question or system design request" ;
            oc:hasStep _:ref_0a5c38db46171e4d,
                _:ref_21096498eaa3519d,
                _:ref_6d55d6a9bc29f717,
                [ a oc:WorkflowStep ;
                    dcterms:description "Draft the full ADR document using the canonical template, including consequences and action items" ;
                    oc:expectedOutcome "Complete ADR document ready for review" ;
                    oc:stepDependsOn _:ref_21096498eaa3519d ;
                    oc:stepId "draft-adr" ],
                _:ref_f60fd95fedcb9c1a ;
            oc:workflowId "adr-creation" ;
            oc:workflowName "ADR Creation Workflow" ] ;
    oc:impartsKnowledge oc:kn_071d31e1,
        oc:kn_30a44c59,
        oc:kn_572447a4,
        oc:kn_c2c7ca8a,
        oc:kn_dcf19a2d ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "compare technology options with trade-offs",
        "create architecture decision record",
        "design new system components from requirements",
        "document design decisions with consequences",
        "evaluate system design proposal" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_071d31e1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating an ADR or evaluating a design" ;
    oc:directiveContent "State constraints upfront — time pressure, performance requirements, or resource limits fundamentally shape architectural recommendations." ;
    oc:hasRationale "Constraints define the feasible solution space; without them, analysis becomes abstract and unactionable." .

oc:kn_30a44c59 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When comparing technology choices" ;
    oc:directiveContent "Name explicit alternatives even when leaning toward one option — a balanced analysis requires structured comparison of all viable options." ;
    oc:hasRationale "Explicit alternatives prevent confirmation bias and produce more defensible decisions." .

oc:kn_572447a4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the request goes beyond ADR creation into full system design" ;
    oc:directiveContent "The system-design skill provides detailed frameworks for requirements gathering, scalability analysis, and trade-off evaluation — delegate to it for deep system design work." ;
    oc:hasRationale "Avoids duplicating framework logic and ensures consistency with established design patterns." .

oc:kn_c2c7ca8a a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When validating ADR output completeness" ;
    oc:directiveContent "A complete ADR includes: Context, Decision, at least 2 named Options with dimensional assessment tables (Complexity/Cost/Scalability/Team familiarity), Trade-off Analysis, Consequences, and Action Items." ;
    oc:hasRationale "Missing sections reduce the document's ability to serve as a durable decision record." .

oc:kn_dcf19a2d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating options in an ADR" ;
    oc:directiveContent "Non-functional requirements (latency, cost, team expertise, maintenance burden) must be weighted alongside functional features in any architectural decision." ;
    oc:hasRationale "Ignoring NFRs leads to architecturally sound but operationally impractical decisions." ;
    oc:severityLevel "HIGH" .

_:ref_3e84cdbe5a541e91 a oc:WorkflowStep ;
    dcterms:description "**State constraints upfront** — \"We need to ship in 2 weeks\" or \"Must handle 10K rps\" shapes the answer." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_c4c925d404885e61 a oc:WorkflowStep ;
    dcterms:description "**Include non-functional requirements** — Latency, cost, team expertise, and maintenance burden matter as much as features." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_dcd7dd2707037a7d a oc:WorkflowStep ;
    dcterms:description "**Name your options** — Even if you're leaning one way, I'll give a more balanced analysis with explicit alternatives." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_0a5c38db46171e4d a oc:WorkflowStep ;
    dcterms:description "Identify at least 2 viable alternatives with explicit naming, even if user has a preference" ;
    oc:expectedOutcome "Named list of options to evaluate" ;
    oc:stepDependsOn _:ref_6d55d6a9bc29f717 ;
    oc:stepId "identify-options" .

_:ref_21096498eaa3519d a oc:WorkflowStep ;
    dcterms:description "Perform trade-off analysis between options with clear reasoning" ;
    oc:expectedOutcome "Structured trade-off comparison with reasoning" ;
    oc:stepDependsOn _:ref_f60fd95fedcb9c1a ;
    oc:stepId "analyze-tradeoffs" .

_:ref_48569b42f1c99d61 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_3e84cdbe5a541e91,
        _:ref_c4c925d404885e61,
        _:ref_dcd7dd2707037a7d ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_6d55d6a9bc29f717 a oc:WorkflowStep ;
    dcterms:description "Gather context: understand the decision to be made, identify constraints, and collect requirements" ;
    oc:expectedOutcome "Clear understanding of the decision scope, constraints, and stakeholders" ;
    oc:stepId "gather-context" .

_:ref_f60fd95fedcb9c1a a oc:WorkflowStep ;
    dcterms:description "Evaluate each option across dimensions: complexity, cost, scalability, team familiarity, and other NFRs" ;
    oc:expectedOutcome "Dimensional assessment table per option with pros and cons" ;
    oc:stepDependsOn _:ref_0a5c38db46171e4d ;
    oc:stepId "evaluate-options" .

