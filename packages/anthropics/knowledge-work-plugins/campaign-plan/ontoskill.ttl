oc:kn_1087d29b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When allocating campaign budget" ;
    oc:directiveContent "Allocate budget using the 60-70% highest-confidence channel / 15-20% testing split, with a 10-15% contingency reserve." ;
    oc:hasRationale "This split balances proven performance with exploration while protecting against overruns." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1256aeaa a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When crafting the message hierarchy" ;
    oc:directiveContent "1. Why should I care? (pain point). 2. What is the solution? (positioning). 3. Why you? (differentiation). 4. What should I do? (CTA)." ;
    oc:stepOrder 3 .

oc:kn_21b0d11e a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating the campaign brief output" ;
    oc:directiveContent """## Campaign Overview
- Name: {name}
- Summary: {one-sentence}
- Primary objective: {SMART goal}

## Target Audience
- Primary: {segment}
- Pain points: {pain_points}
- Buying stage: {stage}

## Key Messages
- Core: {message}
- Supporting: {3-4 points}

## Channel Strategy
- {channel}: {rationale, format, effort, budget}

## Content Calendar
| Week | Content Piece | Channel | Owner/Notes | Status |

## Success Metrics
- Primary KPI: {metric} = {target}

## Risks and Mitigations
- {risk}: {mitigation}

## Next Steps
- {action_items}""" ;
    oc:templateVariables "SMART goal",
        "action_items",
        "channel",
        "message",
        "metric",
        "mitigation",
        "name",
        "one-sentence",
        "pain_points",
        "risk",
        "segment",
        "stage",
        "target" .

oc:kn_95aa0f2d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning any campaign" ;
    oc:directiveContent "Every campaign must follow the Objective → Audience → Message → Channel → Measure framework. Define success before planning anything else." ;
    oc:hasRationale "This five-part framework ensures campaigns are goal-driven and measurable rather than tactic-driven." ;
    oc:severityLevel "HIGH" .

oc:kn_9cc03631 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing campaign channels" ;
    oc:directiveContent "Do not select channels based on comfort or habit; select based on where the target audience spends time and their buying stage." ;
    oc:hasRationale "Channel selection driven by marketer convenience rather than audience behavior leads to wasted spend and low engagement." ;
    oc:severityLevel "HIGH" .

oc:kn_ad01622c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining campaign objectives" ;
    oc:directiveContent "Campaign objectives must be SMART: Specific, Measurable, Achievable, Relevant, Time-bound." ;
    oc:hasRationale "Vague objectives like 'increase awareness' cannot be measured or validated." ;
    oc:severityLevel "HIGH" .

oc:kn_b0600219 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing the campaign-plan skill" ;
    oc:directiveContent "1. Gather campaign goal, target audience, timeline, budget, and context from user (ask if missing). 2. Generate 10-section campaign brief: Overview, Audience, Messages, Channel Strategy, Content Calendar, Content Pieces, Metrics, Budget, Risks, Next Steps. 3. Present brief and offer follow-up actions." ;
    oc:stepOrder 1 .

oc:kn_c06702e8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the content calendar" ;
    oc:directiveContent "Leave 20% of content calendar slots open for reactive or opportunistic content. Do not over-index on a single channel." ;
    oc:hasRationale "Rigid calendars miss trending opportunities and single-channel dependency risks audience fatigue." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c2d6731c a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Campaign goal, target audience, and timeline are required inputs. Budget range and additional context are optional but improve plan quality." .

oc:kn_da67eef8 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating the content calendar" ;
    oc:directiveContent "1. Start with milestones (launch, events, seasonality). 2. Work backward from deadlines. 3. Map content to funnel stages. 4. Batch by theme weekly/bi-weekly. 5. Balance across channels. 6. Reserve 20% for reactive content." ;
    oc:stepOrder 2 .

