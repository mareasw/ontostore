oc:skill_knowledge_work_plugins_campaign_plan a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "campaign-plan" ;
    skos:broader "Campaign planning artifact generator" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/campaign-plan" ;
    oc:contentHash "97293b74516d91563b9b0f04f5c37922cff808b1812fbedf7062636e3cea1517" ;
    oc:differentia "Produces a structured marketing campaign brief with objectives, audience profiling, messaging hierarchy, channel strategy, week-by-week content calendar, and success metrics aligned to campaign type" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<campaign objective or product>" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Generate a full campaign brief with objectives, audience, messaging, channel strategy, content calendar, and success metrics. Use when planning a product launch, lead-gen push, or awareness campaign, when you need a week-by-week content calendar with dependencies, or when translating a marketing goal into a structured, executable plan." ;
    oc:hasName "campaign-plan" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: campaign-plan
description: Generate a full campaign brief with objectives, audience, messaging, channel strategy, content calendar, and success metrics. Use when planning a product launch, lead-gen push, or awareness campaign, when you need a week-by-week content calendar with dependencies, or when translating a marketing goal into a structured, executable plan.
argument-hint: "<campaign objective or product>"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Generate a comprehensive marketing campaign brief with objectives, audience, messaging, channel strategy, content calendar, and success metrics." ],
                [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Industry benchmark: 5-15% of revenue for marketing, with B2B typically at 5-10% and B2C at 10-15%" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "Within the marketing budget, allocate across brand (long-term) and performance (short-term)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Startups and growth-stage companies often invest 15-25% of revenue in marketing" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 32 ;
                                    oc:sectionTitle "Percentage of Revenue Method" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "Shift budget monthly based on performance data (do not set and forget)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Reserve 15-20% for testing new channels or tactics" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "Include a 10-15% contingency for unexpected opportunities or overruns" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Start with your highest-confidence channel and allocate 60-70% of paid budget there" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "Account for production costs, not just media spend" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 34 ;
                                    oc:sectionTitle "Budget Optimization Principles" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "A common starting framework (adjust based on goals and historical data):" ],
                                        [ a oc:Table ;
                                            oc:blockType "table" ;
                                            oc:contentOrder 2 ;
                                            oc:rowCount 5 ;
                                            oc:tableCaption "A common starting framework (adjust based on goals and historical data)" ;
                                            oc:tableMarkdown """| Category | Percentage of Budget | Examples |
|----------|---------------------|----------|
| Paid acquisition | 30-40% | Search ads, social ads, display |
| Content production | 20-30% | Blog, video, design, ebooks |
| Events and sponsorships | 10-20% | Conferences, webinars, meetups |
| Tools and technology | 10-15% | Analytics, automation, CRM |
| Testing and experimentation | 5-10% | New channels, A/B tests, pilots |
""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 33 ;
                                    oc:sectionTitle "Channel Allocation Framework" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 31 ;
                            oc:sectionTitle "Budget Allocation Approaches" ],
                        [ a oc:Section ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "Landing page: 5-7 business days (copy, design, development, QA)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Email campaign: 2-3 business days (copy, design, test, send)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "Social media posts: 1-2 business days (draft, design, schedule)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 6 ;
                                                    oc:itemText "Ebook/whitepaper: 2-4 weeks (outline, draft, design, review)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Blog post: 3-5 business days (research, draft, review, publish)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "Video content: 2-4 weeks (script, production, editing)" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 30 ;
                                    oc:sectionTitle "Production Timeline Benchmarks" ],
                                [ a oc:Section ;
                                    oc:hasContent _:ref_7bd8012a6da72b18 ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 28 ;
                                    oc:sectionTitle "Calendar Planning Process" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "**Paid campaigns**: continuous during campaign window with creative refreshes every 2-4 weeks" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Email newsletter**: weekly or bi-weekly for most audiences" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "**Social media**: 3-7 posts per week per platform (varies by platform)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "**Webinars**: monthly or quarterly depending on resources" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Blog**: 1-4 posts per week depending on team size and goals" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 29 ;
                                    oc:sectionTitle "Content Cadence Guidelines" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 27 ;
                            oc:sectionTitle "Content Calendar Creation" ],
                        [ a oc:Section ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:Table ;
                                            oc:blockType "table" ;
                                            oc:contentOrder 1 ;
                                            oc:rowCount 5 ;
                                            oc:tableCaption "#### Event/Webinar Campaign" ;
                                            oc:tableMarkdown """| Metric | What It Measures |
|--------|-----------------|
| Registrations | Interest generated |
| Attendance rate | Conversion from registration |
| Engagement during event | Questions, polls, chat activity |
| Post-event conversions | Leads or pipeline from attendees |
| Content repurposing reach | Downstream audience from recordings |
""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 40 ;
                                    oc:sectionTitle "Event/Webinar Campaign" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Table ;
                                            oc:blockType "table" ;
                                            oc:contentOrder 1 ;
                                            oc:rowCount 5 ;
                                            oc:tableCaption "#### Product Launch Campaign" ;
                                            oc:tableMarkdown """| Metric | What It Measures |
|--------|-----------------|
| Signups or trials | Adoption of new product |
| Activation rate | Users who complete key first action |
| Media coverage | Earned media hits |
| Social buzz | Mentions, shares, engagement spike |
| Feature adoption | Usage of specific launched features |
""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 38 ;
                                    oc:sectionTitle "Product Launch Campaign" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Table ;
                                            oc:blockType "table" ;
                                            oc:contentOrder 1 ;
                                            oc:rowCount 5 ;
                                            oc:tableCaption "#### Awareness Campaign" ;
                                            oc:tableMarkdown """| Metric | What It Measures |
|--------|-----------------|
| Reach/Impressions | How many people saw the campaign |
| Brand mention volume | Increase in brand conversations |
| Share of voice | Your mentions vs. competitors |
| Direct traffic | People coming to your site unprompted |
| Social follower growth | Audience building |
""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 36 ;
                                    oc:sectionTitle "Awareness Campaign" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Table ;
                                            oc:blockType "table" ;
                                            oc:contentOrder 1 ;
                                            oc:rowCount 5 ;
                                            oc:tableCaption "#### Retention/Engagement Campaign" ;
                                            oc:tableMarkdown """| Metric | What It Measures |
|--------|-----------------|
| Churn rate change | Customer retention improvement |
| Engagement rate | Interactions with campaign content |
| NPS or CSAT change | Satisfaction improvement |
| Upsell/cross-sell revenue | Expansion revenue |
| Feature adoption | Usage of promoted features |
""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 39 ;
                                    oc:sectionTitle "Retention/Engagement Campaign" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Table ;
                                            oc:blockType "table" ;
                                            oc:contentOrder 1 ;
                                            oc:rowCount 5 ;
                                            oc:tableCaption "#### Lead Generation Campaign" ;
                                            oc:tableMarkdown """| Metric | What It Measures |
|--------|-----------------|
| Total leads | Volume of new contacts |
| Marketing qualified leads (MQLs) | Leads meeting quality threshold |
| Cost per lead (CPL) | Efficiency of spend |
| Lead-to-MQL conversion rate | Quality of leads generated |
| Pipeline influenced | Revenue opportunity created |
""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 37 ;
                                    oc:sectionTitle "Lead Generation Campaign" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 35 ;
                            oc:sectionTitle "Success Metrics by Campaign Type" ],
                        [ a oc:Section ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Where does your target audience spend time?" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "What is the buying stage you are targeting? (awareness channels vs. conversion channels)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "What content assets do you already have or can you produce?" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "What has worked in the past? (reference historical data if available)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "What is your budget? (paid channels require spend; owned/earned require time)" ] ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "When choosing channels, consider:" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 26 ;
                                    oc:sectionTitle "Channel Selection Criteria" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Table ;
                                            oc:blockType "table" ;
                                            oc:contentOrder 1 ;
                                            oc:rowCount 5 ;
                                            oc:tableCaption "#### Paid Channels" ;
                                            oc:tableMarkdown """| Channel | Best For | Typical Metrics | Effort |
|---------|----------|----------------|--------|
| Search ads (SEM) | High-intent lead capture | CPC, CTR, conversion rate, CPA | Medium |
| Social ads | Awareness, retargeting, lead gen | CPM, CPC, CTR, CPA, ROAS | Medium |
| Display/Programmatic | Awareness, retargeting | Impressions, CPM, view-through conversions | Low-Medium |
| Sponsored content | Thought leadership, lead gen | Engagement, leads, cost per lead | Medium |
| Events/Sponsorships | Relationship building, brand | Leads, meetings, pipeline influenced | High |
""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 25 ;
                                    oc:sectionTitle "Paid Channels" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Table ;
                                            oc:blockType "table" ;
                                            oc:contentOrder 1 ;
                                            oc:rowCount 5 ;
                                            oc:tableCaption "#### Earned Channels" ;
                                            oc:tableMarkdown """| Channel | Best For | Typical Metrics | Effort |
|---------|----------|----------------|--------|
| PR/Media | Awareness, credibility, launches | Coverage, share of voice, referral traffic | High |
| Guest content | Audience expansion, SEO, credibility | Referral traffic, backlinks | Medium |
| Influencer/Partner | Audience expansion, trust | Reach, engagement, referral conversions | Medium-High |
| Community | Awareness, trust, feedback | Mentions, engagement, referral traffic | Medium |
| Reviews/Ratings | Credibility, SEO, consideration | Review volume, rating, conversion lift | Low-Medium |
""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 24 ;
                                    oc:sectionTitle "Earned Channels" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Table ;
                                            oc:blockType "table" ;
                                            oc:contentOrder 1 ;
                                            oc:rowCount 5 ;
                                            oc:tableCaption "#### Owned Channels" ;
                                            oc:tableMarkdown """| Channel | Best For | Typical Metrics | Effort |
|---------|----------|----------------|--------|
| Blog/Website | SEO, thought leadership, education | Traffic, time on page, conversions | Medium |
| Email | Nurture, retention, announcements | Open rate, CTR, conversions | Low-Medium |
| Social (organic) | Awareness, community, brand building | Engagement, reach, follower growth | Medium |
| Webinars | Education, lead gen, product demos | Registrations, attendance, pipeline | High |
| Podcast | Thought leadership, brand awareness | Downloads, subscriber growth | High |
""" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 23 ;
                                    oc:sectionTitle "Owned Channels" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 22 ;
                            oc:sectionTitle "Channel Selection Guide" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Every campaign should be built on this five-part framework:" ] ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:BlockQuote ;
                                            oc:blockType "blockquote" ;
                                            oc:contentOrder 4 ;
                                            oc:quoteContent "\"[Role] at [company type] who is struggling with [pain point] and looking for [desired outcome]. They typically discover solutions through [channels] and care most about [priorities].\"" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "Define who you are trying to reach with enough specificity to guide messaging and channel decisions." ],
                                        [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Demographics**: role/title, seniority, company size, industry" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Psychographics**: motivations, pain points, goals, objections" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "**Buying stage**: are they unaware of the problem, researching solutions, or ready to buy?" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "**Behavioral**: where they consume content, how they buy, what they have engaged with before" ] ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 3 ;
                                            oc:textContent "Create a brief audience profile (not a full persona) for campaign planning:" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 18 ;
                                    oc:sectionTitle "Audience" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Consideration**: drive engagement and education (measured by content engagement, email signups, webinar attendance)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "**Conversion**: generate leads or sales (measured by signups, demos, purchases, pipeline)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Awareness**: increase brand or product visibility (measured by reach, impressions, share of voice)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "**Advocacy**: turn customers into promoters (measured by referrals, reviews, UGC)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "**Retention**: re-engage existing customers (measured by churn reduction, upsell, NPS)" ] ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 4 ;
                                            oc:textContent "Example: \"Generate 200 marketing qualified leads from mid-market SaaS companies in North America within 6 weeks of campaign launch.\"" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "Define what success looks like before planning anything else." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 3 ;
                                            oc:textContent "Good objectives are SMART: Specific, Measurable, Achievable, Relevant, Time-bound." ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 17 ;
                                    oc:sectionTitle "Objective" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "Select channels based on where your audience is, not where you are most comfortable. See the Channel Selection Guide below." ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 20 ;
                                    oc:sectionTitle "Channel" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 2 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "**Core message**: one sentence that captures what you want the audience to think, feel, or do" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "**Supporting messages**: 3-4 points that provide evidence, address objections, or elaborate on benefits" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "**Proof points**: data, case studies, testimonials, or third-party validation for each supporting message" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "**Differentiation**: what makes your offering different from alternatives (including doing nothing)" ] ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 3 ;
                                            oc:textContent "Message hierarchy:" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "Craft the core message and supporting points that will resonate with the audience." ],
                                        _:ref_a9823fcc1fc8f406 ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 19 ;
                                    oc:sectionTitle "Message" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "Define how you will know the campaign worked. See Success Metrics by Campaign Type below." ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 21 ;
                                    oc:sectionTitle "Measure" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 16 ;
                            oc:sectionTitle "Campaign Framework: Objective, Audience, Message, Channel, Measure" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 15 ;
                    oc:sectionTitle "Planning Reference" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Present the full campaign brief with clear headings and formatting. After the brief, ask:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "\"Would you like me to:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Dive deeper into any section?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Draft specific content pieces from the calendar?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Create a competitive analysis to inform the messaging?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Adjust the plan for a different budget or timeline?\"" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 41 ;
                    oc:sectionTitle "Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Generate a campaign brief with the following sections:" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Proof points or evidence to support each message" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Core campaign message (one sentence)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Message variations by channel (if different tones are needed)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "3-4 supporting messages tailored to audience pain points" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 7 ;
                            oc:sectionTitle "3. Key Messages" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
