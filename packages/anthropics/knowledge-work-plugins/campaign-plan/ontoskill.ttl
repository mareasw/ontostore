@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_campaign_plan a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "campaign-plan" ;
    skos:broader "Campaign planning framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/campaign-plan" ;
    oc:contentHash "97293b74516d91563b9b0f04f5c37922cff808b1812fbedf7062636e3cea1517" ;
    oc:differentia "Generates a comprehensive marketing campaign brief with structured sections for objectives, audience, messaging, channel strategy, content calendar, and success metrics using a five-part Objective-Audience-Message-Channel-Measure framework" ;
    oc:extends oc:skill_content_creation,
        oc:skill_draft_content ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<campaign objective or product>" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Generate a full campaign brief with objectives, audience, messaging, channel strategy, content calendar, and success metrics. Use when planning a product launch, lead-gen push, or awareness campaign, when you need a week-by-week content calendar with dependencies, or when translating a marketing goal into a structured, executable plan." ;
    oc:hasName "campaign-plan" ;
    oc:impartsKnowledge oc:kn_0087cea5,
        oc:kn_28aae826,
        oc:kn_66baa3e7,
        oc:kn_b91f5991,
        oc:kn_c18955b6,
        oc:kn_ca0a02e9,
        oc:kn_d991c16c ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build a lead generation campaign",
        "create a campaign brief",
        "create a week-by-week marketing plan",
        "design a product launch plan",
        "generate a content calendar",
        "plan a marketing campaign",
        "structure an awareness campaign" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0087cea5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When allocating budget across channels" ;
    oc:directiveContent "Allocate 60-70% of paid budget to the highest-confidence channel, reserve 15-20% for testing new channels, and include 10-15% contingency." ;
    oc:hasRationale "Over-diversifying budget too early dilutes impact; the testing reserve allows data-driven reallocation while contingency covers unexpected needs" .

oc:kn_28aae826 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning any marketing campaign" ;
    oc:directiveContent "Every campaign must follow the five-part Objective-Audience-Message-Channel-Measure framework, defining success criteria before selecting tactics." ;
    oc:hasRationale "This ensures campaigns are goal-driven rather than tactic-driven, preventing wasted spend on misaligned channels" ;
    oc:severityLevel "HIGH" .

oc:kn_66baa3e7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining the primary campaign objective" ;
    oc:directiveContent "Campaign objectives must be SMART: Specific, Measurable, Achievable, Relevant, and Time-bound." ;
    oc:hasRationale "Vague objectives make it impossible to measure success or allocate resources effectively" .

oc:kn_b91f5991 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When recommending channels in the channel strategy section" ;
    oc:directiveContent "Channel selection must be based on where the target audience spends time, not where the team is most comfortable." ;
    oc:hasRationale "Selecting familiar channels over audience-appropriate ones leads to low engagement and wasted budget" .

oc:kn_c18955b6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating the content calendar" ;
    oc:directiveContent "Leave 20% of content calendar slots open for reactive or opportunistic content to maintain flexibility." ;
    oc:hasRationale "Rigid calendars break when real-world events or opportunities arise, forcing teams to abandon the plan entirely" .

oc:kn_ca0a02e9 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating any campaign brief" ;
    oc:directiveContent "Gather campaign goal, target audience, timeline, and optional budget and additional context from the user before generating the brief. If not provided, ask before proceeding." ;
    oc:hasRationale "Missing inputs produce generic, unusable plans that do not address the user's specific situation" .

oc:kn_d991c16c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During ongoing campaign execution" ;
    oc:directiveContent "Do not set budget allocations and forget them — shift budget monthly based on actual performance data." ;
    oc:hasRationale "Static budgets ignore channel performance variation and lock spend into underperforming channels" .

