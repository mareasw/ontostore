                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "When a user asks about a specific tool that is not connected:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """[Tool name] isn't currently connected. To add it:
1. Open your MCP settings
2. Add the [tool] MCP server configuration
3. Authenticate when prompted

Once connected, it will be automatically included in future searches.
""" ;
                            oc:codeLanguage "" ;
