                                    oc:blockType "code_block" ;
                                    oc:codeContent """1. Wiki / ~~knowledge base (official documentation)
2. ~~cloud storage (policy docs, handbooks)
3. ~~email (policy announcements)
4. ~~chat (policy discussions)
""" ;
                                    oc:codeLanguage "" ;
                                    oc:contentOrder 10 ;
                                    oc:sourceLocation "lines 100-105" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 7 ;
                                    oc:textContent "**People queries** (\"Who works on...\" / \"Who knows about...\"):" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """1. ~~cloud storage (primary doc storage)
2. Wiki / ~~knowledge base (knowledge base)
3. ~~email (docs shared via email)
4. ~~chat (docs shared in channels)
5. Task tracker (docs linked to tasks)
""" ;
                                    oc:codeLanguage "" ;
