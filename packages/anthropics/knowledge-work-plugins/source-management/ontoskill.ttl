oc:kn_07edfe4d a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When reporting search results to users" ;
    oc:directiveContent "Always report which sources were searched when presenting results so the user knows the scope and completeness of the answer." ;
    oc:hasRationale "Source transparency lets users assess whether critical sources were missed and whether results are comprehensive." ;
    oc:severityLevel "MEDIUM" .

oc:kn_09610248 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a source is rate limited during search" ;
    oc:directiveContent "Never retry immediately when a source returns a rate limit error (HTTP 429, 'too many requests', 'quota exceeded'). Instead, continue with other sources and inform the user." ;
    oc:hasRationale "Immediate retries compound the rate limit problem and can block the entire search flow." ;
    oc:severityLevel "CRITICAL" .

oc:kn_573a3d44 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When digest generation is interrupted by rate limiting" ;
    oc:directiveContent "When rate limited mid-scan for digests, note which time range was covered before the limit hit so the user knows the partial coverage scope." ;
    oc:hasRationale "Partial results are still valuable; documenting the coverage gap allows users to retry for the missing range." .

oc:kn_9c1f1176 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When checking which sources are available" ;
    oc:directiveContent "A source is considered connected and searchable only if its corresponding tool prefix is available in the current tool set." ;
    oc:hasRationale "Tool prefix presence is the definitive signal for source availability; assuming connectivity without verification leads to failed queries." ;
    oc:severityLevel "HIGH" .

oc:kn_a4f91bcc a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When adding custom sources" ;
    oc:directiveContent "Adding a new MCP server to .mcp.json automatically includes it in subsequent searches — no additional configuration needed for search integration." ;
    oc:hasRationale "Auto-detection of new sources eliminates manual configuration overhead and ensures immediate availability." .

oc:kn_ea41c559 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing multi-source searches" ;
    oc:directiveContent "Use source priorities to weight results, never to skip sources entirely. All connected sources should be queried; priority only affects result ranking." ;
    oc:hasRationale "Skipping sources would create blind spots; weighting ensures the most relevant results surface first while maintaining completeness." ;
    oc:severityLevel "HIGH" .

oc:kn_eb035790 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When optimizing API call volume" ;
    oc:directiveContent "Avoid unnecessary API calls by checking if a source is likely to have relevant results before querying. Use targeted queries over broad scans, batch requests for digests, and avoid re-running identical queries immediately." ;
    oc:hasRationale "Reducing unnecessary calls prevents hitting rate limits and improves overall search latency." ;
    oc:severityLevel "MEDIUM" .

oc:kn_faf9d79e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing search relevance by query intent" ;
    oc:directiveContent "Query types map to distinct source priority orders: decision queries start with chat, status queries start with project tracker, document queries start with cloud storage, people queries start with chat, and policy queries start with knowledge base." ;
    oc:hasRationale "Different content types live predominantly in different sources; starting with the most likely source improves result quality and speed." .

