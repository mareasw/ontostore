        oc:kn_412d0922,
        oc:kn_6e537355,
        oc:kn_739a9b84,
        oc:kn_e318020d ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "draft a sprint plan document",
        "estimate team capacity for a sprint",
        "plan a sprint",
        "prioritize backlog items",
        "scope sprint work with carryover" ;
