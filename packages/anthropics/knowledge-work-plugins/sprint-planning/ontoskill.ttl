@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_sprint_planning a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "sprint-planning" ;
    skos:broader "Planning workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/sprint-planning" ;
    oc:contentHash "2bc8fca00372749b3f2ea012a07ef84513f6fc79eeaa392ef8f85389263790df" ;
    oc:differentia "scopes work, estimates team capacity with PTO/meeting deductions, prioritizes backlog into P0/P1/P2 tiers, and produces a structured sprint plan document with risks, definition of done, and key dates" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "[sprint name or date range]" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Plan a sprint — scope work, estimate capacity, set goals, and draft a sprint plan. Use when kicking off a new sprint, sizing a backlog against team availability (accounting for PTO and meetings), deciding what's P0 vs. stretch, or handling carryover from the last sprint." ;
    oc:hasName "sprint-planning" ;
    oc:impartsKnowledge oc:kn_6a369b10,
        oc:kn_6b55fc8e,
        oc:kn_71ed11df,
        oc:kn_73cf0791,
        oc:kn_8a7ef956 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "draft sprint plan",
        "estimate team capacity",
        "handle sprint carryover",
        "plan a sprint",
        "prioritize backlog items",
        "scope sprint work" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_6a369b10 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When estimating sprint capacity and assigning work" ;
    oc:directiveContent "Plan to only 70-80% of team capacity to account for interrupts, unplanned work, and context switching." ;
    oc:hasRationale "Teams consistently over-commit when planning to 100% capacity, leading to missed commitments and burnout." ;
    oc:severityLevel "HIGH" .

oc:kn_6b55fc8e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating a sprint plan" ;
    oc:directiveContent "Gather team availability (PTO, meetings, on-call), sprint length, prioritized backlog, carryover items, and cross-team dependencies before starting planning." ;
    oc:hasRationale "Missing any of these inputs leads to inaccurate capacity estimates, overlooked blockers, or incomplete sprint scope." ;
    oc:severityLevel "HIGH" .

oc:kn_71ed11df a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When handling unfinished work from the prior sprint" ;
    oc:directiveContent "Before re-committing carryover items from the previous sprint, honestly assess why they didn't ship. Do not blindly roll them over." ;
    oc:hasRationale "Blind carryover hides systemic issues like under-estimation, blockers, or scope creep, and leads to recurring over-commitment." ;
    oc:severityLevel "MEDIUM" .

oc:kn_73cf0791 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting sprint goals at the start of planning" ;
    oc:directiveContent "Define one clear sprint goal stated in a single sentence. If you cannot articulate it simply, the sprint is unfocused." ;
    oc:hasRationale "A focused sprint goal aligns the team, simplifies prioritization decisions, and provides a clear success criterion." ;
    oc:severityLevel "HIGH" .

oc:kn_8a7ef956 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When prioritizing and scoping the sprint backlog" ;
    oc:directiveContent "Always identify stretch items (P2) alongside must-ship (P0) and should-ship (P1) items so the team knows what to cut if work takes longer than expected." ;
    oc:hasRationale "Having pre-identified cut candidates prevents ad hoc decisions under pressure and preserves sprint goal integrity." ;
    oc:severityLevel "MEDIUM" .

