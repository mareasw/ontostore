oc:kn_2e75acdf a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When tools are connected (supercharged mode)" ;
    oc:directiveContent "When connected to project tracker, calendar, or chat tools, this skill can pull backlog data, auto-adjust capacity for PTO/meetings, and share the sprint plan with the team." ;
    oc:hasRationale "Integration with external tools reduces manual data entry and ensures capacity estimates reflect actual availability." .

oc:kn_412d0922 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining sprint goals" ;
    oc:directiveContent "State the sprint goal in one clear sentence. If you cannot, the sprint is unfocused and should be re-scoped." ;
    oc:hasRationale "A single clear goal ensures alignment and makes it easy to evaluate sprint success at the end." ;
    oc:severityLevel "HIGH" .

oc:kn_6e537355 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When estimating sprint capacity" ;
    oc:directiveContent "Plan to 70-80% of total team capacity to account for interrupts and unplanned work." ;
    oc:hasRationale "Teams always encounter interrupts; planning to full capacity guarantees overcommitment and missed goals." ;
    oc:severityLevel "HIGH" .

oc:kn_739a9b84 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling carryover from last sprint" ;
    oc:directiveContent "Never re-commit carryover items without understanding why they didn't ship in the previous sprint." ;
    oc:hasRationale "Blindly re-committing without root cause analysis repeats the same failure pattern." ;
    oc:severityLevel "HIGH" .

oc:kn_e318020d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When prioritizing backlog items" ;
    oc:directiveContent "Always identify stretch items (P2) that can be cut if P0/P1 items take longer than expected." ;
    oc:hasRationale "Stretch items provide flexibility without losing commitment to must-ship deliverables." ;
    oc:severityLevel "MEDIUM" .

_:ref_450f4981827db3a9 a oc:WorkflowStep ;
    dcterms:description "**Identify stretch items** — Know what to cut if things take longer than expected." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_5e261e4c14775019 a oc:WorkflowStep ;
    dcterms:description "**Carry over honestly** — If something didn't ship, understand why before re-committing." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_9b1732f9702781f5 a oc:WorkflowStep ;
    dcterms:description "**One clear sprint goal** — If you can't state it in one sentence, the sprint is unfocused." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_b26754e234763b96 a oc:WorkflowStep ;
    dcterms:description "**Leave buffer** — Plan to 70-80% capacity. You will get interrupts." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_0393d07eed41d5ee a oc:WorkflowStep ;
    dcterms:description "Identify risks, blockers, and cross-team dependencies; define mitigation strategies." ;
    oc:expectedOutcome "Risk register with impact assessment and mitigation plan." ;
    oc:stepDependsOn _:ref_742bd1fa6a2347c3 ;
    oc:stepId "identify-risks" .

_:ref_742bd1fa6a2347c3 a oc:WorkflowStep ;
    dcterms:description "Scope and prioritize backlog items into P0 (must ship), P1 (should ship), and P2 (stretch) tiers, assigning estimates and owners." ;
    oc:expectedOutcome "Prioritized sprint backlog with estimates, owners, and dependency flags for each item." ;
    oc:stepDependsOn _:ref_a0a11b1d2e034910 ;
    oc:stepId "prioritize-backlog" .

_:ref_8baa8ff8db743a02 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_450f4981827db3a9,
        _:ref_5e261e4c14775019,
        _:ref_9b1732f9702781f5,
        _:ref_b26754e234763b96 ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_92b0024f171af941 a oc:WorkflowStep ;
    dcterms:description "Collect team roster, availability, sprint length, prioritized backlog, carryover items, and cross-team dependencies from the user or connected tools." ;
    oc:expectedOutcome "All required inputs assembled: team list with availability, backlog items, carryover, and dependencies." ;
    oc:stepId "gather-inputs" .

_:ref_a0a11b1d2e034910 a oc:WorkflowStep ;
    dcterms:description "Calculate total team capacity in points or hours, subtracting PTO, meetings, and on-call rotations." ;
    oc:expectedOutcome "Capacity table with per-person available days and allocation, and total team capacity figure." ;
    oc:stepDependsOn _:ref_92b0024f171af941 ;
    oc:stepId "estimate-capacity" .

