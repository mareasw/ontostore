    oc:hasWorkflow _:ref_8baa8ff8db743a02,
        [ a oc:Workflow ;
            dcterms:description "Complete sprint planning process from gathering inputs to generating the sprint plan document." ;
            oc:hasStep _:ref_0393d07eed41d5ee,
                [ a oc:WorkflowStep ;
                    dcterms:description "Generate the complete sprint plan document with capacity table, prioritized backlog, capacity vs load summary, risks, definition of done, and key dates." ;
                    oc:expectedOutcome "Structured sprint plan document ready to share with the team." ;
                    oc:stepDependsOn _:ref_0393d07eed41d5ee ;
