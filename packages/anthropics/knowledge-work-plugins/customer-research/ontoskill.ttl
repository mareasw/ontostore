                                    oc:contentOrder 3 ;
                                    oc:textContent "Before searching, clarify what you're actually trying to find:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Identify what type of research is needed:" ],
