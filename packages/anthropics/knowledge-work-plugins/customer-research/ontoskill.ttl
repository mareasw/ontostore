oc:kn_03f90013 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting any research finding" ;
    oc:directiveContent "Never share Low confidence or inferred answers with customers without explicit verification from an authoritative source. Always assign and communicate a confidence level (High / Medium / Low / Unable to Determine)." ;
    oc:hasRationale "Customer-facing misinformation damages trust and can create legal or contractual obligations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_09e2c6b2 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating knowledge base documentation from research" ;
    oc:directiveContent """## {Question/Topic}
**Last Verified:** {date}
**Confidence:** {level}
### Answer
{Direct answer}
### Details
{Supporting detail, context}
### Sources
{Where information came from}
### Related Questions
{Other questions this helps}
### Review Notes
{When to re-verify, what might change}""" ;
    oc:templateVariables "Direct answer",
        "Other questions this helps",
        "Question/Topic",
        "Supporting detail, context",
        "When to re-verify, what might change",
        "Where information came from",
        "date",
        "level" .

oc:kn_41a39e6e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing research output" ;
    oc:directiveContent "Lead with the bottom-line answer first, then provide supporting detail organized by source with clear attribution. Structure output as: Answer → Confidence → Key Findings by Source → Context & Nuance → Sources → Gaps → Next Steps." ;
    oc:hasRationale "Structured output with attribution enables the reader to assess reliability and act decisively" .

oc:kn_48699cf4 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "Before finalizing research brief" ;
    oc:directiveContent "Research is complete when: answer is stated clearly, confidence level is assigned, at least 2 source tiers were consulted, gaps are explicitly identified, and next steps are recommended." ;
    oc:hasRationale "These indicators ensure the research is actionable and transparent about its limitations" .

oc:kn_53666479 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When findings touch sensitive or precedent-setting topics" ;
    oc:directiveContent "Escalate when the answer involves product roadmap commitments, pricing, legal terms, security, compliance, contradictory sources, custom configurations, or at-risk customer situations. Use the most conservative answer for customers until contradictions are resolved." ;
    oc:hasRationale "Wrong answers on sensitive topics can create binding commitments or exacerbate customer risk" ;
    oc:severityLevel "HIGH" .

oc:kn_5506b3aa a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When synthesizing research findings" ;
    oc:directiveContent """## Research: {Question/Topic}
### Answer
{Clear, direct answer}
**Confidence:** {High/Medium/Low}
{Confidence driver explanation}
### Key Findings
**From {Source 1}:**
- {Finding}
**From {Source 2}:**
- {Finding}
### Context & Nuance
{Caveats, edge cases}
### Sources
1. {Source name/link} — {contribution}
2. {Source name/link} — {contribution}
### Gaps & Unknowns
- {Unconfirmed items}
### Recommended Next Steps
- {Actions}""" ;
    oc:templateVariables "Actions",
        "Caveats, edge cases",
        "Clear, direct answer",
        "Confidence driver explanation",
        "Finding",
        "High/Medium/Low",
        "Question/Topic",
        "Source 1",
        "Source 2",
        "Source name/link",
        "Unconfirmed items",
        "contribution" .

oc:kn_69947924 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every research execution" ;
    oc:directiveContent "1. Parse request → identify type (customer question, issue investigation, account context, topic research) and audience. 2. Search 5 source tiers systematically, cross-referencing results. 3. Synthesize into structured brief with confidence scoring. 4. Handle gaps transparently. 5. Review customer-facing risks. 6. Suggest knowledge capture." ;
    oc:stepOrder 1 .

oc:kn_8a7ce054 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When searching and synthesizing sources" ;
    oc:directiveContent "Do not stop at the first source that yields a result. Do not present inferred or analogical findings (Tier 5) as confirmed facts. Do not ignore date stamps on sources — outdated information may no longer be accurate." ;
    oc:hasRationale "Premature convergence on a single source leads to incomplete or inaccurate research" ;
    oc:severityLevel "HIGH" .

oc:kn_9c5b0d42 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During source search phase" ;
    oc:directiveContent "Search systematically through all 5 source tiers rather than stopping at the first result. Cross-reference across sources to corroborate findings. Internal official docs (Tier 1) always override informal sources (Tier 3) and external sources (Tier 4)." ;
    oc:hasRationale "Single-source answers are unreliable; cross-referencing reduces hallucination and increases accuracy" .

oc:kn_b94e22af a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When conflicting information is found across sources" ;
    oc:directiveContent "When sources contradict: (1) note the contradiction explicitly, (2) identify which source is more authoritative or recent, (3) present both perspectives with context, (4) recommend how to resolve, (5) use most conservative answer for customers." ;
    oc:hasRationale "Unresolved contradictions mislead; structured handling ensures the user can make informed decisions" .

oc:kn_dec1b272 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When all source searches return empty" ;
    oc:directiveContent "When no connected sources yield results: perform web research, ask user for internal context or SME referrals, and transparently state limitations. Quote exact limitation language: 'This answer is based on web research only — please verify against your internal documentation.'" ;
    oc:hasRationale "Transparency about limitations prevents overconfident decisions based on incomplete information" .

