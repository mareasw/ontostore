                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Account context**: History with a specific customer (e.g., \"What did we tell Acme Corp last time they asked about this?\")" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "1. Parse the Research Request" ],
                        [ a oc:Section ;
