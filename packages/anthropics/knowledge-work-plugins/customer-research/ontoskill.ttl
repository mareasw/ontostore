                                                            oc:itemText "\"I found a possible answer but couldn't confirm it from an authoritative internal source.\"" ] ] ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Be transparent about limitations:" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 7 ;
                            oc:sectionTitle "4. Handle Insufficient Sources" ],
                        [ a oc:Section ;
