@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_customer_research a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "customer-research" ;
    skos:broader "Research workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/customer-research" ;
    oc:contentHash "b462bc474763f2abb70edd026e098f02601d8f773b0da8fbd6d53e3f6bf143d1" ;
    oc:dependsOnSkill oc:skill_search_strategy ;
    oc:differentia "that systematically searches multiple source tiers, synthesizes findings with confidence scoring and source attribution to answer customer questions or investigate topics" ;
    oc:handlesFailure oc:ContradictoryInformation,
        oc:InsufficientSources ;
    oc:hasArgumentHint "<question or topic>" ;
    oc:hasCategory "research" ;
    oc:hasDescription "Multi-source research on a customer question or topic with source attribution. Use when a customer asks something you need to look up, investigating whether a bug has been reported before, checking what was previously told to a specific account, or gathering background before drafting a response." ;
    oc:hasName "customer-research" ;
    oc:impartsKnowledge oc:kn_3de01f88,
        oc:kn_b9e3502c,
        oc:kn_cc6e777c,
        oc:kn_cf9e6d58,
        oc:kn_e4444acc,
        oc:kn_e51915fa ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "answer a customer-facing question with source attribution",
        "gather account context and history",
        "investigate a reported issue",
        "research a customer question",
        "synthesize multi-source research findings" ;
    oc:yieldsState oc:ResearchSynthesized,
        oc:SourcesAttributed .

oc:kn_3de01f88 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sharing research results with customers or stakeholders" ;
    oc:directiveContent "Never present an inferred or low-confidence answer as definitive fact to a customer. Clearly flag inference levels and recommend verification." ;
    oc:hasRationale "Presenting uncertain information as fact can erode trust, set incorrect expectations, or create liability." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b9e3502c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when conducting customer research" ;
    oc:directiveContent "Search systematically through prioritized source tiers (official internal > organizational context > team communications > external > inferred) and cross-reference across sources rather than stopping at the first result." ;
    oc:hasRationale "Tiered source prioritization ensures higher-confidence sources are checked first and cross-referencing prevents relying on a single potentially unreliable source." ;
    oc:severityLevel "HIGH" .

oc:kn_cc6e777c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When contradictory information is found across sources" ;
    oc:directiveContent "When sources contradict each other, note the contradiction explicitly, identify which source is more authoritative or recent, present both perspectives, and use the most conservative answer for customer-facing responses until resolved." ;
    oc:hasRationale "Contradictions often signal important nuances or outdated information; transparency protects against propagating errors." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cf9e6d58 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After research synthesis is complete" ;
    oc:directiveContent "After completing research, suggest capturing the knowledge as a KB entry, FAQ, or runbook when the question is likely to recur, took significant effort, corrected a misunderstanding, or involves nuance." ;
    oc:hasRationale "Knowledge capture builds institutional memory and reduces duplicate research effort across the team over time." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e4444acc a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting research findings" ;
    oc:directiveContent "Always assign and communicate a confidence level (High, Medium, Low, or Unable to Determine) based on source tier, corroboration, recency, and authority." ;
    oc:hasRationale "Confidence scoring helps the recipient assess risk and decide whether to act on the answer or escalate for verification." ;
    oc:severityLevel "HIGH" .

oc:kn_e51915fa a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When determining whether to answer directly or escalate" ;
    oc:directiveContent "Escalate rather than answer directly when the topic involves product roadmap commitments, pricing/legal terms, security/compliance, contradictory sources, custom configurations, or at-risk customers." ;
    oc:hasRationale "Sensitive topics carry disproportionate risk from incorrect answers — escalation ensures the right expertise reviews the response." ;
    oc:severityLevel "HIGH" .

