                                            oc:itemText "The question is factual and non-sensitive" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "You've answered similar questions before with confirmed accuracy" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
