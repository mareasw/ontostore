oc:kn_002f9421 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Signing workflow" ;
    oc:directiveContent "1. Ask user for signature/initials image path → 2. display_pdf, check formFields for signature fields or ask page/position → 3. interact add_annotations type:image at target coordinates → 4. get_screenshot to confirm" ;
    oc:stepOrder 3 .

oc:kn_16a63214 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user asks to summarize, extract text, or read PDF content" ;
    oc:directiveContent "Do NOT use the PDF viewer for pure text ingestion (summarization, extraction, reading). Use the native Read tool instead. The viewer's value is showing the user the document and collaborating on markup." ;
    oc:hasRationale "The viewer is optimized for interactive visual collaboration, not text streaming. Misusing it for ingestion wastes resources and provides a worse experience." ;
    oc:severityLevel "HIGH" .

oc:kn_2179f33a a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before displaying any PDF" ;
    oc:directiveContent "PDF must be a local file path under client MCP roots, an arXiv URL (auto-converts), or a direct HTTPS PDF URL. Landing page URLs will not work." ;
    oc:hasRationale "The viewer can only render direct PDF sources, not HTML landing pages or indirect links." ;
    oc:severityLevel "HIGH" .

oc:kn_2892cb54 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When placing any annotation on a PDF page" ;
    oc:codeLanguage "json" ;
    oc:directiveContent "Annotation coordinates: PDF points (1/72 inch), origin top-left, Y increases downward. US Letter = 612×792pt. All annotations need id (unique string), type, page (1-indexed)." .

oc:kn_29fd5bc2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When placing signatures or initials on PDFs" ;
    oc:directiveContent "Signature placement via image annotation is a visual stamp only — it is NOT a certified or cryptographic digital signature." ;
    oc:hasRationale "Users may assume legal validity of placed signatures. Must disclose that these are visual-only and not cryptographically verified." ;
    oc:severityLevel "HIGH" .

oc:kn_95351d2b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When highlighting text in PDFs" ;
    oc:directiveContent "Use highlight_text (query-based) instead of manual rect-based highlighting when marking up text content — it auto-finds the text by query." ;
    oc:hasRationale "Query-based highlighting is more reliable and easier than manually calculating PDF point coordinates for text rectangles." ;
    oc:severityLevel "LOW" .

oc:kn_95540dd6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When opening a PDF document" ;
    oc:directiveContent "Call display_pdf only ONCE per document. Each call creates a separate viewer; interact calls with a new viewUUID won't reach the previous viewer." ;
    oc:hasRationale "Multiple display_pdf calls for the same document create orphaned viewer sessions, breaking the user's collaborative workflow." ;
    oc:severityLevel "CRITICAL" .

oc:kn_abcd4911 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling PDF forms with poorly labeled fields (e.g., Text1, Field_7)" ;
    oc:directiveContent "For cryptic/unnamed form fields, use get_screenshot to match bounding boxes to visual labels on the page, then ask the user for values using the visual labels." ;
    oc:hasRationale "PDF form field names often don't match the visual labels users see. Screenshot-based matching bridges this gap." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b3bc56b2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing multiple annotation or form actions" ;
    oc:directiveContent "Batch multiple interact commands in a single call via the commands array. End batches with get_screenshot to visually verify changes." ;
    oc:hasRationale "Batching reduces round trips and get_screenshot provides visual confirmation that all commands applied correctly." ;
    oc:severityLevel "MEDIUM" .

oc:kn_db9dd2d2 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Collaborative annotation workflow" ;
    oc:directiveContent "1. display_pdf to open → 2. get_text on relevant pages → 3. Propose annotations to user → 4. On approval, interact with add_annotations + get_screenshot → 5. Show result, iterate → 6. Remind user to download annotated PDF" ;
    oc:stepOrder 1 .

oc:kn_f27e1963 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Form filling workflow" ;
    oc:directiveContent "1. display_pdf and inspect formFields → 2. If cryptic names, get_screenshot and match bounding boxes → 3. Ask user for values using visual labels → 4. interact fill_form + get_screenshot → 5. User confirms or edits. For simple forms, use elicit_form_inputs: true on display_pdf." ;
    oc:stepOrder 2 .

oc:kn_fc20e5cd a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When placing signature images or logos" ;
    oc:directiveContent "Image annotations only accept local file paths or HTTPS URLs — no data: URIs are supported." ;
    oc:hasRationale "Attempting to use data: URIs will fail silently or produce errors." ;
    oc:severityLevel "MEDIUM" .

_:ref_1fafde43ac8deaac a oc:WorkflowStep ;
    dcterms:description "On approval, `interact` → `add_annotations` + `get_screenshot`" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_2dc64e1a4947c6e1 a oc:WorkflowStep ;
    dcterms:description """`interact` → `add_annotations` with `type: "image"` at the target
coordinates""" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_3aae6d1a11301df2 a oc:WorkflowStep ;
    dcterms:description "`interact` → `fill_form`, then `get_screenshot` to show the result" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_424a4ed298c79e25 a oc:WorkflowStep ;
    dcterms:description "Ask for the signature/initials image path" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_53b8d206933e2c05 a oc:WorkflowStep ;
    dcterms:description "`get_screenshot` to confirm placement" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_596476ebb6e5ad14 a oc:WorkflowStep ;
    dcterms:description """When done, remind them they can download the annotated PDF from the
viewer toolbar""" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_5c374b0a7acb4730 a oc:WorkflowStep ;
    dcterms:description """`display_pdf` — inspect returned `formFields` (name, type, page,
bounding box)""" ;
    oc:blockType "workflow_step" ;
