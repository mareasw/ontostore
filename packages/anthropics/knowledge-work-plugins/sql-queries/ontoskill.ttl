                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """-- Ranking
ROW_NUMBER() OVER (PARTITION BY user_id ORDER BY created_at DESC)
RANK() OVER (PARTITION BY category ORDER BY revenue DESC)
DENSE_RANK() OVER (ORDER BY score DESC)

-- Running totals / moving averages
SUM(revenue) OVER (ORDER BY date_col ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) as running_total
AVG(revenue) OVER (ORDER BY date_col ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) as moving_avg_7d

-- Lag / Lead
LAG(value, 1) OVER (PARTITION BY entity ORDER BY date_col) as prev_value
LEAD(value, 1) OVER (PARTITION BY entity ORDER BY date_col) as next_value

-- First / Last value
FIRST_VALUE(status) OVER (PARTITION BY user_id ORDER BY created_at ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING)
LAST_VALUE(status) OVER (PARTITION BY user_id ORDER BY created_at ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING)

-- Percent of total
revenue / SUM(revenue) OVER () as pct_of_total
revenue / SUM(revenue) OVER (PARTITION BY category) as pct_of_category
""" ;
                                    oc:codeLanguage "sql" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 283-304" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Window Functions" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """WITH
-- Step 1: Define the base population
base_users AS (
    SELECT user_id, created_at, plan_type
    FROM users
    WHERE created_at >= DATE '2024-01-01'
      AND status = 'active'
),

-- Step 2: Calculate user-level metrics
user_metrics AS (
    SELECT
        u.user_id,
        u.plan_type,
        COUNT(DISTINCT e.session_id) as session_count,
        SUM(e.revenue) as total_revenue
    FROM base_users u
    LEFT JOIN events e ON u.user_id = e.user_id
    GROUP BY u.user_id, u.plan_type
),

-- Step 3: Aggregate to summary level
summary AS (
    SELECT
        plan_type,
        COUNT(*) as user_count,
        AVG(session_count) as avg_sessions,
        SUM(total_revenue) as total_revenue
    FROM user_metrics
    GROUP BY plan_type
)

SELECT * FROM summary ORDER BY total_revenue DESC;
""" ;
                                    oc:codeLanguage "sql" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 308-342" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "CTEs for Readability" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """-- Keep the most recent record per key
WITH ranked AS (
    SELECT
        *,
        ROW_NUMBER() OVER (
            PARTITION BY entity_id
            ORDER BY updated_at DESC
        ) as rn
    FROM source_table
)
SELECT * FROM ranked WHERE rn = 1;
""" ;
                                    oc:codeLanguage "sql" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 405-417" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Deduplication" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """WITH funnel AS (
    SELECT
        user_id,
        MAX(CASE WHEN event = 'page_view' THEN 1 ELSE 0 END) as step_1_view,
        MAX(CASE WHEN event = 'signup_start' THEN 1 ELSE 0 END) as step_2_start,
        MAX(CASE WHEN event = 'signup_complete' THEN 1 ELSE 0 END) as step_3_complete,
        MAX(CASE WHEN event = 'first_purchase' THEN 1 ELSE 0 END) as step_4_purchase
    FROM events
    WHERE event_date >= CURRENT_DATE - INTERVAL '30 days'
    GROUP BY user_id
)
SELECT
    COUNT(*) as total_users,
    SUM(step_1_view) as viewed,
    SUM(step_2_start) as started_signup,
    SUM(step_3_complete) as completed_signup,
    SUM(step_4_purchase) as purchased,
    ROUND(100.0 * SUM(step_2_start) / NULLIF(SUM(step_1_view), 0), 1) as view_to_start_pct,
    ROUND(100.0 * SUM(step_3_complete) / NULLIF(SUM(step_2_start), 0), 1) as start_to_complete_pct,
    ROUND(100.0 * SUM(step_4_purchase) / NULLIF(SUM(step_3_complete), 0), 1) as complete_to_purchase_pct
FROM funnel;
""" ;
                                    oc:codeLanguage "sql" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 379-401" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Funnel Analysis" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """WITH cohorts AS (
    SELECT
        user_id,
        DATE_TRUNC('month', first_activity_date) as cohort_month
    FROM users
),
activity AS (
    SELECT
        user_id,
        DATE_TRUNC('month', activity_date) as activity_month
    FROM user_activity
)
SELECT
    c.cohort_month,
    COUNT(DISTINCT c.user_id) as cohort_size,
    COUNT(DISTINCT CASE
        WHEN a.activity_month = c.cohort_month THEN a.user_id
    END) as month_0,
    COUNT(DISTINCT CASE
        WHEN a.activity_month = c.cohort_month + INTERVAL '1 month' THEN a.user_id
    END) as month_1,
    COUNT(DISTINCT CASE
        WHEN a.activity_month = c.cohort_month + INTERVAL '3 months' THEN a.user_id
    END) as month_3
FROM cohorts c
LEFT JOIN activity a ON c.user_id = a.user_id
GROUP BY c.cohort_month
ORDER BY c.cohort_month;
""" ;
                                    oc:codeLanguage "sql" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 346-375" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Cohort Retention" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Common SQL Patterns" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "SQL Queries Skill" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: sql-queries
description: Write correct, performant SQL across all major data warehouse dialects (Snowflake, BigQuery, Databricks, PostgreSQL, etc.). Use when writing queries, optimizing slow SQL, translating between dialects, or building complex analytical queries with CTEs, window functions, or aggregations.
user-invocable: false
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow _:ref_3c55cc7505e23114 ;
    oc:impartsKnowledge oc:kn_0a6559e9,
        oc:kn_2e888fb7,
        oc:kn_43057753,
        oc:kn_55fa432a,
        oc:kn_8dfb71b2,
        oc:kn_a24dcf99,
        oc:kn_d206f095,
        oc:kn_d7b8f9ea,
        oc:kn_e2c60e4f,
        oc:kn_f6c1612d ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:DatabaseConnectionAvailable,
        oc:SchemaAccessible ;
    oc:resolvesIntent "build analytical queries with CTEs and window functions",
        "debug SQL errors",
        "deduplicate data with SQL",
        "optimize SQL performance",
        "translate SQL between dialects",
        "write SQL queries" ;
    oc:yieldsState oc:QueryOptimized,
        oc:SQLQueryGenerated .

oc:kn_0a6559e9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deduplicating records" ;
    oc:directiveContent "For deduplication, use ROW_NUMBER() OVER (PARTITION BY key ORDER BY updated_at DESC) with a WHERE rn = 1 filter to keep the most recent record per key." ;
    oc:hasRationale "This pattern is portable across all major dialects and handles ties deterministically" .

oc:kn_2e888fb7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any SQL query with JOINs or arithmetic" ;
    oc:directiveContent "Always qualify column names with table alias in JOINs to avoid ambiguous column errors. Use NULLIF(denominator, 0) to prevent division by zero. Cast explicitly when comparing different types." ;
    oc:hasRationale "These are the most common sources of runtime errors in analytical SQL" ;
    oc:severityLevel "MEDIUM" .

oc:kn_43057753 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building multi-step analytical queries" ;
    oc:directiveContent "Use CTEs (WITH clauses) to break complex queries into named, sequential logical steps for readability and maintainability." ;
    oc:hasRationale "CTEs make complex SQL self-documenting and easier to debug compared to deeply nested subqueries" .

oc:kn_55fa432a a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When writing Snowflake queries" ;
    oc:directiveContent "Snowflake: use clustering keys (not traditional indexes), filter on clustering key columns for partition pruning, and use RESULT_SCAN(LAST_QUERY_ID()) to avoid re-running expensive queries." ;
    oc:hasRationale "Snowflake uses micro-partition clustering rather than B-tree indexes; proper clustering key usage is the primary performance lever" ;
    oc:severityLevel "HIGH" .

oc:kn_8dfb71b2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing SQL for any data warehouse" ;
    oc:directiveContent "Never use dialect-specific syntax without verifying target platform support (e.g., ILIKE unavailable in BigQuery, SAFE_DIVIDE only in BigQuery, Snowflake uses DATEADD not INTERVAL arithmetic)." ;
    oc:hasRationale "Syntax incompatibility causes query failures when translating between dialects or running on unfamiliar platforms" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a24dcf99 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When debugging SQL errors or translating between dialects" ;
    oc:directiveContent "PostgreSQL is case-sensitive for quoted identifiers; BigQuery allows GROUP BY alias while other dialects require GROUP BY the actual expression; Databricks DATEDIFF argument order differs from Snowflake." ;
    oc:hasRationale "These subtle dialect differences are frequent sources of silent bugs and confusing errors" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d206f095 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When computing running totals, moving averages, rankings, or percent-of-total" ;
    oc:codeLanguage "sql" ;
    oc:directiveContent "LAG(value, 1) OVER (PARTITION BY entity ORDER BY date_col) for previous row; SUM(revenue) OVER (ORDER BY date_col ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) for running totals; revenue / SUM(revenue) OVER () for percent of total." .

oc:kn_d7b8f9ea a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When writing Redshift queries" ;
    oc:directiveContent "Redshift: design DISTKEY for collocated joins, use SORTKEY for filtered columns, avoid cross-node data movement (DS_BCAST, DS_DIST), and run ANALYZE/VACUUM regularly." ;
    oc:hasRationale "Redshift is a columnar MPP database; data distribution and sort order are the dominant performance factors" ;
    oc:severityLevel "HIGH" .

oc:kn_e2c60e4f a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When writing BigQuery queries" ;
    oc:directiveContent "BigQuery: always filter on partition columns to reduce bytes scanned, avoid SELECT *, use APPROX_COUNT_DISTINCT for large cardinalities, and preview cost with dry run." ;
    oc:hasRationale "BigQuery bills per byte scanned; unfiltered queries on large tables incur significant cost" ;
    oc:severityLevel "HIGH" .

oc:kn_f6c1612d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When a SQL query fails with syntax, column, type, or grouping errors" ;
    oc:directiveContent "1. Check dialect-specific syntax (ILIKE vs LOWER/LIKE, DATEADD vs INTERVAL, etc.) 2. Verify column names against schema for typos/case 3. Cast types explicitly 4. Use NULLIF for division by zero 5. Qualify columns with aliases in JOINs 6. Ensure GROUP BY includes all non-aggregated columns" ;
    oc:stepOrder 1 .

oc:req_36a56323 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Target data warehouse dialect specifics" .

oc:req_76b97429 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "SQL fundamentals (SELECT, JOIN, GROUP BY, subqueries)" .

_:ref_100d41aa7401ee10 a oc:WorkflowStep ;
    dcterms:description "**Column not found**: Verify column names against schema -- check for typos, case sensitivity (PostgreSQL is case-sensitive for quoted identifiers)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_21cc5c3dfa3d2e3c a oc:WorkflowStep ;
    dcterms:description "**Type mismatches**: Cast explicitly when comparing different types (`CAST(col AS DATE)`, `col::DATE`)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_2d06764705a439e6 a oc:WorkflowStep ;
    dcterms:description "**Group by errors**: All non-aggregated columns must be in GROUP BY (except in BigQuery which allows grouping by alias)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_651e35fd7e46dabb a oc:WorkflowStep ;
    dcterms:description "**Division by zero**: Use `NULLIF(denominator, 0)` or dialect-specific safe division" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_89775d5438500cae a oc:WorkflowStep ;
    dcterms:description "**Syntax errors**: Check for dialect-specific syntax (e.g., `ILIKE` not available in BigQuery, `SAFE_DIVIDE` only in BigQuery)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_f06f487b78dfd367 a oc:WorkflowStep ;
    dcterms:description "**Ambiguous columns**: Always qualify column names with table alias in JOINs" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

