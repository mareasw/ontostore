oc:kn_367255d6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Step 5 enrichment of multiple leads" ;
    oc:directiveContent "Batch enrichment calls to apollo_people_bulk_match with up to 10 people per call for efficiency." ;
    oc:hasRationale "Bulk matching reduces API round-trips and stays within rate limits." .

oc:kn_57b30baa a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning the people search in Step 4" ;
    oc:directiveContent "Verify that a matching Apollo sequence exists and at least one email account is linked before searching for leads." ;
    oc:hasRationale "Discovering missing sequences or email accounts after finding leads wastes the user's time and potentially their credits." .

oc:kn_adecf8c2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After finding matching people and before Step 5 enrichment" ;
    oc:directiveContent "Always ask for user confirmation before enriching contacts, as enrichment consumes Apollo credits." ;
    oc:hasRationale "Apollo enrichment costs credits per contact; users must approve the spend before proceeding." ;
    oc:severityLevel "HIGH" .

oc:kn_ca7835fa a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating contacts in Apollo via apollo_contacts_create" ;
    oc:directiveContent "Never skip the deduplication step when creating contacts — always set run_dedupe to true." ;
    oc:hasRationale "Skipping deduplication can create duplicate contacts, leading to multiple sequence enrollments and unprofessional outreach." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fc8abf03 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always — executing this workflow has financial and communication consequences" ;
    oc:directiveContent "This skill consumes Apollo credits for each enriched contact and sends outreach emails from the selected account once contacts are enrolled." ;
    oc:hasRationale "Users must understand the cost implications and that enrolled contacts may receive emails automatically." ;
    oc:severityLevel "HIGH" .

