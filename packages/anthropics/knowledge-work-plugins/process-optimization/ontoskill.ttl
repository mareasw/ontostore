    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Four-phase workflow to analyze, identify waste, redesign, and measure improvement of a business process" ;
            oc:hasStep _:ref_0d2d42a1502251d8,
                _:ref_41bd9d7a1afb23f2,
                [ a oc:WorkflowStep ;
                    dcterms:description "Measure impact: quantify time saved per cycle, error rate reduction, cost savings, and employee satisfaction improvement. Produce before/after comparison with implementation plan." ;
                    oc:expectedOutcome "Before/after process comparison with recommendations, estimated impact metrics, and implementation plan" ;
                    oc:stepDependsOn _:ref_f7aaf6e0c22260b2 ;
                    oc:stepId "measure-impact" ],
                _:ref_f7aaf6e0c22260b2 ;
            oc:workflowId "process-optimization-main" ;
            oc:workflowName "Process Optimization Workflow" ] ;
    oc:impartsKnowledge oc:kn_438e5d43,
        oc:kn_487ebdb7,
        oc:kn_63f2ee19,
        oc:kn_7233aec0,
        oc:kn_9512ac8b,
        oc:kn_c5873a7c,
        oc:kn_c73b5825 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProcessDocumented ;
    oc:resolvesIntent "analyze inefficient process",
        "design optimized future-state process",
        "identify process bottlenecks",
        "improve business workflow",
        "reduce process waste",
        "streamline operations" ;
    oc:yieldsState oc:ProcessOptimized .

oc:kn_438e5d43 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing future-state processes" ;
    oc:directiveContent "Add checkpoints (not gates) when designing the future state — checkpoints allow flow with visibility, whereas gates introduce waiting and bottlenecks" ;
    oc:hasRationale "Gates create approval queues that re-introduce the very delays the optimization seeks to eliminate" ;
    oc:severityLevel "MEDIUM" .

oc:kn_487ebdb7 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When delivering process optimization output" ;
    oc:directiveContent "A successful optimization produces a before/after process comparison with specific recommendations, estimated impact metrics, and an implementation plan" ;
    oc:hasRationale "Without quantified before/after comparison and an implementation plan, optimization recommendations remain abstract and unactionable" .

oc:kn_63f2ee19 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning process optimization analysis" ;
    oc:directiveContent "Before optimizing, ensure you have sufficient detail about the current process: every step, decision point, handoff, owner, and duration" ;
    oc:hasRationale "Incomplete current-state mapping leads to optimizations that miss root causes or create new problems" .

oc:kn_7233aec0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying waste in a process" ;
    oc:directiveContent "Do not overlook handoffs — each handoff between people or teams is a potential point of failure or delay that must be scrutinized" ;
    oc:hasRationale "Handoffs are the most commonly underestimated source of process delay and error" ;
    oc:severityLevel "HIGH" .

oc:kn_9512ac8b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing future-state process flows" ;
    oc:directiveContent "Parallelize only independent steps — steps with dependencies on each other cannot be run in parallel" ;
    oc:hasRationale "Parallelizing dependent steps creates coordination failures and rework, defeating the optimization goal" ;
    oc:severityLevel "HIGH" .

oc:kn_c5873a7c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When optimizing any business process" ;
    oc:directiveContent "1. Map current state — document every step, decision point, handoff, owner, and duration. 2. Identify waste — catalog waiting, rework, handoffs, over-processing, and manual work. 3. Design future state — eliminate unnecessary steps, automate, reduce handoffs, parallelize independent steps, add checkpoints. 4. Measure impact — quantify time saved, error rate reduction, cost savings, and satisfaction improvement." ;
    oc:hasRationale "Following a structured 4-phase framework ensures systematic analysis from understanding through to measurable outcomes" ;
    oc:stepOrder 1 .

oc:kn_c73b5825 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing a process for inefficiencies" ;
    oc:directiveContent "Focus waste identification on five categories: waiting (queues/approvals), rework (failed steps), handoffs (transfer points), over-processing (zero-value steps), and manual work (automation candidates)" ;
    oc:hasRationale "A structured waste taxonomy ensures no major inefficiency category is missed during analysis" .

_:ref_0d2d42a1502251d8 a oc:WorkflowStep ;
    dcterms:description "Identify waste across five categories: waiting, rework, handoffs, over-processing, and manual work that could be automated." ;
    oc:expectedOutcome "Cataloged waste items categorized by type with estimated impact" ;
    oc:stepDependsOn _:ref_41bd9d7a1afb23f2 ;
    oc:stepId "identify-waste" .

_:ref_41bd9d7a1afb23f2 a oc:WorkflowStep ;
    dcterms:description "Map the current state: document every step, decision point, handoff, who does what, and how long each step takes. Note manual steps, approvals, and waiting times." ;
    oc:expectedOutcome "Complete current-state process map with owners, durations, and pain points identified" ;
    oc:stepId "map-current" .

_:ref_f7aaf6e0c22260b2 a oc:WorkflowStep ;
    dcterms:description "Design the future state: eliminate unnecessary steps, automate where possible, reduce handoffs, parallelize independent steps, add checkpoints (not gates)." ;
    oc:expectedOutcome "Optimized future-state process design with specific changes documented" ;
    oc:stepDependsOn _:ref_0d2d42a1502251d8 ;
    oc:stepId "design-future" .

