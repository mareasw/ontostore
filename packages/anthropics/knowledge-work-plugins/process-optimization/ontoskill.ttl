@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_process_optimization a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "process-optimization" ;
    skos:broader "Business analysis methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/process-optimization" ;
    oc:contentHash "4c8fafdf449512869433a738dd7984198c6c3915185f565a0a8faa21a2fabe09" ;
    oc:differentia "that maps current workflows, identifies waste patterns, designs streamlined future states, and quantifies improvement impact" ;
    oc:handlesFailure oc:AmbiguousWorkflow,
        oc:InsufficientProcessDetail ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Analyze and improve business processes. Trigger with \"this process is slow\", \"how can we improve\", \"streamline this workflow\", \"too many steps\", \"bottleneck\", or when the user describes an inefficient process they want to fix." ;
    oc:hasName "process-optimization" ;
    oc:impartsKnowledge oc:kn_2b54e6c4,
        oc:kn_54c448c8,
        oc:kn_5f68523a,
        oc:kn_749b9534,
        oc:kn_e8afd93e ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProcessDescribed ;
    oc:resolvesIntent "analyze business process efficiency",
        "identify bottlenecks in workflows",
        "recommend process improvements",
        "streamline inefficient processes" ;
    oc:yieldsState oc:ImprovementPlanGenerated,
        oc:ProcessOptimized .

oc:kn_2b54e6c4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When redesigning process flow for speed" ;
    oc:directiveContent "Parallelize independent steps rather than running them sequentially." ;
    oc:hasRationale "Independent steps running in parallel reduce total cycle time without sacrificing quality or adding risk." .

oc:kn_54c448c8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing a process for inefficiencies" ;
    oc:directiveContent "Focus waste identification on five categories: waiting time, rework, handoffs, over-processing, and manual work." ;
    oc:hasRationale "These five waste categories cover the vast majority of process inefficiencies in business workflows, providing a systematic lens for analysis." .

oc:kn_5f68523a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing the future state of a process" ;
    oc:directiveContent "Do not add approval gates as process improvements; use checkpoints instead." ;
    oc:hasRationale "Approval gates introduce bottlenecks and waiting time — the very waste being eliminated. Checkpoints provide visibility without blocking flow." ;
    oc:severityLevel "MEDIUM" .

oc:kn_749b9534 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When measuring the impact of process changes" ;
    oc:directiveContent "A successful optimization produces measurable impact across four dimensions: time saved per cycle, error rate reduction, cost savings, and employee satisfaction improvement." ;
    oc:hasRationale "Multi-dimensional measurement ensures optimizations are not improving one metric at the expense of others, particularly employee experience." .

oc:kn_e8afd93e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning any process optimization engagement" ;
    oc:directiveContent "Always map the current state completely before designing the future state — document every step, decision point, handoff, and timing." ;
    oc:hasRationale "You cannot improve what you do not fully understand; incomplete current-state mapping leads to solutions that miss root causes." ;
    oc:severityLevel "HIGH" .

