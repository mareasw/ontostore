@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_competitive_intelligence a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "competitive-intelligence" ;
    skos:broader "Competitive research and analysis generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/competitive-intelligence" ;
    oc:contentHash "15dcc0105d83acf0da9b527460f08d13fad548b6b4300e06959ac62d46f053d9" ;
    oc:differentia "that produces self-contained interactive HTML battlecards with clickable competitor tabs, comparison matrices, talk tracks, and landmine questions for sales enablement" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout ;
    oc:hasArgumentHint "company name and 1-5 competitor names" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Research your competitors and build an interactive battlecard. Outputs an HTML artifact with clickable competitor cards and a comparison matrix. Trigger with \"competitive intel\", \"research competitors\", \"how do we compare to [competitor]\", \"battlecard for [competitor]\", or \"what's new with [competitor]\"." ;
    oc:hasName "competitive-intelligence" ;
    oc:impartsKnowledge oc:kn_0c2feb1f,
        oc:kn_3150479c,
        oc:kn_74106672,
        oc:kn_862c84ea,
        oc:kn_c0409ce5,
        oc:kn_ecf41f29,
        oc:kn_ee5f2f5b,
        oc:kn_f34d1a39 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "analyze competitive landscape",
        "build battlecard",
        "compare products against competitors",
        "generate competitive intel report",
        "prepare sales positioning against competitors",
        "research competitors" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0c2feb1f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "At the start of every skill execution" ;
    oc:directiveContent "Before starting research, confirm the user's company name, what they sell, and their list of competitors (1-5). For returning users, confirm existing context is still accurate." ;
    oc:hasRationale "Incorrect company or competitor context produces misleading battlecards that can damage sales conversations." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3150479c a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When connected data sources are unavailable" ;
    oc:directiveContent "If no CRM, docs, chat, or transcript connectors are available, fall back entirely to web research from public sources — product pages, pricing, blogs, release notes, reviews (G2/Capterra/TrustRadius), and job postings." ;
    oc:hasRationale "Web-only research still produces actionable battlecards; connectors are enhancement layers, not requirements." ;
    oc:severityLevel "MEDIUM" .

oc:kn_74106672 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining whether to re-execute the skill" ;
    oc:directiveContent "This skill should be re-run monthly or before major deals to refresh stale intel; each run generates a new timestamped HTML file rather than updating the previous one." ;
    oc:hasRationale "Competitive intelligence decays quickly; explicit refresh cadences (monthly, before deals, after win/loss) ensure data stays current." ;
    oc:severityLevel "MEDIUM" .

oc:kn_862c84ea a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring differentiation matrices and talk tracks" ;
    oc:directiveContent "Focus battlecard content on customer outcomes rather than feature checklists — frame every comparison around what the customer achieves, not just what features exist." ;
    oc:hasRationale "Outcome-based positioning resonates with buyers making purchasing decisions; feature lists alone don't drive conviction." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c0409ce5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoping and generating the battlecard artifact" ;
    oc:directiveContent "Limit competitor analysis to 1-5 competitors per battlecard; the output must be a single self-contained HTML file with no external dependencies." ;
    oc:hasRationale "More than 5 competitors dilutes focus and makes the HTML artifact unwieldy; self-containment ensures it can be shared and hosted anywhere." ;
    oc:severityLevel "HIGH" .

oc:kn_ecf41f29 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After generating the HTML artifact" ;
    oc:directiveContent "Verify the generated HTML file is self-contained (no external CSS/JS dependencies), renders correctly in a browser, and contains all requested competitor tabs with populated data." ;
    oc:hasRationale "A broken or incomplete battlecard undermines credibility when shared with sales teams or leadership." ;
    oc:severityLevel "HIGH" .

oc:kn_ee5f2f5b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating talk tracks and objection handling content" ;
    oc:directiveContent "Never badmouth competitors directly; instead, plant landmine questions that naturally expose their weaknesses during customer conversations." ;
    oc:hasRationale "Direct negativity destroys credibility with buyers; strategic questioning lets prospects discover weaknesses themselves." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f34d1a39 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "During Phase 2 and Phase 3 research execution" ;
    oc:directiveContent "Always research both your own company and each competitor using at least 5 web searches per entity — product features, pricing, news (90 days), releases/changelogs, and existing comparisons." ;
    oc:hasRationale "Comprehensive coverage ensures the battlecard reflects current market reality and avoids outdated positioning." ;
    oc:severityLevel "HIGH" .

