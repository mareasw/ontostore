oc:kn_00c912e4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating all competitive analysis content" ;
    oc:directiveContent "Be honest about competitor weaknesses AND strengths — credibility comes from acknowledging where competitors are strong, not just trashing them." ;
    oc:hasRationale "Sales reps lose credibility if they can't acknowledge legitimate competitor strengths; buyers see through one-sided analysis." ;
    oc:severityLevel "HIGH" .

oc:kn_2871a1f5 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always — this is the primary output artifact" ;
    oc:directiveContent "Creates a self-contained HTML file ([YourCompany]-battlecard-[date].html) that can be shared, hosted, or opened in any browser." ;
    oc:hasRationale "The HTML artifact is the deliverable; ensure it's saved and accessible to the user." ;
    oc:severityLevel "LOW" .

oc:kn_31ba18d1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing differentiation and talk tracks" ;
    oc:directiveContent "Focus on outcomes not features — 'They have X feature' matters less than 'customers achieve Y result'." ;
    oc:hasRationale "Outcome-oriented positioning resonates more with buyers than feature comparisons." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4c2e934b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining whether to re-run the skill" ;
    oc:directiveContent "Competitive intel gets stale — refresh monthly at minimum, or before major deals, after win/loss, and on competitor announcements." ;
    oc:hasRationale "Stale competitive data leads to incorrect positioning and missed opportunities." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6135da98 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating sales talk tracks and objection handling" ;
    oc:directiveContent "Plant landmines (questions that expose competitor weaknesses) rather than badmouthing competitors directly." ;
    oc:hasRationale "Questions that lead buyers to discover weaknesses themselves are far more persuasive than direct criticism." ;
    oc:severityLevel "HIGH" .

oc:kn_69a563f7 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When planning execution time for multiple competitors" ;
    oc:directiveContent "Researching each competitor requires 8 web searches (product features, pricing, news, releases, reviews, positioning, customers, careers). Researching your own company requires 5 web searches. Total scales linearly with number of competitors." ;
    oc:hasRationale "Each competitor requires independent multi-source research; 5 competitors = ~45 web searches total." ;
    oc:severityLevel "LOW" .

oc:kn_d4005d8e a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When researching competitor recent releases (last 90 days window)" ;
    oc:directiveContent "Track competitor releases religiously — what they ship reveals their strategy and your opportunity." ;
    oc:hasRationale "Release patterns are the most reliable strategic signal; hiring signals from careers pages complement this." ;
    oc:severityLevel "MEDIUM" .

_:ref_0a3ce350b366a103 a oc:WorkflowStep ;
    dcterms:description "**Track releases religiously** — What they ship tells you their strategy and your opportunity" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_1b0a7673ba70a172 a oc:WorkflowStep ;
    dcterms:description "**Update from the field** — Best intel comes from actual customer conversations, not just websites" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_54de4bc0299d00fe a oc:WorkflowStep ;
    dcterms:description "**Be honest about weaknesses** — Credibility comes from acknowledging where competitors are strong" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_634a4a68df103c0f a oc:WorkflowStep ;
    dcterms:description "**Plant landmines, don't badmouth** — Ask questions that expose weaknesses; never trash-talk" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_f6840f0514173c25 a oc:WorkflowStep ;
    dcterms:description "**Focus on outcomes, not features** — \"They have X feature\" matters less than \"customers achieve Y result\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

