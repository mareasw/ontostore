_:ref_36509c9bb2fde751 a oc:WorkflowStep ;
    dcterms:description "Research your own company via web search: product offerings, pricing model, recent announcements (90 days), releases, existing comparisons." ;
    oc:expectedOutcome "Structured data about your company's current positioning and recent activity" ;
    oc:stepDependsOn _:ref_47b1328b99fa9fae ;
    oc:stepId "research-own-company" .

_:ref_5f078641dd13754c a oc:WorkflowStep ;
    dcterms:description "Research each competitor via 8 web searches: features, pricing, news, releases, reviews, positioning, customers, careers/hiring signals." ;
    oc:expectedOutcome "Structured data per competitor covering profile, releases, strengths, weaknesses, pricing" ;
    oc:stepDependsOn _:ref_47b1328b99fa9fae ;
    oc:stepId "research-competitors" .

_:ref_f6a7350c9de8f163 a oc:WorkflowStep ;
    dcterms:description "Pull data from connected sources if available: CRM win/loss patterns, existing battlecards from docs, chat field intel, call transcript mentions." ;
    oc:expectedOutcome "Augmented intel from internal sources (optional — web research alone is sufficient)" ;
    oc:stepDependsOn _:ref_47b1328b99fa9fae ;
    oc:stepId "pull-connected-sources" .

_:ref_47b1328b99fa9fae a oc:WorkflowStep ;
    dcterms:description "Gather seller context — ask for company name, product/service, and 1-5 competitor names. Confirm with returning users." ;
    oc:expectedOutcome "Company name, product description, and competitor list confirmed" ;
