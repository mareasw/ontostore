@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_knowledge_work_plugins_cowork_plugin_customizer a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "cowork-plugin-customizer" ;
    skos:broader "Plugin configuration tool" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/cowork-plugin-customizer" ;
    oc:contentHash "448dd38df23eeacf5efe9a0d7b637949d1e86867dc185bb11cab1cc27aab96cd" ;
    oc:dependsOnSkill oc:skill_ontoskills_plugin_structure ;
    oc:differentia "Customizes Claude Code plugins for specific organizations by replacing placeholders, connecting MCPs, and packaging results" ;
    oc:handlesFailure oc:KnowledgeMCPsUnavailable,
        oc:PluginNotFound,
        oc:RemoteContainerDetected ;
    oc:hasArgumentHint "plugin-name or customization request (e.g., 'customize the standup skill', 'set up plugin for my team')" ;
    oc:hasCategory "automation" ;
    oc:hasDescription """Customize a Claude Code plugin for a specific organization's tools and workflows. Use when: customize plugin, set up plugin, configure plugin, tailor plugin, adjust plugin settings, customize plugin connectors, customize plugin skill, tweak plugin, modify plugin configuration.
""" ;
    oc:hasName "cowork-plugin-customizer" ;
    oc:hasRequirement oc:req_0d1bdfac,
        oc:req_1c27a29c,
        oc:req_5abdb5ed,
        oc:req_5bb0916a,
        oc:req_94be50d0,
        oc:req_ab506b85,
        oc:req_d883b522,
        oc:req_debc444e ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 2 ;
                    oc:quoteContent "**Finding the plugin**: To find the plugin's source files, run `find mnt/.local-plugins mnt/.plugins -type d -name \"*<plugin-name>*\"` to locate the plugin directory, then read its files to understand its structure before making changes. If you cannot find the plugin directory, the user is likely running this conversation in a remote container. Abort and let them know: \"Customizing plugins is currently only available in the desktop app's Cowork mode.\"" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Customize a plugin for a specific organization — either by setting up a generic plugin template for the first time, or by tweaking and refining an already-configured plugin." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "After customization, present the user with a summary of what was learned grouped by source. Always include the MCPs sections showing which MCPs were connected during setup and which ones the user should still connect:" ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 5 ;
                            oc:quoteContent "By the way, connecting sources like Slack or Microsoft Teams would let me find answers automatically next time you customize a plugin." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """## From searching Slack

- You use Asana for project management
- Sprint cycles are 2 weeks

## From searching documents

- Story points use T-shirt sizes

## From your answers

- Ticket statuses are: Backlog, In Progress, In Review, Done
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 124-137" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Then present the MCPs that were connected during setup and any that the user should still connect, with instructions on how to connect them." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "If no knowledge MCPs were available in Phase 1, and the user had to answer at least one question manually, include a note at the end:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 10 ;
                    oc:sectionTitle "Summary Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**`examples/customized-mcp.json`** — Example fully configured `.mcp.json`" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**`references/mcp-servers.md`** — MCP discovery workflow, category-to-keywords mapping, config file locations" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**`references/search-strategies.md`** — Knowledge MCP query patterns for finding tool names and org values" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 11 ;
                    oc:sectionTitle "Additional Resources" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**If the user's free-form input (Phase 0) or knowledge MCPs (Phase 1) provided a clear answer**: Apply directly without confirmation." ],
                                _:ref_3b7fa4a0c0804049,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Work through each item using context from Phase 0 and Phase 1." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Types of changes:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "If user doesn't know or skips, leave the value unchanged (or the `~~`-prefixed placeholder, for generic setup)." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Otherwise**: Use AskUserQuestion. Don't assume \"industry standard\" defaults are correct — if neither the user's input nor knowledge MCPs provided a specific answer, ask. Note: AskUserQuestion always includes a Skip button and a free-text input box for custom answers, so do not include `None` or `Other` as options." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 7 ;
                            oc:sectionTitle "Phase 3: Complete Todo Items" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**For generic plugin setup**: Run `grep -rn '~~\\w' /path/to/plugin --include='*.md' --include='*.json'` to find all placeholder customization points. Group them by theme." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**For general customization**: Read the plugin files, understand the current config, and based on the user's request, identify what needs to change." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**For scoped customization**: Only include items related to the specific section the user asked about." ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Use user-friendly descriptions that focus on the plugin's purpose:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Build a todo list of changes to make, scoped appropriately:" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Bad**: \"Replace placeholders in skills/standup-prep/SKILL.md\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Good**: \"Learn how standup prep works at Company\"" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "Phase 2: Create Todo List" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "For **scoped customization** and **general customization** (not generic plugin setup), check whether the user provided free-form context alongside their request (e.g., \"customize the standup skill — we do async standups in #eng-updates every morning\")." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 2 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**If the user provided context**: Record it and use it to pre-fill answers in Phase 3 — skip asking questions that the user already answered here." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:hasChild [ a oc:Paragraph ;
                                                    oc:blockType "paragraph" ;
                                                    oc:contentOrder 1 ;
                                                    oc:textContent "Use their response (if any) as additional context throughout the remaining phases." ] ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**If the user did not provide context**: Ask a single open-ended question using AskUserQuestion before proceeding. Tailor the question to what they asked to customize — e.g., \"What changes do you have in mind for the brief skill?\" or \"What would you like to change about how this plugin works?\" Keep it short and specific to their request." ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Phase 0: Gather User Intent (scoped and general customization only)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "Collect all MCP results and present them together in the summary output (see below) — don't present MCPs one at a time during this phase." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "After customization items have been resolved, connect MCPs for any tools that were identified or changed. See `references/mcp-servers.md` for the full workflow, category-to-keywords mapping, and config file format." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "For each tool identified during customization:" ],
                                _:ref_e4f6b737672d853d ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 8 ;
                            oc:sectionTitle "Phase 4: Search for Useful MCPs" ],
                        [ a oc:Section ;
                            oc:hasContent _:ref_2a11d85bf5dd1a1a,
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Configuration values (workspace IDs, project names, team identifiers)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Team conventions (naming, statuses, estimation scales)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Tool names and services the organization uses" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Organizational processes and workflows" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Use company-internal knowledge MCPs to collect information relevant to the customization scope. See `references/search-strategies.md` for detailed query patterns by category." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Sources to search:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "Record all findings for use in Phase 3." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**What to gather** (scope to what's relevant):" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Phase 1: Gather Context from Knowledge MCPs" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Customization Workflow" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_170d281077e63009,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "After all customizations are applied, package the plugin as a `.plugin` file for the user:" ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 3 ;
                            oc:quoteContent "**Important**: Always create the zip in `/tmp/` first, then copy to the outputs folder. Writing directly to the outputs folder may fail due to permissions and leave behind temporary files." ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 4 ;
                            oc:quoteContent "**Naming**: Use the original plugin directory name for the `.plugin` file (e.g., if the plugin directory is `coder`, the output file should be `coder.plugin`). Do not rename the plugin or its files during customization — only replace placeholder values and update content." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 9 ;
                    oc:sectionTitle "Packaging the Plugin" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 7 ;
                            oc:quoteContent "**Important**: Never change the name of the plugin or skill being customized. Do not rename directories, files, or the plugin/skill name fields." ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 5 ;
                            oc:quoteContent "**Legacy `commands/` directories**: Some plugins include a `commands/` directory. The Cowork UI now presents these alongside skills as a single \"Skills\" concept, so treat `commands/*.md` files the same way you would `skills/*/SKILL.md` files when customizing." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "After locating the plugin, check for `~~`-prefixed placeholders: `grep -rn '~~\\w' /path/to/plugin --include='*.md' --include='*.json'`" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "**3. General customization** — No `~~` placeholders exist, and the user wants to modify the plugin broadly. Read the plugin's files to understand its current configuration, then ask the user what they'd like to change." ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent "**Default rule**: If `~~` placeholders exist, default to **Generic plugin setup** unless the user explicitly asks to customize a specific part of the plugin." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**1. Generic plugin setup** — The plugin contains `~~`-prefixed placeholders. These are customization points in a template that need to be replaced with real values (e.g., `~~Jira` → `Asana`, `~~your-team-channel` → `#engineering`)." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**2. Scoped customization** — No `~~` placeholders exist, and the user asked to customize a specific part of the plugin (e.g., \"customize the connectors\", \"update the standup skill\", \"change the ticket tool\"). Read the plugin files to find the relevant section(s) and focus only on those. Do not scan the entire plugin or present unrelated customization items." ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 8 ;
                            oc:quoteContent "**Nontechnical output**: All user-facing output (todo list items, questions, summaries) must be written in plain, nontechnical language. Never mention `~~` prefixes, placeholders, or customization points to the user. Frame everything in terms of the plugin's capabilities and the organization's tools." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Determining the Customization Mode" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Cowork Plugin Customization" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: cowork-plugin-customizer
description: >
  Customize a Claude Code plugin for a specific organization's tools and workflows.
  Use when: customize plugin, set up plugin, configure plugin, tailor plugin, adjust plugin settings,
  customize plugin connectors, customize plugin skill, tweak plugin, modify plugin configuration.
compatibility: Requires Cowork desktop app environment with access to mounted plugin directories (mnt/.local-plugins, mnt/.plugins).
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow _:ref_170d281077e63009,
        _:ref_2a11d85bf5dd1a1a,
        _:ref_3b7fa4a0c0804049,
        [ a oc:Workflow ;
            dcterms:description "Set up a generic plugin template by replacing all ~~ placeholders with real organizational values" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Check for ~~ placeholders: grep -rn '~~\\w' /path/to/plugin --include='*.md' --include='*.json'" ;
                    oc:expectedOutcome "List of all placeholder customization points found" ;
                    oc:stepId "detect-placeholders" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Search MCP registry for tools identified during customization, connect unconnected ones via suggest_connectors, update .mcp.json config" ;
                    oc:expectedOutcome "Relevant MCPs connected and configured in plugin" ;
                    oc:stepId "connect-mcps" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Build todo list of all placeholder replacements grouped by theme, using user-friendly descriptions" ;
                    oc:expectedOutcome "Todo list of customization items ready for resolution" ;
                    oc:stepId "build-todo" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Work through each todo item: apply MCP-found answers directly, ask user via AskUserQuestion for unknowns" ;
                    oc:expectedOutcome "All placeholders replaced with real values or left unchanged if skipped" ;
                    oc:stepId "resolve-items" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Locate plugin directory: find mnt/.local-plugins mnt/.plugins -type d -name '*<plugin-name>*'" ;
                    oc:expectedOutcome "Plugin directory path identified" ;
                    oc:stepId "find-plugin" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Search knowledge MCPs (Slack, Documents, Email) for tool names, org processes, team conventions, and config values" ;
                    oc:expectedOutcome "Organizational context collected for pre-filling placeholders" ;
                    oc:stepId "gather-knowledge" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Zip plugin directory (excluding setup/) to /tmp/, copy .plugin file to outputs, present summary to user" ;
                    oc:expectedOutcome "Customized .plugin file ready for user installation" ;
                    oc:stepId "package-plugin" ] ;
            oc:workflowId "generic-plugin-setup" ;
            oc:workflowName "Generic Plugin Setup" ],
        _:ref_e4f6b737672d853d,
        [ a oc:Workflow ;
            dcterms:description "Customize a specific part of an already-configured plugin" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Package the updated plugin and present summary" ;
                    oc:expectedOutcome "Updated .plugin file ready for user" ;
                    oc:stepId "package-scoped" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Check for free-form context; if none, ask one open-ended question about what they want to change" ;
                    oc:expectedOutcome "User's customization intent captured" ;
                    oc:stepId "gather-user-intent" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Search for and connect MCPs for any tools changed during customization" ;
                    oc:expectedOutcome "New MCPs connected and configured" ;
                    oc:stepId "connect-mcps-scoped" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Build scoped todo list for the requested section only, resolve items using gathered context" ;
                    oc:expectedOutcome "Targeted section customized with real values" ;
                    oc:stepId "customize-section" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Search knowledge MCPs for information relevant to the specific section being customized" ;
                    oc:expectedOutcome "Targeted organizational context collected" ;
                    oc:stepId "gather-knowledge-scoped" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Locate plugin directory and read its files to understand structure" ;
                    oc:expectedOutcome "Plugin directory and relevant files identified" ;
                    oc:stepId "find-plugin-scoped" ] ;
            oc:workflowId "scoped-customization" ;
            oc:workflowName "Scoped Customization" ] ;
    oc:impartsKnowledge oc:kn_050265ca,
        oc:kn_11bdaae2,
        oc:kn_2a7859eb,
        oc:kn_3051308e,
        oc:kn_4fa2d90d,
        oc:kn_58bdd980,
        oc:kn_b9ba3fb5,
        oc:kn_c5d0a38d,
        oc:kn_e0f9a8ed,
        oc:kn_e8adcefa ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:CoworkDesktopEnvironment,
        oc:PluginDirectoryFound ;
    oc:resolvesIntent "configure plugin connectors and MCPs",
        "customize plugin for organization",
        "package a customized plugin",
        "set up a generic plugin template",
        "tailor plugin skills to team workflows" ;
    oc:yieldsState oc:MCPsConnected,
        oc:PluginCustomized,
        oc:PluginPackaged .

oc:kn_050265ca a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user provides context alongside their customization request" ;
    oc:directiveContent "Use free-form user context from Phase 0 to pre-fill answers in Phase 3, skipping questions the user already answered." ;
    oc:hasRationale "Reduces back-and-forth questions and respects the user's initial input" ;
    oc:severityLevel "MEDIUM" .

oc:kn_11bdaae2 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Phase 3 — completing todo items" ;
    oc:directiveContent "Running customization multiple times is safe; placeholder replacements and content updates are deterministic. If a user skips or doesn't know an answer, leave the value unchanged." ;
    oc:hasRationale "Partial customization should not destroy existing configuration" ;
    oc:severityLevel "MEDIUM" .

oc:kn_2a7859eb a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "Phase 1 — when no knowledge MCPs are configured" ;
    oc:directiveContent "If no knowledge MCPs are available, skip automatic discovery and proceed directly to AskUserQuestion for all customization items. Include a note recommending connecting sources like Slack or Teams for future use." ;
    oc:hasRationale "Graceful degradation ensures customization can proceed without MCPs" ;
    oc:severityLevel "LOW" .

oc:kn_3051308e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Phase 3 — completing todo items" ;
    oc:directiveContent "If neither the user's input nor knowledge MCPs provided a specific answer for a customization item, ask the user via AskUserQuestion rather than assuming industry-standard defaults." ;
    oc:hasRationale "Assumed defaults are frequently wrong for organizational tools and conventions" ;
    oc:severityLevel "HIGH" .

oc:kn_4fa2d90d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running `find` returns no results for the plugin directory" ;
    oc:directiveContent "If the plugin directory cannot be found, abort and inform the user that customization is only available in the desktop app's Cowork mode." ;
    oc:hasRationale "Remote containers do not have access to mounted plugin directories needed for customization" ;
    oc:severityLevel "CRITICAL" .

oc:kn_58bdd980 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Packaging phase — creating the .plugin file" ;
    oc:directiveContent "Customization modifies plugin source files in-place and creates a .plugin zip file in the outputs directory. Always zip to /tmp/ first, then copy to outputs." ;
    oc:hasRationale "Writing directly to the outputs folder may fail due to permissions and leave behind temporary files" ;
    oc:severityLevel "HIGH" .

oc:kn_b9ba3fb5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "All customization modes" ;
    oc:directiveContent "Never change the name of the plugin or skill being customized. Do not rename directories, files, or the plugin/skill name fields." ;
    oc:hasRationale "Renaming breaks internal references and plugin identification" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c5d0a38d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "All user-facing output including todo lists, questions, and summaries" ;
    oc:directiveContent "Never expose `~~` placeholders, placeholder syntax, or customization points to the user. Frame everything in plain language about capabilities and tools." ;
    oc:hasRationale "Users are nontechnical; exposing internal template syntax causes confusion and breaks the abstraction" ;
    oc:severityLevel "HIGH" .

oc:kn_e0f9a8ed a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When scanning plugin files for customization points" ;
    oc:directiveContent "Some plugins include a legacy `commands/` directory. The Cowork UI presents these alongside skills as a single 'Skills' concept, so treat commands/*.md files the same as skills/*/SKILL.md files." ;
    oc:hasRationale "Failing to treat commands as skills leads to missed customization opportunities" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e8adcefa a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Determining which customization mode to use" ;
    oc:directiveContent "If `~~` placeholders exist, default to generic plugin setup mode unless the user explicitly asks to customize a specific part." ;
    oc:hasRationale "Generic setup is the safe default when a template has never been configured" ;
    oc:severityLevel "MEDIUM" .

