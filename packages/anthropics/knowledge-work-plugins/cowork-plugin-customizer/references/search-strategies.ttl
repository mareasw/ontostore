oc:kn_39793d5d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning search strategy across Knowledge MCP sources" ;
    oc:directiveContent "For each tool category, use two search passes: (1) search for brand names to identify which tools are used, (2) look for contextual signals like links, mentions, and configuration references to find specific workspace IDs and values." ;
    oc:hasRationale "Brand names reliably identify tool presence; contextual signals extract the specific instance details needed for plugin configuration" .

oc:kn_71b2e39b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When searching Knowledge MCPs for organization-specific identifiers and conventions" ;
    oc:directiveContent """Workspace/project IDs: search existing integrations or bookmarked links, look for admin/setup documentation
Team conventions: "story points" OR "estimation", "workflow" OR "ticket status", look for engineering process docs
Channel/team names: "standup" OR "engineering" OR "releases", look for channel naming patterns""" .

oc:kn_e72d8b31 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When Knowledge MCPs are unavailable" ;
    oc:directiveContent "If no Knowledge MCPs are configured, skip automatic discovery and proceed directly to AskUserQuestion for all categories. Do not include 'None' or 'Other' as options since AskUserQuestion always includes a Skip button and free-text input." ;
    oc:hasRationale "Prevents futile search attempts and ensures graceful degradation to interactive user prompting" ;
    oc:severityLevel "HIGH" .

oc:kn_ed4e08c7 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When searching Knowledge MCPs to discover which tools an organization uses" ;
    oc:directiveContent """Source control: "GitHub" OR "GitLab" OR "Bitbucket", "pull request" OR "merge request"
Project management: "Asana" OR "Jira" OR "Linear" OR "Monday", "sprint" AND "tickets"
Chat: "Slack" OR "Teams" OR "Discord"
Analytics: "Datadog" OR "Grafana" OR "Mixpanel", "monitoring" OR "observability"
Design: "Figma" OR "Sketch" OR "Adobe XD"
CRM: "Salesforce" OR "HubSpot\"""" .

oc:kn_f900882f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing AskUserQuestion option lists" ;
    oc:directiveContent "Do not include 'None' or 'Other' as options in AskUserQuestion calls. The tool always provides a Skip button and free-text input box natively." ;
    oc:hasRationale "Avoids redundant options that duplicate built-in AskUserQuestion functionality" ;
    oc:severityLevel "MEDIUM" .

