@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_cowork_plugin_customizer_search_strategies a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "search-strategies" ;
    skos:broader "Reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/cowork-plugin-customizer" ;
    oc:contentHash "66a53f10aac4738b8fd091de6054145511f8416e8633627f8a5a4dd9250f355a" ;
    oc:differentia "that provides structured search query patterns for discovering organizational tool names and values via Knowledge MCP during plugin customization" ;
    oc:extends oc:skill_anthropics_knowledge_work_plugins_cowork_plugin_customizer ;
    oc:handlesFailure oc:SourceUnavailable ;
    oc:hasAllowedTool "Search" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_1f7aa628,
        oc:kn_4b46180a,
        oc:kn_5787ce67,
        oc:kn_68bfe12e,
        oc:kn_d81aa942 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "discover organizational tools",
        "find tool names in workspace",
        "gather organizational context for plugin customization" ;
    oc:yieldsState oc:OrganizationContextDiscovered .

oc:kn_1f7aa628 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When Knowledge MCP sources are unavailable or not configured" ;
    oc:directiveContent "If no Knowledge MCPs are configured, skip automatic discovery entirely and proceed directly to AskUserQuestion for all configuration categories." ;
    oc:hasRationale "Graceful degradation ensures the customization flow continues without blocking on unavailable infrastructure" ;
    oc:severityLevel "HIGH" .

oc:kn_4b46180a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting organization-specific values and identifiers" ;
    oc:directiveContent "After identifying tool names, search for contextual signals like repository links, task links, channel mentions, dashboard links, and design file links to confirm active usage and find workspace/project IDs." ;
    oc:hasRationale "Tool presence alone doesn't confirm active usage; contextual signals validate integration needs and surface configuration values" ;
    oc:severityLevel "MEDIUM" .

oc:kn_5787ce67 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When discovering organizational tool landscape during plugin customization" ;
    oc:directiveContent "Use targeted OR-based search queries combining product names (e.g., 'GitHub' OR 'GitLab' OR 'Bitbucket') to identify which tools an organization uses across categories like source control, project management, chat, analytics, design, and CRM." ;
    oc:hasRationale "Broad OR queries maximize recall across multiple possible tools in each category, reducing missed integrations" ;
    oc:severityLevel "MEDIUM" .

oc:kn_68bfe12e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning and executing a discovery search strategy" ;
    oc:directiveContent "Organize search queries by functional category (source control, project management, chat, analytics, design, CRM) and search in two passes: first for tool names, then for organizational values like IDs, conventions, and team names." ;
    oc:hasRationale "Categorical organization ensures systematic coverage without gaps, and the two-pass approach separates tool identification from configuration extraction" ;
    oc:severityLevel "LOW" .

oc:kn_d81aa942 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing AskUserQuestion prompts as fallback for missing MCP data" ;
    oc:directiveContent "Never include 'None' or 'Other' as options in AskUserQuestion prompts, since the interface always provides a Skip button and free-text input box for custom answers." ;
    oc:hasRationale "Redundant options clutter the UI and may confuse users; the built-in Skip and free-text inputs already cover these cases" ;
    oc:severityLevel "MEDIUM" .

