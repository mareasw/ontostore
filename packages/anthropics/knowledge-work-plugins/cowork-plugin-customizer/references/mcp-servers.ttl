@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_knowledge_work_plugins_cowork_plugin_customizer_mcp_servers a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "mcp-servers" ;
    skos:broader "MCP discovery and connection guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/cowork-plugin-customizer" ;
    oc:contentHash "d373337fe74fc77a2d0f648819c05aa9988e53eba53ad55edadec47bd8a451a1" ;
    oc:differentia "that maps organizational tool categories to registry search keywords and manages MCP server configuration during plugin customization" ;
    oc:extends oc:skill_knowledge_work_plugins_cowork_plugin_customizer ;
    oc:handlesFailure oc:MCPConnectionFailed,
        oc:MCPSearchNoResults ;
    oc:hasAllowedTool "search_mcp_registry",
        "suggest_connectors" ;
    oc:hasArgumentHint "customization category or tool name" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "How to find and connect MCPs during plugin customization." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Search the MCP directory for available connectors." ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 4 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "`tools`: List of tool names the MCP provides" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "`url`: MCP endpoint URL (use this in `.mcp.json`)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "`description`: One-liner description" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "`directoryUuid`: UUID for use with suggest_connectors" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "`connected`: Boolean - whether user has this MCP connected" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`name`: MCP display name" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Output:** Up to 10 results, each with:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Input:** `{ \"keywords\": [\"array\", \"of\", \"search\", \"terms\"] }`" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "`search_mcp_registry`" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Output:** Renders UI with Connect buttons for each MCP" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Display Connect buttons to let users install/connect MCPs." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Input:** `{ \"directoryUuids\": [\"uuid1\", \"uuid2\"] }`" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "`suggest_connectors`" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Available Tools" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_ad6c36cee3433b29 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Workflow" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Some directory entries have no `url` because the endpoint is dynamic — the admin provides it when connecting the server. These servers can still be referenced in the plugin's MCP config by **name**: if the MCP server name in the config matches the directory entry name, it is treated the same as a URL match." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Directory Entries Without a URL" ],
                        [ a oc:Section ;
                            oc:hasContent _:ref_ad54e9467317822b ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Finding the Config File" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    }
  }
}
""" ;
                                    oc:codeLanguage "json" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 76-85" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Use the `url` field from `search_mcp_registry` results." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Both wrapped and unwrapped formats are supported:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Config File Format" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Updating Plugin MCP Configuration" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 12 ;
                            oc:tableCaption "## Category-to-Keywords Mapping" ;
                            oc:tableMarkdown """| Category | Search Keywords |
|----------|-----------------|
| `project-management` | `["asana", "jira", "linear", "monday", "tasks"]` |
| `software-coding` | `["github", "gitlab", "bitbucket", "code"]` |
| `chat` | `["slack", "teams", "discord"]` |
| `documents` | `["google docs", "notion", "confluence"]` |
| `calendar` | `["google calendar", "calendar"]` |
| `email` | `["gmail", "outlook", "email"]` |
| `design-graphics` | `["figma", "sketch", "design"]` |
| `analytics-bi` | `["datadog", "grafana", "analytics"]` |
| `crm` | `["salesforce", "hubspot", "crm"]` |
| `wiki-knowledge-base` | `["notion", "confluence", "outline", "wiki"]` |
| `data-warehouse` | `["bigquery", "snowflake", "redshift"]` |
| `conversation-intelligence` | `["gong", "chorus", "call recording"]` |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Category-to-Keywords Mapping" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "MCP Discovery and Connection" ] ;
    oc:hasWorkflow _:ref_ad54e9467317822b,
        _:ref_ad6c36cee3433b29 ;
    oc:impartsKnowledge oc:kn_25564c38,
        oc:kn_3b71b20d,
        oc:kn_652ca163,
        oc:kn_8281eb1c,
        oc:kn_aaf0fd01,
        oc:kn_e1db38d2,
        oc:kn_e55cf0f6 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:PluginCustomizationStarted ;
    oc:resolvesIntent "connect MCP servers to a plugin",
        "discover MCP connectors for plugin customization",
        "search MCP registry for available tools",
        "update plugin MCP configuration" ;
    oc:yieldsState oc:MCPConfigUpdated .

oc:kn_25564c38 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before calling search_mcp_registry" ;
    oc:directiveContent "Always check earlier customization phase findings before searching — the user's tool preference may already be known" ;
    oc:hasRationale "Avoids redundant registry searches and provides a smoother user experience by reusing known preferences" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3b71b20d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering MCP registry entries without a URL endpoint" ;
    oc:directiveContent "If a directory entry has no url, reference the MCP server by name in config — name matching is equivalent to URL matching" ;
    oc:hasRationale "Some MCP servers have dynamic endpoints provided by the admin during connection, so name-based matching serves as a fallback" .

oc:kn_652ca163 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When searching the MCP registry" ;
    oc:directiveContent "search_mcp_registry returns at most 10 results per query — use specific keywords to narrow results" ;
    oc:hasRationale "Broad searches may miss relevant results due to the 10-result limit" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8281eb1c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When determining which config file to update for MCP server entries" ;
    oc:directiveContent "1. Check plugin.json for mcpServers field → edit file at that path 2. If no mcpServers field → use .mcp.json at plugin root 3. If mcpServers points only to .mcpb files → create new .mcp.json at plugin root" ;
    oc:hasRationale "Plugin configuration locations vary; this hierarchy prevents overwriting bundled server configs" ;
    oc:stepOrder 2 .

oc:kn_aaf0fd01 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "After receiving search_mcp_registry results" ;
    oc:directiveContent "Present search results as: name, description, tools list, connected status. Ask user which they use." ;
    oc:hasRationale "Consistent presentation helps users make informed decisions about which MCP to connect" .

oc:kn_e1db38d2 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing MCP server configuration entries" ;
    oc:codeLanguage "json" ;
    oc:directiveContent """{
  "mcpServers": {
    "server-name": {
      "type": "http",
      "url": "https://endpoint-url/mcp/"
    }
  }
}""" ;
    oc:hasRationale "Both wrapped and unwrapped formats are supported; use the url field from search_mcp_registry results" .

oc:kn_e55cf0f6 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When discovering MCP connectors during plugin customization" ;
    oc:directiveContent "1. Find customization point (~~-prefixed values) 2. Check earlier phase findings for known tool preference 3. If known, search for that specific tool to get URL → skip to step 5 4. If unknown, call search_mcp_registry with category-mapped keywords 5. Present all results, ask user which they use 6. If not connected, call suggest_connectors 7. Update MCP config using URL from search results" ;
    oc:hasRationale "Ensures systematic discovery and avoids redundant searches when tool preference is already known" ;
    oc:stepOrder 1 .

_:ref_02b28d4eff643fd7 a oc:WorkflowStep ;
    dcterms:description "**Check `plugin.json`** for an `mcpServers` field:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:Paragraph ;
            oc:blockType "paragraph" ;
            oc:contentOrder 2 ;
            oc:textContent "If present, edit the file at that path." ],
        [ a oc:CodeExample ;
            oc:blockType "code_block" ;
            oc:codeContent """{
  "name": "my-plugin",
  "mcpServers": "./config/servers.json"
}
""" ;
            oc:codeLanguage "json" ;
            oc:contentOrder 1 ;
            oc:sourceLocation "lines 60-65" ] ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_05f9a72a54731502 a oc:WorkflowStep ;
    dcterms:description "**If `mcpServers` points only to `.mcpb` files** (bundled servers), create a new `.mcp.json` at the plugin root." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_5a2a0428e654df8f a oc:WorkflowStep ;
    dcterms:description "**Find customization point**: Look for `~~`-prefixed values (e.g., `~~Jira`)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_6792bdd5fd9b9217 a oc:WorkflowStep ;
    dcterms:description "**Check earlier phase findings**: Did you already learn which tool they use?" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "**Yes**: Search for that specific tool to get its `url`, skip to step 5" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "**No**: Continue to step 3" ] ] ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_6db685064ee9ccf7 a oc:WorkflowStep ;
    dcterms:description "**Update MCP config**: Add config using the `url` from search results" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_902e4b046ad66030 a oc:WorkflowStep ;
    dcterms:description "**Search**: Call `search_mcp_registry` with mapped keywords" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_92455a74751727d5 a oc:WorkflowStep ;
    dcterms:description "**Present choices and ask user**: Show all results, ask which they use" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_c735615e2b4d807a a oc:WorkflowStep ;
    dcterms:description "**If no `mcpServers` field**, use `.mcp.json` at the plugin root (default)." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_cae4492d34010f7a a oc:WorkflowStep ;
    dcterms:description "**Connect if needed**: If not connected, call `suggest_connectors`" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_ad54e9467317822b a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_02b28d4eff643fd7,
        _:ref_05f9a72a54731502,
        _:ref_c735615e2b4d807a ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

