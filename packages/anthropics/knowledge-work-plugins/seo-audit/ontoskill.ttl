                                    oc:contentOrder 8 ;
                                    oc:textContent "For each keyword opportunity, assess:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**If ~~SEO tools are connected:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "**If tools are not connected:**" ],
