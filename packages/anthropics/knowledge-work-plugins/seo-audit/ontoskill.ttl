    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "audit website SEO health",
        "compare SEO against competitors",
        "generate prioritized SEO action plan",
        "identify content gaps",
        "perform technical SEO check",
        "research keyword opportunities" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_10cbe34c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When audit type is unspecified" ;
    oc:directiveContent "Default to full site audit when user does not specify an audit type. The five supported types are: full site audit, keyword research, content gap analysis, technical SEO check, and competitor SEO comparison." ;
    oc:hasRationale "Full audit provides the most comprehensive baseline and avoids incomplete analysis from user indecision." ;
    oc:severityLevel "MEDIUM" .

oc:kn_497d8b7e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating the prioritized action plan" ;
    oc:directiveContent "Split action plan into Quick Wins (under 2 hours, immediate impact) and Strategic Investments (long-term growth, quarterly planning). Always include specific actions with expected impact, effort estimate, and dependencies." ;
    oc:hasRationale "This split helps marketers act immediately while planning long-term, avoiding analysis paralysis." ;
    oc:severityLevel "MEDIUM" .

oc:kn_52fd66b2 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "After audit output is presented" ;
    oc:directiveContent "After presenting the audit, offer five specific follow-up options: draft content briefs, create optimized title tags and meta descriptions, build a content calendar, dive deeper into any section, or run the analysis for a different competitor/domain." ;
    oc:hasRationale "Follow-up options convert the static audit into an ongoing optimization workflow, increasing the skill's value." ;
    oc:severityLevel "LOW" .

oc:kn_5a2daed6 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When performing on-page SEO audit" ;
    oc:directiveContent "On-page SEO evaluation must check all eight dimensions: title tags (50-60 chars), meta descriptions (150-160 chars), H1 tags (exactly one per page), H2/H3 hierarchy, keyword usage in first 100 words, internal linking, image alt text, and URL structure." ;
    oc:hasRationale "Missing any on-page dimension produces incomplete audits and unreliable prioritization." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8993ebae a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When competitor domains are needed but not supplied" ;
    oc:directiveContent "If competitors are not provided and the audit type requires competitor data, auto-identify 2-3 likely competitors using web search based on the user's domain and keyword space." ;
    oc:hasRationale "Competitor comparison is essential for gap analysis; auto-discovery prevents blocking on missing user input." ;
    oc:severityLevel "LOW" .

oc:kn_a1c688f9 a oc:KnowledgeNode,
        oc:RequiresHumanClarification ;
    oc:appliesToContext "When initiating an SEO audit" ;
    oc:directiveContent "Always ask for URL or domain before proceeding if not provided. Also ask for target keywords/topics and competitors, but these are optional and the skill can proceed without them." ;
    oc:hasRationale "The URL is essential; the skill cannot function without a target site. Optional inputs should be prompted but not block execution." ;
    oc:severityLevel "HIGH" .

oc:kn_cf218213 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating audit output" ;
    oc:directiveContent "Do not skip the Executive Summary or Prioritized Action Plan sections — these are the primary deliverables for marketers. The keyword table alone is insufficient output." ;
    oc:hasRationale "Marketers need actionable summaries and prioritized next steps, not raw data tables. Skipping these defeats the skill's purpose." ;
    oc:severityLevel "HIGH" .

oc:kn_ecd61016 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When SEO tools are not connected via MCP" ;
    oc:directiveContent "If no SEO tools are connected via MCP, fall back to web search for keyword landscape research and explicitly note the limitation to the user, recommending they connect Ahrefs or Semrush for precise volume and difficulty data." ;
    oc:hasRationale "Without specialized SEO tools, keyword volume and difficulty are approximate; transparency about data quality prevents false confidence in recommendations." ;
    oc:severityLevel "HIGH" .

_:ref_1f81a25895fc117b a oc:WorkflowStep ;
    dcterms:description "**Audit type** — one of:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 5 ;
                    oc:itemText "**Competitor SEO comparison** — head-to-head SEO benchmarking against specific competitors" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "**Full site audit** — end-to-end SEO review covering all sections below" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "**Keyword research** — identify keyword opportunities for a topic or domain" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 3 ;
                    oc:itemText "**Content gap analysis** — find topics competitors rank for that you don't" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 4 ;
                    oc:itemText "**Technical SEO check** — crawlability, speed, structured data, and infrastructure issues" ] ],
        [ a oc:Paragraph ;
            oc:blockType "paragraph" ;
            oc:contentOrder 2 ;
            oc:textContent "If not specified, default to **full site audit**." ] ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_32a04f5db45df4e6 a oc:WorkflowStep ;
    dcterms:description "**Target keywords or topics** (optional) — specific keywords the user is already targeting or wants to rank for" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_ba50e22bc7ec5f1c a oc:WorkflowStep ;
    dcterms:description "**Competitors** (optional) — domains or companies to compare against. If not provided and the audit type requires competitor data, use web search to identify 2-3 likely competitors based on the user's domain and keyword space." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_be205ad6d3c88da5 a oc:WorkflowStep ;
    dcterms:description "**URL or domain** — the site to audit, or a topic/keyword if running in keyword research mode" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_024f94ede63c23c4 a oc:WorkflowStep ;
    dcterms:description "Evaluate page speed, mobile-friendliness, structured data opportunities, crawlability, broken links, HTTPS, Core Web Vitals, and indexation issues." ;
    oc:expectedOutcome "Technical SEO checklist with check, status (Pass/Fail/Warning), and details" ;
    oc:stepDependsOn _:ref_d8e7ee3e364ee586 ;
    oc:stepId "technical-seo-check" .

_:ref_7e72eb6f44467256 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_1f81a25895fc117b,
        _:ref_32a04f5db45df4e6,
        _:ref_ba50e22bc7ec5f1c,
        _:ref_be205ad6d3c88da5 ;
    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_85408c83b6c2f73f a oc:WorkflowStep ;
    dcterms:description "Compare keyword overlap, keyword gaps, domain authority signals, content depth, backlink profiles, SERP feature ownership, and technical advantages against 2-3 competitors." ;
    oc:expectedOutcome "Competitor comparison summary table across key dimensions" ;
    oc:stepDependsOn _:ref_57ecbfc2867082c7 ;
    oc:stepId "competitor-comparison" .

_:ref_c8c070b6a66ee481 a oc:WorkflowStep ;
    dcterms:description "Produce Executive Summary (3-5 sentences with biggest strength, top 3 priorities, overall assessment), all tables, content gap recommendations, and Prioritized Action Plan split into Quick Wins and Strategic Investments." ;
    oc:expectedOutcome "Complete audit report with all sections and prioritized action plan" ;
    oc:stepDependsOn _:ref_024f94ede63c23c4,
        _:ref_57ecbfc2867082c7,
        _:ref_85408c83b6c2f73f,
        _:ref_edad1b8fe9ba3b71,
        _:ref_f67801ffec75dc8b ;
    oc:stepId "generate-output" .

_:ref_edad1b8fe9ba3b71 a oc:WorkflowStep ;
    dcterms:description "Identify missing content: competitor topic coverage, content freshness (12+ months), thin content, missing content types, funnel gaps, and topic cluster opportunities." ;
    oc:expectedOutcome "Content gap recommendations with topic, rationale, format, priority, and effort estimate" ;
    oc:stepDependsOn _:ref_57ecbfc2867082c7 ;
    oc:stepId "content-gap-analysis" .

_:ref_f67801ffec75dc8b a oc:WorkflowStep ;
    dcterms:description "Evaluate key pages for title tags, meta descriptions, H1 tags, heading hierarchy, keyword usage, internal linking, image alt text, and URL structure." ;
    oc:expectedOutcome "On-page issues table with page, issue, severity (Critical/High/Medium/Low), and recommended fix" ;
    oc:stepDependsOn _:ref_d8e7ee3e364ee586 ;
    oc:stepId "on-page-audit" .

_:ref_57ecbfc2867082c7 a oc:WorkflowStep ;
    dcterms:description "Research keywords related to the domain/topic. If SEO tools connected, pull volume and difficulty automatically; otherwise use web search. Assess primary/secondary keywords, search volume signals, difficulty, long-tail opportunities, question-based keywords, and intent classification." ;
    oc:expectedOutcome "15-25 keyword opportunities with difficulty, opportunity score, current ranking, intent, and recommended content type" ;
    oc:stepDependsOn _:ref_d8e7ee3e364ee586 ;
    oc:stepId "keyword-research" .

_:ref_d8e7ee3e364ee586 a oc:WorkflowStep ;
    dcterms:description "Collect URL/domain, audit type (default: full), target keywords (optional), and competitors (optional). Ask before proceeding if URL is missing." ;
    oc:expectedOutcome "All required inputs gathered from user" ;
    oc:stepId "gather-inputs" .

