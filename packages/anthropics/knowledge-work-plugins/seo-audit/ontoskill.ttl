                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Keyword gaps** — terms the competitor ranks for that the user does not" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Backlink profile observations** — types of sites linking to competitors, link-worthy content they've produced" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Domain authority signals** — relative site strength based on backlink profiles, referring domains, and content depth" ],
