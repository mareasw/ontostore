                _:ref_d8e7ee3e364ee586,
                _:ref_edad1b8fe9ba3b71,
                _:ref_f67801ffec75dc8b,
                [ a oc:WorkflowStep ;
                    dcterms:description "Present follow-up options: draft content briefs, create optimized tags, build content calendar, dive deeper, or audit another domain." ;
                    oc:expectedOutcome "User selects next action or ends session" ;
                    oc:stepDependsOn _:ref_c8c070b6a66ee481 ;
                    oc:stepId "offer-followup" ] ;
            oc:workflowId "seo-audit-full" ;
            oc:workflowName "Full SEO Audit Workflow" ],
        _:ref_7e72eb6f44467256 ;
    oc:impartsKnowledge oc:kn_10cbe34c,
        oc:kn_497d8b7e,
        oc:kn_52fd66b2,
