                                            oc:itemOrder 8 ;
                                            oc:itemText "**Indexation** — pages that should be indexed but may not be, duplicate content risks" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**Broken links** — internal and external 404s, redirect chains" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "**Core Web Vitals signals** — LCP, FID/INP, CLS indicators based on observable page behavior" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "**HTTPS** — secure connection, mixed content issues" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Page speed** — identify slow-loading pages and likely causes (large images, render-blocking scripts, excessive redirects)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Mobile-friendliness** — responsive design, tap targets, font sizes, viewport configuration" ],
