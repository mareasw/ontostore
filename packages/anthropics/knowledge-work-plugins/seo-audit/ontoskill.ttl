@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_seo_audit a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "seo-audit" ;
    skos:broader "SEO analysis framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/seo-audit" ;
    oc:contentHash "22d49e0612eac30435d234a5f4d4e0759fc8c318962ee34773f7f58ca68d5de5" ;
    oc:dependsOnSkill oc:skill_web_search ;
    oc:differentia "that performs comprehensive website audits covering keyword research, on-page SEO, content gaps, technical checks, and competitor benchmarking to produce a prioritized action plan" ;
    oc:extends oc:skill_seo_optimizer ;
    oc:handlesFailure oc:InvalidInput,
        oc:NetworkTimeout,
        oc:PermissionDenied ;
    oc:hasArgumentHint "<url or topic> [audit type]" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Run a comprehensive SEO audit — keyword research, on-page analysis, content gaps, technical checks, and competitor comparison. Use when assessing a site's SEO health, when finding keyword opportunities and content gaps competitors own, or when you need a prioritized action plan split into quick wins and strategic investments." ;
    oc:hasName "seo-audit" ;
    oc:impartsKnowledge oc:kn_2b054ee3,
        oc:kn_4eae1ff5,
        oc:kn_6c125b4a,
        oc:kn_aca103c3,
        oc:kn_d2a3458d,
        oc:kn_d99c2517 ;
    oc:isUserInvocable true ;
    oc:nature "concept" ;
    oc:requiresState oc:EnvironmentReady,
        oc:NetworkAvailable ;
    oc:resolvesIntent "audit website SEO health",
        "compare SEO against competitors",
        "generate prioritized SEO action plan",
        "identify content gaps competitors own",
        "perform technical SEO check",
        "research keyword opportunities" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_2b054ee3 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During keyword research phase of the audit" ;
    oc:directiveContent "When SEO tools (Ahrefs, Semrush) are connected via MCP, pull keyword data, search volume, difficulty scores, and ranking positions automatically. When not connected, fall back to web search and explicitly note the limitation." ;
    oc:hasRationale "Connected SEO tools provide precise volume and difficulty data that web search cannot match, but the audit must still produce useful results without them." .

oc:kn_4eae1ff5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting on-page issues or technical SEO problems" ;
    oc:directiveContent "Do not report SEO findings without severity classification and concrete fix recommendations. Every issue must include severity (Critical, High, Medium, Low) and a specific recommended fix." ;
    oc:hasRationale "Unseverityed findings without fixes create confusion and inaction — the audit must be immediately executable by a marketer." .

oc:kn_6c125b4a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing user input to determine audit scope" ;
    oc:directiveContent "Default to full site audit when the user does not specify an audit type. The five audit types are: full site audit, keyword research, content gap analysis, technical SEO check, and competitor SEO comparison." ;
    oc:hasRationale "Prevents analysis paralysis and ensures the user gets comprehensive value even without understanding the available audit modes." .

oc:kn_aca103c3 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When SEO tools are not connected and volume data is approximate" ;
    oc:directiveContent "If product analytics are connected, cross-reference keyword targets with actual organic traffic data to validate which keywords are driving visits and conversions, compensating for imprecise volume estimates." ;
    oc:hasRationale "Traffic data from analytics provides ground-truth validation that compensates for the lower precision of web-search-based keyword research." .

oc:kn_d2a3458d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running competitor SEO comparison or content gap analysis without specified competitors" ;
    oc:directiveContent "If competitors are not provided by the user, use web search to identify 2-3 likely competitors based on the domain and keyword space before proceeding with competitor comparison." ;
    oc:hasRationale "Competitor analysis is essential for meaningful SEO benchmarking, and the audit should not stall just because the user hasn't identified competitors." .

oc:kn_d99c2517 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any SEO audit output" ;
    oc:directiveContent "Always produce output structured as an executive summary, keyword opportunity table, on-page issues table, content gap recommendations, technical SEO checklist, competitor comparison, and prioritized action plan split into quick wins and strategic investments." ;
    oc:hasRationale "Structured output ensures the audit is actionable and marketers can immediately execute the recommendations without further interpretation." ;
    oc:severityLevel "HIGH" .

