@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_anthropics_knowledge_work_plugins_process_doc a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "process-doc" ;
    skos:broader "documentation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/anthropics/knowledge-work-plugins/process-doc" ;
    oc:contentHash "de88cac07f058e3b62fc6fd3ddfbe9e258a93d41216b40390f84d02fe44fc646" ;
    oc:differentia "that captures business processes as structured SOPs with RACI matrices, process flows, detailed steps, exception tables, and metrics" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<process name or description>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Document a business process — flowcharts, RACI, and SOPs. Use when formalizing a process that lives in someone's head, building a RACI to clarify who owns what, writing an SOP for a handoff or audit, or capturing the exceptions and edge cases of how work actually gets done." ;
    oc:hasName "process-doc" ;
    oc:impartsKnowledge oc:kn_39490265,
        oc:kn_5bd14aca,
        oc:kn_8dc219a9,
        oc:kn_a98327a0,
        oc:kn_cbaf18ad ;
    oc:isUserInvocable true ;
    oc:nature "concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build a RACI matrix",
        "capture process flowcharts and steps",
        "create an SOP",
        "document a business process",
        "formalize tribal knowledge into written procedure" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_39490265 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When knowledge base connectors are available" ;
    oc:directiveContent "Do not duplicate existing process documentation — search connected knowledge bases first to find and update rather than create new documents." ;
    oc:hasRationale "Duplicate documentation creates confusion about which version is authoritative and leads to drift over time." .

oc:kn_5bd14aca a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building the RACI matrix for a process document" ;
    oc:directiveContent "Include named individuals in the RACI matrix even if roles may change, as knowing who does what today helps get the process right." ;
    oc:hasRationale "Concrete names ground the process in reality and make it easier to validate accuracy with the team before abstracting to roles." .

oc:kn_8dc219a9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning process documentation with a user who may not have a clear articulation" ;
    oc:directiveContent "Start with the messy, informal description of how the process works today and let the agent structure it into a formal SOP." ;
    oc:hasRationale "Users often know the process tacitly but struggle to articulate it formally; capturing the informal version first ensures accuracy before abstraction." .

oc:kn_a98327a0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any SOP output" ;
    oc:directiveContent "Structure every process document with Purpose, Scope, RACI Matrix, Process Flow, Detailed Steps, Exceptions, Metrics, and Related Documents." ;
    oc:hasRationale "This standardized template ensures completeness, audit-readiness, and consistency across all documented processes." .

oc:kn_cbaf18ad a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interviewing or gathering process details from stakeholders" ;
    oc:directiveContent "Pay special attention to exceptions and edge cases — 'usually we do X, but sometimes Y' is the most valuable part to document." ;
    oc:hasRationale "Exceptions reveal the true complexity of a process and are the areas most likely to cause errors if undocumented." .

