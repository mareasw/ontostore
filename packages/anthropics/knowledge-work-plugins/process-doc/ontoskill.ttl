@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_knowledge_work_plugins_process_doc a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "process-doc" ;
    skos:broader "Business process documentation generator" ;
    prov:wasDerivedFrom "../.agents/skills/anthropics/knowledge-work-plugins/process-doc" ;
    oc:contentHash "de88cac07f058e3b62fc6fd3ddfbe9e258a93d41216b40390f84d02fe44fc646" ;
    oc:differentia "that produces structured SOPs with RACI matrices, process flows, and exception handling tables" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "<process name or description>" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Document a business process — flowcharts, RACI, and SOPs. Use when formalizing a process that lives in someone's head, building a RACI to clarify who owns what, writing an SOP for a handoff or audit, or capturing the exceptions and edge cases of how work actually gets done." ;
    oc:hasName "process-doc" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Document a business process as a complete standard operating procedure (SOP)." ],
                [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 1 ;
                    oc:quoteContent "If you see unfamiliar placeholders or need to check which tools are connected, see [CONNECTORS.md](../../CONNECTORS.md)." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """## Process Document: [Process Name]
**Owner:** [Person/Team] | **Last Updated:** [Date] | **Review Cadence:** [Quarterly/Annually]

### Purpose
[Why this process exists and what it accomplishes]

### Scope
[What's included and excluded]

### RACI Matrix
| Step | Responsible | Accountable | Consulted | Informed |
|------|------------|-------------|-----------|----------|
| [Step] | [Who does it] | [Who owns it] | [Who to ask] | [Who to tell] |

### Process Flow
[ASCII flowchart or step-by-step description]

### Detailed Steps

#### Step 1: [Name]
- **Who**: [Role]
- **When**: [Trigger or timing]
- **How**: [Detailed instructions]
- **Output**: [What this step produces]

#### Step 2: [Name]
[Same format]

### Exceptions and Edge Cases
| Scenario | What to Do |
|----------|-----------|
| [Exception] | [How to handle it] |

### Metrics
| Metric | Target | How to Measure |
|--------|--------|----------------|
| [Metric] | [Target] | [Method] |

### Related Documents
- [Link to related process or policy]
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 25-66" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Output" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/process-doc $ARGUMENTS
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 15-17" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Usage" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Walk me through the process — describe it, paste existing docs, or just tell me the name and I'll ask the right questions. I'll produce a complete SOP." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "How It Works" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "If **~~project tracker** is connected:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Search for existing process documentation to update rather than duplicate" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Publish the completed SOP to your wiki" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Link the process to related projects and workflows" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Create tasks for process improvement action items" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "If **~~knowledge base** is connected:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "If Connectors Available" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_58666929412be209 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Tips" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "/process-doc" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: process-doc
description: Document a business process — flowcharts, RACI, and SOPs. Use when formalizing a process that lives in someone's head, building a RACI to clarify who owns what, writing an SOP for a handoff or audit, or capturing the exceptions and edge cases of how work actually gets done.
argument-hint: "<process name or description>"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Gather process information and produce a complete structured SOP document" ;
            oc:hasStep _:ref_2d735f00e75e11af,
                _:ref_cad61eecf26ae09f,
                [ a oc:WorkflowStep ;
                    dcterms:description "If connectors are available, publish the SOP to the knowledge base and/or create linked tasks in the project tracker" ;
                    oc:expectedOutcome "SOP is published and linked to relevant projects/workflows" ;
                    oc:stepDependsOn _:ref_cad61eecf26ae09f ;
                    oc:stepId "publish" ],
                _:ref_f24ba46e07311174 ;
            oc:workflowId "process-doc-main" ;
            oc:workflowName "SOP Generation Workflow" ],
        _:ref_58666929412be209 ;
    oc:impartsKnowledge oc:kn_10be5ef0,
        oc:kn_62cb6b7c,
        oc:kn_7a971b3d,
        oc:kn_a5173f9b,
        oc:kn_c2c669ec ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build RACI matrix",
        "capture process exceptions and edge cases",
        "create SOP",
        "document a business process",
        "formalize a process from tribal knowledge",
        "write standard operating procedure" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_10be5ef0 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting SOP generation" ;
    oc:directiveContent "Check for connected knowledge base and project tracker connectors to leverage existing documentation and link to related workflows." ;
    oc:hasRationale "Connectors enrich the output by pulling existing context and enabling publish-back workflows." ;
    oc:severityLevel "LOW" .

oc:kn_62cb6b7c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting any process" ;
    oc:directiveContent "Always include exceptions and edge cases — 'Usually we do X, but sometimes Y' is the most valuable part of a process document." ;
    oc:hasRationale "Standard steps are obvious to practitioners; the exceptions are where mistakes and confusion actually happen." ;
    oc:severityLevel "HIGH" .

oc:kn_7a971b3d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When gathering process information from users" ;
    oc:directiveContent "Start messy — accept informal descriptions of how a process works today, then structure it into a formal SOP. Do not require the user to provide a perfect description upfront." ;
    oc:hasRationale "Lowering the barrier to entry increases the chance that undocumented tribal knowledge gets captured before it's lost." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a5173f9b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling in RACI matrices and step ownership" ;
    oc:directiveContent "Name the actual people involved even if roles may change. Knowing who does what today helps get the process right." ;
    oc:hasRationale "Concrete names create accountability and make it easier to validate the process with stakeholders." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c2c669ec a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When knowledge base connector is connected" ;
    oc:directiveContent "When a knowledge base connector is available, search for existing process documentation first to update rather than duplicate." ;
    oc:hasRationale "Duplicate documentation causes confusion and version conflicts; existing docs should be enhanced, not replaced." ;
    oc:severityLevel "HIGH" .

_:ref_02cad2e19dbfcb29 a oc:WorkflowStep ;
    dcterms:description "**Start messy** — You don't need a perfect description. Tell me how it works today and I'll structure it." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_11f0e7a077d087f6 a oc:WorkflowStep ;
    dcterms:description "**Include the exceptions** — \"Usually we do X, but sometimes Y\" is the most valuable part to document." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_548b708dec93d3cc a oc:WorkflowStep ;
    dcterms:description "**Name the people** — Even if roles change, knowing who does what today helps get the process right." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_2d735f00e75e11af a oc:WorkflowStep ;
    dcterms:description "If knowledge base connector is available, search for existing process documentation to update rather than duplicate" ;
    oc:expectedOutcome "Awareness of any existing docs on this process" ;
    oc:stepDependsOn _:ref_f24ba46e07311174 ;
    oc:stepId "search-existing" .

_:ref_58666929412be209 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_02cad2e19dbfcb29,
        _:ref_11f0e7a077d087f6,
        _:ref_548b708dec93d3cc ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_cad61eecf26ae09f a oc:WorkflowStep ;
    dcterms:description "Structure the gathered information into the SOP template: Purpose, Scope, RACI Matrix, Process Flow, Detailed Steps, Exceptions, Metrics, Related Documents" ;
    oc:expectedOutcome "Complete draft SOP document" ;
    oc:stepDependsOn _:ref_2d735f00e75e11af ;
    oc:stepId "structure" .

_:ref_f24ba46e07311174 a oc:WorkflowStep ;
    dcterms:description "Accept user input: process description, existing docs, or process name (agent asks clarifying questions if only a name is given)" ;
    oc:expectedOutcome "Sufficient raw information about the process to structure" ;
    oc:stepId "gather" .

