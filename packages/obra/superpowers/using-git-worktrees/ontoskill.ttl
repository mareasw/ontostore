oc:kn_04bd56d4 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running directory selection process" ;
    oc:directiveContent "Directory selection is idempotent: if .worktrees/ already exists and is ignored, re-running the check simply reuses it" ;
    oc:hasRationale "Safe to re-run checks without side effects" .

oc:kn_4e47876a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before creating any worktree in .worktrees/ or worktrees/" ;
    oc:directiveContent "Never create a project-local worktree without verifying the directory is gitignored first" ;
    oc:hasRationale "Worktree contents that aren't ignored will pollute git status and risk accidental commits to the repository" ;
    oc:severityLevel "CRITICAL" .

oc:kn_5c64d79d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting worktree directory location" ;
    oc:directiveContent "Never assume a directory location when it is ambiguous — follow the priority: existing > CLAUDE.md > ask user" ;
    oc:hasRationale "Hardcoded assumptions violate project conventions and create inconsistency across team members" ;
    oc:severityLevel "MEDIUM" .

oc:kn_60aaa1c9 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After dependency installation in new worktree" ;
    oc:directiveContent "Run project-appropriate test suite after setup to verify clean baseline — report failures and ask before proceeding if any fail" ;
    oc:severityLevel "HIGH" .

oc:kn_798b9607 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Always, before git worktree add for project-local directories" ;
    oc:directiveContent "Run git check-ignore -q to verify worktree directory is ignored before creating any project-local worktree" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9014f274 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user chooses global worktree directory" ;
    oc:directiveContent "For global directory (~/.config/superpowers/worktrees/), no .gitignore verification is needed since it is outside the project entirely" ;
    oc:hasRationale "Global directories are inherently excluded from project git tracking" .

oc:kn_a4f3757e a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always during worktree creation" ;
    oc:directiveContent "Creates a new git worktree (branch + directory), may add lines to .gitignore and create a commit, and runs dependency installation" ;
    oc:hasRationale "Agent must be aware that git state, filesystem, and installed dependencies will change" .

oc:kn_af3fe8e4 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When git check-ignore fails for .worktrees/ or worktrees/" ;
    oc:directiveContent "If a project-local worktree directory is not gitignored, immediately add it to .gitignore and commit before proceeding" ;
    oc:hasRationale "Per 'fix broken things immediately' principle — leaving it unfixed risks tracking worktree contents" ;
    oc:severityLevel "HIGH" .

oc:kn_d0ca5f37 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running project setup in a new worktree" ;
    oc:directiveContent "Auto-detect project type from marker files (package.json, Cargo.toml, requirements.txt, pyproject.toml, go.mod) rather than hardcoding setup commands" ;
    oc:hasRationale "Hardcoded setup commands break on projects using different tools or language ecosystems" .

oc:kn_db44c145 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "After worktree creation and setup" ;
    oc:directiveContent "Never skip baseline test verification after creating a worktree" ;
    oc:hasRationale "Without a clean test baseline, new bugs cannot be distinguished from pre-existing issues" ;
    oc:severityLevel "HIGH" .

