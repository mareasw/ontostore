@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_subagent_driven_development_code_quality_reviewer_prompt a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "code-quality-reviewer-prompt" ;
    skos:broader "Prompt template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/subagent-driven-development" ;
    oc:contentHash "06d1e7c2287e5a00bd1809bf39038abd5f413b4cf917c37d30f00c48f6293421" ;
    oc:differentia "that dispatches a code quality reviewer subagent to verify implementation is clean, tested, and maintainable after spec compliance passes" ;
    oc:extends oc:skill_obra_superpowers_subagent_driven_development ;
    oc:handlesFailure oc:CriticalIssuesFound ;
    oc:hasAllowedTool "Task" ;
    oc:hasArgumentHint "WHAT_WAS_IMPLEMENTED, PLAN_OR_REQUIREMENTS, BASE_SHA, HEAD_SHA, DESCRIPTION" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_1790d7bf,
        oc:kn_3a2af6e5,
        oc:kn_620471da,
        oc:kn_90d51f78,
        oc:kn_a96ae6d0 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:SpecReviewPassed ;
    oc:resolvesIntent "dispatch code quality reviewer subagent",
        "review code quality of implemented tasks",
        "verify implementation is clean tested and maintainable" ;
    oc:yieldsState oc:CodeQualityReviewed .

oc:kn_1790d7bf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing file structure and module decomposition" ;
    oc:directiveContent "Each file should have one clear responsibility with a well-defined interface, and units should be decomposed for independent understanding and testing." ;
    oc:hasRationale "Single-responsibility files with clear interfaces enable maintainability, testability, and parallel development." .

oc:kn_3a2af6e5 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When evaluating the reviewer's output" ;
    oc:directiveContent "The code reviewer returns a structured report containing Strengths, Issues (categorized as Critical/Important/Minor), and an overall Assessment." ;
    oc:hasRationale "Structured output with severity categorization enables the orchestrating agent to make informed decisions about whether to proceed or iterate." .

oc:kn_620471da a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating file size concerns during review" ;
    oc:directiveContent "Do not flag pre-existing file sizes — focus only on files that this change contributed to or created." ;
    oc:hasRationale "Reviewing scope creep from pre-existing code wastes review time and dilutes focus on the actual change's impact." ;
    oc:severityLevel "MEDIUM" .

oc:kn_90d51f78 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before dispatching this subagent" ;
    oc:directiveContent "Only dispatch the code quality reviewer after spec compliance review has passed." ;
    oc:hasRationale "Code quality review is meaningless if the implementation doesn't meet the specification requirements first." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a96ae6d0 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "At the start of code quality review" ;
    oc:directiveContent "Verify that the implementation follows the file structure defined in the plan before proceeding with deeper quality checks." ;
    oc:hasRationale "Structural alignment with the plan ensures the implementation was built as designed, making deeper review meaningful." .

