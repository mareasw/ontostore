                                    oc:itemText "Fresh context per task (no confusion)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Parallel-safe (subagents don't interfere)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Subagents follow TDD naturally" ] ],
                        [ a oc:Paragraph ;
