oc:kn_0002a7af a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting model for subagent dispatch" ;
    oc:directiveContent "Use the least powerful model that can handle each task: cheap model for mechanical tasks (1-2 files, clear spec), standard for integration/judgment, most capable for architecture/design/review." ;
    oc:hasRationale "Conserves cost and increases speed while ensuring adequate capability for each task complexity level." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2469f712 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When dispatching any subagent" ;
    oc:directiveContent "Subagents must never inherit the controller's session context or history — construct exactly what they need from scratch." ;
    oc:hasRationale "Context isolation prevents confusion, keeps subagents focused, and preserves the controller's context for coordination." ;
    oc:severityLevel "HIGH" .

oc:kn_423ad7dd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing completed implementation" ;
    oc:directiveContent "Always run spec compliance review BEFORE code quality review. Never start code quality review while spec compliance has open issues." ;
    oc:hasRationale "Code quality review is wasted effort if the spec isn't met. Wrong order introduces noise and rework." ;
    oc:severityLevel "CRITICAL" .

oc:kn_45045d25 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing subagent prompts" ;
    oc:directiveContent "Never make subagents read plan files — provide full task text and context directly in their prompt." ;
    oc:hasRationale "File reading wastes subagent context window and introduces ambiguity. The controller should curate exactly what's needed." ;
    oc:severityLevel "HIGH" .

oc:kn_475b25b6 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When subagent fails a task" ;
    oc:directiveContent "Do not try to fix subagent failures manually — dispatch a fix subagent with specific instructions to avoid context pollution." ;
    oc:hasRationale "Manual fixes pollute the controller's context window and break the isolation principle." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7a0b92a0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When dispatching subagents" ;
    oc:directiveContent "Never dispatch multiple implementation subagents in parallel — they will conflict on shared files and git state." ;
    oc:hasRationale "Parallel implementation subagents cause file conflicts and race conditions in the same workspace." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c9863946 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before dispatching first subagent" ;
    oc:directiveContent "Before starting: read plan file once, extract ALL tasks with full text, note context/dependencies, create TodoWrite with all tasks." ;
    oc:hasRationale "Upfront extraction avoids repeated file reads and ensures the controller has complete visibility into all tasks." ;
    oc:severityLevel "HIGH" .

oc:kn_dd928002 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When implementer reports BLOCKED" ;
    oc:directiveContent "Handle BLOCKED status by: (1) provide more context and re-dispatch same model, (2) re-dispatch with more capable model, (3) break task into smaller pieces, or (4) escalate to human if plan is wrong. Never force same model to retry without changes." ;
    oc:hasRationale "If an implementer is stuck, something must change — ignoring escalations wastes time and produces bad work." ;
    oc:severityLevel "HIGH" .

oc:kn_e63c1991 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewer reports issues" ;
    oc:directiveContent "Never skip review loops: if a reviewer finds issues, the implementer must fix them and the reviewer must re-review." ;
    oc:hasRationale "Skipping re-review means fixes are unverified, allowing regressions and incomplete fixes to slip through." ;
    oc:severityLevel "HIGH" .

oc:kn_ed9317e0 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-dispatching after failure" ;
    oc:directiveContent "The process is NOT idempotent — each subagent commits code, so re-running the same task creates duplicate commits unless carefully managed." ;
    oc:hasRationale "Subagents commit their work, so re-dispatching needs awareness of existing state." ;
    oc:severityLevel "MEDIUM" .

