@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_subagent_driven_development_implementer_prompt a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "implementer-prompt" ;
    skos:broader "Subagent prompt template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/subagent-driven-development" ;
    oc:contentHash "a416193f881e5a712c988fffabfe1d5a97bffcd091eb95577c84fe2136588617" ;
    oc:differentia "Provides structured instructions for dispatched implementer subagents executing individual plan tasks" ;
    oc:extends oc:skill_obra_superpowers_subagent_driven_development ;
    oc:handlesFailure oc:ImplementationConcerns,
        oc:NeedsContext,
        oc:TaskBlocked ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_1265eb9a,
        oc:kn_20a4fb31,
        oc:kn_614959d1,
        oc:kn_a38c14b0,
        oc:kn_aafe4aa8,
        oc:kn_d280dc6b ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:requiresState oc:PlanReady,
        oc:TaskAssigned ;
    oc:resolvesIntent "dispatch implementer subagent",
        "guide subagent code implementation",
        "implement plan task" ;
    oc:yieldsState oc:CodeCommitted,
        oc:TaskImplemented,
        oc:TestsPassing .

oc:kn_1265eb9a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the subagent encounters uncertainty or completes work with doubts" ;
    oc:directiveContent "Never silently produce work you are unsure about. Always report status as DONE_WITH_CONCERNS, BLOCKED, or NEEDS_CONTEXT when uncertain." ;
    oc:hasRationale "Silent low-quality work is worse than no work — it creates hidden defects and technical debt that compound over time." ;
    oc:severityLevel "CRITICAL" .

oc:kn_20a4fb31 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any implementation work" ;
    oc:directiveContent "Before implementing, the subagent must raise any questions about requirements, approach, dependencies, or unclear aspects of the task description." ;
    oc:hasRationale "Clarifying ambiguities upfront prevents wasted effort and rework from building the wrong thing." ;
    oc:severityLevel "HIGH" .

oc:kn_614959d1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When modifying existing code in a codebase" ;
    oc:directiveContent "In existing codebases, follow established patterns. Improve code you are touching but do not restructure things outside the task's scope." ;
    oc:hasRationale "Maintaining consistency with existing patterns reduces cognitive load for the team and avoids unintended side effects from scope creep." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a38c14b0 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After implementation is complete, before final report" ;
    oc:directiveContent "Before reporting back, perform a self-review checking completeness against the spec, code quality, YAGNI discipline, and test comprehensiveness. Fix any issues found before reporting." ;
    oc:hasRationale "Self-review catches errors before they propagate, reducing round-trips and maintaining implementation quality." ;
    oc:severityLevel "HIGH" .

oc:kn_aafe4aa8 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When the subagent encounters situations beyond its confidence or capability" ;
    oc:directiveContent "When in over your head — facing architectural ambiguity, inability to understand the system, or tasks requiring restructuring — stop and escalate with status BLOCKED or NEEDS_CONTEXT describing what was tried and what help is needed." ;
    oc:hasRationale "Escalation enables the controller to provide context, re-dispatch with a more capable model, or break the task into smaller pieces — all better outcomes than guessing." ;
    oc:severityLevel "HIGH" .

oc:kn_d280dc6b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or modifying code files during implementation" ;
    oc:directiveContent "Keep files focused with one clear responsibility. If a file grows beyond the plan's intent, report it as DONE_WITH_CONCERNS rather than splitting files without plan guidance." ;
    oc:hasRationale "Subagents reasoning is most reliable with focused files; autonomous restructuring decisions can diverge from the plan's architecture." ;
    oc:severityLevel "HIGH" .

