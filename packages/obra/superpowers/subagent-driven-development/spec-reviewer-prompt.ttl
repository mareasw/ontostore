@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_subagent_driven_development_spec_reviewer_prompt a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "spec-reviewer-prompt" ;
    skos:broader "Prompt template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/subagent-driven-development" ;
    oc:contentHash "631980e472eec5394de8b89b69d432e54fd3f7f523ecf9afa7eb4cda0c9b2baf" ;
    oc:differentia "that instructs a subagent to verify implementation against specification by reading actual code rather than trusting implementer reports" ;
    oc:extends oc:skill_obra_superpowers_subagent_driven_development ;
    oc:handlesFailure oc:ExtraWorkDetected,
        oc:MissingRequirements,
        oc:SpecViolationDetected ;
    oc:hasArgumentHint "task requirements and implementer report" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_0bd2466e,
        oc:kn_2c251266,
        oc:kn_4bc79102,
        oc:kn_ae5b34ec,
        oc:kn_b1b11d40 ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:requiresState oc:ImplementationComplete ;
    oc:resolvesIntent "audit code against specification",
        "detect missing or extra work in implementation",
        "review spec compliance",
        "verify implementation matches requirements" ;
    oc:yieldsState oc:SpecComplianceVerified .

oc:kn_0bd2466e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating whether implementation matches specification" ;
    oc:directiveContent "Check for both missing requirements AND extra unrequested work. Spec compliance means nothing more, nothing less." ;
    oc:hasRationale "Over-engineering or adding unrequested features introduces risk, scope creep, and maintenance burden just as much as missing requirements." ;
    oc:severityLevel "HIGH" .

oc:kn_2c251266 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing spec compliance review" ;
    oc:directiveContent "Compare actual implementation to requirements line by line, verifying each requirement has corresponding code and each code section maps to a requirement." ;
    oc:hasRationale "Line-by-line comparison catches subtle misunderstandings, partial implementations, and features that solve the wrong problem." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4bc79102 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When discrepancies exist between spec and implementation" ;
    oc:directiveContent "Implementers may interpret requirements differently than intended, solving the wrong problem or implementing the right feature the wrong way." ;
    oc:hasRationale "Ambiguous requirements lead to divergent interpretations; the reviewer must detect when the implementer's understanding drifted from intent." ;
    oc:severityLevel "HIGH" .

oc:kn_ae5b34ec a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "When producing the final spec compliance review report" ;
    oc:directiveContent "Report must include specific file:line references for any issues found, and a clear ✅ or ❌ verdict based on code inspection, not report claims." ;
    oc:hasRationale "Specific references make issues actionable and prevent vague feedback that requires additional review cycles." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b1b11d40 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing any implementation for spec compliance" ;
    oc:directiveContent "Never trust the implementer's self-report about what was built. Always verify by reading the actual code independently." ;
    oc:hasRationale "Implementers may finish quickly and produce reports that are incomplete, inaccurate, or optimistic about what was actually implemented." ;
    oc:severityLevel "CRITICAL" .

