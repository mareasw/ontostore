    oc:isUserInvocable true ;
    oc:nature "Workflow" ;
    oc:requiresState oc:GitRepository,
        oc:ImplementationComplete ;
    oc:resolvesIntent "clean up after implementation",
        "create a pull request",
        "discard incomplete work",
        "finish a development branch",
        "merge completed work" ;
    oc:yieldsState oc:BranchFinalized,
        oc:WorktreeCleaned .

oc:kn_43a800cd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user selects the discard option" ;
    oc:directiveContent "Option 4 (discard) requires the user to type 'discard' exactly before any destructive action is taken." ;
    oc:hasRationale "Prevents accidental permanent deletion of work, branches, and commits" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7baa3f11 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always — the entire skill is about making irreversible git changes" ;
    oc:directiveContent "This skill can delete branches, remove worktrees, push to remote, and create PRs — all destructive or external-facing actions." ;
    oc:hasRationale "Agent must be certain of user intent before executing any option since these actions modify git state" ;
    oc:severityLevel "MEDIUM" .

oc:kn_87881b2b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementation is complete and branch needs finalization" ;
    oc:directiveContent "1. Run test suite → halt on failure. 2. Determine base branch. 3. Present 4 options. 4. Execute chosen option. 5. Cleanup worktree (Options 1 & 4 only)." ;
    oc:stepOrder 1 .

oc:kn_8bd1c7a3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Step 5 cleanup after executing user's choice" ;
    oc:directiveContent "Only clean up worktree for Options 1 (merge locally) and 4 (discard). Preserve worktree for Options 2 (PR) and 3 (keep)." ;
    oc:hasRationale "The worktree may still be needed for PR review or continued work; premature cleanup loses work" ;
    oc:severityLevel "HIGH" .

oc:kn_a1f09ee6 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When presenting completion options after tests pass" ;
    oc:directiveContent """Implementation complete. What would you like to do?

1. Merge back to <base-branch> locally
2. Push and create a Pull Request
3. Keep the branch as-is (I'll handle it later)
4. Discard this work

Which option?""" .

oc:kn_a63c4cfe a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting completion options to the user" ;
    oc:directiveContent "Never ask open-ended questions like 'What should I do next?'. Always present exactly 4 structured options: merge locally, create PR, keep as-is, or discard." ;
    oc:hasRationale "Open-ended questions create ambiguity and decision fatigue; structured options ensure clear, safe choices" ;
    oc:severityLevel "HIGH" .

oc:kn_b628ebd6 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Executing user's chosen completion option" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """# Merge locally
git checkout <base-branch> && git pull && git merge <feature-branch>
<test command>
git branch -d <feature-branch>

# Push and create PR
git push -u origin <feature-branch>
gh pr create --title "<title>" --body "$(cat <<'EOF'
## Summary
<2-3 bullets>
## Test Plan
- [ ] <verification steps>
EOF
)\"""" .

oc:kn_d59a8ef0 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before and after merging a feature branch into the base branch" ;
    oc:directiveContent "Verify tests pass AND verify tests on the merged result (Option 1) before finalizing any merge." ;
    oc:hasRationale "Tests may pass on the feature branch but fail after merge due to integration issues" ;
    oc:severityLevel "HIGH" .

oc:kn_f1a0c1b3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before presenting branch completion options" ;
    oc:directiveContent "Never proceed with failing tests. If tests fail, stop and report failures — do not present options or merge." ;
    oc:hasRationale "Merging or pushing broken code creates failing PRs and corrupts the target branch" ;
    oc:severityLevel "CRITICAL" .

oc:kn_f3282dc6 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Pre-option verification and base branch discovery" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """# Verify tests
npm test / cargo test / pytest / go test ./...

# Determine base branch
git merge-base HEAD main 2>/dev/null || git merge-base HEAD master 2>/dev/null

# Check worktree
git worktree list | grep $(git branch --show-current)""" .

_:ref_81e2b508c4ac537f a oc:WorkflowStep ;
    dcterms:description "Run the project's test suite to confirm all tests pass before proceeding" ;
    oc:expectedOutcome "All tests pass; agent can proceed to present options" ;
    oc:stepId "verify-tests" .

_:ref_8ff7d02edac19275 a oc:WorkflowStep ;
    dcterms:description "Present exactly 4 structured options: merge locally, push and create PR, keep as-is, or discard" ;
    oc:expectedOutcome "User selects one of the 4 options" ;
    oc:stepDependsOn _:ref_c3cd9c9617b835d8 ;
    oc:stepId "present-options" .

_:ref_c3cd9c9617b835d8 a oc:WorkflowStep ;
    dcterms:description "Identify the base branch (main/master) from which the feature branch diverged" ;
    oc:expectedOutcome "Base branch identified or confirmed with user" ;
    oc:stepDependsOn _:ref_81e2b508c4ac537f ;
    oc:stepId "determine-base" .

_:ref_f58b9b971fdf3cbb a oc:WorkflowStep ;
    dcterms:description "Execute the user's chosen option (merge, PR, keep, or discard) with appropriate safeguards" ;
    oc:expectedOutcome "Chosen action completed successfully" ;
    oc:stepDependsOn _:ref_8ff7d02edac19275 ;
    oc:stepId "execute-choice" .

