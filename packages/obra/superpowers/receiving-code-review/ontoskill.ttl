                                    oc:itemOrder 3 ;
                                    oc:itemText "Push back with technical reasoning if wrong" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Forbidden Responses" ],
