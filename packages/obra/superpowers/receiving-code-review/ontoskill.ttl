oc:kn_1970f132 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When receiving feedback from external reviewers (not your human partner)" ;
    oc:directiveContent "Before implementing external reviewer suggestions, verify: (1) technically correct for this codebase, (2) doesn't break existing functionality, (3) reason for current implementation, (4) works on all platforms, (5) reviewer has full context." ;
    oc:hasRationale "External reviewers often lack full project context. Their feedback is a suggestion to evaluate, not an order to follow." ;
    oc:severityLevel "HIGH" .

oc:kn_725ce236 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When receiving multi-item code review feedback with unclear items" ;
    oc:directiveContent "If any feedback item is unclear, STOP and clarify ALL unclear items before implementing anything. Never partially implement a batch of feedback." ;
    oc:hasRationale "Feedback items may be interrelated. Partial understanding leads to wrong implementation that conflicts with unclear items once clarified." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7a9470ee a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When acknowledging any code review feedback" ;
    oc:directiveContent "Never respond with performative agreement like 'You're absolutely right!', 'Great point!', or any gratitude expression. State the technical requirement or just implement the fix." ;
    oc:hasRationale "Performative agreement is an explicit CLAUDE.md violation and substitutes social comfort for technical rigor. The code itself demonstrates the feedback was heard." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b2efe339 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When external reviewers suggest adding 'professional' features or proper implementations" ;
    oc:directiveContent "When reviewer suggests 'implementing properly', grep the codebase for actual usage first. If unused, propose removal (YAGNI). If used, implement properly." ;
    oc:hasRationale "Adding features nobody uses violates YAGNI and increases maintenance burden without value." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d0611289 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When you pushed back on feedback but verification proved you wrong" ;
    oc:directiveContent "If you pushed back and were wrong, state the correction factually ('You were right - I checked [X] and it does [Y]. Implementing now.') without long apologies or defending the pushback." ;
    oc:hasRationale "Over-apologizing wastes time and shifts focus from the technical issue. Factual correction maintains credibility." ;
    oc:severityLevel "MEDIUM" .

oc:kn_dfd597c5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When external reviewer suggestions conflict with established architecture" ;
    oc:directiveContent "If external feedback conflicts with your human partner's prior architectural decisions, stop and discuss with your human partner first." ;
    oc:hasRationale "Your human partner has final authority on architectural decisions. External reviewers don't override that." ;
    oc:severityLevel "HIGH" .

oc:kn_e357d754 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, as the core principle of receiving code review feedback" ;
    oc:directiveContent "Verify before implementing. Ask before assuming. Technical correctness over social comfort." ;
    oc:hasRationale "Blind implementation of unverified feedback introduces bugs and architectural drift. Technical rigor protects codebase integrity." ;
    oc:severityLevel "HIGH" .

oc:kn_eef80230 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When implementing multiple review feedback items" ;
    oc:directiveContent "Avoid batch-implementing multiple feedback items without testing each individually. Test each fix independently and verify no regressions after each." ;
    oc:hasRationale "Batching changes makes it impossible to identify which change introduced a regression if tests fail." ;
    oc:severityLevel "MEDIUM" .

_:ref_14d0b0784d27a2d3 a oc:WorkflowStep ;
    dcterms:description "Implement complex fixes (refactoring, logic changes), testing each individually" ;
    oc:expectedOutcome "Complex changes applied and verified with no regressions" ;
    oc:stepDependsOn _:ref_2495638878bc5f6f ;
    oc:stepId "implement-complex" .

_:ref_1c57432235a83074 a oc:WorkflowStep ;
    dcterms:description "Implement blocking issues first (breaks, security vulnerabilities)" ;
    oc:expectedOutcome "Critical issues resolved" ;
    oc:stepDependsOn _:ref_2ef4d9480fce2442 ;
    oc:stepId "implement-blocking" .

_:ref_2495638878bc5f6f a oc:WorkflowStep ;
    dcterms:description "Implement simple fixes (typos, imports, minor adjustments), testing each individually" ;
    oc:expectedOutcome "Simple fixes applied and verified" ;
    oc:stepDependsOn _:ref_1c57432235a83074 ;
    oc:stepId "implement-simple" .

_:ref_2ef4d9480fce2442 a oc:WorkflowStep ;
    dcterms:description "For each item: provide technical acknowledgment or reasoned pushback with technical evidence" ;
    oc:expectedOutcome "Reviewer receives substantive technical response" ;
    oc:stepDependsOn _:ref_7a04c018afe00410 ;
    oc:stepId "respond-or-pushback" .

_:ref_711484b3c97bb905 a oc:WorkflowStep ;
    dcterms:description "If ANY item is unclear, stop and request clarification on all unclear items before proceeding" ;
    oc:expectedOutcome "Full clarity on all feedback items" ;
    oc:stepDependsOn _:ref_8e38f15024a72abf ;
    oc:stepId "clarify-unclear-items" .

_:ref_7a04c018afe00410 a oc:WorkflowStep ;
    dcterms:description "Check each suggestion against codebase reality: correctness, breakage risk, current implementation reasons, platform compatibility, reviewer context" ;
    oc:expectedOutcome "Each feedback item evaluated for technical soundness" ;
    oc:stepDependsOn _:ref_711484b3c97bb905 ;
    oc:stepId "verify-feedback" .

_:ref_7cc1a0c2cc337b85 a oc:WorkflowStep ;
    dcterms:description "Read complete feedback without reacting emotionally" ;
    oc:expectedOutcome "All feedback items understood at face value" ;
