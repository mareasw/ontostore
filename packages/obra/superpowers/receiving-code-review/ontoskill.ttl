oc:skill_obra_superpowers_receiving_code_review a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "receiving-code-review" ;
    skos:broader "Code review response methodology" ;
    prov:wasDerivedFrom "../.agents/skills/obra/superpowers/receiving-code-review" ;
    oc:contentHash "0efc7889cdbaad8375dd2c881ca089f07a22bcb42bc99580afb85296561258cd" ;
    oc:differentia "enforces technical verification over social compliance, requiring evaluation before implementation and reasoned pushback when feedback is incorrect" ;
    oc:handlesFailure oc:AmbiguousFeedback,
        oc:TechnicalConflict ;
    oc:hasArgumentHint "code review feedback items" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Use when receiving code review feedback, before implementing suggestions, especially if feedback seems unclear or technically questionable - requires technical rigor and verification, not performative agreement or blind implementation" ;
    oc:hasName "receiving-code-review" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 7 ;
                            oc:tableCaption "## Common Mistakes" ;
                            oc:tableMarkdown """| Mistake | Fix |
|---------|-----|
| Performative agreement | State requirement or just act |
| Blind implementation | Verify against codebase first |
| Batch without testing | One at a time, test each |
| Assuming reviewer is right | Check if breaks things |
| Avoiding pushback | Technical correctness > comfort |
| Partial implementation | Clarify all items first |
| Can't verify, proceed anyway | State limitation, ask for direction |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 14 ;
                    oc:sectionTitle "Common Mistakes" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """FOR multi-item feedback:
  1. Clarify anything unclear FIRST
  2. Then implement in this order:
     - Blocking issues (breaks, security)
     - Simple fixes (typos, imports)
     - Complex fixes (refactoring, logic)
  3. Test each fix individually
  4. Verify no regressions
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 102-111" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 10 ;
                    oc:sectionTitle "Implementation Order" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Core principle:** Verify before implementing. Ask before assuming. Technical correctness over social comfort." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Code review requires technical evaluation, not emotional performance." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Overview" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**NEVER:**" ],
