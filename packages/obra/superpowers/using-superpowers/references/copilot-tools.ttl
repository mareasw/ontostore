@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_using_superpowers_copilot_tools a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "copilot-tools" ;
    skos:broader "Tool mapping reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/using-superpowers" ;
    oc:contentHash "5e0e9248e8bd965a28c8721bed24ddfa44a1ee66a89ee275da4a8260fe636e02" ;
    oc:differentia "that translates Claude Code tool names to Copilot CLI equivalents, including async shell sessions and additional Copilot-specific tools" ;
    oc:extends oc:skill_obra_superpowers_using_superpowers ;
    oc:hasArgumentHint "tool-name to look up" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Table ;
                    oc:blockType "table" ;
                    oc:contentOrder 2 ;
                    oc:rowCount 14 ;
                    oc:tableCaption "Skills use Claude Code tool names. When you encounter these in a skill, use your platform equivalent" ;
                    oc:tableMarkdown """| Skill references | Copilot CLI equivalent |
|-----------------|----------------------|
| `Read` (file reading) | `view` |
| `Write` (file creation) | `create` |
| `Edit` (file editing) | `edit` |
| `Bash` (run commands) | `bash` |
| `Grep` (search file content) | `grep` |
| `Glob` (search files by name) | `glob` |
| `Skill` tool (invoke a skill) | `skill` |
| `WebFetch` | `web_fetch` |
| `Task` tool (dispatch subagent) | `task` (see [Agent types](#agent-types)) |
| Multiple `Task` calls (parallel) | Multiple `task` calls |
| Task status/output | `read_agent`, `list_agents` |
| `TodoWrite` (task tracking) | `sql` with built-in `todos` table |
| `WebSearch` | No equivalent â€” use `web_fetch` with a search engine URL |
| `EnterPlanMode` / `ExitPlanMode` | No equivalent â€” stay in the main session |
""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Skills use Claude Code tool names. When you encounter these in a skill, use your platform equivalent:" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 3 ;
                            oc:tableCaption "Copilot CLI's `task` tool accepts an `agent_type` parameter" ;
                            oc:tableMarkdown """| Claude Code agent | Copilot CLI equivalent |
|-------------------|----------------------|
| `general-purpose` | `"general-purpose"` |
| `Explore` | `"explore"` |
| Named plugin agents (e.g. `superpowers:code-reviewer`) | Discovered automatically from installed plugins |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Copilot CLI's `task` tool accepts an `agent_type` parameter:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Agent types" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 5 ;
                            oc:tableCaption "Copilot CLI supports persistent async shell sessions, which have no direct Claude Code equivalent" ;
                            oc:tableMarkdown """| Tool | Purpose |
|------|---------|
| `bash` with `async: true` | Start a long-running command in the background |
| `write_bash` | Send input to a running async session |
| `read_bash` | Read output from an async session |
| `stop_bash` | Terminate an async session |
| `list_bash` | List all active shell sessions |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Copilot CLI supports persistent async shell sessions, which have no direct Claude Code equivalent:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Async shell sessions" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 5 ;
                            oc:tableCaption "## Additional Copilot CLI tools" ;
                            oc:tableMarkdown """| Tool | Purpose |
|------|---------|
| `store_memory` | Persist facts about the codebase for future sessions |
| `report_intent` | Update the UI status line with current intent |
| `sql` | Query the session's SQLite database (todos, metadata) |
| `fetch_copilot_cli_documentation` | Look up Copilot CLI documentation |
| GitHub MCP tools (`github-mcp-server-*`) | Native GitHub API access (issues, PRs, code search) |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Additional Copilot CLI tools" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Copilot CLI Tool Mapping" ] ;
    oc:impartsKnowledge oc:kn_20bce09c,
        oc:kn_4ed98004,
        oc:kn_9645cdd2,
        oc:kn_a4d95eeb,
        oc:kn_e07d55be,
        oc:kn_ef44ddec,
        oc:kn_f921328a ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ToolInstalled ;
    oc:resolvesIntent "discover Copilot CLI-specific tools",
        "dispatch agents using Copilot CLI task tool",
        "translate tool names between Claude Code and Copilot CLI",
        "use async shell sessions in Copilot CLI" ;
    oc:yieldsState oc:EnvironmentReady .

oc:kn_20bce09c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When running long-running or background commands on Copilot CLI" ;
    oc:directiveContent "Use bash with async:true for long-running commands, then write_bash/read_bash/stop_bash to manage the session. Use list_bash to see active sessions." ;
    oc:hasRationale "Copilot CLI supports persistent async shell sessions not available in Claude Code, enabling better management of long processes." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4ed98004 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a skill calls WebSearch on Copilot CLI" ;
    oc:directiveContent "WebSearch has no Copilot CLI equivalent â€” use web_fetch with a search engine URL instead." ;
    oc:hasRationale "Copilot CLI lacks a dedicated web search tool; the workaround preserves search functionality." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9645cdd2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a skill references plan mode on Copilot CLI" ;
    oc:directiveContent "EnterPlanMode and ExitPlanMode have no Copilot CLI equivalent â€” stay in the main session." ;
    oc:hasRationale "Copilot CLI does not support plan mode; agents must remain in the main session." ;
    oc:severityLevel "LOW" .

oc:kn_a4d95eeb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing any skill on Copilot CLI platform" ;
    oc:directiveContent "When a skill references Claude Code tools (Read, Write, Edit, Bash, Grep, Glob, Skill, WebFetch, Task), use the Copilot CLI equivalent (view, create, edit, bash, grep, glob, skill, web_fetch, task)." ;
    oc:hasRationale "Skills are authored with Claude Code tool names; Copilot CLI agents must translate these to work correctly." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e07d55be a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When translating any skill for Copilot CLI execution" ;
    oc:directiveContent "1. Identify the Claude Code tool name in the skill â†’ 2. Look up the Copilot CLI equivalent in the mapping table â†’ 3. Use the Copilot CLI tool with appropriate parameters" ;
    oc:stepOrder 1 .

oc:kn_ef44ddec a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When dispatching sub-agents on Copilot CLI" ;
    oc:codeLanguage "json" ;
    oc:directiveContent "Task agent types: \"general-purpose\", \"explore\", or plugin-discovered names. Task status uses read_agent/list_agents." .

oc:kn_f921328a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a skill uses task tracking on Copilot CLI" ;
    oc:directiveContent "TodoWrite maps to sql with the built-in todos table, not a dedicated tool." ;
    oc:hasRationale "Copilot CLI uses its SQLite database for todo management rather than a standalone tool." ;
    oc:severityLevel "HIGH" .

