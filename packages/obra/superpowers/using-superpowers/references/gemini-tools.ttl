@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_using_superpowers_gemini_tools a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "gemini-tools" ;
    skos:broader "Platform tool mapping reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/using-superpowers" ;
    oc:contentHash "477239fd7b4868f016662831e0fe840557ce91217f057f742a41af57a53554de" ;
    oc:differentia "translates Claude Code tool names to their Gemini CLI equivalents for cross-platform skill execution" ;
    oc:extends oc:skill_obra_superpowers_using_superpowers ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_b3d0b0bd ;
    oc:impartsKnowledge oc:kn_0690a42a,
        oc:kn_68be5413,
        oc:kn_721cfbe6,
        oc:kn_aa65a3e2,
        oc:kn_f7272eaa ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "adapt skill instructions for Gemini CLI platform",
        "determine Gemini CLI capabilities and limitations for skill execution",
        "translate Claude Code tool names to Gemini CLI equivalents" .

oc:kn_0690a42a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When skills require web access on Gemini CLI" ;
    oc:directiveContent "When WebSearch is needed, use google_web_search as the direct Gemini CLI equivalent. When WebFetch is needed, use web_fetch identically." ;
    oc:hasRationale "Gemini CLI provides native web search and fetch tools that map directly to the Claude Code equivalents." ;
    oc:severityLevel "LOW" .

oc:kn_68be5413 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing skills on Gemini CLI and looking for enhanced capabilities" ;
    oc:directiveContent "Gemini CLI provides additional tools with no Claude Code equivalent: list_directory, save_memory, ask_user, tracker_create_task, and enter_plan_mode/exit_plan_mode. These can be used to enhance skill execution on Gemini CLI." ;
    oc:hasRationale "Leveraging platform-native tools can improve skill outcomes beyond the baseline Claude Code experience." ;
    oc:severityLevel "MEDIUM" .

oc:kn_721cfbe6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing skills that reference the Task tool or subagent dispatch on Gemini CLI" ;
    oc:directiveContent "Gemini CLI has no equivalent to the Task tool for dispatching subagents. Skills requiring subagent dispatch (subagent-driven-development, dispatching-parallel-agents) must fall back to single-session execution via executing-plans." ;
    oc:hasRationale "Attempting to use subagent patterns on Gemini CLI will fail silently or produce errors; falling back to sequential plan execution is the only viable path." ;
    oc:severityLevel "CRITICAL" .

oc:kn_aa65a3e2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating any skill's tool invocations for Gemini CLI execution" ;
    oc:directiveContent "Map all Claude Code tool references to their Gemini CLI equivalents: Read→read_file, Write→write_file, Edit→replace, Bash→run_shell_command, Grep→grep_search, Glob→glob, TodoWrite→write_todos, Skill→activate_skill, WebSearch→google_web_search, WebFetch→web_fetch." ;
    oc:hasRationale "Skills are authored against Claude Code's tool names; correct platform-specific translation is essential for proper skill execution." ;
    oc:severityLevel "HIGH" .

oc:kn_f7272eaa a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering subagent-dependent skills on Gemini CLI" ;
    oc:directiveContent "When a skill requires parallel subagent execution, degrade gracefully to sequential single-session execution using the executing-plans skill as the fallback pattern." ;
    oc:hasRationale "Ensuring a viable execution path exists even without subagent support prevents total skill failure." ;
    oc:severityLevel "HIGH" .

oc:req_b3d0b0bd a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Gemini CLI tool names and capabilities" .

