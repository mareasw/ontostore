@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_using_superpowers a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "using-superpowers" ;
    skos:broader "meta-skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/using-superpowers" ;
    oc:contentHash "da09b7e0d983d2506c11505c9e67a108871c5d2ceacebb9ca2ffc850cf1c57b2" ;
    oc:differentia "that establishes the protocol for discovering, invoking, and following skills before any agent action, serving as the root orchestrator for all other skills in the system" ;
    oc:handlesFailure oc:AmbiguousTask,
        oc:SkillNotFound ;
    oc:hasArgumentHint "any user message or task" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Use when starting any conversation - establishes how to find and use skills, requiring Skill tool invocation before ANY response including clarifying questions" ;
    oc:hasName "using-superpowers" ;
    oc:impartsKnowledge oc:kn_18f303cd,
        oc:kn_218a681a,
        oc:kn_63db97aa,
        oc:kn_7c5636c1,
        oc:kn_bd637e7c,
        oc:kn_ddaee408 ;
    oc:isUserInvocable true ;
    oc:nature "concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "adapt skill invocation across multiple AI platforms",
        "discover and invoke relevant skills before responding",
        "establish skill-checking as mandatory pre-action behavior",
        "override default system behavior with skill-based workflows",
        "prioritize process skills over implementation skills" ;
    oc:yieldsState oc:SkillDiscoveryComplete,
        oc:SkillsInvoked .

oc:kn_18f303cd a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Immediately after invoking and loading a skill" ;
    oc:directiveContent "After invoking a skill, announce 'Using [skill] to [purpose]' and check if it has a checklist; if so, create a TodoWrite item for each checklist entry before following the skill." ;
    oc:hasRationale "Announcing intent creates accountability, and materializing checklists as todos ensures no steps are skipped during execution" ;
    oc:severityLevel "HIGH" .

oc:kn_218a681a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When skill instructions conflict with user configuration or explicit requests" ;
    oc:directiveContent "User instructions (CLAUDE.md, GEMINI.md, AGENTS.md, direct requests) always take precedence over skill instructions, which in turn override default system prompt behavior." ;
    oc:hasRationale "The user retains ultimate control; skills are guidance, not overrides of user autonomy" ;
    oc:severityLevel "HIGH" .

oc:kn_63db97aa a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Any time you catch yourself thinking a skill check is unnecessary" ;
    oc:directiveContent "Never skip skill invocation by rationalizing that the task is simple, you remember the skill, you need more context first, or the skill is overkill. These are all documented rationalization patterns." ;
    oc:hasRationale "Simple tasks become complex, skills evolve between sessions, and undisciplined action wastes time — the 12 documented red-flag thoughts are the most common failure modes" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7c5636c1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When two or more skills are potentially relevant to the current task" ;
    oc:directiveContent "When multiple skills could apply, invoke process skills first (brainstorming, debugging) as they determine HOW to approach the task, then invoke implementation skills second as they guide execution." ;
    oc:hasRationale "Process skills establish the correct approach before execution begins, preventing premature implementation" ;
    oc:severityLevel "HIGH" .

oc:kn_bd637e7c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before every agent response to any user message" ;
    oc:directiveContent "Invoke relevant skills BEFORE any response or action, including clarifying questions. Even a 1% chance a skill might apply means you must invoke it to check." ;
    oc:hasRationale "Skills encode accumulated best practices and workflows; skipping them means reinventing solutions poorly and inconsistently" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ddaee408 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When the agent is a dispatched subagent with specific task instructions" ;
    oc:directiveContent "Subagents dispatched for a specific task should skip this meta-skill entirely, as they already have scoped instructions." ;
    oc:hasRationale "Subagents have pre-determined scope; re-running skill discovery would be redundant and could conflict with their delegated task" ;
    oc:severityLevel "MEDIUM" .

