@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_using_superpowers a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "using-superpowers" ;
    skos:broader "Meta-skill framework" ;
    prov:wasDerivedFrom "../.agents/skills/obra/superpowers/using-superpowers" ;
    oc:contentHash "da09b7e0d983d2506c11505c9e67a108871c5d2ceacebb9ca2ffc850cf1c57b2" ;
    oc:differentia "establishes mandatory skill invocation discipline before any response, ensuring agents discover and apply relevant skills for every task" ;
    oc:handlesFailure oc:SkillNotFound ;
    oc:hasAllowedTool "Skill",
        "TodoWrite",
        "activate_skill",
        "skill",
        "update_plan",
        "write_todos" ;
    oc:hasArgumentHint "any user message or task description" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "Use when starting any conversation - establishes how to find and use skills, requiring Skill tool invocation before ANY response including clarifying questions" ;
    oc:hasName "using-superpowers" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Skills use Claude Code tool names. Non-CC platforms: see `references/copilot-tools.md` (Copilot CLI), `references/codex-tools.md` (Codex) for tool equivalents. Gemini CLI users get the tool mapping loaded automatically via GEMINI.md." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Platform Adaptation" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**In Gemini CLI:** Skills activate via the `activate_skill` tool. Gemini loads skill metadata at session start and activates the full content on demand." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "**In Claude Code:** Use the `Skill` tool. When you invoke a skill, its content is loaded and presented to you—follow it directly. Never use the Read tool on skill files." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**In other environments:** Check your platform's documentation for how skills are loaded." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**In Copilot CLI:** Use the `skill` tool. Skills are auto-discovered from installed plugins. The `skill` tool works the same as Claude Code's `Skill` tool." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "How to Access Skills" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Superpowers skills override default system prompt behavior, but **user instructions always take precedence**:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "If CLAUDE.md, GEMINI.md, or AGENTS.md says \"don't use TDD\" and a skill says \"always use TDD,\" follow the user's instructions. The user is in control." ],
                _:ref_e40bcf4f989539fd ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Instruction Priority" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:HTMLBlock ;
                    oc:blockType "html_block" ;
                    oc:contentOrder 3 ;
                    oc:htmlContent """<EXTREMELY-IMPORTANT>
If you think there is even a 1% chance a skill might apply to what you are doing, you ABSOLUTELY MUST invoke the skill.""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 5 ;
                    oc:textContent """This is not negotiable. This is not optional. You cannot rationalize your way out of this.
</EXTREMELY-IMPORTANT>""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "IF A SKILL APPLIES TO YOUR TASK, YOU DO NOT HAVE A CHOICE. YOU MUST USE IT." ],
                [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: using-superpowers
description: Use when starting any conversation - establishes how to find and use skills, requiring Skill tool invocation before ANY response including clarifying questions
""" ],
                [ a oc:HTMLBlock ;
                    oc:blockType "html_block" ;
                    oc:contentOrder 2 ;
                    oc:htmlContent """<SUBAGENT-STOP>
If you were dispatched as a subagent to execute a specific task, skip this skill.
</SUBAGENT-STOP>""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "When multiple skills could apply, use this order:" ],
                        _:ref_8a28e40e7791f92b,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """"Let's build X" → brainstorming first, then implementation skills.
"Fix this bug" → debugging first, then domain-specific skills.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Skill Priority" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Flowchart ;
                            oc:blockType "flowchart" ;
                            oc:contentOrder 2 ;
                            oc:flowchartSource """digraph skill_flow {
    "User message received" [shape=doublecircle];
    "About to EnterPlanMode?" [shape=doublecircle];
    "Already brainstormed?" [shape=diamond];
    "Invoke brainstorming skill" [shape=box];
    "Might any skill apply?" [shape=diamond];
    "Invoke Skill tool" [shape=box];
    "Announce: 'Using [skill] to [purpose]'" [shape=box];
    "Has checklist?" [shape=diamond];
    "Create TodoWrite todo per item" [shape=box];
    "Follow skill exactly" [shape=box];
    "Respond (including clarifications)" [shape=doublecircle];

    "About to EnterPlanMode?" -> "Already brainstormed?";
    "Already brainstormed?" -> "Invoke brainstorming skill" [label="no"];
    "Already brainstormed?" -> "Might any skill apply?" [label="yes"];
    "Invoke brainstorming skill" -> "Might any skill apply?";

    "User message received" -> "Might any skill apply?";
    "Might any skill apply?" -> "Invoke Skill tool" [label="yes, even 1%"];
    "Might any skill apply?" -> "Respond (including clarifications)" [label="definitely not"];
    "Invoke Skill tool" -> "Announce: 'Using [skill] to [purpose]'";
    "Announce: 'Using [skill] to [purpose]'" -> "Has checklist?";
    "Has checklist?" -> "Create TodoWrite todo per item" [label="yes"];
    "Has checklist?" -> "Follow skill exactly" [label="no"];
    "Create TodoWrite todo per item" -> "Follow skill exactly";
}
""" ;
                            oc:flowchartType "graphviz" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Invoke relevant or requested skills BEFORE any response or action.** Even a 1% chance a skill might apply means that you should invoke the skill to check. If an invoked skill turns out to be wrong for the situation, you don't need to use it." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "The Rule" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Instructions say WHAT, not HOW. \"Add X\" or \"Fix Y\" doesn't mean skip workflows." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "User Instructions" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "These thoughts mean STOP—you're rationalizing:" ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 12 ;
                            oc:tableCaption "These thoughts mean STOP—you're rationalizing" ;
                            oc:tableMarkdown """| Thought | Reality |
|---------|---------|
| "This is just a simple question" | Questions are tasks. Check for skills. |
| "I need more context first" | Skill check comes BEFORE clarifying questions. |
| "Let me explore the codebase first" | Skills tell you HOW to explore. Check first. |
| "I can check git/files quickly" | Files lack conversation context. Check for skills. |
| "Let me gather information first" | Skills tell you HOW to gather information. |
| "This doesn't need a formal skill" | If a skill exists, use it. |
| "I remember this skill" | Skills evolve. Read current version. |
| "This doesn't count as a task" | Action = task. Check for skills. |
| "The skill is overkill" | Simple things become complex. Use it. |
| "I'll just do this one thing first" | Check BEFORE doing anything. |
| "This feels productive" | Undisciplined action wastes time. Skills prevent this. |
| "I know what that means" | Knowing the concept ≠ using the skill. Invoke it. |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Red Flags" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Rigid** (TDD, debugging): Follow exactly. Don't adapt away discipline." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "The skill itself tells you which." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Flexible** (patterns): Adapt principles to context." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Skill Types" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Using Skills" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "How to order and apply skills when multiple are relevant" ;
            oc:hasStep _:ref_a6f070245af3ce75,
                _:ref_d556b73140bb557e,
                [ a oc:WorkflowStep ;
                    dcterms:description "Apply implementation skills second (domain-specific, technical) to guide execution" ;
                    oc:expectedOutcome "Execution is guided by domain expertise" ;
                    oc:stepDependsOn _:ref_d556b73140bb557e ;
                    oc:stepId "apply-implementation-skills" ] ;
            oc:workflowId "multi-skill-priority" ;
            oc:workflowName "Multiple Skill Priority Resolution" ],
        _:ref_8a28e40e7791f92b,
        [ a oc:Workflow ;
            dcterms:description "The mandatory decision process for determining whether and how to invoke skills for any incoming task" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Follow the skill exactly (rigid) or adapt principles to context (flexible)" ;
                    oc:expectedOutcome "Skill guidance is fully applied to the task" ;
                    oc:stepDependsOn _:ref_e89a09455d11a7c0 ;
                    oc:stepId "follow-skill" ],
                _:ref_18a4b94f08b59748,
                _:ref_375fe9d871c10f3c,
                _:ref_50ac453540928600,
                _:ref_e58e3b1adc4cd57b,
                _:ref_e89a09455d11a7c0 ;
            oc:workflowId "skill-invocation-flow" ;
            oc:workflowName "Skill Invocation Decision Flow" ],
        _:ref_e40bcf4f989539fd ;
    oc:impartsKnowledge oc:kn_026b3897,
        oc:kn_0883fdf2,
        oc:kn_2d406b4f,
        oc:kn_32bc4f34,
        oc:kn_3d4a1220,
        oc:kn_86e46212,
        oc:kn_bce8ef65,
        oc:kn_d464cfd4 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "adapt skill usage across platforms (Claude Code, Copilot CLI, Gemini CLI, Codex)",
        "avoid rationalizing away skill usage",
        "determine which skills apply to current work",
        "find relevant skills for a task",
        "invoke skills before responding",
        "prioritize multiple applicable skills" ;
    oc:yieldsState oc:SkillsInvoked .

oc:kn_026b3897 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When 2+ skills could apply to the current task" ;
    oc:directiveContent "When multiple skills apply, prioritize process skills (brainstorming, debugging) first to determine HOW to approach the task, then implementation skills (frontend-design, mcp-builder) second to guide execution." ;
    oc:hasRationale "Process skills establish the approach methodology before implementation skills guide specific execution, preventing premature action." ;
    oc:severityLevel "MEDIUM" .

oc:kn_0883fdf2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding how strictly to follow a skill's instructions" ;
    oc:directiveContent "Rigid skills (TDD, debugging) must be followed exactly without adaptation. Flexible skills (patterns) allow adapting principles to context. The skill itself declares which type it is." ;
    oc:hasRationale "Some skills encode discipline that fails if relaxed; others provide guiding principles meant to be adapted." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2d406b4f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Whenever the agent considers not invoking a skill" ;
    oc:directiveContent "Never rationalize skipping skill invocation with thoughts like 'this is simple', 'I need more context first', 'I remember this skill', or 'the skill is overkill'. These are red flags indicating you should immediately check for skills." ;
    oc:hasRationale "These rationalizations are documented cognitive traps that lead to skipping disciplined workflows, causing errors and wasted time." ;
    oc:severityLevel "HIGH" .

oc:kn_32bc4f34 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "After invoking and confirming a skill applies" ;
    oc:directiveContent "When a skill has a checklist, create a TodoWrite todo for each item before following the skill. Announce skill usage with 'Using [skill] to [purpose]' before execution." ;
    oc:hasRationale "Checklists ensure no steps are skipped; announcements provide transparency to the user about which skills are active." ;
    oc:severityLevel "LOW" .

oc:kn_3d4a1220 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running on Copilot CLI, Codex, or Gemini CLI instead of Claude Code" ;
    oc:directiveContent "Skills use Claude Code tool names by default. Non-Claude platforms must consult platform-specific reference files (copilot-tools.md, codex-tools.md, gemini-tools.md) for tool equivalents." ;
    oc:hasRationale "Tool names differ across platforms; incorrect tool invocation causes skill execution failures." ;
    oc:severityLevel "MEDIUM" .

oc:kn_86e46212 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Every user message received, before taking any action" ;
    oc:directiveContent "Invoke relevant skills BEFORE any response or action, including clarifying questions. Even a 1% chance a skill might apply means invoke it to check." ;
    oc:hasRationale "Skills encode domain expertise and disciplined workflows; skipping them leads to undisciplined, context-poor responses." ;
    oc:severityLevel "CRITICAL" .

oc:kn_bce8ef65 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running as a dispatched subagent" ;
    oc:directiveContent "Subagents dispatched for a specific task must skip this meta-skill entirely. It is designed for the primary conversation agent only." ;
    oc:hasRationale "Subagents already operate within a skill-guided context; re-applying this meta-skill would cause redundant overhead." ;
    oc:severityLevel "HIGH" .

oc:kn_d464cfd4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When skill instructions conflict with user-level configuration" ;
    oc:directiveContent "User instructions (CLAUDE.md, GEMINI.md, AGENTS.md, direct requests) always take precedence over skills, and skills override default system prompt behavior." ;
    oc:hasRationale "The user is in control; skills adapt the agent's behavior but cannot override explicit user preferences." ;
    oc:severityLevel "HIGH" .

_:ref_68186920948125a6 a oc:WorkflowStep ;
    dcterms:description "**Default system prompt** — lowest priority" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_72a5d0377c1edb46 a oc:WorkflowStep ;
    dcterms:description "**User's explicit instructions** (CLAUDE.md, GEMINI.md, AGENTS.md, direct requests) — highest priority" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_7a2a5f63e88f2588 a oc:WorkflowStep ;
    dcterms:description "**Process skills first** (brainstorming, debugging) - these determine HOW to approach the task" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_7b71efe8f6e896fa a oc:WorkflowStep ;
    dcterms:description "**Implementation skills second** (frontend-design, mcp-builder) - these guide execution" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_c95d249b9896fdd1 a oc:WorkflowStep ;
    dcterms:description "**Superpowers skills** — override default system behavior where they conflict" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_18a4b94f08b59748 a oc:WorkflowStep ;
    dcterms:description "Announce: 'Using [skill] to [purpose]'" ;
    oc:expectedOutcome "User is informed which skill is being used and why" ;
    oc:stepDependsOn _:ref_e58e3b1adc4cd57b ;
    oc:stepId "announce-skill" .

_:ref_375fe9d871c10f3c a oc:WorkflowStep ;
    dcterms:description "Receive user message or task" ;
    oc:expectedOutcome "Task is understood at a high level" ;
    oc:stepId "receive-message" .

_:ref_50ac453540928600 a oc:WorkflowStep ;
    dcterms:description "Evaluate if any skill might apply (even 1% chance). If about to plan, check if brainstorming was already done first." ;
    oc:expectedOutcome "List of potentially relevant skills identified" ;
    oc:stepDependsOn _:ref_375fe9d871c10f3c ;
    oc:stepId "check-skills" .

_:ref_8a28e40e7791f92b a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_7a2a5f63e88f2588,
        _:ref_7b71efe8f6e896fa ;
    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_a6f070245af3ce75 a oc:WorkflowStep ;
    dcterms:description "Identify all potentially applicable skills for the task" ;
    oc:expectedOutcome "Complete list of relevant skills" ;
    oc:stepId "identify-all-skills" .

_:ref_d556b73140bb557e a oc:WorkflowStep ;
    dcterms:description "Apply process skills first (brainstorming, debugging) to determine approach" ;
    oc:expectedOutcome "Task approach methodology is established" ;
    oc:stepDependsOn _:ref_a6f070245af3ce75 ;
    oc:stepId "apply-process-skills" .

_:ref_e40bcf4f989539fd a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_68186920948125a6,
        _:ref_72a5d0377c1edb46,
        _:ref_c95d249b9896fdd1 ;
    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_e58e3b1adc4cd57b a oc:WorkflowStep ;
    dcterms:description "Invoke the Skill tool for each potentially relevant skill. If none apply with certainty, proceed to respond." ;
    oc:expectedOutcome "Skill content is loaded and available" ;
    oc:stepDependsOn _:ref_50ac453540928600 ;
    oc:stepId "invoke-skill" .

_:ref_e89a09455d11a7c0 a oc:WorkflowStep ;
    dcterms:description "If the skill has a checklist, create a TodoWrite todo for each item" ;
    oc:expectedOutcome "All checklist items are tracked as todos" ;
    oc:stepDependsOn _:ref_18a4b94f08b59748 ;
    oc:stepId "create-checklist-todos" .

