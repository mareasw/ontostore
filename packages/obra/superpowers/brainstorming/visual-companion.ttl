    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:DirectoryWritable,
        oc:NetworkAvailable ;
    oc:resolvesIntent "collect visual feedback from user",
        "compare UI layouts side-by-side",
        "display architecture diagrams",
        "present design options visually",
        "show visual mockups in browser" ;
    oc:yieldsState oc:BrowserSessionActive,
        oc:VisualContentServed .

oc:kn_3dba753f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing HTML files to screen_dir" ;
    oc:directiveContent "Never reuse filenames — each screen gets a fresh file. Never use cat/heredoc to write HTML (dumps noise into terminal) — always use the Write tool." ;
    oc:hasRationale "Reused filenames confuse the server's newest-file detection. cat/heredoc clutters terminal output." ;
    oc:severityLevel "HIGH" .

oc:kn_4eed36c5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When transitioning from visual to terminal-only questions" ;
    oc:directiveContent "Push a waiting screen to clear stale visual content when the conversation returns to terminal-only discussion. This prevents users from staring at a resolved choice." ;
    oc:hasRationale "Stale content in the browser can confuse users about what's currently being discussed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5f4b0aab a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Each visual brainstorming iteration" ;
    oc:directiveContent "1. Check server alive (verify $STATE_DIR/server-info exists, restart if $STATE_DIR/server-stopped exists) 2. Write HTML content fragment to new file in screen_dir 3. Tell user what to expect, remind URL, end turn 4. Next turn: read $STATE_DIR/events and merge with terminal text 5. Iterate or advance — if feedback changes current screen, write new versioned file 6. When returning to terminal-only discussion, push waiting.html to clear stale content" ;
    oc:stepOrder 1 .

oc:kn_8f25b6f0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting the visual companion server" ;
    oc:directiveContent "Pass --project-dir to start-server.sh so mockups persist in .superpowers/brainstorm/. Without it, files go to /tmp and get cleaned up. Remind user to add .superpowers/ to .gitignore." ;
    oc:hasRationale "Persistence ensures mockups survive server restarts and are available for later reference." ;
    oc:severityLevel "MEDIUM" .

oc:kn_93e11610 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before starting the server" ;
    oc:directiveContent "The start-server.sh script must exist in the scripts/ directory. On Windows, use run_in_background: true on Bash tool. On Codex, foreground mode is auto-detected. On Gemini CLI, use --foreground with is_background: true." ;
    oc:severityLevel "HIGH" .

oc:kn_aa510e17 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When server starts but browser cannot reach the URL" ;
    oc:directiveContent "If URL is unreachable from browser (common in remote/containerized setups), bind non-loopback host with --host 0.0.0.0 and control displayed hostname with --url-host." ;
    oc:hasRationale "Remote and containerized environments often restrict localhost binding, requiring explicit host configuration." ;
    oc:severityLevel "LOW" .

oc:kn_c5505f7a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing HTML content to screen_dir" ;
    oc:directiveContent "Write content fragments by default (no DOCTYPE/html tags). Only write full documents when you need complete control over the page. The server auto-wraps fragments in the frame template." ;
    oc:hasRationale "Content fragments are simpler and automatically get the header, CSS theme, selection indicator, and interactive infrastructure." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ee62deda a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "Before each write to screen_dir" ;
    oc:directiveContent "The server auto-exits after 30 minutes of inactivity. If $STATE_DIR/server-info doesn't exist or $STATE_DIR/server-stopped exists, the server has shut down — restart before continuing." ;
    oc:hasRationale "Long gaps between visual questions can cause the server to time out, leading to failed writes." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f9dad66a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating visual content for brainstorming" ;
    oc:directiveContent "Scale fidelity to the question — wireframes for layout, polish for polish questions. Keep 2-4 options max per screen. Explain the question on each page." ;
    oc:hasRationale "Overloading screens with options or mismatching fidelity to the question confuses users and obscures the decision." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fe069379 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before each brainstorming question" ;
    oc:directiveContent "Decide per-question whether to use browser or terminal, not per-session. Use browser when content is visual (mockups, diagrams, spatial relationships). Use terminal when content is text or tabular (requirements, tradeoff lists, conceptual choices)." ;
    oc:hasRationale "A question about a UI topic is not automatically a visual question. 'What kind of wizard?' is conceptual; 'Which wizard layout feels right?' is visual." ;
    oc:severityLevel "HIGH" .

_:ref_04cd281307f8e347 a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 2 ;
            oc:itemText "Give a brief text summary of what's on screen (e.g., \"Showing 3 layout options for the homepage\")" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 1 ;
            oc:itemText "Remind them of the URL (every step, not just first)" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 3 ;
            oc:itemText "Ask them to respond in the terminal: \"Take a look and let me know what you think. Click to select an option if you'd like.\"" ] .

