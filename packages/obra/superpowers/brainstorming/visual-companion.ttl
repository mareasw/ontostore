_:ref_46777514f4742e18 a oc:WorkflowStep ;
    dcterms:description "Repeat until done." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_6487527d0f0c8025 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "Merge with the user's terminal text to get the full picture" .

_:ref_6ea2f0ff9efcb0f5 a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem _:ref_6487527d0f0c8025,
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 3 ;
            oc:itemText "The terminal message is the primary feedback; `state_dir/events` provides structured interaction data" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 1 ;
            oc:itemText "Read `$STATE_DIR/events` if it exists — this contains the user's browser interactions (clicks, selections) as JSON lines" ] .

_:ref_83fff9b7e7b6cb11 a oc:WorkflowStep ;
    dcterms:description "**Iterate or advance** — if feedback changes current screen, write a new file (e.g., `layout-v2.html`). Only move to the next question when the current step is validated." ;
