    dcterms:description "**Tell user what to expect and end your turn:**" ;
    oc:blockType "workflow_step" ;
    oc:hasChild _:ref_04cd281307f8e347 ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_3828de8b00ed81f3 a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 5 ;
