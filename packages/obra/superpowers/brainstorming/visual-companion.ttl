</div>
<button class="mock-button">Action Button</button>
<input class="mock-input" placeholder="Input field">
<div class="placeholder">Placeholder area</div>
""" ;
                                    oc:codeLanguage "html" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 227-236" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "Mock elements (wireframe building blocks)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """<div class="split">
  <div class="mockup"><!-- left --></div>
  <div class="mockup"><!-- right --></div>
</div>
""" ;
                                    oc:codeLanguage "html" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 209-214" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Split view (side-by-side)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """<div class="options" data-multiselect>
  <!-- same option markup — users can select/deselect multiple -->
