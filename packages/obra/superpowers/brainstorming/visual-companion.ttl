        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 3 ;
            oc:itemText "**Never reuse filenames** — each screen gets a fresh file" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 4 ;
