@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_brainstorming a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "brainstorming" ;
    skos:broader "Collaborative design methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/brainstorming" ;
    oc:contentHash "97245712e7ad9fce46d8cf7fd5dc945f8b8a7e66408f60f1dd90b9b63d03da4f" ;
    oc:dependsOnSkill oc:skill_writing_plans ;
    oc:differentia "guides iterative idea refinement through structured questioning, approach exploration, and spec writing before any implementation, with optional browser-based visual companion for mockups and diagrams" ;
    oc:handlesFailure oc:DesignAmbiguityDetected,
        oc:ScopeTooLarge,
        oc:UserDeclinesApproval ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "idea or feature description" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "You MUST use this before any creative work - creating features, building components, adding functionality, or modifying behavior. Explores user intent, requirements and design before implementation." ;
    oc:hasName "brainstorming" ;
    oc:impartsKnowledge oc:kn_03301385,
        oc:kn_256890c3,
        oc:kn_413025ba,
        oc:kn_4527d262,
        oc:kn_523f34fa,
        oc:kn_527fafc3,
        oc:kn_5e7320e5,
        oc:kn_7612131a,
        oc:kn_798138f0,
        oc:kn_95533898,
        oc:kn_c84e0813 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProjectContextAvailable ;
    oc:resolvesIntent "brainstorm approaches and trade-offs for a feature or project",
        "collaboratively define requirements, constraints, and success criteria",
        "create a design specification before implementation",
        "decompose large projects into scoped sub-projects",
        "explore and refine an idea into a fully formed design",
        "visualize design options with browser-based mockups and diagrams" ;
    oc:yieldsState oc:DesignApproved,
        oc:DesignSpecWritten,
        oc:SpecReviewed .

oc:kn_03301385 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When returning to a visual brainstorming session after a break" ;
    oc:directiveContent "If the brainstorming visual companion server has shut down (check for server-stopped file or missing server-info), restart it using start-server.sh before continuing with visual questions." ;
    oc:hasRationale "The server auto-exits after 30 minutes of inactivity. Restarting is straightforward and preserves the session directory." ;
    oc:severityLevel "LOW" .

oc:kn_256890c3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning any new creative work, feature, or modification" ;
    oc:directiveContent "Never skip the design phase by claiming a project is 'too simple to need a design'. Every project — even a config change or single-function utility — must have a design presented and approved before implementation begins." ;
    oc:hasRationale "Simple projects are where unexamined assumptions cause the most wasted work. A design can be short (a few sentences), but it must be presented and approved." ;
    oc:severityLevel "CRITICAL" .

oc:kn_413025ba a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When considering whether brainstorming can be re-run" ;
    oc:directiveContent "The brainstorming process is inherently iterative and non-idempotent: designs are refined through user feedback loops, and the spec document is overwritten as the design evolves. Each session produces a unique spec." ;
    oc:hasRationale "The collaborative nature means each pass may produce different results based on user input. This is by design." ;
    oc:severityLevel "LOW" .

oc:kn_4527d262 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During the clarifying questions phase of brainstorming" ;
    oc:directiveContent "Ask only ONE clarifying question per message. Do not combine multiple questions, context summaries, or the visual companion offer into a single message." ;
    oc:hasRationale "One question at a time prevents overwhelming the user and ensures each answer is thoughtful and complete." ;
    oc:severityLevel "HIGH" .

oc:kn_523f34fa a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After the spec document is written, before user review" ;
    oc:directiveContent "After writing the spec document, perform a self-review: scan for placeholders (TBD, TODO), check internal consistency across sections, verify scope is focused enough for one implementation plan, and resolve any ambiguous requirements." ;
    oc:hasRationale "Catching your own errors before user review saves a round-trip and demonstrates thoroughness. Fix issues inline without re-reviewing." ;
    oc:severityLevel "HIGH" .

oc:kn_527fafc3 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "After design approval, during documentation phase" ;
    oc:directiveContent "This skill writes a design spec file to docs/superpowers/specs/YYYY-MM-DD-<topic>-design.md and commits it to git. The visual companion creates session files under .superpowers/brainstorm/." ;
    oc:hasRationale "These side effects create persistent artifacts. The .superpowers/ directory should be added to .gitignore." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5e7320e5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating a new project request before detailed questioning" ;
    oc:directiveContent "Before refining details, assess whether the project scope involves multiple independent subsystems. If so, decompose into sub-projects first, then brainstorm the first sub-project through the normal flow." ;
    oc:hasRationale "Large projects that aren't decomposed first lead to specs that are too broad for a single implementation plan, wasting effort on premature detail." ;
    oc:severityLevel "HIGH" .

oc:kn_7612131a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "At the very start of a brainstorming session" ;
    oc:directiveContent "Before asking any questions, explore the current project context: check files, docs, and recent commits. When working in existing codebases, follow existing patterns and only propose targeted improvements that serve the current goal." ;
    oc:hasRationale "Contextual awareness prevents proposing designs that contradict existing patterns or duplicate existing functionality." ;
    oc:severityLevel "HIGH" .

oc:kn_798138f0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Throughout the entire brainstorming process" ;
    oc:directiveContent "Never invoke any implementation skill, write code, scaffold a project, or take implementation action until a design has been presented and user-approved. The ONLY skill to invoke after brainstorming is writing-plans." ;
    oc:hasRationale "This hard gate prevents premature implementation and ensures all creative work is preceded by intentional design thinking." ;
    oc:severityLevel "CRITICAL" .

oc:kn_95533898 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During the approach exploration phase of brainstorming" ;
    oc:directiveContent "Always propose 2-3 different approaches with trade-offs before settling on one. Lead with your recommended option and explain the reasoning." ;
    oc:hasRationale "Exploring alternatives ensures the chosen approach is deliberate rather than default, and the user benefits from seeing the design space." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c84e0813 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting the design and architecture sections" ;
    oc:directiveContent "Break the system into smaller units with one clear purpose, well-defined interfaces, and independent testability. For each unit, you should be able to answer: what does it do, how do you use it, and what does it depend on?" ;
    oc:hasRationale "Smaller, well-bounded units are easier to reason about in context, edits are more reliable when files are focused, and a file growing large signals it's doing too much." ;
    oc:severityLevel "MEDIUM" .

