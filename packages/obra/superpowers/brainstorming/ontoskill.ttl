@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_brainstorming a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "brainstorming" ;
    skos:broader "Collaborative design process" ;
    prov:wasDerivedFrom "../.agents/skills/obra/superpowers/brainstorming" ;
    oc:contentHash "97245712e7ad9fce46d8cf7fd5dc945f8b8a7e66408f60f1dd90b9b63d03da4f" ;
    oc:dependsOnSkill oc:skill_ontoskills_writing_plans ;
    oc:differentia "that explores user intent and requirements through structured dialogue before producing an approved design specification" ;
    oc:handlesFailure oc:DesignRejected,
        oc:ScopeTooLarge ;
    oc:hasArgumentHint "idea or feature description" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "You MUST use this before any creative work - creating features, building components, adding functionality, or modifying behavior. Explores user intent, requirements and design before implementation." ;
    oc:hasName "brainstorming" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: brainstorming
description: "You MUST use this before any creative work - creating features, building components, adding functionality, or modifying behavior. Explores user intent, requirements and design before implementation."
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Start by understanding the current project context, then ask questions one at a time to refine the idea. Once you understand what you're building, present the design and get user approval." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Help turn ideas into fully formed designs and specs through natural collaborative dialogue." ],
                [ a oc:HTMLBlock ;
                    oc:blockType "html_block" ;
                    oc:contentOrder 3 ;
                    oc:htmlContent """<HARD-GATE>
Do NOT invoke any implementation skill, write any code, scaffold any project, or take any implementation action until you have presented a design and the user has approved it. This applies to EVERY project regardless of perceived simplicity.
</HARD-GATE>""" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Use elements-of-style:writing-clearly-and-concisely skill if available" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Commit the design document to git" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:hasChild [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "(User preferences for spec location override this default)" ] ] ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Write the validated design (spec) to `docs/superpowers/specs/YYYY-MM-DD-<topic>-design.md`" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 8 ;
                            oc:textContent "Wait for the user's response. If they request changes, make them and re-run the spec review loop. Only proceed once the user approves." ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 7 ;
                            oc:quoteContent "\"Spec written and committed to `<path>`. Please review it and let me know if you want to make any changes before we start writing out the implementation plan.\"" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**Spec Self-Review:**
After writing the spec document, look at it with fresh eyes:""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent """**User Review Gate:**
After the spec review loop passes, ask the user to review the written spec before proceeding:""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 9 ;
                            oc:textContent "**Implementation:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "Fix any issues inline. No need to re-review — just fix and move on." ],
                        _:ref_b8800af5cb183bad,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Documentation:**" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 10 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Do NOT invoke any other skill. writing-plans is the next step." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Invoke the writing-plans skill to create a detailed implementation plan" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "After the Design" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**This offer MUST be its own message.** Do not combine it with clarifying questions, context summaries, or any other content. The message should contain ONLY the offer above and nothing else. Wait for the user's response before continuing. If they decline, proceed with text-only brainstorming." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "A browser-based companion for showing mockups, diagrams, and visual options during brainstorming. Available as a tool — not a mode. Accepting the companion means it's available for questions that benefit from visual treatment; it does NOT mean every question goes through the browser." ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 6 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Use the terminal** for content that is text — requirements questions, conceptual choices, tradeoff lists, A/B/C/D text options, scope decisions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Use the browser** for content that IS visual — mockups, wireframes, layout comparisons, architecture diagrams, side-by-side visual designs" ] ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 3 ;
                            oc:quoteContent "\"Some of what we're working on might be easier to explain if I can show it to you in a web browser. I can put together mockups, diagrams, comparisons, and other visuals as we go. This feature is still new and can be token-intensive. Want to try it? (Requires opening a local URL)\"" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Offering the companion:** When you anticipate that upcoming questions will involve visual content (mockups, layouts, diagrams), offer it once for consent:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent "A question about a UI topic is not automatically a visual question. \"What does personality mean in this context?\" is a conceptual question — use the terminal. \"Which wizard layout works better?\" is a visual question — use the browser." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 8 ;
                            oc:textContent """If they agree to the companion, read the detailed guide before proceeding:
`skills/brainstorming/visual-companion.md`""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "**Per-question decision:** Even after the user accepts, decide FOR EACH QUESTION whether to use the browser or the terminal. The test: **would the user understand this better by seeing it than reading it?**" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Visual Companion" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**The terminal state is invoking writing-plans.** Do NOT invoke frontend-design, mcp-builder, or any other implementation skill. The ONLY skill you invoke after brainstorming is writing-plans." ],
                        [ a oc:Flowchart ;
                            oc:blockType "flowchart" ;
                            oc:contentOrder 1 ;
                            oc:flowchartSource """digraph brainstorming {
    "Explore project context" [shape=box];
    "Visual questions ahead?" [shape=diamond];
    "Offer Visual Companion\\n(own message, no other content)" [shape=box];
    "Ask clarifying questions" [shape=box];
    "Propose 2-3 approaches" [shape=box];
    "Present design sections" [shape=box];
    "User approves design?" [shape=diamond];
    "Write design doc" [shape=box];
    "Spec self-review\\n(fix inline)" [shape=box];
    "User reviews spec?" [shape=diamond];
    "Invoke writing-plans skill" [shape=doublecircle];

    "Explore project context" -> "Visual questions ahead?";
    "Visual questions ahead?" -> "Offer Visual Companion\\n(own message, no other content)" [label="yes"];
    "Visual questions ahead?" -> "Ask clarifying questions" [label="no"];
    "Offer Visual Companion\\n(own message, no other content)" -> "Ask clarifying questions";
    "Ask clarifying questions" -> "Propose 2-3 approaches";
    "Propose 2-3 approaches" -> "Present design sections";
    "Present design sections" -> "User approves design?";
    "User approves design?" -> "Present design sections" [label="no, revise"];
    "User approves design?" -> "Write design doc" [label="yes"];
    "Write design doc" -> "Spec self-review\\n(fix inline)";
    "Spec self-review\\n(fix inline)" -> "User reviews spec?";
    "User reviews spec?" -> "Write design doc" [label="changes requested"];
    "User reviews spec?" -> "Invoke writing-plans skill" [label="approved"];
}
""" ;
                            oc:flowchartType "graphviz" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Process Flow" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_7b837be375a04f7e,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "You MUST create a task for each of these items and complete them in order:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Checklist" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Every project goes through this process. A todo list, a single-function utility, a config change — all of them. \"Simple\" projects are where unexamined assumptions cause the most wasted work. The design can be short (a few sentences for truly simple projects), but you MUST present it and get approval." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Anti-Pattern: \"This Is Too Simple To Need A Design\"" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Understanding the idea:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent "**Design for isolation and clarity:**" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Present options conversationally with your recommendation and reasoning" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Propose 2-3 different approaches with trade-offs" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Lead with your recommended option and explain why" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 8 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "For each unit, you should be able to answer: what does it do, how do you use it, and what does it depend on?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Break the system into smaller units that each have one clear purpose, communicate through well-defined interfaces, and can be understood and tested independently" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Can someone understand what a unit does without reading its internals? Can you change the internals without breaking consumers? If not, the boundaries need work." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Smaller, well-bounded units are also easier for you to work with - you reason better about code you can hold in context at once, and your edits are more reliable when files are focused. When a file grows large, that's often a signal that it's doing too much." ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Exploring approaches:**" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 6 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Ask after each section whether it looks right so far" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Once you believe you understand what you're building, present the design" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Be ready to go back and clarify if something doesn't make sense" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Scale each section to its complexity: a few sentences if straightforward, up to 200-300 words if nuanced" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Cover: architecture, components, data flow, error handling, testing" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "Only one question per message - if a topic needs more exploration, break it into multiple questions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Prefer multiple choice questions when possible, but open-ended is fine too" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "If the project is too large for a single spec, help the user decompose into sub-projects: what are the independent pieces, how do they relate, what order should they be built? Then brainstorm the first sub-project through the normal design flow. Each sub-project gets its own spec → plan → implementation cycle." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Before asking detailed questions, assess scope: if the request describes multiple independent subsystems (e.g., \"build a platform with chat, file storage, billing, and analytics\"), flag this immediately. Don't spend questions refining details of a project that needs to be decomposed first." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "For appropriately-scoped projects, ask questions one at a time to refine the idea" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Check out the current project state first (files, docs, recent commits)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "Focus on understanding: purpose, constraints, success criteria" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 9 ;
                            oc:textContent "**Working in existing codebases:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "**Presenting the design:**" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 10 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Explore the current structure before proposing changes. Follow existing patterns." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Don't propose unrelated refactoring. Stay focused on what serves the current goal." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Where existing code has problems that affect the work (e.g., a file that's grown too large, unclear boundaries, tangled responsibilities), include targeted improvements as part of the design - the way a good developer improves code they're working in." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "The Process" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Be flexible** - Go back and clarify when something doesn't make sense" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**One question at a time** - Don't overwhelm with multiple questions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Multiple choice preferred** - Easier to answer than open-ended when possible" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Incremental validation** - Present design, get approval before moving on" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Explore alternatives** - Always propose 2-3 approaches before settling" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**YAGNI ruthlessly** - Remove unnecessary features from all designs" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Key Principles" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Brainstorming Ideas Into Designs" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Iterative loop for browser-based visual brainstorming questions within the main brainstorming flow." ;
            oc:hasStep _:ref_115554bcd6cc5caa,
                [ a oc:WorkflowStep ;
                    dcterms:description "Iterate on current visual or advance. Push waiting.html when returning to terminal-only questions" ;
                    oc:expectedOutcome "Visual questions resolved, ready to continue terminal-only brainstorming" ;
                    oc:stepDependsOn _:ref_115554bcd6cc5caa ;
                    oc:stepId "iterate-or-advance" ],
                _:ref_b21e29c768c3cd84,
                _:ref_ea12338902fc68b1 ;
            oc:workflowId "visual-companion-loop" ;
            oc:workflowName "Visual Companion Interaction Loop" ],
        _:ref_7b837be375a04f7e,
        [ a oc:Workflow ;
            dcterms:description "Complete flow from idea exploration to approved design specification ready for implementation planning." ;
            oc:hasStep _:ref_07c4652d84acf091,
                _:ref_14ff3da2b780185b,
                _:ref_15512b8d97ce66b8,
                _:ref_31f8719e4cf86422,
                _:ref_68684c7dcb1adb0a,
                _:ref_872393fc1a442a93,
                _:ref_c2d621d76a78ef87,
                _:ref_df5e8d553fca4569,
                [ a oc:WorkflowStep ;
                    dcterms:description "Invoke writing-plans skill to create implementation plan" ;
                    oc:expectedOutcome "Implementation planning begins" ;
                    oc:stepDependsOn _:ref_14ff3da2b780185b ;
                    oc:stepId "transition" ] ;
            oc:workflowId "brainstorming-main" ;
            oc:workflowName "Brainstorming to Design Spec" ],
        _:ref_b8800af5cb183bad ;
    oc:impartsKnowledge oc:kn_09e01d00,
        oc:kn_0d338a12,
        oc:kn_1acc0f23,
        oc:kn_1cd7a4de,
        oc:kn_4ac5a18d,
        oc:kn_7e04beb9,
        oc:kn_919467a3,
        oc:kn_a399e917,
        oc:kn_a6b8aeb9,
        oc:kn_ab10a329,
        oc:kn_ac85825f,
        oc:kn_b8ac8442,
        oc:kn_c7447730,
        oc:kn_c9640a9e,
        oc:kn_d8c1d305,
        oc:kn_fa0be349 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:ProjectContextAvailable ;
    oc:resolvesIntent "brainstorm ideas",
        "create design specification",
        "decompose large projects",
        "design a feature",
        "explore requirements",
        "validate design before implementation" ;
    oc:yieldsState oc:DesignDocumentWritten,
        oc:DesignSpecApproved .

oc:kn_09e01d00 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "During approach exploration phase" ;
    oc:directiveContent "Always propose 2-3 different approaches with trade-offs before settling on a design. Lead with your recommended option and explain why." ;
    oc:hasRationale "Single-option proposals skip critical evaluation. Multiple approaches surface assumptions and help users make informed choices." ;
    oc:severityLevel "HIGH" .

oc:kn_0d338a12 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "At the start of brainstorming, after exploring project context" ;
    oc:directiveContent "Before detailed questions, assess scope. If the request describes multiple independent subsystems, flag immediately and decompose into sub-projects before refining details." ;
    oc:hasRationale "Refining details of an oversized project wastes questions. Decomposition must happen first so each sub-project gets its own spec→plan→implementation cycle." ;
    oc:severityLevel "HIGH" .

oc:kn_1acc0f23 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every brainstorming session" ;
    oc:directiveContent "1. Explore project context (files, docs, commits) 2. Offer visual companion if visual questions ahead (own message, no other content) 3. Ask clarifying questions one at a time 4. Propose 2-3 approaches with trade-offs and recommendation 5. Present design in scaled sections, get approval per section 6. Write design doc to docs/superpowers/specs/ and commit 7. Self-review spec (placeholders, contradictions, ambiguity, scope) 8. User reviews written spec 9. Invoke writing-plans skill" ;
    oc:hasRationale "Ensures complete coverage from context gathering through approved spec to planning handoff." ;
    oc:severityLevel "CRITICAL" ;
    oc:stepOrder 1 .

oc:kn_1cd7a4de a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "After writing the spec document, before user review" ;
    oc:directiveContent "1. Placeholder scan (TBD/TODO/vague requirements) 2. Internal consistency (contradictions, architecture vs feature descriptions) 3. Scope check (single plan or needs decomposition) 4. Ambiguity check (requirements interpretable two ways — pick one)" ;
    oc:hasRationale "Self-review catches gaps before the user sees them, reducing back-and-forth." ;
    oc:severityLevel "MEDIUM" ;
    oc:stepOrder 7 .

oc:kn_4ac5a18d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When using the visual companion for browser-based brainstorming" ;
    oc:directiveContent "1. Write HTML content fragment to screen_dir (no full document needed, server wraps it) 2. Tell user what to expect, remind URL, ask for terminal response 3. Next turn: read state_dir/events for browser interactions, merge with terminal text 4. Iterate or advance; push waiting.html when returning to terminal-only questions" ;
    oc:hasRationale "Structured loop ensures the browser visual channel is used effectively alongside terminal conversation." ;
    oc:stepOrder 3 .

oc:kn_7e04beb9 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When writing the design specification document" ;
    oc:directiveContent """docs/superpowers/specs/YYYY-MM-DD-<topic>-design.md

Sections: architecture, components, data flow, error handling, testing.
Scale each section to complexity (sentences for simple, up to 200-300 words for nuanced).""" ;
    oc:hasRationale "Standardized location and naming enables downstream tools to find specs. User preferences override default location." ;
    oc:templateVariables "YYYY-MM-DD",
        "topic" .

oc:kn_919467a3 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Node.js must be available for running the visual companion server (scripts/server.cjs)" .

oc:kn_a399e917 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any implementation work" ;
    oc:directiveContent "Never skip the design phase regardless of perceived simplicity. Even single-function utilities and config changes must have a design presented and approved." ;
    oc:hasRationale "'Simple' projects are where unexamined assumptions cause the most wasted work. A short design is acceptable, but skipping design entirely is not." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a6b8aeb9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After design is approved" ;
    oc:directiveContent "The ONLY skill to invoke after brainstorming is writing-plans. Do NOT invoke frontend-design, mcp-builder, or any other implementation skill directly." ;
    oc:hasRationale "Maintains the pipeline: brainstorming → writing-plans → implementation. Skipping writing-plans breaks the planning chain." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ab10a329 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When brainstorming changes to existing codebases" ;
    oc:directiveContent "Follow existing codebase patterns when working in existing projects. Include targeted improvements only where existing problems affect the current work. Do not propose unrelated refactoring." ;
    oc:hasRationale "Consistency with existing code reduces cognitive load. Unrelated refactoring scope-creeps the design." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ac85825f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting design sections" ;
    oc:directiveContent "YAGNI ruthlessly — remove unnecessary features from all designs. Scale design sections to complexity: a few sentences for straightforward parts, up to 200-300 words for nuanced ones." ;
    oc:hasRationale "Over-designed specs waste time on features that may never be needed. Proportional detail keeps specs focused." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b8ac8442 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During clarifying questions phase" ;
    oc:directiveContent "Ask one question at a time. Prefer multiple choice over open-ended when possible. Break complex topics into multiple sequential questions." ;
    oc:hasRationale "Multiple questions overwhelm users. One-at-a-time keeps dialogue focused and yields better answers." ;
    oc:severityLevel "HIGH" .

oc:kn_c7447730 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting designs" ;
    oc:directiveContent "Break the system into smaller units that each have one clear purpose, communicate through well-defined interfaces, and can be understood and tested independently." ;
    oc:hasRationale "Smaller well-bounded units are easier to reason about, test, and edit reliably. A file growing large signals it's doing too much." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c9640a9e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — hard gate" ;
    oc:directiveContent "Do NOT invoke any implementation skill, write any code, scaffold any project, or take any implementation action until a design has been presented and user-approved." ;
    oc:hasRationale "Premature implementation wastes effort when requirements are unclear or wrong." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d8c1d305 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting visual companion session" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """scripts/start-server.sh --project-dir /path/to/project
# Returns: {"type":"server-started","port":52341,"url":"http://localhost:52341",
#           "screen_dir":".../content","state_dir":".../state"}""" .

oc:kn_fa0be349 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When dispatching spec document reviewer subagent" ;
    oc:directiveContent """Spec Review Status: Approved | Issues Found
Issues: [Section X]: [specific issue] - [why it matters for planning]
Recommendations (advisory, non-blocking): [suggestions]""" ;
    oc:templateVariables "Section",
        "issue",
        "planning_impact",
        "suggestion" .

