    oc:contentHash "f39ca847f32dc560b1ec784dd50e86831f4e9197a1862a8a0946f9fbc23ee053" ;
    oc:dependsOnSkill oc:skill_ontoskills_executing_plans,
        oc:skill_ontoskills_subagent_driven_development ;
    oc:differentia "dispatches a code-reviewer subagent with isolated context to evaluate git diff ranges against requirements before proceeding" ;
    oc:handlesFailure oc:CriticalIssuesFound,
        oc:ReviewFailed ;
    oc:hasAllowedTool "Bash",
        "Task" ;
    oc:hasArgumentHint "BASE_SHA and HEAD_SHA git commit range to review" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Use when completing tasks, implementing major features, or before merging to verify work meets requirements" ;
    oc:hasName "requesting-code-review" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: requesting-code-review
description: Use when completing tasks, implementing major features, or before merging to verify work meets requirements
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Dispatch superpowers:code-reviewer subagent to catch issues before they cascade. The reviewer gets precisely crafted context for evaluation — never your session's history. This keeps the reviewer focused on the work product, not your thought process, and preserves your own context for continued work." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Core principle:** Review early, review often." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """[Just completed Task 2: Add verification function]

You: Let me request code review before proceeding.

BASE_SHA=$(git log --oneline | grep "Task 1" | head -1 | awk '{print $1}')
HEAD_SHA=$(git rev-parse HEAD)

[Dispatch superpowers:code-reviewer subagent]
  WHAT_WAS_IMPLEMENTED: Verification and repair functions for conversation index
  PLAN_OR_REQUIREMENTS: Task 2 from docs/superpowers/plans/deployment-plan.md
  BASE_SHA: a7981ec
  HEAD_SHA: 3df7661
  DESCRIPTION: Added verifyIndex() and repairIndex() with 4 issue types

[Subagent returns]:
  Strengths: Clean architecture, real tests
  Issues:
    Important: Missing progress indicators
    Minor: Magic number (100) for reporting interval
  Assessment: Ready to proceed

You: [Fix progress indicators]
[Continue to Task 3]
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 51-75" ] ;
