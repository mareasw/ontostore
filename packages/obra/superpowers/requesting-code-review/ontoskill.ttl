    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Full workflow for dispatching a code review subagent and acting on its feedback" ;
            oc:hasStep _:ref_ad9d8a694ef79c42,
                _:ref_b31eab853b35afb0,
                [ a oc:WorkflowStep ;
                    dcterms:description "Triage feedback: fix Critical issues immediately, fix Important issues before proceeding, note Minor issues for later. Push back on incorrect feedback with technical reasoning." ;
                    oc:expectedOutcome "All Critical and Important issues resolved or acknowledged, code ready to proceed or merge" ;
                    oc:stepDependsOn _:ref_ad9d8a694ef79c42 ;
                    oc:stepId "act-on-feedback" ] ;
