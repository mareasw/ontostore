    oc:isUserInvocable true ;
    oc:nature "Workflow" ;
    oc:requiresState oc:CodeCommitted,
        oc:GitAvailable ;
    oc:resolvesIntent "catch issues before merge",
        "get fresh perspective on code",
        "request code review",
        "validate implementation against plan",
        "verify work meets requirements" ;
    oc:yieldsState oc:CodeReviewed,
        oc:IssuesIdentified .

oc:kn_02efe867 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When integrating code review into any development workflow" ;
    oc:directiveContent "Review early, review often. In subagent-driven development, review after EACH task. In executing plans, review after each batch (3 tasks). In ad-hoc development, review before merge." ;
    oc:hasRationale "Catching issues early prevents them from compounding across subsequent tasks, reducing total rework." ;
    oc:severityLevel "HIGH" .

oc:kn_30a5c918 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When considering re-reviewing already reviewed code" ;
    oc:directiveContent "Multiple reviews of the same code range are safe and encouraged — each review provides independent assessment." ;
    oc:hasRationale "Fresh perspectives catch different issues, and subsequent reviews can verify fixes." ;
    oc:severityLevel "LOW" .

oc:kn_481ab9ee a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Expected output format from code-reviewer subagent" ;
    oc:directiveContent """### Strengths
[Specific positive findings]

### Issues
#### Critical (Must Fix)
[Bugs, security, data loss]
#### Important (Should Fix)
[Architecture, missing features, test gaps]
#### Minor (Nice to Have)
[Style, optimization, docs]
For each: File:line, what's wrong, why it matters, how to fix

### Recommendations
[Improvements]

### Assessment
**Ready to merge?** [Yes/No/With fixes]
**Reasoning:** [1-2 sentences]""" ;
    oc:templateVariables "Critical Issues",
        "Important Issues",
        "Minor Issues",
        "Ready to merge",
        "Reasoning",
        "Recommendations",
        "Strengths" .

oc:kn_a957aa47 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When dispatching any code review subagent" ;
    oc:directiveContent "Dispatch the code-reviewer subagent with precisely crafted context — never your session's history. The reviewer gets only the work product context." ;
    oc:hasRationale "Isolated context keeps the reviewer focused on the work product, not your thought process, and preserves your own context for continued work." ;
    oc:severityLevel "HIGH" .

oc:kn_b92011d5 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When disagreeing with code review feedback" ;
    oc:directiveContent "If the reviewer is wrong, push back with technical reasoning, show code/tests that prove it works, or request clarification." ;
    oc:hasRationale "Blind acceptance of incorrect feedback introduces unnecessary changes; reasoned pushback maintains code quality." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d15131fa a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When receiving code review feedback" ;
    oc:directiveContent "Fix Critical issues immediately. Fix Important issues before proceeding. Note Minor issues for later." ;
    oc:hasRationale "Severity-based triage ensures production-blocking issues are resolved before new work begins while not blocking progress on minor improvements." ;
    oc:severityLevel "HIGH" .

oc:kn_d7d3e683 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When capturing git commit range for code review" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """BASE_SHA=$(git rev-parse HEAD~1)  # or origin/main
HEAD_SHA=$(git rev-parse HEAD)""" .

oc:kn_e0e565a4 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before requesting code review" ;
    oc:directiveContent "Git repository with committed changes and a Task tool capable of dispatching subagents" .

oc:kn_ec693c57 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to request or act on code review" ;
    oc:directiveContent "Never skip review because 'it's simple', ignore Critical issues, proceed with unfixed Important issues, or argue with valid technical feedback." ;
    oc:hasRationale "Skipping review on 'simple' changes is exactly when subtle bugs slip through, and ignoring issues compounds technical debt." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f969d49d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When requesting any code review" ;
    oc:directiveContent "1. Get git SHAs (BASE_SHA from origin/main or HEAD~1, HEAD_SHA from HEAD) 2. Dispatch superpowers:code-reviewer subagent via Task tool with filled template from code-reviewer.md 3. Act on feedback by severity (Critical immediately, Important before proceeding, Minor noted for later)" ;
    oc:stepOrder 1 .

_:ref_ad9d8a694ef79c42 a oc:WorkflowStep ;
    dcterms:description "Dispatch superpowers:code-reviewer subagent via Task tool, filling the code-reviewer.md template with WHAT_WAS_IMPLEMENTED, PLAN_OR_REQUIREMENTS, BASE_SHA, HEAD_SHA, and DESCRIPTION" ;
    oc:expectedOutcome "Subagent returns structured review with Strengths, Issues (by severity), Recommendations, and Assessment" ;
    oc:stepDependsOn _:ref_b31eab853b35afb0 ;
    oc:stepId "dispatch-reviewer" .

_:ref_b31eab853b35afb0 a oc:WorkflowStep ;
    dcterms:description "Capture BASE_SHA (origin/main or HEAD~1) and HEAD_SHA (HEAD) to define the git diff range" ;
    oc:expectedOutcome "Two valid git commit SHAs identifying the changes to review" ;
    oc:stepId "get-shas" .

