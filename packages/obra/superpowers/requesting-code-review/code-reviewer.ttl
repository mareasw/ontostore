oc:kn_28a018fb a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When formatting code review output" ;
    oc:directiveContent """### Strengths
[Specific, file-referenced positives]

### Issues

#### Critical (Must Fix)
[File:line, issue, why, fix]

#### Important (Should Fix)
[File:line, issue, why, fix]

#### Minor (Nice to Have)
[File:line, issue, why, fix]

### Recommendations
[Quality/architecture/process improvements]

### Assessment
**Ready to merge?** [Yes/No/With fixes]
**Reasoning:** [1-2 sentence technical assessment]""" ;
    oc:templateVariables "Critical Issues",
        "Important Issues",
        "Minor Issues",
        "Ready to merge?",
        "Reasoning",
        "Recommendations",
        "Strengths" .

oc:kn_2b94c1d0 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When retrieving the code changes to review" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "git diff --stat {BASE_SHA}..{HEAD_SHA} && git diff {BASE_SHA}..{HEAD_SHA}" .

oc:kn_2c15047d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing a comprehensive code review" ;
    oc:directiveContent "Review must cover five dimensions: code quality (separation, error handling, DRY), architecture (scalability, security, performance), testing (real logic tests, edge cases, integration), requirements (spec compliance, scope creep), and production readiness (migrations, backward compat, documentation)." ;
    oc:hasRationale "Incomplete reviews miss entire classes of defects; the checklist ensures systematic coverage" ;
    oc:severityLevel "HIGH" .

oc:kn_2f7cbe77 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When reporting any issue in code review" ;
    oc:directiveContent "Every issue must include: file:line reference, what's wrong, why it matters, and how to fix (if not obvious)." ;
    oc:hasRationale "Vague feedback like 'improve error handling' is unactionable; specific file:line references let the author locate and fix issues immediately" ;
    oc:severityLevel "HIGH" .

oc:kn_31a5d3cc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When completing a code review" ;
    oc:directiveContent "Never say 'looks good' without actually reviewing the code. Never give feedback on code you didn't review. Never avoid giving a clear verdict." ;
    oc:hasRationale "Rubber-stamping reviews undermine the entire review process and allow defects into production" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4ae93fbf a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning code review" ;
    oc:directiveContent "Verify git range is valid, plan/requirements are available, and what-was-implemented description is provided before starting review" ;
    oc:hasRationale "Missing context leads to incomplete or misguided reviews" .

oc:kn_5789332e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing a code review" ;
    oc:directiveContent "1. Review what was implemented against the description 2. Compare against plan/requirements 3. Check code quality, architecture, testing 4. Categorize issues by severity (Critical/Important/Minor) 5. Assess production readiness and give clear verdict" ;
    oc:stepOrder 1 .

oc:kn_d6fdb1dd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring review output" ;
    oc:directiveContent "Always acknowledge strengths before listing issues. Be specific about what's well done with file references." ;
    oc:hasRationale "Balanced feedback maintains developer morale and reinforces good patterns worth keeping" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fd3dbd24 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When categorizing review findings" ;
    oc:directiveContent "Categorize every issue by actual severity: Critical (bugs, security, data loss), Important (architecture, missing features, test gaps), or Minor (style, optimization, docs). Never mark nitpicks as Critical." ;
    oc:hasRationale "Severity inflation erodes trust and wastes developer time; accurate categorization enables correct prioritization" ;
    oc:severityLevel "HIGH" .

