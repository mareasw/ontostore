oc:skill_obra_superpowers_test_driven_development_testing_anti_patterns a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "testing-anti-patterns" ;
    skos:broader "Reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/test-driven-development" ;
    oc:contentHash "bde453bc258f06543987477c837939afaa774ea2acbd9f308d702fc452bc4283" ;
    oc:differentia "catalogs common testing anti-patterns and their corrections, emphasizing that tests must verify real behavior not mock behavior" ;
    oc:extends oc:skill_obra_superpowers_test_driven_development,
        oc:skill_test_driven_development ;
    oc:handlesFailure oc:IncompleteMockDetected,
        oc:MockBehaviorTested,
        oc:TestOnlyMethodAdded ;
    oc:hasArgumentHint "context of the test being written or reviewed" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_03eec3e7,
        oc:kn_07ba2ba3,
        oc:kn_59ffac2e,
        oc:kn_7f6b120c,
        oc:kn_c56ca3d4,
        oc:kn_f00a8414,
        oc:kn_ff0a9bd1 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:TestBeingWritten ;
    oc:resolvesIntent "avoid testing anti-patterns",
        "fix existing test anti-patterns",
        "identify bad test practices",
        "write correct mocks" ;
    oc:yieldsState oc:AntiPatternAvoided .

oc:kn_03eec3e7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before adding any mock to a test" ;
    oc:directiveContent "Never mock a dependency without understanding its side effects and what the test actually depends on. Mock at the lowest level needed, preserving behavior the test relies on." ;
    oc:hasRationale "Over-mocking or mocking at the wrong level can suppress side effects the test depends on, causing tests to pass for the wrong reasons or fail mysteriously." ;
    oc:severityLevel "HIGH" .

oc:kn_07ba2ba3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mock complexity grows — long setup, many mocked methods, or mocking 'just to be safe'" ;
    oc:directiveContent "If mock setup exceeds 50% of the test, or you can't explain why the mock is needed, consider replacing mocks with integration tests using real components." ;
    oc:hasRationale "Over-complex mocks indicate the test is fighting the design; integration tests with real components are often simpler and more trustworthy." ;
    oc:severityLevel "MEDIUM" .

oc:kn_59ffac2e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "As a gate check before writing or modifying any test" ;
    oc:directiveContent "Before asserting on any mock: ask 'Am I testing real behavior or mock existence?' Before adding any production method: ask 'Is this only used by tests?' Before mocking: ask 'What side effects does the real method have, and does this test depend on them?'" ;
    oc:hasRationale "These three gate questions catch the most common and damaging testing anti-patterns before they enter the codebase." ;
    oc:severityLevel "HIGH" .

oc:kn_7f6b120c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — TDD is the preventive discipline that eliminates testing anti-patterns at the root" ;
    oc:directiveContent "Following strict TDD prevents all these anti-patterns: write the test first, watch it fail against real code, then add minimal mocks only as needed." ;
    oc:hasRationale "TDD forces you to think about what you're testing before you mock, confirms tests verify real behavior by watching them fail, and prevents test-only methods from creeping into production code." ;
    oc:severityLevel "HIGH" .

oc:kn_c56ca3d4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating mock response objects or test data" ;
    oc:directiveContent "Mock data structures must mirror the complete real API response schema, including all fields that downstream code may consume — not just the fields the immediate test uses." ;
    oc:hasRationale "Partial mocks hide structural assumptions, cause silent failures when code accesses omitted fields, and create false confidence where tests pass but integration fails." ;
    oc:severityLevel "HIGH" .

oc:kn_f00a8414 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any test assertion involving mocked components" ;
    oc:directiveContent "Never assert on mock elements or test mock existence. Tests must verify real component behavior, not that a mock is present." ;
    oc:hasRationale "Testing mock behavior gives false confidence — the test passes when the mock is present but tells you nothing about real runtime behavior." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ff0a9bd1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When considering adding any method to a production class for test cleanup or setup" ;
    oc:directiveContent "Never add methods to production classes that are only used by tests. Put test-only logic in test utility files instead." ;
    oc:hasRationale "Test-only methods pollute production code, create confusion about object lifecycle, violate YAGNI, and can be dangerous if accidentally called in production." ;
    oc:severityLevel "CRITICAL" .

