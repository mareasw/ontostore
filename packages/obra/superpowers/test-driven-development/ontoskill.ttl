            oc:sectionTitle "Test-Driven Development (TDD)" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "The core TDD loop: write a failing test, verify it fails, write minimal code, verify it passes, refactor, repeat." ;
