                            oc:contentOrder 10 ;
                            oc:textContent """**REFACTOR**
Extract validation for multiple fields if needed.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "**GREEN**" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """$ npm test
PASS
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 9 ;
                            oc:sourceLocation "lines 319-322" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """function submitForm(data: FormData) {
  if (!data.email?.trim()) {
    return { error: 'Email required' };
  }
  // ...
}
""" ;
                            oc:codeLanguage "typescript" ;
                            oc:contentOrder 7 ;
                            oc:sourceLocation "lines 309-316" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**Verify RED**" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """test('rejects empty email', async () => {
  const result = await submitForm({ email: '' });
  expect(result.error).toBe('Email required');
});
""" ;
                            oc:codeLanguage "typescript" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 295-300" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 8 ;
                            oc:textContent "**Verify GREEN**" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """$ npm test
FAIL: expected 'Email required', got undefined
""" ;
                            oc:codeLanguage "bash" ;
