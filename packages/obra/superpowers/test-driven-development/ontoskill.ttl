                            oc:contentOrder 3 ;
                            oc:textContent "Can't check all boxes? You skipped TDD. Start over." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 17 ;
                    oc:sectionTitle "Verification Checklist" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
