                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Exceptions (ask your human partner):**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Always:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "Thinking \"skip TDD just this once\"? Stop. That's rationalization." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "When to Use" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 4 ;
                            oc:tableCaption "## When Stuck" ;
                            oc:tableMarkdown """| Problem | Solution |
|---------|----------|
| Don't know how to test | Write wished-for API. Write assertion first. Ask your human partner. |
| Test too complicated | Design too complicated. Simplify interface. |
| Must mock everything | Code too coupled. Use dependency injection. |
| Test setup huge | Extract helpers. Still complex? Simplify design. |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 18 ;
                    oc:sectionTitle "When Stuck" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**RED**" ],
                        [ a oc:Paragraph ;
