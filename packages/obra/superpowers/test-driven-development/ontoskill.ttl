@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_test_driven_development a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "test-driven-development" ;
    skos:broader "development methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/test-driven-development" ;
    oc:contentHash "62d4b1b3b8e65d345da6daa1dedb5a3d5689fc95f6e4f12d6051d1547e66baea" ;
    oc:differentia "enforces strict red-green-refactor cycle requiring tests to fail before any production code is written" ;
    oc:extends oc:skill_brainstorming ;
    oc:handlesFailure oc:OtherTestsBroken,
        oc:RationalizationDetected,
        oc:TestErrorsNotFails,
        oc:TestPassesUnexpectedly ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "feature-or-bugfix-description" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Use when implementing any feature or bugfix, before writing implementation code" ;
    oc:hasName "test-driven-development" ;
    oc:impartsKnowledge oc:kn_16fd0738,
        oc:kn_1f3557ef,
        oc:kn_2369733f,
        oc:kn_286ce68e,
        oc:kn_4f89feed,
        oc:kn_6a83a56f,
        oc:kn_82df3d7a,
        oc:kn_91a36e45,
        oc:kn_b7adb6d6,
        oc:kn_d1ce53a5 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DevelopmentEnvironmentReady,
        oc:FeatureSpecified ;
    oc:resolvesIntent "fix bugs using test-first approach",
        "implement features using TDD",
        "refactor code safely with test coverage",
        "verify behavior through test-driven cycles",
        "write failing tests before production code" ;
    oc:yieldsState oc:CodeRefactored,
        oc:FeatureImplemented,
        oc:TestPassing .

oc:kn_16fd0738 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "At the end of every implementation session" ;
    oc:directiveContent "Before marking work complete, verify: every new function has a test, each test was watched to fail first, each test failed for the expected reason, minimal code was written to pass, all tests pass with pristine output, mocks are used only when unavoidable, and edge cases are covered." ;
    oc:hasRationale "This checklist is the quality gate that ensures TDD discipline was actually followed, not just claimed." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1f3557ef a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when writing any production code" ;
    oc:directiveContent "No production code shall be written without a failing test first. Code written before its test must be deleted entirely — not kept as reference, not adapted." ;
    oc:hasRationale "Writing code before tests means you can never verify the test actually catches the absence of the feature — it passes immediately, proving nothing." ;
    oc:severityLevel "CRITICAL" .

oc:kn_2369733f a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When encountering any bug or unexpected behavior" ;
    oc:directiveContent "When a bug is found, write a failing test that reproduces it first, then follow the standard TDD cycle to fix it. Never fix a bug without a reproducing test." ;
    oc:hasRationale "A test that reproduces the bug proves the fix works and prevents regression. Fixing without a test leaves no safety net for future changes." ;
    oc:severityLevel "HIGH" .

oc:kn_286ce68e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During the GREEN phase of every TDD cycle" ;
    oc:directiveContent "Write minimal code to pass the test. Do not add features, refactor other code, or over-engineer beyond what the test requires. Each GREEN step should be the simplest possible passing implementation." ;
    oc:hasRationale "Over-engineering during GREEN violates YAGNI and defeats the incremental discipline of TDD. Each cycle adds exactly one behavior." ;
    oc:severityLevel "HIGH" .

oc:kn_4f89feed a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "Whenever considering writing tests after code" ;
    oc:directiveContent "Tests written after implementation pass immediately and prove nothing — they test what was built, not what should be built. They are biased by the implementation and miss edge cases the implementer forgot." ;
    oc:hasRationale "Tests-after answer 'what does this do?' while tests-first answer 'what should this do?'. Tests-first force edge case discovery before implementing." ;
    oc:severityLevel "HIGH" .

oc:kn_6a83a56f a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After writing implementation code to pass a test" ;
    oc:directiveContent "After each GREEN step, run the full test suite — not just the new test. Confirm: the new test passes, all existing tests still pass, and output is pristine with no errors or warnings." ;
    oc:hasRationale "Running only the new test misses regressions. Pristine output catches subtle issues like warnings that indicate problems." ;
    oc:severityLevel "HIGH" .

oc:kn_82df3d7a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Whenever tempted to write code before tests or skip the TDD cycle" ;
    oc:directiveContent "Treat all rationalizations for skipping TDD as red flags requiring an immediate stop and restart. Common rationalizations include: 'too simple to test', 'I'll test after', 'already manually tested', 'deleting is wasteful', 'TDD is dogmatic', 'keep as reference', and 'this is different because...'" ;
    oc:hasRationale "Every rationalization for skipping TDD has been documented as leading to lower confidence, missed edge cases, and technical debt. The discipline is the value." ;
    oc:severityLevel "HIGH" .

oc:kn_91a36e45 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When struggling to write a test during the RED phase" ;
    oc:directiveContent "If a test is hard to write, the design is too complicated. Listen to the test — difficult testing signals poor interface design, excessive coupling, or unclear responsibilities. Simplify the design, not the test." ;
    oc:hasRationale "TDD is a design tool. Test difficulty is diagnostic feedback about your architecture, not a testing problem to work around." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b7adb6d6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any test that involves mocking" ;
    oc:directiveContent "Never assert on mock behavior or test-only artifacts. Tests must verify real behavior of the system. Use mocks only to isolate external dependencies, never as the thing being tested." ;
    oc:hasRationale "Testing mock behavior tells you the mock works, not that your code works. This creates false confidence and hides real bugs. Consult testing-anti-patterns.md for detailed guidance." ;
    oc:severityLevel "HIGH" .

oc:kn_d1ce53a5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "After writing each failing test, before writing implementation code" ;
    oc:directiveContent "Never skip the verify-RED step. You must watch each test fail and confirm it fails for the expected reason (feature missing, not a typo or error) before writing implementation." ;
    oc:hasRationale "Without watching the test fail correctly, you don't know if the test tests the right thing. A test that passes immediately or errors is not a valid RED." ;
    oc:severityLevel "CRITICAL" .

