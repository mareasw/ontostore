                            oc:sourceLocation "lines 303-306" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Bug:** Empty email accepted" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 16 ;
                    oc:sectionTitle "Example: Bug Fix" ],
