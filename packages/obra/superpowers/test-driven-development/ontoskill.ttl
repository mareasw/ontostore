oc:kn_0884a293 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "During Verify RED phase" ;
    oc:directiveContent "If test passes immediately in RED, you're testing existing behavior—fix the test. If test errors (not fails), fix the error and re-run until it fails correctly for the right reason." ;
    oc:hasRationale "A test that doesn't fail for the expected reason provides no proof that the test is valid" ;
    oc:severityLevel "HIGH" .

oc:kn_15abeb65 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When discovering code was written before tests" ;
    oc:directiveContent "If you wrote code before tests, delete all of it. Don't keep as reference, don't adapt it. Start fresh with TDD from tests. Sunk cost is a fallacy." ;
    oc:hasRationale "Keeping pre-written code biases the tests toward the implementation rather than the requirement" ;
    oc:severityLevel "CRITICAL" .

oc:kn_23047a60 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Every TDD cycle iteration" ;
    oc:directiveContent "Both Verify RED and Verify GREEN steps are MANDATORY. Never skip watching the test fail before implementing, and never skip watching it pass after implementing." ;
    oc:hasRationale "Verify RED proves the test catches the missing feature; Verify GREEN proves the implementation satisfies the requirement" ;
    oc:severityLevel "CRITICAL" .

oc:kn_25b9a287 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding mocks or test utilities" ;
    oc:directiveContent "Never test mock behavior instead of real behavior. Never add test-only methods to production classes. Never mock without understanding dependencies. Mocks are isolation tools, not the thing being tested." ;
    oc:hasRationale "Testing mocks gives false confidence—the test passes but proves nothing about real behavior" ;
    oc:severityLevel "CRITICAL" .

oc:kn_2a424855 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing tests in the RED phase" ;
    oc:directiveContent "Write one minimal test showing one behavior. Clear name, real code (no mocks unless unavoidable). If 'and' appears in the test name, split it." ;
    oc:hasRationale "Tests that cover multiple behaviors are harder to debug and violate the single-responsibility focus of TDD" ;
    oc:severityLevel "HIGH" .

oc:kn_2d4c9286 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every feature or bugfix implementation" ;
    oc:directiveContent "1. Write one minimal failing test (RED) 2. Run test, verify it fails for the right reason (Verify RED) 3. Write minimal code to pass (GREEN) 4. Run test, verify it passes and all other tests pass (Verify GREEN) 5. Refactor while keeping tests green (REFACTOR) 6. Repeat for next behavior" ;
    oc:stepOrder 1 .

oc:kn_4261fa80 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when writing any production code" ;
    oc:directiveContent "NO PRODUCTION CODE WITHOUT A FAILING TEST FIRST. Write code before the test? Delete it entirely and start over. Don't keep as reference, don't adapt it, don't look at it." ;
    oc:hasRationale "Without seeing the test fail first, you cannot prove the test actually tests anything meaningful" ;
    oc:severityLevel "CRITICAL" .

oc:kn_96dea482 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When stuck writing tests" ;
    oc:directiveContent "If a test is too complicated, the design is too complicated—simplify the interface. If you must mock everything, the code is too coupled—use dependency injection. If test setup is huge, extract helpers or simplify the design." ;
    oc:hasRationale "Test difficulty is a signal about design quality; listen to the test" ;
    oc:severityLevel "MEDIUM" .

oc:kn_da2b63a6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "During the GREEN phase" ;
    oc:directiveContent "Write the simplest code to pass the test. Don't add features, don't refactor other code, don't improve beyond what the test requires. YAGNI." ;
    oc:hasRationale "Over-engineering during GREEN leads to untested code paths and violates the incremental nature of TDD" ;
    oc:severityLevel "HIGH" .

oc:req_28b7e85d a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "test runner (e.g., npm test, pytest, jest)" .

oc:req_fdb8ab49 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "testing-anti-patterns" .

_:ref_1d5347ee516b7b7c a oc:WorkflowStep ;
    dcterms:description "Write the simplest possible code to make the test pass" ;
    oc:expectedOutcome "Minimal implementation that satisfies the test" ;
    oc:stepDependsOn _:ref_e52a54e0159ea9dd ;
    oc:stepId "green" .

_:ref_4ef89f4cb6180e56 a oc:WorkflowStep ;
    dcterms:description "Run the test and confirm it passes, all other tests still pass, and output is pristine" ;
    oc:expectedOutcome "All tests pass with no errors or warnings" ;
    oc:stepDependsOn _:ref_1d5347ee516b7b7c ;
    oc:stepId "verify-green" .

_:ref_c16fe4b9a62ace27 a oc:WorkflowStep ;
    dcterms:description "Write one minimal test showing the desired behavior with a clear name" ;
    oc:expectedOutcome "A single test case that describes one behavior" ;
    oc:stepId "red" .

_:ref_e52a54e0159ea9dd a oc:WorkflowStep ;
    dcterms:description "Run the test and confirm it fails for the expected reason (feature missing, not typo or error)" ;
    oc:expectedOutcome "Test fails with expected failure message" ;
    oc:stepDependsOn _:ref_c16fe4b9a62ace27 ;
    oc:stepId "verify-red" .

_:ref_fe39f62b86b391b2 a oc:WorkflowStep ;
    dcterms:description "Clean up: remove duplication, improve names, extract helpers. Keep tests green, don't add behavior." ;
    oc:expectedOutcome "Cleaner code with all tests still passing" ;
    oc:stepDependsOn _:ref_4ef89f4cb6180e56 ;
    oc:stepId "refactor" .

