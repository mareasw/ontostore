                [ a oc:WorkflowStep ;
                    dcterms:description "Offer execution choice: subagent-driven-development or executing-plans. Route to chosen skill." ;
                    oc:expectedOutcome "Execution mode selected and appropriate skill invoked" ;
                    oc:stepDependsOn _:ref_b9452b4933b1eac7 ;
                    oc:stepId "execution-handoff" ],
                _:ref_828a694b2cbbc1b2,
                _:ref_b53eb8fa0a787955,
                _:ref_b9452b4933b1eac7,
                _:ref_cc49546552e1b78f ;
