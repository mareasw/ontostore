    oc:requiresState oc:SpecReady,
        oc:WorktreeCreated ;
    oc:resolvesIntent "break down requirements into executable steps",
        "create implementation plan",
        "decompose spec into tasks",
        "write TDD-structured plan" ;
    oc:yieldsState oc:PlanDocumentCreated .

oc:kn_05b3b59e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During self-review type consistency check" ;
    oc:directiveContent "Never reference types, functions, or methods not defined in any prior task. A function called clearLayers() in Task 3 but clearFullLayers() in Task 7 is a plan bug." ;
    oc:hasRationale "Type and naming inconsistencies between tasks cause implementation failures that are hard to diagnose because each task is implemented independently" ;
    oc:severityLevel "HIGH" .

oc:kn_0e2f7cab a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any step in a plan document" ;
    oc:directiveContent "Never include placeholders like 'TBD', 'TODO', 'implement later', 'add appropriate error handling', or 'Write tests for the above' without actual test code. Every step must contain the actual content an engineer needs." ;
    oc:hasRationale "Placeholders force the implementer to make design decisions they lack context for, defeating the purpose of a comprehensive plan" ;
    oc:severityLevel "CRITICAL" .

oc:kn_55ce1366 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When evaluating scope before writing a plan" ;
    oc:directiveContent "If a spec covers multiple independent subsystems, it should have been broken into sub-project specs during brainstorming. If it wasn't, suggest breaking into separate plans — one per subsystem." ;
    oc:hasRationale "Monolithic plans for independent subsystems create unnecessary coupling and prevent parallel execution" ;
    oc:severityLevel "HIGH" .

oc:kn_73de6516 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "After writing the complete plan, before saving" ;
    oc:directiveContent "Run a three-part self-review after writing the complete plan: (1) spec coverage — can you point to a task for each requirement, (2) placeholder scan — search for red-flag patterns, (3) type consistency — do signatures and names match across tasks." ;
    oc:hasRationale "Self-review catches gaps between spec and plan that are invisible during writing because of focused attention on individual tasks" ;
    oc:severityLevel "MEDIUM" .

oc:kn_80ad7f7b a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When writing any task step that resembles a previous task" ;
    oc:directiveContent "Never say 'Similar to Task N' — always repeat the code. The engineer (or subagent) may be reading tasks out of order." ;
    oc:hasRationale "Out-of-order task execution is common in agentic workflows; implicit references create ambiguity and incorrect implementations" ;
    oc:severityLevel "HIGH" .

oc:kn_978c1611 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After plan document is saved" ;
    oc:directiveContent "After saving the plan, offer two execution choices: subagent-driven (fresh subagent per task with review) or inline execution (batch with checkpoints). Route to the appropriate execution skill." ;
    oc:hasRationale "Explicit handoff ensures the plan is actually executed rather than abandoned, and matching execution mode to situation improves reliability" .

oc:kn_c45ee209 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When decomposing tasks into steps" ;
    oc:directiveContent "Each step must be one atomic action taking 2-5 minutes: write test, run test, implement minimal code, run test, commit. Never combine multiple actions into one step." ;
    oc:hasRationale "Fine granularity enables precise progress tracking, easier debugging, and frequent commits that create reliable rollback points" ;
    oc:severityLevel "HIGH" .

oc:kn_ded60fd3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mapping out file structure before task decomposition" ;
    oc:directiveContent "Files that change together should live together. Split by responsibility, not by technical layer. Each file should have one clear responsibility with well-defined interfaces." ;
    oc:hasRationale "Smaller focused files are more reliable to edit and easier to hold in context simultaneously" ;
    oc:severityLevel "MEDIUM" .

_:ref_3dffa021be08cd68 a oc:WorkflowStep ;
    dcterms:description "Write the mandatory plan document header with goal, architecture, and tech stack" ;
    oc:expectedOutcome "Plan document created with proper header" ;
    oc:stepDependsOn _:ref_3e0a2a6dabb0e015 ;
    oc:stepId "write-plan-header" .

_:ref_3e0a2a6dabb0e015 a oc:WorkflowStep ;
    dcterms:description "Map out which files will be created or modified, define clear responsibilities for each file, lock in decomposition decisions" ;
    oc:expectedOutcome "Complete file structure with exact paths and responsibilities" ;
    oc:stepDependsOn _:ref_828a694b2cbbc1b2 ;
    oc:stepId "map-file-structure" .

_:ref_828a694b2cbbc1b2 a oc:WorkflowStep ;
    dcterms:description "Evaluate spec scope — if it covers multiple independent subsystems, suggest splitting into separate plans" ;
    oc:expectedOutcome "Confirmed single-subsystem scope or decision to split" ;
    oc:stepId "scope-check" .

_:ref_b53eb8fa0a787955 a oc:WorkflowStep ;
    dcterms:description "Break work into bite-sized tasks (2-5 min steps) following TDD cycle: failing test → run → implement → run → commit. Include complete code in every step." ;
    oc:expectedOutcome "All tasks written with exact file paths, complete code blocks, and exact commands" ;
    oc:stepDependsOn _:ref_3dffa021be08cd68 ;
    oc:stepId "decompose-tasks" .

_:ref_b9452b4933b1eac7 a oc:WorkflowStep ;
    dcterms:description "Save plan to docs/superpowers/plans/YYYY-MM-DD-<feature-name>.md (or user-preferred location)" ;
    oc:expectedOutcome "Plan file saved to disk" ;
    oc:stepDependsOn _:ref_cc49546552e1b78f ;
    oc:stepId "save-plan" .

_:ref_cc49546552e1b78f a oc:WorkflowStep ;
    dcterms:description "Run three-part self-review: (1) spec coverage check, (2) placeholder scan, (3) type consistency check. Fix any issues inline." ;
    oc:expectedOutcome "Plan verified against spec with no placeholders or type inconsistencies" ;
    oc:stepDependsOn _:ref_b53eb8fa0a787955 ;
    oc:stepId "self-review" .

