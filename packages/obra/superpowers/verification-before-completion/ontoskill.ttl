oc:skill_obra_superpowers_verification_before_completion a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "verification-before-completion" ;
    skos:broader "Discipline" ;
    prov:wasDerivedFrom "../.agents/skills/obra/superpowers/verification-before-completion" ;
    oc:contentHash "b8677a7625a63908fa74cc66ab4487f796359093702c47899d6acde4fe1adf46" ;
    oc:differentia "that enforces evidence-based verification before any completion claim, preventing false success assertions" ;
    oc:handlesFailure oc:FalseCompletionClaim,
        oc:VerificationFailed ;
    oc:hasCategory "development" ;
    oc:hasDescription "Use when about to claim work is complete, fixed, or passing, before committing or creating PRs - requires running verification commands and confirming output before making any success claims; evidence before assertions always" ;
    oc:hasName "verification-before-completion" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 8 ;
                            oc:tableCaption "## Rationalization Prevention" ;
                            oc:tableMarkdown """| Excuse | Reality |
|--------|---------|
| "Should work now" | RUN the verification |
| "I'm confident" | Confidence ≠ evidence |
| "Just this once" | No exceptions |
| "Linter passed" | Linter ≠ compiler |
| "Agent said success" | Verify independently |
| "I'm tired" | Exhaustion ≠ excuse |
| "Partial check is enough" | Partial proves nothing |
| "Different words so rule doesn't apply" | Spirit over letter |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Rationalization Prevention" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
