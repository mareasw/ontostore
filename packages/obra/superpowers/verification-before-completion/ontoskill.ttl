        oc:kn_ce001541 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "ensure evidence before assertions",
        "prevent false success claims",
        "validate fixes before committing or creating PRs",
        "verify work is complete before claiming completion" ;
    oc:yieldsState oc:EvidenceDocumented,
        oc:VerificationComplete .

oc:kn_1579abd4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When about to claim any status or express satisfaction" ;
    oc:directiveContent "Never use 'should', 'probably', 'seems to', or express satisfaction ('Great!', 'Perfect!', 'Done!') before running verification commands." ;
    oc:hasRationale "These words indicate unverified confidence, which historically leads to false completion claims and shipped defects." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1b3e1160 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When verification output contradicts the expected claim" ;
    oc:directiveContent "If verification fails, state actual status with evidence rather than the hoped-for status. Report gaps honestly." ;
    oc:hasRationale "Honest reporting of actual state preserves trust and enables correct next steps." ;
    oc:severityLevel "HIGH" .

oc:kn_33d519a5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining what verification to run for a specific claim type" ;
    oc:directiveContent "Each claim type requires specific evidence: tests need 0-failure output, builds need exit 0, bug fixes need original symptom re-tested, regression tests need red-green cycle verified, requirements need line-by-line checklist." ;
    oc:hasRationale "Substituting one type of verification for another (e.g., linter for compiler) produces false confidence." .

oc:kn_34225fd0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before making ANY success or completion claim" ;
    oc:directiveContent "No completion claims without fresh verification evidence. If you haven't run the verification command in this message, you cannot claim it passes." ;
    oc:hasRationale "Claiming work is complete without verification is dishonesty, not efficiency. From 24 failure memories including shipped crashes and broken trust." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6a07f3a0 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — each completion claim requires its own fresh verification" ;
    oc:directiveContent "Verification must be run fresh each time. Previous runs do not count as evidence for current claims." ;
    oc:hasRationale "Code state may have changed since last run; stale verification evidence is no evidence." .

oc:kn_6b5f0e37 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Before claiming tests pass, build succeeds, bug is fixed, or requirements are met" ;
    oc:directiveContent "1. IDENTIFY what command proves the claim → 2. RUN the full command fresh → 3. READ full output, check exit code, count failures → 4. VERIFY output confirms claim (if NO: state actual status; if YES: state claim WITH evidence) → 5. ONLY THEN make the claim" ;
    oc:hasRationale "Skipping any step in the gate function is lying, not verifying." ;
    oc:severityLevel "CRITICAL" ;
    oc:stepOrder 1 .

oc:kn_b08d97d0 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When tempted to skip or shortcut verification" ;
    oc:directiveContent "Rationalization patterns to reject: 'should work now', 'just this once', 'I'm confident', 'I'm tired', 'partial check is enough', 'different wording so rule doesn't apply'. Spirit over letter." ;
    oc:hasRationale "These rationalizations have led to 24 documented failures including broken trust and shipped crashes." .

oc:kn_ce001541 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When receiving results from delegated agents" ;
    oc:directiveContent "Never trust agent success reports without independent verification. Check VCS diff and verify actual changes." ;
    oc:hasRationale "Agents can report success while producing incomplete or incorrect results. Independent verification is mandatory." ;
    oc:severityLevel "HIGH" .

_:ref_3e617f8bf9cb9aa4 a oc:WorkflowStep ;
    dcterms:description "Identify what command or evidence proves the claim you want to make" ;
    oc:expectedOutcome "A specific verification command or checklist is identified" ;
    oc:stepId "identify-proof" .

_:ref_93bab3c7f98cd351 a oc:WorkflowStep ;
    dcterms:description "Compare output to claim: does evidence confirm or contradict?" ;
    oc:expectedOutcome "Clear yes/no on whether evidence supports the claim" ;
    oc:stepDependsOn _:ref_dfaa15226de9f614 ;
    oc:stepId "verify-claim" .

_:ref_b1343c54756a2478 a oc:WorkflowStep ;
    dcterms:description "Execute the FULL verification command fresh (not a previous run)" ;
    oc:expectedOutcome "Verification command completes with output and exit code" ;
    oc:stepDependsOn _:ref_3e617f8bf9cb9aa4 ;
    oc:stepId "run-verification" .

_:ref_dfaa15226de9f614 a oc:WorkflowStep ;
    dcterms:description "Read full output, check exit code, count failures" ;
    oc:expectedOutcome "Complete understanding of actual verification results" ;
    oc:stepDependsOn _:ref_b1343c54756a2478 ;
    oc:stepId "read-output" .

