@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_dispatching_parallel_agents a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "dispatching-parallel-agents" ;
    skos:broader "Workflow strategy" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/dispatching-parallel-agents" ;
    oc:contentHash "ced271af52abc7b55009fb95932856e6511cb4cbec29f994cad50dc398af3d6c" ;
    oc:differentia "that delegates independent tasks to specialized agents running concurrently with isolated context for parallel problem-solving" ;
    oc:handlesFailure oc:AgentConflictDetected,
        oc:AgentTaskFailed ;
    oc:hasArgumentHint "list of independent tasks or problem descriptions" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Use when facing 2+ independent tasks that can be worked on without shared state or sequential dependencies" ;
    oc:hasName "dispatching-parallel-agents" ;
    oc:impartsKnowledge oc:kn_40b1ca1c,
        oc:kn_79dda3e0,
        oc:kn_927bd397,
        oc:kn_ae1a2a57,
        oc:kn_c7a5c7a3,
        oc:kn_e827833e ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "coordinate parallel agent execution and integration",
        "debug multiple unrelated failures simultaneously",
        "dispatch parallel agents for independent tasks",
        "solve multiple independent problems concurrently" ;
    oc:yieldsState oc:ParallelTasksCompleted .

oc:kn_40b1ca1c a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning parallel agent dispatch" ;
    oc:directiveContent "Group failures by independent domain first, then create one agent task per domain with specific scope, clear goal, explicit constraints, and expected output format." ;
    oc:hasRationale "Structured task decomposition ensures each agent has a well-bounded problem and the coordinator can efficiently integrate results." ;
    oc:severityLevel "MEDIUM" .

oc:kn_79dda3e0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating whether to use parallel dispatch" ;
    oc:directiveContent "Do not dispatch parallel agents when failures are related, share state, edit the same files, or when fixing one might fix others. Investigate together first." ;
    oc:hasRationale "Related failures may share root causes; parallel agents editing the same files will create merge conflicts or mask cascading issues." ;
    oc:severityLevel "HIGH" .

oc:kn_927bd397 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "When integrating results from parallel agent execution" ;
    oc:directiveContent "After agents return: review each summary, check for conflicting edits between agents, run the full test suite, and spot-check results for systematic errors." ;
    oc:hasRationale "Agents can make systematic errors or produce changes that conflict with each other. Integration verification ensures parallel fixes work together correctly." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ae1a2a57 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When facing 2+ independent failures or tasks that share no state" ;
    oc:directiveContent "Dispatch one agent per independent problem domain. Each agent should have a focused scope covering exactly one test file, subsystem, or problem area." ;
    oc:hasRationale "Focused agents are less likely to get lost, consume less context, and produce more reliable results than agents with broad scope." ;
    oc:severityLevel "HIGH" .

oc:kn_c7a5c7a3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing agent dispatch prompts" ;
    oc:directiveContent "Each agent prompt must be: focused (one clear problem), self-contained (all context needed included), and specific about expected output format." ;
    oc:hasRationale "Vague prompts lead to agents getting lost, making unwanted changes, or returning unactionable results. Precision in prompts directly correlates with agent success." ;
    oc:severityLevel "HIGH" .

oc:kn_e827833e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting instructions for any dispatched agent" ;
    oc:directiveContent "Agents must never inherit the session's context or history — construct exactly the context they need from scratch in their prompt." ;
    oc:hasRationale "Inheriting session context pollutes the agent's focus, wastes its context window, and may introduce irrelevant biases from prior conversation." ;
    oc:severityLevel "CRITICAL" .

