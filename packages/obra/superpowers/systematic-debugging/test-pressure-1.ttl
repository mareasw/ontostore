@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_systematic_debugging_test_pressure_1 a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "test-pressure-1" ;
    skos:broader "Pressure test" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/systematic-debugging" ;
    oc:contentHash "0b6a915db0054577819834c79be9eb614e97bddba10d73768e1fbe91cfed048a" ;
    oc:dependsOnSkill oc:skill_systematic_debugging ;
    oc:differentia "presents a production emergency scenario with extreme financial pressure to evaluate adherence to systematic debugging over quick symptom fixes" ;
    oc:extends oc:skill_obra_superpowers_systematic_debugging ;
    oc:handlesFailure oc:AgentChoseQuickFix,
        oc:AgentRationalizedShortcut ;
    oc:hasCategory "research" ;
    oc:impartsKnowledge oc:kn_03955019,
        oc:kn_0cd00b3e,
        oc:kn_58ec44d2,
        oc:kn_9d917803,
        oc:kn_d426a815 ;
    oc:isUserInvocable false ;
    oc:nature "Test" ;
    oc:requiresState oc:SkillLoaded ;
    oc:resolvesIntent "assess whether agent prioritizes root cause investigation over symptom patching in crises",
        "evaluate debugging discipline under production emergency time pressure",
        "test resistance to quick-fix rationalization when revenue is at stake" ;
    oc:yieldsState oc:PressureTestCompleted .

oc:kn_03955019 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When analyzing this pressure test to determine correct behavior" ;
    oc:directiveContent "The scenario deliberately echoes the parent skill's 'Quick fix for now, investigate later' rationalization — recognizing this pattern is the core test of whether the skill has been internalized." ;
    oc:hasRationale "The parent skill lists this exact rationalization in its table: Excuse = 'Emergency, no time for process' → Reality = 'Systematic debugging is FASTER than guess-and-check thrashing.' The test checks if the agent applies this knowledge." ;
    oc:severityLevel "HIGH" .

oc:kn_0cd00b3e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When tempted to skip all investigation under time pressure" ;
    oc:directiveContent "Option B (quick fix now, investigate later) is the trap — applying a retry without any investigation assumes the root cause is transient, which may be wrong and the retry may mask or worsen the real issue." ;
    oc:hasRationale "The systematic debugging skill explicitly warns against 'Quick fix for now, investigate later' as a red flag. The scenario deliberately mirrors this exact rationalization pattern." ;
    oc:severityLevel "CRITICAL" .

oc:kn_58ec44d2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or interpreting pressure test scenarios for skill validation" ;
    oc:directiveContent "Pressure tests use real-world stakes (revenue loss, manager pressure, social consequences) to test whether learned behaviors hold under emotional stress, not just intellectual understanding." ;
    oc:hasRationale "Academic tests confirm comprehension; pressure tests confirm behavioral adherence. The scenario is constructed to trigger the exact rationalizations listed in the parent skill's 'Common Rationalizations' table." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9d917803 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating tradeoffs between process rigor and operational urgency" ;
    oc:directiveContent "Production emergency scenarios create a false binary between 'full process (35 min)' vs 'skip process (5 min)' — a minimal 5-minute investigation phase is a valid application of systematic debugging, not a violation." ;
    oc:hasRationale "The skill itself notes that systematic investigation is faster than thrashing — even 5 minutes of checking recent changes is investigation, not skipping." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d426a815 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing how to respond to this pressure test scenario" ;
    oc:directiveContent "Option C (compromise: minimal investigation before fix) is the correct answer — quick check of recent changes, then apply stopgap, then full root cause investigation after service is restored." ;
    oc:hasRationale "Systematic debugging's own SKILL.md states: 'Systematic debugging is FASTER than guess-and-check thrashing' — meaning the process is designed to be efficient, not dogmatic. A pragmatic compromise preserves both revenue and discipline." ;
    oc:severityLevel "HIGH" .

