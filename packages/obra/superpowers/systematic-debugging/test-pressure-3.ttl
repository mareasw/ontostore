@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_systematic_debugging_test_pressure_3 a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "test-pressure-3" ;
    skos:broader "pressure test" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/systematic-debugging" ;
    oc:contentHash "96b50a52e2c7989c9cf20fb752c47c1e9a3a70dc362f8f7989f8f5b64dac7708" ;
    oc:dependsOnSkill oc:skill_systematic_debugging ;
    oc:differentia "that challenges adherence to systematic debugging under authority bias and social conformity pressure in a group setting" ;
    oc:extends oc:skill_obra_superpowers_systematic_debugging ;
    oc:handlesFailure oc:AbandonedRootCauseInvestigation,
        oc:ConcededToAuthorityPressure ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_21ab5b12,
        oc:kn_3b53aad7,
        oc:kn_689244d0,
        oc:kn_adbb3342,
        oc:kn_ef7c4bf1 ;
    oc:isUserInvocable false ;
    oc:nature "test" ;
    oc:requiresState oc:SystematicDebuggingSkillLoaded ;
    oc:resolvesIntent "assess commitment to root cause investigation when team consensus favors a shortcut",
        "evaluate whether agent maintains systematic process under social pressure from senior engineers",
        "test resistance to authority bias during debugging" ;
    oc:yieldsState oc:AuthorityBiasResistanceTested .

oc:kn_21ab5b12 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always - this is a structural principle of the systematic debugging methodology" ;
    oc:directiveContent "Root cause discipline must be independent of organizational hierarchy. A fix proposed without investigation is a symptom patch regardless of who proposes it." ;
    oc:hasRationale "The parent skill states: 'Violating the letter of this process is violating the spirit of debugging.' and 'NO FIXES WITHOUT ROOT CAUSE INVESTIGATION FIRST'. These rules make no exception for seniority or consensus." ;
    oc:severityLevel "HIGH" .

oc:kn_3b53aad7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When any fix is proposed for a middleware-related bug without first reading the middleware code" ;
    oc:directiveContent "The systematic debugging skill's Phase 2 mandates reading middleware implementation completely and understanding its dependencies before proposing fixes, regardless of social pressure." ;
    oc:hasRationale "The parent skill explicitly states: 'Don't claim to implement pattern without reading it completely' and 'Understand dependencies (what assumptions does middleware make?)'. These rules are non-negotiable per the Iron Law." ;
    oc:severityLevel "CRITICAL" .

oc:kn_689244d0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a senior colleague proposes a fix based on pattern recognition without tracing the actual data flow" ;
    oc:directiveContent "Never defer to senior engineer authority as a substitute for root cause investigation. Experience does not replace understanding the actual failure mechanism." ;
    oc:hasRationale "Experienced engineers can be wrong, and their pattern-matching may not apply to the specific system. The systematic debugging skill explicitly requires reading middleware implementation completely before proposing fixes." ;
    oc:severityLevel "CRITICAL" .

oc:kn_adbb3342 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When facing social pressure in a group setting and full systematic process seems politically impossible" ;
    oc:directiveContent "When team consensus pushes for a shortcut, propose the minimum viable investigation (5-minute doc check) rather than all-or-nothing confrontation." ;
    oc:hasRationale "A compromise that preserves some investigation is better than zero investigation. Reading the middleware docs may reveal the real issue quickly, and if not, the team has invested only 5 minutes." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ef7c4bf1 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When debugging in a group setting with hierarchy and time pressure" ;
    oc:directiveContent "Social conformity pressure ('everyone wants the call to end') and authority bias ('trust me, I've debugged auth for years') are the two most powerful rationalization triggers that override systematic debugging discipline." ;
    oc:hasRationale "The combination of authority figure endorsement + team fatigue + desire to be a 'team player' creates a rationalization pathway that the debugging skill explicitly warns against. The skill's Common Rationalizations table lists 'I see the problem, let me fix it' (seeing symptoms ≠ understanding root cause) and 'Issue is simple, don't need process' (simple issues have root causes too)." ;
    oc:severityLevel "HIGH" .

