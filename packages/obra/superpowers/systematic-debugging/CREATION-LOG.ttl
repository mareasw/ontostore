@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_systematic_debugging_creation_log a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "creation-log" ;
    skos:broader "creation log" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/systematic-debugging" ;
    oc:contentHash "b482ef9a918fbfc6c369729e8160633ddfa2332466dd362ee73f1527c239ef8b" ;
    oc:differentia "documents the extraction, structuring, and bulletproofing process used to create the systematic-debugging skill" ;
    oc:extends oc:skill_obra_superpowers_systematic_debugging ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_07d6ac9c,
        oc:kn_44be8849,
        oc:kn_d7211ea2,
        oc:kn_e4b67d39,
        oc:kn_e624492d ;
    oc:isUserInvocable false ;
    oc:nature "meta" ;
    oc:resolvesIntent "learn how to extract and bulletproof a critical agent skill",
        "reference the testing approach used to validate debugging skill resilience",
        "understand the design rationale behind the systematic-debugging skill" .

oc:kn_07d6ac9c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating any skill that must resist deviation under real-world conditions" ;
    oc:directiveContent "Test skills under multiple pressure scenarios (no pressure, time pressure + obvious fix, complex uncertainty, failed first attempt) to verify behavioral compliance." ;
    oc:hasRationale "Skills that work perfectly in calm conditions may fail under pressure; only adversarial testing reveals rationalization vulnerabilities." .

oc:kn_44be8849 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing multi-phase procedural skills" ;
    oc:directiveContent "Build structural defenses into skills: phase requirements that prevent skipping, single-hypothesis rules that force thinking, and explicit failure-mode handling." ;
    oc:hasRationale "Structural constraints are more reliable than reminding language alone — they make the wrong path physically harder to follow." .

oc:kn_d7211ea2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or bulletproofing any skill that must resist agent shortcut behavior" ;
    oc:directiveContent "Use absolute language ('ALWAYS'/'NEVER') rather than soft language ('should'/'try to') in critical skills to resist rationalization under pressure." ;
    oc:hasRationale "Absolute language creates cognitive friction against rationalization, especially when agents face time pressure or obvious-looking shortcuts." ;
    oc:severityLevel "HIGH" .

oc:kn_e4b67d39 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When prioritizing which bulletproofing elements to include in a constrained skill" ;
    oc:directiveContent "Key insight from testing: the single most effective bulletproofing element is the anti-patterns section that shows exact patterns of shortcuts that feel justified in the moment." ;
    oc:hasRationale "Pattern-matching against a known-bad example is the strongest defense against rationalization because it triggers at the exact moment of temptation." .

oc:kn_e624492d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing skills with critical behavioral constraints" ;
    oc:directiveContent "Include an explicit anti-patterns section showing exact shortcuts that feel justified in the moment, so the agent recognizes and resists them." ;
    oc:hasRationale "Seeing a specific shortcut pattern listed as wrong creates cognitive friction at the exact moment the agent is tempted to take that shortcut." .

