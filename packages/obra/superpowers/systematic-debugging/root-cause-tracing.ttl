                                    oc:itemOrder 3 ;
                                    oc:itemText "Identify the pattern (same test? same parameter?)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Find the line number triggering the call" ] ],
