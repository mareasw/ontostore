                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "**Analyze stack traces:**" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """// Before the problematic operation
async function gitInit(directory: string) {
  const stack = new Error().stack;
  console.error('DEBUG git init:', {
    directory,
    cwd: process.cwd(),
    nodeEnv: process.env.NODE_ENV,
    stack,
  });

  await execFileAsync('git', ['init'], { cwd: directory });
}
""" ;
                            oc:codeLanguage "typescript" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 70-83" ],
