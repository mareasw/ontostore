@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_systematic_debugging_root_cause_tracing a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "root-cause-tracing" ;
    skos:broader "debugging technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/systematic-debugging" ;
    oc:contentHash "a81bee9448794d261b4aca8487c595d11ff4bd4e10a5f96bca1117dd32527050" ;
    oc:differentia "traces bugs backward through the call chain from symptom to original trigger, then fixes at the source" ;
    oc:extends oc:skill_obra_superpowers_systematic_debugging ;
    oc:handlesFailure oc:DeadEndTrace ;
    oc:hasArgumentHint "error-symptom or stack-trace" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_075fc258,
        oc:kn_0a1185ac,
        oc:kn_8763c053,
        oc:kn_8d3e0e18,
        oc:kn_fb49377f ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ErrorObserved ;
    oc:resolvesIntent "add stack trace instrumentation for debugging",
        "find original trigger of an error",
        "identify which test causes pollution",
        "trace root cause of deep-stack bugs" ;
    oc:yieldsState oc:RootCauseIdentified .

oc:kn_075fc258 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding instrumentation to capture stack traces during test debugging" ;
    oc:directiveContent "Use console.error() for debug logging in tests, not the application logger which may be suppressed" ;
    oc:hasRationale "Application loggers may be silenced or redirected in test environments, causing debug output to be lost" ;
    oc:severityLevel "MEDIUM" .

oc:kn_0a1185ac a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering any bug deep in the call stack" ;
    oc:directiveContent "NEVER fix where the error appears. That is treating a symptom, not the root cause." ;
    oc:hasRationale "Fixing at the symptom point leaves the original trigger intact, allowing the same class of bug to recur through other code paths" ;
    oc:severityLevel "CRITICAL" .

oc:kn_8763c053 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "After successfully identifying and fixing a root cause" ;
    oc:directiveContent "After fixing at the source, add defense-in-depth validation at each layer in the call chain to make the bug class impossible" ;
    oc:hasRationale "Multi-layer validation ensures that even if one defense fails, downstream guards catch the problem before damage occurs" ;
    oc:severityLevel "HIGH" .

oc:kn_8d3e0e18 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When instrumenting code to diagnose where a problematic operation originates" ;
    oc:directiveContent "Log before the dangerous operation, not after it fails. Include directory, cwd, environment variables, and the full call stack via new Error().stack" ;
    oc:hasRationale "Pre-failure logging captures the exact state leading to the error; post-failure logging may never execute if the process crashes" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fb49377f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When debugging errors that manifest deep in execution, not at entry point" ;
    oc:directiveContent "Trace backward through the call chain step by step: observe symptom → find immediate cause → ask what called this → keep tracing up → find original trigger → fix at source" ;
    oc:hasRationale "Bugs often originate far from where they surface; systematic backward tracing ensures you address the true cause" ;
    oc:severityLevel "HIGH" .

