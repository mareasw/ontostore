        oc:kn_ef69a895 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:BugObserved ;
    oc:resolvesIntent "find original trigger of deep stack error",
        "fix bugs at source rather than symptom",
        "identify which test causes pollution",
        "trace bug to root cause" ;
    oc:yieldsState oc:DefenseInDepthAdded,
        oc:RootCauseIdentified .

oc:kn_26c1a406 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a bug manifests deep in the call stack" ;
    oc:directiveContent "NEVER fix where the error appears. Fixing at the symptom point leaves the root cause intact and the bug will recur." ;
    oc:hasRationale "Symptom-level fixes are bandaids; the original trigger remains and can cause the same or similar bugs through other paths" ;
    oc:severityLevel "CRITICAL" .

oc:kn_63871aee a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When tracing any bug back to its root cause" ;
    oc:directiveContent "1. Observe the symptom (error message/location) 2. Find the immediate cause (what code directly triggers it) 3. Ask: what called this? Trace the call chain upward 4. Keep tracing up — track parameter values at each level 5. Find the original trigger (where the invalid value originated)" ;
    oc:hasRationale "Systematic backward tracing ensures you reach the true source rather than stopping at an intermediate layer" ;
    oc:stepOrder 1 .

oc:kn_6502aac8 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When a side effect appears during test runs but the triggering test is unknown" ;
    oc:directiveContent "Use the bisection script (find-polluter.sh) to identify which test causes pollution by running tests one-by-one until the polluter is found." ;
    oc:hasRationale "Binary/bisection search is O(log n) vs running all tests sequentially every time" .

oc:kn_6a6268ca a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding instrumentation to trace bugs in test suites" ;
    oc:directiveContent "Use console.error() for debug logging in tests, not logger — logger output may be suppressed in test environments." ;
    oc:hasRationale "Test frameworks often suppress or redirect logger output, making debug traces invisible" ;
    oc:severityLevel "HIGH" .

oc:kn_cd42733c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "After identifying and fixing the root cause" ;
    oc:directiveContent "After fixing at the source, add defense-in-depth validation at every layer between the source and the symptom to make the bug impossible to recur." ;
    oc:hasRationale "Layered validation catches similar issues at the earliest possible point and prevents entire classes of bugs" .

oc:kn_cf316f26 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting root cause tracing" ;
    oc:directiveContent "Check if you can trace backwards through the call chain. If you hit a dead end, fall back to fixing at the symptom point and adding instrumentation." ;
    oc:hasRationale "Some call chains cannot be traced (async boundaries, native code, external processes) and attempting to trace them wastes time" .

oc:kn_ef69a895 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding debug instrumentation to trace a bug" ;
    oc:directiveContent "Log context BEFORE the dangerous operation, not after it fails. Include directory, cwd, environment variables, and the full call stack." ;
    oc:hasRationale "Post-failure logs miss the state that led to the failure; pre-operation captures capture the exact triggering conditions" .

