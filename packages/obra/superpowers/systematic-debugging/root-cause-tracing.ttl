                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**Run and capture:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "When you can't trace manually, add instrumentation:" ] ;
