oc:kn_076bcf12 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "After fixing any data validation bug" ;
    oc:directiveContent "Never add validation at only one point and consider the bug fixed. Different code paths, mocks, and platform edge cases will bypass single-point checks." ;
    oc:hasRationale "During testing, each layer catches bugs the others missed — different code paths bypass entry validation, mocks bypass business logic, and platform edge cases need environment guards" ;
    oc:severityLevel "HIGH" .

oc:kn_443fba1f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Layer 3: Environment guards for test safety" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """if (process.env.NODE_ENV === 'test') {
  const normalized = normalize(resolve(directory));
  const tmpDir = normalize(resolve(tmpdir()));
  if (!normalized.startsWith(tmpDir)) {
    throw new Error(`Refusing git init outside temp dir during tests: ${directory}`);
  }
}""" .

oc:kn_4de512c6 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When tempted to stop after adding one or two validation layers" ;
    oc:directiveContent "All four layers are necessary. During testing, each layer catches bugs the others missed: different code paths bypass entry validation, mocks bypass business logic checks, edge cases on different platforms need environment guards, and debug logging identifies structural misuse." ;
    oc:hasRationale "Real-world evidence shows each layer independently catches distinct failure modes" ;
    oc:severityLevel "HIGH" .

oc:kn_6583c7ac a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When operations have context-specific safety requirements" ;
    oc:directiveContent "Environment guards (Layer 3) prevent dangerous operations in specific contexts, such as refusing git init outside temp directories during tests." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6f5afc53 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Layer 1: Entry point validation at API boundary" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """if (!workingDirectory || workingDirectory.trim() === '') {
  throw new Error('workingDirectory cannot be empty');
}
if (!existsSync(workingDirectory)) {
  throw new Error(`workingDirectory does not exist: ${workingDirectory}`);
}
if (!statSync(workingDirectory).isDirectory()) {
  throw new Error(`workingDirectory is not a directory: ${workingDirectory}`);
}""" .

oc:kn_864df479 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When fixing any bug caused by invalid data" ;
    oc:directiveContent "Validate at EVERY layer data passes through, not just one. Single validation can be bypassed by different code paths, refactoring, or mocks." ;
    oc:hasRationale "Single validation is a point fix; multi-layer validation makes the bug structurally impossible" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9d074438 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After adding all four validation layers" ;
    oc:directiveContent "Test each layer independently by attempting to bypass earlier layers and verifying later layers still catch the bad data." ;
    oc:hasRationale "Confirms that the defense-in-depth actually works end-to-end" .

oc:kn_a572ee1e a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Layer 4: Debug instrumentation for forensics" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """const stack = new Error().stack;
logger.debug('About to git init', {
  directory,
  cwd: process.cwd(),
  stack,
});""" .

oc:kn_cd96e9bb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating whether a bug fix is sufficient" ;
    oc:directiveContent "Single validation means 'we fixed the bug'. Multiple layers mean 'we made the bug impossible'. Aim for the latter." ;
    oc:hasRationale "The goal is structural impossibility, not point-fixing" .

oc:kn_e10c58e5 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When applying defense-in-depth after finding a bug" ;
    oc:directiveContent "1. Trace the data flow — where does bad value originate and where is it used 2. Map all checkpoints — list every point data passes through 3. Add validation at each layer — entry, business, environment, debug 4. Test each layer — try to bypass layer 1, verify layer 2 catches it" ;
    oc:stepOrder 1 .

oc:kn_f65ce81f a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When defining API or function boundaries" ;
    oc:directiveContent "Entry point validation (Layer 1) rejects obviously invalid input at API boundaries — empty strings, non-existent paths, wrong types — preventing bad data from propagating deeper into the system." ;
    oc:severityLevel "MEDIUM" .

