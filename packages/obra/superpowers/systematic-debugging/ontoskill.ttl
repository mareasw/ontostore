_:ref_1a1b25d1a323c047 a oc:WorkflowStep ;
    dcterms:description "**Gather Evidence in Multi-Component Systems**" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:Paragraph ;
            oc:blockType "paragraph" ;
            oc:contentOrder 6 ;
            oc:textContent "**This reveals:** Which layer fails (secrets → workflow ✓, workflow → build ✗)" ],
        [ a oc:CodeExample ;
            oc:blockType "code_block" ;
            oc:codeContent """# Layer 1: Workflow
echo "=== Secrets available in workflow: ==="
echo "IDENTITY: ${IDENTITY:+SET}${IDENTITY:-UNSET}"

# Layer 2: Build script
echo "=== Env vars in build script: ==="
env | grep IDENTITY || echo "IDENTITY not in environment"

# Layer 3: Signing script
echo "=== Keychain state: ==="
security list-keychains
security find-identity -v

# Layer 4: Actual signing
codesign --sign "$IDENTITY" --verbose=4 "$APP"
""" ;
            oc:codeLanguage "bash" ;
            oc:contentOrder 5 ;
            oc:sourceLocation "lines 90-106" ],
        [ a oc:Paragraph ;
            oc:blockType "paragraph" ;
            oc:contentOrder 1 ;
            oc:textContent "**WHEN system has multiple components (CI → build → signing, API → service → database):**" ],
        [ a oc:Paragraph ;
            oc:blockType "paragraph" ;
            oc:contentOrder 2 ;
            oc:textContent "**BEFORE proposing fixes, add diagnostic instrumentation:**" ],
        [ a oc:Paragraph ;
            oc:blockType "paragraph" ;
            oc:contentOrder 4 ;
            oc:textContent "**Example (multi-layer system):**" ],
        [ a oc:CodeExample ;
            oc:blockType "code_block" ;
            oc:codeContent """For EACH component boundary:
  - Log what data enters component
  - Log what data exits component
  - Verify environment/config propagation
  - Check state at each layer

Run once to gather evidence showing WHERE it breaks
THEN analyze evidence to identify failing component
THEN investigate that specific component
""" ;
            oc:codeLanguage "" ;
            oc:contentOrder 3 ;
            oc:sourceLocation "lines 77-87" ] ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

