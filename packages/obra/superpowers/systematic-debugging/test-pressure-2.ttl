        oc:kn_f82ae4b7 ;
    oc:isUserInvocable false ;
    oc:nature "Tool" ;
    oc:requiresState oc:SystematicDebuggingLoaded ;
    oc:resolvesIntent "evaluate whether agent chooses root cause investigation over symptom patching after wasted effort",
        "test adherence to systematic debugging under exhaustion and time pressure",
        "test resistance to sunk cost fallacy in debugging" ;
    oc:yieldsState oc:SunkCostBiasResisted .

oc:kn_90ed3925 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When facing this specific pressure test scenario" ;
    oc:directiveContent "The correct answer is Option A: Delete all timeout code and restart systematic debugging from Phase 1. The status field not updating has a specific root cause that must be found, not worked around." ;
    oc:hasRationale "Option B (large timeout + TODO) is the exact 'quick fix for now, investigate later' pattern that systematic-debugging explicitly flags as a red flag. Option C still risks settling for a symptom fix. Only Option A follows the iron law of systematic debugging." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d3ac7945 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to restart investigation after prolonged failed attempts" ;
    oc:directiveContent "Time invested in wrong approaches is sunk cost — it must not influence the decision to restart with correct approach. All 4 hours of timeout attempts are irrelevant to whether systematic debugging is the right next step." ;
    oc:hasRationale "Sunk cost fallacy causes agents to continue flawed approaches to justify prior investment, compounding waste rather than cutting losses." ;
    oc:severityLevel "HIGH" .

oc:kn_dc2ab979 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When debugging flaky tests with timing issues" ;
    oc:directiveContent "Never increase arbitrary timeouts to fix intermittent test failures. Six escalating sleep attempts (100ms → 500ms → 1000ms → 2000ms) are all symptom fixes that indicate the root cause was never investigated." ;
    oc:hasRationale "Escalating timeouts is the hallmark of treating symptoms rather than root causes. The systematic-debugging skill mandates Phase 1 root cause investigation before ANY fix attempt." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e536bff9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When exhausted or under deadline pressure" ;
    oc:directiveContent "Exhaustion and time pressure make systematic processes MORE important, not less. The skill's language ('ESPECIALLY when under time pressure') anticipates exactly this rationalization." ;
    oc:hasRationale "Exhaustion degrades judgment precisely when judgment matters most. Following a written process compensates for degraded intuition." ;
    oc:severityLevel "HIGH" .

oc:kn_f82ae4b7 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When diagnostic evidence has already been gathered but not properly analyzed" ;
    oc:directiveContent "Debug logging already revealed 'payment processes, status not updating' — this IS evidence from Phase 1. The next step is to trace WHY status isn't updating (event emission? listener? state mutation?), not to add more sleep." ;
    oc:hasRationale "The debug logging output contains a concrete clue. Tracing the data flow of the status field would likely reveal the root cause quickly, making Option A's 2-3 hour estimate pessimistic." ;
    oc:severityLevel "MEDIUM" .

