@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_systematic_debugging_test_pressure_2 a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "test-pressure-2" ;
    skos:broader "pressure test" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/systematic-debugging" ;
    oc:contentHash "b2030aeffba07050e8ad573ddf87486457c4a016a786bb326235bebd856f2016" ;
    oc:dependsOnSkill oc:skill_systematic_debugging ;
    oc:differentia "that challenges the agent to resist sunk cost fallacy and exhaustion-driven shortcuts during extended debugging sessions" ;
    oc:extends oc:skill_obra_superpowers_systematic_debugging ;
    oc:handlesFailure oc:ExhaustionOverride,
        oc:SpeculativeFixCommitted ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_0dbc7bf3,
        oc:kn_601e9d65,
        oc:kn_6859ae2a,
        oc:kn_9ef00145,
        oc:kn_a76e3393 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:DebuggingSessionActive,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "choose systematic debugging over speculative fixes even when fatigued",
        "evaluate decision-making under exhaustion and sunk cost bias",
        "resist pragmatic shortcuts that embed technical debt" ;
    oc:yieldsState oc:DebuggingDecisionMade,
        oc:SunkCostBiasEvaluated .

oc:kn_0dbc7bf3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When you've spent hours trying fixes without understanding the root cause" ;
    oc:directiveContent "Always go back to Phase 1 (root cause investigation) when debugging attempts become increasingly speculative. The sunk cost of previous failed attempts should have zero weight in the decision to restart with proper methodology." ;
    oc:hasRationale "Escalating guesswork (sleep 100 → 500 → 1000 → 2000 → 5000) is a clear signal you lack understanding of the underlying mechanism. Each failed attempt proves the theory wrong — continuing the same pattern is irrational." ;
    oc:severityLevel "HIGH" .

oc:kn_601e9d65 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When debugging any test failure or unexpected behavior" ;
    oc:directiveContent "If you've tried the same category of fix more than twice without progress, stop and switch to a fundamentally different approach. The pattern 'increase timeout, check, increase again' is one approach tried multiple times, not multiple approaches." ;
    oc:hasRationale "The scenario shows 6 attempts all in the 'add more waiting' category. Recognizing when you are in a loop of same-category attempts is critical for breaking out of unproductive debugging spirals." ;
    oc:severityLevel "HIGH" .

oc:kn_6859ae2a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When tempted to commit a 'good enough' fix after hours of failed guessing" ;
    oc:directiveContent "Never commit speculative fixes like arbitrary sleep timeouts as solutions. Sleep-based workarounds for race conditions are not fixes — they are time bombs that shift failure modes rather than eliminating them." ;
    oc:hasRationale "Sunk cost fallacy makes throwing away failed attempts feel wasteful, but keeping broken code is worse than deleting it. A 5-second timeout that 'sometimes works' will fail in production under load." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9ef00145 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When debugging late at night or under deadline pressure" ;
    oc:directiveContent "Exhaustion and time pressure systematically bias toward Option B (pragmatic shortcut) even when it's the worst technical choice. The 'balanced' Option C is often a rationalization that leads to the same outcome as B after 30 more wasted minutes." ;
    oc:hasRationale "Fatigue impairs judgment. The scenario deliberately constructs Option C as a temptation that feels reasonable but often results in the same compromised outcome. Option A (systematic restart) is almost always correct regardless of sunk cost." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a76e3393 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When debugging time exceeds initial estimate by 2x or more" ;
    oc:directiveContent "Before continuing any debugging session past the expected time budget, explicitly ask: 'Do I understand WHY this is failing?' If the answer is no, switch to systematic root cause investigation immediately rather than trying more speculative fixes." ;
    oc:hasRationale "The scenario's 4 hours of failed attempts all share one trait: never understanding why the status wasn't updating. Checking understanding is the diagnostic that separates productive debugging from thrashing." ;
    oc:severityLevel "HIGH" .

