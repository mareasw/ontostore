oc:skill_obra_superpowers_systematic_debugging_condition_based_waiting a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "condition-based-waiting" ;
    skos:broader "testing strategy" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/systematic-debugging" ;
    oc:contentHash "e89fec8400d6cd50f43407cec9fab50976ba4d55d0ec2eb51c0bd68036b54c26" ;
    oc:differentia "replaces arbitrary delays with condition polling to eliminate race conditions and flaky tests" ;
    oc:extends oc:skill_obra_superpowers_systematic_debugging ;
    oc:handlesFailure oc:ConditionNeverMet,
        oc:TimeoutExceeded ;
    oc:hasArgumentHint "test code with arbitrary delays or flaky behavior" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_483d8054,
        oc:kn_54785873,
        oc:kn_55e33f29,
        oc:kn_95dbfced,
        oc:kn_d410e5e1 ;
    oc:isUserInvocable true ;
    oc:nature "technique" ;
    oc:requiresState oc:TestCodeAvailable ;
    oc:resolvesIntent "eliminate race conditions in tests",
        "fix flaky tests",
        "replace arbitrary delays with condition-based waiting",
        "wait for async operations in tests" ;
    oc:yieldsState oc:TestRaceConditionFixed .

oc:kn_483d8054 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or fixing tests with async operations" ;
    oc:directiveContent "Never use arbitrary delays (setTimeout, sleep, time.sleep()) in tests unless testing actual timing behavior. Always wait for the condition you care about." ;
    oc:hasRationale "Arbitrary delays create race conditions that pass on fast machines but fail under load or in CI, causing flaky tests." ;
    oc:severityLevel "CRITICAL" .

oc:kn_54785873 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When testing actual timing behavior like debounce or throttle intervals" ;
    oc:directiveContent "First wait for the triggering condition using condition-based waiting, then if an arbitrary timeout is truly needed for timing behavior, document exactly WHY with the timing rationale." ;
    oc:hasRationale "Some timing behavior legitimately requires delays, but they must be based on known timing intervals and justified with comments, not guesses." ;
    oc:severityLevel "MEDIUM" .

oc:kn_55e33f29 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When implementing waitFor-style polling functions" ;
    oc:directiveContent "Never cache state outside the polling loop. Call the getter or condition function inside the loop to get fresh data each iteration." ;
    oc:hasRationale "Stale data from caching state before the loop means the condition check never sees updated values, causing false timeouts." ;
    oc:severityLevel "HIGH" .

oc:kn_95dbfced a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running tests or retrying failed assertions" ;
    oc:directiveContent "Condition-based waiting is inherently safe to re-run: if the condition is already met, it returns immediately without side effects." ;
    oc:hasRationale "Unlike arbitrary delays which always consume time regardless of state, condition-based waiting short-circuits when the condition is already satisfied, making tests faster and more reliable." ;
    oc:severityLevel "LOW" .

oc:kn_d410e5e1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing condition-based wait loops" ;
    oc:directiveContent "Poll every 10ms as a balance between responsiveness and CPU efficiency. Always include a timeout with a descriptive error message." ;
    oc:hasRationale "Polling at 1ms wastes CPU; polling too slowly delays test execution. 10ms is a proven sweet spot. Timeouts prevent infinite loops when conditions are never met." ;
    oc:severityLevel "HIGH" .

