                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Tests are flaky (pass sometimes, fail under load)" ],
                                [ a oc:BulletItem ;
