oc:skill_obra_superpowers_systematic_debugging_test_academic a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "test-academic" ;
    skos:broader "Assessment instrument" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/systematic-debugging" ;
    oc:contentHash "fe2ba480d78ac0d686dc025f41c2a32a43d642bf533f91b0c6053a04d35d6486" ;
    oc:differentia "that tests comprehension of the systematic debugging skill's four phases, root cause investigation requirements, and anti-patterns through direct-quote-based questioning" ;
    oc:extends oc:skill_obra_superpowers_systematic_debugging ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "(none - self-contained test)" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_7b83f0a2,
        oc:req_8e35d124 ;
    oc:impartsKnowledge oc:kn_1f92e5d9,
        oc:kn_2f3f7e3c,
        oc:kn_92e80b25,
        oc:kn_a9a30ee2,
        oc:kn_d1859004 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "assess knowledge of root cause investigation requirements",
        "test comprehension of debugging anti-patterns",
        "verify understanding of systematic debugging phases" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_1f92e5d9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing academic tests for other skills" ;
    oc:directiveContent "The six questions cover the skill's core epistemic content: phase structure, prerequisites (root cause before fix), hypothesis iteration, anti-patterns (multiple fixes), knowledge boundaries (don't understand), and process discipline (no skipping)." ;
    oc:hasRationale "This question set is a template for knowledge verification — it probes structural knowledge (phases), procedural constraints (before fixing), iterative reasoning (hypothesis failure), anti-patterns (multiple fixes), epistemic humility (not understanding), and discipline (no shortcuts)." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2f3f7e3c a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When evaluating academic test responses" ;
    oc:directiveContent "The test requires answers with direct quotes from the skill, validating that the agent has actually read and retained the skill content rather than relying on prior knowledge." ;
    oc:hasRationale "Direct-quote requirements prevent hallucination and confirm the agent is grounding answers in the specific skill text, not general debugging knowledge." ;
    oc:severityLevel "HIGH" .

oc:kn_92e80b25 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When answering all six test questions" ;
    oc:directiveContent "Answers must be based SOLELY on what the skill says, not on general debugging knowledge or assumptions." ;
    oc:hasRationale "The 'SOLELY' constraint prevents the agent from conflating the skill's specific guidance with external knowledge, ensuring accurate comprehension testing." ;
    oc:severityLevel "HIGH" .

oc:kn_a9a30ee2 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, before attempting the test" ;
    oc:directiveContent "The test assumes the skill content at skills/debugging/systematic-debugging is accessible and that the agent can read it before answering." ;
    oc:hasRationale "If the skill content is unavailable, the test cannot be completed as designed, since answers must derive from the actual skill text." ;
    oc:severityLevel "LOW" .

oc:kn_d1859004 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before answering any academic test question" ;
    oc:directiveContent "The agent must first read the systematic-debugging skill before answering any questions. The test explicitly states: 'Read the skill and answer these questions based SOLELY on what the skill says.'" ;
    oc:hasRationale "Ensures answers derive from the actual skill content rather than assumptions or prior knowledge, maintaining fidelity to the skill's specific guidance." ;
    oc:severityLevel "CRITICAL" .

oc:req_7b83f0a2 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Ability to read and quote from skill documentation" .

oc:req_8e35d124 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Access to systematic-debugging skill content" .

