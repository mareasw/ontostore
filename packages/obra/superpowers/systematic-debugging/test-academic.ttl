oc:kn_43922142 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When running the academic test" ;
    oc:directiveContent "1. Read the systematic-debugging SKILL.md 2. Answer six specific questions using ONLY direct quotes from the skill 3. Questions cover: four phases, pre-fix requirements, hypothesis failure handling, multiple-fix policy, uncertainty handling, and process skip policy" ;
