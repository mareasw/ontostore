        oc:kn_809ce847,
        oc:kn_a9d21d9d,
        oc:kn_cbe110e8,
        oc:kn_e903200a ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:FileExists ;
    oc:resolvesIntent "execute implementation plan",
        "follow written plan step by step",
        "review and implement plan tasks",
        "run plan with verification checkpoints" ;
    oc:yieldsState oc:PlanExecuted .

oc:kn_02bd6cce a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing execution strategy" ;
    oc:directiveContent "If subagents are available on the platform (e.g., Claude Code, Codex), use subagent-driven-development instead of this skill for significantly higher quality work." ;
    oc:hasRationale "Subagents enable parallel execution and isolation, producing better results for multi-task plans." ;
    oc:severityLevel "MEDIUM" .

oc:kn_193c3e02 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing plan tasks" ;
    oc:directiveContent "Never skip verifications specified in the plan, even if implementation appears complete." ;
    oc:hasRationale "Verifications are the quality gate that ensures each task was implemented correctly before moving on." ;
    oc:severityLevel "CRITICAL" .

oc:kn_2ba79a17 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before beginning any plan execution" ;
    oc:directiveContent "Never start implementation on main/master branch without explicit user consent." ;
    oc:hasRationale "Direct commits to main/master can destabilize the codebase and make rollback difficult." ;
    oc:severityLevel "CRITICAL" .

oc:kn_50d5ed0f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning plan execution" ;
    oc:directiveContent "Verify plan file exists, plan content is complete, and an isolated workspace (git worktree) is set up before starting execution." ;
    oc:severityLevel "HIGH" .

oc:kn_809ce847 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When first loading a plan" ;
    oc:directiveContent "Review the plan critically before executing any task. Raise concerns with your human partner before starting implementation." ;
    oc:hasRationale "Plans may contain gaps, ambiguities, or outdated assumptions that will cause problems during execution." ;
    oc:severityLevel "HIGH" .

oc:kn_a9d21d9d a oc:KnowledgeNode,
        oc:RequiresHumanClarification ;
    oc:appliesToContext "During plan execution when blocked" ;
    oc:directiveContent "Stop executing and ask the human partner when hitting blockers, unclear instructions, critical plan gaps, or repeated verification failures." ;
    oc:hasRationale "Forcing through blockers wastes time and introduces errors. Human input resolves ambiguity efficiently." ;
    oc:severityLevel "HIGH" .

oc:kn_cbe110e8 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing a plan from start to finish" ;
    oc:directiveContent "1. Load and review plan critically 2. Raise concerns or create TodoWrite 3. For each task: mark in_progress → follow steps exactly → run verifications → mark completed 4. After all tasks: delegate to finishing-a-development-branch" ;
    oc:stepOrder 1 .

oc:kn_e903200a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When blocked or confused during execution" ;
    oc:directiveContent "Never guess when instructions are unclear or verification fails repeatedly. Stop and ask for clarification." ;
    oc:hasRationale "Guessing leads to incorrect implementations that compound errors across dependent tasks." ;
    oc:severityLevel "HIGH" .

