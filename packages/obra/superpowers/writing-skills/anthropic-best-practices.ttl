_:ref_3422dd3a04aa0b9a a oc:WorkflowStep ;
    dcterms:description "**No context penalty for large files**: Reference files, data, or documentation don't consume context tokens until actually read" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

