                            oc:sectionTitle "Writing Pressure Scenarios" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "Make agent believe it's real work, not a quiz." ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """IMPORTANT: This is a real scenario. You must choose and act.
