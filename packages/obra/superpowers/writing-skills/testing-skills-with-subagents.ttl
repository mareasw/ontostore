@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_writing_skills_testing_skills_with_subagents a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "testing-skills-with-subagents" ;
    skos:broader "testing framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/writing-skills" ;
    oc:contentHash "c711346852c911b24a84aa161e0cff06a4cd7f4e2fa9e9c0a266cead5afcbade" ;
    oc:dependsOnSkill oc:skill_test_driven_development ;
    oc:differentia "applies TDD principles (RED-GREEN-REFACTOR) to skill validation using pressure scenarios and rationalization capture with subagents" ;
    oc:extends oc:skill_obra_superpowers_writing_skills ;
    oc:handlesFailure oc:AgentNonCompliant,
        oc:RationalizationDetected,
        oc:SkillInsufficient ;
    oc:hasArgumentHint "skill-to-test" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_2084b324,
        oc:kn_5aea4f64,
        oc:kn_5c0d59d3,
        oc:kn_64477eaf,
        oc:kn_78ac3f1f,
        oc:kn_a529f719,
        oc:kn_cd376a7a ;
    oc:isUserInvocable true ;
    oc:nature "methodology" ;
    oc:requiresState oc:SkillDrafted ;
    oc:resolvesIntent "bulletproof discipline-enforcing skills",
        "capture agent rationalizations against skill rules",
        "test skill effectiveness",
        "verify skill compliance under pressure" ;
    oc:yieldsState oc:SkillBulletproof,
        oc:SkillTested .

oc:kn_2084b324 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which skills to test" ;
    oc:directiveContent "Do not test pure reference skills (API docs, syntax guides) or skills without rules to violate. Only test skills that enforce discipline, have compliance costs, could be rationalized away, or contradict immediate goals." ;
    oc:hasRationale "Testing reference skills wastes effort—agents have no incentive to bypass them. Focus testing on skills where agents are motivated to skip or weaken compliance." ;
    oc:severityLevel "LOW" .

oc:kn_5aea4f64 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When agent violates skill despite having it (during any phase)" ;
    oc:directiveContent "Use meta-testing after agent fails: ask 'How could the skill have been written differently to make the correct answer crystal clear?' Three outcomes distinguish documentation problems from foundation problems from organization problems." ;
    oc:hasRationale "Meta-testing categorizes failures into actionable fixes: 'skill was clear' means add foundational principle, 'should have said X' means add that text, 'didn't see Y' means reorganize." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5c0d59d3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing pressure scenarios for GREEN and REFACTOR phases" ;
    oc:directiveContent "Never test skills with single-pressure academic scenarios like 'What does the skill say?'. Always combine 3+ pressures (time + sunk cost + exhaustion, etc.) to simulate real temptation to violate." ;
    oc:hasRationale "Agents resist single pressure easily. Multiple combined pressures expose the actual rationalizations the skill must counter. Academic tests only verify recitation, not compliance." ;
    oc:severityLevel "HIGH" .

oc:kn_64477eaf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before deploying any discipline-enforcing skill" ;
    oc:directiveContent "If you didn't watch an agent fail without the skill, you don't know if the skill prevents the right failures. Always run RED phase baseline tests before writing or refining the skill." ;
    oc:hasRationale "Baseline failures reveal what ACTUALLY needs preventing, not what you think needs preventing. Skipping RED means guessing at requirements." ;
    oc:severityLevel "CRITICAL" .

oc:kn_78ac3f1f a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When agent violates the skill during testing" ;
    oc:directiveContent "When skill fails under pressure, capture the agent's exact rationalization verbatim—never paraphrase. The specific wording reveals the loophole to close." ;
    oc:hasRationale "Paraphrasing loses the exact rationalization pattern. Verbatim capture ensures the counter directly addresses the actual reasoning, not an approximation." ;
    oc:severityLevel "HIGH" .

oc:kn_a529f719 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When evaluating whether testing is complete" ;
    oc:directiveContent "Before declaring a skill bulletproof, verify all four signs: agent chooses correct option under max pressure, cites skill sections as justification, acknowledges temptation but follows rule, and meta-testing reveals 'skill was clear, I should follow it'." ;
    oc:hasRationale "Partial compliance (e.g., correct choice but for wrong reasons) means the skill works by accident, not by design. All four signs must be present." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cd376a7a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During REFACTOR phase when closing loopholes" ;
    oc:directiveContent "For each rationalization found during testing, add three counters: (1) explicit negation in rules, (2) entry in rationalization table mapping excuse to reality, (3) red flag entry so the pattern is recognized." ;
    oc:hasRationale "Vague fixes like 'don't cheat' don't work. Each specific rationalization needs a specific, explicit counter-addressing the exact wording the agent used." ;
    oc:severityLevel "HIGH" .

