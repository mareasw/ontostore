oc:skill_obra_superpowers_writing_skills_testing_skills_with_subagents a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "testing-skills-with-subagents" ;
    skos:broader "Testing methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/writing-skills" ;
    oc:contentHash "c711346852c911b24a84aa161e0cff06a4cd7f4e2fa9e9c0a266cead5afcbade" ;
    oc:dependsOnSkill oc:skill_ontoskills_test_driven_development ;
    oc:differentia "applies TDD's RED-GREEN-REFACTOR cycle to skill documentation by using pressure scenarios with subagents to verify skills resist rationalization before deployment" ;
    oc:extends oc:skill_obra_superpowers_writing_skills ;
    oc:handlesFailure oc:AgentNonCompliance,
        oc:SkillIncomplete ;
    oc:hasArgumentHint "skill-to-test" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "**Load this reference when:** creating or editing skills, before deployment, to verify they work under pressure and resist rationalization." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 6 ;
                            oc:tableCaption "## Quick Reference (TDD Cycle)" ;
                            oc:tableMarkdown """| TDD Phase | Skill Testing | Success Criteria |
|-----------|---------------|------------------|
| **RED** | Run scenario without skill | Agent fails, document rationalizations |
| **Verify RED** | Capture exact wording | Verbatim documentation of failures |
| **GREEN** | Write skill addressing failures | Agent now complies with skill |
| **Verify GREEN** | Re-test scenarios | Agent follows rule under pressure |
| **REFACTOR** | Close loopholes | Add counters for new rationalizations |
| **Stay GREEN** | Re-verify | Agent still complies after refactoring |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 26 ;
                    oc:sectionTitle "Quick Reference (TDD Cycle)" ],
