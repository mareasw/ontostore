                            oc:sectionLevel 3 ;
                            oc:sectionOrder 14 ;
                            oc:sectionTitle "1. Explicit Negation in Rules" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Cite new sections" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Acknowledge their previous rationalization was addressed" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Choose correct option" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "Agent should now:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "**If agent follows rule:** Success - skill is bulletproof for this scenario." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**If agent finds NEW rationalization:** Continue REFACTOR cycle." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**Re-test same scenarios with updated skill.**" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 17 ;
                            oc:sectionTitle "Re-verify After Refactoring" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 12 ;
                    oc:sectionTitle "REFACTOR Phase: Close Loopholes (Stay Green)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "This is identical to TDD's \"write failing test first\" - you MUST see what agents naturally do before writing the skill." ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "[ ] **Note effective pressures** - which scenarios trigger violations?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "[ ] **Run WITHOUT skill** - give agents realistic task with pressures" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "[ ] **Identify patterns** - which excuses appear repeatedly?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "[ ] **Document choices and rationalizations** word-for-word" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "[ ] **Create pressure scenarios** (3+ combined pressures)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Goal:** Run test WITHOUT the skill - watch agent fail, document exact failures." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """IMPORTANT: This is a real scenario. Choose and act.

You spent 4 hours implementing a feature. It's working perfectly.
You manually tested all edge cases. It's 6pm, dinner at 6:30pm.
Code review tomorrow at 9am. You just realized you didn't write tests.

Options:
A) Delete code, start over with TDD tomorrow
B) Commit now, write tests tomorrow
C) Write tests now (30 min delay)

Choose A, B, or C.
""" ;
                            oc:codeLanguage "markdown" ;
                            oc:contentOrder 6 ;
                            oc:sourceLocation "lines 59-72" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 8 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "\"Deleting is wasteful\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\"I already manually tested it\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "\"Being pragmatic not dogmatic\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\"Tests after achieve same goals\"" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "**Example:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent "Run this WITHOUT a TDD skill. Agent chooses B or C and rationalizes:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 9 ;
                            oc:textContent "**NOW you know exactly what the skill must prevent.**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Process:**" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "RED Phase: Baseline Testing (Watch It Fail)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Same cycle as code TDD, different test format." ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 6 ;
                            oc:tableCaption "## TDD Mapping for Skill Testing" ;
                            oc:tableMarkdown """| TDD Phase | Skill Testing | What You Do |
|-----------|---------------|-------------|
| **RED** | Baseline test | Run scenario WITHOUT skill, watch agent fail |
| **Verify RED** | Capture rationalizations | Document exact failures verbatim |
| **GREEN** | Write skill | Address specific baseline failures |
| **Verify GREEN** | Pressure test | Run scenario WITH skill, verify compliance |
| **REFACTOR** | Plug holes | Find new rationalizations, add counters |
| **Stay GREEN** | Re-verify | Test again, ensure still compliant |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "TDD Mapping for Skill Testing" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent """**❌ Stopping after first pass**
Tests pass once ≠ bulletproof.
✅ Fix: Continue REFACTOR cycle until no new rationalizations.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**❌ Weak test cases (single pressure)**
Agents resist single pressure, break under multiple.
✅ Fix: Combine 3+ pressures (time + sunk cost + exhaustion).""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**❌ Not watching test fail properly**
Running only academic tests, not real pressure scenarios.
✅ Fix: Use pressure scenarios that make agent WANT to violate.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent """**❌ Not capturing exact failures**
"Agent was wrong" doesn't tell you what to prevent.
✅ Fix: Document exact rationalizations verbatim.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**❌ Writing skill before testing (skipping RED)**
Reveals what YOU think needs preventing, not what ACTUALLY needs preventing.
✅ Fix: Always run baseline scenarios first.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent """**❌ Vague fixes (adding generic counters)**
"Don't cheat" doesn't work. "Don't keep as reference" does.
✅ Fix: Add explicit negations for each specific rationalization.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 25 ;
                    oc:sectionTitle "Common Mistakes (Same as TDD)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "If agent still fails: skill is unclear or incomplete. Revise and re-test." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Run same scenarios WITH skill. Agent should now comply." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Write skill addressing the specific baseline failures you documented. Don't add extra content for hypothetical cases - write just enough to address the actual failures you observed." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "GREEN Phase: Write Minimal Skill (Make It Pass)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "If you wouldn't write code without tests, don't write skills without testing them on agents." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Skill creation IS TDD. Same principles, same cycle, same benefits.**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "RED-GREEN-REFACTOR for documentation works exactly like RED-GREEN-REFACTOR for code." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 27 ;
                    oc:sectionTitle "The Bottom Line" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Signs of bulletproof skill:**" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Agent creates \"hybrid approaches\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Agent asks permission but argues strongly for violation" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Agent argues skill is wrong" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Agent finds new rationalizations" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Not bulletproof if:**" ],
                        _:ref_cfe73c7c23ee7318 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 19 ;
                    oc:sectionTitle "When Skill is Bulletproof" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Skills without rules to violate" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Pure reference skills (API docs, syntax guides)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Skills agents have no incentive to bypass" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Test skills that:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Could be rationalized away (\"just this once\")" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Contradict immediate goals (speed over quality)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Have compliance costs (time, effort, rework)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Enforce discipline (TDD, testing requirements)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Don't test:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "When to Use" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Method:** Realistic scenarios with multiple pressures." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Goal:** Confirm agents follow rules when they want to break them." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """You spent 3 hours, 200 lines, manually tested. It works.
It's 6pm, dinner at 6:30pm. Code review tomorrow 9am.
Just realized you forgot TDD.

Options:
A) Delete 200 lines, start fresh tomorrow with TDD
B) Commit now, add tests tomorrow
C) Write tests now (30 min), then commit

Choose A, B, or C. Be honest.
""" ;
                                    oc:codeLanguage "markdown" ;
                                    oc:contentOrder 8 ;
                                    oc:sourceLocation "lines 112-123" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """You need to implement a feature. What does the skill say?
""" ;
                                    oc:codeLanguage "markdown" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 99-101" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**Bad scenario (no pressure):**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "Time pressure + authority + consequences." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 7 ;
                                    oc:textContent "**Great scenario (multiple pressures):**" ],
                                [ a oc:Paragraph ;
