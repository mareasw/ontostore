                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Skills that enforce discipline (like TDD) need to resist rationalization. Agents are smart and will find loopholes when under pressure." ],
                        [ a oc:Paragraph ;
