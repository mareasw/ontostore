oc:skill_obra_superpowers_writing_skills a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "writing-skills" ;
    skos:broader "Meta-skill documentation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/writing-skills" ;
    oc:contentHash "9f58e8f3258605c667207513f5a73ff50d07048cb6dd788055b8e65f4f106255" ;
    oc:dependsOnSkill oc:skill_test_driven_development ;
    oc:differentia "applies test-driven development methodology to the creation, testing, and refinement of agent skill documentation using pressure scenarios with subagents to validate compliance before deployment" ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasAlias "create-skill",
        "create-skills",
        "skill-authoring",
        "skill-writing" ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Glob",
        "Grep",
        "Read",
        "TodoWrite",
        "Write" ;
    oc:hasArgumentHint "skill-name or skill-directory path" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Use when creating new skills, editing existing skills, or verifying skills work before deployment" ;
    oc:hasName "writing-skills" ;
    oc:hasPackageName "null" ;
    oc:hasRequirement oc:req_10b56d52,
        oc:req_164fdbdc,
        oc:req_3d1908a7,
        oc:req_724a2fc7 ;
    oc:impartsKnowledge oc:kn_1eea22c6,
        oc:kn_270e3c44,
        oc:kn_4eb4c02b,
        oc:kn_508652e6,
        oc:kn_61ef1db7,
        oc:kn_977915cb,
        oc:kn_9d24fe46,
        oc:kn_ed4ebbca,
        oc:kn_f109f7f5 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create new skills",
        "edit existing skills",
        "test skills against rationalization",
        "verify skills work before deployment",
        "write skill documentation with TDD methodology" ;
    oc:yieldsState oc:DocumentCreated,
        oc:SkillTestedAndVerified .

oc:kn_1eea22c6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing skill content and cross-references" ;
    oc:directiveContent "Do NOT use @ syntax to cross-reference other skills — it force-loads files immediately consuming 200k+ context. Do NOT create multi-language examples. Do NOT use flowcharts for reference material or linear instructions. Do NOT use generic labels like step1, helper2." ;
    oc:hasRationale "@ links burn context before it's needed. One excellent example beats many mediocre ones. Flowcharts should only be used for non-obvious decision points. Labels must have semantic meaning." ;
    oc:severityLevel "MEDIUM" .

oc:kn_270e3c44 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any skill's YAML frontmatter description" ;
    oc:directiveContent "NEVER summarize the skill's process or workflow in the YAML description field. The description should ONLY contain triggering conditions starting with 'Use when...'. Including workflow summaries causes agents to follow the description shortcut instead of reading the full skill body." ;
    oc:hasRationale "Testing revealed that descriptions summarizing workflow cause Claude to skip reading the skill content. A description saying 'code review between tasks' caused one review instead of two. Trigger-only descriptions force agents to read the full skill." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4eb4c02b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring any SKILL.md file" ;
    oc:directiveContent "Skills MUST have YAML frontmatter with exactly two required fields: name (letters, numbers, hyphens only, max 64 chars) and description (third-person, max 1024 chars total frontmatter). Keep SKILL.md body under 500 lines. Separate heavy reference (100+ lines) into supporting files." ;
    oc:hasRationale "Context window is a shared public good. Getting-started skills load into every conversation. Token efficiency directly impacts agent performance. Name/description are pre-loaded at startup for discovery." ;
    oc:severityLevel "HIGH" .

oc:kn_508652e6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When bulletproofing discipline-enforcing skills against rationalization" ;
    oc:directiveContent "For discipline-enforcing skills, explicitly close every rationalization loophole: add explicit negations for specific workarounds, address 'spirit vs letter' arguments with a foundational principle, build a rationalization table from testing, create red flags lists for self-checking." ;
    oc:hasRationale "Agents are smart and find loopholes under pressure. 'Don't cheat' doesn't work but 'Don't keep as reference' does. Verbatim rationalizations from baseline testing become the raw material for explicit counters." ;
    oc:severityLevel "HIGH" .

oc:kn_61ef1db7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When following the skill creation process" ;
    oc:directiveContent "Use the RED-GREEN-REFACTOR cycle for skill creation: RED = run pressure scenarios WITHOUT skill and document baseline failures verbatim; GREEN = write minimal skill addressing those specific failures; REFACTOR = close loopholes as agents find new rationalizations." ;
    oc:hasRationale "This mirrors TDD for code. Writing the skill first reveals what YOU think needs preventing, not what ACTUALLY needs preventing. Baseline testing reveals real agent rationalizations." ;
    oc:severityLevel "HIGH" .

oc:kn_977915cb a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When testing skills before deployment" ;
    oc:directiveContent "Different skill types require different testing approaches: discipline-enforcing skills need pressure scenarios with 3+ combined pressures (time + sunk cost + exhaustion); technique skills need application and edge case scenarios; pattern skills need recognition and counter-example scenarios; reference skills need retrieval and gap testing." ;
    oc:hasRationale "A single test approach doesn't work for all skill types. Discipline skills fail under rationalization pressure. Technique skills fail on edge cases. Reference skills fail on coverage gaps." ;
    oc:severityLevel "HIGH" .

oc:kn_9d24fe46 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When optimizing skill content for token efficiency" ;
    oc:directiveContent "Target word counts: getting-started workflows <150 words each, frequently-loaded skills <200 words total, other skills <500 words. Use cross-references instead of repeating content. Compress examples. Move details to tool --help or separate reference files." ;
    oc:hasRationale "Skills share the context window with system prompt, conversation history, and other skills. Every token counts. Progressive disclosure via separate files avoids loading unnecessary content." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ed4ebbca a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before committing or deploying any skill" ;
    oc:directiveContent "Before deploying ANY skill, verify through the complete checklist: RED phase (pressure scenarios created, baseline run, rationalizations documented), GREEN phase (correct naming, frontmatter, description format, keywords, baseline failures addressed, compliance verified), REFACTOR phase (new rationalizations countered, table built, red flags created, re-tested until bulletproof)." ;
    oc:hasRationale "Deploying untested skills equals deploying untested code. No exceptions — not for simple additions, documentation updates, or batch creation. Each skill must be individually verified." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f109f7f5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or editing any skill" ;
    oc:directiveContent "Writing skills IS Test-Driven Development applied to process documentation. You MUST write failing tests (baseline pressure scenarios) BEFORE writing the skill document. No skill without a failing test first." ;
    oc:hasRationale "If you didn't watch an agent fail without the skill, you don't know if the skill teaches the right thing. Untested skills always have issues." ;
    oc:severityLevel "CRITICAL" .

oc:req_10b56d52 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "TodoWrite for checklist tracking" .

oc:req_164fdbdc a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "test-driven-development" .

oc:req_3d1908a7 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "subagent dispatching capability for pressure testing" .

oc:req_724a2fc7 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "graphviz (dot) for flowchart rendering" .

