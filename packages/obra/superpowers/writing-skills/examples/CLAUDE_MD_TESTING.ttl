@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_writing_skills_claude_md_testing a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "claude-md-testing" ;
    skos:broader "Testing methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/writing-skills" ;
    oc:contentHash "0b379a3415e185d3c434b3ad283d8aa132f3022c2a4f210f168865b5986bcef0" ;
    oc:differentia "that evaluates CLAUDE.md documentation variants for their ability to make agents discover and use skills under psychological pressure scenarios" ;
    oc:extends oc:skill_obra_superpowers_writing_skills ;
    oc:hasCategory "research" ;
    oc:impartsKnowledge oc:kn_10749464,
        oc:kn_bda0fcde,
        oc:kn_d8231db9,
        oc:kn_dd499d66,
        oc:kn_df973111 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "compare documentation variant compliance rates",
        "evaluate skill discovery compliance under pressure",
        "identify rationalizations that bypass skill usage",
        "test CLAUDE.md documentation effectiveness" .

oc:kn_10749464 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When evaluating CLAUDE.md variant test results" ;
    oc:directiveContent "A documentation variant succeeds only if the agent checks for skills unprompted, reads the skill completely before acting, follows guidance under pressure, and cannot rationalize away compliance." ;
    oc:hasRationale "Partial compliance (checks but doesn't read, or reads but adapts without following) indicates the variant is insufficient" ;
    oc:severityLevel "HIGH" .

oc:kn_bda0fcde a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing test scenarios for documentation variants" ;
    oc:directiveContent "Combine multiple pressure types (time + sunk cost + authority + familiarity) when testing, as single-pressure tests may pass while combined pressures cause compliance breakdown." ;
    oc:hasRationale "Real-world conditions layer multiple pressures simultaneously; single-pressure testing gives false confidence" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d8231db9 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When beginning CLAUDE.md documentation testing" ;
    oc:directiveContent "Always run NULL baseline first (no skills documentation) to capture natural agent behavior and exact rationalizations before testing any variant." ;
    oc:hasRationale "Without a baseline you cannot measure improvement; verbatim rationalizations reveal which pressures bypass compliance" ;
    oc:severityLevel "HIGH" .

oc:kn_dd499d66 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing documentation tone for skill discovery" ;
    oc:directiveContent "Soft suggestions like 'consider checking skills' fail under pressure; agents rationalize skipping them when time, sunk cost, or authority pressure is present." ;
    oc:hasRationale "Variant A testing shows soft language provides plausible deniability for skipping skill checks" ;
    oc:severityLevel "MEDIUM" .

oc:kn_df973111 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing CLAUDE.md skill discovery documentation" ;
    oc:directiveContent "Test documentation variants against psychological pressure scenarios (time pressure, sunk cost, authority bias, familiarity) to measure real-world compliance, not just ideal conditions." ;
    oc:hasRationale "Agents optimize for speed and confidence; only pressure-tested documentation proves effective in production" ;
    oc:severityLevel "HIGH" .

