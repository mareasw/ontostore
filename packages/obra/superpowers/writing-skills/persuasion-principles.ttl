@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_obra_superpowers_writing_skills_persuasion_principles a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "persuasion-principles" ;
    skos:broader "persuasion framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/obra/superpowers/writing-skills" ;
    oc:contentHash "c3c84f572a51dd8b6d4fc6e5cbdc2bc3b9e07ba381a45bdabfce7ad2894dd828" ;
    oc:differentia "applies Cialdini's seven principles to LLM skill design for higher compliance with critical practices" ;
    oc:extends oc:skill_obra_superpowers_writing_skills ;
    oc:hasArgumentHint "skill-type or skill being designed" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_fa8d1f58 ;
    oc:impartsKnowledge oc:kn_369def91,
        oc:kn_a9a4c93e,
        oc:kn_afe8fca0,
        oc:kn_b00f5432,
        oc:kn_d52067dc,
        oc:kn_e9cd3ffb ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "avoid manipulative or ineffective persuasion in skills",
        "choose appropriate persuasion techniques for skill types",
        "design more effective skills",
        "increase LLM compliance with skill instructions" .

oc:kn_369def91 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before deploying any persuasion technique in a skill" ;
    oc:directiveContent "Apply the ethical test: would this technique serve the user's genuine interests if they fully understood it? Legitimate uses ensure critical practices are followed and prevent predictable failures. Illegitimate uses manipulate for personal gain, create false urgency, or use guilt-based compliance." ;
    oc:hasRationale "Persuasion is a powerful tool that can be misused. The ethical boundary ensures skills remain user-serving rather than self-serving" ;
    oc:severityLevel "HIGH" .

oc:kn_a9a4c93e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing step-by-step instructions or workflow triggers in skills" ;
    oc:directiveContent "Use implementation intentions ('When X, do Y') rather than general directives ('generally do Y'). Pair clear triggers with required actions for automatic execution." ;
    oc:hasRationale "Implementation intentions reduce cognitive load on compliance by creating automatic behavior patterns. Clear trigger-action pairs are more effective than vague directives." ;
    oc:severityLevel "MEDIUM" .

oc:kn_afe8fca0 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing instructions for discipline-enforcing or safety-critical skills" ;
    oc:directiveContent "Use imperative, absolute language for critical practices: 'YOU MUST', 'Never', 'Always', 'No exceptions'. Avoid hedging language like 'consider', 'when feasible', 'probably'." ;
    oc:hasRationale "Bright-line rules eliminate decision fatigue and rationalization. LLMs trained on human text where authority language precedes compliance. Meincke et al. (2025) showed persuasion more than doubled compliance (33% → 72%)." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b00f5432 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing skill language and framing" ;
    oc:directiveContent "Do not combine all seven persuasion principles in a single skill. Select 2-3 maximum based on skill type. Overusing principles reduces effectiveness." ;
    oc:hasRationale "Stacking too many persuasion techniques creates noise and can feel coercive rather than helpful. Focused application of the right principles is more effective." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d52067dc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any skill that requires disciplined behavior from the LLM" ;
    oc:directiveContent "Never use Liking or Reciprocity principles for compliance enforcement in skills. Liking creates sycophancy and conflicts with honest feedback culture. Reciprocity can feel manipulative and is rarely needed." ;
    oc:hasRationale "These principles undermine the skill's purpose by prioritizing agreement over correctness, and creating inauthentic compliance patterns" ;
    oc:severityLevel "HIGH" .

oc:kn_e9cd3ffb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or reviewing any skill's language and framing" ;
    oc:directiveContent "Match persuasion principles to skill type: use Authority + Commitment + Social Proof for discipline-enforcing skills; moderate Authority + Unity for guidance skills; Unity + Commitment for collaborative skills; only clarity (no persuasion) for reference skills." ;
    oc:hasRationale "Mismatched persuasion techniques reduce effectiveness — heavy authority in collaborative skills creates resistance, while lacking authority in discipline skills enables rationalization" ;
    oc:severityLevel "HIGH" .

oc:req_fa8d1f58 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Cialdini's seven persuasion principles" .

