        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or editing any skill" ;
    oc:directiveContent "Match persuasion principles to skill type: use Authority + Commitment + Social Proof for discipline-enforcing skills; moderate Authority + Unity for guidance/technique skills; Unity + Commitment for collaborative skills; clarity only for reference skills." ;
    oc:hasRationale "Principle combinations that match the skill's purpose produce the right compliance level without over- or under-constraining the agent." ;
    oc:severityLevel "HIGH" .

oc:kn_12cdf3e5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing discipline-enforcing skill instructions" ;
    oc:directiveContent "Use absolute imperative language ('YOU MUST', 'Never', 'Always', 'No exceptions') for discipline-enforcing skills to remove decision fatigue and eliminate rationalization loopholes." ;
    oc:hasRationale "Bright-line rules with absolute language reduce rationalization. 'Consider doing X' is far less effective than 'YOU MUST do X. No exceptions.'" ;
    oc:severityLevel "MEDIUM" .

oc:kn_60ffef5c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying persuasion to any skill" ;
    oc:directiveContent "Do not combine all seven persuasion principles in a single skill — select 2-3 that match the skill type. The ethical test: would this technique serve the user's genuine interests if they fully understood it?" ;
    oc:hasRationale "Overuse of principles reduces effectiveness and risks crossing into manipulation. Ethical application ensures skills serve the user's genuine interests." ;
    oc:severityLevel "CRITICAL" .

oc:kn_650d8a13 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When designing multi-step or discipline-enforcing skills" ;
    oc:directiveContent "Require explicit commitment mechanisms in skills: force announcements ('Announce skill usage'), explicit choices ('Choose A, B, or C'), and use tracking tools like TodoWrite for checklists." ;
    oc:hasRationale "Commitment and consistency principles more than doubled compliance rates (33% → 72%) in research with N=28,000 AI conversations." ;
    oc:severityLevel "HIGH" .

oc:kn_6ce5d9de a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When documenting the persuasion strategy for a skill" ;
    oc:directiveContent """## Skill Type: {type}
## Principles to Use: {principles}
## Principles to Avoid: {avoided}
## Implementation: {how_applied}
## Ethical Check: {passes_test}""" ;
    oc:templateVariables "avoided",
        "how_applied",
        "passes_test",
        "principles",
        "type" .

oc:kn_b006033e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When designing or reviewing any skill's persuasion strategy" ;
    oc:directiveContent "1. Identify the skill type (discipline, guidance, collaborative, or reference). 2. Determine the target behavior to change. 3. Select 2-3 matching persuasion principles. 4. Avoid over-combining principles. 5. Verify ethical legitimacy (does it serve the user's genuine interests if fully understood?)." ;
    oc:hasRationale "Provides a systematic approach to selecting and applying persuasion principles that are appropriate and ethical for the skill context." ;
    oc:stepOrder 1 .

oc:kn_d3052133 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing discipline-enforcing or any skill" ;
    oc:directiveContent "Never use Liking for compliance enforcement — it creates sycophancy and conflicts with honest feedback culture. Avoid Reciprocity in almost all cases as it feels manipulative." ;
    oc:hasRationale "Liking and Reciprocity undermine the agent's ability to give truthful, critical feedback and can lead to manipulative skill designs." ;
    oc:severityLevel "HIGH" .

oc:kn_d68ce3eb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing skill step instructions" ;
    oc:directiveContent "Use implementation intentions ('When X, do Y') rather than general directives ('generally do Y') to create automatic behavior triggers." ;
    oc:hasRationale "Clear trigger + required action pairs reduce cognitive load on compliance and produce more reliable execution than vague guidance." ;
    oc:severityLevel "MEDIUM" .

