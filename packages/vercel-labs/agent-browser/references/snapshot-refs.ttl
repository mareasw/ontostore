    oc:impartsKnowledge oc:kn_1ece8f33,
        oc:kn_9e16ce40,
        oc:kn_cf0416f9 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:BrowserRunning,
        oc:PageLoaded ;
    oc:resolvesIntent "get element references",
        "interact with page elements by ref",
        "navigate dynamic pages using refs",
        "reduce token usage for browser automation",
        "take page snapshot" ;
    oc:yieldsState oc:RefsAssigned,
        oc:SnapshotCaptured .

oc:kn_1ece8f33 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any ref-based interaction" ;
    oc:directiveContent "Never attempt to interact with refs (e.g., click @e1) without first running `agent-browser snapshot -i` on the current page." ;
    oc:hasRationale "Refs only exist after a snapshot is taken; they are not persistent across pages or sessions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9e16ce40 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every browser automation workflow" ;
    oc:directiveContent "1. Open/navigate to page → 2. Run `agent-browser snapshot -i` → 3. Identify target element ref → 4. Interact using ref (click/fill/type) → 5. Re-snapshot after any DOM change → Repeat from step 3" ;
    oc:stepOrder 1 .

oc:kn_cf0416f9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After any action that changes the DOM (click, navigate, submit)" ;
    oc:directiveContent "Refs are invalidated when the page changes — after any click, navigation, or dynamic content change, you MUST re-snapshot before using refs." ;
    oc:hasRationale "Using stale refs causes 'ref not found' errors because element IDs are reassigned on each snapshot." ;
    oc:severityLevel "CRITICAL" .

