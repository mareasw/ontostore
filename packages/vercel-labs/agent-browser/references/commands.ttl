oc:kn_0843b1fc a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard browser automation workflow" ;
    oc:directiveContent "1. Open URL → 2. Snapshot -i to discover interactive elements → 3. Interact using @refs from snapshot → 4. Wait for navigation/changes → 5. Snapshot again if page changed → 6. Extract data or repeat" ;
    oc:stepOrder 1 .

oc:kn_0937bb7c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Recording browser interactions as video" ;
    oc:directiveContent "1. record start ./demo.webm → 2. Perform actions → 3. record stop" ;
    oc:stepOrder 3 .

oc:kn_14eab5eb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When element refs are stale or unavailable" ;
    oc:directiveContent "Use semantic locators ('find' command) when @refs are unavailable or unreliable. Prefer find by role/label/placeholder/testid over text matching for stability." ;
    oc:hasRationale "Semantic locators are more resilient to page changes than positional or text-based selectors." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1f82fdf9 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When working with pages containing iframes" ;
    oc:directiveContent "For iframe interaction: iframes are auto-resolved in snapshots so refs inside iframes work directly. Use 'frame' command only when you need scoped snapshots within an iframe." ;
    oc:hasRationale "Direct ref usage is simpler; frame switching is only needed for scoped operations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_241aec27 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When entering text or pressing keys" ;
    oc:directiveContent "Use 'fill' to clear and type into an input, 'type' to append without clearing. For key combinations use 'press Control+a', for held keys use keydown/keyup pairs." ;
    oc:hasRationale "Correct command choice prevents unintended text duplication or missed keystrokes." ;
    oc:severityLevel "MEDIUM" .

oc:kn_76ae09b9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing JavaScript in the browser" ;
    oc:directiveContent "Never use raw eval for complex JavaScript. Use eval -b (base64 encoded) or eval --stdin to avoid shell escaping issues with nested quotes and special characters." ;
    oc:hasRationale "Shell escaping with nested quotes and special characters is error-prone and causes silent failures." ;
    oc:severityLevel "HIGH" .

oc:kn_7bad5144 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any page interaction" ;
    oc:directiveContent "Always use 'snapshot -i' to get interactive elements with @refs before interacting with a page. Use @refs from snapshot output for all click/fill/type interactions." ;
    oc:hasRationale "Snapshot -i gives the current element refs which change between page loads; stale refs from previous snapshots will fail." ;
    oc:severityLevel "HIGH" .

oc:kn_7c3916be a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When pages trigger JavaScript dialogs" ;
    oc:directiveContent "alert and beforeunload dialogs are auto-accepted by default. confirm and prompt dialogs require explicit handling with 'dialog accept/dismiss'." ;
    oc:hasRationale "Auto-accepting blocking dialogs prevents agent deadlocks; explicit handling ensures correct responses for confirm/prompt." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9b53b8d8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working with nested iframes" ;
    oc:directiveContent "Iframe nesting is resolved only one level deep. Iframes within iframes are not automatically expanded in snapshots." ;
    oc:hasRationale "Deep iframe nesting is rare and expensive to resolve; use frame command to drill into nested iframes manually." ;
    oc:severityLevel "LOW" .

oc:kn_a0c95e92 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When interactions fail or produce unexpected results" ;
    oc:directiveContent "Use --headed flag to show browser window for visual debugging. Use 'console' and 'errors' commands to check for page errors. Use 'highlight @ref' to visually locate elements." ;
    oc:hasRationale "Visual debugging reveals issues invisible in headless mode such as overlays, wrong elements, or rendering problems." ;
    oc:severityLevel "LOW" .

oc:kn_a35277ed a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Persisting authentication across sessions" ;
    oc:directiveContent "1. state save auth.json → 2. Perform login flow → 3. state save auth.json → 4. In future sessions: state load auth.json to restore auth" ;
    oc:stepOrder 2 .

oc:kn_b05b2689 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Typical web automation sequence" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """agent-browser open https://example.com
agent-browser snapshot -i
agent-browser fill @e2 "search query"
agent-browser click @e1
agent-browser wait --text "Results"
agent-browser get text @result1""" .

oc:kn_e0502c14 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Executing multiline JavaScript safely" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """cat <<'EOF' | agent-browser eval --stdin
const links = document.querySelectorAll('a');
Array.from(links).map(a => a.href);
EOF""" .

oc:kn_ea5f6bfa a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Using semantic locators instead of @refs" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """agent-browser find role button click --name "Submit"
agent-browser find text "Sign In" click
agent-browser find testid "submit-btn" click""" .

oc:kn_f2ed82a6 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any browser automation" ;
    oc:directiveContent "agent-browser must be installed (npx agent-browser or global install). A browser session must be open (via 'open' or 'connect') before running most commands." ;
    oc:hasRationale "Commands require an active browser instance to execute against." .

oc:kn_f8de6e6f a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Snapshot output format for interactive elements" ;
    oc:directiveContent """@e{N} [{role}] "{accessible name}"
# Example: @e3 [button] "Submit"
# Example: @e4 [textbox] "Email\"""" ;
    oc:templateVariables "N",
        "accessible name",
        "role" .

