oc:kn_3f4b8472 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "After any login form submission" ;
    oc:directiveContent "Verify login succeeded by checking the URL is the dashboard/protected page and not still on the login page after form submission." ;
    oc:hasRationale "Silent login failures propagate as confusing downstream errors" .

oc:kn_661c00d8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When target site requires two-factor authentication" ;
    oc:directiveContent "2FA flows require --headed mode and manual user intervention. Use wait --url with a long timeout (e.g., 120000ms) to accommodate the manual step." ;
    oc:hasRationale "2FA by design cannot be fully automated; the agent must wait for human completion" ;
    oc:severityLevel "HIGH" .

oc:kn_6d26ba97 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "Whenever saving or storing auth state files" ;
    oc:directiveContent "State files contain session tokens in plaintext. Add them to .gitignore, delete when no longer needed, and set AGENT_BROWSER_ENCRYPTION_KEY for encryption at rest." ;
    oc:hasRationale "Leaked state files grant full session access to anyone who obtains them" ;
    oc:severityLevel "CRITICAL" .

oc:kn_79428051 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After automation completes, especially in CI/CD environments" ;
    oc:directiveContent "Clean up auth artifacts after automation: clear cookies, delete state files, close browser sessions." ;
    oc:hasRationale "Residual auth state is an attack surface; cleanup limits exposure window" ;
    oc:severityLevel "MEDIUM" .

oc:kn_83660d90 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When using Chrome remote debugging to import auth" ;
    oc:directiveContent "--remote-debugging-port exposes full browser control on localhost. Any local process can connect and read cookies, execute JS. Only use on trusted machines and close Chrome when done." ;
    oc:hasRationale "Remote debugging port is an unauthenticated gateway to the browser" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c5f771b2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a session persistence strategy" ;
    oc:directiveContent "Use --profile for full browser state persistence (cookies, IndexedDB, service workers) or --session-name for lightweight cookie/localStorage persistence. Choose based on whether the site relies on advanced browser storage." ;
    oc:hasRationale "Matching persistence depth to site requirements avoids stale state and reduces storage overhead" .

oc:kn_c88c60c4 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When automating long-running sessions with expiring tokens" ;
    oc:directiveContent "For token refresh, load existing state, check if session is still valid by inspecting the URL, and fall back to fresh login if redirected to login page. Always re-save state after re-authentication." ;
    oc:hasRationale "Sessions expire unpredictably; defensive re-authentication prevents silent failures" .

oc:kn_d6f33642 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When target site has complex auth and manual browser login is feasible" ;
    oc:directiveContent "The fastest way to authenticate is to import cookies from an already-logged-in Chrome session using --auto-connect state save, bypassing complex OAuth/SSO/2FA flows entirely." ;
    oc:hasRationale "Reusing existing sessions avoids re-implementing multi-step auth flows" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e6bcd403 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling login forms in any automation flow" ;
    oc:directiveContent "Never hardcode credentials in automation scripts. Use environment variables for all usernames and passwords." ;
    oc:hasRationale "Hardcoded credentials leak via version control, logs, and process listings" ;
    oc:severityLevel "HIGH" .

