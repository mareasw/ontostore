                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Output Format" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The `--categories` flag accepts a comma-separated list of Chrome trace categories. Default categories include:" ],
