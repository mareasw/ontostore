    oc:requiresState oc:BrowserRunning,
        oc:NetworkAvailable ;
    oc:resolvesIntent "analyze browser performance traces",
        "capture performance profile",
        "diagnose slow page loads",
        "profile user interactions",
        "run CI performance regression checks" ;
    oc:yieldsState oc:FileCreated,
        oc:ProfileCaptured .

oc:kn_19993f0a a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When stopping the profiler via agent-browser profiler stop" ;
    oc:directiveContent "Data collection on stop has a 30-second timeout. If the browser is unresponsive, the stop command may fail." ;
    oc:hasRationale "An unresponsive browser cannot flush trace events, causing the stop command to timeout and potentially lose data." ;
    oc:severityLevel "MEDIUM" .

oc:kn_22aef49e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting a profiling session" ;
    oc:directiveContent "Only works with Chromium-based browsers (Chrome, Edge). Not supported on Firefox or WebKit." ;
    oc:hasRationale "The profiler relies on Chrome DevTools Protocol trace event APIs that are not available in non-Chromium browsers." ;
    oc:severityLevel "CRITICAL" .

oc:kn_29fbec4e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any profiling session" ;
    oc:directiveContent "Ensure the browser is running and responsive before starting the profiler, and plan the profiling window to cover only the specific interaction or page load of interest." ;
    oc:hasRationale "Narrow profiling windows produce more actionable traces and avoid hitting the event cap." ;
    oc:severityLevel "LOW" .

oc:kn_34ca47af a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When starting profiling for targeted analysis" ;
    oc:directiveContent "Use --categories flag to narrow trace scope to relevant categories (e.g., devtools.timeline, v8.execute, blink.user_timing) instead of capturing all events." ;
    oc:hasRationale "Targeted categories reduce trace volume and noise, making analysis more efficient and staying under the 5M event cap." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fab752e5 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "During active profiling sessions" ;
    oc:directiveContent "Trace data accumulates in memory while profiling is active, capped at 5 million events. Stop profiling promptly after the area of interest." ;
    oc:hasRationale "Unbounded memory accumulation can crash the browser or agent; the 5M event cap prevents runaway traces." ;
    oc:severityLevel "HIGH" .

_:ref_0ee17d4228e65338 a oc:WorkflowStep ;
    dcterms:description "Navigate to target URL and wait for network idle: agent-browser navigate <url> && agent-browser wait --load networkidle" ;
    oc:expectedOutcome "Page fully loaded" ;
    oc:stepDependsOn _:ref_3df088c9342b8ca5 ;
    oc:stepId "navigate-and-wait" .

_:ref_3df088c9342b8ca5 a oc:WorkflowStep ;
    dcterms:description "Start profiling: agent-browser profiler start" ;
    oc:expectedOutcome "Profiler is recording" ;
    oc:stepId "start-profiler" .

_:ref_8b215f704a229048 a oc:WorkflowStep ;
    dcterms:description "Start the profiler with optional custom categories: agent-browser profiler start [--categories ...]" ;
    oc:expectedOutcome "Profiler is recording trace events" ;
    oc:stepId "start-profiler" .

_:ref_bbe1312aed533cac a oc:WorkflowStep ;
    dcterms:description "Perform the browser actions to profile (navigate, click, wait, etc.)" ;
    oc:expectedOutcome "Actions are captured in the trace" ;
    oc:stepDependsOn _:ref_8b215f704a229048 ;
    oc:stepId "perform-actions" .

