                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The output is a JSON file in Chrome Trace Event format:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "The `metadata.clock-domain` field is set based on the host platform (Linux or macOS). On Windows it is omitted." ] ;
