oc:kn_14dddbbc a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Ensuring recordings are saved even on script failure or unexpected exit" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """cleanup() {
    agent-browser record stop 2>/dev/null || true
    agent-browser close 2>/dev/null || true
}
trap cleanup EXIT

agent-browser record start ./automation.webm""" .

oc:kn_6805f877 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Recording any browser automation session" ;
    oc:directiveContent "1. `agent-browser record start ./output.webm` 2. Perform browser actions (open, click, fill, etc.) 3. Add wait pauses between actions for clarity 4. `agent-browser record stop` to save" ;
    oc:hasRationale "Ensures recording covers the full automation lifecycle and is saved properly" ;
    oc:stepOrder 1 .

oc:kn_8c35ac08 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When recording extended automation sessions" ;
    oc:directiveContent "Large recordings can consume significant disk space. Long automation sessions should monitor available storage." ;
    oc:hasRationale "WebM compression is efficient but not unlimited; long recordings can fill disks especially in CI environments" ;
    oc:severityLevel "LOW" .

oc:kn_92a43d4e a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When naming recording output files" ;
    oc:directiveContent "Use descriptive filenames that include context: workflow name, date, and test identifier (e.g., `login-flow-2024-01-15.webm`, `checkout-test-run-42.webm`)" ;
    oc:hasRationale "Descriptive filenames make recordings searchable and identifiable without playing them" .

oc:kn_b3668239 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — recording format and performance constraints" ;
    oc:directiveContent "Default output format is WebM (VP8/VP9 codec). Some headless environments may have codec limitations. Recording adds slight overhead to automation." ;
    oc:hasRationale "Codec incompatibility can cause silent failures in CI; overhead may affect timing-sensitive tests" ;
    oc:severityLevel "MEDIUM" .

oc:kn_bd72f337 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Basic recording control commands" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """agent-browser record start ./output.webm
# ... actions ...
agent-browser record stop
agent-browser record restart ./take2.webm  # stops current + starts new""" .

oc:kn_deea2e0f a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On script error or unexpected termination during recording" ;
    oc:directiveContent "Use a shell trap on EXIT to ensure `agent-browser record stop` runs even when the script fails or is interrupted, preventing lost recordings" ;
    oc:hasRationale "Without a cleanup trap, recording data may be lost on crash, negating the debugging value" .

oc:kn_e2c27b04 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When recording for documentation or human review" ;
    oc:directiveContent "Insert `agent-browser wait 500` between actions to slow down for human viewing, making recordings useful as documentation" ;
    oc:hasRationale "Full-speed automation is too fast for human viewers to follow; pauses let viewers see each step's result" .

_:ref_8a787b5c7bb53c76 a oc:WorkflowStep ;
    dcterms:description "Start recording with descriptive filename: agent-browser record start ./output.webm" ;
    oc:expectedOutcome "Recording begins, file path is set" ;
    oc:stepId "start-recording" .

