oc:kn_07198b38 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring proxy in any environment" ;
    oc:directiveContent "Set NO_PROXY for local/internal domains (localhost, 127.0.0.1, .internal.com) and CDN domains to avoid unnecessary proxy overhead." ;
    oc:hasRationale "Routing local and CDN traffic through a proxy adds latency and load without benefit." ;
    oc:severityLevel "MEDIUM" .

oc:kn_446dd529 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring proxy authentication" ;
    oc:directiveContent "Proxy credentials should never be hardcoded in scripts; use environment variables (HTTP_PROXY, HTTPS_PROXY, ALL_PROXY) instead." ;
    oc:hasRationale "Hardcoded credentials leak into version control and logs, creating security vulnerabilities." ;
    oc:severityLevel "HIGH" .

oc:kn_6ab89e4b a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When proxy connection fails or behaves unexpectedly" ;
    oc:directiveContent "Test proxy connectivity with 'curl -x <proxy-url> https://httpbin.org/ip' before running browser automation, and verify apparent IP with 'agent-browser open https://httpbin.org/ip'." ;
    oc:hasRationale "Pre-flight validation isolates proxy issues from browser automation issues." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a0cd73f2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing large-scale scraping via proxy" ;
    oc:directiveContent "Rotate proxies across requests and add polite delays (sleep) when scraping at scale to avoid rate limiting and IP bans." ;
    oc:hasRationale "Single-proxy scraping triggers rate limits and bans; rotation distributes load." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d2355c6a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running any proxied browser automation" ;
    oc:directiveContent "Verify proxy is reachable and credentials are correct by making a simple request through the proxy before launching any automation session." ;
    oc:hasRationale "Catches proxy misconfiguration early before wasting automation time." ;
    oc:severityLevel "HIGH" .

oc:kn_ffc3acdb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering SSL certificate errors through a proxy" ;
    oc:directiveContent "Do not use --ignore-https-errors in production environments to bypass SSL/TLS errors caused by proxy SSL inspection." ;
    oc:hasRationale "Disabling HTTPS errors disables certificate validation entirely, enabling man-in-the-middle attacks." ;
    oc:severityLevel "CRITICAL" .

