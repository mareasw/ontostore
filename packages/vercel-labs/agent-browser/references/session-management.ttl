@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_agent_browser_session_management a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "session-management" ;
    skos:broader "browser session management pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/agent-browser" ;
    oc:contentHash "2ce531bf105aaf827a907a4e255e00321eef5994ca0e21e41c28489c0a8efebb" ;
    oc:differentia "enables multiple isolated browser sessions with independent cookies, storage, and state persistence via named sessions using the --session flag" ;
    oc:extends oc:skill_vercel_labs_agent_browser ;
    oc:handlesFailure oc:PermissionDenied,
        oc:SessionNotFound,
        oc:StateFileInvalid ;
    oc:hasAllowedTool "Bash" ;
    oc:hasArgumentHint "--session <name> <command> [args]" ;
    oc:hasCategory "automation" ;
    oc:hasRequirement oc:req_33dc207f,
        oc:req_f09a609f ;
    oc:impartsKnowledge oc:kn_182451e8,
        oc:kn_8f55e58c,
        oc:kn_9239086b,
        oc:kn_c379be2a,
        oc:kn_db8ebc38,
        oc:kn_f05f1a9d ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ToolInstalled ;
    oc:resolvesIntent "isolate browser contexts",
        "manage browser sessions",
        "persist authentication state across sessions",
        "reuse authenticated sessions",
        "run concurrent browsing sessions" ;
    oc:yieldsState oc:SessionCreated,
        oc:SessionStatePersisted .

oc:kn_182451e8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running session commands in unattended or automated scripts" ;
    oc:directiveContent "Use 'timeout' command to wrap long-running session commands to prevent hanging in automated scripts, e.g., 'timeout 60 agent-browser --session <name> get text body'." ;
    oc:hasRationale "Browser sessions can hang on slow or unresponsive pages; timeouts ensure scripts terminate gracefully rather than blocking indefinitely." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8f55e58c a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When persisting and restoring session state" ;
    oc:directiveContent "Session state save/load operations can be used idempotently — loading state multiple times restores the same session, and saving overwrites the previous snapshot." ;
    oc:hasRationale "Enables safe retry patterns for authentication flows where the saved state can be reloaded if a session expires or is interrupted." ;
    oc:severityLevel "LOW" .

oc:kn_9239086b a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When saving or loading session state files" ;
    oc:directiveContent "State files contain auth tokens and cookies — never commit them to version control. Add '*.auth-state.json' to .gitignore and delete state files after use." ;
    oc:hasRationale "State files persist sensitive authentication data (cookies, localStorage, sessionStorage) that could be exploited if leaked into version control or shared systems." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c379be2a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing multi-session workflows like concurrent scraping or A/B testing" ;
    oc:directiveContent "Each named session has fully independent cookies, localStorage, sessionStorage, IndexedDB, cache, browsing history, and open tabs — sessions never interfere with each other." ;
    oc:hasRationale "Full isolation guarantees that concurrent sessions can represent different users or browsing contexts without cross-contamination of state." ;
    oc:severityLevel "HIGH" .

oc:kn_db8ebc38 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating named sessions with --session flag" ;
    oc:directiveContent "Use semantically meaningful session names (e.g., 'github-auth', 'docs-scrape') rather than generic names (e.g., 's1', 's2') to keep sessions identifiable and maintainable." ;
    oc:hasRationale "Semantic naming improves debugging, log readability, and prevents session confusion in scripts with multiple concurrent sessions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f05f1a9d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "After completing work in any named session" ;
    oc:directiveContent "Always close sessions with 'agent-browser --session <name> close' when done to free resources." ;
    oc:hasRationale "Unclosed sessions leak browser resources (memory, processes) and can cause issues in long-running automation scripts." ;
    oc:severityLevel "HIGH" .

oc:req_33dc207f a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "agent-browser CLI" .

oc:req_f09a609f a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "browser session isolation concepts" .

