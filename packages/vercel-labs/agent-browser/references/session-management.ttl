oc:kn_32966d45 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When saving browser state to disk" ;
    oc:directiveContent "Never commit state files to version control — they contain auth tokens, cookies, and session data." ;
    oc:hasRationale "State files expose authentication credentials and sensitive session data." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3eac7bae a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating named sessions" ;
    oc:directiveContent "Name sessions semantically (e.g., github-auth, docs-scrape) rather than generically (s1, s2) to clarify purpose and avoid confusion." ;
    oc:hasRationale "Semantic naming makes multi-session workflows debuggable and maintainable." ;
    oc:severityLevel "MEDIUM" .

oc:kn_72af3388 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When running sessions in automated/CI environments" ;
    oc:directiveContent "Use timeout command to wrap long-running session commands to prevent hanging automated scripts." ;
    oc:hasRationale "Browser sessions can hang on slow loads or infinite waits; timeouts ensure scripts terminate." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7daa8f50 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After completing any session-based workflow" ;
    oc:directiveContent "Always close sessions when done and delete temporary state files after use to prevent resource leaks and credential exposure." ;
    oc:hasRationale "Unclosed sessions consume resources; lingering state files are a security risk." ;
    oc:severityLevel "HIGH" .

oc:kn_d3c4955f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running concurrent sessions or managing multiple contexts" ;
    oc:directiveContent "Each session is fully isolated: independent cookies, localStorage, sessionStorage, IndexedDB, cache, browsing history, and open tabs." ;
    oc:hasRationale "Isolation ensures sessions don't interfere with each other's authentication or state." ;
    oc:severityLevel "HIGH" .

oc:kn_deb683fa a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When handling saved session state" ;
    oc:directiveContent "State files (auth-state.json) contain cookies, localStorage, sessionStorage, and origin data — treat them as secrets." ;
    oc:hasRationale "State files can be used to impersonate authenticated sessions if leaked." ;
    oc:severityLevel "CRITICAL" .

