oc:kn_1f23d3dc a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every browser automation task follows this open→snapshot→interact→re-snapshot cycle" ;
    oc:directiveContent "1. agent-browser open <url> — 2. agent-browser snapshot -i — 3. Interact using @refs (click, fill, select) — 4. agent-browser wait --load networkidle — 5. agent-browser snapshot -i (re-snapshot to get fresh refs)" ;
    oc:stepOrder 1 .

oc:kn_cf143a62 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "After any action that changes the DOM (click navigation, form submit, dropdown open, modal appear)" ;
    oc:directiveContent "Never use stale refs after page navigation, form submission, or dynamic content loading. Always re-snapshot to get fresh refs before interacting." ;
    oc:hasRationale "Refs (@e1, @e2, etc.) are invalidated when the page changes. Using stale refs causes 'ref not found' errors and incorrect interactions." ;
    oc:severityLevel "CRITICAL" .

