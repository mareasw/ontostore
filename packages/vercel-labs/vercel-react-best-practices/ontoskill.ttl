        "reduce unnecessary React re-renders",
        "refactor React code using best practices",
        "review React/Next.js code for performance issues",
        "write performant Next.js pages and components" ;
    oc:yieldsState oc:CodeOptimized,
        oc:PerformanceRulesApplied .

oc:kn_0e477374 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating state based on current state value" ;
    oc:directiveContent "Use functional setState (setItems(curr => [...curr, item])) instead of direct state references in callbacks. This prevents stale closures and eliminates unnecessary useCallback dependencies." ;
    oc:hasRationale "Functional updates create stable callback references, prevent stale closure bugs, and simplify dependency arrays." ;
    oc:severityLevel "MEDIUM" .

oc:kn_530e2ff0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which performance optimizations to apply first" ;
    oc:directiveContent "Prioritize performance rules by category: 1) Eliminating Waterfalls (CRITICAL), 2) Bundle Size (CRITICAL), 3) Server-Side (HIGH), 4) Client-Side Data Fetching (MEDIUM-HIGH), 5) Re-render (MEDIUM), 6) Rendering (MEDIUM), 7) JavaScript (LOW-MEDIUM), 8) Advanced (LOW)." ;
    oc:hasRationale "Waterfalls and bundle size have the largest measurable impact on user-perceived performance." ;
    oc:severityLevel "HIGH" .

oc:kn_5411a104 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing React components" ;
    oc:directiveContent "Never define components inside other components. This creates a new component type on every render, causing full remount, state destruction, and DOM recreation. Always pass props to externally defined components instead." ;
    oc:hasRationale "Inline component definitions cause input fields to lose focus, animations to restart, and effects to re-run on every parent render." ;
    oc:severityLevel "HIGH" .

oc:kn_58f5788f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When importing libraries or structuring component loading" ;
    oc:directiveContent "Reduce initial bundle size by avoiding barrel file imports, using next/dynamic for heavy components, deferring non-critical third-party libraries after hydration, and loading modules only when features are activated." ;
    oc:hasRationale "Reducing bundle size directly improves Time to Interactive and Largest Contentful Paint." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5bb5efa8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When implementing server-side data fetching in React Server Components" ;
    oc:directiveContent "Use React.cache() for per-request deduplication of DB queries and auth checks (not fetch, which Next.js auto-deduplicates). Use LRU cache for cross-request caching. Avoid inline objects as React.cache() arguments — use same reference for cache hits." ;
    oc:hasRationale "React.cache() uses shallow equality (Object.is). Inline objects create new references each call, preventing cache hits." ;
    oc:severityLevel "MEDIUM" .

oc:kn_794e7553 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When writing Next.js Server Actions with 'use server'" ;
    oc:directiveContent "Always authenticate and authorize inside each Server Action — never rely solely on middleware or layout guards. Server Actions are public endpoints that can be invoked directly." ;
    oc:hasRationale "Next.js docs state: treat Server Actions with same security considerations as public-facing API endpoints." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9b67c6a1 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When sorting arrays in React components" ;
    oc:directiveContent "Use .toSorted() instead of .sort() in React components. .sort() mutates arrays in place, breaking React's immutability model and causing stale closure bugs with props and state." ;
    oc:hasRationale "React expects props and state to be treated as read-only. Mutation breaks change detection and can cause subtle bugs." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a0c10a4a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing React Server Components or SSR code" ;
    oc:directiveContent "Never use mutable module-level variables to share request-scoped data in RSC/SSR. Server renders can run concurrently in the same process, causing race conditions and cross-request data leaks." ;
    oc:hasRationale "Concurrent renders sharing mutable module state can expose one user's data in another user's response." ;
    oc:severityLevel "HIGH" .

oc:kn_ab0afd2b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any async data fetching in React/Next.js" ;
    oc:directiveContent "Async waterfalls are the #1 performance killer. Always use Promise.all() for independent operations, defer await to branches where values are actually used, and start promises early then await late." ;
    oc:hasRationale "Each sequential await adds full network latency. Eliminating waterfalls yields 2-10x improvement." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d6a76419 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When passing props from Server Components to Client Components" ;
    oc:directiveContent "Minimize data passed across RSC→client boundaries. Only pass fields the client actually uses, not entire objects. RSC serialization embeds all properties in the HTML response." ;
    oc:hasRationale "Serialized data directly impacts page weight and load time. Passing 50 fields when 1 is used wastes bandwidth." ;
    oc:severityLevel "HIGH" .

oc:kn_f8e20b28 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing React component state" ;
    oc:directiveContent "Do not store derived state in useState when it can be computed from existing props/state during render. Do not set state in effects solely in response to prop changes." ;
    oc:hasRationale "Storing derived state causes redundant renders and state drift between the source and derived values." ;
    oc:severityLevel "MEDIUM" .

oc:req_9ad95a47 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "React and Next.js framework fundamentals" .

oc:req_c9a0e80f a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "React Server Components architecture" .

oc:req_e9575845 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "TypeScript/JavaScript async patterns" .

