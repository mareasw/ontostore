                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "`js-length-check-first` - Check array length before expensive comparison" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 8 ;
                                            oc:itemText "`js-early-exit` - Return early from functions" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 11 ;
                                            oc:itemText "`js-set-map-lookups` - Use Set/Map for O(1) lookups" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 14 ;
                                            oc:itemText "`js-request-idle-callback` - Defer non-critical work to browser idle time" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 9 ;
                                            oc:itemText "`js-hoist-regexp` - Hoist RegExp creation outside loops" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 12 ;
                                            oc:itemText "`js-tosorted-immutable` - Use toSorted() for immutability" ],
