                                            oc:itemText "`rendering-script-defer-async` - Use defer or async on script tags" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "`rendering-hydration-suppress-warning` - Suppress expected mismatches" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 10 ;
                                            oc:itemText "`rendering-resource-hints` - Use React DOM resource hints for preloading" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "`rendering-hoist-jsx` - Extract static JSX outside components" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "`rendering-svg-precision` - Reduce SVG coordinate precision" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "`rendering-activity` - Use Activity component for show/hide" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "`rendering-content-visibility` - Use content-visibility for long lists" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 9 ;
                                            oc:itemText "`rendering-usetransition-loading` - Prefer useTransition for loading state" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`rendering-animate-svg-wrapper` - Animate div wrapper, not SVG element" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 8 ;
                                            oc:itemText "`rendering-conditional-render` - Use ternary, not && for conditionals" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "`rendering-hydration-no-flicker` - Use inline script for client-only data" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "6. Rendering Performance (MEDIUM)" ],
                        [ a oc:Section ;
