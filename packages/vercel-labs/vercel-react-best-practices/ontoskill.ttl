                                            oc:itemOrder 10 ;
                                            oc:itemText "`js-min-max-loop` - Use loop for min/max instead of sort" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
