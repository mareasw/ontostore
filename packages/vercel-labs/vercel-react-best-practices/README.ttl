oc:kn_2d5c5389 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating or naming any new rule file" ;
    oc:directiveContent "Rule files must use area prefixes (async-, bundle-, server-, client-, rerender-, rendering-, js-, advanced-) mapped to one of 8 sections. Section and ID are auto-inferred from the filename prefix." ;
    oc:hasRationale "Ensures consistent organization and automatic section assignment without manual ID management" ;
    oc:severityLevel "HIGH" .

oc:kn_85e56cc0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing files in the rules/ directory" ;
    oc:directiveContent "Files starting with _ are special files (like _sections.md, _template.md) and are excluded from the build output." ;
    oc:hasRationale "Prevents template and metadata files from being compiled as actual rules" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a188f9c5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing rule content" ;
    oc:directiveContent "Each rule must include clear incorrect (bad) and correct (good) code examples with explanations, plus a reference link when applicable." ;
    oc:hasRationale "Concrete before/after examples make rules actionable and verifiable for both humans and LLMs" ;
    oc:severityLevel "HIGH" .

oc:kn_b43817ef a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring rule files" ;
    oc:directiveContent "Do not manually manage rule IDs or numbering. IDs (e.g., 1.1, 1.2) are auto-generated during build and rules are sorted alphabetically by title within each section." ;
    oc:hasRationale "Manual IDs cause conflicts and merge issues; alphabetical sorting by title eliminates the need for manual ordering" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fbb7958a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before and after modifying rule files" ;
    oc:directiveContent "Run pnpm validate to check all rule files before building, and run pnpm build after any rule changes to regenerate AGENTS.md and test-cases.json." ;
    oc:hasRationale "Validation catches structural errors; build regenerates the compiled outputs that consumers depend on" ;
    oc:severityLevel "HIGH" .

