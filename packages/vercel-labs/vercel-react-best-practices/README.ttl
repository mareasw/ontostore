oc:skill_vercel_labs_vercel_react_best_practices_readme a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "readme" ;
    skos:broader "Best practices framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "9eafb2123d3b8b2aef41fba0db2648a3f4f49996f8c7c8bb2c86263befd8b48a" ;
    oc:differentia "provides a structured, rule-based repository for creating and maintaining React performance optimization guidelines optimized for LLM consumption, with automated build, validation, and test extraction workflows" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "action (build|validate|extract-tests|dev) or rule-file-path" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_5080db2f,
        oc:kn_54b88997,
        oc:kn_8e9e7e46,
        oc:kn_ada69573,
        oc:kn_f47c6c42 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DirectoryWritable,
        oc:EnvironmentReady ;
    oc:resolvesIntent "build and validate react optimization rules",
        "create new performance rules",
        "navigate the rules repository",
        "understand react best practices structure" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_5080db2f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating or modifying rule files in the rules/ directory" ;
    oc:directiveContent "Rule files must follow the naming convention with area prefixes: async-, bundle-, server-, client-, rerender-, rendering-, js-, advanced- to be correctly categorized into sections during build." ;
    oc:hasRationale "Section assignment is automatically inferred from the filename prefix, so incorrect prefixes cause rules to land in wrong sections" ;
    oc:severityLevel "HIGH" .

oc:kn_54b88997 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring new rule content" ;
    oc:directiveContent "Each rule must include clear incorrect (bad) and correct (good) TypeScript code examples with explanations, following the template structure with frontmatter (title, impact, tags)." ;
    oc:hasRationale "Bad/good example pairs with explanations make rules actionable and evaluable by LLMs, enabling automated test case extraction" ;
    oc:severityLevel "HIGH" .

oc:kn_8e9e7e46 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting the impact frontmatter field in a rule file" ;
    oc:directiveContent "Use the impact levels CRITICAL > HIGH > MEDIUM-HIGH > MEDIUM > LOW-MEDIUM > LOW to communicate the relative performance significance of each rule." ;
    oc:hasRationale "Impact levels help agents prioritize which rules to apply first when optimizing React applications" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ada69573 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "After any change to files in rules/" ;
    oc:directiveContent "After creating or modifying any rule, always run pnpm build to regenerate AGENTS.md and test-cases.json before considering the work complete." ;
    oc:hasRationale "AGENTS.md is the compiled output consumed by agents; without rebuilding, changes remain invisible to consumers" ;
    oc:severityLevel "CRITICAL" .

oc:kn_f47c6c42 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming files in the rules/ directory" ;
    oc:directiveContent "Files starting with underscore (_) are special files and excluded from the build output. Never name a rule file with an underscore prefix." ;
    oc:hasRationale "The build system filters out _-prefixed files to exclude templates and metadata from compiled output" ;
    oc:severityLevel "MEDIUM" .

