oc:skill_vercel_labs_vercel_react_best_practices_js_index_maps a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "js-index-maps" ;
    skos:broader "Performance optimization technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "5df1bdc2cfabb2c98abd55d26762e5c18189535c2e686184f426082e62920391" ;
    oc:differentia "replaces repeated O(n) lookups with O(1) Map-based index lookups in JavaScript" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "array data with repeated lookups by key" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Multiple `.find()` calls by the same key should use a Map." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Correct (O(1) per lookup):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function processOrders(orders: Order[], users: User[]) {
  return orders.map(order => ({
    ...order,
    user: users.find(u => u.id === order.userId)
  }))
}
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-21" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Incorrect (O(n) per lookup):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function processOrders(orders: Order[], users: User[]) {
  const userById = new Map(users.map(u => [u.id, u]))

  return orders.map(order => ({
    ...order,
    user: userById.get(order.userId)
  }))
}
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 25-34" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent """Build map once (O(n)), then all lookups are O(1).
For 1000 orders × 1000 users: 1M ops → 2K ops.""" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Build Index Maps for Repeated Lookups" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Build Index Maps for Repeated Lookups
impact: LOW-MEDIUM
impactDescription: 1M ops to 2K ops
tags: javascript, map, indexing, optimization, performance
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:impartsKnowledge oc:kn_41072a0a,
        oc:kn_5ee80633,
        oc:kn_aa9b7a07,
        oc:kn_e51484be,
        oc:kn_ea975c2c ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "build index maps from arrays",
        "optimize repeated array lookups",
        "reduce time complexity of find operations" .

oc:kn_41072a0a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing arrays that require cross-referencing by ID or key" ;
    oc:directiveContent "Never use Array.find() inside a loop or .map() when looking up by the same key repeatedly — this creates O(n²) complexity." ;
    oc:hasRationale "Each .find() is O(n), so nested inside an O(n) loop the total becomes O(n×m), which scales poorly" ;
    oc:severityLevel "HIGH" .

oc:kn_5ee80633 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating whether to optimize array lookups" ;
    oc:directiveContent "If you call .find() more than once by the same key across iterations, build a Map instead." ;
    oc:hasRationale "The crossover point is very low — even 2+ lookups benefit from indexing" .

oc:kn_aa9b7a07 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing data processing pipelines" ;
    oc:directiveContent "Pre-compute index structures once, then use constant-time lookups. Separate the indexing phase from the lookup phase." ;
    oc:hasRationale "This single-pass indexing pattern is fundamental to efficient data transformation" .

oc:kn_e51484be a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When estimating performance impact of index map conversion" ;
    oc:directiveContent "Building a Map from an array of n items is O(n). Each subsequent Map.get() lookup is O(1). For 1000 orders × 1000 users: reduces from 1M operations to 2K operations." ;
    oc:hasRationale "The cost of building the map is amortized across all subsequent O(1) lookups" .

oc:kn_ea975c2c a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building an index for repeated lookups from an array" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent "const lookupMap = new Map(array.map(item => [item.key, item])); // O(1) lookups via lookupMap.get(key)" ;
    oc:hasRationale "Map construction is O(n) once, then every .get() is O(1), reducing total from O(n×m) to O(n+m)" .

