oc:skill_vercel_labs_vercel_react_best_practices_bundle_preload a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "bundle-preload" ;
    skos:broader "Performance optimization technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "d1f7cc28da7cd5ab249acd287edc5b761afcfb194e9cb62cd44c5f3543db2de2" ;
    oc:differentia "preloads heavy JavaScript bundles based on user intent signals (hover, focus, feature flags) before they are needed" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:ImportFailed ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Preload heavy bundles before they're needed to reduce perceived latency." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Example (preload when feature flag is enabled):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Example (preload on hover/focus):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function EditorButton({ onClick }: { onClick: () => void }) {
  const preload = () => {
    if (typeof window !== 'undefined') {
      void import('./monaco-editor')
    }
  }

  return (
    <button
      onMouseEnter={preload}
      onFocus={preload}
      onClick={onClick}
    >
      Open Editor
    </button>
  )
}
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-32" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent "The `typeof window !== 'undefined'` check prevents bundling preloaded modules for SSR, optimizing server bundle size and build speed." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function FlagsProvider({ children, flags }: Props) {
  useEffect(() => {
    if (flags.editorEnabled && typeof window !== 'undefined') {
      void import('./monaco-editor').then(mod => mod.init())
    }
  }, [flags.editorEnabled])

  return <FlagsContext.Provider value={flags}>
    {children}
  </FlagsContext.Provider>
}
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 36-48" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Preload Based on User Intent" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Preload Based on User Intent
impact: MEDIUM
impactDescription: reduces perceived latency
tags: bundle, preload, user-intent, hover
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:impartsKnowledge oc:kn_41fc216a,
        oc:kn_6aa176e2,
        oc:kn_87ce0396,
        oc:kn_a93bfad7,
        oc:kn_b2ef3aa7 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "optimize bundle loading strategy",
        "preload bundles on user interaction",
        "reduce perceived latency" ;
    oc:yieldsState oc:BundlesPreloaded .

oc:kn_41fc216a a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When using void import() for preloading" ;
    oc:directiveContent "void import() triggers a network fetch and module evaluation as a side effect; the discarded promise means no value is consumed." ;
    oc:hasRationale "Agents must understand this is intentional — the import is purely for cache warming, not for using the module's exports." .

oc:kn_6aa176e2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing preload logic in isomorphic/universal React components" ;
    oc:directiveContent "Never preload modules without a typeof window !== 'undefined' guard — SSR builds will include preloaded modules in the server bundle, increasing bundle size and build time." ;
    oc:hasRationale "Without the guard, the dynamic import executes during server rendering, bloating the server bundle with client-only dependencies like Monaco Editor." ;
    oc:severityLevel "HIGH" .

oc:kn_87ce0396 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing perceived latency for heavy client-side modules" ;
    oc:directiveContent "Preload heavy bundles based on user intent signals such as hover, focus, or feature flags rather than loading everything eagerly or waiting until navigation." ;
    oc:hasRationale "Intent-based preloading reduces perceived latency by starting fetches before the user explicitly requests the feature, without penalizing initial page load." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a93bfad7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which DOM events to use for preloading" ;
    oc:directiveContent "Use onMouseEnter and onFocus as preload triggers — they fire 200-500ms before a click, giving the bundle time to load." ;
    oc:hasRationale "Hover and focus events provide a reliable time window to preload before the user's click action actually needs the module." .

oc:kn_b2ef3aa7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before adding any dynamic import-based preloading in React components" ;
    oc:directiveContent "Always guard preload logic with typeof window !== 'undefined' to prevent SSR bundle contamination." ;
    oc:severityLevel "HIGH" .

