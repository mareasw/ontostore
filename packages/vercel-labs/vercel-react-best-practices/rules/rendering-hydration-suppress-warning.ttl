oc:skill_vercel_labs_vercel_react_best_practices_rendering_hydration_suppress_warning a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rendering-hydration-suppress-warning" ;
    skos:broader "Rendering technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "915bacb934e2927d84b37a3f3d225a47b309ac8f9e494ed2bcb66ce07c5676a2" ;
    oc:differentia "that suppresses expected hydration mismatch warnings in SSR frameworks without hiding real bugs" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function Timestamp() {
  return <span>{new Date().toLocaleString()}</span>
}
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-18" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Incorrect (known mismatch warnings):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "In SSR frameworks (e.g., Next.js), some values are intentionally different on server vs client (random IDs, dates, locale/timezone formatting). For these *expected* mismatches, wrap the dynamic text in an element with `suppressHydrationWarning` to prevent noisy warnings. Do not use this to hide real bugs. Don’t overuse it." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function Timestamp() {
  return (
    <span suppressHydrationWarning>
      {new Date().toLocaleString()}
    </span>
  )
}
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 22-30" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Correct (suppress expected mismatch only):**" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Suppress Expected Hydration Mismatches" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Suppress Expected Hydration Mismatches
impact: LOW-MEDIUM
impactDescription: avoids noisy hydration warnings for known differences
tags: rendering, hydration, ssr, nextjs
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:impartsKnowledge oc:kn_0f7a7cb3,
        oc:kn_46ac470f,
        oc:kn_95fbce08,
        oc:kn_aab6e52d,
        oc:kn_cff1d8db ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "fix ssr hydration mismatch",
        "handle server client differences in nextjs",
        "suppress hydration warnings" .

oc:kn_0f7a7cb3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When rendering dynamic content that differs between SSR and client in Next.js or other SSR frameworks" ;
    oc:directiveContent "Use suppressHydrationWarning only on elements containing values that are intentionally different between server and client (random IDs, dates, locale/timezone formatting)." ;
    oc:hasRationale "Expected mismatches like timestamps and random IDs are unavoidable and produce noisy warnings that obscure real issues." ;
    oc:severityLevel "MEDIUM" .

oc:kn_46ac470f a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When building SSR/SSG pages with dynamic time or locale-dependent content" ;
    oc:directiveContent "SSR frameworks produce hydration mismatch warnings when server-rendered HTML contains values that differ on the client (e.g., Date.now(), Math.random(), Intl formatting)." ;
    oc:hasRationale "These mismatches are inherent to SSR and expected — they are not bugs but generate console noise that can mask real problems." ;
    oc:severityLevel "LOW" .

oc:kn_95fbce08 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When applying suppressHydrationWarning to elements" ;
    oc:directiveContent "suppressHydrationWarning only suppresses warnings for the text content of the element it is placed on, not its children or attributes." ;
    oc:hasRationale "Understanding the scope of suppression prevents accidental hiding of deeper hydration mismatches in child components." ;
    oc:severityLevel "MEDIUM" .

oc:kn_aab6e52d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering date/time, locale-formatted values, or random IDs in SSR components" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent "<span suppressHydrationWarning>{new Date().toLocaleString()}</span>" .

oc:kn_cff1d8db a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When considering suppressHydrationWarning usage" ;
    oc:directiveContent "Do not use suppressHydrationWarning to hide real bugs or overuse it across components." ;
    oc:hasRationale "Suppressing warnings indiscriminately masks genuine hydration errors that indicate broken SSR/CSR consistency, making real bugs harder to detect." ;
    oc:severityLevel "HIGH" .

