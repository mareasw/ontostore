@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_rendering_hydration_suppress_warning a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rendering-hydration-suppress-warning" ;
    skos:broader "Hydration mismatch handling technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "915bacb934e2927d84b37a3f3d225a47b309ac8f9e494ed2bcb66ce07c5676a2" ;
    oc:differentia "uses React's suppressHydrationWarning to silence expected SSR/client rendering differences without masking real bugs" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "component with dynamic SSR/client content" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_2d6194dc,
        oc:kn_37b4b20b,
        oc:kn_535964db,
        oc:kn_cac02fd5 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "fix noisy hydration mismatch warnings in Next.js",
        "handle expected SSR/client mismatches",
        "suppress hydration warnings" ;
    oc:yieldsState oc:HydrationWarningSuppressed .

oc:kn_2d6194dc a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding suppressHydrationWarning to components" ;
    oc:directiveContent "Do not overuse suppressHydrationWarning — apply it only to specific elements with known dynamic content." ;
    oc:hasRationale "Over-suppression defeats the purpose of hydration warnings as a debugging tool and can hide regressions." ;
    oc:severityLevel "HIGH" .

oc:kn_37b4b20b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When placing suppressHydrationWarning on elements" ;
    oc:directiveContent "suppressHydrationWarning only needs to be applied to the innermost element containing the dynamic text, not to parent wrappers." ;
    oc:hasRationale "Scoping suppression to the minimal element reduces the risk of hiding unrelated hydration issues in child components." ;
    oc:severityLevel "MEDIUM" .

oc:kn_535964db a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering values that are known to differ between server and client in SSR frameworks like Next.js" ;
    oc:directiveContent "Wrap intentionally dynamic values (random IDs, dates, locale/timezone formatting) in an element with suppressHydrationWarning to silence expected SSR/client mismatches." ;
    oc:hasRationale "Expected mismatches are benign and produce noisy console warnings that obscure real issues." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cac02fd5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When considering adding suppressHydrationWarning to any component" ;
    oc:directiveContent "Never use suppressHydrationWarning to hide real bugs or actual unintentional rendering mismatches." ;
    oc:hasRationale "Suppressing real hydration bugs masks underlying logic errors and can lead to broken UI states that go undetected." ;
    oc:severityLevel "CRITICAL" .

