oc:kn_2a5cacfc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing loop-based validation or search functions." ;
    oc:directiveContent "Avoid accumulating error state with boolean flags and string messages across loop iterations when you can return immediately on the first error." ;
    oc:hasRationale "Flag-based accumulation requires tracking mutable state across iterations, increasing complexity and the chance of bugs (e.g., overwriting error messages)." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3b12c5bb a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing validation, search, or any function where a definitive answer can be determined before examining all inputs." ;
    oc:directiveContent "Return early from functions when the result is already determined, rather than accumulating state and processing remaining items." ;
    oc:hasRationale "Early return avoids unnecessary computation, reduces cognitive load by eliminating mutable accumulator variables, and makes the control flow easier to reason about." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6c95532d a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When processing arrays or iterables where the answer can be determined at any point." ;
    oc:directiveContent "Early exit can convert O(n) worst-case operations to O(k) where k is the position of the first matching element, providing significant speedup for large collections." ;
    oc:hasRationale "Skipping unnecessary iterations directly reduces CPU cycles spent on work whose results would be discarded." ;
    oc:severityLevel "LOW" .

oc:kn_9ff5d1f1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring function control flow in JavaScript/TypeScript." ;
    oc:directiveContent "Prefer guard clauses and early returns over deeply nested conditional logic." ;
    oc:hasRationale "Flattening control flow with early returns makes code more readable and maintainable by reducing nesting depth and making the happy path clearly visible at the bottom." ;
    oc:severityLevel "LOW" .

oc:req_3a2a55fb a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "JavaScript/TypeScript function syntax" .

