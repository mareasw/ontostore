oc:skill_vercel_labs_vercel_react_best_practices_js_early_exit a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "js-early-exit" ;
    skos:broader "Code optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "925ce5ce87f3347186ca62212f29cc6baa2b8c85a96d2720ad07c3d0abf781c0" ;
    oc:dependsOnSkill oc:skill_vercel_react_best_practices ;
    oc:differentia "that returns early from functions when the result is determined, avoiding unnecessary computation" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "function code to refactor" ;
