oc:kn_01e0917c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring event handlers that mix immediate UI feedback with async data loading" ;
    oc:directiveContent "Keep urgent updates (like input value changes) outside startTransition, and wrap non-urgent updates (like data fetching and result rendering) inside startTransition." ;
    oc:hasRationale "This separation ensures the input remains responsive while heavy updates are deferred, providing better perceived performance." .

oc:kn_54287f7f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing loading/pending states for async operations in React components" ;
    oc:directiveContent "Never use manual useState for loading states (isLoading/setIsLoading) when useTransition is available — it introduces error-prone boolean toggling and fails to reset correctly on errors." ;
    oc:hasRationale "Manual loading state management is error-prone: forgetting to reset on error, race conditions on rapid interactions, and unnecessary re-renders." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d474d461 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When replacing manual loading states with useTransition for async data fetching" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """const [isPending, startTransition] = useTransition()

startTransition(async () => {
  const data = await fetchResults(value)
  setResults(data)
})""" .

oc:kn_dbb15221 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When users trigger multiple rapid transitions (e.g., typing in search)" ;
    oc:directiveContent "New transitions automatically cancel pending ones — rapid user interactions will not cause stale results to overwrite newer ones." ;
    oc:hasRationale "Automatic interrupt handling eliminates race conditions common with manual loading state patterns." .

oc:kn_f915964a a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a transition or async operation fails" ;
    oc:directiveContent "useTransition's isPending state automatically resets even if the transition throws an error, unlike manual setIsLoading(false) which must be in a finally block." ;
    oc:hasRationale "Error resilience prevents the UI from being stuck in a loading state when exceptions occur." .

