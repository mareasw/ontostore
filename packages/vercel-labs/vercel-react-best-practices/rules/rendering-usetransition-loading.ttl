oc:skill_vercel_labs_vercel_react_best_practices_rendering_usetransition_loading a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rendering-usetransition-loading" ;
    skos:broader "React pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "3a1249c3f13026b6f54ab5712c388df219d6af01b12aa542749acd99a46f4bc1" ;
    oc:differentia "prescribes useTransition hook over manual useState loading states for improved rendering performance and code clarity" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_29754a97,
        oc:kn_7aadc829,
        oc:kn_b7b47b05,
        oc:kn_e8fa1145,
        oc:kn_ef55c6f3 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "improve React rendering performance with transitions",
        "manage loading states in React components",
        "simplify async state management in React" ;
    oc:yieldsState oc:LoadingStateRefactored .

oc:kn_29754a97 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When async operations may fail or throw exceptions" ;
    oc:directiveContent "useTransition's isPending state automatically resets even if the transition throws an error, unlike manual setIsLoading(false) which can be missed." ;
    oc:hasRationale "Manual loading state requires try/catch to ensure setIsLoading(false) runs on error; useTransition handles this automatically, reducing bug surface area." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7aadc829 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When users trigger rapid consecutive async operations (e.g., typing in search)" ;
    oc:directiveContent "New transitions started via startTransition automatically cancel pending transitions—no manual abort/cleanup logic needed." ;
    oc:hasRationale "This built-in interruption handling prevents stale results from overwriting newer ones and eliminates the need for manual AbortController or debounce patterns." ;
    oc:severityLevel "LOW" .

oc:kn_b7b47b05 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When structuring useTransition calls in event handlers" ;
    oc:directiveContent "Keep immediate UI feedback (like input value updates) outside startTransition, and wrap only the expensive/result-updating async work inside startTransition." ;
    oc:hasRationale "Separating urgent updates (typing) from non-urgent updates (fetching results) is the core idea of React transitions—urgent updates stay responsive." ;
    oc:severityLevel "HIGH" .

oc:kn_e8fa1145 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing async loading behavior in React components" ;
    oc:directiveContent "Never use manual useState for loading states (setIsLoading(true/false)) when React's useTransition provides built-in isPending state." ;
    oc:hasRationale "Manual loading state management is error-prone—pending state can get stuck if the async operation throws, and it doesn't integrate with React's concurrent rendering scheduler." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ef55c6f3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing React components with search, filter, or other async-driven UI updates" ;
    oc:directiveContent "Use useTransition's startTransition to wrap async operations that update UI state, keeping the input responsive while results load." ;
    oc:hasRationale "startTransition keeps the UI responsive during heavy updates and automatically handles interruption—new transitions cancel pending ones without manual cleanup." ;
    oc:severityLevel "HIGH" .

