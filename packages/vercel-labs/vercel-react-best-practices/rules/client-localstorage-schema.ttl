oc:kn_066ce849 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, for every localStorage read/write" ;
    oc:directiveContent "Always wrap every localStorage.getItem() and localStorage.setItem() call in try-catch." ;
    oc:hasRationale "These calls throw in Safari/Firefox private browsing, when storage quota is exceeded, or when storage is disabled by the user." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8eb696aa a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting fields to persist" ;
    oc:directiveContent "Never store authentication tokens, PII, or internal server flags in localStorage." ;
    oc:hasRationale "localStorage is accessible to any JS on the same origin including XSS attacks; sensitive data must use secure storage mechanisms." ;
    oc:severityLevel "CRITICAL" .

oc:kn_dc282fc4 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing migration logic" ;
    oc:directiveContent "localStorage read operations are idempotent; writes overwrite previous values. Migration functions should remove old-version keys after successful migration." ;
    oc:hasRationale "Leaving old keys wastes quota and can cause confusion about which version is canonical." .

oc:kn_f0196673 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When caching server data to localStorage" ;
    oc:directiveContent "Never store full API response objects in localStorage — only extract and persist the minimal fields the UI actually needs." ;
    oc:hasRationale "Full objects bloat storage, risk exposing sensitive/internal fields (tokens, PII), and increase parsing cost." ;
    oc:severityLevel "HIGH" .

oc:kn_f1b7df03 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining any localStorage key" ;
    oc:directiveContent "Always prefix localStorage keys with a version identifier (e.g., 'userConfig:v2') and provide a migration function to transform data between versions." ;
    oc:hasRationale "Version prefixes prevent schema conflicts when the data shape changes across app releases, enabling safe migration." ;
    oc:severityLevel "HIGH" .

_:ref_8f5e1afe920a1e5d a oc:WorkflowStep ;
    dcterms:description "Write a migration function that reads old-version data, transforms it, saves under new version, and removes the old key." ;
    oc:expectedOutcome "Seamless upgrade path between schema versions" ;
    oc:stepId "4" .

