        oc:kn_f52aa4e2 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "avoid expensive re-renders for toggled components",
        "optimize show/hide rendering",
        "preserve component state during visibility toggling" .

oc:kn_14fd7e71 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When using Activity component in hidden mode" ;
    oc:directiveContent "The <Activity> component keeps the DOM node mounted but hidden when mode is 'hidden', preserving all internal component state, refs, and scroll positions." ;
    oc:hasRationale "Agents need to understand the memory trade-off: hidden components still consume memory vs being fully unmounted" ;
    oc:severityLevel "LOW" .

oc:kn_9549c303 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When wrapping components that need state-preserving visibility toggling" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """import { Activity } from 'react'

function Dropdown({ isOpen }: Props) {
  return (
    <Activity mode={isOpen ? 'visible' : 'hidden'}>
      <ExpensiveMenu />
    </Activity>
  )
}""" .

oc:kn_b3cbeced a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing show/hide patterns for expensive components like dropdowns, modals, or panels" ;
    oc:directiveContent "Use React's <Activity> component with mode='visible'/'hidden' for expensive components that frequently toggle visibility, instead of conditional rendering (&&) or ternaries." ;
    oc:hasRationale "Preserves both DOM and component state across visibility toggles, avoiding expensive re-renders and state loss" ;
    oc:severityLevel "MEDIUM" .

oc:kn_eed71084 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When toggling visibility of components with significant render cost or meaningful internal state" ;
    oc:directiveContent "Avoid using conditional rendering (e.g., {isOpen && <Component />}) for expensive components that toggle visibility frequently, as it destroys and recreates both DOM and state each time." ;
    oc:hasRationale "Destruction and recreation cycles cause unnecessary performance overhead and lose user state (scroll position, form inputs, etc.)" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f52aa4e2 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating whether to use Activity vs standard conditional rendering" ;
    oc:directiveContent "Activity has MEDIUM impact — it preserves state/DOM for expensive components, trading memory for faster re-activation. Best suited for components with high render cost that toggle frequently." ;
    oc:hasRationale "For cheap components that rarely toggle, the memory overhead of keeping them in the DOM outweighs the re-render savings" ;
    oc:severityLevel "LOW" .

