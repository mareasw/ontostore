@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_rendering_activity a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rendering-activity" ;
    skos:broader "React rendering optimization technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "1e5e7eaf3555e61d6a2e900089c676527d26259501db5594f59544b6c664f85a" ;
    oc:differentia "preserves component state and DOM nodes for expensive components that frequently toggle visibility using React's Activity component" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:APIUnavailable ;
    oc:hasArgumentHint "component visibility toggle scenario" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_67c5c50b,
        oc:kn_a57bf120,
        oc:kn_b096d046,
        oc:kn_b54111f0,
        oc:kn_c4685872 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ReactProjectInitialized ;
    oc:resolvesIntent "avoid expensive re-renders for toggled components",
        "optimize show/hide rendering performance",
        "preserve component state on visibility toggle",
        "prevent state loss when hiding and showing components" ;
    oc:yieldsState oc:VisibilityOptimized .

oc:kn_67c5c50b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before using the Activity component in any project." ;
    oc:directiveContent "The <Activity> component is a React API — ensure the project uses a React version that supports it." ;
    oc:hasRationale "Activity is a relatively new React API and may not be available in older React versions, requiring a minimum version check." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a57bf120 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When deciding whether to use Activity vs conditional rendering for a given component." ;
    oc:directiveContent "Using Activity mode='hidden' keeps the component's DOM in memory but offscreen, trading memory usage for faster re-show performance." ;
    oc:hasRationale "The memory tradeoff is beneficial for components with expensive render cycles or critical user state, but should not be overused for trivial components." ;
    oc:severityLevel "LOW" .

oc:kn_b096d046 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When implementing show/hide toggles for expensive React components such as dropdowns, modals, or panels." ;
    oc:directiveContent "Use React's <Activity> component with mode='visible' or mode='hidden' to preserve state and DOM for expensive components that frequently toggle visibility." ;
    oc:hasRationale "Preserving the DOM subtree avoids costly unmount/remount cycles and prevents loss of internal component state (form inputs, scroll position, etc.)." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b54111f0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating which components to wrap with Activity." ;
    oc:directiveContent "Apply Activity only to components that are both expensive to render and frequently toggled; simple or one-time toggle components don't benefit." ;
    oc:hasRationale "Unnecessary use of Activity increases memory footprint without meaningful performance gain, so reserve it for genuinely expensive, frequently toggled components." ;
    oc:severityLevel "LOW" .

oc:kn_c4685872 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When toggling visibility of components with significant initialization cost or user state." ;
    oc:directiveContent "Do not conditionally render (unmount) expensive components that will be re-shown, as this destroys their DOM tree and internal state." ;
    oc:hasRationale "Unmounting and re-mounting expensive components causes unnecessary re-renders, layout recalculations, and state loss, degrading perceived performance." ;
    oc:severityLevel "HIGH" .

