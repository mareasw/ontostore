    oc:yieldsState oc:StreamingRenderOptimized .

oc:kn_44fdd0c0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring page layouts with async data" ;
    oc:directiveContent "Push Suspense boundaries as close to the data-dependent leaf components as possible. Static layout elements (sidebar, header, footer) should render immediately." ;
    oc:hasRationale "Smaller suspense boundaries mean more of the UI is visible sooner, improving perceived performance." .

oc:kn_6ae168a2 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing the basic strategic suspense boundary pattern" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """function Page() {
  return (
    <div>
      <StaticShell />
      <Suspense fallback={<Skeleton />}>
        <AsyncLeafComponent />
      </Suspense>
    </div>
  )
}

async function AsyncLeafComponent() {
  const data = await fetchData()
  return <div>{data.content}</div>
}""" .

oc:kn_93acc73b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sharing a promise across multiple components with deduplication" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """function Page() {
  const dataPromise = fetchData()
  return (
    <Suspense fallback={<Skeleton />}>
      <ComponentA dataPromise={dataPromise} />
      <ComponentB dataPromise={dataPromise} />
    </Suspense>
  )
}

function ComponentA({ dataPromise }) {
  const data = use(dataPromise)
  ...
}""" .

oc:kn_a1e6a381 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When implementing streaming with Suspense fallbacks" ;
    oc:directiveContent "Using Suspense boundaries introduces potential layout shift: a skeleton fallback is shown, then replaced with actual content that may differ in size." ;
    oc:hasRationale "Layout shift degrades user experience; weigh faster initial paint against content jump stability." .

oc:kn_e5485231 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing async React Server Components that mix static and data-dependent UI" ;
    oc:directiveContent "Never await data at the top of an async page/layout component if only a subset of the JSX needs that data. It blocks the entire wrapper from rendering." ;
    oc:hasRationale "Blocking the full layout negates the streaming benefits of React Server Components and delays initial paint." ;
    oc:severityLevel "HIGH" .

oc:kn_e92f9c32 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When multiple sibling or cousin components share the same async data source" ;
    oc:directiveContent "When multiple components need the same data, create the promise at the page level and pass it down as a prop. Each child uses React.use(promise) to unwrap it. This deduplicates fetches while maintaining streaming." ;
    oc:hasRationale "Sharing the promise ensures a single network request while still allowing Suspense to coordinate the loading state." .

oc:kn_ea74441d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to apply streaming suspense" ;
    oc:directiveContent "Do NOT use Suspense boundaries when: data affects layout positioning, content is SEO-critical above the fold, the query is so fast that Suspense overhead isn't justified, or layout shift from loading→content is unacceptable." ;
    oc:hasRationale "These cases either break functionality (SEO, layout) or the trade-off is net negative (fast queries, layout shift)." ;
    oc:severityLevel "CRITICAL" .

