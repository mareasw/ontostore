@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_rendering_animate_svg_wrapper a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rendering-animate-svg-wrapper" ;
    skos:broader "Performance optimization technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "9c6ae0ca7a51434e803887c64cded760956579a1452ccb80a461a03f9c937c77" ;
    oc:differentia "wraps SVG elements in div containers to enable GPU-accelerated CSS animations instead of animating SVG elements directly" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "SVG component or animation code to optimize" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_22830bb3,
        oc:kn_57e55ba1,
        oc:kn_6da171cd,
        oc:kn_f74caa58 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "animate SVG elements smoothly",
        "enable hardware acceleration for SVG animations",
        "optimize SVG animation performance" ;
    oc:yieldsState oc:SVGAnimationOptimized .

oc:kn_22830bb3 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When refactoring existing SVG animations to use the wrapper pattern" ;
    oc:directiveContent "This wrapping technique is purely structural and can be applied or removed without side effects on SVG content or layout, provided the wrapper div does not alter sizing." ;
    oc:hasRationale "The div wrapper is a transparent container that delegates animation to the GPU without changing the visual output of the SVG itself." ;
    oc:severityLevel "LOW" .

oc:kn_57e55ba1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing CSS-based animations on SVG elements in React/Next.js components" ;
    oc:directiveContent "Never apply CSS animation classes (like animate-spin, transform, opacity transitions) directly to SVG elements; always wrap the SVG in a div and animate the wrapper." ;
    oc:hasRationale "Most browsers lack hardware acceleration for CSS3 animations on SVG elements, resulting in janky or suboptimal animation performance." ;
    oc:severityLevel "HIGH" .

oc:kn_6da171cd a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "Always when evaluating SVG animation rendering performance" ;
    oc:directiveContent "Animating the SVG wrapper div enables hardware (GPU) acceleration, significantly reducing CPU load during animation frames." ;
    oc:hasRationale "GPU-accelerated compositing avoids main-thread jank and provides consistent frame rates during animations." ;
    oc:severityLevel "LOW" .

oc:kn_f74caa58 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When animating SVG with any CSS transform or transition property" ;
    oc:directiveContent "Apply CSS transforms and transitions (transform, opacity, translate, scale, rotate) to a wrapper div element rather than the SVG element itself to leverage GPU compositing." ;
    oc:hasRationale "Browsers delegate div animations to the GPU compositor layer, producing smoother 60fps animations compared to CPU-rendered SVG animations." ;
    oc:severityLevel "MEDIUM" .

