oc:skill_vercel_labs_vercel_react_best_practices_async_defer_await a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "async-defer-await" ;
    skos:broader "Async optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "f3c142d090615abdcc99d31c123be37b31f0f1ed8d9ec9f7789a3bc6883ae0fb" ;
    oc:differentia "defers await operations into code branches where the result is actually consumed, avoiding unnecessary blocking of unused code paths" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Move `await` operations into the branches where they're actually used to avoid blocking code paths that don't need them." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Incorrect (blocks both branches):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Correct (only blocks when needed):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent "**Another example (early return optimization):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """async function handleRequest(userId: string, skipProcessing: boolean) {
  const userData = await fetchUserData(userId)
  
  if (skipProcessing) {
    // Returns immediately but still waited for userData
    return { skipped: true }
  }
  
  // Only this branch uses userData
  return processUserData(userData)
}
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-26" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """// Incorrect: always fetches permissions
async function updateResource(resourceId: string, userId: string) {
  const permissions = await fetchPermissions(userId)
  const resource = await getResource(resourceId)
  
  if (!resource) {
    return { error: 'Not found' }
  }
  
  if (!permissions.canEdit) {
    return { error: 'Forbidden' }
  }
  
  return await updateResourceData(resource, permissions)
}

// Correct: fetches only when needed
async function updateResource(resourceId: string, userId: string) {
  const resource = await getResource(resourceId)
  
  if (!resource) {
    return { error: 'Not found' }
  }
  
  const permissions = await fetchPermissions(userId)
  
  if (!permissions.canEdit) {
    return { error: 'Forbidden' }
  }
  
  return await updateResourceData(resource, permissions)
}
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 7 ;
                    oc:sourceLocation "lines 45-78" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """async function handleRequest(userId: string, skipProcessing: boolean) {
  if (skipProcessing) {
    // Returns immediately without waiting
    return { skipped: true }
  }
  
  // Fetch only when needed
  const userData = await fetchUserData(userId)
  return processUserData(userData)
}
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 30-41" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 9 ;
                    oc:textContent "For `await getFlag()` combined with a cheap synchronous guard (`flag && someCondition`), see [Check Cheap Conditions Before Async Flags](./async-cheap-condition-before-await.md)." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 8 ;
                    oc:textContent "This optimization is especially valuable when the skipped branch is frequently taken, or when the deferred operation is expensive." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Defer Await Until Needed" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Defer Await Until Needed
impact: HIGH
impactDescription: avoids blocking unused code paths
tags: async, await, conditional, optimization
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:impartsKnowledge oc:kn_288ce113,
        oc:kn_45014e75,
        oc:kn_87d59324,
        oc:kn_8bfe952b,
        oc:kn_e855e622 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CodeExists ;
    oc:resolvesIntent "avoid blocking unused code paths",
        "defer await until needed",
        "improve async performance",
        "optimize async functions" ;
    oc:yieldsState oc:AsyncOptimized .

oc:kn_288ce113 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When async functions have multiple validation steps or early return conditions" ;
    oc:directiveContent "Place cheap synchronous checks and early returns before expensive async operations. Fetch data only when prior guards have passed." ;
    oc:hasRationale "Early returns on cheap synchronous conditions can skip expensive async fetches entirely, significantly reducing latency for error or edge-case paths." ;
    oc:severityLevel "HIGH" .

oc:kn_45014e75 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing async functions with conditional logic" ;
    oc:directiveContent "Never await all dependencies at the top of an async function when some branches return early without using those values." ;
    oc:hasRationale "Top-level awaits before conditionals force the runtime to wait for data that may never be used, adding unnecessary latency." ;
    oc:severityLevel "HIGH" .

oc:kn_87d59324 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing async functions with conditional branches that may not consume the awaited value" ;
    oc:directiveContent "Move await operations into the branches where the result is actually used, rather than awaiting at the top of the function." ;
    oc:hasRationale "Awaiting at the top of a function blocks execution for all branches, even those that never use the result, wasting time on unnecessary async operations." ;
    oc:severityLevel "HIGH" .

oc:kn_8bfe952b a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating whether to refactor existing async code for deferred await" ;
    oc:directiveContent "This optimization is most valuable when the skipped branch is frequently taken or when the deferred operation is expensive." ;
    oc:hasRationale "The performance gain scales with how often the early-return path is hit and how costly the avoided async operation is." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e855e622 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing multi-step async validation or processing flows" ;
    oc:directiveContent "Order async operations from cheapest/earliest-failing to most expensive, interleaving early-return checks between fetches." ;
    oc:hasRationale "This minimizes wasted work by failing fast on cheap checks before committing to expensive async operations." ;
    oc:severityLevel "MEDIUM" .

