    oc:differentia "converts array membership checks from O(n) to O(1) using Set/Map data structures" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Use Set/Map for O(1) Lookups
impact: LOW-MEDIUM
impactDescription: O(n) to O(1)
tags: javascript, set, map, data-structures, performance
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Correct (O(1) per check):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Convert arrays to Set/Map for repeated membership checks." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Incorrect (O(n) per check):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """const allowedIds = ['a', 'b', 'c', ...]
items.filter(item => allowedIds.includes(item.id))
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-17" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """const allowedIds = new Set(['a', 'b', 'c', ...])
items.filter(item => allowedIds.has(item.id))
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 21-24" ] ;
            oc:sectionLevel 2 ;
