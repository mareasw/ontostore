    oc:resolvesIntent "improve membership check performance",
        "optimize array lookups",
        "replace includes with Set.has" .

oc:kn_0088887c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any filter/map/reduce that checks membership" ;
    oc:directiveContent "If you call .includes(), .indexOf(), or .find() inside a loop or .filter() callback, convert the target array to a Set or Map first" ;
    oc:hasRationale "The overhead of creating a Set is O(n) once, but saves O(n) on every subsequent lookup" .

oc:kn_05b0095d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing repeated membership/existence checks against a known set of values" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """const allowedIds = new Set(['a', 'b', 'c']);
items.filter(item => allowedIds.has(item.id))""" .

oc:kn_e7417e18 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When the lookup collection has more than a trivial number of elements" ;
    oc:directiveContent "Using Set.has() or Map.has() provides O(1) lookup vs O(n) for Array.includes(), yielding up to O(n)→O(1) improvement per check" ;
    oc:hasRationale "Hash-based data structures provide constant-time lookups regardless of collection size" .

oc:kn_ec570750 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filtering or checking if items exist in a collection" ;
    oc:directiveContent "Never use Array.includes() or Array.indexOf() for repeated membership checks on large arrays" ;
    oc:hasRationale "Array.includes() is O(n) per check — for m items checked against n allowed values, total complexity is O(m×n)" ;
    oc:severityLevel "MEDIUM" .

