oc:skill_vercel_labs_vercel_react_best_practices_js_set_map_lookups a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "js-set-map-lookups" ;
    skos:broader "Performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "a7fd781a6ba9ad49065961b6f9a90ef486bf6b648390e1a08704025f98e1642b" ;
    oc:differentia "replaces O(n) array lookups with O(1) Set/Map lookups for repeated membership checks in JavaScript/TypeScript" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "code with repeated array membership checks" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_a9e68898,
        oc:kn_b3ac0eff,
        oc:kn_d8444411,
        oc:kn_fcd56e83 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CodebaseAvailable ;
    oc:resolvesIntent "improve array filtering performance",
        "optimize membership checks",
        "replace array.includes with Set.has" ;
    oc:yieldsState oc:PerformanceOptimized .

oc:kn_a9e68898 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When filtering arrays or performing repeated membership checks against a static or semi-static list of values" ;
    oc:directiveContent "Use Set instead of arrays for repeated membership checks (includes/contains operations) to achieve O(1) lookup time instead of O(n)." ;
    oc:hasRationale "Array.includes() scans every element in the worst case, making it O(n) per check. Set.has() uses hash-based lookup for O(1) average time, which compounds significantly when used inside filter/map loops." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b3ac0eff a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing JavaScript/TypeScript code that filters or checks membership against a list" ;
    oc:directiveContent "Avoid using Array.includes() or Array.indexOf() for membership checks inside loops like filter(), map(), or reduce() when the lookup collection has more than a few elements." ;
    oc:hasRationale "This creates O(n×m) complexity (n items × m lookup collection size), which becomes a performance bottleneck at scale with large datasets." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d8444411 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting data structures in JavaScript/TypeScript" ;
    oc:directiveContent "Choose the data structure that matches the access pattern: use Set for membership checks, Map for key-value lookups, and Array for ordered iteration." ;
    oc:hasRationale "Using the right data structure for the dominant operation avoids hidden performance costs and communicates intent more clearly to other developers." .

oc:kn_fcd56e83 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating whether to convert arrays to Sets for lookup optimization" ;
    oc:directiveContent "Set/Map lookups are O(1) average case; array includes/indexOf are O(n). The performance gain is LOW-MEDIUM impact depending on collection sizes and frequency of lookups." ;
    oc:hasRationale "For small arrays (<10 items) the difference is negligible, but for large arrays or hot paths inside render cycles, the O(n)→O(1) improvement is meaningful." ;
    oc:severityLevel "LOW" .

