oc:skill_vercel_labs_vercel_react_best_practices_rendering_hoist_jsx a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rendering-hoist-jsx" ;
    skos:broader "rendering optimization technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "93b229560fae92005ed9a2a829064607b39b2e984e92d221d05b2d41df2b7c0e" ;
    oc:differentia "hoists static JSX elements outside components to avoid re-creation on every render" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "JSX component or element to optimize" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_073ce541,
        oc:kn_2bfedb6d,
        oc:kn_5d001e1b,
        oc:kn_b811851b,
        oc:kn_d1116a7c ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ReactComponentWritten ;
    oc:resolvesIntent "avoid unnecessary JSX element re-creation",
        "optimize JSX rendering performance",
        "reduce render cost for static elements" ;
    oc:yieldsState oc:StaticJSXHoisted .

oc:kn_073ce541 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, by definition of the hoisting technique" ;
    oc:directiveContent "Hoisting a static JSX element is idempotent — moving it outside the component once produces the same result regardless of how many times the component re-renders." ;
    oc:hasRationale "The hoisted element is created once at module load time and reused, guaranteeing consistent references across all renders." ;
    oc:severityLevel "LOW" .

oc:kn_2bfedb6d a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When working in a project that has React Compiler enabled" ;
    oc:directiveContent "If React Compiler is enabled in the project, manual hoisting of static JSX elements is unnecessary because the compiler automatically performs this optimization." ;
    oc:hasRationale "Manual hoisting adds code complexity; if the compiler already handles it, the manual version becomes redundant noise and may even conflict with compiler optimizations." ;
    oc:severityLevel "LOW" .

oc:kn_5d001e1b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing React components with static sub-elements that never change" ;
    oc:directiveContent "Do not define static JSX elements inside component functions when the element does not depend on any props or state." ;
    oc:hasRationale "Defining static elements inside the component body causes them to be recreated on every render cycle, wasting CPU cycles and memory allocations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b811851b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing React components that contain static, unchanging JSX elements" ;
    oc:directiveContent "Extract static JSX elements outside of component functions so the same element reference is reused across renders instead of being recreated each time." ;
    oc:hasRationale "Recreating JSX elements on every render allocates new objects unnecessarily, increasing garbage collection pressure and render cost, especially for complex static subtrees like SVGs." ;
    oc:severityLevel "LOW" .

oc:kn_d1116a7c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a component renders SVG or other large static subtrees" ;
    oc:directiveContent "Large static SVG nodes are prime candidates for hoisting, as they are expensive to recreate on every render." ;
    oc:hasRationale "SVG nodes tend to be deeply nested and structurally complex, making their re-creation cost disproportionately high compared to simple HTML elements." ;
    oc:severityLevel "MEDIUM" .

