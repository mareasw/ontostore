oc:skill_vercel_labs_vercel_react_best_practices_async_parallel a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "async-parallel" ;
    skos:broader "Performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "6d2f841896279e976dfcdc1ac89e70771ac188baadfd43c096b5706cb838b961" ;
    oc:differentia "that parallelizes independent async operations using Promise.all() to eliminate sequential waterfalls" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Promise.all() for Independent Operations
impact: CRITICAL
impactDescription: 2-10× improvement
tags: async, parallelization, promises, waterfalls
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "When async operations have no interdependencies, execute them concurrently using `Promise.all()`." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Incorrect (sequential execution, 3 round trips):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """const [user, posts, comments] = await Promise.all([
  fetchUser(),
  fetchPosts(),
  fetchComments()
])
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 22-28" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Correct (parallel execution, 1 round trip):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """const user = await fetchUser()
const posts = await fetchPosts()
const comments = await fetchComments()
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-18" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Promise.all() for Independent Operations" ] ;
    oc:impartsKnowledge oc:kn_1e6d0b14,
        oc:kn_3e0d28e7,
        oc:kn_87f07bf7,
        oc:kn_d2e431ba ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "eliminate sequential async waterfalls",
        "optimize data fetching in React components",
        "parallelize independent async operations" .

oc:kn_1e6d0b14 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating async code performance" ;
    oc:directiveContent "Sequential awaits cause N round trips for N independent operations; Promise.all() reduces this to 1 round trip batch." ;
    oc:hasRationale "Network latency compounds with each sequential await, whereas Promise.all() overlaps all network wait times." .

oc:kn_3e0d28e7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or writing any code with multiple async calls" ;
    oc:directiveContent "If async operation B does not depend on the result of async operation A, run them in parallel with Promise.all()." ;
    oc:hasRationale "Independent operations have no reason to wait on each other; parallelization yields 2-10× improvement." ;
    oc:severityLevel "HIGH" .

oc:kn_87f07bf7 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When multiple async operations are independent and can run concurrently" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """const [user, posts, comments] = await Promise.all([
  fetchUser(),
  fetchPosts(),
  fetchComments()
])""" .

oc:kn_d2e431ba a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When multiple async calls have no data dependency on each other" ;
    oc:directiveContent "Never await independent async operations sequentially — this creates artificial waterfalls where each operation waits for the previous one to complete." ;
    oc:hasRationale "Sequential awaits on independent operations waste network time and can turn 1 round trip into N round trips, causing 2-10× slower performance." ;
    oc:severityLevel "CRITICAL" .

