        oc:kn_d4733918 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ReactComponentMounted ;
    oc:resolvesIntent "fix stale closure bugs in React callbacks",
        "optimize useCallback to prevent unnecessary recreations",
        "write stable React state updates" ;
    oc:yieldsState oc:StableCallbacksCreated .

oc:kn_5dd48ced a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating state based on its current value inside useCallback or event handlers" ;
    oc:directiveContent "Never reference a state variable directly inside a useCallback/setState call that depends on the current state value — use the functional update form setItems(curr => ...) instead." ;
    oc:hasRationale "Direct references cause stale closures (capturing outdated state) or force dependency-driven recreations that trigger unnecessary child re-renders." ;
    oc:severityLevel "CRITICAL" .

oc:kn_956fd1fb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between functional vs direct setState" ;
    oc:directiveContent "Use functional setState whenever the new state depends on the previous state value — use direct setState only for static values or prop/argument-derived values." ;
    oc:hasRationale "Functional updates guarantee correctness and stability; direct updates are simpler and safe only when no previous-state dependency exists." .

oc:kn_a32fda78 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When appending items to an array state inside useCallback with an empty dependency array" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent "setItems(curr => [...curr, ...newItems])" ;
    oc:hasRationale "Functional update receives the latest state snapshot, eliminating the need to include the state variable in the dependency array." .

oc:kn_b65a0483 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When React Compiler is enabled in the project" ;
    oc:directiveContent "React Compiler can auto-optimize some cases, but functional updates are still recommended for correctness and stale closure prevention." ;
    oc:hasRationale "The compiler handles memoization optimization but does not guarantee protection against stale closure semantics." .

oc:kn_d4733918 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When state is accessed within closures that may execute asynchronously or be memoized" ;
    oc:directiveContent "Prefer functional updates inside useCallback, useMemo, async operations, and event handlers that reference state." ;
    oc:hasRationale "These contexts carry the highest risk of stale closures; functional updates eliminate that risk entirely." .

