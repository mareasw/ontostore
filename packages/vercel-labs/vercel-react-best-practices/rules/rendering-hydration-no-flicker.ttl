oc:skill_vercel_labs_vercel_react_best_practices_rendering_hydration_no_flicker a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rendering-hydration-no-flicker" ;
    skos:broader "React rendering pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "dc7ab358c67c177bca6e6f360fbc935ebe4efa928c0ba3ebd3f9f3d9e2000ca3" ;
    oc:differentia "prevents hydration mismatch and visual flickering when using client-side storage in SSR contexts via synchronous inline scripts" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "client-side storage key and wrapper component" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_384fb543,
        oc:kn_6f374942,
        oc:kn_6f86a9e6,
        oc:kn_da4132b8,
        oc:kn_ea54d790 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "avoid visual flicker on theme toggle",
        "implement flicker-free theme switching in Next.js",
        "prevent hydration mismatch with localStorage",
        "render client-only data without SSR errors" .

oc:kn_384fb543 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing inline scripts that access browser storage APIs" ;
    oc:directiveContent "Wrap localStorage reads in try/catch within inline scripts to gracefully handle environments where storage may be disabled or restricted." ;
    oc:hasRationale "Private browsing modes, storage quotas, and browser security policies can cause localStorage access to throw, which would break the page if unhandled." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6f374942 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering components that depend on client-side storage (localStorage, sessionStorage, cookies) in an SSR/SSG environment" ;
    oc:directiveContent "Never access localStorage or other browser-only APIs directly during component render in SSR contexts — they are undefined on the server and will throw errors." ;
    oc:hasRationale "Server-side rendering executes in Node.js where browser APIs like localStorage do not exist, causing runtime errors and broken renders." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6f86a9e6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing theme toggles, user preferences, or any client-only data that should render immediately" ;
    oc:directiveContent "Avoid using useEffect to read localStorage and then setState, as this causes a visible flash of incorrect/default content before the update applies." ;
    oc:hasRationale "useEffect runs after hydration, meaning the component first renders with the default value and then re-renders with the stored value, producing a visible flicker." ;
    oc:severityLevel "HIGH" .

oc:kn_da4132b8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When you need client-only data to be present in the DOM immediately on first paint without breaking SSR" ;
    oc:directiveContent "Use a synchronous inline script (via dangerouslySetInnerHTML) to read client-side storage and update the DOM before React hydrates, eliminating both SSR errors and post-hydration flicker." ;
    oc:hasRationale "Synchronous inline scripts execute before the browser paints and before React hydration begins, so the DOM already has the correct value when React takes over — no mismatch, no flash." ;
    oc:severityLevel "HIGH" .

oc:kn_ea54d790 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing the inline script hydration-safe pattern" ;
    oc:directiveContent "The synchronous script pattern requires a identifiable DOM element (by id) that exists in the SSR output, so the script can target it before hydration." ;
    oc:hasRationale "Without a stable DOM selector, the script cannot find the element to apply the class or attribute before React hydrates." ;
    oc:severityLevel "MEDIUM" .

