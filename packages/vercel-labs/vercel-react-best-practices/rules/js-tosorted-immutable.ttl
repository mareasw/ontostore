    oc:stepOrder 1 .

_:ref_75c573b06c3fcd32 a oc:WorkflowStep ;
    dcterms:description "Causes stale closure bugs - Mutating arrays inside closures (callbacks, effects) can lead to unexpected behavior" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

