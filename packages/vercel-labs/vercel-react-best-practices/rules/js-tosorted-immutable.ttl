    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "prevent mutation bugs when sorting state or props",
        "sort arrays immutably in React components",
        "use modern immutable array methods" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_2720530e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sorting arrays derived from React props or state" ;
    oc:directiveContent "Never use .sort() on React state or props arrays — it mutates the original array in place, breaking React's immutability contract." ;
    oc:hasRationale "Mutating props/state breaks React's change detection, causes stale closure bugs, and violates the one-way data flow model." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3d4dd3d4 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before using .toSorted() in production code" ;
    oc:directiveContent "Verify .toSorted() is available in your target runtime (Chrome 110+, Safari 16+, Firefox 115+, Node.js 20+) or configure a transpiler/polyfill." ;
    oc:hasRationale "Older environments will throw a TypeError if .toSorted() is not available." ;
    oc:severityLevel "LOW" .

oc:kn_4c9c6509 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When sorting arrays in React components" ;
    oc:directiveContent "Use .toSorted() instead of .sort() to create a new sorted array without mutating the original." ;
    oc:hasRationale "Immutable operations preserve the original array reference, ensuring React correctly detects changes and re-renders as expected." ;
    oc:severityLevel "HIGH" .

oc:kn_8ae7a38e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any array transformation in React components" ;
    oc:directiveContent "Prefer the family of immutable array methods (.toSorted(), .toReversed(), .toSpliced(), .with()) over their mutating counterparts (.sort(), .reverse(), .splice(), bracket assignment) in React code." ;
    oc:hasRationale "These methods provide a consistent, safe pattern for array operations that align with React's immutability expectations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f4537115 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When targeting older browsers or Node.js < 20" ;
    oc:directiveContent "For environments without .toSorted() support (pre-ES2023), use [...items].sort() as a safe immutable fallback." ;
    oc:hasRationale "The spread operator creates a shallow copy before sorting, achieving the same immutability guarantee." ;
    oc:severityLevel "MEDIUM" .

oc:req_42d61229 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of React immutability model and array mutation pitfalls" .

oc:req_d5e21e25 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "ES2023-compatible runtime (Chrome 110+, Safari 16+, Firefox 115+, Node.js 20+) or transpiler for fallback" .

_:ref_3b7c4f9af2c3150a a oc:WorkflowStep ;
    dcterms:description "Props/state mutations break React's immutability model - React expects props and state to be treated as read-only" ;
    oc:blockType "workflow_step" ;
