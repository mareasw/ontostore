oc:skill_vercel_labs_vercel_react_best_practices_js_tosorted_immutable a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "js-tosorted-immutable" ;
    skos:broader "JavaScript array method pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "d0a5e1b0fec48a0a81397957e2f068e224329f7c42cb5feeed8aae6fa64025e8" ;
    oc:differentia "that prevents mutation bugs in React by using toSorted() instead of sort() for immutable array operations" ;
    oc:extends oc:skill_ontoskills_vercel_react_best_practices,
        oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "array-to-sort" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_42d61229,
        oc:req_d5e21e25 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Use toSorted() Instead of sort() for Immutability
impact: MEDIUM-HIGH
impactDescription: prevents mutation bugs in React state
tags: javascript, arrays, immutability, react, state, mutation
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Incorrect (mutates original array):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent "**Why this matters in React:**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "`.sort()` mutates the array in place, which can cause bugs with React state and props. Use `.toSorted()` to create a new sorted array without mutation." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function UserList({ users }: { users: User[] }) {
  // Creates new sorted array, original unchanged
  const sorted = useMemo(
    () => users.toSorted((a, b) => a.name.localeCompare(b.name)),
    [users]
  )
  return <div>{sorted.map(renderUser)}</div>
}
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 27-36" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Correct (creates new array):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """// Fallback for older browsers
const sorted = [...items].sort((a, b) => a.value - b.value)
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 10 ;
                    oc:sourceLocation "lines 47-50" ],
                _:ref_62417892c27f6da6,
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 9 ;
                    oc:textContent "`.toSorted()` is available in all modern browsers (Chrome 110+, Safari 16+, Firefox 115+, Node.js 20+). For older environments, use spread operator:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 12 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "`.toReversed()` - immutable reverse" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "`.with()` - immutable element replacement" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "`.toSpliced()` - immutable splice" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "`.toSorted()` - immutable sort" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 11 ;
                    oc:textContent "**Other immutable array methods:**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 8 ;
                    oc:textContent "**Browser support (fallback for older browsers):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function UserList({ users }: { users: User[] }) {
  // Mutates the users prop array!
  const sorted = useMemo(
    () => users.sort((a, b) => a.name.localeCompare(b.name)),
    [users]
  )
  return <div>{sorted.map(renderUser)}</div>
}
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-23" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Use toSorted() Instead of sort() for Immutability" ] ;
    oc:hasWorkflow _:ref_62417892c27f6da6 ;
    oc:impartsKnowledge oc:kn_2720530e,
        oc:kn_3d4dd3d4,
