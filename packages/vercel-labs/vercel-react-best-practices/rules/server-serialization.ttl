oc:skill_vercel_labs_vercel_react_best_practices_server_serialization a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "server-serialization" ;
    skos:broader "Performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "f4c7d68b29c82381baad059c4a7f09e868e71ec9c3115a26ad3ae7d24c0dfe1f" ;
    oc:differentia "minimizes data serialization at React Server/Client component boundaries by passing only required fields as props" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Minimize Serialization at RSC Boundaries
impact: HIGH
impactDescription: reduces data transfer size
tags: server, rsc, serialization, props
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """async function Page() {
  const user = await fetchUser()  // 50 fields
  return <Profile user={user} />
}

'use client'
function Profile({ user }: { user: User }) {
  return <div>{user.name}</div>  // uses 1 field
}
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-24" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Incorrect (serializes all 50 fields):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """async function Page() {
  const user = await fetchUser()
  return <Profile name={user.name} />
}

'use client'
function Profile({ name }: { name: string }) {
  return <div>{name}</div>
}
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 28-38" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Correct (serializes only 1 field):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "The React Server/Client boundary serializes all object properties into strings and embeds them in the HTML response and subsequent RSC requests. This serialized data directly impacts page weight and load time, so **size matters a lot**. Only pass fields that the client actually uses." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Minimize Serialization at RSC Boundaries" ] ;
    oc:impartsKnowledge oc:kn_50b2d982,
        oc:kn_b139e124,
        oc:kn_c2d81f57,
        oc:kn_f3a705b5 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "improve RSC boundary performance",
        "optimize RSC serialization",
        "reduce page weight in React Server Components" .

oc:kn_50b2d982 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "Always when evaluating RSC component boundaries" ;
    oc:directiveContent "Serialized data at RSC boundaries directly impacts page weight and load time. The size of serialized props is proportional to the number of fields passed, not the number of fields used." ;
    oc:hasRationale "Understanding this cost model enables informed decisions about what data crosses the server/client boundary." ;
    oc:severityLevel "HIGH" .

oc:kn_b139e124 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing any component that uses 'use client'" ;
    oc:directiveContent "Audit every 'use client' component's prop types to ensure no full objects are being passed when only individual fields are needed." ;
    oc:hasRationale "Catching over-serialization early prevents bloated payloads from reaching production." .

oc:kn_c2d81f57 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When passing props from Server Components to Client Components" ;
    oc:directiveContent "Never pass entire data objects across RSC boundaries when the client component only uses a subset of fields. All object properties are serialized into strings and embedded in the HTML response." ;
    oc:hasRationale "Serializing all 50 fields when only 1 is needed dramatically increases page weight and load time, as RSC serialization embeds all data in the HTML/RSC payload." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f3a705b5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing the prop interface for a 'use client' component" ;
    oc:directiveContent "Pass only the specific primitive fields that a client component actually uses, rather than the full parent object." ;
    oc:hasRationale "RSC serialization converts all object properties to strings in the payload; fewer fields means smaller HTML responses and faster page loads." .

