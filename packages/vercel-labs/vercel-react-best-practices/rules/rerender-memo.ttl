@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_rerender_memo a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rerender-memo" ;
    skos:broader "React performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "1f258990c2f27ff6256b3cc5c43300631bb3f0d81f749aed08d07fcdcc131dd1" ;
    oc:differentia "extracts expensive computation into memoized components to enable early returns that skip unnecessary work" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_49c5cfa2,
        oc:kn_d8e2edb6,
        oc:kn_f7d1dc11,
        oc:kn_fb104b99 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ReactComponentExists ;
    oc:resolvesIntent "avoid unnecessary computation during loading states",
        "extract memoized components",
        "optimize React component re-renders" ;
    oc:yieldsState oc:ComponentMemoized .

oc:kn_49c5cfa2 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When profiling or optimizing component render performance" ;
    oc:directiveContent "Extracting to a memoized component enables early-return optimization that can completely skip expensive avatar ID computation during loading states." ;
    oc:hasRationale "Skipping computation entirely (via early return) is always cheaper than computing and memoizing a result that is never used." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d8e2edb6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a React component has both expensive computations and early return paths (e.g., loading states)" ;
    oc:directiveContent "Do not wrap expensive computation in useMemo inside a component that may return early — the useMemo hook runs before any conditional return, wasting computation." ;
    oc:hasRationale "React hooks execute in order before conditional returns, so useMemo will compute even when the result is never rendered, defeating the purpose of memoization." ;
    oc:severityLevel "HIGH" .

oc:kn_f7d1dc11 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing React components that have conditional rendering paths with expensive computations" ;
    oc:directiveContent "Extract expensive work into a separate memoized child component so the parent can return early without triggering the child's computation." ;
    oc:hasRationale "If the parent returns early, the memoized child component never renders, and its internal computation is entirely skipped — achieving the early-return optimization." ;
    oc:severityLevel "HIGH" .

oc:kn_fb104b99 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to manually apply memoization in a React project" ;
    oc:directiveContent "If React Compiler is enabled in the project, skip manual memo() and useMemo() — the compiler handles re-render optimization automatically." ;
    oc:hasRationale "React Compiler automatically optimizes re-renders, making manual memoization redundant and potentially adding unnecessary complexity." ;
    oc:severityLevel "MEDIUM" .

