@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_bundle_barrel_imports a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "bundle-barrel-imports" ;
    skos:broader "Performance optimization guideline" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "e648f6d54525f07a691357040ca5bff6ea3424788a91ff63812adb29622a671b" ;
    oc:differentia "that eliminates barrel file import overhead by using direct source imports or Next.js optimizePackageImports" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:TypeScriptTypeError ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Avoid Barrel File Imports
impact: CRITICAL
impactDescription: 200-800ms import cost, slow builds
tags: bundle, imports, tree-shaking, barrel-files, performance
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Import directly from source files instead of barrel files to avoid loading thousands of unused modules. **Barrel files** are entry points that re-export multiple modules (e.g., `index.js` that does `export * from './module'`)." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """// Keep the standard imports - Next.js transforms them to direct imports
import { Check, X, Menu } from 'lucide-react'
// Full TypeScript support, no manual path wrangling
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 8 ;
                    oc:sourceLocation "lines 38-42" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 10 ;
                    oc:textContent "**Correct - Direct imports (non-Next.js projects):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """// next.config.js - automatically optimizes barrel imports at build time
module.exports = {
  experimental: {
    optimizePackageImports: ['lucide-react', '@mui/material']
  }
}
""" ;
                    oc:codeLanguage "js" ;
                    oc:contentOrder 7 ;
                    oc:sourceLocation "lines 29-36" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """import { Check, X, Menu } from 'lucide-react'
// Loads 1,583 modules, takes ~2.8s extra in dev
// Runtime cost: 200-800ms on every cold start

import { Button, TextField } from '@mui/material'
// Loads 2,225 modules, takes ~4.2s extra in dev
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 18-25" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**Why tree-shaking doesn't help:** When a library is marked as external (not bundled), the bundler can't optimize it. If you bundle it to enable tree-shaking, builds become substantially slower analyzing the entire module graph." ],
                [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 12 ;
                    oc:quoteContent "**TypeScript warning:** Some libraries (notably `lucide-react`) don't ship `.d.ts` files for their deep import paths. Importing from `lucide-react/dist/esm/icons/check` resolves to an implicit `any` type, causing errors under `strict` or `noImplicitAny`. Prefer `optimizePackageImports` when available, or verify the library exports types for its subpaths before using direct imports." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 15 ;
                    oc:textContent "Reference: [How we optimized package imports in Next.js](https://vercel.com/blog/how-we-optimized-package-imports-in-next-js)" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """import Button from '@mui/material/Button'
import TextField from '@mui/material/TextField'
// Loads only what you use
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 11 ;
                    oc:sourceLocation "lines 48-52" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Popular icon and component libraries can have **up to 10,000 re-exports** in their entry file. For many React packages, **it takes 200-800ms just to import them**, affecting both development speed and production cold starts." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent "**Correct - Next.js 13.5+ (recommended):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 9 ;
                    oc:textContent "This is the recommended approach because it preserves TypeScript type safety and editor autocompletion while still eliminating the barrel import cost." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 14 ;
                    oc:textContent "Libraries commonly affected: `lucide-react`, `@mui/material`, `@mui/icons-material`, `@tabler/icons-react`, `react-icons`, `@headlessui/react`, `@radix-ui/react-*`, `lodash`, `ramda`, `date-fns`, `rxjs`, `react-use`." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Incorrect (imports entire library):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 13 ;
                    oc:textContent "These optimizations provide 15-70% faster dev boot, 28% faster builds, 40% faster cold starts, and significantly faster HMR." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Avoid Barrel File Imports" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Identify and resolve barrel file import performance issues in a React/Next.js project" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Verify TypeScript compilation passes and measure dev boot / cold start improvement" ;
                    oc:stepDependsOn _:ref_3eea30c70e21b986,
                        _:ref_4babca83fd2294f3 ;
                    oc:stepId "verify" ],
                _:ref_3eea30c70e21b986,
                _:ref_4babca83fd2294f3,
                _:ref_55044bdab3f2fd36,
                _:ref_b7a18391767691be ;
            oc:workflowId "optimize-barrel-imports" ;
            oc:workflowName "Optimize Barrel File Imports" ] ;
    oc:impartsKnowledge oc:kn_5e0ad990,
        oc:kn_66d07fa7,
        oc:kn_67f91e6c,
        oc:kn_79e7ff68,
        oc:kn_9cac5ff9 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:NextJsProjectConfigured ;
    oc:resolvesIntent "configure optimizePackageImports in Next.js",
        "optimize barrel file imports",
        "reduce bundle import cost",
        "speed up dev boot and cold starts" ;
    oc:yieldsState oc:BarrelImportsOptimized .

oc:kn_5e0ad990 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When auditing a project for barrel import issues" ;
    oc:directiveContent "Libraries commonly affected by barrel file overhead: lucide-react, @mui/material, @mui/icons-material, @tabler/icons-react, react-icons, @headlessui/react, @radix-ui/react-*, lodash, ramda, date-fns, rxjs, react-use." ;
    oc:hasRationale "These popular libraries are known to have 1,000-10,000+ re-exports in their entry files, causing measurable import costs." .

oc:kn_66d07fa7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Next.js 13.5+ projects using barrel-exporting libraries" ;
    oc:directiveContent "Prefer optimizePackageImports in next.config.js over manual direct imports. It preserves TypeScript type safety and editor autocompletion while eliminating barrel import cost at build time." ;
    oc:hasRationale "Manual deep path imports lose type safety for libraries like lucide-react that don't ship .d.ts files for subpaths. optimizePackageImports handles the transformation automatically." ;
    oc:severityLevel "HIGH" .

oc:kn_67f91e6c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Non-Next.js projects or when manual direct imports are the only option" ;
    oc:directiveContent "Some libraries (notably lucide-react) don't ship .d.ts files for their deep import paths, causing implicit any errors under strict or noImplicitAny. Verify subpath type exports before using direct imports." ;
    oc:hasRationale "TypeScript strict mode will error on implicit any types from untyped deep imports, breaking builds." ;
    oc:severityLevel "HIGH" .

oc:kn_79e7ff68 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When importing from libraries like lucide-react, @mui/material, @mui/icons-material, @tabler/icons-react, react-icons, lodash, ramda, date-fns, rxjs" ;
    oc:directiveContent "Never import from barrel files (index.js re-exporting many modules) when the library has thousands of re-exports. This loads all modules and costs 200-800ms per import on cold starts." ;
    oc:hasRationale "Barrel files force the bundler to load thousands of unused modules. Tree-shaking cannot help when libraries are marked as external, and bundling them to enable tree-shaking makes builds substantially slower." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9cac5ff9 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "After applying optimizePackageImports or converting to direct imports" ;
    oc:directiveContent "Eliminating barrel imports yields 15-70% faster dev boot, 28% faster builds, 40% faster cold starts, and significantly faster HMR." ;
    oc:hasRationale "Measured performance improvements from Vercel's internal benchmarks on real-world projects." .

_:ref_3eea30c70e21b986 a oc:WorkflowStep ;
    dcterms:description "For Next.js projects: add optimizePackageImports to next.config.js with affected package names" ;
    oc:expectedOutcome "next.config.js updated with optimizePackageImports array" ;
    oc:stepDependsOn _:ref_b7a18391767691be ;
    oc:stepId "apply-nextjs" .

_:ref_4babca83fd2294f3 a oc:WorkflowStep ;
    dcterms:description "For non-Next.js projects: refactor imports to use direct source paths (e.g., @mui/material/Button instead of @mui/material)" ;
    oc:expectedOutcome "All barrel imports replaced with direct imports, TypeScript compilation passes" ;
    oc:stepDependsOn _:ref_b7a18391767691be ;
    oc:stepId "apply-direct" .

_:ref_55044bdab3f2fd36 a oc:WorkflowStep ;
    dcterms:description "Identify barrel file imports from commonly affected libraries (lucide-react, @mui/material, lodash, etc.)" ;
    oc:expectedOutcome "List of files importing from barrel files with estimated module load counts" ;
    oc:stepId "audit" .

_:ref_b7a18391767691be a oc:WorkflowStep ;
    dcterms:description "Determine optimization strategy: Next.js 13.5+ use optimizePackageImports, other projects use direct source imports" ;
    oc:expectedOutcome "Chosen strategy documented" ;
    oc:stepDependsOn _:ref_55044bdab3f2fd36 ;
    oc:stepId "choose-strategy" .

