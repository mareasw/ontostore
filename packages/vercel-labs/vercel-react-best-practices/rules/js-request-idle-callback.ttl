oc:kn_1880b876 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up cross-browser idle scheduling" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """const scheduleIdleWork = window.requestIdleCallback ?? ((cb: () => void) => setTimeout(cb, 1))

scheduleIdleWork(() => {
  // Non-critical work
})""" .

oc:kn_2c81298a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling user interactions like search, navigation, or form submission" ;
    oc:directiveContent "Never execute analytics, localStorage writes, or prefetching synchronously during user-initiated event handlers — they block the main thread and cause jank." ;
    oc:hasRationale "Synchronous non-critical work during interactions degrades perceived performance and causes frame drops." ;
    oc:severityLevel "HIGH" .

oc:kn_46ec64c1 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When optimizing any event handler with mixed critical and non-critical work" ;
    oc:directiveContent "1. Identify critical vs non-critical work in event handlers. 2. Execute critical work synchronously (rendering, state updates). 3. Wrap each non-critical task in its own requestIdleCallback. 4. For time-sensitive deferred work, add { timeout: N }. 5. For large tasks, implement chunked processing using deadline.timeRemaining(). 6. Add setTimeout fallback for unsupported browsers." ;
    oc:stepOrder 1 .

oc:kn_664ed6ff a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When targeting browsers without native requestIdleCallback support" ;
    oc:directiveContent "Use a setTimeout(cb, 1) fallback when requestIdleCallback is not supported by the browser." ;
    oc:hasRationale "setTimeout fallback ensures the code still works, just with less optimal scheduling." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6809d2f5 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When processing large datasets or long-running tasks in idle callbacks" ;
    oc:directiveContent "Keep idle callback work chunks under 50ms by using deadline.timeRemaining() to check available idle time within the callback." ;
    oc:hasRationale "Exceeding 50ms in a single chunk risks dropping frames and causing visible jank, defeating the purpose of idle scheduling." .

oc:kn_6b68f8f4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deferring multiple non-critical operations" ;
    oc:directiveContent "Split non-critical tasks into separate requestIdleCallback calls rather than batching them into one, so the browser can interleave them with higher-priority work." ;
    oc:hasRationale "Separate callbacks give the browser finer-grained scheduling control and prevent one deferred task from monopolizing idle time." .

oc:kn_820f7b61 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When deferred work must eventually run (e.g., analytics)" ;
    oc:directiveContent "Use the { timeout: N } option to guarantee deferred work executes within N milliseconds, even if the browser stays busy." ;
    oc:hasRationale "Without a timeout, requestIdleCallback may never fire if the browser stays persistently busy." ;
    oc:severityLevel "MEDIUM" .

oc:kn_82c49630 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deferred work must execute within a guaranteed timeframe" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """requestIdleCallback(
  () => analytics.track('page_view', { path: location.pathname }),
  { timeout: 2000 }
)""" .

oc:kn_a81ae981 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When chunking large dataset processing into idle-period-safe pieces" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """function processChunk(deadline: IdleDeadline) {
  while (index < items.length && deadline.timeRemaining() > 0) {
    processItem(items[index])
    index++
  }
  if (index < items.length) {
    requestIdleCallback(processChunk)
  }
}""" .

oc:kn_ccb98c70 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When categorizing work as deferrable vs. immediate" ;
    oc:directiveContent "Use requestIdleCallback for: analytics/telemetry, saving state to localStorage/IndexedDB, prefetching resources, processing non-urgent data, lazy initialization of non-critical features." ;
    oc:hasRationale "These tasks don't affect the current user interaction and can safely execute during idle periods." .

oc:kn_da654cd1 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires browser environment with window object; requestIdleCallback is available in modern browsers (Chrome, Firefox, Edge) with Safari support added in 15.4." .

oc:kn_fd4974ad a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to defer work" ;
    oc:directiveContent "Do NOT use requestIdleCallback for user-initiated actions requiring immediate feedback, rendering updates the user is waiting for, or time-sensitive operations." ;
    oc:hasRationale "Deferred work may execute much later or not at all, breaking expected UI responsiveness for critical paths." ;
    oc:severityLevel "CRITICAL" .

