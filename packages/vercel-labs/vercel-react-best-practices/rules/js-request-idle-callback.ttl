                            oc:itemText "Lazy initialization of non-critical features" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Analytics and telemetry" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
