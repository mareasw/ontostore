oc:skill_vercel_labs_vercel_react_best_practices_js_request_idle_callback a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "js-request-idle-callback" ;
    skos:broader "Performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "ee08f83905b4011abbc33d594033157d77561b5bbd9b36b04f0f409581ffec32" ;
    oc:differentia "defers non-critical browser work to idle periods using requestIdleCallback to keep the main thread responsive" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:BrowserBusyTimeout ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 15 ;
                    oc:textContent "**When NOT to use:**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 11 ;
                    oc:textContent "**With fallback for unsupported browsers:**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**Incorrect (blocks main thread during user interaction):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function handleSearch(query: string) {
  const results = searchItems(query)
  setResults(results)

  // These block the main thread immediately
  analytics.track('search', { query })
  saveToRecentSearches(query)
  prefetchTopResults(results.slice(0, 3))
}
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 4 ;
                    oc:sourceLocation "lines 16-26" ],
