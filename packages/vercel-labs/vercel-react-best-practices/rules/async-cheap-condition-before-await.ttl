@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_async_cheap_condition_before_await a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "async-cheap-condition-before-await" ;
    skos:broader "Performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "03107c1f70a293cd58a8abc5474c5548e20ea4efdf01b6d45aae7ad0ac1cb32c" ;
    oc:differentia "that evaluates cheap synchronous conditions before expensive async calls to short-circuit unnecessary network requests" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:SemanticChangeDetected ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Check Cheap Conditions Before Async Flags
impact: HIGH
impactDescription: avoids unnecessary async work when a synchronous guard already fails
tags: async, await, feature-flags, short-circuit, conditional
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "This is a specialization of [Defer Await Until Needed](./async-defer-await.md) for `flag && cheapCondition` style checks." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**Incorrect:**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 7 ;
                    oc:textContent "This matters when `getFlag` hits the network, a feature-flag service, or `React.cache` / DB work: skipping it when `someCondition` is false removes that cost on the cold path." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 8 ;
                    oc:textContent "Keep the original order if `someCondition` is expensive, depends on the flag, or you must run side effects in a fixed order." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """if (someCondition) {
  const someFlag = await getFlag()
  if (someFlag) {
    // ...
  }
}
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 6 ;
                    oc:sourceLocation "lines 26-33" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 5 ;
                    oc:textContent "**Correct:**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """const someFlag = await getFlag()

if (someFlag && someCondition) {
  // ...
}
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 4 ;
                    oc:sourceLocation "lines 16-22" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "When a branch uses `await` for a flag or remote value and also requires a **cheap synchronous** condition (local props, request metadata, already-loaded state), evaluate the cheap condition **first**. Otherwise you pay for the async call even when the compound condition can never be true." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Check Cheap Conditions Before Async Flags" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Reorder compound conditions to evaluate cheap synchronous guards before expensive async calls" ;
            oc:hasStep _:ref_1959f9285cae3426,
                _:ref_2c96b0b522bb60ee,
                _:ref_68573664c2d5f188,
                [ a oc:WorkflowStep ;
                    dcterms:description "Verify behavior is unchanged for all logical paths (condition true/false, async resolves true/false)" ;
                    oc:expectedOutcome "All tests pass, no semantic change" ;
                    oc:stepDependsOn _:ref_2c96b0b522bb60ee ;
                    oc:stepId "4-test" ] ;
            oc:workflowId "refactor-async-condition-order" ;
            oc:workflowName "Refactor Async Condition Evaluation Order" ] ;
    oc:impartsKnowledge oc:kn_214bf839,
        oc:kn_4281030f,
        oc:kn_b7d5fc80,
        oc:kn_bad6d1db,
        oc:kn_f6a9a154 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CodeExists ;
    oc:resolvesIntent "avoid unnecessary async calls",
        "improve code performance with feature flags",
        "optimize async condition evaluation" ;
    oc:yieldsState oc:CodeOptimized .

oc:kn_214bf839 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying broader async optimization strategies" ;
    oc:directiveContent "This is a specialization of 'Defer Await Until Needed' for `flag && cheapCondition` style compound checks." ;
    oc:hasRationale "Connects this specific pattern to the more general principle of deferring async work, providing a coherent optimization framework" .

oc:kn_4281030f a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When assessing whether to apply this pattern" ;
    oc:directiveContent "The performance benefit is proportional to how often the cheap condition is false and how expensive the async call is (network round-trip, feature-flag service, DB query, React.cache miss)." ;
    oc:hasRationale "The optimization only matters when both the false-positive rate of the cheap condition is high and the async call is costly" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b7d5fc80 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing compound conditions that mix synchronous checks with async flag/remote value lookups" ;
    oc:directiveContent "Evaluate cheap synchronous conditions (local props, request metadata, already-loaded state) before awaiting async flag values or remote calls." ;
    oc:hasRationale "Skipping the async call entirely when the cheap condition is false removes network/DB cost on the cold path" ;
    oc:severityLevel "HIGH" .

oc:kn_bad6d1db a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing `if (await getFlag() && someCondition)` style checks" ;
    oc:directiveContent "Never await an async flag or remote value if a cheap synchronous guard already fails the compound condition." ;
    oc:hasRationale "Paying for the async call when the compound condition can never be true wastes network, feature-flag service, or DB resources" ;
    oc:severityLevel "HIGH" .

oc:kn_f6a9a154 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When considering reordering conditions for optimization" ;
    oc:directiveContent "Keep the original evaluation order if the synchronous condition is expensive, depends on the async flag result, or side effects must run in a fixed order." ;
    oc:hasRationale "Reordering could change semantics or introduce bugs when conditions have dependencies or side-effect ordering requirements" ;
    oc:severityLevel "MEDIUM" .

_:ref_1959f9285cae3426 a oc:WorkflowStep ;
    dcterms:description "Identify compound conditions mixing async flag/remote lookups with cheap synchronous checks" ;
    oc:expectedOutcome "List of code locations with `await` followed by `&&` with a cheap condition" ;
    oc:stepId "1-identify" .

_:ref_2c96b0b522bb60ee a oc:WorkflowStep ;
    dcterms:description "Move the cheap synchronous condition before the await, wrapping the async call inside the synchronous guard" ;
    oc:expectedOutcome "Async call is only invoked when the cheap condition passes" ;
    oc:stepDependsOn _:ref_68573664c2d5f188 ;
    oc:stepId "3-reorder" .

_:ref_68573664c2d5f188 a oc:WorkflowStep ;
    dcterms:description "Verify the synchronous condition is cheap, does not depend on the async result, and side-effect ordering is not required" ;
    oc:expectedOutcome "Confirmation that reordering is safe" ;
    oc:stepDependsOn _:ref_1959f9285cae3426 ;
    oc:stepId "2-verify" .

