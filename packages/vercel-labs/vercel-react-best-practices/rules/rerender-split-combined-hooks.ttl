@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_rerender_split_combined_hooks a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rerender-split-combined-hooks" ;
    skos:broader "React performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "6f45d703343484ef9acef9388397f3642966ae6a5a258899a0cf1f9977cfbf6c" ;
    oc:differentia "splits combined hook computations with independent dependencies into separate hooks to avoid unnecessary recomputation" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_4459d8a4,
        oc:kn_49334fe4,
        oc:kn_c2ee26ab,
        oc:kn_e3ebcdde,
        oc:kn_e5f4afa6 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "optimize React rerender performance",
        "reduce unnecessary recomputation in React hooks",
        "split combined useEffect side effects",
        "split combined useMemo computations" .

oc:kn_4459d8a4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a hook contains multiple independent tasks with different dependencies" ;
    oc:directiveContent "Split combined hook computations into separate hooks, each with its own minimal dependency array" ;
    oc:hasRationale "Separate hooks allow React to skip recomputation for tasks whose dependencies haven't changed, improving render performance" ;
    oc:severityLevel "HIGH" .

oc:kn_49334fe4 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating whether to refactor combined hooks" ;
    oc:directiveContent "Splitting combined hooks has MEDIUM impact — it avoids recomputing independent steps but the performance gain depends on the computational cost of the tasks involved" ;
    oc:hasRationale "The benefit is proportional to the cost of the recomputed tasks and the frequency of dependency changes that don't affect all tasks" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c2ee26ab a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or writing useMemo or useEffect calls" ;
    oc:directiveContent "If two computations or side effects depend on different values, they should be in different hooks" ;
    oc:hasRationale "Dependency array mismatch is a strong signal that the hook is doing too much and can be split for better performance" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e3ebcdde a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When the project has React Compiler enabled" ;
    oc:directiveContent "React Compiler can automatically optimize dependency tracking and may handle some combined hook cases, making manual splitting unnecessary" ;
    oc:hasRationale "React Compiler performs automatic memoization and dependency optimization, reducing the need for manual hook splitting" ;
    oc:severityLevel "LOW" .

oc:kn_e5f4afa6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing React hooks that perform multiple tasks" ;
    oc:directiveContent "Never combine independent computations or side effects in a single useMemo or useEffect when they have different dependencies" ;
    oc:hasRationale "Combined hooks rerun all tasks when any dependency changes, causing unnecessary recomputation for tasks unrelated to the changed value" ;
    oc:severityLevel "HIGH" .

