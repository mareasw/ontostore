oc:skill_vercel_labs_vercel_react_best_practices_js_combine_iterations a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "js-combine-iterations" ;
    skos:broader "Performance optimization technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "71add08aeeb43091d4ff4c0b2842cce8b4bdef8ad3e732cc034bb5a84827e746" ;
    oc:differentia "combines multiple array iteration operations (filter/map) into a single loop to reduce unnecessary passes over data" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_3e74a056,
        oc:req_d16d3697 ;
    oc:impartsKnowledge oc:kn_033d0496,
        oc:kn_2b2c8e4e,
        oc:kn_3ea4cf98,
        oc:kn_43d4f9eb,
        oc:kn_7b1fdda2 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "improve array processing performance",
        "optimize array iterations",
        "reduce loop overhead in JavaScript",
        "refactor multiple filter/map calls into one pass" ;
    oc:yieldsState oc:ArrayIterationsOptimized .

oc:kn_033d0496 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During code review or refactoring of array-heavy JavaScript/TypeScript modules." ;
    oc:directiveContent "Consider combining iterations when you have 2 or more filter/map calls on the same source array, especially if the array is large or the code runs in a hot path." ;
    oc:hasRationale "For small arrays or non-critical paths, the readability of chained methods may outweigh the minor performance gain. This heuristic helps decide when the optimization is worthwhile." .

oc:kn_2b2c8e4e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing JavaScript/TypeScript code that filters or maps the same array multiple times to produce different subsets or transformations." ;
    oc:directiveContent "Avoid chaining multiple .filter() or .map() calls that each iterate the entire array independently when they can be combined into a single pass." ;
    oc:hasRationale "Each chained iteration method creates a full pass over the array, multiplying time complexity by the number of iterations. For large arrays this becomes a measurable performance bottleneck." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3ea4cf98 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When refactoring from functional style (filter/map) to imperative style (for loop)." ;
    oc:directiveContent "The combined iteration pattern requires pre-declaring result arrays and manually managing push logic, which increases code verbosity compared to functional chaining." ;
    oc:hasRationale "The tradeoff is readability vs performance. Teams should establish consistent patterns to avoid mixing styles incoherently across a codebase." ;
    oc:severityLevel "LOW" .

oc:kn_43d4f9eb a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "Always, when evaluating performance of array processing code." ;
    oc:directiveContent "Multiple filter/map calls on the same array multiply iteration count linearly. Three .filter() calls = three full passes. A combined for loop = one pass regardless of how many categories are extracted." ;
    oc:hasRationale "Understanding the iteration cost helps developers make informed tradeoffs between readability (chained methods) and performance (combined loop)." ;
    oc:severityLevel "LOW" .

oc:kn_7b1fdda2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting multiple non-mutually-exclusive subsets from the same source array." ;
    oc:directiveContent "Prefer a single for...of loop with conditional push operations when you need to categorize array elements into multiple buckets." ;
    oc:hasRationale "A single iteration reduces time from O(n*k) where k is the number of filters to O(n), while maintaining readable and maintainable code." .

oc:req_3e74a056 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "TypeScript or JavaScript syntax" .

oc:req_d16d3697 a oc:RequirementKnowledge ;
