    oc:resolvesIntent "combine multiple filter calls",
        "optimize array iterations",
        "reduce loop overhead in JavaScript" ;
    oc:yieldsState oc:CodeOptimized .

oc:kn_3bc6d433 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating performance impact of array operations" ;
    oc:directiveContent "Multiple .filter() calls on the same array cost O(k * n) where k is the number of filters; combining into one loop costs O(n)." ;
    oc:hasRationale "For large arrays, reducing iterations from k to 1 provides a linear speedup factor of k." ;
    oc:severityLevel "LOW" .

oc:kn_46ecb003 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When combining multiple independent array filters into a single pass" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """const results: TypeA[] = []
const resultsB: TypeB[] = []
for (const item of items) {
  if (conditionA) results.push(item)
  if (conditionB) resultsB.push(item)
}""" ;
    oc:hasRationale "A single for-of loop with conditional pushes collects all derived arrays in one traversal." .

oc:kn_7a0be2b8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing array filtering/mapping logic in JavaScript or TypeScript" ;
    oc:directiveContent "When you need to produce 2+ independent derived arrays from the same source, combine into a single for loop with multiple conditional pushes." ;
    oc:hasRationale "Single-pass iteration reduces total work and improves cache locality." .

oc:kn_a09fa515 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filtering or mapping the same array multiple times" ;
    oc:directiveContent "Avoid chaining multiple .filter() or .map() calls on the same array when results are independent — each call creates a separate iteration." ;
    oc:hasRationale "Each chained iteration traverses the entire array again, multiplying time complexity by the number of operations." ;
    oc:severityLevel "MEDIUM" .

