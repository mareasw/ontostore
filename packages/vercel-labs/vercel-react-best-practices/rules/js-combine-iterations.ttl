oc:skill_vercel_labs_vercel_react_best_practices_js_combine_iterations a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "js-combine-iterations" ;
    skos:broader "Performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "71add08aeeb43091d4ff4c0b2842cce8b4bdef8ad3e732cc034bb5a84827e746" ;
    oc:differentia "Combines multiple array filter/map operations into a single iteration to reduce loop overhead" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Multiple `.filter()` or `.map()` calls iterate the array multiple times. Combine into one loop." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """const admins: User[] = []
const testers: User[] = []
const inactive: User[] = []

for (const user of users) {
  if (user.isAdmin) admins.push(user)
  if (user.isTester) testers.push(user)
  if (!user.isActive) inactive.push(user)
}
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 22-32" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """const admins = users.filter(u => u.isAdmin)
const testers = users.filter(u => u.isTester)
const inactive = users.filter(u => !u.isActive)
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-18" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Incorrect (3 iterations):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Correct (1 iteration):**" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Combine Multiple Array Iterations" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Combine Multiple Array Iterations
impact: LOW-MEDIUM
impactDescription: reduces iterations
tags: javascript, arrays, loops, performance
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:impartsKnowledge oc:kn_3bc6d433,
