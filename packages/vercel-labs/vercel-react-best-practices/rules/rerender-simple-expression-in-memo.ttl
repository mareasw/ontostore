oc:skill_vercel_labs_vercel_react_best_practices_rerender_simple_expression_in_memo a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rerender-simple-expression-in-memo" ;
    skos:broader "Performance optimization rule" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "5bdcf2d1558ba5204e643c887b7b4060f89630969425651eb68e96427d97f800" ;
    oc:differentia "advises against wrapping simple primitive-returning expressions in useMemo since the hook overhead exceeds the computation cost" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent """When an expression is simple (few logical or arithmetical operators) and has a primitive result type (boolean, number, string), do not wrap it in `useMemo`.
Calling `useMemo` and comparing hook dependencies may consume more resources than the expression itself.""" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function Header({ user, notifications }: Props) {
  const isLoading = user.isLoading || notifications.isLoading

  if (isLoading) return <Skeleton />
  // return some markup
}
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 28-35" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function Header({ user, notifications }: Props) {
  const isLoading = useMemo(() => {
    return user.isLoading || notifications.isLoading
  }, [user.isLoading, notifications.isLoading])

  if (isLoading) return <Skeleton />
  // return some markup
}
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 15-24" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Incorrect:**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Correct:**" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Do not wrap a simple expression with a primitive result type in useMemo" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Do not wrap a simple expression with a primitive result type in useMemo
impact: LOW-MEDIUM
impactDescription: wasted computation on every render
tags: rerender, useMemo, optimization
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:impartsKnowledge oc:kn_439ca1e7,
        oc:kn_59f1c459,
        oc:kn_bd537dfb,
        oc:kn_e90374ed ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:ReactComponentExists ;
    oc:resolvesIntent "avoid unnecessary useMemo wrapping",
        "identify over-optimized simple expressions",
        "optimize React component rendering" ;
    oc:yieldsState oc:PerformanceOptimized .

oc:kn_439ca1e7 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When profiling React component render performance" ;
    oc:directiveContent "useMemo incurs overhead from hook call setup and dependency array comparison on every render, even when the memoized value is reused." ;
    oc:hasRationale "Understanding the fixed cost of useMemo is essential to making informed optimization decisions." ;
    oc:severityLevel "LOW" .

oc:kn_59f1c459 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating whether to add useMemo to a variable assignment in a React component" ;
    oc:directiveContent "Do not wrap simple expressions (few logical/arithmetic operators) with primitive result types (boolean, number, string) in useMemo — the hook call and dependency comparison overhead costs more than the expression itself." ;
    oc:hasRationale "Calling useMemo and comparing hook dependencies consumes more resources than computing a simple primitive expression directly on every render." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bd537dfb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether useMemo is appropriate for a given expression" ;
    oc:directiveContent "useMemo is only worth the cost when the expression is computationally expensive or returns a non-primitive (object/array) reference that would cause unnecessary re-renders downstream." ;
    oc:hasRationale "Primitive values are compared by value, so they never cause referential inequality issues that useMemo is designed to prevent." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e90374ed a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing a React component for useMemo usage" ;
    oc:directiveContent "An expression is 'simple' if it uses few logical or arithmetical operators. Such expressions with primitive return types should be computed inline without memoization." ;
    oc:hasRationale "The cost model for useMemo only favors memoization when the expression computation exceeds the cost of the hook infrastructure." ;
    oc:severityLevel "LOW" .

