@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_rerender_simple_expression_in_memo a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rerender-simple-expression-in-memo" ;
    skos:broader "React performance optimization guideline" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "5bdcf2d1558ba5204e643c887b7b4060f89630969425651eb68e96427d97f800" ;
    oc:differentia "that identifies unnecessary useMemo wrapping of simple primitive expressions as an anti-pattern" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_4e8fd3ed,
        oc:kn_b8426e94,
        oc:kn_c6544f82,
        oc:kn_f570b162 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ReactComponentExists ;
    oc:resolvesIntent "identify unnecessary useMemo usage",
        "optimize React component re-renders",
        "refactor simple expressions out of useMemo" ;
    oc:yieldsState oc:ExpressionOptimized .

oc:kn_4e8fd3ed a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to memoize a value in a React component" ;
    oc:directiveContent "Only use useMemo when the computation is expensive enough that the memoization overhead is justified, such as creating non-primitive values (objects, arrays) passed as props or dependencies, or performing costly calculations." ;
    oc:hasRationale "Premature memoization adds complexity and can degrade performance rather than improve it." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b8426e94 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing React component code for useMemo usage" ;
    oc:directiveContent "An expression qualifies as 'simple' when it involves few logical or arithmetic operators and produces a primitive result type (boolean, number, string). Such expressions should not be memoized." ;
    oc:hasRationale "Primitive comparisons are cheap; the memoization infrastructure costs more than the computation it attempts to save." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c6544f82 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When a React component containing unnecessary useMemo calls renders" ;
    oc:directiveContent "Wrapping simple primitive expressions in useMemo results in wasted computation on every render due to dependency comparison overhead, with LOW-MEDIUM impact severity." ;
    oc:hasRationale "The dependency array comparison and memoization cache lookup are themselves operations that execute on every render, adding overhead without meaningful savings for simple expressions." ;
    oc:severityLevel "LOW" .

oc:kn_f570b162 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating whether to add useMemo to a simple expression in a React component" ;
    oc:directiveContent "Do not wrap simple expressions with primitive result types (boolean, number, string) in useMemo. The overhead of calling useMemo and comparing dependencies may exceed the cost of the expression itself." ;
    oc:hasRationale "useMemo has its own computational cost for dependency comparison and memoization overhead. For simple expressions (few logical or arithmetic operators), this overhead outweighs any benefit from caching the result." ;
    oc:severityLevel "MEDIUM" .

