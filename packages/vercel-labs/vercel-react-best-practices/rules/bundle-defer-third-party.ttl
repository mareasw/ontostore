@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_bundle_defer_third_party a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "bundle-defer-third-party" ;
    skos:broader "Performance optimization technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "3719fb47b191e8db4fe22686ec88448ad5af9e6838585425abbe103d0b642e37" ;
    oc:differentia "defers non-critical third-party libraries like analytics and logging until after hydration using Next.js dynamic imports" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "component name or import path to defer" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_0bd0a991,
        oc:kn_49825b22,
        oc:kn_66bf083f,
        oc:kn_909bdcb5,
        oc:kn_b23719a8 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "defer third-party script loading",
        "improve hydration performance",
        "lazy-load analytics libraries",
        "optimize initial bundle size" .

oc:kn_0bd0a991 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When architecting the dependency loading strategy for a Next.js application" ;
    oc:directiveContent "Classify all third-party dependencies as either critical (blocks interaction) or non-critical (observational) and apply deferred loading accordingly." ;
    oc:hasRationale "A deliberate classification ensures consistent performance optimization without accidentally deferring essential functionality." .

oc:kn_49825b22 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When integrating any third-party library that does not contribute to initial page render or user interaction" ;
    oc:directiveContent "Use next/dynamic with { ssr: false } to defer non-critical third-party libraries so they load after hydration." ;
    oc:hasRationale "Dynamic imports with SSR disabled ensure the library is only loaded client-side after the page is interactive, keeping the main bundle lean." .

oc:kn_66bf083f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding analytics, logging, or error tracking libraries to a Next.js layout or page" ;
    oc:directiveContent "Never import non-critical third-party libraries (analytics, logging, error tracking) as static imports in the initial bundle, as they block hydration and delay Time to Interactive." ;
    oc:hasRationale "Static imports force these libraries to be parsed and executed before the page becomes interactive, degrading user-perceived performance." ;
    oc:severityLevel "HIGH" .

oc:kn_909bdcb5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether a third-party library should use dynamic imports" ;
    oc:directiveContent "Libraries that affect rendering or user interaction must NOT be deferred — only defer libraries that are purely observational (analytics, logging, error tracking)." ;
    oc:hasRationale "Deferring a library that provides visible UI or handles user input would break functionality or cause layout shifts." .

oc:kn_b23719a8 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When relying on deferred analytics or tracking for early page events" ;
    oc:directiveContent "Deferred libraries will not be available during server-side rendering and may briefly be absent on the client immediately after page load." ;
    oc:hasRationale "Events that fire before the deferred library loads may be missed, so critical tracking may need an alternative capture mechanism." ;
    oc:severityLevel "MEDIUM" .

