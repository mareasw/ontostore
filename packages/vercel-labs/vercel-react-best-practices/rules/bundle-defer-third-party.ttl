oc:kn_0d9b0aaf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deferring third-party React components in Next.js" ;
    oc:directiveContent "Use next/dynamic with { ssr: false } to load non-critical third-party components after client-side hydration completes." ;
    oc:hasRationale "The { ssr: false } option ensures the component is never server-rendered, and dynamic() code-splits it into a separate chunk loaded on demand." ;
    oc:severityLevel "HIGH" .

oc:kn_3d496b3b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating whether to defer any third-party dependency" ;
    oc:directiveContent "If a third-party library does not contribute to initial render or user interaction, it should be deferred until after hydration." ;
    oc:hasRationale "Deferring non-critical scripts separates the critical rendering path from background initialization, improving Core Web Vitals." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c2d9014b a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When relying on deferred analytics or tracking" ;
    oc:directiveContent "Deferring third-party libraries means their functionality (e.g., analytics events) will not be available until after the component dynamically loads post-hydration." ;
    oc:hasRationale "Early user interactions may not be captured if the deferred library hasn't loaded yet — this is an acceptable trade-off for faster initial page load." ;
    oc:severityLevel "LOW" .

oc:kn_fd23eae9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding analytics, logging, or error tracking to a Next.js app" ;
    oc:directiveContent "Never import non-critical third-party libraries (analytics, logging, error tracking) as static imports in the root layout — they will block the initial bundle and delay hydration." ;
    oc:hasRationale "Static imports force these libraries into the initial JavaScript bundle, increasing time-to-interactive even though they serve no user-facing purpose during initial page load." ;
    oc:severityLevel "HIGH" .

_:ref_b203629309345f1d a oc:WorkflowStep ;
    dcterms:description "Identify third-party imports in root layout that are non-critical (analytics, logging, error tracking)" ;
    oc:expectedOutcome "List of imports that can be safely deferred" ;
    oc:stepId "identify-non-critical" .

_:ref_ca2065c0d9e0eef7 a oc:WorkflowStep ;
    dcterms:description "Replace the static import with next/dynamic, using .then(m => m.NamedExport) and { ssr: false }" ;
    oc:expectedOutcome "Component is code-split into a separate chunk loaded only on client" ;
    oc:stepDependsOn _:ref_b203629309345f1d ;
    oc:stepId "convert-to-dynamic" .

