        oc:kn_d37cc2f3 ;
    oc:isUserInvocable true ;
    oc:nature "Technique" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "defer off-screen content rendering",
        "improve initial render performance",
        "optimize rendering of long lists" ;
    oc:yieldsState oc:RenderingOptimized .

oc:kn_05dbe007 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using content-visibility on any element" ;
    oc:directiveContent "Always pair content-visibility: auto with contain-intrinsic-size to provide an estimated dimensions hint" ;
    oc:hasRationale "Without contain-intrinsic-size, the browser has no size estimate and scrollbar behavior will be erratic as off-screen items are rendered" .

oc:kn_0fcdb577 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting contain-intrinsic-size" ;
    oc:directiveContent "contain-intrinsic-size value should approximate the actual rendered height of each item to avoid scrollbar jitter" ;
    oc:hasRationale "Inaccurate size estimates cause visible layout shifts and poor scroll experience" ;
    oc:severityLevel "MEDIUM" .

oc:kn_26d1b1f0 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying content-visibility to list items" ;
    oc:codeLanguage "css" ;
    oc:directiveContent """.message-item {
  content-visibility: auto;
  contain-intrinsic-size: 0 80px;
}""" ;
    oc:hasRationale "content-visibility: auto defers rendering of off-screen elements; contain-intrinsic-size provides an estimated size to prevent layout shift during scroll" .

oc:kn_a041f3ce a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering long scrollable lists (message feeds, data tables, infinite scroll)" ;
    oc:directiveContent "Apply content-visibility: auto to items in lists with 100+ elements for significant initial render speedups (~10× faster for 1000 items)" ;
    oc:hasRationale "Browser skips layout/paint for off-screen items, reducing initial render workload dramatically" .

oc:kn_d37cc2f3 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "Long virtualized lists with uniform item heights" ;
    oc:directiveContent "For 1000 messages, browser skips layout/paint for ~990 off-screen items, yielding approximately 10× faster initial render" ;
    oc:hasRationale "Quantified impact helps decide when to apply this optimization" .

