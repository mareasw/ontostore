@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_rendering_content_visibility a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rendering-content-visibility" ;
    skos:broader "CSS rendering optimization technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "64eee6d5b916fe74df33363994b27fc7f71bea3bcedc7ee04bda23107ca3e6e4" ;
    oc:differentia "uses content-visibility: auto to defer off-screen rendering of long list items for faster initial paint" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "CSS class or component with long scrollable list" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_09fe74a8,
        oc:kn_1c9b6ab2,
        oc:kn_4aa1c770,
        oc:kn_6e74494b ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "defer off-screen content rendering",
        "improve initial page load performance",
        "optimize rendering of long lists" ;
    oc:yieldsState oc:ContentVisibilityApplied .

oc:kn_09fe74a8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating whether to apply content-visibility to a component" ;
    oc:directiveContent "content-visibility is most impactful when off-screen items outnumber visible items by a large ratio (e.g., 990 out of 1000 items off-screen)." ;
    oc:hasRationale "The performance gain is proportional to the number of skipped items; small lists with most items visible see negligible benefit." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1c9b6ab2 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When measuring or estimating rendering performance improvements" ;
    oc:directiveContent "For a list of 1000 messages, applying content-visibility: auto can yield approximately 10× faster initial render by skipping layout/paint on ~990 off-screen items." ;
    oc:hasRationale "This provides a concrete benchmark for expecting ~10× improvement in initial render speed for long scrollable lists." ;
    oc:severityLevel "LOW" .

oc:kn_4aa1c770 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering scrollable lists with many items (e.g., 100+ messages, rows, cards)" ;
    oc:directiveContent "Apply `content-visibility: auto` combined with `contain-intrinsic-size` to long list items to skip layout/paint for off-screen elements." ;
    oc:hasRationale "The browser can skip layout, style, and paint for off-screen items, yielding up to 10× faster initial render for lists of 1000+ items." ;
    oc:severityLevel "HIGH" .

oc:kn_6e74494b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying content-visibility to any scrollable container element" ;
    oc:directiveContent "Always pair `content-visibility: auto` with `contain-intrinsic-size` to provide an estimated size for hidden elements." ;
    oc:hasRationale "Without contain-intrinsic-size, the browser cannot estimate the scroll area, causing scrollbar jitter and incorrect scroll positions." ;
    oc:severityLevel "CRITICAL" .

