@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_sections a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "sections" ;
    skos:broader "Performance optimization taxonomy" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "01c59969e4e867f0708c8f8ef9c6d87fab9a07d0586244f429ff84013db8a115" ;
    oc:differentia "that organizes React and Next.js performance rules into prioritized sections ranked by impact level from critical waterfall elimination to advanced micro-optimizations" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "section-id (async, bundle, server, client, rerender, rendering, js, advanced)" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_515fae66,
        oc:kn_520eb62d,
        oc:kn_9fb6ba16,
        oc:kn_b60369f3,
        oc:kn_f53183ec ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "identify which performance improvements yield the largest gains",
        "navigate React/Next.js performance optimization sections by impact",
        "understand performance optimization priorities" ;
    oc:yieldsState oc:OptimizationPriorityKnown .

oc:kn_515fae66 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which performance optimizations to implement first in a React/Next.js application" ;
    oc:directiveContent "Performance optimizations should be prioritized by impact: waterfalls and bundle size are CRITICAL, server-side and client-side data fetching are HIGH/MEDIUM-HIGH, re-renders and rendering are MEDIUM, JS perf is LOW-MEDIUM, and advanced patterns are LOW." ;
    oc:hasRationale "Prioritization by impact ensures engineering effort yields maximum user-perceivable improvements rather than wasting time on micro-optimizations while critical issues remain unaddressed." ;
    oc:severityLevel "HIGH" .

oc:kn_520eb62d a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When considering advanced optimization techniques like complex memoization or custom scheduling" ;
    oc:directiveContent "Advanced patterns (section 8) require careful implementation and apply only to specific cases — they should not be the first optimization attempted." ;
    oc:hasRationale "Advanced patterns have LOW impact relative to other sections and carry higher risk of introducing complexity or bugs; simpler high-impact fixes should always be exhausted first." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9fb6ba16 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or writing async data fetching code in React/Next.js components" ;
    oc:directiveContent "Sequential awaits that create request waterfalls are the #1 performance killer — each one adds full network latency." ;
    oc:hasRationale "Waterfalls compound latency multiplicatively; eliminating them yields the single largest performance gain available in most applications." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b60369f3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring or consuming performance rules within this skill's documentation" ;
    oc:directiveContent "Section IDs (async, bundle, server, client, rerender, rendering, js, advanced) are filename prefixes used to group rules — they must be used consistently for rule organization." ;
    oc:hasRationale "Consistent naming ensures rules can be correctly mapped to their section and impact level for progressive disclosure and targeted application." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f53183ec a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing application loading performance" ;
    oc:directiveContent "Reducing initial bundle size directly improves Time to Interactive and Largest Contentful Paint — it should be addressed immediately after waterfalls." ;
    oc:hasRationale "Bundle size affects both TTI and LCP, the two most user-facing Core Web Vitals metrics, making it second only to waterfall elimination in priority." ;
    oc:severityLevel "HIGH" .

