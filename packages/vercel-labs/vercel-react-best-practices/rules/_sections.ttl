    oc:nature "Concept" ;
    oc:resolvesIntent "identify performance optimization areas for React and Next.js",
        "navigate the vercel-react-best-practices skill sections",
        "prioritize React performance improvements by impact level" .

oc:kn_1bfa24a5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When prioritizing React/Next.js performance work" ;
    oc:directiveContent "Eliminating async waterfalls is the highest-impact optimization (#1 priority, CRITICAL impact), followed by bundle size optimization (#2, CRITICAL), then server-side performance (#3, HIGH)." ;
    oc:hasRationale "Waterfalls add full network latency per sequential await — eliminating them yields the largest single gain. Bundle size directly impacts TTI and LCP." ;
    oc:severityLevel "CRITICAL" .

oc:kn_bb9c639c a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When navigating or referencing sub-skills within vercel-react-best-practices" ;
    oc:directiveContent "The 8 sections cover the full scope of React/Next.js performance optimization; section IDs (async, bundle, server, client, rerender, rendering, js, advanced) map to filename prefixes for rule grouping." ;
    oc:hasRationale "Section IDs are the linking mechanism between this registry and the actual rule files." .

oc:kn_d0a0352b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning a React/Next.js performance optimization sprint" ;
    oc:directiveContent "Address performance issues in section order: async waterfalls → bundle size → server-side → client-side data fetching → re-render → rendering → JS performance → advanced patterns." ;
    oc:hasRationale "Sections are ordered by decreasing impact; earlier sections yield disproportionately larger gains." ;
    oc:severityLevel "HIGH" .

oc:kn_f724b9c8 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When allocating limited development time for performance" ;
    oc:directiveContent "Focus optimization effort on CRITICAL sections (async, bundle) before HIGH (server) before MEDIUM (client, rerender, rendering) before LOW (js, advanced)." ;
    oc:hasRationale "Impact levels signal expected return on investment — critical sections address the #1 performance killer." .

