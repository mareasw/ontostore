oc:skill_vercel_labs_vercel_react_best_practices_js_hoist_regexp a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "js-hoist-regexp" ;
    skos:broader "optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "f9e9aef2f7c2307dd7310f283df85dcada45fc43e9bb941b0c3aa414dec21ec4" ;
    oc:differentia "hoists or memoizes RegExp creation outside of React component render paths to avoid unnecessary object recreation on every render cycle" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "React component code using RegExp" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_03a38ee7,
        oc:req_eb5171d4 ;
    oc:impartsKnowledge oc:kn_57f986a7,
        oc:kn_65618da9,
        oc:kn_9756277f,
        oc:kn_9e8dcfd2,
        oc:kn_f88818e0 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "avoid regexp recreation on every render",
        "hoist static regexp to module scope",
        "memoize dynamic regexp in react components",
        "optimize regexp usage in react components" ;
    oc:yieldsState oc:RegExpOptimized .

oc:kn_57f986a7 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When constructing RegExp from user-provided query strings" ;
    oc:directiveContent "When user input is interpolated into dynamic RegExp, always escape special regex characters to prevent both injection and malformed patterns." ;
    oc:hasRationale "Unescaped user input in RegExp can cause syntax errors or unintended regex behavior (ReDoS-like patterns)." ;
    oc:severityLevel "HIGH" .

oc:kn_65618da9 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using global RegExp at module scope or sharing a single RegExp instance across multiple calls" ;
    oc:directiveContent "Global RegExp (using /g flag) carries mutable lastIndex state that changes between .test() or .exec() calls, causing alternating true/false results on repeated calls with the same input." ;
    oc:hasRationale "The lastIndex mutation is a well-known JavaScript footgun that can cause intermittent bugs in component logic, especially with hoisted or shared regex instances." ;
    oc:severityLevel "HIGH" .

oc:kn_9756277f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing React components that use RegExp" ;
    oc:directiveContent "Never create RegExp objects directly inside the render body of a React component, as they will be recreated on every render cycle." ;
    oc:hasRationale "Recreating RegExp on every render is wasteful allocation and can degrade performance in frequently-rendered components." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9e8dcfd2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the RegExp pattern includes variable input like query strings" ;
    oc:directiveContent "For dynamic RegExp patterns that depend on props or state, wrap creation in useMemo() with the appropriate dependencies." ;
    oc:hasRationale "useMemo ensures the RegExp is only recreated when its dependencies actually change, not on every render." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f88818e0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the RegExp pattern does not depend on props or state" ;
    oc:directiveContent "Hoist static, constant RegExp patterns to module scope so they are created once and shared across all component instances." ;
    oc:hasRationale "Module-scoped RegExp avoids repeated allocation and is the simplest optimization for fixed patterns." ;
    oc:severityLevel "MEDIUM" .

oc:req_03a38ee7 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "JavaScript RegExp API" .

oc:req_eb5171d4 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "React hooks (useMemo)" .

