oc:skill_vercel_labs_vercel_react_best_practices_js_hoist_regexp a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "js-hoist-regexp" ;
    skos:broader "Performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "f9e9aef2f7c2307dd7310f283df85dcada45fc43e9bb941b0c3aa414dec21ec4" ;
    oc:differentia "hoists or memoizes RegExp creation outside React render paths to avoid per-render object allocation" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:RegExpMutableStateConflict ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Hoist RegExp Creation
impact: LOW-MEDIUM
impactDescription: avoids recreation
tags: javascript, regexp, optimization, memoization
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """const regex = /foo/g
regex.test('foo')  // true, lastIndex = 3
regex.test('foo')  // false, lastIndex = 0
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 8 ;
                    oc:sourceLocation "lines 41-45" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """const EMAIL_REGEX = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/

function Highlighter({ text, query }: Props) {
  const regex = useMemo(
    () => new RegExp(`(${escapeRegex(query)})`, 'gi'),
    [query]
  )
  const parts = text.split(regex)
  return <>{parts.map((part, i) => ...)}</>
}
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 24-35" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Incorrect (new RegExp every render):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent "**Warning (global regex has mutable state):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function Highlighter({ text, query }: Props) {
  const regex = new RegExp(`(${query})`, 'gi')
  const parts = text.split(regex)
  return <>{parts.map((part, i) => ...)}</>
}
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-20" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Correct (memoize or hoist):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 7 ;
                    oc:textContent "Global regex (`/g`) has mutable `lastIndex` state:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Don't create RegExp inside render. Hoist to module scope or memoize with `useMemo()`." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Hoist RegExp Creation" ] ;
    oc:impartsKnowledge oc:kn_25492df3,
        oc:kn_51fa4db4,
        oc:kn_598f5b6a,
        oc:kn_86d3fced,
        oc:kn_a37d77a0 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ReactComponentDefined ;
    oc:resolvesIntent "avoid recreating RegExp on every render",
        "fix mutable state bugs with global regex",
        "optimize regex performance in React components" ;
    oc:yieldsState oc:RegExpOptimized .

oc:kn_25492df3 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a component needs a RegExp derived from props or state" ;
    oc:directiveContent "Hoist static regex patterns to module scope: `const MY_REGEX = /^pattern$/` — for dynamic patterns dependent on props/state, wrap in `useMemo(() => new RegExp(...), [deps])`." ;
    oc:hasRationale "Module-scope hoisting is free; useMemo only re-creates when dependencies change, avoiding redundant allocation." .

oc:kn_51fa4db4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing React components that use regular expressions" ;
    oc:directiveContent "Never create a new RegExp inside a React component's render body — it allocates a fresh object on every render cycle." ;
    oc:hasRationale "Unnecessary per-render allocation wastes memory and GC pressure, especially in frequently re-rendering components." ;
    oc:severityLevel "MEDIUM" .

oc:kn_598f5b6a a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using shared or hoisted regex with the /g flag" ;
    oc:directiveContent "Global regex (with /g flag) carries mutable `lastIndex` state — calling `.test()` or `.exec()` advances it, causing alternating true/false results on repeated calls with the same input." ;
    oc:hasRationale "This is a well-known JavaScript footgun: a hoisted /g regex used across renders or call sites will produce inconsistent results due to internal state mutation." ;
    oc:severityLevel "HIGH" .

oc:kn_86d3fced a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between hoisting vs memoizing a RegExp" ;
    oc:directiveContent "Use module-scope constants for fixed patterns (e.g., email validation); use `useMemo` only for patterns that depend on props or state; always escape dynamic input with an escape function before embedding in RegExp." ;
    oc:hasRationale "Fixed patterns never change and should never be in render scope; dynamic patterns must be memoized to balance correctness and performance." .

oc:kn_a37d77a0 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When hoisting regex to module scope with the global flag" ;
    oc:directiveContent "Shared module-scope RegExp objects with the /g flag have side-effectful `.test()` and `.exec()` methods that mutate internal `lastIndex`." ;
    oc:hasRationale "This side effect can cause non-deterministic behavior in concurrent or reused contexts." ;
    oc:severityLevel "HIGH" .

