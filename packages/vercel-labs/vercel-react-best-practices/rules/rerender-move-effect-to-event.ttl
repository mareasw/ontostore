@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_rerender_move_effect_to_event a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rerender-move-effect-to-event" ;
    skos:broader "React performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "abc2cbf167bee056743023351e96806a411d3398da8802093620aecf0721f029" ;
    oc:dependsOnSkill oc:skill_vercel_react_best_practices ;
    oc:differentia "moves side effects triggered by user actions from useEffect into event handlers to prevent unnecessary re-runs and duplicate side effects" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "React component code with useEffect that handles user interactions" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_53505c82,
        oc:kn_7673a79a,
        oc:kn_d22b1bc0,
        oc:kn_ef978345,
        oc:kn_f5bfc6c1 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "eliminate duplicate side effects from useEffect",
        "fix unnecessary effect re-runs",
        "optimize React component re-rendering behavior",
        "refactor interaction logic from effects to event handlers" .

oc:kn_53505c82 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing state management for user interactions in React components" ;
    oc:directiveContent "Do not introduce intermediate state variables solely to trigger effects from user actions. The event handler itself is the correct trigger mechanism." ;
    oc:hasRationale "Each unnecessary state variable added to trigger an effect creates additional re-render cycles and widens the dependency surface for unrelated changes" .

oc:kn_7673a79a a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When validating that a refactor from useEffect to event handler was successful" ;
    oc:directiveContent "After refactoring, the interaction logic should execute exactly once per user action regardless of other state changes (theme, context, props) in the component." ;
    oc:hasRationale "The primary signal that the pattern was applied correctly is that the side effect is no longer sensitive to unrelated dependency changes" .

oc:kn_d22b1bc0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When architecting React component logic and deciding between useEffect vs event handlers" ;
    oc:directiveContent "Separate interaction-driven logic (belongs in event handlers) from synchronization-driven logic (belongs in effects). User actions are discrete events, not continuous state to synchronize with." ;
    oc:hasRationale "This separation of concerns keeps the code predictable — event handlers fire exactly when the user acts, while effects handle syncing with external systems over time" .

oc:kn_ef978345 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding where to place interaction logic in React components" ;
    oc:directiveContent "If a side effect is triggered by a specific user action, place the logic directly in the corresponding event handler (onClick, onSubmit, onDrag, etc.) instead of useEffect." ;
    oc:hasRationale "Event handlers execute exactly once per user action, making them the correct locus for interaction-driven side effects, whereas effects run on every render where dependencies change" .

oc:kn_f5bfc6c1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing React components that respond to user interactions" ;
    oc:directiveContent "Never model user-initiated actions (submit, click, drag) as state + useEffect. This causes the effect to re-run on unrelated state changes and can duplicate the action." ;
    oc:hasRationale "State + effect pattern creates hidden coupling between the action and unrelated dependency changes (e.g., theme changes), leading to duplicate API calls or side effects" ;
    oc:severityLevel "HIGH" .

