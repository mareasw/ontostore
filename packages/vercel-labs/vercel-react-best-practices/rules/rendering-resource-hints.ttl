@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_rendering_resource_hints a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rendering-resource-hints" ;
    skos:broader "Performance optimization technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "351b1095d641717b930f1b2253282b7120af3023bc74e06c17675168d4286864" ;
    oc:differentia "uses React DOM resource hint APIs (prefetchDNS, preconnect, preload, preloadModule, preinit, preinitModule) to instruct the browser to eagerly load critical resources" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidResourceURL ;
    oc:hasArgumentHint "React component or resource loading scenario" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_0b0c37c8,
        oc:kn_9489162e,
        oc:kn_b51e6d4f,
        oc:kn_ce005e2f,
        oc:kn_e3c7f8f4 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ReactAppInitialized ;
    oc:resolvesIntent "optimize resource loading with React DOM hints",
        "preconnect to third-party APIs and CDNs",
        "prefetch modules for code-split routes",
        "preload critical fonts and stylesheets",
        "reduce page load time with resource hints" ;
    oc:yieldsState oc:PerformanceOptimized,
        oc:ResourcesPreloaded .

oc:kn_0b0c37c8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing resource hints in React applications" ;
    oc:directiveContent "Resource hint APIs from react-dom are especially effective in server components where they can start loading resources before the client receives HTML." ;
    oc:hasRationale "Server components emit the hints into the initial HTML response, allowing the browser to begin fetching before JavaScript hydrates" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9489162e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When resources need both fetching AND immediate evaluation, not just fetching" ;
    oc:directiveContent "Use preinit for stylesheets and scripts that must execute early, and preinitModule for ES modules that must execute early." ;
    oc:hasRationale "preinit/preinitModule go beyond preloading by also executing the resource, which is critical for render-blocking CSS and essential scripts" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b51e6d4f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which resources to hint" ;
    oc:directiveContent "Do not overuse resource hints by preloading every possible resource; reserve them for genuinely critical resources." ;
    oc:hasRationale "Over-hinting wastes browser bandwidth and connection slots on non-critical resources, potentially delaying resources that actually matter" ;
    oc:severityLevel "HIGH" .

oc:kn_ce005e2f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing resource loading for current vs future navigation" ;
    oc:directiveContent "Use preload for critical resources needed for the current page and preloadModule for JS modules likely needed on next navigation." ;
    oc:hasRationale "Preloading current-page resources improves initial render, while preloading future-route modules on hover eliminates navigation latency" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e3c7f8f4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which resource hint API to use for external domains" ;
    oc:directiveContent "Use prefetchDNS for third-party domains you'll connect to later, and preconnect for APIs/CDNs you'll fetch from immediately." ;
    oc:hasRationale "prefetchDNS only resolves DNS (lighter weight), while preconnect also establishes TCP and TLS (more expensive but reduces latency for immediate requests)" ;
    oc:severityLevel "MEDIUM" .

