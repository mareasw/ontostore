    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ReactAppConfigured ;
    oc:resolvesIntent "optimize resource loading with React DOM hints",
        "preconnect to third-party APIs",
        "preload critical fonts and stylesheets",
        "preload modules for code-split routes" ;
    oc:yieldsState oc:ResourcesPreloaded .

oc:kn_02943b96 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which resources to hint" ;
    oc:directiveContent "Do not preload resources that are not actually needed soon—over-using resource hints wastes bandwidth and can delay loading of truly critical resources." ;
    oc:hasRationale "Browser connection limits mean every hinted resource competes for network priority; excessive hints hurt rather than help performance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3bc22c88 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using preload() for fonts and other CORS-sensitive resources" ;
    oc:directiveContent "preload requires an 'as' option to specify the resource type (e.g., 'font', 'style', 'script'). Fonts must also specify crossOrigin when CORS is needed." ;
    oc:hasRationale "The browser uses the 'as' attribute for proper resource prioritization and caching. Missing crossOrigin on fonts causes double-fetches." ;
    oc:severityLevel "MEDIUM" .

oc:kn_434eaacc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering server components that depend on external resources" ;
    oc:directiveContent "Place resource hint calls (prefetchDNS, preconnect) early in server components so the browser begins resolving connections before the client even receives the HTML." ;
    oc:hasRationale "Server-side resource hints are emitted as HTML <link> tags in the initial response, giving the browser a head start on network operations." ;
    oc:severityLevel "HIGH" .

oc:kn_65001022 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading critical CSS or JS that blocks rendering" ;
    oc:directiveContent "Use preinit (not preload) for stylesheets and scripts that must execute early, as preinit both fetches and evaluates the resource immediately." ;
    oc:hasRationale "preload only fetches but does not execute; preinit fetches and evaluates, making it suitable for resources that must run to unblock rendering." .

oc:kn_faa7ed63 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which resource hint API to use" ;
    oc:directiveContent "Use prefetchDNS for third-party domains you'll connect to later, and preconnect for APIs/CDNs you'll fetch from immediately. Use preload for critical resources needed on the current page, and preloadModule for JS modules on likely next navigations." ;
    oc:hasRationale "Each API has different browser behavior granularity—DNS-only resolution, full connection setup, or full resource fetch with optional evaluation." ;
    oc:severityLevel "HIGH" .

