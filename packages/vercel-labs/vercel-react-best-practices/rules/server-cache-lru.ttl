        oc:kn_ff478fdf ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DatabaseAccessible,
        oc:ServerRuntimeReady ;
    oc:resolvesIntent "avoid redundant database queries on sequential requests",
        "cache data across server requests",
        "implement LRU caching in Next.js server components",
        "optimize server-side data fetching with cross-request caching" ;
    oc:yieldsState oc:CacheInitialized,
        oc:CrossRequestCachingEnabled .

oc:kn_443f6177 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When using Vercel Fluid Compute" ;
    oc:directiveContent "LRU caching is especially effective with Vercel Fluid Compute because multiple concurrent requests share the same function instance and cache, persisting data without external storage." ;
    oc:hasRationale "Fluid Compute keeps function instances warm and shared, enabling in-memory caches to work reliably across requests." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a2381f73 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating whether cross-request caching is appropriate" ;
    oc:directiveContent "Use LRU caching when sequential user actions hit multiple endpoints needing the same data within seconds." ;
    oc:hasRationale "Sequential requests within a short time window benefit from in-memory caching without the overhead of external stores like Redis." ;
    oc:severityLevel "MEDIUM" .

oc:kn_aaf9cefd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between React.cache() and LRU caching strategies" ;
    oc:directiveContent "Use React.cache() for single-request deduplication; use LRU cache (e.g., lru-cache package) for cross-request data persistence where sequential user actions hit multiple endpoints needing the same data." ;
    oc:hasRationale "React.cache() scopes to a single request — it cannot share data across sequential requests, which is a common pattern when users perform chained actions." ;
    oc:severityLevel "HIGH" .

oc:kn_f6ba6904 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always when using LRU caching" ;
    oc:directiveContent "LRU cache entries are in-memory only and will be lost on process restart or redeployment. Cache misses fall back to the original data source." ;
    oc:hasRationale "In-memory caches are volatile; agents must ensure the underlying data fetch still works as a fallback." ;
    oc:severityLevel "HIGH" .

oc:kn_ff478fdf a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deploying to traditional serverless platforms without Fluid Compute" ;
    oc:directiveContent "In traditional serverless environments, each invocation runs in isolation — LRU cache does not persist across processes. Use Redis or an external store for cross-process caching." ;
    oc:hasRationale "Serverless cold starts create isolated execution contexts, making in-memory caches unreliable for cross-request persistence." ;
    oc:severityLevel "CRITICAL" .

oc:req_70044c8d a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Understanding of React server components and request lifecycle" .

oc:req_e69251b2 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "lru-cache npm package" .

