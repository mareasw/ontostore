oc:skill_vercel_labs_vercel_react_best_practices_server_cache_lru a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "server-cache-lru" ;
    skos:broader "Caching Strategy" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "1924b64561841923b88a657085097a0aeba3e0ba2d5470b9f5c15cc10d6ae70f" ;
    oc:differentia "Uses in-memory LRU cache to persist frequently accessed data across sequential server requests in React/Next.js applications" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "data-fetching-function-or-cache-key" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_70044c8d,
        oc:req_e69251b2 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Cross-Request LRU Caching
impact: HIGH
impactDescription: caches across requests
tags: server, cache, lru, cross-request
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 7 ;
                    oc:textContent "Reference: [https://github.com/isaacs/node-lru-cache](https://github.com/isaacs/node-lru-cache)" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent "**In traditional serverless:** Each invocation runs in isolation, so consider Redis for cross-process caching." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """import { LRUCache } from 'lru-cache'

const cache = new LRUCache<string, any>({
  max: 1000,
  ttl: 5 * 60 * 1000  // 5 minutes
})

export async function getUser(id: string) {
  const cached = cache.get(id)
  if (cached) return cached

  const user = await db.user.findUnique({ where: { id } })
  cache.set(id, user)
  return user
}

// Request 1: DB query, result cached
// Request 2: cache hit, no DB query
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-33" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 5 ;
                    oc:textContent "**With Vercel's [Fluid Compute](https://vercel.com/docs/fluid-compute):** LRU caching is especially effective because multiple concurrent requests can share the same function instance and cache. This means the cache persists across requests without needing external storage like Redis." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "Use when sequential user actions hit multiple endpoints needing the same data within seconds." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Implementation:**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "`React.cache()` only works within one request. For data shared across sequential requests (user clicks button A then button B), use an LRU cache." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Cross-Request LRU Caching" ] ;
    oc:impartsKnowledge oc:kn_443f6177,
