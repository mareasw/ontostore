oc:kn_37aa8950 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which components should be async in an RSC tree" ;
    oc:directiveContent "If a parent component only composes children and doesn't consume their data, make it synchronous (non-async). Only make a component async if it itself needs to await data." ;
    oc:hasRationale "A synchronous parent allows all async children to begin fetching immediately rather than being blocked by the parent's await." .

oc:kn_6e4cbfaf a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When using layout components with React Server Components" ;
    oc:directiveContent "When a layout or shared wrapper needs both async components and a children prop, keep the layout synchronous and pass async components as siblings or via children — the layout itself should not await." ;
    oc:hasRationale "The children prop pattern allows async components to be composed without the layout itself creating a sequential bottleneck." .

oc:kn_a246a7b1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring RSC component trees with multiple independent data sources" ;
    oc:directiveContent "Lift each data fetch into its own dedicated async server component so that sibling components fetch in parallel when rendered by a shared non-async parent." ;
    oc:hasRationale "Sibling async components rendered by a non-async parent initiate their fetches concurrently, eliminating waterfall latency." .

oc:kn_f3850257 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating the performance impact of component restructuring" ;
    oc:directiveContent "Sequential waterfall fetching has total latency = sum of all fetch times; parallel composition has total latency = max of individual fetch times." ;
    oc:hasRationale "This is the fundamental performance win — from additive to max-based latency." .

oc:kn_f75ec192 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing async React Server Components that contain other async components" ;
    oc:directiveContent "Never await data fetching in a parent component and then render child server components below — this creates a sequential waterfall where the child cannot begin fetching until the parent completes." ;
    oc:hasRationale "React Server Components execute sequentially within a tree; a parent's await blocks all children from starting their own fetches." ;
    oc:severityLevel "CRITICAL" .

