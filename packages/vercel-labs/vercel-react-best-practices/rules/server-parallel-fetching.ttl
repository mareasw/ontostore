oc:skill_vercel_labs_vercel_react_best_practices_server_parallel_fetching a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "server-parallel-fetching" ;
    skos:broader "React Server Component optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "569a2e9fc04f9606686cd75c5894ef8781b502786a7fffe241396846c7733472" ;
    oc:differentia "parallelizes data fetching by restructuring component trees to avoid sequential awaits, eliminating server-side waterfalls" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "React Server Component tree to refactor" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_244d6e6e,
        oc:kn_37a30c1d,
        oc:kn_6b6aed29,
        oc:kn_bead4d84,
        oc:kn_fc074aa8 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "eliminate server-side waterfalls in RSC",
        "optimize server-side data fetching",
        "parallelize data fetching in React Server Components",
        "restructure component composition for concurrent fetching" .

oc:kn_244d6e6e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When refactoring page layouts for parallel fetching" ;
    oc:directiveContent "When a component has no data dependencies of its own, make it synchronous and compose async children into it — this preserves parallelism of those children." ;
    oc:hasRationale "Synchronous parent components act as transparent composition boundaries that don't introduce sequential await barriers." .

oc:kn_37a30c1d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When layout components don't need to await data themselves" ;
    oc:directiveContent "Use the children prop pattern to decompose the tree — a parent that doesn't await can still wrap async children without blocking them." ;
    oc:hasRationale "A non-async layout component passes through children without creating an await boundary, preserving parallelism of descendant async components." .

oc:kn_6b6aed29 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when working with RSC architecture" ;
    oc:directiveContent "React Server Components within a single tree execute sequentially; there is no automatic parallelism within a single component's function body." ;
    oc:hasRationale "This is a fundamental property of RSC execution model — only sibling-level composition enables parallelism, not nested awaits." ;
    oc:severityLevel "HIGH" .

oc:kn_bead4d84 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing React Server Component trees with multiple data sources" ;
    oc:directiveContent "Never await data fetching in a parent component and then render child components that also fetch data — this creates sequential waterfalls where children wait for parents." ;
    oc:hasRationale "RSCs execute sequentially within a tree; a parent's await blocks all child rendering, including their own fetches, compounding latency." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fc074aa8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When multiple independent data sources are needed on a single page" ;
    oc:directiveContent "Push data fetching into sibling async components so their fetches execute concurrently rather than sequentially." ;
    oc:hasRationale "Sibling async components fire their fetches in parallel, reducing total wait time from sum(latencies) to max(latencies)." .

