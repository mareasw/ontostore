oc:skill_vercel_labs_vercel_react_best_practices_advanced_event_handler_refs a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "advanced-event-handler-refs" ;
    skos:broader "React hook pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "a3097edeecfb2ff6851cd66ed8cdf0617c3c88180504bee824aa6e75a215bbbc" ;
    oc:differentia "stores event handler callbacks in refs to maintain stable subscriptions without re-subscribing on callback changes" ;
    oc:extends oc:skill_ontoskills_vercel_react_best_practices,
        oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Store Event Handlers in Refs
impact: LOW
impactDescription: stable subscriptions
tags: advanced, hooks, refs, event-handlers, optimization
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function useWindowEvent(event: string, handler: (e) => void) {
  useEffect(() => {
    window.addEventListener(event, handler)
    return () => window.removeEventListener(event, handler)
  }, [event, handler])
}
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-21" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Correct (stable subscription):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Incorrect (re-subscribes on every render):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function useWindowEvent(event: string, handler: (e) => void) {
  const handlerRef = useRef(handler)
  useEffect(() => {
    handlerRef.current = handler
  }, [handler])

  useEffect(() => {
    const listener = (e) => handlerRef.current(e)
    window.addEventListener(event, listener)
    return () => window.removeEventListener(event, listener)
  }, [event])
}
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 25-38" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Store callbacks in refs when used in effects that shouldn't re-subscribe on callback changes." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent "**Alternative: use `useEffectEvent` if you're on latest React:**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """import { useEffectEvent } from 'react'

function useWindowEvent(event: string, handler: (e) => void) {
  const onEvent = useEffectEvent(handler)

  useEffect(() => {
    window.addEventListener(event, onEvent)
    return () => window.removeEventListener(event, onEvent)
  }, [event])
}
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 7 ;
                    oc:sourceLocation "lines 42-53" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 8 ;
                    oc:textContent "`useEffectEvent` provides a cleaner API for the same pattern: it creates a stable function reference that always calls the latest version of the handler." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Store Event Handlers in Refs" ] ;
    oc:impartsKnowledge oc:kn_4ffcb850,
        oc:kn_62744038,
        oc:kn_b009ad33,
        oc:kn_f1113784,
        oc:kn_fa93578b ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create stable event listener hooks",
        "optimize event handler subscriptions",
        "prevent unnecessary re-subscriptions in effects" ;
    oc:yieldsState oc:StableSubscriptions .

oc:kn_4ffcb850 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing hooks that bridge imperative subscriptions with declarative React components" ;
    oc:directiveContent "Separate the subscription lifecycle from the handler update lifecycle — the subscription effect should only depend on the event type, not the callback." ;
    oc:hasRationale "This separation ensures subscriptions remain stable while callback logic stays fresh" .

oc:kn_62744038 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using useEffect with event listeners or subscriptions" ;
    oc:directiveContent "Never include handler functions in useEffect dependency arrays if the handler changes frequently — this causes re-subscription on every render." ;
    oc:hasRationale "Including unstable handler references in dependency arrays defeats the purpose of memoization and causes performance issues from constant subscribe/unsubscribe cycles" ;
    oc:severityLevel "HIGH" .

oc:kn_b009ad33 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When React version supports useEffectEvent (experimental/latest)" ;
    oc:directiveContent "Prefer useEffectEvent over manual ref-based handler storage when using latest React versions — it provides the same stability guarantee with cleaner syntax." ;
    oc:hasRationale "useEffectEvent is the canonical React API for this pattern and is less error-prone than manual ref management" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f1113784 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating custom hooks that subscribe to events with frequently-changing handlers" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent "const handlerRef = useRef(handler); useEffect(() => { handlerRef.current = handler }, [handler]); useEffect(() => { const listener = (e) => handlerRef.current(e); /* subscribe */ return () => { /* unsubscribe */ } }, [event]);" .

oc:kn_fa93578b a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating whether to apply this optimization" ;
    oc:directiveContent "This pattern eliminates unnecessary DOM addEventListener/removeEventListener calls, reducing GC pressure and preventing brief subscription gaps during re-renders." ;
    oc:hasRationale "Re-subscribing on every render is wasteful for events like resize or scroll that rarely change handlers" .

