        oc:kn_cf91feb3,
        oc:kn_fb5ce092 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "optimize React state subscriptions",
        "prevent unnecessary re-renders from continuous value changes",
        "reduce re-render frequency in React components" .

oc:kn_135c3b27 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When subscribing to window dimensions, scroll position, or other continuously-changing values in React components" ;
    oc:directiveContent "Never subscribe to continuous values (e.g., window width in pixels) when only a derived boolean threshold matters — it causes re-renders on every pixel change." ;
    oc:hasRationale "Continuous value subscriptions trigger re-renders far more frequently than needed when only a boolean decision (e.g., mobile vs desktop) is relevant." ;
    oc:severityLevel "HIGH" .

oc:kn_4ed8888c a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a component needs responsive behavior based on a viewport breakpoint" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent "const isMobile = useMediaQuery('(max-width: 767px)')" .

oc:kn_9e4228f0 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating performance impact of state subscription patterns" ;
    oc:directiveContent "Subscribing to derived boolean state reduces re-renders from O(pixels_changed) to O(threshold_crossings), which is typically 1-2 re-renders per resize instead of dozens." .

oc:kn_cf91feb3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing state subscriptions in React components" ;
    oc:directiveContent "Subscribe to the most coarse-grained state that satisfies the UI's needs — prefer boolean flags over continuous values." ;
    oc:hasRationale "Coarser state granularity dramatically reduces re-render frequency while preserving correct UI behavior." .

oc:kn_fb5ce092 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating custom hooks for responsive or threshold-based state" ;
    oc:directiveContent "Derive boolean state at the subscription layer, not in the component body — compute the threshold where the subscription is defined." ;
    oc:hasRationale "Matching CSS media queries in JS ensures behavioral parity between styles and component logic." .

