@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_rerender_transitions a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rerender-transitions" ;
    skos:broader "React performance optimization technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "60f4033909a62df5e5b8c601494f9e50a562e2f8c1c2d81eac24f38142265f1c" ;
    oc:differentia "uses startTransition to wrap non-urgent state updates so they don't block the main thread during high-frequency events like scrolling" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "React component or hook code that handles frequent events" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_95b09047,
        oc:kn_a3086645,
        oc:kn_d9fb459a,
        oc:kn_fd64cfa5 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "apply startTransition to scroll handlers and similar high-frequency updates",
        "optimize React re-renders for non-urgent updates",
        "prevent UI jank during frequent events" ;
    oc:yieldsState oc:TransitionApplied .

oc:kn_95b09047 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When auditing React components for performance optimization opportunities" ;
    oc:directiveContent "If a state update originates from scroll, resize, pointermove, or similar rapidly-repeating events, it is a strong candidate for startTransition." ;
    oc:hasRationale "These events fire at 60+ times per second; even lightweight renders at this frequency compete with user input for the main thread." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a3086645 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which setState calls to wrap in startTransition" ;
    oc:directiveContent "Only wrap non-urgent updates in startTransition — never wrap urgent updates like controlled input values, focus management, or immediate visual feedback." ;
    oc:hasRationale "Urgent updates wrapped in startTransition will be deferred, causing perceptible lag in user-facing interactions that should feel instantaneous." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d9fb459a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a state update is triggered by a frequent event and does not need to be visually immediate" ;
    oc:directiveContent "Use startTransition to wrap non-urgent state updates so React can interrupt them if more urgent updates (like user input) arrive." ;
    oc:hasRationale "startTransition marks the update as low-priority, allowing React to batch and defer rendering while keeping the UI responsive to user interaction." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fd64cfa5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing React event handlers for scroll, resize, or other rapidly-firing DOM events" ;
    oc:directiveContent "Never call setState directly inside high-frequency event handlers (scroll, resize, mousemove) without wrapping in startTransition." ;
    oc:hasRationale "Direct setState in high-frequency handlers blocks the main thread on every event, causing visible UI jank and degraded responsiveness." ;
    oc:severityLevel "HIGH" .

