oc:skill_vercel_labs_vercel_react_best_practices_rendering_conditional_render a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rendering-conditional-render" ;
    skos:broader "React rendering pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "2ec2fa23c4148285144687050c52369adba3da2fbe3d486f8d3e0aad8f06f2bc" ;
    oc:differentia "that prevents falsy value rendering bugs by using explicit ternary operators instead of && for conditional JSX" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Use Explicit Conditional Rendering
impact: LOW
impactDescription: prevents rendering 0 or NaN
tags: rendering, conditional, jsx, falsy-values
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function Badge({ count }: { count: number }) {
  return (
    <div>
      {count > 0 ? <span className="badge">{count}</span> : null}
    </div>
  )
}

// When count = 0, renders: <div></div>
// When count = 5, renders: <div><span class="badge">5</span></div>
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 29-40" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Correct (renders nothing when count is 0):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Use explicit ternary operators (`? :`) instead of `&&` for conditional rendering when the condition can be `0`, `NaN`, or other falsy values that render." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Incorrect (renders \"0\" when count is 0):**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """function Badge({ count }: { count: number }) {
  return (
    <div>
      {count && <span className="badge">{count}</span>}
    </div>
  )
}

// When count = 0, renders: <div>0</div>
// When count = 5, renders: <div><span class="badge">5</span></div>
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-25" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Use Explicit Conditional Rendering" ] ;
    oc:impartsKnowledge oc:kn_2b60a3a1,
        oc:kn_b6ce7f00,
        oc:kn_c92a5b7d,
        oc:kn_ea0ab823 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "avoid rendering 0 or NaN in JSX",
        "fix conditional rendering bugs with falsy values",
        "write correct conditional rendering in React components" .

oc:kn_2b60a3a1 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When conditionally rendering elements based on numeric or falsy-prone values" ;
    oc:directiveContent "Use explicit ternary: `{count > 0 ? <Component /> : null}` instead of `{count && <Component />}`" ;
    oc:hasRationale "Ternary with null ensures nothing renders for falsy cases, while && leaks falsy values into the DOM" .

oc:kn_b6ce7f00 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing conditional JSX with numeric or potentially falsy conditions" ;
    oc:directiveContent "Never use && for conditional rendering when the left operand can be 0, NaN, or other falsy values that React will render as text" ;
    oc:hasRationale "React renders falsy values like 0 and NaN as visible text in the DOM, causing unexpected UI output" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c92a5b7d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between && and ternary for conditional rendering" ;
    oc:directiveContent "The && operator is safe only when the left operand is strictly boolean (true/false). For any other type, use a ternary." ;
    oc:hasRationale "Boolean && never produces a renderable falsy value, but number/string/object && can" ;
    oc:severityLevel "LOW" .

oc:kn_ea0ab823 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any conditional rendering in React components" ;
    oc:directiveContent "Prefer explicit over implicit conditional logic in JSX — always make the 'else' branch visible (even if null)" ;
    oc:hasRationale "Explicit ternaries make intent clear and prevent accidental rendering of unexpected values" .

