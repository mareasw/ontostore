oc:skill_vercel_labs_vercel_react_best_practices_rendering_conditional_render a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rendering-conditional-render" ;
    skos:broader "React rendering pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "2ec2fa23c4148285144687050c52369adba3da2fbe3d486f8d3e0aad8f06f2bc" ;
    oc:differentia "uses explicit ternary operators instead of && for conditional rendering to prevent falsy value rendering bugs" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "React component code with conditional rendering" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_10944545,
        oc:kn_34685884,
        oc:kn_b79aace5,
        oc:kn_d726ebe9 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "fix conditional rendering bugs with falsy values",
        "prevent rendering 0 or NaN in JSX",
        "write correct conditional rendering in React components" ;
    oc:yieldsState oc:CodePatternApplied .

oc:kn_10944545 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After implementing conditional rendering with ternary operators" ;
    oc:directiveContent "When count is 0, the component should render an empty container with no visible text content." ;
    oc:hasRationale "This confirms the falsy branch correctly returns null instead of rendering the falsy value as text." ;
    oc:severityLevel "LOW" .

oc:kn_34685884 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using numeric values as conditions in JSX && expressions" ;
    oc:directiveContent "The expression {count && <Badge />} renders '0' as text when count is 0, because 0 is a valid React node that gets rendered." ;
    oc:hasRationale "In JavaScript, 0 && <Badge /> evaluates to 0 (not false), and React treats 0 as a renderable value, displaying it as text content." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b79aace5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When conditionally rendering JSX elements based on any value that could be a falsy primitive" ;
    oc:directiveContent "Use explicit ternary operators (condition ? <Component /> : null) for conditional rendering to make the intent unambiguous." ;
    oc:hasRationale "Ternary operators explicitly define both the truthy and falsy branches, eliminating ambiguity about what gets rendered when the condition is falsy." ;
    oc:severityLevel "HIGH" .

oc:kn_d726ebe9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing JSX conditional rendering with numeric or potentially falsy conditions" ;
    oc:directiveContent "Never use the && operator for conditional rendering when the left-hand expression can be 0, NaN, or other falsy values that React will render as text." ;
    oc:hasRationale "React renders falsy values like 0 and NaN as visible text in the DOM, causing unexpected UI output such as '0' appearing on screen." ;
    oc:severityLevel "MEDIUM" .

