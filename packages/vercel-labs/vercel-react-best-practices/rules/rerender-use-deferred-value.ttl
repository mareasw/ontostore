@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_rerender_use_deferred_value a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rerender-use-deferred-value" ;
    skos:broader "React rendering optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "8c3579576a61a949884167745dcfaf1d5426ba305cc61fd0a79602d70fda4909" ;
    oc:differentia "uses useDeferredValue to keep user input responsive during expensive derived computations by deferring the heavy render until the browser is idle" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:RenderStutterDetected,
        oc:UnmemoizedComputationFound ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_290fe9b9,
        oc:kn_570333db,
        oc:kn_b9400540,
        oc:kn_ded92286,
        oc:kn_e567bf76 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ExpensiveDerivationIdentified,
        oc:ReactComponentMounted ;
    oc:resolvesIntent "defer heavy computations in React components",
        "optimize search filtering responsiveness",
        "prevent input lag during expensive renders" ;
    oc:yieldsState oc:DeferredRenderOptimized,
        oc:InputResponsivenessPreserved .

oc:kn_290fe9b9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating whether a component needs deferred value optimization" ;
    oc:directiveContent "Apply useDeferredValue when filtering/searching large lists, rendering expensive visualizations, or any derived state causing noticeable render delays." ;
    oc:hasRationale "useDeferredValue is specifically designed for concurrent rendering scenarios where input responsiveness must be preserved despite heavy downstream computation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_570333db a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering deferred results alongside live user input" ;
    oc:directiveContent "Use a visual staleness indicator (e.g., reduced opacity) when the deferred value lags behind the actual input to communicate state to the user." ;
    oc:hasRationale "Users need feedback that the displayed results are stale and will update shortly, preventing confusion about mismatched results." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b9400540 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user input triggers filtering, searching, or visualization of large datasets" ;
    oc:directiveContent "Never run expensive derived computations directly on user input state without deferral — the input will feel laggy and unresponsive." ;
    oc:hasRationale "Synchronous expensive computation blocks the main thread, making the input field feel frozen until the computation completes." ;
    oc:severityLevel "HIGH" .

oc:kn_ded92286 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always, when useDeferredValue is in use" ;
    oc:directiveContent "useDeferredValue introduces a deliberate temporal mismatch between input state and rendered results — the deferred value lags behind the actual value." ;
    oc:hasRationale "This lag is intentional and enables concurrent rendering, but components must be designed to handle the intermediate stale state gracefully." ;
    oc:severityLevel "LOW" .

oc:kn_e567bf76 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When implementing useDeferredValue for any derived state computation" ;
    oc:directiveContent "Always wrap the expensive computation in useMemo with the deferred value as a dependency, not the original value." ;
    oc:hasRationale "Without useMemo, the expensive computation still runs on every render, negating the benefit of deferring the value." ;
    oc:severityLevel "CRITICAL" .

