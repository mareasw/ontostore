oc:skill_vercel_labs_vercel_react_best_practices_client_passive_event_listeners a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "client-passive-event-listeners" ;
    skos:broader "Performance optimization technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "1f35016f9053de69e884ee9be00654e37979c2ca85f5e57764dc2626ff7acb4b" ;
    oc:differentia "adds passive flag to touch and wheel event listeners to eliminate scroll blocking" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "component or event listener code to optimize" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent "**Use passive when:** tracking/analytics, logging, any listener that doesn't call `preventDefault()`." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Incorrect:**" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """useEffect(() => {
  const handleTouch = (e: TouchEvent) => console.log(e.touches[0].clientX)
  const handleWheel = (e: WheelEvent) => console.log(e.deltaY)
  
  document.addEventListener('touchstart', handleTouch, { passive: true })
  document.addEventListener('wheel', handleWheel, { passive: true })
  
  return () => {
    document.removeEventListener('touchstart', handleTouch)
    document.removeEventListener('wheel', handleWheel)
  }
}, [])
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 31-44" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Add `{ passive: true }` to touch and wheel event listeners to enable immediate scrolling. Browsers normally wait for listeners to finish to check if `preventDefault()` is called, causing scroll delay." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 7 ;
                    oc:textContent "**Don't use passive when:** implementing custom swipe gestures, custom zoom controls, or any listener that needs `preventDefault()`." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """useEffect(() => {
  const handleTouch = (e: TouchEvent) => console.log(e.touches[0].clientX)
  const handleWheel = (e: WheelEvent) => console.log(e.deltaY)
  
  document.addEventListener('touchstart', handleTouch)
  document.addEventListener('wheel', handleWheel)
  
  return () => {
    document.removeEventListener('touchstart', handleTouch)
    document.removeEventListener('wheel', handleWheel)
  }
}, [])
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 14-27" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Correct:**" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Use Passive Event Listeners for Scrolling Performance" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Use Passive Event Listeners for Scrolling Performance
impact: MEDIUM
impactDescription: eliminates scroll delay caused by event listeners
tags: client, event-listeners, scrolling, performance, touch, wheel
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:impartsKnowledge oc:kn_6b24c55d,
        oc:kn_791bbcc0,
        oc:kn_7c998627,
        oc:kn_7e212107,
        oc:kn_8fda8f10 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "add passive event listeners",
        "optimize scrolling performance",
        "prevent scroll delay from event listeners" .

oc:kn_6b24c55d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding touchstart, touchmove, wheel, or similar scroll-related event listeners" ;
    oc:directiveContent "Never add touch or wheel event listeners without the { passive: true } option if the listener does not call preventDefault()." ;
    oc:hasRationale "Browsers block scrolling while waiting for non-passive listeners to finish executing, to check if preventDefault() will be called. This causes visible scroll delay." ;
    oc:severityLevel "HIGH" .

oc:kn_791bbcc0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding scroll-related event listeners for observational purposes" ;
    oc:directiveContent "Use passive listeners for tracking, analytics, logging, or any listener that only reads event data without calling preventDefault()." ;
    oc:hasRationale "These listeners never need to block the browser's default scroll behavior, so marking them passive eliminates unnecessary waiting." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7c998627 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When converting existing event listeners to passive" ;
    oc:directiveContent "Before adding passive: true, verify that the event handler never calls preventDefault() under any code path." ;
    oc:hasRationale "A passive listener that calls preventDefault() will be ignored by the browser and generate a console warning, breaking intended behavior silently." ;
    oc:severityLevel "HIGH" .

oc:kn_7e212107 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "Always, when touch/wheel listeners are present on a page" ;
    oc:directiveContent "Passive event listeners eliminate the browser's wait time for scroll-related event handlers, enabling immediate scrolling response." ;
    oc:hasRationale "Without passive, the browser must synchronously execute each listener before it can begin scrolling, introducing frame delays." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8fda8f10 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing custom gesture handling that requires preventing default browser behavior" ;
    oc:directiveContent "Do NOT use passive: true when the listener needs to call preventDefault(), such as for custom swipe gestures or custom zoom controls." ;
    oc:hasRationale "Passive listeners signal that preventDefault() will not be called, so the browser skips waiting. If you need to prevent default behavior, passive mode breaks that contract." ;
    oc:severityLevel "CRITICAL" .

