oc:skill_vercel_labs_vercel_react_best_practices_js_flatmap_filter a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "js-flatmap-filter" ;
    skos:broader "Performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "9e5b166a41914d975bef7635467f8fb32cd98b5c3126c0bc6f163490812fb5f0" ;
    oc:differentia "replaces chained .map().filter() with .flatMap() to eliminate intermediate arrays and reduce iterations from two to one" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "code with .map().filter() chains" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_9643d672,
        oc:kn_9d147fa7,
        oc:kn_9d9b7e8f,
        oc:kn_e2e91ae7,
        oc:kn_eb08ef87 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CodeReady ;
    oc:resolvesIntent "optimize array transformations",
        "reduce memory allocations in array processing",
        "replace map-filter chains with flatMap" ;
    oc:yieldsState oc:CodeOptimized .

oc:kn_9643d672 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing array transformations that include conditional filtering" ;
    oc:directiveContent "Avoid chaining .map().filter(Boolean) when the map step produces null/undefined for items that should be excluded." ;
    oc:hasRationale "This pattern creates an unnecessary intermediate array and iterates twice over the data, wasting memory and compute." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9d147fa7 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When optimizing hot paths or processing large arrays" ;
    oc:directiveContent "Replacing .map().filter() with .flatMap() removes one intermediate array allocation per transformation chain, reducing peak memory usage proportional to the input array size." ;
    oc:hasRationale "Intermediate arrays from .map() consume memory equal to the input size even if most items are filtered out; flatMap avoids this allocation entirely." ;
    oc:severityLevel "LOW" .

oc:kn_9d9b7e8f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating whether flatMap is the right tool for an array transformation" ;
    oc:directiveContent "Use flatMap when you need to transform items while filtering some out, perform conditional mapping where some inputs produce no output, or parse/validate where invalid inputs should be skipped." ;
    oc:hasRationale "These are the canonical use cases where flatMap provides clear benefits over separate map and filter operations." ;
    oc:severityLevel "LOW" .

oc:kn_e2e91ae7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing flatMap for map-filter replacement" ;
    oc:directiveContent "The flatMap callback must return an array — use [value] to include and [] to exclude. Returning a non-array value will produce unexpected results." ;
    oc:hasRationale "flatMap flattens the returned array one level; returning a non-array value will not behave as expected for filtering." ;
    oc:severityLevel "HIGH" .

oc:kn_eb08ef87 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When transforming arrays where some items should be conditionally excluded from the result" ;
    oc:directiveContent "Use .flatMap() to map and filter in a single pass by returning a single-element array for items to keep and an empty array for items to exclude." ;
    oc:hasRationale "Eliminates the intermediate array created by chaining .map().filter() and reduces iterations from two to one, improving both memory usage and CPU cycles." ;
    oc:severityLevel "MEDIUM" .

