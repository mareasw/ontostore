oc:kn_03b2a0b2 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating performance of array transformation chains" ;
    oc:directiveContent "flatMap replaces O(2n) with O(n) iteration and eliminates one intermediate array allocation." ;
    oc:hasRationale "The performance gain is LOW-MEDIUM impact — measurable on large arrays but not transformative on small ones." .

oc:kn_862b6fdb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing data transformation pipelines in JavaScript" ;
    oc:directiveContent "Combine transformation and filtering into a single pass using flatMap instead of separate map and filter operations." ;
    oc:hasRationale "Single-pass operations are more efficient than multi-pass chains for large datasets." .

oc:kn_a33a4bff a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When transforming and filtering arrays in JavaScript/TypeScript" ;
    oc:directiveContent "Avoid chaining .map().filter(Boolean) — it creates an intermediate array and iterates twice over the data." ;
    oc:hasRationale "Two iterations and an intermediate array waste memory and CPU cycles, especially on large collections." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fcd7ffec a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When you need to transform items while conditionally filtering some out" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent "Use .flatMap() returning [] for items to exclude and [value] for items to include: `arr.flatMap(x => condition ? [transform(x)] : [])`" ;
    oc:hasRationale "flatMap maps each element to an array, then flattens one level — returning an empty array effectively filters that element out in a single pass." .

