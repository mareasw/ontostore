@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_advanced_effect_event_deps a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "advanced-effect-event-deps" ;
    skos:broader "React hook pattern guideline" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "55ed8f9f27a1bff803d6fa55828176207714b02123cbb97ddb8a90d88024a723" ;
    oc:differentia "prescribes excluding useEffectEvent functions from useEffect dependency arrays because they lack stable identity" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:EffectReRunOnEveryRender,
        oc:LintValueTriggered ;
    oc:hasArgumentHint "React component code using useEffectEvent" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_5232e844,
        oc:kn_5ee94bfe,
        oc:kn_a621fc75,
        oc:kn_e857aca1 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ReactComponentDefined,
        oc:UseEffectEventImported ;
    oc:resolvesIntent "avoid effect re-runs caused by unstable Effect Event identity",
        "fix React Hooks lint errors related to Effect Event dependencies",
        "write correct useEffect dependencies when using useEffectEvent" ;
    oc:yieldsState oc:EffectDependenciesCorrectlyConfigured .

oc:kn_5232e844 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reasoning about the identity semantics of useEffectEvent return values" ;
    oc:directiveContent "An Effect Event function is intentionally non-stable — its identity changes every render by design so it always reads the latest props/state values." ;
    oc:hasRationale "This unstable identity is a feature, not a bug — it allows Effect Events to always read the latest values without triggering re-subscriptions in effects." ;
    oc:severityLevel "LOW" .

oc:kn_5ee94bfe a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When incorrectly adding useEffectEvent results to dependency arrays" ;
    oc:directiveContent "Including an Effect Event in a dependency array causes the effect to re-run on every single render, creating unnecessary re-executions and potential infinite re-render loops." ;
    oc:hasRationale "Since useEffectEvent returns a function with unstable identity (new reference each render), React's dependency comparison always detects a change, triggering the effect unnecessarily." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a621fc75 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing useEffect hooks that call functions created by useEffectEvent" ;
    oc:directiveContent "Never include the function returned by useEffectEvent in a useEffect dependency array. Effect Events intentionally lack stable identity and change on every render." ;
    oc:hasRationale "Including Effect Events in dependency arrays causes the effect to re-run on every render and triggers React Hooks lint rule violations, defeating the purpose of useEffectEvent." ;
    oc:severityLevel "HIGH" .

oc:kn_e857aca1 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When an effect needs to read non-reactive values without subscribing to their changes" ;
    oc:directiveContent "Keep only actual reactive values (e.g., roomId, props, state) in the useEffect dependency array and call the Effect Event from inside the effect body or its subscriptions." ;
    oc:hasRationale "This preserves the effect's subscription stability while allowing access to the latest non-reactive values through the Effect Event wrapper." ;
    oc:severityLevel "CRITICAL" .

