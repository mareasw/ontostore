@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_template a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "template" ;
    skos:broader "Rule template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "99df2a3ea088c6c22de2484ddc7e964d0e9923846f44c63380343ecc64455442" ;
    oc:differentia "provides the boilerplate structure for creating new performance optimization rules in the Vercel React best practices collection" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "rule-name with impact level and tags" ;
    oc:hasCategory "development" ;
    oc:hasPackageName "vercel-labs/vercel-react-best-practices" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**Incorrect (description of what's wrong):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Brief explanation of the rule and why it matters. This should be clear and concise, explaining the performance implications." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """// Bad code example here
const bad = example()
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 4 ;
                    oc:sourceLocation "lines 16-19" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """// Good code example here
const good = example()
""" ;
                    oc:codeLanguage "typescript" ;
                    oc:contentOrder 6 ;
                    oc:sourceLocation "lines 23-26" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 5 ;
                    oc:textContent "**Correct (description of what's right):**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "**Impact: MEDIUM (optional impact description)**" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 7 ;
                    oc:textContent "Reference: [Link to documentation or resource](https://example.com)" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Rule Title Here" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """title: Rule Title Here
impact: MEDIUM
impactDescription: Optional description of impact (e.g., "20-50% improvement")
tags: tag1, tag2
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:impartsKnowledge oc:kn_424fb106,
        oc:kn_bc6cd80d,
        oc:kn_beda66d9,
        oc:kn_e3e8ae0a,
        oc:kn_f51f6c06 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "author optimization guideline",
        "create new performance rule",
        "write best practice rule" .

oc:kn_424fb106 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing rule content" ;
    oc:directiveContent "Every rule must demonstrate both an Incorrect and Correct code example in TypeScript, with clear explanations of what makes each right or wrong" ;
    oc:hasRationale "Contrastive examples are the primary teaching mechanism; developers learn best from seeing the anti-pattern alongside the fix" .

oc:kn_bc6cd80d a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When authoring a new performance rule" ;
    oc:directiveContent """## {Rule Title}

**Impact: {LEVEL} ({impact description})**

{Brief explanation}

**Incorrect ({what's wrong}):**
```typescript
// Bad code example
```

**Correct ({what's right}):**
```typescript
// Good code example
```

Reference: [Link](url)""" ;
    oc:hasRationale "Consistent structure across all 69+ rules enables agents and developers to quickly parse and apply rules" ;
    oc:templateVariables "Brief explanation",
        "LEVEL",
        "Link",
        "Rule Title",
        "impact description",
        "url",
        "what's right",
        "what's wrong" .

oc:kn_beda66d9 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before creating any rule file" ;
    oc:directiveContent "Frontmatter must include: title (string), impact (MEDIUM|CRITICAL|HIGH|LOW), impactDescription (optional string), tags (comma-separated list)" ;
    oc:hasRationale "Frontmatter metadata enables rule categorization, prioritization, and filtering in the larger rule set" .

oc:kn_e3e8ae0a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming a new rule file" ;
    oc:directiveContent "File naming convention: use category prefix followed by descriptive kebab-case name (e.g., async-parallel, bundle-barrel-imports, rerender-memo)" ;
    oc:hasRationale "Prefix-based naming maps to the 8 priority categories (async-, bundle-, server-, client-, rerender-, rendering-, js-, advanced-) enabling quick identification of rule domain" .

oc:kn_f51f6c06 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting impact in frontmatter" ;
    oc:directiveContent "Impact levels must be one of: CRITICAL, HIGH, MEDIUM, LOW. Template defaults to MEDIUM." ;
    oc:hasRationale "Fixed impact levels enable prioritized sorting and progressive disclosure — CRITICAL rules are applied first" .

