@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_vercel_labs_vercel_react_best_practices_template a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "template" ;
    skos:broader "scaffold" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "99df2a3ea088c6c22de2484ddc7e964d0e9923846f44c63380343ecc64455442" ;
    oc:differentia "template for authoring new React/Next.js performance optimization rules with consistent structure and metadata" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "rule-name (used as filename prefix with category, e.g. async-my-rule)" ;
    oc:hasCategory "development" ;
    oc:hasPackageName "vercel-react-best-practices" ;
    oc:impartsKnowledge oc:kn_042f2746,
        oc:kn_6cb9fa67,
        oc:kn_82af2fca,
        oc:kn_968cc91e ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "author best practice rule",
        "create new performance rule",
        "scaffold optimization guideline" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_042f2746 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating new rules" ;
    oc:directiveContent "Do not add rules without assigning an impact level or without providing both incorrect and correct code examples" ;
    oc:hasRationale "Rules without impact levels cannot be prioritized; rules without code examples are abstract and harder to apply correctly" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6cb9fa67 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring rule content" ;
    oc:directiveContent "Each rule must contain three sections: an explanation of why it matters, an Incorrect code example, and a Correct code example" ;
    oc:hasRationale "The before/after pattern provides concrete, actionable guidance that developers and AI agents can immediately apply" ;
    oc:severityLevel "HIGH" .

oc:kn_82af2fca a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring any new performance rule file" ;
    oc:directiveContent "Every rule must include frontmatter with title, impact level (CRITICAL/HIGH/MEDIUM/LOW), optional impactDescription, and tags for categorization" ;
    oc:hasRationale "Consistent metadata enables automated prioritization and filtering of rules by impact and category" ;
    oc:severityLevel "HIGH" .

oc:kn_968cc91e a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When naming a new rule file" ;
    oc:directiveContent "Rule filenames must be prefixed with their category (async-, bundle-, server-, client-, rerender-, rendering-, js-, advanced-) to enable automatic grouping" ;
    oc:hasRationale "Category prefixes allow rule files to be discovered, sorted, and loaded by section without a central registry" ;
    oc:severityLevel "MEDIUM" .

