oc:skill_vercel_labs_vercel_react_best_practices_server_after_nonblocking a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "server-after-nonblocking" ;
    skos:broader "Performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "d0b8d24a3db9f0f65f9e2bddbf230b0e03a5f60e1229d93a4a18f5e7a991c7c2" ;
    oc:differentia "uses Next.js after() to schedule non-blocking post-response side effects like logging, analytics, and notifications" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:AfterCallbackError ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_94ad3145,
        oc:kn_ec1e822c,
        oc:kn_ed3c3ca4,
        oc:kn_f383b287,
        oc:kn_ff13c6e6 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "defer logging and analytics after response",
        "implement background tasks in Next.js server routes",
        "optimize server response times",
        "schedule non-blocking side effects" ;
    oc:yieldsState oc:NonBlockingSideEffectsConfigured .

oc:kn_94ad3145 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Next.js Route Handlers, Server Actions, or Server Components that perform non-critical side effects" ;
    oc:directiveContent "Never await side-effect operations like logging, analytics, or notifications before returning a server response — they block the response and degrade perceived performance." ;
    oc:hasRationale "Awaiting side effects before responding adds unnecessary latency to the user-facing response, making the server feel slower." ;
    oc:severityLevel "HIGH" .

oc:kn_ec1e822c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When a server route or action needs to perform side effects that don't affect the response payload" ;
    oc:directiveContent "Use next/server's after() function to schedule non-critical work (logging, analytics, notifications, cache invalidation, cleanup) that should execute after the response is sent." ;
    oc:hasRationale "after() ensures the response is sent immediately while background work proceeds without blocking, improving response times." ;
    oc:severityLevel "HIGH" .

oc:kn_ed3c3ca4 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using after() to schedule post-response work" ;
    oc:directiveContent "after() callbacks run even if the response fails or redirects — do not assume the response was successful inside the after() block." ;
    oc:hasRationale "This behavior means any state checks or conditional logic inside after() must not assume the preceding response succeeded." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f383b287 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing server route handlers and server actions" ;
    oc:directiveContent "Classify operations into critical path (mutations, data fetches that affect the response) vs. non-critical side effects (logging, analytics, notifications) — only critical path operations should block the response." ;
    oc:hasRationale "Clear separation of critical vs. non-critical work enables targeted optimization where side effects are deferred via after() without risking response integrity." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ff13c6e6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When accessing request context inside after() in Next.js" ;
    oc:directiveContent "Within after() callbacks, use dynamic request helpers like headers() and cookies() by awaiting them (e.g., (await headers()).get(...)) rather than referencing the outer request object." ;
    oc:hasRationale "The original request object may not be available in the after() scope; Next.js dynamic APIs (headers, cookies) are the correct way to access request-scoped data inside after()." ;
    oc:severityLevel "MEDIUM" .

