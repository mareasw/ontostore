oc:kn_09b602ac a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Whenever a server function performs mutations followed by side-effect operations" ;
    oc:directiveContent "Use next/server's after() to schedule non-essential work (logging, analytics, cache invalidation, notifications) to run after the response is sent." ;
    oc:hasRationale "Decoupling side effects from the response path improves perceived and actual performance." ;
    oc:severityLevel "HIGH" .

oc:kn_3ded54a0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When accessing request context inside after() callbacks" ;
    oc:directiveContent "Inside after() callbacks, use next/headers helpers (headers(), cookies()) with await since the request context is still available but must be accessed asynchronously." ;
    oc:hasRationale "The dynamic request context is preserved for after() but requires explicit await in the async callback pattern." ;
    oc:severityLevel "MEDIUM" .

oc:kn_49447c05 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using after() for critical operations like audit logging" ;
    oc:directiveContent "after() is fire-and-forget — there is no built-in guarantee that the scheduled work completes or retry mechanism if it fails." ;
    oc:hasRationale "Operations that require guaranteed delivery should not rely solely on after() without additional reliability measures." ;
    oc:severityLevel "LOW" .

oc:kn_4b6ff28f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Route Handlers, Server Actions, or Server Components with side effects" ;
    oc:directiveContent "Never await side-effect operations (logging, analytics, notifications) before returning a server response — they block the response unnecessarily." ;
    oc:hasRationale "Awaiting non-essential work before returning increases response latency for the client with no user benefit." ;
    oc:severityLevel "HIGH" .

oc:kn_a527d219 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using after() for operations that depend on response success" ;
    oc:directiveContent "after() runs even if the response fails or redirects — code inside after() cannot assume the response succeeded." ;
    oc:hasRationale "Developers may incorrectly assume after()-scheduled code only runs on success, leading to stale or incorrect analytics/logging." ;
    oc:severityLevel "MEDIUM" .

