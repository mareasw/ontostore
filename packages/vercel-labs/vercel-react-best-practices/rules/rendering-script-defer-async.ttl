oc:skill_vercel_labs_vercel_react_best_practices_rendering_script_defer_async a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rendering-script-defer-async" ;
    skos:broader "Performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "4cea07b7875ba7fc2c7465ff23b63a2bb334f90aaf2d9293d38d67b05fdb32ab" ;
    oc:differentia "that eliminates render-blocking by applying defer or async attributes to script tags" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_16732eec,
        oc:kn_2747000d,
        oc:kn_4f299be7,
        oc:kn_cde905a4 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DocumentCreated ;
    oc:resolvesIntent "configure script defer and async attributes",
        "eliminate render-blocking scripts",
        "improve first contentful paint",
        "optimize script loading" ;
    oc:yieldsState oc:ScriptsNonBlocking .

oc:kn_16732eec a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding any <script> tag in a Next.js custom Document or page" ;
    oc:directiveContent "Never include script tags without defer or async attributes, as they block HTML parsing during download and execution." ;
    oc:hasRationale "Render-blocking scripts delay First Contentful Paint and Time to Interactive, directly degrading user-perceived performance." ;
    oc:severityLevel "HIGH" .

oc:kn_2747000d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding scripts in Next.js applications" ;
    oc:directiveContent "In Next.js, prefer the next/script component with the strategy prop over raw HTML script tags." ;
    oc:hasRationale "next/script integrates with Next.js routing and optimization lifecycle, providing strategies like beforeInteractive, afterInteractive, lazyOnload, and worker for fine-grained control." .

oc:kn_4f299be7 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "Always, when evaluating page load performance" ;
    oc:directiveContent "Script tags without defer or async block HTML parsing for the full duration of script download AND execution, directly impacting FCP and TTI metrics." ;
    oc:hasRationale "The browser must halt the HTML parser when it encounters a synchronous script, creating a waterfall that delays both rendering and interactivity." ;
    oc:severityLevel "HIGH" .

oc:kn_cde905a4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between defer and async strategies for script loading" ;
    oc:directiveContent "Use defer for scripts that depend on the DOM or need to maintain execution order with other scripts. Use async for independent scripts like analytics." ;
    oc:hasRationale "defer guarantees execution order and runs after parsing, preserving dependencies; async executes immediately upon download, which is ideal for isolated scripts but breaks order guarantees." .

