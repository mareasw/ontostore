oc:kn_3732720a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating render-blocking resources" ;
    oc:directiveContent "Scripts without defer or async block both download and execution during HTML parsing, directly delaying First Contentful Paint and Time to Interactive metrics." ;
    oc:hasRationale "These are core Web Vitals that directly impact SEO ranking and user experience." ;
    oc:severityLevel "HIGH" .

oc:kn_6b6ef8fb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding scripts in Next.js applications" ;
    oc:directiveContent "In Next.js, prefer the next/script component with the strategy prop over raw <script> tags for optimal loading behavior." ;
    oc:hasRationale "next/script integrates with Next.js lifecycle and provides strategies like afterInteractive and beforeInteractive that align with framework rendering phases." ;
    oc:severityLevel "HIGH" .

oc:kn_6f1b0a32 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "Understanding the performance trade-off between defer and async" ;
    oc:directiveContent "Both defer and async download scripts in parallel with HTML parsing. The difference is execution timing: defer waits until parsing completes, async executes immediately upon download completion." ;
    oc:hasRationale "Knowing the execution model helps predict and debug script timing issues." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c1019945 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between defer and async attributes" ;
    oc:directiveContent "Use defer for scripts that depend on the DOM or other scripts (maintains execution order). Use async for independent scripts like analytics (no guaranteed order, executes immediately when ready)." ;
    oc:hasRationale "defer preserves order guarantees needed by interdependent scripts, while async maximizes parallelism for standalone scripts." ;
    oc:severityLevel "HIGH" .

oc:kn_f5e8b7dd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding any <script> tag to HTML" ;
    oc:directiveContent "Never use bare <script> tags without defer or async attributes — they block HTML parsing during download and execution, delaying FCP and TTI." ;
    oc:hasRationale "Render-blocking scripts are one of the most impactful and easily fixable performance bottlenecks." ;
    oc:severityLevel "CRITICAL" .

