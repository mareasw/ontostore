    oc:contentHash "ed468533f6e95f622859c884b122cf21f9f593ed6bb3d500a54de4b9f9bcb9fb" ;
    oc:differentia "reduces SVG coordinate precision to decrease file size while maintaining visual fidelity" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:FileNotFound ;
