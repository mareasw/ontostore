oc:kn_2526c4a5 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating SVG optimization trade-offs" ;
    oc:directiveContent "Reducing SVG coordinate precision reduces file size with no visual degradation for typical use cases." ;
    oc:hasRationale "Smaller SVG files mean faster transfers and parses, directly improving page load performance." ;
    oc:severityLevel "LOW" .

oc:kn_77dbd662 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Correct SVG path with reduced precision" ;
    oc:codeLanguage "svg" ;
    oc:directiveContent "<path d=\"M 10.3 20.8 L 30.9 40.2\" />" .

oc:kn_ce06d9b8 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When automating SVG precision reduction" ;
    oc:directiveContent "npx svgo --precision=1 --multipass icon.svg" ;
    oc:hasRationale "SVGO with --multipass ensures multiple optimization passes; --precision=1 targets coordinate rounding." ;
    oc:severityLevel "LOW" .

oc:kn_d9359a3e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or generating SVG path data" ;
    oc:directiveContent "Avoid excessive decimal precision in SVG path coordinates (e.g., 10.293847); use 1 decimal place (e.g., 10.3) to reduce file size." ;
    oc:hasRationale "Excessive precision bloats file size without perceptible visual difference since most SVGs are rendered at limited pixel density." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f86b50be a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding SVG coordinate precision" ;
    oc:directiveContent "Optimal precision depends on the viewBox size; smaller viewBoxes need less precision, but 1 decimal place is a good general default." ;
    oc:hasRationale "The visual impact of rounding is negligible relative to the viewBox dimensions, while file size savings are significant." ;
    oc:severityLevel "MEDIUM" .

