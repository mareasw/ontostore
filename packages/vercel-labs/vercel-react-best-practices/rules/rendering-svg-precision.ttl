oc:kn_09c37aeb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When exporting SVGs from design tools or hand-authoring SVG markup" ;
    oc:directiveContent "Never leave SVG path coordinates with excessive decimal precision (e.g., 6 decimal places like 10.293847) in production assets." ;
    oc:hasRationale "Design tools often export coordinates with floating-point precision that far exceeds what is visually distinguishable, resulting in bloated file sizes." ;
    oc:severityLevel "LOW" .

oc:kn_882fc958 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining the appropriate precision level for SVG optimization" ;
    oc:directiveContent "Choose coordinate precision relative to the SVG viewBox dimensions — larger viewBoxes may tolerate lower precision, smaller viewBoxes may need slightly more." ;
    oc:hasRationale "The relationship between viewBox size and pixel density determines the threshold at which rounding becomes visually noticeable; a one-size-fits-all precision may not be optimal." ;
    oc:severityLevel "LOW" .

oc:kn_dc48d012 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring or optimizing SVG files" ;
    oc:directiveContent "Reduce SVG coordinate precision to 1 decimal place; optimal precision depends on viewBox size but excessive precision (5+ decimals) is never justified." ;
    oc:hasRationale "Excessive decimal precision in SVG path coordinates dramatically increases file size without any visible difference, as screen pixels cannot represent sub-pixel detail beyond a certain threshold." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e48e81bd a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When automating SVG optimization in a build pipeline or manually optimizing SVG assets" ;
    oc:directiveContent "Use SVGO with --precision=1 --multipass flags to automate SVG coordinate precision reduction." ;
    oc:hasRationale "SVGO's multipass mode ensures repeated optimizations converge on minimal output, and precision flag controls decimal places uniformly across the entire SVG." ;
    oc:severityLevel "MEDIUM" .

oc:req_341e5166 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "npx" .

oc:req_f54cd32a a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "svgo" .

