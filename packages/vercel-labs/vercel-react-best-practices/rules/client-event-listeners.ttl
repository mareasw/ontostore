    oc:differentia "deduplicates global event listeners using useSWRSubscription to share a single listener across N component instances" ;
    oc:extends oc:skill_ontoskills_vercel_react_best_practices,
        oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:handlesFailure oc:MemoryLeak ;
