    oc:requiresState oc:ServerActionDefined ;
    oc:resolvesIntent "authenticate server mutations",
        "authorize server action calls",
        "secure server actions",
        "validate input in server actions" ;
    oc:yieldsState oc:ServerActionSecured .

oc:kn_5bf99561 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing any Server Action that modifies data" ;
    oc:directiveContent "For every Server Action: 1. Validate input with Zod schema 2. Authenticate via verifySession() 3. Authorize by checking session.user.role or session.user.id 4. Only then perform the mutation" ;
    oc:hasRationale "This order ensures invalid input is rejected cheaply before auth checks, and auth completes before any side effects." ;
    oc:severityLevel "HIGH" ;
    oc:stepOrder 1 .

oc:kn_600dd7d3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Every Server Action function (functions with 'use server' directive)" ;
    oc:directiveContent "Always verify authentication and authorization INSIDE each Server Action. Never rely solely on middleware, layout guards, or page-level checks—Server Actions can be invoked directly as public endpoints." ;
    oc:hasRationale "Server Actions are exposed as public endpoints just like API routes. Page-level or middleware checks can be bypassed by direct invocation." ;
    oc:severityLevel "CRITICAL" .

oc:kn_88a6f85c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When securing Server Actions with role-based or ownership-based access" ;
    oc:directiveContent "Combine both authentication (is this user logged in?) AND authorization (is this user allowed to do this specific action?) inside each Server Action." ;
    oc:hasRationale "Authentication alone is insufficient—a logged-in user should not be able to delete another user's account unless authorized." .

oc:kn_b12aa73f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any Server Action that modifies data" ;
    oc:directiveContent "Never write a Server Action that performs mutations without first verifying the user's session and authorization level inside the action body." ;
    oc:hasRationale "Without in-action auth checks, anyone can invoke the action directly, leading to unauthorized mutations." ;
    oc:severityLevel "CRITICAL" .

oc:kn_efe180bd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing security architecture for Next.js applications" ;
    oc:directiveContent "Treat Server Actions with the same security considerations as public-facing API endpoints." ;
    oc:hasRationale "Server Actions are network-callable endpoints despite looking like regular functions. The Next.js documentation explicitly recommends this parity." ;
    oc:severityLevel "HIGH" .

