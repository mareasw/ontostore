    oc:resolvesIntent "optimize loop performance",
        "reduce property lookup overhead",
        "refactor hot paths" .

oc:kn_31f7dd8a a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating whether a loop is worth optimizing" ;
    oc:directiveContent "Impact is LOW-MEDIUM: reduces repeated lookups proportionally to nesting depth × iteration count. Most impactful when nesting depth ≥ 2 and iterations ≥ 1000." ;
    oc:hasRationale "Modern JS engines inline-cache some patterns, but deep chains and dynamic access patterns can still deopt." ;
    oc:severityLevel "LOW" .

oc:kn_4f1e8bfb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing loops that run many iterations or access deeply nested object paths" ;
    oc:directiveContent "Never access deeply nested properties (e.g., obj.config.settings.value) or computed properties (e.g., arr.length) inside loop bodies when the value does not change across iterations." ;
    oc:hasRationale "Each iteration re-traverses the prototype chain and property chain, multiplying O(depth) lookups by N iterations unnecessarily." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a920d5df a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When refactoring loops for performance" ;
    oc:directiveContent "1. Identify loop-invariant property accesses inside the loop body 2. Extract each invariant to a const before the loop 3. Replace inner references with the cached variable" ;
    oc:hasRationale "Systematic extraction ensures no invariant is missed and the loop body remains clean." ;
    oc:stepOrder 1 .

oc:kn_dbab02b9 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When caching property access before any hot loop" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """const cachedValue = obj.deep.nested.path;
const len = arr.length;
for (let i = 0; i < len; i++) {
  process(cachedValue);
}""" .

oc:kn_e16e8b46 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing hot paths and tight loops" ;
    oc:directiveContent "Cache any property lookup that is invariant across loop iterations by assigning it to a local variable before the loop." ;
    oc:hasRationale "Local variable access is a register-level operation; property access requires prototype chain traversal. Caching converts N×O(depth) lookups to O(depth)+N register reads." ;
    oc:severityLevel "MEDIUM" .

