oc:skill_vercel_labs_vercel_react_best_practices_js_min_max_loop a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "js-min-max-loop" ;
    skos:broader "Performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "87dfb67e2f39df6ad8bcfb5b78c5fb364d3c07554ad188a202408d99f3763421" ;
    oc:differentia "uses O(n) single-pass loop instead of O(n log n) sort to find min/max values in arrays" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_21dbe2ef,
        oc:kn_24bf4ae2,
        oc:kn_ac86c2f3,
        oc:kn_b9ed4ad1,
        oc:kn_dd213f93 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "avoid unnecessary sorting when finding extremal values",
        "find minimum or maximum value in array efficiently",
        "optimize min/max array operations" ;
    oc:yieldsState oc:CodeOptimized .

oc:kn_21dbe2ef a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using Math.min/Math.max with spread operator on arrays of unknown or large size" ;
    oc:directiveContent "Do not use Math.min(...array) or Math.max(...array) with spread operator on large arrays. Chrome limits spread to ~124,000 elements and Safari to ~638,000; exceeding these throws an error." ;
    oc:hasRationale "The spread operator passes each element as an argument to the function, and JavaScript engines impose maximum argument limits that vary by browser." ;
    oc:severityLevel "HIGH" .

oc:kn_24bf4ae2 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When choosing between loop and sort approaches for min/max extraction" ;
    oc:directiveContent "Loop-based min/max is O(n) time and O(1) space. Sort-based min/max is O(n log n) time and O(n) space if array is copied before sorting." ;
    oc:hasRationale "The asymptotic difference becomes significant on large arrays: for 1M elements, sort is roughly 20x slower than a single pass." ;
    oc:severityLevel "LOW" .

oc:kn_ac86c2f3 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing a min/max loop on any array" ;
    oc:directiveContent "Always handle the empty array case before iterating. Return null or a sensible default when the input array has length 0." ;
    oc:hasRationale "Accessing index 0 on an empty array returns undefined, which propagates NaN or errors through comparisons and downstream code." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b9ed4ad1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finding min or max values in JavaScript/TypeScript arrays" ;
    oc:directiveContent "Never use Array.sort() to find the minimum or maximum element in an array. Sorting is O(n log n) when a single-pass loop is O(n)." ;
    oc:hasRationale "Sorting performs unnecessary work by ordering all elements when only the extremal value is needed, wasting CPU cycles and potentially memory if the array is copied before sorting." ;
    oc:severityLevel "HIGH" .

oc:kn_dd213f93 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting minimum, maximum, or both from an array of objects or primitives" ;
    oc:directiveContent "Use a single-pass loop to find min/max values, comparing each element against tracked extremal values in one iteration." ;
    oc:hasRationale "A single loop is O(n) with no extra memory allocation for copies or sorting overhead, making it optimal for this specific task." ;
    oc:severityLevel "MEDIUM" .

