oc:skill_vercel_labs_vercel_react_best_practices_js_cache_function_results a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "js-cache-function-results" ;
    skos:broader "Performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "3daaa11d24f4295cb6be8bc6f407f2ce83cc7b5bd1f0e68891ea8ab835721dc7" ;
    oc:differentia "uses module-level Map caching to memoize repeated pure function calls and avoid redundant computation during React renders" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "function-name or component code to optimize" ;
    oc:hasCategory "development" ;
    oc:hasPackageName "vercel-react-best-practices" ;
    oc:impartsKnowledge oc:kn_218b446d,
        oc:kn_2fdc723f,
        oc:kn_48dc8fbc,
        oc:kn_55525675,
        oc:kn_75f56f23 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "avoid redundant computation",
        "cache function results",
        "memoize pure function outputs",
        "optimize repeated function calls" ;
    oc:yieldsState oc:PerformanceOptimized .

oc:kn_218b446d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mapping over lists in React components that invoke computation-heavy functions" ;
    oc:directiveContent "Do not call expensive pure functions (like slugify) inside render loops without caching, as they execute redundantly for duplicate inputs on every render." ;
    oc:hasRationale "Redundant computation wastes CPU cycles and increases render time, especially with large lists where the same inputs recur." ;
    oc:severityLevel "HIGH" .

oc:kn_2fdc723f a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When rendering lists with 100+ items where many share the same computed values" ;
    oc:directiveContent "Module-level caching reduces repeated computation from O(n) per render to O(1) per unique input, providing significant speedups when the same inputs recur across list items or re-renders." ;
    oc:hasRationale "The Vercel Dashboard achieved a 2x speed improvement partly through this pattern." ;
    oc:severityLevel "MEDIUM" .

oc:kn_48dc8fbc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When caching pure function results that are called repeatedly with the same inputs" ;
    oc:directiveContent "Use a module-level Map for caching function results rather than React hooks like useMemo, so the cache works everywhere: utilities, event handlers, and non-component code." ;
    oc:hasRationale "React hooks only work inside components; module-level Maps are universally accessible across the entire module scope." ;
    oc:severityLevel "HIGH" .

oc:kn_55525675 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using module-level caches for values that depend on mutable external state like cookies or auth tokens" ;
    oc:directiveContent "Cache invalidation must be handled manually — set cached values to null or clear Map entries when the underlying data changes (e.g., auth state changes)." ;
    oc:hasRationale "Without explicit invalidation, stale cached values will be returned indefinitely, causing incorrect behavior." ;
    oc:severityLevel "CRITICAL" .

oc:kn_75f56f23 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a caching strategy based on function signature complexity" ;
    oc:directiveContent "For single-value functions (e.g., boolean checks), a simple nullable variable is sufficient; for multi-key lookups, use a Map." ;
    oc:hasRationale "Simpler caching mechanisms reduce overhead and are easier to reason about for trivial cases." ;
    oc:severityLevel "LOW" .

