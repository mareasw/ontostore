    oc:yieldsState oc:PerformanceOptimized .

oc:kn_5c6a27be a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which functions to cache" ;
    oc:directiveContent "Only cache pure functions — functions whose output depends solely on their inputs with no side effects." ;
    oc:hasRationale "Impure functions or functions depending on mutable external state will return incorrect cached results." ;
    oc:severityLevel "CRITICAL" .

oc:kn_62c1b2b5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering lists that call utility functions on each item" ;
    oc:directiveContent "Never call expensive pure functions (like slugify) repeatedly inside render loops with the same inputs — each invocation redundantly recomputes the same result." ;
    oc:hasRationale "Redundant computation wastes CPU cycles and can significantly degrade performance with large datasets." ;
    oc:severityLevel "HIGH" .

oc:kn_79733cf9 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When caching values derived from mutable state like cookies or auth tokens" ;
    oc:directiveContent "Module-level caches persist across renders and re-renders. You must invalidate them when the underlying data or auth state changes." ;
    oc:hasRationale "Stale cached values can cause incorrect behavior when the source data changes without cache invalidation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_96625a04 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding where to place a function result cache" ;
    oc:directiveContent "Use a module-level Map for caching, not a React hook, so the cache works everywhere: utility functions, event handlers, and components alike." ;
    oc:hasRationale "Hooks are limited to React component scope; module-level caches are universally accessible across the module." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cd6681f9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between Map cache and simple variable cache" ;
    oc:directiveContent "For single-value caching, a simple nullable variable (let x: T | null = null) is simpler than a Map. Use Map when caching multiple keys." ;
    oc:hasRationale "Simpler patterns reduce code complexity and are easier to reason about for single-value scenarios." .

_:ref_09b9bcbd2d12fae1 a oc:WorkflowStep ;
    dcterms:description "Identify pure functions called repeatedly with the same inputs inside render paths or loops." ;
    oc:expectedOutcome "A list of candidate functions that would benefit from caching." ;
    oc:stepId "identify" .

_:ref_b8088a7f1fa6c7bd a oc:WorkflowStep ;
    dcterms:description "Implement the module-level cache and wrapper function using the chosen pattern." ;
    oc:expectedOutcome "A cached version of the function that checks the cache before computing." ;
    oc:stepDependsOn _:ref_fc1c2fda4e526393 ;
    oc:stepId "implement-cache" .

_:ref_fc1c2fda4e526393 a oc:WorkflowStep ;
    dcterms:description "Choose cache pattern: Map for multi-key functions, nullable variable for single-value functions." ;
    oc:expectedOutcome "The appropriate caching strategy is selected." ;
    oc:stepDependsOn _:ref_09b9bcbd2d12fae1 ;
    oc:stepId "choose-pattern" .

