oc:skill_vercel_labs_vercel_react_best_practices_rerender_dependencies a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "rerender-dependencies" ;
    skos:broader "Performance optimization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/vercel-labs/vercel-react-best-practices" ;
    oc:contentHash "17eb5830956fb56486fd3cfc7431f5849d39751730c05ad9e77dd4f0c27169c5" ;
    oc:dependsOnSkill oc:skill_vercel_react_best_practices ;
    oc:differentia "narrows useEffect dependency arrays to primitive values instead of object references to minimize unnecessary effect re-runs" ;
    oc:extends oc:skill_vercel_labs_vercel_react_best_practices ;
    oc:hasArgumentHint "React component code with useEffect hooks" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_8ae208fd,
        oc:kn_8ca919bf,
        oc:kn_a8da96ec,
        oc:kn_dd634af4 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "minimize useEffect re-runs",
        "optimize effect dependencies",
        "reduce unnecessary re-renders in React components" .

oc:kn_8ae208fd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing useEffect dependency arrays in React components" ;
    oc:directiveContent "Never pass entire objects (e.g., `user`) as useEffect dependencies when the effect only uses a single primitive property (e.g., `user.id`). Object references change on every render, causing the effect to re-run unnecessarily." ;
    oc:hasRationale "Object references are compared by identity, not value — a new object is created on each render even if the data is identical, triggering spurious effect executions." ;
    oc:severityLevel "HIGH" .

oc:kn_8ca919bf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When an effect depends on a condition derived from a frequently changing value (e.g., window width, scroll position)" ;
    oc:directiveContent "Compute derived state (e.g., boolean thresholds) outside the useEffect, then use the derived primitive as the dependency instead of the raw source value." ;
    oc:hasRationale "Computing derived state outside the effect narrows the dependency to a less frequently changing value. For example, a boolean `isMobile` only transitions twice, while raw `width` changes on every pixel resize." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a8da96ec a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating React component performance" ;
    oc:directiveContent "Using object dependencies in useEffect can cause effects to fire on every render, leading to cascading re-renders, unnecessary network requests, or repeated computations." ;
    oc:hasRationale "Unnecessary effect re-runs are a common source of performance degradation and bugs in React applications, especially when effects trigger state updates." ;
    oc:severityLevel "LOW" .

oc:kn_dd634af4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining useEffect dependencies for any React component" ;
    oc:directiveContent "Prefer primitive values (strings, numbers, booleans) over object references in useEffect dependency arrays. Extract only the specific properties the effect actually uses." ;
    oc:hasRationale "Primitive values are compared by value, so effects only re-run when the actual data changes, not when a parent re-renders with a new object reference." ;
    oc:severityLevel "MEDIUM" .

