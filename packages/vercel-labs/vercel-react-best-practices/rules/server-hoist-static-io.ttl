oc:kn_0bbdc0d1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to apply the hoisting pattern" ;
    oc:directiveContent "Do NOT hoist I/O to module level if the asset varies per request/user, may change at runtime, is very large (memory pressure), or contains sensitive data that shouldn't persist in memory." ;
    oc:hasRationale "Hoisting inappropriate assets causes stale data, excessive memory consumption, or security exposure." ;
    oc:severityLevel "HIGH" .

oc:kn_1a03b540 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assets are semi-static (updated occasionally but not per-request)" ;
    oc:directiveContent "Use caching with TTL instead of module-level hoisting when files may change during runtime." ;
    oc:hasRationale "Module-level variables live for the lifetime of the function instance; TTL-based caching allows periodic refresh without per-request overhead." .

oc:kn_298e4864 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "Serverless and edge function deployments" ;
    oc:directiveContent "Module-level hoisting trades a one-time blocking cost during module initialization for O(1) per-request access. In traditional serverless, cold starts re-run module-level code but warm invocations reuse loaded assets." .

oc:kn_3d705457 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When refactoring route handlers that load static assets" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent "Move static fetch() or fs.readFile() calls outside the handler function to module scope. Inside the handler, await the already-started promise to get the result." ;
    oc:hasRationale "Module-level code executes once on first import, not per request, so assets are loaded a single time and reused." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5f70d3ba a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading fonts, images, config files, or templates in Next.js route handlers or server functions" ;
    oc:directiveContent "Never perform static file/network I/O inside a request handler function body — it re-executes on every single request invocation, wasting CPU and increasing latency." ;
    oc:hasRationale "Per-request I/O for unchanging assets is pure overhead that compounds under load, especially in serverless environments." ;
    oc:severityLevel "HIGH" .

oc:kn_7f2e9084 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deploying to Vercel with Fluid Compute enabled" ;
    oc:directiveContent "With Vercel Fluid Compute, module-level caching is especially effective because concurrent requests share the same function instance, keeping static assets warm in memory." ;
    oc:hasRationale "Fluid Compute extends function lifetime and enables true in-memory reuse across many requests, amplifying the benefit of hoisting." .

oc:kn_c8164bcd a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synchronous file loading is acceptable at module init time" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """import { readFileSync } from 'fs'
import { join } from 'path'

const fontData = readFileSync(join(process.cwd(), 'public/fonts/Inter.ttf'))

export async function GET(request: Request) {
  return new ImageResponse(..., { fonts: [{ name: 'Inter', data: fontData }] })
}""" .

oc:kn_cb3ebe37 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When optimizing any Next.js server route handler" ;
    oc:directiveContent "1. Identify static I/O (fetch, fs.readFile) inside handler body 2. Move the I/O call to module scope (outside the function) 3. Store the resulting promise (async) or value (sync fs) in a module-level variable 4. Inside the handler, await or reference the module-level promise/value 5. Verify the asset does not vary per request or change at runtime" ;
    oc:stepOrder 1 .

oc:kn_e00b7ecc a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading fonts and images for OG image generation" ;
