                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "1.1 Check Cheap Conditions Before Async Flags" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
