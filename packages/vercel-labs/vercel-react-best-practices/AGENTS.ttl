oc:kn_00da035c a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When importing large third-party libraries or heavy components not needed on initial render" ;
    oc:directiveContent "Use next/dynamic with ssr: false for non-critical third-party libraries (analytics, logging) and heavy components (Monaco, charts). Preload based on user intent (hover/focus)." ;
    oc:hasRationale "Directly affects Time to Interactive and Largest Contentful Paint. Monaco editor is ~300KB; deferring it avoids blocking the main chunk." ;
    oc:severityLevel "CRITICAL" .

oc:kn_10523a88 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When writing Server Actions ('use server' functions)" ;
    oc:directiveContent "Server Actions are public endpoints. Always validate input with Zod schemas and verify authentication/authorization inside each action, not just in middleware." ;
    oc:hasRationale "Server Actions can be invoked directly by any client, bypassing page-level guards and middleware." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1591825b a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working on projects with React Compiler enabled" ;
    oc:directiveContent "If React Compiler is enabled, manual memoization with memo() and useMemo() is not necessary for many cases, but functional setState updates are still recommended for correctness." ;
    oc:hasRationale "React Compiler automatically optimizes re-renders, dependency tracking, and static JSX hoisting. But stale closure bugs remain a correctness issue." ;
    oc:severityLevel "LOW" .

oc:kn_2e7ba5d3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any async code in React/Next.js (API routes, Server Actions, data fetching)" ;
    oc:directiveContent "Never use sequential awaits for independent async operations. Always use Promise.all() or dependency-based parallelization to eliminate waterfalls." ;
    oc:hasRationale "Waterfalls are the #1 performance killer. Each sequential await adds full network latency, yielding 2-10x improvement when parallelized." ;
    oc:severityLevel "CRITICAL" .

oc:kn_377d5c91 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the same data is fetched in multiple components within one request" ;
    oc:directiveContent "Use React.cache() for per-request deduplication of DB queries, auth checks, and non-fetch async work. Use LRU cache for cross-request deduplication." ;
    oc:hasRationale "React.cache() deduplicates within a single request. Next.js fetch is already memoized, but React.cache() is needed for DB queries and other async work." ;
    oc:severityLevel "MEDIUM" .

oc:kn_441ed21e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When importing from libraries like lucide-react, @mui/material, lodash, date-fns, rxjs" ;
    oc:directiveContent "Avoid barrel file imports (e.g., index.js with export * from './module'). Import directly from source files or use optimizePackageImports in Next.js 13.5+." ;
    oc:hasRationale "Barrel files can load up to 10,000 unused modules, taking 200-800ms per import. Tree-shaking doesn't help for external packages." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4cd696ba a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When loading static assets in route handlers or server functions" ;
    oc:directiveContent "Module-level code runs once when the module is first imported, not on every request. Hoist static I/O (fonts, logos, config) to module level to eliminate redundant reads." ;
    oc:hasRationale "Especially effective with Vercel Fluid Compute where concurrent requests share the same function instance." ;
    oc:severityLevel "HIGH" .

oc:kn_53d5599a a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When rendering content that depends on localStorage, cookies, or other client-only storage" ;
    oc:directiveContent "For client-only data (theme, preferences) that causes hydration mismatch, use a synchronous inline script that sets the DOM before React hydrates." ;
    oc:hasRationale "Prevents both SSR breakage (localStorage undefined on server) and post-hydration flickering (flash of default then correct value)." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5e9b3720 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing React components" ;
    oc:directiveContent "Never define components inside other components. This creates a new component type on every render, causing React to fully remount it, destroying all state and DOM." ;
    oc:hasRationale "Symptoms include input fields losing focus, animations restarting, effects re-running on every parent render, and scroll position resets." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5fba2b63 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing React Server Components or SSR code" ;
    oc:directiveContent "Never use mutable module-level variables for request-scoped data in Server Components. Concurrent renders in the same process cause race conditions and cross-request data leaks." ;
    oc:hasRationale "Server renders can run concurrently in the same process. Module scope is process-wide shared memory, not request-local state." ;
    oc:severityLevel "HIGH" .

oc:kn_6deccdf6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When fetching data in async components that have surrounding static UI" ;
    oc:directiveContent "Use Suspense boundaries to show wrapper UI immediately while data loads in child components, rather than blocking the entire page with top-level await." ;
    oc:hasRationale "Faster initial paint. Sidebar, header, and footer render immediately while only the data-dependent component waits." ;
    oc:severityLevel "HIGH" .

oc:kn_71b58456 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing conditional async logic" ;
    oc:directiveContent "Evaluate cheap synchronous conditions before expensive async flags. Move await into branches where the result is actually used." ;
    oc:hasRationale "Avoids paying for async calls (network, feature flags, DB) when a compound condition can never be true due to a synchronous guard." ;
    oc:severityLevel "HIGH" .

oc:kn_9a08de05 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using React.cache() for per-request deduplication" ;
    oc:directiveContent "React.cache() uses shallow equality (Object.is) for cache hits. Inline objects as arguments create new references each call, preventing cache hits." ;
    oc:hasRationale "Passing { uid: 1 } twice creates two different objects that never hit cache. Pass the same reference or use primitive arguments." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9e877c80 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When beginning performance optimization work on a React/Next.js codebase" ;
    oc:directiveContent "Before optimizing, identify which category the bottleneck falls into: waterfalls (sequential awaits), bundle size (large imports), server-side (serialization, shared state), re-renders (unnecessary renders), or rendering (DOM/layout work)." ;
    oc:hasRationale "The 8 categories are ordered by impact. Start with waterfalls and bundle size for maximum ROI." ;
    oc:severityLevel "HIGH" .

oc:kn_b68d3b95 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any Server Action ('use server' functions)" ;
    oc:directiveContent "Always authenticate and authorize Server Actions internally. Server Actions are exposed as public endpoints and can be invoked directly, bypassing middleware or layout guards." ;
    oc:hasRationale "Next.js documentation explicitly states: treat Server Actions with the same security considerations as public-facing API endpoints." ;
    oc:severityLevel "CRITICAL" .

oc:kn_be2339a6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating state based on current state value, especially inside useCallback/useMemo" ;
    oc:directiveContent "Use functional setState updates (setItems(curr => [...curr, item])) instead of referencing state directly in callbacks. This prevents stale closures and creates stable callback references." ;
    oc:hasRationale "Functional updates eliminate the most common source of React closure bugs and remove state from dependency arrays." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ccc6946c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When passing props from Server Components to Client Components" ;
    oc:directiveContent "Only pass fields the client actually uses across RSC boundaries. The Server/Client boundary serializes all object properties, directly impacting page weight and load time." ;
    oc:hasRationale "Serializing 50 fields when only 1 is used wastes network bandwidth and increases page load time." ;
    oc:severityLevel "HIGH" .

oc:kn_e498cd73 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which performance optimizations to apply" ;
    oc:directiveContent "Prioritize optimization rules by impact: CRITICAL (waterfalls, bundle size) > HIGH (server-side perf, auth) > MEDIUM (re-renders, rendering) > LOW (JS micro-optimizations)." ;
    oc:hasRationale "The guide is organized by impact. Waterfall elimination and bundle size reduction yield the largest measurable gains (2-10x improvement)." ;
    oc:severityLevel "HIGH" .

oc:kn_ed3c9311 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When tracking high-frequency updates like mouse movement, timers, or transient flags" ;
    oc:directiveContent "Use useRef for transient values that change frequently (mouse position, intervals, flags) and don't need to trigger re-renders. Keep useState for UI-visible state." ;
    oc:hasRationale "Updating a ref does not trigger a re-render. Using useState for high-frequency values causes performance degradation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f0754090 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When tempted to add useEffect to synchronize state with props" ;
    oc:directiveContent "Calculate derived values during render instead of storing them in state or computing in effects. If a value can be computed from current props/state, derive it inline." ;
    oc:hasRationale "Derived state in effects causes extra renders and state drift. Inline derivation is simpler and more correct." ;
    oc:severityLevel "MEDIUM" .

