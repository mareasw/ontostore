oc:kn_0ffc03f3 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building an x402 paid API from scratch" ;
    oc:directiveContent "1. Verify wallet auth with `npx awal@2.0.3 status` 2. Get payment address with `npx awal@2.0.3 address` 3. Create project dir, run `npm init -y`, install `express @x402/express @x402/core @x402/evm @x402/extensions` 4. Create `index.js` with x402ResourceServer, ExactEvmScheme, paymentMiddleware, and route handlers 5. Run `node index.js` 6. Test with `curl` (expect 402) and `npx awal@2.0.3 x402 pay` (expect 200)" ;
    oc:hasRationale "Provides the complete sequential workflow for creating a monetized API endpoint" ;
    oc:stepOrder 1 .

oc:kn_25efdf67 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When deploying to production" ;
    oc:directiveContent "The default facilitator at https://x402.org/facilitator is for development; for production use the Coinbase CDP facilitator which requires CDP_API_KEY_ID and CDP_API_KEY_SECRET environment variables" ;
    oc:hasRationale "The development facilitator may not support mainnet settlement reliably" ;
    oc:severityLevel "MEDIUM" .

oc:kn_43d244e1 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding Bazaar discovery to a route" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """extensions: {
  ...declareDiscoveryExtension({
    output: {
      example: { result: "example response" },
      schema: { properties: { result: { type: "string" } } }
    }
  })
}""" ;
    oc:hasRationale "Enables automatic service discovery by other agents in the x402 ecosystem" .

oc:kn_6715f73d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — core boilerplate for setting up x402 payment middleware" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """const { paymentMiddleware } = require("@x402/express");
const { x402ResourceServer, HTTPFacilitatorClient } = require("@x402/core/server");
const { ExactEvmScheme } = require("@x402/evm/exact/server");

const facilitator = new HTTPFacilitatorClient({ url: "https://x402.org/facilitator" });
const server = new x402ResourceServer(facilitator);
server.register("eip155:8453", new ExactEvmScheme());

app.use(paymentMiddleware(
  { "GET /api/example": { accepts: { scheme: "exact", price: "$0.01", network: "eip155:8453", payTo: PAY_TO }, description: "...", mimeType: "application/json" } },
  server
));""" ;
    oc:hasRationale "This is the minimal working pattern that must be present in every x402 server" .

oc:kn_6f9b93f7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining route config for endpoints that should be discoverable" ;
    oc:directiveContent "Use `declareDiscoveryExtension` with `output.example` and `output.schema` to register endpoints with the x402 Bazaar for automatic agent discoverability" ;
    oc:hasRationale "Without discovery extensions, other agents cannot find the service via the Bazaar marketplace" .

oc:kn_715b3978 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding pricing for endpoints" ;
    oc:directiveContent "Price simple lookups at $0.001-$0.01, API proxies at $0.01-$0.10, compute-heavy at $0.10-$0.50, AI inference at $0.05-$1.00" ;
    oc:hasRationale "Reasonable pricing drives adoption; overpricing deters agent consumers" .

oc:kn_b0d03a43 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any monetization workflow" ;
    oc:directiveContent "Do not skip wallet authentication before creating the server — `npx awal@2.0.3 status` must succeed first" ;
    oc:hasRationale "Without an authenticated wallet, payments cannot be received and the payTo address will be invalid" ;
    oc:severityLevel "CRITICAL" .

oc:kn_da738bd5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mixing free and paid endpoints" ;
    oc:directiveContent "Register free endpoints (e.g. /health) BEFORE the payment middleware; payment middleware only applies to routes registered after it" ;
    oc:hasRationale "Express middleware is order-dependent — payment middleware will intercept all subsequent routes" ;
    oc:severityLevel "HIGH" .

oc:kn_e613db12 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before setting up the project" ;
    oc:directiveContent "Node.js must be installed. Packages required: express, @x402/express, @x402/core, @x402/evm, @x402/extensions" .

_:ref_227c2a205ef166b2 a oc:WorkflowStep ;
    dcterms:description "Create project directory, init npm, install express @x402/express @x402/core @x402/evm @x402/extensions" ;
    oc:expectedOutcome "Project directory with node_modules containing all dependencies" ;
    oc:stepDependsOn _:ref_f52671cd6db66bd1 ;
    oc:stepId "setup-project" .

_:ref_2ffba74311a8cce8 a oc:WorkflowStep ;
    dcterms:description "Verify wallet is authenticated with `npx awal@2.0.3 status`" ;
    oc:expectedOutcome "Wallet shows as authenticated and ready" ;
    oc:stepId "check-wallet" .

_:ref_e698ffef7432ba38 a oc:WorkflowStep ;
    dcterms:description "Start server with `node index.js`" ;
    oc:expectedOutcome "Server listening on port 3000" ;
    oc:stepDependsOn _:ref_fcc3a2c1d999f39e ;
    oc:stepId "run-server" .

_:ref_f52671cd6db66bd1 a oc:WorkflowStep ;
    dcterms:description "Get wallet address with `npx awal@2.0.3 address` to use as payTo" ;
    oc:expectedOutcome "Ethereum address displayed for payment receipt" ;
    oc:stepDependsOn _:ref_2ffba74311a8cce8 ;
    oc:stepId "get-address" .

_:ref_fcc3a2c1d999f39e a oc:WorkflowStep ;
    dcterms:description "Create index.js with x402ResourceServer, ExactEvmScheme, paymentMiddleware, and route handlers" ;
    oc:expectedOutcome "Complete server file with payment-protected endpoints" ;
    oc:stepDependsOn _:ref_227c2a205ef166b2 ;
    oc:stepId "write-server" .

