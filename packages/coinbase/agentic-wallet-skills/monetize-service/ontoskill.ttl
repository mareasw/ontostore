oc:skill_coinbase_agentic_wallet_skills_monetize_service a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "monetize-service" ;
    skos:broader "Payment server generator" ;
    prov:wasDerivedFrom "../.agents/skills/coinbase/agentic-wallet-skills/monetize-service" ;
    oc:contentHash "8aaf083c63cc3897e6c6b8666011274c24231999fa63c263be3f586b6642bf2a" ;
    oc:dependsOnSkill oc:skill_ontoskills_authenticate_wallet ;
    oc:differentia "that creates an Express-based x402 payment-gated API enabling per-request USDC charging on Base network" ;
    oc:handlesFailure oc:NetworkTimeout,
        oc:PermissionDenied,
        oc:WalletNotAuthenticated ;
    oc:hasAllowedTool "Bash(curl *)",
        "Bash(mkdir *)",
        "Bash(node *)",
        "Bash(npm *)",
        "Bash(npx awal@2.0.3 address*)",
        "Bash(npx awal@2.0.3 status*)",
        "Bash(npx awal@2.0.3 x402 details *)",
        "Bash(npx awal@2.0.3 x402 pay *)" ;
    oc:hasArgumentHint "service description or API endpoint specification" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Build and deploy a paid API that other agents can pay to use via x402. Use when you or the user want to monetize an API, make money, earn money, offer a service, sell a service to other agents, charge for endpoints, create a paid endpoint, or set up a paid service. Covers \"make money by offering an endpoint\", \"sell a service\", \"monetize your data\", \"create a paid API\"." ;
    oc:hasName "monetize-service" ;
    oc:hasPackageName "awal" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: monetize-service
description: Build and deploy a paid API that other agents can pay to use via x402. Use when you or the user want to monetize an API, make money, earn money, offer a service, sell a service to other agents, charge for endpoints, create a paid endpoint, or set up a paid service. Covers "make money by offering an endpoint", "sell a service", "monetize your data", "create a paid API".
user-invocable: true
disable-model-invocation: false
allowed-tools: ["Bash(npx awal@2.0.3 status*)", "Bash(npx awal@2.0.3 address*)", "Bash(npx awal@2.0.3 x402 details *)", "Bash(npx awal@2.0.3 x402 pay *)", "Bash(npm *)", "Bash(node *)", "Bash(curl *)", "Bash(mkdir *)"]
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Create an Express server that charges USDC for API access using the x402 payment protocol. Callers pay per-request in USDC on Base — no accounts, API keys, or subscriptions needed. Your service is automatically discoverable by other agents via the x402 Bazaar." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 4 ;
                            oc:tableCaption "## Pricing Guidelines" ;
                            oc:tableMarkdown """| Use Case               | Suggested Price |
| ---------------------- | --------------- |
| Simple data lookup     | $0.001 - $0.01 |
| API proxy / enrichment | $0.01 - $0.10  |
| Compute-heavy query    | $0.10 - $0.50  |
| AI inference           | $0.05 - $1.00  |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 23 ;
                    oc:sectionTitle "Pricing Guidelines" ],
