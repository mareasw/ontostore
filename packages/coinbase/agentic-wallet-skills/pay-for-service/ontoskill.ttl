@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coinbase_agentic_wallet_skills_pay_for_service a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "pay-for-service" ;
    skos:broader "paid API request executor" ;
    prov:wasDerivedFrom "../.agents/skills/coinbase/agentic-wallet-skills/pay-for-service" ;
    oc:contentHash "1d893db92c12469914096f003b1e7be620bbbbe46a944f895e564c89bd982101" ;
    oc:dependsOnSkill oc:skill_ontoskills_authenticate_wallet,
        oc:skill_ontoskills_search_for_service ;
    oc:differentia "automates x402 protocol payment with USDC on Base network" ;
    oc:handlesFailure oc:InsufficientBalance,
        oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasAllowedTool "Bash(npx awal@2.0.3 balance*)",
        "Bash(npx awal@2.0.3 status*)",
        "Bash(npx awal@2.0.3 x402 pay *)" ;
    oc:hasArgumentHint "url [-X method] [-d json] [-q params] [-h json] [--max-amount n]" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Make a paid API request to an x402 endpoint with automatic USDC payment. Use when you or the user want to call a paid API, make an x402 request, use a paid service, or pay for an API call. Use after finding a service with search-for-service." ;
    oc:hasName "pay-for-service" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Use the `npx awal@2.0.3 x402 pay` command to call paid API endpoints with automatic USDC payment on Base." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """npx awal@2.0.3 x402 pay <url> [-X <method>] [-d <json>] [-q <params>] [-h <json>] [--max-amount <n>] [--json]
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 23-25" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Command Syntax" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\"No X402 payment requirements found\" - URL may not be an x402 endpoint; use `search-for-service` to find valid endpoints" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\"Not authenticated\" - Run `awal auth login <email>` first, or see `authenticate-wallet` skill" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "\"Insufficient balance\" - Fund wallet with USDC; see `fund` skill" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Error Handling" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**IMPORTANT**: Always single-quote amounts that use `$` to prevent bash variable expansion (e.g. `'$1.00'` not `$1.00`)." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "X402 uses USDC atomic units (6 decimals):" ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 4 ;
                            oc:tableCaption "X402 uses USDC atomic units (6 decimals)" ;
                            oc:tableMarkdown """| Atomic Units | USD   |
| ------------ | ----- |
| 1000000      | $1.00 |
| 100000       | $0.10 |
| 50000        | $0.05 |
| 10000        | $0.01 |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "USDC Amounts" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "If you don't know the endpoint URL, use the `search-for-service` skill to find services first" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Must be authenticated (`npx awal@2.0.3 status` to check, see `authenticate-wallet` skill)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Wallet must have sufficient USDC balance (`npx awal@2.0.3 balance` to check)" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Prerequisites" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Make a GET request (auto-pays)
npx awal@2.0.3 x402 pay https://example.com/api/weather

# Make a POST request with body
npx awal@2.0.3 x402 pay https://example.com/api/sentiment -X POST -d '{"text": "I love this product"}'

# Limit max payment to $0.10
npx awal@2.0.3 x402 pay https://example.com/api/data --max-amount 100000
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 64-73" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Examples" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Do not pass unvalidated user input into the command." ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**max-amount**: Must be a positive integer (`^\\d+$`)." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**url**: Must be a valid URL starting with `https://` or `http://`. Reject if it contains spaces, semicolons, pipes, backticks, or shell metacharacters." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**data (-d)**: Must be valid JSON. Always wrap in single quotes to prevent shell expansion." ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Before constructing the command, validate all user-provided values to prevent shell injection:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Input Validation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 7 ;
                            oc:tableCaption "## Options" ;
                            oc:tableMarkdown """| Option                  | Description                                        |
| ----------------------- | -------------------------------------------------- |
| `-X, --method <method>` | HTTP method (default: GET)                         |
| `-d, --data <json>`     | Request body as JSON string                        |
| `-q, --query <params>`  | Query parameters as JSON string                    |
| `-h, --headers <json>`  | Custom HTTP headers as JSON string                 |
| `--max-amount <amount>` | Max payment in USDC atomic units (1000000 = $1.00) |
| `--correlation-id <id>` | Group related operations                           |
| `--json`                | Output as JSON                                     |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Options" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "If the wallet is not authenticated, refer to the `authenticate-wallet` skill." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """npx awal@2.0.3 status
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 15-17" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Confirm wallet is initialized and authed" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Making Paid x402 Requests" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: pay-for-service
description: Make a paid API request to an x402 endpoint with automatic USDC payment. Use when you or the user want to call a paid API, make an x402 request, use a paid service, or pay for an API call. Use after finding a service with search-for-service.
user-invocable: true
disable-model-invocation: false
allowed-tools: ["Bash(npx awal@2.0.3 status*)", "Bash(npx awal@2.0.3 balance*)", "Bash(npx awal@2.0.3 x402 pay *)"]
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Complete workflow for making a paid x402 API request with automatic USDC payment" ;
            oc:hasStep _:ref_150150b4d5bbef83,
                _:ref_2d8bee0daac90040,
                [ a oc:WorkflowStep ;
                    dcterms:description "Run npx awal@2.0.3 x402 pay with validated URL and options" ;
                    oc:expectedOutcome "API response received, payment automatically deducted" ;
                    oc:stepDependsOn _:ref_150150b4d5bbef83,
                        _:ref_2d8bee0daac90040,
                        _:ref_a6273298ff878e72 ;
                    oc:stepId "execute-payment" ],
                _:ref_a6273298ff878e72 ;
            oc:workflowId "x402-pay-workflow" ;
            oc:workflowName "Execute Paid API Request" ] ;
    oc:impartsKnowledge oc:kn_238965cb,
        oc:kn_310040ee,
        oc:kn_6ffe9896,
        oc:kn_bdd319e5,
        oc:kn_de8f1e6d,
        oc:kn_fa0cd4a3 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "call x402 endpoint with automatic payment",
        "make paid API request",
        "pay for API service",
        "use paid API" ;
    oc:yieldsState oc:APIResponseReceived,
        oc:PaymentCompleted .

oc:kn_238965cb a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user wants to use a paid service but hasn't specified a URL" ;
    oc:directiveContent "If you don't know the endpoint URL, use the search-for-service skill to discover available x402 services first." ;
    oc:hasRationale "x402 pay requires a valid endpoint URL; guessing URLs leads to 'No X402 payment requirements found' errors" ;
    oc:severityLevel "MEDIUM" .

oc:kn_310040ee a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying USDC dollar amounts in commands" ;
    oc:directiveContent "Always single-quote amounts that use $ to prevent bash variable expansion (e.g. '$1.00' not $1.00)." ;
    oc:hasRationale "Bash interprets $ as variable expansion, which would substitute empty string and cause incorrect amounts" ;
    oc:severityLevel "HIGH" .

oc:kn_6ffe9896 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any x402 pay command" ;
    oc:directiveContent "Run npx awal@2.0.3 status to confirm wallet is authenticated, and npx awal@2.0.3 balance to confirm sufficient USDC before making any paid request." ;
    oc:hasRationale "Avoids unnecessary payment failures and provides clear user guidance if prerequisites are unmet" ;
    oc:severityLevel "MEDIUM" .

oc:kn_bdd319e5 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On any error response from x402 pay command" ;
    oc:directiveContent "If 'Not authenticated' error occurs, run authenticate-wallet skill. If 'No X402 payment requirements found', use search-for-service to find valid endpoints. If 'Insufficient balance', use fund skill to add USDC." ;
    oc:hasRationale "Each error has a specific remediation path; using the wrong recovery wastes time and may not resolve the issue" .

oc:kn_de8f1e6d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, before constructing any x402 pay command" ;
    oc:directiveContent "Never pass unvalidated user input into the x402 pay command. URL must start with https:// or http:// and contain no spaces, semicolons, pipes, backticks, or shell metacharacters. Data must be valid JSON wrapped in single quotes. max-amount must match ^\\d+$." ;
    oc:hasRationale "Prevents shell injection attacks that could execute arbitrary commands" ;
    oc:severityLevel "CRITICAL" .

oc:kn_fa0cd4a3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying --max-amount values" ;
    oc:directiveContent "X402 uses USDC atomic units with 6 decimals: 1000000 = $1.00, 100000 = $0.10, 50000 = $0.05, 10000 = $0.01." ;
    oc:hasRationale "Incorrect unit conversion results in overpaying or underpaying for API calls" ;
    oc:severityLevel "HIGH" .

_:ref_150150b4d5bbef83 a oc:WorkflowStep ;
    dcterms:description "Run npx awal@2.0.3 balance to verify sufficient USDC funds" ;
    oc:expectedOutcome "Wallet has enough USDC to cover expected payment" ;
    oc:stepDependsOn _:ref_2d8bee0daac90040 ;
    oc:stepId "check-balance" .

_:ref_a6273298ff878e72 a oc:WorkflowStep ;
    dcterms:description "Validate user-provided URL, data, and max-amount against injection rules" ;
    oc:expectedOutcome "All inputs pass validation checks" ;
    oc:stepId "validate-input" .

_:ref_2d8bee0daac90040 a oc:WorkflowStep ;
    dcterms:description "Run npx awal@2.0.3 status to verify wallet is authenticated" ;
    oc:expectedOutcome "Wallet shows authenticated status" ;
    oc:stepId "check-auth" .

