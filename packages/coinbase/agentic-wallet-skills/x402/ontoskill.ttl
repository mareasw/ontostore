oc:kn_08af5e38 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Making a paid API request with automatic USDC payment" ;
    oc:directiveContent "awal x402 pay <url> [-X <method>] [-d <json>] [-q <params>] [-h <json>] [--max-amount <n>] [--json]" .

oc:kn_134530e4 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When using x402 protocol" ;
    oc:directiveContent "1. Search bazaar: npx awal@2.0.3 x402 bazaar search <query> 2. Inspect endpoint: awal x402 details <url> 3. Call with payment: awal x402 pay <url> [-X method] [-d json] [--max-amount n]" ;
    oc:hasRationale "Following find → inspect → pay avoids spending USDC on wrong endpoints" ;
    oc:stepOrder 1 .

oc:kn_17b1809b a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When search/list commands fail with 429" ;
    oc:directiveContent "CDP API rate limits (429) are handled by falling back to locally cached data at ~/.config/awal/bazaar/ (auto-refreshes after 12 hours)" ;
    oc:hasRationale "Prevents workflow interruption from rate limiting" ;
    oc:severityLevel "MEDIUM" .

oc:kn_49464513 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When retrying commands" ;
    oc:directiveContent "Search and details commands are read-only and safe to repeat. Paid requests trigger real USDC transactions — use --max-amount to cap spending." ;
    oc:hasRationale "Prevents accidental double-spending on retries" ;
    oc:severityLevel "HIGH" .

oc:kn_6402a95a a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Inspecting an endpoint's price, method, and schemas before paying" ;
    oc:directiveContent "awal x402 details <url> [--json]" .

oc:kn_77e38faa a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running 'awal x402 pay'" ;
    oc:directiveContent "Verify authentication (awal auth login) and sufficient USDC balance (awal balance) before attempting paid requests" ;
    oc:hasRationale "Paid requests will fail without authentication or balance" ;
    oc:severityLevel "CRITICAL" .

oc:kn_be3f81c4 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On error from any x402 command" ;
    oc:directiveContent "If 'Not authenticated' error occurs, run 'awal auth login <email>'. If 'Insufficient balance', fund wallet. If 'No X402 payment requirements found', verify the URL is an x402 endpoint." ;
    oc:hasRationale "Provides clear remediation paths for common failures" .

oc:kn_e3cf8840 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying --max-amount or interpreting payment amounts" ;
    oc:directiveContent "USDC atomic units use 6 decimals: 1000000 = $1.00, 100000 = $0.10, 10000 = $0.01" ;
    oc:hasRationale "Incorrect unit conversion can lead to overpaying or rejected payments" ;
    oc:severityLevel "HIGH" .

oc:kn_e49db3dc a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "Searching for paid API services by keyword" ;
    oc:directiveContent "npx awal@2.0.3 x402 bazaar search <query> [-k <n>] [--force-refresh] [--json]" .

oc:kn_e7893335 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using any x402 command" ;
    oc:directiveContent "Node.js/npx must be available. Search/details require no auth. Pay requires authenticated wallet with USDC on Base." .

