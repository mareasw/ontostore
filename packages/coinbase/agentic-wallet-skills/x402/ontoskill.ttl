_:ref_4417879dd510f99b a oc:WorkflowStep ;
    dcterms:description "**Make the request** - Call the endpoint with automatic USDC payment" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_18efa55f26dd1260 a oc:WorkflowStep ;
    dcterms:description "Search the bazaar for relevant services using keyword query" ;
    oc:expectedOutcome "List of matching x402 endpoints with descriptions" ;
    oc:stepId "search" .

_:ref_32152202f28b5eae a oc:WorkflowStep ;
    dcterms:description "Inspect the chosen endpoint's payment requirements (price, method, schemas)" ;
    oc:expectedOutcome "Price, accepted payment schemes, network, input/output schemas" ;
    oc:stepDependsOn _:ref_18efa55f26dd1260 ;
    oc:stepId "inspect" .

