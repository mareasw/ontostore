oc:kn_018ba0bd a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When budgeting and planning queries" ;
    oc:directiveContent "Each query costs $0.10 (100000 USDC atomic units). Time-bounded queries with indexed fields are fast; unbounded queries will timeout." ;
    oc:hasRationale "Query cost is fixed per execution regardless of complexity. Performance depends entirely on proper use of indexed fields." ;
    oc:severityLevel "MEDIUM" .

oc:kn_55c429a1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing x402 query commands" ;
    oc:directiveContent "Never use double quotes for the outer -d JSON wrapper. Always use single quotes: -d '{\"sql\": \"...\"}'. Never use SELECT * — always specify needed columns. Always include a LIMIT clause." ;
    oc:hasRationale "Double quotes enable shell expansion of $ and backticks, creating injection vulnerabilities. SELECT * and missing LIMIT cause excessive data retrieval and cost." ;
    oc:severityLevel "HIGH" .

oc:kn_712f33f7 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When query returns timeout error" ;
    oc:directiveContent "Query timeouts indicate missing indexed field filters or excessively broad time ranges. Ensure WHERE clause includes event_signature, address, and/or block_timestamp with a reasonable time bound." ;
    oc:hasRationale "Full table scans on blockchain data are computationally infeasible and will always timeout." ;
    oc:severityLevel "HIGH" .

oc:kn_813bf0e2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When querying base.events table" ;
    oc:directiveContent "Queries against base.events MUST filter on at least one indexed field (event_signature, address, or block_timestamp) in the WHERE clause. Combining all three gives best performance." ;
    oc:hasRationale "Without indexed field filters, queries perform full table scans and will timeout or be prohibitively expensive." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a443d460 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When accepting user-provided SQL queries or addresses" ;
    oc:directiveContent "Validate all user inputs before embedding in commands. Addresses must match ^0x[0-9a-fA-F]{40}$. Reject any value containing shell metacharacters." ;
    oc:hasRationale "Unvalidated input enables shell injection attacks through the bash command layer." ;
    oc:severityLevel "CRITICAL" .

oc:kn_da5b8ed3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filtering by address or event type in queries" ;
    oc:directiveContent "Always wrap address values in lower() function (e.g., address = lower('0xAbC...')). Use event_signature instead of event_name for filtering — it is indexed and faster." ;
    oc:hasRationale "The database stores lowercase addresses but users may provide checksummed (mixed-case) addresses. event_signature is indexed while event_name is not." ;
    oc:severityLevel "MEDIUM" .

oc:req_033c75f5 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "CoinbaseQL SQL dialect (ClickHouse-based)" .

oc:req_8489f4c9 a oc:RequirementAPI ;
    oc:isOptional false ;
    oc:requirementValue "Sufficient USDC balance for query payment ($0.10 per query)" .

oc:req_8c6b7c33 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "npx (Node.js package runner)" .

oc:req_efffe2be a oc:RequirementAPI ;
    oc:isOptional false ;
    oc:requirementValue "CDP SQL API endpoint (x402 paid)" .

_:ref_4c76ef23dba6cb39 a oc:WorkflowStep ;
    dcterms:description "**Always wrap address values in `lower()`** - the database stores lowercase addresses but users may provide checksummed (mixed-case) addresses. Use `address = lower('0xAbC...')` not `address = '0xAbC...'`." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_5ec457d8a1d8d5b2 a oc:WorkflowStep ;
    dcterms:description "**Always filter on indexed fields** (`event_signature`, `address`, `block_timestamp`) in `base.events` queries." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_71c3b8bc8b56d6bf a oc:WorkflowStep ;
    dcterms:description "**Use `event_signature` instead of `event_name`** for filtering - it is indexed and much faster." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_8560c6fd97850aa2 a oc:WorkflowStep ;
    dcterms:description "**Use time-bounded queries** with `block_timestamp` to narrow the scan range." ;
    oc:blockType "workflow_step" ;
