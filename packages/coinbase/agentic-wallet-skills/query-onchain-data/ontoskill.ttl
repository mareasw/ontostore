                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**SQL query**: Always embed the query inside a single-quoted JSON string (`-d '{\"sql\": \"...\"}'`). Never use double quotes for the outer `-d` wrapper, as this enables shell expansion of `$` and backticks within the query." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Addresses**: Must be valid `0x` hex addresses (`^0x[0-9a-fA-F]{40}$`). Reject any value containing shell metacharacters." ] ],
                        [ a oc:Paragraph ;
