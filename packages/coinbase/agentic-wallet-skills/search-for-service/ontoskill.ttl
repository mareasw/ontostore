@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coinbase_agentic_wallet_skills_search_for_service a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "search-for-service" ;
    skos:broader "Marketplace search tool" ;
    prov:wasDerivedFrom "../.agents/skills/coinbase/agentic-wallet-skills/search-for-service" ;
    oc:contentHash "63e97e8b28dc1d86d30fe0dabe32b2b77756f0f6abdf26495373e6afb7eac32a" ;
    oc:differentia "that discovers and inspects paid API endpoints on the x402 bazaar without requiring authentication" ;
    oc:handlesFailure oc:NetworkTimeout,
        oc:RateLimited ;
    oc:hasAllowedTool "Bash(npx awal@2.0.3 x402 bazaar *)",
        "Bash(npx awal@2.0.3 x402 details *)" ;
    oc:hasArgumentHint "query (keyword to search the bazaar) or url (endpoint to inspect)" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Search and browse the x402 bazaar marketplace for paid API services. Use when you or the user want to find available services, see what's available, discover APIs, or need an external service to accomplish a task. Also use as a fallback when no other skill clearly matches — search the bazaar to see if a paid service exists. Covers \"what can I do?\", \"find me an API for...\", \"what services are available?\", \"search for...\", \"browse the bazaar\"." ;
    oc:hasName "search-for-service" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Use the `npx awal@2.0.3 x402` commands to discover and inspect paid API endpoints available on the x402 bazaar marketplace. No authentication or balance is required for searching." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Once you've found a service you want to use, use the `pay-for-service` skill to make a paid request to the endpoint." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Next Steps" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\"No X402 payment requirements found\" - URL may not be an x402 endpoint" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\"CDP API returned 429\" - Rate limited; cached data will be used if available" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Error Handling" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "No authentication needed for search, list, or details commands" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Prerequisites" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Search for weather-related paid APIs
npx awal@2.0.3 x402 bazaar search "weather"

# Search with more results
npx awal@2.0.3 x402 bazaar search "sentiment analysis" -k 10

# Browse all bazaar resources with full details
npx awal@2.0.3 x402 bazaar list --full

# Check what an endpoint costs
npx awal@2.0.3 x402 details https://example.com/api/weather
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 57-69" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Examples" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 3 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "```" ;
                                    oc:tableMarkdown """| Option             | Description                             |
| ------------------ | --------------------------------------- |
| `--network <name>` | Filter by network (base, base-sepolia)  |
| `--full`           | Show complete details including schemas |
| `--json`           | Output as JSON                          |
""" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """npx awal@2.0.3 x402 bazaar list [--network <network>] [--full] [--json]
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 35-37" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Browse all available resources:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "List Bazaar Resources" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Find paid services by keyword using BM25 relevance search:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "Results are cached locally at `~/.config/awal/bazaar/` and auto-refresh after 12 hours." ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 3 ;
                                    oc:rowCount 3 ;
                                    oc:tableCaption "```" ;
                                    oc:tableMarkdown """| Option            | Description                          |
| ----------------- | ------------------------------------ |
| `-k, --top <n>`   | Number of results (default: 5)       |
| `--force-refresh` | Re-fetch resource index from CDP API |
| `--json`          | Output as JSON                       |
""" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """npx awal@2.0.3 x402 bazaar search <query> [-k <n>] [--force-refresh] [--json]
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 19-21" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Search the Bazaar" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Inspect an endpoint's x402 payment requirements without paying:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """npx awal@2.0.3 x402 details <url> [--json]
""" ;
                                    oc:codeLanguage "bash" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 49-51" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "Auto-detects the correct HTTP method (GET, POST, PUT, DELETE, PATCH) by trying each until it gets a 402 response, then displays price, accepted payment schemes, network, and input/output schemas." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Discover Payment Requirements" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Commands" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Searching the x402 Bazaar" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: search-for-service
description: Search and browse the x402 bazaar marketplace for paid API services. Use when you or the user want to find available services, see what's available, discover APIs, or need an external service to accomplish a task. Also use as a fallback when no other skill clearly matches — search the bazaar to see if a paid service exists. Covers "what can I do?", "find me an API for...", "what services are available?", "search for...", "browse the bazaar".
user-invocable: true
disable-model-invocation: false
allowed-tools: ["Bash(npx awal@2.0.3 x402 bazaar *)", "Bash(npx awal@2.0.3 x402 details *)"]
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Search the bazaar marketplace for relevant services, then inspect pricing and requirements before paying." ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Use the pay-for-service skill to make a paid request to the discovered endpoint." ;
                    oc:expectedOutcome "Successful paid API response" ;
                    oc:stepDependsOn _:ref_e319e5dda465234b ;
                    oc:stepId "pay" ],
                _:ref_c00e6153e86e5cf2,
                _:ref_e319e5dda465234b ;
            oc:workflowId "search-for-service-workflow" ;
            oc:workflowName "Discover and Inspect x402 Service" ] ;
    oc:impartsKnowledge oc:kn_02077486,
        oc:kn_06ce383c,
        oc:kn_5c85777d,
        oc:kn_609af5bc,
        oc:kn_94ec11e0 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "browse available paid APIs",
        "check API pricing and requirements",
        "discover x402 endpoints",
        "find external services for a task",
        "search for API services" ;
    oc:yieldsState oc:ServiceDiscovered .

oc:kn_02077486 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before running any bazaar search, list, or details command" ;
    oc:directiveContent "No authentication or wallet balance is required for search, list, or details commands — these are free operations." ;
    oc:hasRationale "Allows zero-barrier discovery of services before committing to payment" ;
    oc:severityLevel "LOW" .

oc:kn_06ce383c a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When receiving a 429 rate limit error" ;
    oc:directiveContent "CDP API may return 429 (rate limited); cached data at ~/.config/awal/bazaar/ will be used if available, and the cache auto-refreshes after 12 hours." ;
    oc:hasRationale "Search still works offline via cache, but results may be stale" ;
    oc:severityLevel "MEDIUM" .

oc:kn_5c85777d a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When running x402 details on a URL" ;
    oc:directiveContent "'No X402 payment requirements found' means the URL is not a valid x402 endpoint — the service may not support paid access." ;
    oc:hasRationale "Prevents attempting payment on non-x402 endpoints" ;
    oc:severityLevel "MEDIUM" .

oc:kn_609af5bc a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When search results appear stale or missing new services" ;
    oc:directiveContent "Use --force-refresh flag to bypass stale cache and re-fetch the resource index from the CDP API when results seem outdated." ;
    oc:hasRationale "Ensures fresh data when the 12-hour cache window is too long" ;
    oc:severityLevel "LOW" .

oc:kn_94ec11e0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user's intent doesn't map cleanly to a known skill" ;
    oc:directiveContent "Use this skill as a fallback when no other skill clearly matches a user request — search the bazaar to see if a paid service exists for the task." ;
    oc:hasRationale "The x402 marketplace may have a paid API that fills capability gaps" ;
    oc:severityLevel "MEDIUM" .

_:ref_c00e6153e86e5cf2 a oc:WorkflowStep ;
    dcterms:description "Search the bazaar by keyword using: npx awal@2.0.3 x402 bazaar search <query>" ;
    oc:expectedOutcome "List of relevant paid API endpoints matching the query" ;
    oc:stepId "search" .

_:ref_e319e5dda465234b a oc:WorkflowStep ;
    dcterms:description "Inspect the desired endpoint's payment requirements using: npx awal@2.0.3 x402 details <url>" ;
    oc:expectedOutcome "Price, accepted payment schemes, network, and input/output schemas for the endpoint" ;
    oc:stepDependsOn _:ref_c00e6153e86e5cf2 ;
    oc:stepId "inspect" .

