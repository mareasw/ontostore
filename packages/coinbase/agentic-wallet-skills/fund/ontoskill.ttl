@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coinbase_agentic_wallet_skills_fund a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "fund" ;
    skos:broader "Wallet funding skill" ;
    prov:wasDerivedFrom "../.agents/skills/coinbase/agentic-wallet-skills/fund" ;
    oc:contentHash "77d51d70f525f2b680ae11487707e89d4e32b5969e412add85169048726a06e5" ;
    oc:dependsOnSkill oc:skill_ontoskills_authenticate_wallet ;
    oc:differentia "adds USDC to an authenticated wallet via Coinbase Onramp with multiple payment methods or direct transfer" ;
    oc:handlesFailure oc:PaymentFailed,
        oc:RegionNotSupported,
        oc:WalletNotAuthenticated ;
    oc:hasAllowedTool "Bash(npx awal@2.0.3 address*)",
        "Bash(npx awal@2.0.3 balance*)",
        "Bash(npx awal@2.0.3 show*)",
        "Bash(npx awal@2.0.3 status*)" ;
    oc:hasArgumentHint "none (interactive UI flow)" ;
    oc:hasCategory "finance" ;
    oc:hasDescription "Add money to the wallet. Use when you or the user want to fund, deposit, top up, load, buy USDC, add funds, onramp, or get USDC. Also use when the wallet has insufficient balance for a send or trade operation, or when someone asks \"how do I get USDC?\"" ;
    oc:hasName "fund" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Use the wallet companion app to fund the wallet with USDC via Coinbase Onramp. This supports multiple payment methods including Apple Pay, debit cards, bank transfers, and funding from a Coinbase account." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Check updated balance
npx awal@2.0.3 balance
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 65-68" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Checking Balance After Funding" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Funding goes through Coinbase's regulated onramp" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Funds are deposited as USDC on Base network" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Processing time varies by payment method (instant for card/Apple Pay, 1-3 days for bank)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "If funding is not available, users can also send USDC on Base directly to the wallet address" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Notes" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 4 ;
                            oc:tableCaption "## Payment Methods" ;
                            oc:tableMarkdown """| Method    | Description                                    |
| --------- | ---------------------------------------------- |
| Apple Pay | Fast checkout with Apple Pay (where available) |
| Coinbase  | Transfer from existing Coinbase account        |
| Card      | Debit card payment                             |
| Bank      | ACH bank transfer                              |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Payment Methods" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Coinbase Onramp is available in supported regions (US, etc.)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Must be authenticated (`npx awal@2.0.3 status` to check)" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Prerequisites" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "If the wallet is not authenticated, refer to the `authenticate-wallet` skill." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """npx awal@2.0.3 status
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 15-17" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Confirm wallet is initialized and authed" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "This opens the wallet companion window where users can:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """npx awal@2.0.3 show
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 23-25" ],
                        _:ref_f91942f33e48d536 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Opening the Funding Interface" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_ae1a4a1b1708166c ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Flow" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """npx awal@2.0.3 address
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 46-48" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "You can also ask your human to send usdc on Base to your wallet address. You can find your wallet address buy running the following:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Alternative" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Funding the Wallet" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: fund
description: Add money to the wallet. Use when you or the user want to fund, deposit, top up, load, buy USDC, add funds, onramp, or get USDC. Also use when the wallet has insufficient balance for a send or trade operation, or when someone asks "how do I get USDC?"
user-invocable: true
disable-model-invocation: false
allowed-tools: ["Bash(npx awal@2.0.3 status*)", "Bash(npx awal@2.0.3 show*)", "Bash(npx awal@2.0.3 address*)", "Bash(npx awal@2.0.3 balance*)"]
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Standard flow for adding USDC to the wallet using Coinbase Onramp with various payment methods" ;
            oc:hasStep _:ref_014e632a77e6f918,
                _:ref_1184d03ae0d6195b,
                _:ref_5c031209a5d4c59b,
                [ a oc:WorkflowStep ;
                    dcterms:description "Run npx awal@2.0.3 balance to confirm USDC deposit" ;
                    oc:expectedOutcome "Balance reflects the newly deposited USDC on Base" ;
                    oc:stepDependsOn _:ref_5c031209a5d4c59b ;
                    oc:stepId "verify-balance" ] ;
            oc:workflowId "fund-wallet-onramp" ;
            oc:workflowName "Fund Wallet via Coinbase Onramp" ],
        [ a oc:Workflow ;
            dcterms:description "Alternative flow for receiving USDC via direct transfer on Base network" ;
            oc:hasStep _:ref_9e42fbaea72acd3a,
                [ a oc:WorkflowStep ;
                    dcterms:description "Run npx awal@2.0.3 balance to confirm incoming USDC" ;
                    oc:expectedOutcome "Balance shows received USDC" ;
                    oc:stepDependsOn _:ref_f4ef4ae6b6054385 ;
                    oc:stepId "verify-direct" ],
                _:ref_f4ef4ae6b6054385 ;
            oc:workflowId "fund-wallet-direct" ;
            oc:workflowName "Fund Wallet via Direct Transfer" ],
        _:ref_ae1a4a1b1708166c,
        _:ref_f91942f33e48d536 ;
    oc:impartsKnowledge oc:kn_18ffbadb,
        oc:kn_3cc002f5,
        oc:kn_5856a8e1,
        oc:kn_9b28373a,
        oc:kn_ad8f0150,
        oc:kn_ae1de56f,
        oc:kn_f1e40507,
        oc:kn_f5b3e94c ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:SystemAuthenticated ;
    oc:resolvesIntent "add money to wallet",
        "buy USDC",
        "deposit USDC",
        "fund wallet",
        "onramp to wallet",
        "top up balance" ;
    oc:yieldsState oc:WalletFunded .

oc:kn_18ffbadb a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any funding attempt" ;
    oc:directiveContent "Wallet must be authenticated before funding. Run `npx awal@2.0.3 status` to verify. If not authenticated, use the authenticate-wallet skill first." ;
    oc:hasRationale "Funding requires an authenticated wallet to receive USDC deposits" ;
    oc:severityLevel "CRITICAL" .

oc:kn_3cc002f5 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When onramp is unavailable" ;
    oc:directiveContent "If Coinbase Onramp funding is not available, users can receive USDC on Base directly to their wallet address obtained via `npx awal@2.0.3 address`." ;
    oc:hasRationale "Direct transfer provides a universal fallback that bypasses regional restrictions" ;
    oc:severityLevel "MEDIUM" .

oc:kn_5856a8e1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user attempts to fund via onramp" ;
    oc:directiveContent "Coinbase Onramp is only available in supported regions (US, etc.). If unavailable, fall back to direct USDC transfer on Base." ;
    oc:hasRationale "Regulatory restrictions limit Coinbase Onramp availability by geography" ;
    oc:severityLevel "HIGH" .

oc:kn_9b28373a a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "After payment is initiated" ;
    oc:directiveContent "Funds are deposited as USDC on Base network. Processing time varies: instant for card/Apple Pay, 1-3 days for bank transfer." ;
    oc:hasRationale "Users need to know settlement timing to manage expectations" .

oc:kn_ad8f0150 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After funding completes" ;
    oc:directiveContent "Run `npx awal@2.0.3 balance` after funding to confirm USDC deposit." ;
    oc:hasRationale "Confirms the deposit was successful and balance reflects new funds" .

oc:kn_ae1de56f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Always, before funding flow" ;
    oc:directiveContent "Verify wallet authentication with `npx awal@2.0.3 status` before attempting funding." ;
    oc:hasRationale "Unauthenticated wallets cannot receive funds" .

oc:kn_f1e40507 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When funding wallet via Coinbase Onramp" ;
    oc:directiveContent "1. Run `npx awal@2.0.3 status` to confirm wallet is authenticated. 2. Run `npx awal@2.0.3 show` to open wallet companion UI. 3. Instruct user to click Fund button, select amount and payment method. 4. User completes payment via Coinbase Pay in browser. 5. Run `npx awal@2.0.3 balance` to confirm USDC deposit." ;
    oc:stepOrder 1 .

oc:kn_f5b3e94c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When Coinbase Onramp is unavailable or user prefers direct transfer" ;
    oc:directiveContent "Alternative: Run `npx awal@2.0.3 address` to get wallet address, then instruct human to send USDC on Base directly to that address." ;
    oc:stepOrder 2 .

