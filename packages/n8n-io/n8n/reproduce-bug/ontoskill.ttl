oc:kn_1fa2f891 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running tests, ensure build is current" ;
    oc:directiveContent "Always redirect build output: pnpm build > build.log 2>&1. Check recent git history on affected files with git log --oneline -10 -- <path>." .

oc:kn_35e85fcf a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """**Ticket:** [{ID}] — [{title}]
**Confidence:** [CONFIRMED | LIKELY | UNCONFIRMED | SKIPPED | ALREADY_FIXED]

### Root Cause
[{1-2 sentences}]

### Location
| File | Lines | Issue |
| `path/to/file.ts` | XX-YY | Description |

### Failing Test
`path/to/test/file.test.ts` — X/Y tests fail:
1. `test name` — [failure description]

### Fix Hint
[{pseudocode or description}]""" ;
    oc:templateVariables "Confidence",
        "Failing Test",
        "File",
        "Fix Hint",
        "ID",
        "Issue",
        "Lines",
        "Root Cause",
        "title" .

oc:kn_56c47b11 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Running tests — always run from the package directory" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "pushd packages/nodes-base && pnpm test <file> && popd" .

oc:kn_5f6874d8 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After running the regression test" ;
    oc:directiveContent "Classify confidence as CONFIRMED (consistent failure matching hypothesis), LIKELY (failure mode differs slightly), UNCONFIRMED (cannot trigger failure), SKIPPED (hit bailout trigger), or ALREADY_FIXED (no longer reproduces)." .

oc:kn_6b1d7531 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Parse signals from ticket → 2. Route to test strategy by affected area → 3. Locate source files → 4. Trace code path → 5. Form hypothesis → 6. Find test patterns → 7. Write failing test → 8. Run and score confidence → 9. Iterate or bail" ;
    oc:stepOrder 1 .

oc:kn_7293e81c a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "After writing regression tests" ;
    oc:directiveContent "Leaves test files in place as evidence — do not commit unless explicitly asked." ;
    oc:hasRationale "Test files serve as reproduction evidence for the team to review before a fix is attempted" .

oc:kn_98e27361 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before attempting test writing, evaluate bailout triggers" ;
    oc:directiveContent "Do not attempt reproduction when the bug requires real third-party API credentials, involves race conditions/timing dependencies, requires specific cloud/enterprise infrastructure, or requires manual UI interaction that cannot be scripted." ;
    oc:hasRationale "These scenarios cannot be reliably reproduced in automated tests and waste time; declare SKIPPED instead" ;
    oc:severityLevel "HIGH" .

oc:kn_d662d00e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, throughout entire reproduction process" ;
    oc:directiveContent "DO NOT fix the bug — only reproduce it with a failing regression test. DO NOT look at existing fix PRs." ;
    oc:hasRationale "The goal is independent reproduction from ticket signals alone; fixing or peeking at fixes defeats the purpose of confirming the bug independently" ;
    oc:severityLevel "CRITICAL" .

oc:kn_dfc4f4c9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After first test run fails to reproduce the bug" ;
    oc:directiveContent "When UNCONFIRMED, revisit the hypothesis and re-read the code path, try a different test approach or layer. Maximum 3 attempts before declaring UNCONFIRMED." ;
    oc:hasRationale "Balances thoroughness with time investment; after 3 attempts the signal is likely insufficient" .

