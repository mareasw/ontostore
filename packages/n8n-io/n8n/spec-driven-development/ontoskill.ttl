oc:skill_n8n_io_n8n_spec_driven_development a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "spec-driven-development" ;
    skos:broader "Development methodology" ;
    prov:wasDerivedFrom "../.agents/skills/n8n-io/n8n/spec-driven-development" ;
    oc:contentHash "1cd29a949809c03300148de5d3f49df609bbc0e5990e49458c86dddea8957d3e" ;
    oc:differentia "keeps implementation and specification files in sync through a read-implement-verify-update loop" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "feature name or spec file path" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Keeps implementation and specs in sync. Use when working on a feature that has a spec in .claude/specs/, when the user says /spec, or when starting implementation of a documented feature. Also use when the user asks to verify implementation against a spec or update a spec after changes." ;
    oc:hasName "spec-driven-development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: spec-driven-development
description: Keeps implementation and specs in sync. Use when working on a feature that has a spec in .claude/specs/, when the user says /spec, or when starting implementation of a documented feature. Also use when the user asks to verify implementation against a spec or update a spec after changes.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent """Specs live in `.claude/specs/`. They are the source of truth for architectural
decisions, API contracts, and implementation scope. Implementation and specs
must stay in sync — neither leads exclusively.""" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent _:ref_27b6b725609ddb77 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "When the User Asks to \"Self-Review\" or \"Verify Against Spec\"" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """Read spec → Implement → Verify alignment → Update spec or code → Repeat
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 14-16" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Loop" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:hasChild [ a oc:CodeExample ;
                                            oc:blockType "code_block" ;
                                            oc:codeContent """- [x] ~~OpenRouter proxy~~ → Direct execution: nodes call OpenRouter directly
""" ;
                                            oc:codeLanguage "markdown" ;
                                            oc:contentOrder 1 ;
                                            oc:sourceLocation "lines 41-43" ] ;
                                    oc:itemOrder 4 ;
                                    oc:itemText """**Strike through or annotate** items that were deliberately skipped or
replaced, with a brief reason:""" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Tick off TODO checkboxes** (`- [ ]` → `- [x]`) as items are completed." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText """**When you diverge from the spec** (better approach found, user requested
change, constraint discovered), update the spec immediately in the same
session. Don't leave spec and code out of sync.""" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Reference spec decisions** — don't re-decide what the spec already settled." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "During Implementation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Use `## Implementation TODO` with checkboxes to track progress." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText """Split into multiple files when it helps (e.g. separate backend/frontend),
but don't enforce a rigid naming scheme.""" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Keep specs concise. Use tables for mappings, code blocks for shapes." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "One or more markdown files per feature in `.claude/specs/`." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Spec File Conventions" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_dd2205cd9b4e7978,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Run a spec verification pass:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "After Completing Work" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """ls .claude/specs/
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 22-24" ],
                        _:ref_375758bd30ebc938,
                        _:ref_a1a62d45351a177a ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Before Starting Work" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Spec-Driven Development" ] ;
    oc:hasWorkflow _:ref_27b6b725609ddb77,
        _:ref_375758bd30ebc938,
        [ a oc:Workflow ;
            dcterms:description "When asked to verify or self-review, produce a structured comparison of spec vs implementation." ;
            oc:hasStep _:ref_16fe11c84f9648fa,
                [ a oc:WorkflowStep ;
