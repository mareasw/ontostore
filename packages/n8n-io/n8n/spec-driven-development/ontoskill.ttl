    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create a new spec for a feature",
        "implement a feature from a spec",
        "review code-spec alignment",
        "update spec after code changes",
        "verify implementation against spec" ;
    oc:yieldsState oc:SpecAligned .

oc:kn_2afbb9c5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting implementation work" ;
    oc:directiveContent "If no spec exists and the task is non-trivial (new module, new API, architectural change), ask the user whether to create one first." ;
    oc:hasRationale "Creating specs for non-trivial work upfront reduces rework and ensures shared understanding." ;
    oc:severityLevel "HIGH" .

oc:kn_34b1ab55 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "During implementation" ;
    oc:directiveContent "Reference spec decisions during implementation — don't re-decide what the spec already settled." ;
    oc:hasRationale "Avoids wasted effort and maintains consistency with agreed-upon architecture." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3880a854 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "During implementation when diverging from spec" ;
    oc:directiveContent "When a spec item is deliberately skipped or replaced, strike through the item and annotate with a brief reason rather than deleting it." ;
    oc:hasRationale "Preserving the history of decisions helps future readers understand why something was changed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6ce5e9d8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — this is the foundational principle of spec-driven development" ;
    oc:directiveContent "Specs are the source of truth for architectural decisions, API contracts, and implementation scope. Neither spec nor code leads exclusively." ;
    oc:hasRationale "Maintaining bidirectional sync ensures specs remain relevant and code remains documented." ;
    oc:severityLevel "HIGH" .

oc:kn_bc446d77 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementation diverges from spec (better approach found, user change, constraint discovered)" ;
    oc:directiveContent "Never leave spec and code out of sync after diverging during implementation — update the spec immediately in the same session." ;
    oc:hasRationale "Unsynced specs erode trust in the specification as source of truth and cause confusion in future work." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e6977531 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before writing any code" ;
    oc:directiveContent "Before starting work, search .claude/specs/ for matching spec files and read the full spec to understand scope, decisions, API contracts, and open questions." ;
    oc:hasRationale "Reading the spec first prevents re-deciding what was already settled and ensures alignment from the start." ;
    oc:severityLevel "HIGH" .

oc:kn_feb218c5 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing implementation of a feature" ;
    oc:directiveContent "After completing work, re-read the spec alongside implementation and verify: API endpoints match, config/env vars match, module structure matches, type definitions match, and TODO items are correctly checked." ;
    oc:hasRationale "A verification pass catches drift before it compounds and ensures the spec remains a reliable reference." ;
    oc:severityLevel "HIGH" .

