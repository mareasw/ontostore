                [ a oc:WorkflowStep ;
                    dcterms:description "Fix any drift found — update spec or code as needed. Flag unresolved gaps to the user." ;
                    oc:expectedOutcome "Spec and code are fully aligned, or gaps are explicitly documented." ;
                    oc:stepDependsOn _:ref_91d850599dd7d8a8 ;
                    oc:stepId "resolve-drift" ],
                _:ref_91d850599dd7d8a8 ;
            oc:workflowId "spec-core-loop" ;
            oc:workflowName "Spec-Driven Development Core Loop" ],
