oc:kn_4a1ef0ec a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before ticket creation on any platform" ;
    oc:directiveContent "Always present a preview and wait for user confirmation before creating any ticket or issue." ;
    oc:hasRationale "Prevents creating incorrect or unwanted tickets that require manual cleanup" ;
    oc:severityLevel "HIGH" .

oc:kn_57dcef24 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing issue titles on either platform" ;
    oc:directiveContent "Use sentence case for all issue titles. Imperative mood for features/enhancements ('Add...', 'Support...'). Bug titles prefix with 'Bug - ' on Linear." ;
    oc:hasRationale "Consistent title formatting improves searchability and scanning in issue backlogs" ;
    oc:severityLevel "MEDIUM" .

oc:kn_5bbe82c2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting Linear ticket status" ;
    oc:directiveContent "Never create Linear issues in Triage status — Triage is for externally-reported issues from automated pipelines. Agent-created tickets have known context and should skip triage." ;
    oc:hasRationale "Triage is managed by automation for incoming external issues; agent-created tickets already have vetted context" ;
    oc:severityLevel "HIGH" .

oc:kn_738a8f46 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining where to create the issue" ;
    oc:directiveContent "If target platform is ambiguous, ask the user. Use keywords: 'Linear'/'ticket'/team key → Linear; 'GitHub'/'GH issue'/'open source' → GitHub." ;
    oc:hasRationale "Prevents creating issues on the wrong platform which requires manual migration" ;
    oc:severityLevel "MEDIUM" .

oc:kn_756bd5cc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before creating Linear tickets" ;
    oc:directiveContent "Never create duplicate issues — if the user describes something that may already exist, search first with mcp__linear-server__list_issues." ;
    oc:hasRationale "Duplicate issues create confusion and waste triage effort" ;
    oc:severityLevel "MEDIUM" .

oc:kn_842717b0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting Linear ticket priority" ;
    oc:directiveContent "Never set Urgent (priority 1) unless the user explicitly says 'urgent', 'P0', 'production down', or 'security vulnerability'. Default to Normal (3)." ;
    oc:hasRationale "Urgent priority triggers incident response workflows and should not be set casually" ;
    oc:severityLevel "CRITICAL" .

oc:kn_87c1c43a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any ticket creation" ;
    oc:directiveContent "Verify Linear MCP connection before creating Linear tickets. Verify `gh auth status` before creating GitHub issues." ;
    oc:hasRationale "Avoids partial failures and informs the user early if a platform is unavailable" ;
    oc:severityLevel "HIGH" .

oc:kn_887e39ee a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating GitHub issues" ;
    oc:directiveContent "Never file feature requests as GitHub issues on n8n-io/n8n. The GitHub issue tracker is bug-only. Redirect users to the community forum or suggest a Linear ticket instead." ;
    oc:hasRationale "n8n GitHub repo has blank issues disabled and redirects non-bug reports to the community forum" ;
    oc:severityLevel "HIGH" .

oc:kn_8c621e3c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating GitHub issues" ;
    oc:directiveContent "Never manually apply labels when creating GitHub issues. Triage automation handles labeling automatically." ;
    oc:hasRationale "n8n GitHub triage automation auto-applies triage:pending and status:in-linear labels" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ce0d02bd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying labels to Linear tickets" ;
    oc:directiveContent "Never apply triage-state, release, or docs-automation labels on Linear tickets. These are managed by automation." ;
    oc:hasRationale "Manual application of automated labels conflicts with triage and release automation systems" ;
    oc:severityLevel "HIGH" .

