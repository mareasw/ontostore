                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "**No prefixes required** — do not add \"Bug:\" or \"Bug Report:\" (the template handles categorization)" ],
