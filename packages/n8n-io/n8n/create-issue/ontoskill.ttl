                                            oc:contentOrder 9 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Use the relevant feature-area bucket (e.g., `Credentials`, `Canvas/Node`, `RBAC`, `LangChain nodes`, `Form Trigger`, etc.)" ] ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 7 ;
                                    oc:sectionTitle "Labels" ],
                                [ a oc:Section ;
