    oc:dependsOnSkill oc:skill_ontoskills_n8n_conventions ;
    oc:differentia "Creates Linear tickets or GitHub issues following n8n conventions with structured templates and guardrails" ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "[linear|github] <description of the issue>" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "Create Linear tickets or GitHub issues following n8n conventions. Use when the user asks to create a ticket, file a bug, open an issue, or says /create-issue." ;
    oc:hasName "create-issue" ;
    oc:hasRequirement oc:req_697f5a17,
        oc:req_8c9d9228,
        oc:req_d07ce4a6 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Create a Linear ticket or GitHub issue for: **$ARGUMENTS**" ] ;
            oc:hasSubsection [ a oc:Section ;
