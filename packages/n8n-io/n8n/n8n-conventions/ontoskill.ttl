oc:kn_3c3a5446 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When performing type assertions in TypeScript" ;
    oc:directiveContent "Prefer `satisfies` over `as` for type assertions in production code; `as` is acceptable only in test files." ;
    oc:hasRationale "`satisfies` validates the type without widening, preserving literal types and catching mismatches at the assignment site." ;
    oc:severityLevel "MEDIUM" .

oc:kn_740e5800 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or reviewing TypeScript code in any n8n package" ;
    oc:directiveContent "Never use the `any` type in TypeScript — always use `unknown` instead." ;
    oc:hasRationale "Using `any` bypasses type safety and can introduce runtime errors that the type system should catch." ;
    oc:severityLevel "CRITICAL" .

oc:kn_835c3382 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When this quick reference is insufficient for the task at hand" ;
    oc:directiveContent "For full documentation, read `/AGENTS.md` (general architecture, commands, workflows) and `/packages/frontend/AGENTS.md` (CSS variables, timing)." ;
    oc:hasRationale "This skill is a quick reference; deeper context and detailed patterns live in the full AGENTS.md files." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a78af642 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When throwing errors in backend or workflow code" ;
    oc:directiveContent "Never use the deprecated `ApplicationError` — always use `UnexpectedError` from `n8n-workflow` with `{ extra: { context } }`." ;
    oc:hasRationale "ApplicationError is deprecated and will be removed; UnexpectedError provides structured context for debugging." ;
    oc:severityLevel "HIGH" .

oc:kn_aa58f716 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building or committing code changes" ;
    oc:directiveContent "Always redirect build output: use `pnpm build > build.log 2>&1` and run `pnpm typecheck` and `pnpm lint` before every commit." ;
    oc:hasRationale "Redirecting build output prevents console flooding and captures errors for review. Typechecking and linting before commit prevents CI failures." ;
    oc:severityLevel "HIGH" .

oc:kn_c65a911f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or modifying backend API endpoints" ;
    oc:directiveContent "Follow the Controller → Service → Repository layering on the backend, using dependency injection via `@n8n/di` and configuration via `@n8n/config`." ;
    oc:hasRationale "Consistent layering ensures separation of concerns, testability, and adherence to the established n8n architecture." ;
    oc:severityLevel "HIGH" .

oc:kn_f147fb86 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Vue 3 frontend components" ;
    oc:directiveContent "All user-facing text must go through i18n using `$t('key')`, and all E2E-targeted elements must use `data-testid` with a single value containing no spaces." ;
    oc:hasRationale "i18n ensures the product supports localization; data-testid ensures stable E2E test selectors that don't break on text changes." ;
    oc:severityLevel "HIGH" .

