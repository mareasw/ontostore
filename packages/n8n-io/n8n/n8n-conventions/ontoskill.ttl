oc:kn_0a3c25f7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing TypeScript in n8n codebase" ;
    oc:directiveContent "Never use `any` type — use `unknown` instead. Prefer `satisfies` over `as` (except in tests)." ;
    oc:hasRationale "Type safety prevents runtime errors and maintains codebase integrity" ;
    oc:severityLevel "CRITICAL" .

oc:kn_179ffae7 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When starting any n8n development task" ;
    oc:directiveContent "1. Check conventions in this skill before writing code 2. Consult /AGENTS.md for full docs if needed 3. Use shared types from @n8n/api-types 4. Run typecheck and lint before committing" ;
    oc:stepOrder 1 .

oc:kn_2193a820 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating Vue components" ;
    oc:codeLanguage "vue" ;
    oc:directiveContent """<script setup lang="ts">
type Props = { title: string };
const props = defineProps<Props>();
</script>""" .

oc:kn_24ab8f06 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing frontend code" ;
    oc:directiveContent "Vue 3 Composition API with `<script setup lang=\"ts\">`. CSS via variables (never hardcode px). All text via i18n `$t('key')`. Use `data-testid` for E2E selectors." ;
    oc:hasRationale "Consistent Vue 3 patterns, theme-safe styling, internationalization, and reliable E2E selectors" ;
    oc:severityLevel "HIGH" .

oc:kn_354dde99 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating Pinia stores in frontend" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """import { STORES } from '@n8n/stores';
export const useMyStore = defineStore(STORES.MY_STORE, () => {
  const state = shallowRef([]);
  return { state };
});""" .

oc:kn_905faa26 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building or committing code" ;
    oc:directiveContent "Always redirect build output: `pnpm build > build.log 2>&1`. Run `pnpm typecheck` and `pnpm lint` before commit." ;
    oc:hasRationale "Redirecting build output avoids flooding terminal; typecheck and lint catch errors before CI" ;
    oc:severityLevel "MEDIUM" .

oc:kn_93fef9e4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When this quick reference is insufficient" ;
    oc:directiveContent "For full architecture, commands, and workflow details read `/AGENTS.md`. For CSS variables and timing read `/packages/frontend/AGENTS.md`." ;
    oc:hasRationale "This skill is a condensed reference; the full AGENTS.md files contain comprehensive documentation" ;
    oc:severityLevel "LOW" .

oc:kn_aa9750c3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating or modifying shared TypeScript types" ;
    oc:directiveContent "Shared types must go in `@n8n/api-types`." ;
    oc:hasRationale "Centralized shared types prevent duplication and ensure type consistency across packages" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c52c0e0f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When throwing errors in backend code" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent "throw new UnexpectedError('message', { extra: { context } });" .

oc:kn_dc293253 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating backend services" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """import { Service } from '@n8n/di';
import { Config } from '@n8n/config';

@Service()
export class MyService {
  constructor(private readonly config: Config) {}
}""" .

oc:kn_e72e62ad a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working with database schemas or queries" ;
    oc:directiveContent "Only SQLite and PostgreSQL for the app database. DB nodes (MySQL Node, etc.) may use DB-specific features as an exception." ;
    oc:hasRationale "n8n must remain portable across SQLite (local) and PostgreSQL (production) deployments" ;
    oc:severityLevel "HIGH" .

oc:kn_f79036d4 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing backend code" ;
    oc:directiveContent "Backend follows Controller → Service → Repository pattern. Use `@n8n/di` for dependency injection, `@n8n/config` for configuration, Zod schemas for validation." ;
    oc:hasRationale "Layered architecture ensures separation of concerns and testability" ;
    oc:severityLevel "HIGH" .

oc:kn_f870e855 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When throwing errors in backend code" ;
    oc:directiveContent "Never use deprecated `ApplicationError` — use `UnexpectedError` from `n8n-workflow` instead." ;
    oc:hasRationale "ApplicationError is deprecated; UnexpectedError is the current standard with structured context support" ;
    oc:severityLevel "HIGH" .

