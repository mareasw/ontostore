oc:kn_044b43f0 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optional tools are missing" ;
    oc:directiveContent "If Notion MCP or loom-transcript skill is unavailable, gracefully degrade by noting the links in the summary and telling the user to check them manually." ;
    oc:hasRationale "Partial context is better than failing entirely. The user can manually review unavailable resources." ;
    oc:severityLevel "MEDIUM" .

oc:kn_0f73ba13 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "This skill is read-only and idempotent. It only fetches and analyzes data, making no changes to Linear, GitHub, or any external system." ;
    oc:hasRationale "Safe to re-run multiple times without side effects." ;
    oc:severityLevel "LOW" .

oc:kn_5632b4b5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing attachments and media (Step 2)" ;
    oc:directiveContent "Never skip downloading and viewing images or fetching Loom transcripts from BOTH the issue description AND comments. Visual content often contains critical context like error messages, UI states, or reproduction steps." ;
    oc:hasRationale "Images and videos frequently contain the most important context that text alone cannot convey." ;
    oc:severityLevel "HIGH" .

oc:kn_7bda16c3 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before presenting summary in Step 7" ;
    oc:directiveContent "Before presenting the final summary, verify: all images downloaded/viewed, all Loom transcripts fetched, all GitHub links fetched via gh, all comments listed, node-specificity checked, and effort assessed." ;
    oc:hasRationale "Ensures no critical context is missed before the agent presents results to the user." ;
    oc:severityLevel "HIGH" .

oc:kn_84923d38 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying affected n8n nodes in Step 5" ;
    oc:directiveContent "Node type IDs follow naming patterns: core nodes are `n8n-nodes-base.<camelCaseName>`, triggers are `<name>Trigger`, tools are `<name>Tool`, LangChain nodes are `@n8n/n8n-nodes-langchain.<camelCaseName>`." ;
    oc:hasRationale "Knowing the naming patterns allows quick lookup without guessing the exact type ID." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e60849ad a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When fetching initial issue data (Step 1)" ;
    oc:directiveContent "Fetch issue details and comments together in the same step to gather complete context upfront before proceeding to deeper analysis." ;
    oc:hasRationale "Batching the initial fetch avoids repeated context-switching and ensures all text is available for media scanning." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ec07be83 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any issue analysis" ;
    oc:directiveContent "Linear MCP and GitHub CLI are required hard dependencies. If either is missing, stop execution and inform the user what needs setup." ;
    oc:hasRationale "The skill cannot fetch issue details without Linear MCP or linked GitHub context without gh CLI." ;
    oc:severityLevel "CRITICAL" .

