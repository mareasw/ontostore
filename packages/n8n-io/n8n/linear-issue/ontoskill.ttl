                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Determine whether this issue is specific to a particular n8n node (e.g. a trigger, action, or tool node). Look for clues in:" ],
