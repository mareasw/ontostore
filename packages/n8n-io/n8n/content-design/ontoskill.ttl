oc:kn_48544d4c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "All copy referencing n8n concepts" ;
    oc:directiveContent "Use terminology exactly as defined: workflow (not flow/automation), node (not block/step), trigger (not starter), execution (not run), credential (not secret/key), canvas (not editor/board), connection (not edge/link)." ;
    oc:hasRationale "Terminology inconsistency confuses users and fragments documentation/search" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4e9957e9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "All UI copy generation and review" ;
    oc:directiveContent "Always use US English, active voice, sentence case, contractions, and Oxford comma. Never use Latin abbreviations (e.g., i.e., etc., via, vs) in customer-facing copy." ;
    oc:hasRationale "Consistency across the product reduces cognitive load and matches the established n8n voice" ;
    oc:severityLevel "CRITICAL" .

oc:kn_84fc3582 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "All copy mentioning n8n product names" ;
    oc:directiveContent "'n8n' is always lowercase even at the start of a sentence. Node names are proper nouns ('Slack Node', 'GitHub Node'). Feature names are lowercase. 'n8n Cloud' always capitalizes 'Cloud'." ;
    oc:hasRationale "n8n-specific brand conventions that differ from standard English capitalization rules" ;
    oc:severityLevel "HIGH" .

oc:kn_8d33d359 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Writing error messages" ;
    oc:directiveContent "Never blame the user in error messages. Write 'The API key isn't valid' not 'You entered an invalid API key'. Error messages must include what happened and what to do next." ;
    oc:hasRationale "User-blaming language increases frustration; actionable errors reduce support requests" ;
    oc:severityLevel "HIGH" .

oc:kn_9d056bf0 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "All three modes of operation" ;
    oc:directiveContent "Review and Audit modes are read-only analysis that can be run multiple times safely. Write mode produces the same recommendations given the same input." ;
    oc:hasRationale "Non-destructive operations ensure safety when iterating on copy suggestions" .

oc:kn_a6faa364 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing existing copy in the codebase" ;
    oc:directiveContent "Prefer editing i18n JSON (en.json) over hardcoded strings in Vue files. Flag any hardcoded user-facing strings found in Vue templates." ;
    oc:hasRationale "Centralized i18n strings enable localization and prevent copy drift" .

oc:kn_af2b52ab a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering ambiguous copy decisions" ;
    oc:directiveContent "When no guideline covers a specific case, flag the inconsistency rather than guessing. Do not invent conventions." ;
    oc:hasRationale "Guessing leads to inconsistency; flagging creates opportunities to extend the guidelines deliberately" .

oc:kn_bcedaad7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "All UI surfaces — buttons, modals, tooltips, empty states" ;
    oc:directiveContent "Lead with the action or outcome, then add context only if it earns its space. Prefer 'Save' over 'Save changes', 'Delete project?' over 'Are you sure you want to delete this project?'." ;
    oc:hasRationale "Concise copy respects user attention and speeds comprehension" .

