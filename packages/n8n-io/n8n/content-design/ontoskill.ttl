                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Don't: \"New\", \"Submit\", \"OK\"" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**Action labels (buttons and CTAs).** Start with a verb. Be specific." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 13 ;
                                    oc:textContent """**Tooltips.** One or two sentences. Add information the label alone can't
convey — don't repeat the label.""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 9 ;
                            oc:sectionTitle "UI copy patterns" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "files to find the most common violations" ;
                                    oc:tableMarkdown """| Violation | Grep pattern | Notes |
|-----------|-------------|-------|
| Latin abbreviations | `e\\.g\\.\\|i\\.e\\.\\|etc\\.\\| via \\| vs ` | 50+ instances typical |
| Missing contractions | `cannot\\|do not\\|will not\\|does not\\|is not\\|are not` | 20+ instances typical |
| "please" overuse | `[Pp]lease` | Review each in context — one per surface is fine |
| User-blaming language | `You need\\|You must\\|You entered\\|You have to` | Rewrite to focus on the system state |
| Passive voice | `was created\\|is controlled\\|will be shown\\|was deleted` | Not exhaustive — scan manually too |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """When running Audit mode, use these grep patterns against `en.json` and Vue
files to find the most common violations:""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent """Run each pattern with Grep against the relevant files, then triage results by
severity: terminology violations first, then tone, then grammar/formatting.""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 13 ;
                            oc:sectionTitle "Common audit patterns" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Content guidelines" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Before finalizing any copy, verify:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 16 ;
                                    oc:itemText "[ ] Placeholders use realistic examples, not label echoes" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 15 ;
                                    oc:itemText "[ ] Empty states include a next step" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "[ ] Oxford comma present in lists" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "[ ] Sentence case (not Title Case)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 10 ;
                                    oc:itemText "[ ] Single fragments have no trailing period" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 11 ;
                                    oc:itemText "[ ] Multi-sentence groups all have periods" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 8 ;
                                    oc:itemText "[ ] No user-blaming language in errors" ],
                                [ a oc:BulletItem ;
