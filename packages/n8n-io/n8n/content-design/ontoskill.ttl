@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_n8n_io_n8n_content_design a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "content-design" ;
    skos:broader "Content design system" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/n8n-io/n8n/content-design" ;
    oc:contentHash "82164eded754090e2ce37da04e830468fa0a1afcc97b813148638ee6b2a18097" ;
    oc:dependsOnSkill oc:skill_n8n_conventions ;
    oc:differentia "that provides structured guidelines, terminology, and review workflows for producing consistent, user-facing UI copy in the n8n product" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "Edit",
        "Glob",
        "Grep",
        "Read" ;
    oc:hasArgumentHint "surface type and user action or system state (e.g., \"button for deleting a workflow\", \"error message for failed connection\")" ;
    oc:hasCategory "document" ;
    oc:hasDescription """Product content designer for UI copy. Use when writing, reviewing, or auditing user-facing text: button labels, error messages, tooltips, empty states, modal copy, placeholder text, confirmation dialogs, onboarding flows, or i18n strings. Also use when the user says /copy, /content, or /ux-copy.
""" ;
    oc:hasName "content-design" ;
    oc:impartsKnowledge oc:kn_0f0f52c2,
        oc:kn_3eddb543,
        oc:kn_48acdcd4,
        oc:kn_99b13af8,
        oc:kn_a5934eea,
        oc:kn_f12f7a96,
        oc:kn_fda7a655 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "audit codebase files for content violations using grep patterns",
        "maintain consistent product terminology across surfaces",
        "review existing UI copy against content guidelines",
        "suggest i18n keys and manage localization strings",
        "write UI copy for buttons, modals, tooltips, errors, and empty states" ;
    oc:yieldsState oc:ContentReviewed .

oc:kn_0f0f52c2 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When performing an audit of en.json or Vue files" ;
    oc:directiveContent "In audit mode, run grep patterns for Latin abbreviations, missing contractions, please overuse, user-blaming language, and passive voice. Triage by severity: terminology violations first, then tone, then grammar/formatting." ;
    oc:hasRationale "Systematic grep-based auditing catches violations at scale and prioritizes fixes by user impact" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3eddb543 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering ambiguous or undocumented copy decisions" ;
    oc:directiveContent "Flag inconsistencies rather than guessing when no guideline covers a case. Push back on feature names that sound good in marketing but confuse in-product." ;
    oc:hasRationale "Guessing leads to inconsistency; surfacing gaps improves the guideline system itself over time" ;
    oc:severityLevel "MEDIUM" .

oc:kn_48acdcd4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or reviewing any UI copy" ;
    oc:directiveContent "Treat content as interface: every label, error message, and tooltip is a design decision. Lead with the action or outcome, then add context only if it earns its space." ;
    oc:hasRationale "UI copy directly impacts user success and comprehension; precision in terminology reduces cognitive load" ;
    oc:severityLevel "HIGH" .

oc:kn_99b13af8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When modifying any UI text in the n8n codebase" ;
    oc:directiveContent "Always prefer editing the i18n JSON (en.json) over hardcoded strings in Vue files. Flag hardcoded user-facing strings — they should use i18n." ;
    oc:hasRationale "Hardcoded strings break localization and make copy updates harder to track and maintain" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a5934eea a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Always, for all UI surfaces" ;
    oc:directiveContent "Use sentence case everywhere (titles, headings, menu items, labels, buttons). Only capitalize the first word and proper nouns. 'n8n' is always lowercase, even at sentence start. Node names are proper nouns: 'Slack Node', 'HTTP Request Node'." ;
    oc:hasRationale "Sentence case is the n8n standard and prevents the visual noise and inconsistency of Title Case across the product" ;
    oc:severityLevel "HIGH" .

oc:kn_f12f7a96 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing error messages or reviewing error copy" ;
    oc:directiveContent "Never blame the user in error messages. Write 'The API key isn't valid' not 'You entered an invalid API key'. Structure errors as: what happened + why (if known) + what to do next." ;
    oc:hasRationale "User-blaming language creates frustration and defensiveness; system-focused language reduces anxiety and guides resolution" ;
    oc:severityLevel "HIGH" .

oc:kn_fda7a655 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before delivering any written or reviewed UI copy" ;
    oc:directiveContent "Before finalizing copy, verify against the full checklist: US English, active voice, sentence case, contractions used, Oxford comma, no Latin abbreviations, no please overuse, no user-blaming, terminology matches glossary, correct period usage, verb-first button labels, destructive action naming, error structure, empty state guidance, and realistic placeholders." ;
    oc:hasRationale "The checklist catches the most common violations and ensures consistency with n8n's content standards" ;
    oc:severityLevel "HIGH" .

