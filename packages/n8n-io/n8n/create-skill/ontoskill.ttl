@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_n8n_io_n8n_create_skill a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "create-skill" ;
    skos:broader "Skill authoring guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/n8n-io/n8n/create-skill" ;
    oc:contentHash "5c32f66fd2817ee59ca82701cadbc75ba500eb3d04a771c639f81f7cfb065f08" ;
    oc:differentia "that teaches the agent how to create, structure, and validate new Agent Skills as concise markdown documents with optional supporting files" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "skill-name, purpose description, and optional reference files" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Guides users through creating effective Agent Skills. Use when you want to create, write, or author a new skill, or asks about skill structure, best practices, or SKILL.md format." ;
    oc:hasName "create-skill" ;
    oc:impartsKnowledge oc:kn_1113c6da,
        oc:kn_1127b6fd,
        oc:kn_55472c51,
        oc:kn_918b95b7,
        oc:kn_9ef59aad,
        oc:kn_a05af092,
        oc:kn_c724732d ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "author skill documentation with proper frontmatter",
        "create a new agent skill",
        "design skill structure and layout",
        "review or audit skill best practices",
        "write a SKILL.md file" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_1113c6da a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring or editing any skill's SKILL.md" ;
    oc:directiveContent "Keep SKILL.md well under ~200 lines; use progressive disclosure by moving long reference material into separate reference.md files linked one level deep." ;
    oc:hasRationale "The context window is shared with chat, code, and other skills—verbose skills waste tokens and degrade agent performance." ;
    oc:severityLevel "HIGH" .

oc:kn_1127b6fd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any new skill" ;
    oc:directiveContent "Every skill must have a SKILL.md with YAML frontmatter containing a hyphenated name (max 64 chars) and a description (max 1024 chars, third-person, with trigger words and WHEN conditions)." ;
    oc:hasRationale "Discovery depends entirely on the description field—vague or first-person descriptions cause the agent to miss or mis-select skills." ;
    oc:severityLevel "CRITICAL" .

oc:kn_55472c51 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a skill depends on external integrations or tools" ;
    oc:directiveContent "Never assume an MCP tool or CLI is present without stating it explicitly in the description and offering a fallback (e.g. web UI, alternative CLI, or asking the user)." ;
    oc:hasRationale "Not every user has the same MCP servers enabled; silent failures or broken workflows result from unstated dependencies." ;
    oc:severityLevel "HIGH" .

oc:kn_918b95b7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before creating any new skill" ;
    oc:directiveContent "Before writing a skill, gather requirements: purpose (one concrete task), triggers (when to apply), gaps (what the agent doesn't already know), outputs (templates/checklists), and examples (existing skills to follow)." ;
    oc:hasRationale "Rushed skill authoring without clear requirements produces vague, unfocused skills that fail at discovery and execution." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9ef59aad a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between CLI tools and MCP integrations for a skill" ;
    oc:directiveContent "Prefer CLI and repo commands (e.g. gh, pnpm) over MCP tools when they solve the same problem—they add less scaffolding noise to the context window." ;
    oc:hasRationale "Agents handle CLI commands well and they avoid the overhead of MCP tool discovery and schema loading." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a05af092 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a skill's triggers and steps diverge across multiple distinct workflows" ;
    oc:directiveContent "Never create one oversized skill that mixes unrelated workflows; instead split into smaller dedicated skills and use a thin parent/orchestrator skill to delegate." ;
    oc:hasRationale "Large monolithic skills load irrelevant detail into context, wasting tokens and increasing error rates." ;
    oc:severityLevel "HIGH" .

oc:kn_c724732d a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing skill authoring" ;
    oc:directiveContent "After creating a skill, verify: third-person description with trigger words, consistent terminology, no duplicate encyclopedic content the model already knows." ;
    oc:hasRationale "Validation catches common authoring mistakes like first-person descriptions, inconsistent naming, and redundant content that wastes context." ;
    oc:severityLevel "MEDIUM" .

