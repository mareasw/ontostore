    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "apply skill authoring best practices and avoid anti-patterns",
        "author a SKILL.md file",
        "create a new agent skill",
        "design skill structure and layout",
        "write skill descriptions and frontmatter" .

oc:kn_28c2d293 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a skill has detailed or edge-case content" ;
    oc:directiveContent "Practice progressive disclosure — essentials in SKILL.md, long reference material in reference.md. Link only one level deep from SKILL.md." ;
    oc:hasRationale "Avoids bloating context with rarely-needed detail while keeping it accessible when required" ;
    oc:severityLevel "HIGH" .

oc:kn_841ca896 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoping a new skill" ;
    oc:directiveContent "One primary workflow or decision tree per skill. Split into smaller dedicated skills when triggers and steps diverge significantly." ;
    oc:hasRationale "Single responsibility keeps irrelevant detail out of context until needed; small composed skills are more flexible than one monolithic skill" ;
    oc:severityLevel "HIGH" .

oc:kn_8b153439 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When a skill needs to invoke or link to another skill" ;
    oc:directiveContent "Reference other skills by their repository-root path (e.g. .claude/skills/create-issue/SKILL.md). Parent skills should delegate steps instead of duplicating long procedures." ;
    oc:hasRationale "Path-based references are resolvable by both humans and tools; delegation avoids content duplication and stale copies" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a5b30607 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing skill workflows" ;
    oc:directiveContent "Prefer one default library or workflow per skill. Add alternatives only as escape hatches when truly needed." ;
    oc:hasRationale "Multiple equivalent options cause decision paralysis and increase context without adding value" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a9767d36 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring any skill" ;
    oc:directiveContent "Keep SKILL.md concise — aim for well under ~200 lines. The context window is shared with chat, code, and other skills." ;
    oc:hasRationale "Verbose skills waste context tokens and reduce the agent's effective reasoning capacity" ;
    oc:severityLevel "HIGH" .

oc:kn_bf314147 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing frontmatter" ;
    oc:directiveContent "Skill name: lowercase, hyphens, max 64 chars. Description: max 1024 chars, non-empty, third person, WHAT + WHEN with trigger words." ;
    oc:hasRationale "Discovery depends entirely on the description matching user intent; naming conventions ensure consistent routing" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e99acddf a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring any skill" ;
    oc:directiveContent "Avoid verbose tutorials explaining concepts the model already knows, vague names like 'helper' or 'utils', many equivalent options with no default, deep chains of linked files, and assuming MCP tools are present without fallbacks." ;
    oc:hasRationale "These anti-patterns waste tokens, cause confusion, reduce determinism, and create fragile dependencies" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f6096098 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing tool integrations for a skill" ;
    oc:directiveContent "Prefer CLI and repo commands over MCPs when they solve the same problem. If an MCP is required, state it explicitly in the description and provide a fallback." ;
    oc:hasRationale "CLI commands add less scaffolding noise; MCPs are optional per user so skills must degrade gracefully" ;
    oc:severityLevel "MEDIUM" .

