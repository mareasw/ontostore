_:ref_424c3ecb92c43532 a oc:WorkflowStep ;
    dcterms:description "**Create PR** using gh CLI with the template from `.github/pull_request_template.md`:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:CodeExample ;
            oc:blockType "code_block" ;
            oc:codeContent """gh pr create --draft --title "<type>(<scope>): <summary>" --body "$(cat <<'EOF'
## Summary

<Describe what the PR does and how to test. Photos and videos are recommended.>

## Related Linear tickets, Github issues, and Community forum posts

<!-- Link to Linear ticket: https://linear.app/n8n/issue/[TICKET-ID] -->
