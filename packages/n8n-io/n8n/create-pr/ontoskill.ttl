                    oc:itemText "Scope: Which package/area is affected?" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "Type: What kind of change is this?" ] ] ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

