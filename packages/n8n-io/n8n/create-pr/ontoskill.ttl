oc:kn_22966fe6 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After PR creation" ;
    oc:directiveContent "PR creation succeeds when gh pr create returns a URL. Title validation passes CI when it matches: ^(?feat|fix|perf|test|docs|refactor|build|ci|chore|revert)(\\([a-zA-Z0-9 ]+( Node)?\\))?!?: [A-Z].+[^.]$" ;
    oc:hasRationale "The check-pr-title CI job must pass for the PR to be mergeable" .

oc:kn_31b93f45 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating PRs for security fixes" ;
    oc:directiveContent "Never expose attack vectors in any public-facing artifact (branch name, PR title, commit message, PR body, Linear URL, test name, code comment). Describe what the code does, not what threat it prevents." ;
    oc:hasRationale "This repo is public; exposing the attack vector helps attackers before the fix is widely deployed" ;
    oc:severityLevel "CRITICAL" .

oc:kn_460394d8 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always when executing this skill" ;
    oc:directiveContent "Pushes current branch to origin with tracking (git push -u origin HEAD) and creates a draft PR on GitHub via gh CLI." ;
    oc:hasRationale "The skill has external side effects: remote branch creation and GitHub PR creation" ;
    oc:severityLevel "HIGH" .

oc:kn_5e8c4bca a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating the PR body" ;
    oc:directiveContent """## Summary
<description and how to test>

## Related Linear tickets, Github issues, and Community forum posts
<!-- Linear: https://linear.app/n8n/issue/[TICKET-ID] -->
<!-- closes/fixes/resolves #<issue-number> -->

## Review / Merge checklist
- [ ] PR title and summary are descriptive
- [ ] Docs updated or follow-up ticket created
- [ ] Tests included
- [ ] PR Labeled with release/backport (if urgent fix)""" ;
    oc:templateVariables "TICKET-ID",
        "description",
        "issue-number" .

oc:kn_75214c25 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a pull request" ;
    oc:directiveContent "1. Check git state (status, diff, log) 2. Check .claude/plans/ for matching plan file 3. If security fix, audit all public artifacts 4. Analyze changes to determine type/scope/summary 5. Push branch (git push -u origin HEAD) 6. Create draft PR via gh pr create with template body" ;
    oc:hasRationale "Sequential steps ensure no artifacts are leaked and the PR is properly formatted" ;
    oc:stepOrder 1 .

oc:kn_98fdff5b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any PR title" ;
    oc:directiveContent "PR title must match pattern: <type>(<scope>): <summary> where type is one of feat|fix|perf|test|docs|refactor|build|ci|chore|revert, scope is optional alphanumeric with optional ' Node' suffix, summary starts with capital letter and no trailing period." ;
    oc:hasRationale "PR titles are validated by check-pr-title CI; non-conforming titles block merging" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a3ccf407 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating the PR via gh CLI" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """gh pr create --draft --title "<type>(<scope>): <summary>" --body "$(cat <<'EOF'
## Summary
...
## Related Linear tickets, Github issues, and Community forum posts
...
## Review / Merge checklist
...
EOF
)\"""" .

oc:kn_c3aa3ae9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing PR title summaries" ;
    oc:directiveContent "Summary must use imperative present tense (Add not Added), capitalize first letter, no trailing period, no ticket IDs. Add (no-changelog) suffix to exclude from changelog." ;
    oc:hasRationale "Consistent verb tense and formatting enables automated changelog generation" ;
    oc:severityLevel "HIGH" .

oc:kn_c5bd4c1c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After checking git state but before creating the PR" ;
    oc:directiveContent "Check .claude/plans/ for a plan file matching the branch ticket ID. If found, ask user if they want it included as a collapsible <details> section. Only include with explicit user approval." ;
    oc:hasRationale "Plans provide implementation context for reviewers but may contain private deliberations" ;
    oc:severityLevel "LOW" .

oc:kn_d83368b1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running gh pr create" ;
    oc:directiveContent "Always create PRs as drafts using --draft flag. Include Summary, Related Links, and Review/Merge checklist sections in the PR body." ;
    oc:hasRationale "Draft PRs signal work-in-progress and prevent premature merges; template sections ensure complete reviews" ;
    oc:severityLevel "MEDIUM" .

oc:kn_dcd1f20c a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before executing this skill" ;
    oc:directiveContent "Requires gh CLI authenticated with GitHub. Requires git repository with commits on a branch different from master." .

oc:kn_fc1baf1a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When the PR addresses a security vulnerability" ;
    oc:directiveContent "Before pushing a security fix, audit all six artifact types for vulnerability hints: branch name, commits, PR title, PR body, Linear URL, and test names." ;
    oc:hasRationale "A single leaked vulnerability detail in any public artifact can be exploited" ;
    oc:severityLevel "CRITICAL" .

_:ref_2c05df7613d84b3e a oc:WorkflowStep ;
    dcterms:description "**Analyze changes** to determine:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem [ a oc:BulletItem ;
