oc:kn_2850ad7b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing captions in any Remotion project" ;
    oc:directiveContent "Put captioning logic in a separate component in its own file, keeping it isolated from video composition logic." ;
    oc:hasRationale "Separation of concerns makes caption components reusable and easier to maintain" .

oc:kn_5f469ccf a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing per-word highlighting in caption rendering" ;
    oc:directiveContent "For word highlighting, compute absoluteTimeMs = page.startMs + (frame / fps) * 1000, then compare against each token's fromMs and toMs to determine if it's the active word." ;
    oc:hasRationale "Frame-relative time must be converted to absolute time to correctly match tokens since frames are relative to the Sequence start, not the video start" .

oc:kn_8c2c992c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing caption assets for a Remotion project" ;
    oc:directiveContent "Each video must have its own separate captions JSON file. Do not reuse caption files across different videos." ;
    oc:hasRationale "Captions are time-synced to specific audio; sharing caption files breaks synchronization" .

oc:kn_ae3b7176 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering any caption text in Remotion" ;
    oc:directiveContent "Captions are whitespace sensitive. Include spaces in the text field before each word and use whiteSpace: 'pre' CSS property to preserve whitespace in the rendered captions." ;
    oc:hasRationale "Without whitespace preservation, caption words will collapse together and become unreadable" ;
    oc:severityLevel "HIGH" .

oc:kn_b9deb71e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling createTikTokStyleCaptions() to group captions into pages" ;
    oc:directiveContent "Use combineTokensWithinMilliseconds to control caption grouping: higher values mean more words per page (subtitle-style), lower values mean fewer words (word-by-word karaoke-style). A value of 1200ms is a good default." ;
    oc:hasRationale "The timing threshold determines the viewing experience and readability of captions" .

oc:kn_f2b1fe8f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When fetching caption data from a file or API before rendering" ;
    oc:directiveContent "Always use useDelayRender() when fetching captions JSON asynchronously. Call continueRender(handle) on success and cancelRender(e) on failure." ;
    oc:hasRationale "Without delayRender, Remotion will render before captions are loaded, resulting in empty frames" ;
    oc:severityLevel "CRITICAL" .

