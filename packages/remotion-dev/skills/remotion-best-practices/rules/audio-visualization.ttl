oc:kn_68266288 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When interpreting visualizeAudio() output for visual mapping" ;
    oc:directiveContent "Frequency array indices map left-to-right: left indices are bass, right indices are treble. Values range 0-1." ;
    oc:hasRationale "Understanding the frequency-to-index mapping is essential for creating meaningful visual representations like bass-reactive effects (use early indices) or full-spectrum displays." ;
    oc:severityLevel "HIGH" .

oc:kn_8da6089b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing audio visualization components inside <Sequence> with offsets" ;
    oc:directiveContent "Never call useCurrentFrame() inside child components when passing audioData down. Always pass the parent's frame value as a prop." ;
    oc:hasRationale "Calling useCurrentFrame() in children inside <Sequence> produces discontinuous visualization because the hook returns the sequence-relative frame, not the absolute frame." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a04ea338 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering frequency spectrum visualizations" ;
    oc:directiveContent "Low frequencies naturally dominate audio data. Apply logarithmic scaling (converting to dB) for visually balanced frequency displays." ;
    oc:hasRationale "Bass frequencies have higher amplitude in raw FFT output. Logarithmic scaling maps the dB range to a linear visual range, producing a more balanced and aesthetically useful display." ;
    oc:severityLevel "MEDIUM" .

oc:kn_aef33c58 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring frequency spectrum visualization" ;
    oc:directiveContent "numberOfSamples must be a power of 2 (32, 64, 128, 256, 512, 1024) when using visualizeAudio()." ;
    oc:hasRationale "FFT algorithms require power-of-2 sample counts for correct frequency decomposition." ;
    oc:severityLevel "HIGH" .

oc:kn_cfa68dce a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling visualizeAudio() with numberOfSamples >= 256 or rendering on Remotion Lambda" ;
    oc:directiveContent "Use optimizeFor: 'speed' for Lambda rendering or high sample counts to improve performance." ;
    oc:hasRationale "The speed optimization reduces computation overhead significantly for large sample counts or distributed rendering." ;
    oc:severityLevel "MEDIUM" .

