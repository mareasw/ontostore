oc:kn_4c64166d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before attempting to use any TailwindCSS classes in Remotion" ;
    oc:directiveContent "TailwindCSS must be installed and enabled in the project before it can be used in Remotion components." ;
    oc:hasRationale "Tailwind is an optional dependency; Remotion does not bundle it by default." ;
    oc:severityLevel "HIGH" .

oc:kn_8ba7533c a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using TailwindCSS in a Remotion project" ;
    oc:directiveContent "Fetch https://www.remotion.dev/docs/tailwind using WebFetch for Tailwind installation and setup instructions." ;
    oc:hasRationale "Remotion requires specific configuration steps to integrate TailwindCSS properly with its webpack/bundler setup." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b8706308 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling any Remotion component with TailwindCSS" ;
    oc:directiveContent "Never use Tailwind `transition-*` or `animate-*` classes in Remotion components." ;
    oc:hasRationale "CSS transitions and animations are time-based and not synchronized with Remotion's frame-based rendering model, causing inconsistent playback." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f9418999 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When animating any Tailwind-styled element in Remotion" ;
    oc:directiveContent "Use `useCurrentFrame()` hook to drive all animations instead of CSS transition/animation classes." ;
    oc:hasRationale "Remotion renders frames discretely; frame-based animation ensures deterministic, frame-accurate output." ;
    oc:severityLevel "HIGH" .

