oc:kn_6a7d76e3 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using the Audio component" ;
    oc:directiveContent "Requires @remotion/sfx package installed" ;
    oc:hasRationale "The Audio tag is imported from @remotion/sfx, not the main remotion package" .

oc:kn_a87bf16d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the 11 pre-defined sound effects are insufficient" ;
    oc:directiveContent "For additional sound effects beyond the built-in set, search the internet or use https://github.com/kapishdima/soundcn/tree/main/assets as a resource" ;
    oc:hasRationale "The built-in library is small; external resources expand the available palette" .

oc:kn_be7a153b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding any sound effect to a Remotion composition" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """import { Audio } from "@remotion/sfx";

<Audio src={"https://remotion.media/whoosh.wav"} />;""" .

