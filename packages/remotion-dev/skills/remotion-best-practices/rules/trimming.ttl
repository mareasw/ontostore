@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_trimming a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "trimming" ;
    skos:broader "Animation timing technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "ae00948f6a903e384c7c312896adba9b50ed592f24a5a090699b7345849b36b9" ;
    oc:differentia "uses Sequence from/durationInFrames to cut the beginning or end of Remotion animations" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "animation component to trim" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """<Sequence durationInFrames={1.5 * fps}>
  <MyAnimation />
</Sequence>
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 2 ;
                    oc:sourceLocation "lines 31-35" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Use `durationInFrames` to unmount content after a specified duration:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "The animation plays for 45 frames, then the component unmounts." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Trim the End" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent """The animation appears 15 frames into its progress - the first 15 frames are trimmed off.
Inside `<MyAnimation>`, `useCurrentFrame()` starts at 15 instead of 0.""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "A negative `from` value shifts time backwards, making the animation start partway through:" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """import { Sequence, useVideoConfig } from "remotion";

const fps = useVideoConfig();

<Sequence from={-0.5 * fps}>
  <MyAnimation />
</Sequence>;
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 2 ;
                    oc:sourceLocation "lines 14-22" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Trim the Beginning" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: trimming
description: Trimming patterns for Remotion - cut the beginning or end of animations
metadata:
  tags: sequence, trim, clip, cut, offset
""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Use `<Sequence>` with a negative `from` value to trim the start of an animation." ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "The inner sequence trims 15 frames from the start, and the outer sequence delays the result by 30 frames." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """<Sequence from={30}>
  <Sequence from={-15}>
    <MyAnimation />
  </Sequence>
</Sequence>
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 2 ;
                    oc:sourceLocation "lines 43-49" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Nest sequences to both trim the beginning and delay when it appears:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Trim and Delay" ] ;
    oc:impartsKnowledge oc:kn_06cd6e15,
        oc:kn_579d2da2,
        oc:kn_6868b912,
        oc:kn_7373c00a,
        oc:kn_cac61dd1 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "combine trim and delay in animations",
        "cut beginning of animation",
        "shorten animation duration",
        "trim animation end",
        "trim animation start" ;
    oc:yieldsState oc:AnimationTrimmed .

oc:kn_06cd6e15 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When both trimming and delaying an animation" ;
    oc:directiveContent "Use Sequence composition (nesting) to combine independent timing transformations rather than trying to compute combined offsets manually" ;
    oc:hasRationale "Nesting keeps each timing concern isolated and composable" .

oc:kn_579d2da2 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Trimming the end of an animation; component unmounts after the specified number of frames" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """<Sequence durationInFrames={1.5 * fps}>
  <MyAnimation />
</Sequence>""" ;
    oc:hasRationale "durationInFrames controls when the Sequence unmounts its children, cutting off the animation" .

oc:kn_6868b912 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Any animation component wrapped in a Sequence with negative from" ;
    oc:directiveContent "When trimming the start with negative from, useCurrentFrame() inside the child component returns the offset value (e.g., 15) not 0" ;
    oc:hasRationale "The child animation must account for the fact that its frame counter starts mid-animation, not at 0" ;
    oc:severityLevel "HIGH" .

oc:kn_7373c00a a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Combining trim and delay; inner Sequence trims start, outer Sequence delays appearance" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """<Sequence from={30}>
  <Sequence from={-15}>
    <MyAnimation />
  </Sequence>
</Sequence>""" ;
    oc:hasRationale "Nesting Sequences composes time transformations — inner handles trim, outer handles delay" .

oc:kn_cac61dd1 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Trimming the start of an animation; negative from value causes useCurrentFrame() inside the child to start at the offset frame rather than 0" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """<Sequence from={-0.5 * fps}>
  <MyAnimation />
</Sequence>""" ;
    oc:hasRationale "Negative from shifts time backwards, effectively skipping the first N frames of the animation" .

