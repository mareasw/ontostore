    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "calculate optimal font size for text layout",
        "check text overflow in box",
        "fit text to container width",
        "measure text dimensions" ;
    oc:yieldsState oc:TextMeasured .

oc:kn_0c806788 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling measureText multiple times" ;
    oc:directiveContent "measureText() results are cached - duplicate calls with the same parameters return the cached result." ;
    oc:hasRationale "Caching improves performance and ensures consistent results across calls." ;
    oc:severityLevel "LOW" .

oc:kn_603164ff a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling text containers that need measurement" ;
    oc:directiveContent "Do not use padding or border on text containers when measuring layout. Use outline instead." ;
    oc:hasRationale "Padding and border affect box dimensions and cause measurement/rendering mismatches; outline does not affect layout." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c6b9f367 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When measuring text for layout calculations" ;
    oc:directiveContent "Use the exact same font properties (fontFamily, fontSize, fontWeight, letterSpacing) for measurement calls and rendering." ;
    oc:hasRationale "Mismatched font properties between measurement and rendering produce incorrect layout calculations." ;
    oc:severityLevel "HIGH" .

oc:kn_cde171b7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before measuring text dimensions" ;
    oc:directiveContent "Load fonts using waitUntilDone() before calling any measurement function (measureText, fitText, fillTextBox)." ;
    oc:hasRationale "Measurement results are incorrect if the font hasn't finished loading, because browser metrics depend on the loaded font face." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e1fd30c6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When debugging text measurement issues" ;
    oc:directiveContent "Use validateFontIsLoaded: true during development to catch font loading issues early with a clear error." ;
    oc:hasRationale "Silently wrong measurements from unloaded fonts are hard to diagnose; validation throws immediately." ;
    oc:severityLevel "MEDIUM" .

oc:req_9683b44d a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "React and Remotion fundamentals" .

oc:req_e925f915 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "@remotion/layout-utils" .

_:ref_135a63e64e25f7e9 a oc:WorkflowStep ;
    dcterms:description "Install @remotion/layout-utils via: npx remotion add @remotion/layout-utils" ;
    oc:expectedOutcome "Package installed and importable" ;
    oc:stepId "install" .

_:ref_b9aad86df22899e4 a oc:WorkflowStep ;
    dcterms:description "Load the required font using loadFont() and call waitUntilDone()" ;
    oc:expectedOutcome "Font fully loaded and ready for measurement" ;
    oc:stepDependsOn _:ref_135a63e64e25f7e9 ;
    oc:stepId "load-font" .

_:ref_d2515f1c16a1539b a oc:WorkflowStep ;
    dcterms:description "Use measureText(), fitText(), or fillTextBox() with the same font properties used for rendering" ;
    oc:expectedOutcome "Accurate text dimensions calculated" ;
    oc:stepDependsOn _:ref_b9aad86df22899e4 ;
    oc:stepId "measure" .

