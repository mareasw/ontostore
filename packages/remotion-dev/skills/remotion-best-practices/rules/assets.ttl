                            oc:blockType "code_block" ;
                            oc:codeContent """import { Video } from "@remotion/media";
import { staticFile } from "remotion";

<Video src={staticFile("clip.mp4")} />;
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 4 ;
                            oc:sourceLocation "lines 40-45" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { Audio } from "@remotion/media";
import { staticFile } from "remotion";

<Audio src={staticFile("music.mp3")} />;
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 6 ;
                            oc:sourceLocation "lines 49-54" ],
