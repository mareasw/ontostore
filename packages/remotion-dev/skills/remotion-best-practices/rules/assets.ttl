oc:kn_041bae16 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using externally-hosted media" ;
    oc:directiveContent "Remote URLs can be used directly as src values without staticFile(). Only local assets from public/ need staticFile()." ;
    oc:hasRationale "Remote URLs are already absolute and don't need the path resolution that local assets require" ;
    oc:severityLevel "MEDIUM" .

oc:kn_20ff900c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When importing any static asset into a Remotion composition" ;
    oc:directiveContent "1. Place asset in public/ folder 2. Import staticFile from 'remotion' (and component like Img, Video, Audio) 3. Use staticFile('filename.ext') as src attribute on the component" ;
    oc:stepOrder 1 .

oc:kn_32f86883 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering media in compositions" ;
    oc:directiveContent "Use Remotion components (<Img>, <Video>, <Audio>) instead of native HTML elements for media assets." ;
    oc:hasRationale "Remotion components ensure assets are fully loaded before rendering, preventing blank frames" ;
    oc:severityLevel "HIGH" .

oc:kn_401791b5 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When displaying images in a composition" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """import { Img, staticFile } from "remotion";
<Img src={staticFile("photo.png")} />""" .

oc:kn_5147a5c2 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When organizing project assets" ;
    oc:directiveContent "Place all static assets (images, videos, audio, fonts) in the public/ folder at the project root." ;
    oc:hasRationale "The public/ folder is the canonical location that staticFile() resolves against" ;
    oc:severityLevel "HIGH" .

oc:kn_8e62bb7b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When embedding video in a composition" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """import { Video } from "@remotion/media";
import { staticFile } from "remotion";
<Video src={staticFile("clip.mp4")} />""" .

oc:kn_9d81a6dd a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When loading custom fonts" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """const fontFamily = new FontFace("MyFont", `url(${staticFile("font.woff2")})`);
await fontFamily.load();
document.fonts.add(fontFamily);""" .

oc:kn_a75c946f a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When naming asset files in the public folder" ;
    oc:directiveContent "Special characters in filenames (#, ?, &) are automatically encoded by staticFile(). Avoid manually encoding filenames." ;
    oc:hasRationale "Double-encoding would break the URL resolution" ;
    oc:severityLevel "LOW" .

oc:kn_c9ffbf5d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When loading custom fonts in Remotion" ;
    oc:directiveContent "1. Import staticFile from 'remotion' 2. Create FontFace with url(staticFile('font.woff2')) 3. Call await font.load() 4. Add to document.fonts via document.fonts.add(font)" ;
    oc:stepOrder 2 .

oc:kn_d1b8efb5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When referencing any static asset from the public folder" ;
    oc:directiveContent "You MUST use staticFile() to reference any file from the public/ folder. Never use raw relative paths like '/logo.png' or './logo.png'." ;
    oc:hasRationale "staticFile() returns an encoded URL that works correctly when deploying to subdirectories" ;
    oc:severityLevel "CRITICAL" .

