oc:skill_remotion_dev_skills_remotion_best_practices_get_video_duration a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "get-video-duration" ;
    skos:broader "Media analysis utility" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "ed594a0d73a5274483f21c30e612aba57089d5bbc5437041aa32d07a8e789fd9" ;
    oc:differentia "extracts video file duration in seconds using Mediabunny library across browser and Node.js runtimes" ;
    oc:extends oc:skill_ontoskills_remotion_best_practices,
        oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:FileNotFound,
        oc:NetworkTimeout ;
    oc:hasArgumentHint "src: string — URL or file path to the video" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: get-video-duration
description: Getting the duration of a video file in seconds with Mediabunny
metadata:
  tags: duration, video, length, time, seconds
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Mediabunny can extract the duration of a video file. It works in browser, Node.js, and Bun environments." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use `FileSource` instead of `UrlSource`:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { Input, ALL_FORMATS, FileSource } from "mediabunny";

const input = new Input({
  formats: ALL_FORMATS,
  source: new FileSource(file), // File object from input or drag-drop
});

const durationInSeconds = await input.computeDuration();
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 51-60" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "In Node.js and Bun" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { Input, ALL_FORMATS, UrlSource } from "mediabunny";

export const getVideoDuration = async (src: string) => {
  const input = new Input({
    formats: ALL_FORMATS,
    source: new UrlSource(src, {
      getRetryDelay: () => null,
    }),
  });

  const durationInSeconds = await input.computeDuration();
  return durationInSeconds;
};
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 14-28" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Getting video duration" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Make sure to wrap the file path in `staticFile()`:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { staticFile } from "remotion";

const duration = await getVideoDuration(staticFile("video.mp4"));
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 41-45" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Video files from the public/ directory" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """const duration = await getVideoDuration("https://remotion.media/video.mp4");
console.log(duration); // e.g. 10.5 (seconds)
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 32-35" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Usage" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Getting video duration with Mediabunny" ] ;
    oc:impartsKnowledge oc:kn_1b0f91a0,
        oc:kn_3bd29a67,
        oc:kn_c1b89dad,
        oc:kn_cbab6ca2,
        oc:kn_fc8b41c0 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "determine how long a video file is",
        "extract video length in seconds",
        "get video duration" ;
    oc:yieldsState oc:DurationComputed .

oc:kn_1b0f91a0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — source type must match the runtime environment" ;
    oc:directiveContent "Use UrlSource for browser/Remotion environments and FileSource for Node.js/Bun environments" ;
    oc:hasRationale "Each runtime has different I/O capabilities; UrlSource uses fetch-based loading while FileSource uses filesystem APIs" ;
    oc:severityLevel "CRITICAL" .

oc:kn_3bd29a67 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When referencing video files from the Remotion public/ directory" ;
    oc:directiveContent "Wrap public directory file paths with staticFile() before passing to getVideoDuration" ;
    oc:hasRationale "Remotion's staticFile() resolves the correct URL path for public folder assets at runtime" ;
    oc:severityLevel "HIGH" .

oc:kn_c1b89dad a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When getting video duration in Node.js or Bun environments" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """import { Input, ALL_FORMATS, FileSource } from "mediabunny";

const input = new Input({
  formats: ALL_FORMATS,
  source: new FileSource(file),
});
const durationInSeconds = await input.computeDuration();""" ;
    oc:hasRationale "FileSource handles local file objects instead of URLs in server-side runtimes" .

oc:kn_cbab6ca2 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When getting video duration from a URL in browser/Remotion" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """import { Input, ALL_FORMATS, UrlSource } from "mediabunny";

const input = new Input({
  formats: ALL_FORMATS,
  source: new UrlSource(src, { getRetryDelay: () => null }),
});
const durationInSeconds = await input.computeDuration();""" ;
    oc:hasRationale "UrlSource is required for browser-based video duration extraction; ALL_FORMATS ensures broad codec support" .

oc:kn_fc8b41c0 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Mediabunny package must be installed (npm install mediabunny) and the video source must be accessible" .

