oc:skill_remotion_dev_skills_remotion_best_practices_audio a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "audio" ;
    skos:broader "media handling guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "e931664ac23bc4acfa137d8b415702bb4860b4fbabd6caed0042c0902d3bec90" ;
    oc:differentia "covers importing, trimming, volume control, speed, pitch, looping, and muting of audio in Remotion compositions" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Read" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: audio
description: Using audio and sound in Remotion - importing, trimming, volume, speed, pitch
metadata:
  tags: audio, media, trim, volume, speed, loop, pitch, mute, sound, sfx
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use `trimBefore` and `trimAfter` to remove portions of the audio. Values are in frames." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "The audio still starts playing at the beginning of the composition - only the specified portion is played." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """const { fps } = useVideoConfig();

return (
  <Audio
    src={staticFile("audio.mp3")}
    trimBefore={2 * fps} // Skip the first 2 seconds
    trimAfter={10 * fps} // End at the 10 second mark
  />
);
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 45-55" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Trimming" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Pitch shifting only works during server-side rendering, not in the Remotion Studio preview or in the `<Player />`." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Audio
  src={staticFile("audio.mp3")}
  toneFrequency={1.5} // Higher pitch
/>
<Audio
  src={staticFile("audio.mp3")}
  toneFrequency={0.8} // Lower pitch
/>
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 158-167" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use `toneFrequency` to adjust the pitch without affecting speed. Values range from 0.01 to 2:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 9 ;
                    oc:sectionTitle "Pitch" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Wrap the audio in a `<Sequence>` to delay when it starts:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { Sequence, staticFile } from "remotion";
import { Audio } from "@remotion/media";

const { fps } = useVideoConfig();

return (
  <Sequence from={1 * fps}>
    <Audio src={staticFile("audio.mp3")} />
  </Sequence>
);
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 63-74" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "The audio will start playing after 1 second." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Delaying" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """npx remotion add @remotion/media
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 15-17" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """First, the @remotion/media package needs to be installed.
If it is not installed, use the following command:""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Prerequisites" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Use `loopVolumeCurveBehavior` to control how the frame count behaves when looping:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Audio src={staticFile("audio.mp3")} loop />
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 136-138" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Audio
  src={staticFile("audio.mp3")}
  loop
  loopVolumeCurveBehavior="extend"
  volume={(f) => interpolate(f, [0, 300], [1, 0])} // Fade out over multiple loops
/>
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 5 ;
                            oc:sourceLocation "lines 145-152" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use `loop` to loop the audio indefinitely:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "`\"extend\"`: Frame count continues incrementing" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "`\"repeat\"`: Frame count resets to 0 each loop (default)" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Looping" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { Audio } from "@remotion/media";
import { staticFile } from "remotion";

export const MyComposition = () => {
  return <Audio src={staticFile("audio.mp3")} />;
};
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 23-30" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Audio src="https://remotion.media/audio.mp3" />
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 4 ;
                            oc:sourceLocation "lines 34-36" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Remote URLs are also supported:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent """By default, audio plays from the start, at full volume and full length.
Multiple audio tracks can be layered by adding multiple `<Audio>` components.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use `<Audio>` from `@remotion/media` to add audio to your composition." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Importing Audio" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Reverse playback is not supported." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Audio src={staticFile("audio.mp3")} playbackRate={2} /> {/* 2x speed */}
<Audio src={staticFile("audio.mp3")} playbackRate={0.5} /> {/* Half speed */}
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 125-128" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use `playbackRate` to change the playback speed:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Speed" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { interpolate } from "remotion";

const { fps } = useVideoConfig();

return (
  <Audio
    src={staticFile("audio.mp3")}
    volume={(f) =>
      interpolate(f, [0, 1 * fps], [0, 1], { extrapolateRight: "clamp" })
    }
  />
);
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 4 ;
                            oc:sourceLocation "lines 88-101" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Or use a callback for dynamic volume based on the current frame:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Audio src={staticFile("audio.mp3")} volume={0.5} />
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 82-84" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "The value of `f` starts at 0 when the audio begins to play, not the composition frame." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Set a static volume (0 to 1):" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Volume" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use `muted` to silence the audio. It can be set dynamically:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """const frame = useCurrentFrame();
const { fps } = useVideoConfig();

return (
  <Audio
    src={staticFile("audio.mp3")}
    muted={frame >= 2 * fps && frame <= 4 * fps} // Mute between 2s and 4s
  />
);
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 109-119" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Muting" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Using audio in Remotion" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Complete workflow for integrating audio into a Remotion composition with optional trimming, volume, and timing controls." ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Optionally set trimBefore/trimAfter, wrap in Sequence for delay, set volume/playbackRate/loop/toneFrequency as needed" ;
                    oc:expectedOutcome "Audio plays with desired timing, volume, speed, and pitch settings" ;
                    oc:stepId "configure-playback" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Install @remotion/media package: npx remotion add @remotion/media" ;
                    oc:expectedOutcome "@remotion/media package available in project" ;
                    oc:stepId "install-media" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Import Audio from @remotion/media and add <Audio src={...} /> to composition JSX" ;
                    oc:expectedOutcome "Audio component renders in composition" ;
                    oc:stepId "import-audio" ] ;
            oc:workflowId "audio-setup-and-use" ;
            oc:workflowName "Add Audio to Remotion Composition" ] ;
    oc:impartsKnowledge oc:kn_0f30d8dc,
        oc:kn_cf68600c,
        oc:kn_dfa3ee7f,
        oc:kn_ec4c245f,
        oc:kn_f4d7945a ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "add audio to remotion composition",
        "change audio speed and pitch",
        "control audio volume dynamically",
        "delay audio playback",
        "loop audio in video",
        "trim audio in remotion" .

oc:kn_0f30d8dc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scheduling audio playback timing" ;
    oc:directiveContent "Use <Sequence> to delay audio start rather than trimming. Use trimBefore/trimAfter to select a portion of the audio content." ;
    oc:hasRationale "Trimming selects which portion of the audio file plays; Sequence controls when in the composition timeline it starts. These are orthogonal concerns." .

oc:kn_cf68600c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using toneFrequency prop" ;
    oc:directiveContent "Pitch shifting via toneFrequency only works during server-side rendering, not in Remotion Studio preview or <Player />." ;
    oc:hasRationale "The pitch-shifting algorithm relies on server-side processing and cannot be applied in real-time browser playback." ;
    oc:severityLevel "HIGH" .

oc:kn_dfa3ee7f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before importing Audio in any component" ;
    oc:directiveContent "The @remotion/media package must be installed before using <Audio>. Install via: npx remotion add @remotion/media" ;
    oc:hasRationale "Audio is not part of the core remotion package and requires the separate @remotion/media dependency." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ec4c245f a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When using dynamic volume callbacks" ;
    oc:directiveContent "The volume callback's frame parameter (f) starts at 0 when the audio begins playing, not at the composition-level frame number." ;
    oc:hasRationale "This offset ensures volume curves are relative to audio start, making them reusable and predictable regardless of composition placement." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f4d7945a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting playbackRate on <Audio>" ;
    oc:directiveContent "Do not attempt reverse audio playback - it is not supported by the Audio component's playbackRate prop." ;
    oc:hasRationale "Unlike video, audio does not support negative playbackRate values for reverse playback." ;
    oc:severityLevel "HIGH" .

