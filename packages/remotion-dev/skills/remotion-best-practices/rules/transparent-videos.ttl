                            oc:textContent "**CLI:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**Default in Studio** (restart Studio after changing):" ] ;
