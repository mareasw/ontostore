oc:kn_07a6436d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a specific composition should always render with transparency" ;
    oc:directiveContent "Set transparent render defaults via calculateMetadata on the Composition so Studio picks them up automatically per-composition" ;
    oc:hasRationale "Using calculateMetadata binds transparency settings to the composition itself rather than relying on global config or CLI flags each time" .

oc:kn_34f1911b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing transparent video output format" ;
    oc:directiveContent "Use ProRes for video editing software workflows, use WebM/VP9 for browser playback" ;
    oc:hasRationale "ProRes 4444 is widely supported in NLEs (Premiere, Final Cut, DaVinci); WebM VP9 has native browser playback support" .

oc:kn_52955c5d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering transparent ProRes video" ;
    oc:directiveContent "Transparent ProRes requires --image-format=png, --pixel-format=yuva444p10le, --codec=prores, and --prores-profile=4444 used together" ;
    oc:hasRationale "The combination of PNG image format, YUVA 4:4:4 10-bit pixel format, and ProRes 4444 profile is required to preserve the alpha channel" ;
    oc:severityLevel "CRITICAL" .

oc:kn_8d8d71a8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering transparent WebM video" ;
    oc:directiveContent "Transparent WebM (VP9) requires --image-format=png, --pixel-format=yuva420p, and --codec=vp9 used together" ;
    oc:hasRationale "VP9 with yuva420p pixel format is the supported combination for alpha-enabled WebM output playable in browsers" ;
    oc:severityLevel "CRITICAL" .

oc:kn_913994ab a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When configuring transparent defaults in Studio via remotion.config.ts" ;
    oc:directiveContent "Studio must be restarted after changing remotion.config.ts for transparency settings to take effect" ;
    oc:hasRationale "Studio reads config at startup and does not hot-reload codec/pixel-format changes" ;
    oc:severityLevel "MEDIUM" .

