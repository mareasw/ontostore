oc:kn_7e1b9a3c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building dimension-reading effects" ;
    oc:directiveContent "Include scale as a dependency of the useEffect that reads dimensions, so measurements recompute when the scale changes." ;
    oc:hasRationale "Scale can change dynamically; stale scale values produce incorrect measurements." .

oc:kn_914b1012 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When measuring inside frequently-fired callbacks or animation frames" ;
    oc:directiveContent "getBoundingClientRect() triggers a layout reflow if the DOM has pending style/layout changes, which can be expensive in animation loops." ;
    oc:hasRationale "Excessive reflow calls degrade rendering performance, especially in a video rendering pipeline." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c983a69a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When accessing DOM refs inside useEffect" ;
    oc:directiveContent "Always guard against null refs before calling getBoundingClientRect() — check if ref.current is truthy." ;
    oc:hasRationale "Refs may be null during initial render or if the component unmounts, causing runtime errors." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cbdfd5fe a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when reading element dimensions in Remotion" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent "Use useCurrentScale() hook from remotion to get the current scale factor, then divide getBoundingClientRect() width and height by scale to get true logical dimensions." ;
    oc:hasRationale "This is the only reliable way to get correct pixel measurements in Remotion's scaled rendering environment." ;
    oc:severityLevel "HIGH" .

oc:kn_d67ee922 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When measuring any DOM element in a Remotion composition" ;
    oc:directiveContent "Remotion applies a scale() CSS transform to the video container, so raw getBoundingClientRect() values are incorrect and must be divided by the current scale factor." ;
    oc:hasRationale "Failing to account for scale leads to dimension values that are larger or smaller than the actual logical pixel sizes, breaking layout calculations." ;
    oc:severityLevel "CRITICAL" .

_:ref_36e0267dd11253b5 a oc:WorkflowStep ;
    dcterms:description "In a useEffect, check the ref is non-null, then call getBoundingClientRect() on the element." ;
    oc:expectedOutcome "Raw (scaled) width and height values are obtained." ;
    oc:stepDependsOn _:ref_84548500c6818824 ;
    oc:stepId "get-bounding-rect" .

_:ref_84548500c6818824 a oc:WorkflowStep ;
    dcterms:description "Call useCurrentScale() to obtain the current scale factor applied by Remotion." ;
    oc:expectedOutcome "A numeric scale value is available for correction." ;
    oc:stepId "get-scale" .

