oc:skill_remotion_dev_skills_remotion_best_practices_videos a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "videos" ;
    skos:broader "Media embedding component" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "d9d3032a57f92c759daf0bd60b3282f6810ecc9958e9093a6b828de623b05328" ;
    oc:differentia "that provides video integration with trimming, volume, speed, looping, and pitch control in Remotion compositions" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:FileNotFound,
        oc:PackageNotInstalled ;
    oc:hasArgumentHint "video source path or URL" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_07880c56,
        oc:req_8e3216f4,
        oc:req_c4531000 ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Pitch shifting only works during server-side rendering, not in the Remotion Studio preview or in the `<Player />`." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Video
  src={staticFile("video.mp4")}
  toneFrequency={1.5} // Higher pitch
/>
<Video
  src={staticFile("video.mp4")}
  toneFrequency={0.8} // Lower pitch
/>
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 160-169" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use `toneFrequency` to adjust the pitch without affecting speed. Values range from 0.01 to 2:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Pitch" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use `loop` to loop the video indefinitely:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Video
  src={staticFile("video.mp4")}
  loop
  loopVolumeCurveBehavior="extend"
  volume={(f) => interpolate(f, [0, 300], [1, 0])} // Fade out over multiple loops
/>
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 5 ;
                            oc:sourceLocation "lines 147-154" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "`\"repeat\"`: Frame count resets to 0 each loop (for `volume` callback)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "`\"extend\"`: Frame count continues incrementing" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Use `loopVolumeCurveBehavior` to control how the frame count behaves when looping:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Video src={staticFile("video.mp4")} loop />
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 138-140" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Looping" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { Sequence, staticFile } from "remotion";
import { Video } from "@remotion/media";

const { fps } = useVideoConfig();

return (
  <Sequence from={1 * fps}>
    <Video src={staticFile("video.mp4")} />
  </Sequence>
);
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 59-70" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "The video will appear after 1 second." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Wrap the video in a `<Sequence>` to delay when it appears:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Delaying" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """const { fps } = useVideoConfig();

return (
  <Video
    src={staticFile("video.mp4")}
    trimBefore={2 * fps} // Skip the first 2 seconds
    trimAfter={10 * fps} // End at the 10 second mark
  />
);
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 43-53" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use `trimBefore` and `trimAfter` to remove portions of the video. Values are in seconds." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Trimming" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Or use a callback for dynamic volume based on the current frame:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Video src={staticFile("video.mp4")} volume={0.5} />
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 96-98" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Video src={staticFile("video.mp4")} muted />
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 6 ;
                            oc:sourceLocation "lines 119-121" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { interpolate } from "remotion";

const { fps } = useVideoConfig();

return (
  <Video
    src={staticFile("video.mp4")}
    volume={(f) =>
      interpolate(f, [0, 1 * fps], [0, 1], { extrapolateRight: "clamp" })
    }
  />
);
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 4 ;
                            oc:sourceLocation "lines 102-115" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "Use `muted` to silence the video entirely:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Set a static volume (0 to 1):" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Volume" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use the `style` prop to control size and position:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Video
  src={staticFile("video.mp4")}
  style={{
    width: 500,
    height: 300,
    position: "absolute",
    top: 100,
    left: 50,
    objectFit: "cover",
  }}
/>
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 78-90" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Sizing and Position" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Use `<Video>` from `@remotion/media` to embed videos into your composition." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "Remote URLs are also supported:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { Video } from "@remotion/media";
import { staticFile } from "remotion";

export const MyComposition = () => {
  return <Video src={staticFile("video.mp4")} />;
};
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 4 ;
                            oc:sourceLocation "lines 24-31" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """npx remotion add @remotion/media # If project uses npm
bunx remotion add @remotion/media # If project uses bun
yarn remotion add @remotion/media # If project uses yarn
pnpm exec remotion add @remotion/media # If project uses pnpm
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 15-20" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """First, the @remotion/media package needs to be installed.  
If it is not, use the following command:""" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Video src="https://remotion.media/video.mp4" />
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 6 ;
                            oc:sourceLocation "lines 35-37" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Prerequisites" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Use `playbackRate` to change the playback speed:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """<Video src={staticFile("video.mp4")} playbackRate={2} /> {/* 2x speed */}
<Video src={staticFile("video.mp4")} playbackRate={0.5} /> {/* Half speed */}
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 127-130" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Reverse playback is not supported." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Speed" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Using videos in Remotion" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: videos
description: Embedding videos in Remotion - trimming, volume, speed, looping, pitch
metadata:
  tags: video, media, trim, volume, speed, loop, pitch
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Steps to embed a video in a Remotion composition with common configurations" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Add props: trimBefore/trimAfter for trimming, volume/muted for audio, playbackRate for speed, loop for looping, toneFrequency for pitch" ;
                    oc:expectedOutcome "Video plays with desired behavior" ;
                    oc:stepId "configure-props" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Add <Video src={staticFile('video.mp4')} /> to composition JSX" ;
                    oc:expectedOutcome "Video renders in the composition" ;
                    oc:stepId "add-video-component" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Install @remotion/media package via npx remotion add @remotion/media" ;
                    oc:expectedOutcome "Package available in project dependencies" ;
                    oc:stepId "install-media" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Import Video from @remotion/media and staticFile from remotion" ;
                    oc:expectedOutcome "Components available for use in composition" ;
                    oc:stepId "import-video" ] ;
            oc:workflowId "embed-video" ;
            oc:workflowName "Embed and configure video" ] ;
    oc:impartsKnowledge oc:kn_4e419fe2,
        oc:kn_8e5a3c5c,
        oc:kn_97c8662e,
        oc:kn_a50f9aab,
        oc:kn_c0337827,
        oc:kn_d672b537,
        oc:kn_e81e8feb,
        oc:kn_f99b676f ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "adjust video pitch",
        "change video playback speed",
        "control video volume dynamically",
        "embed video in remotion composition",
        "loop video in remotion",
        "trim video in remotion" ;
    oc:yieldsState oc:VideoEmbedded .

oc:kn_4e419fe2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting video volume" ;
    oc:directiveContent "volume prop accepts 0 to 1 for static values, or a callback (f) => number for dynamic per-frame volume" ;
    oc:hasRationale "Ensures volume stays within audible range and enables frame-accurate audio fading using interpolate()" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8e5a3c5c a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When attempting to reverse video playback via playbackRate" ;
    oc:directiveContent "Reverse playback is not supported by the Video component" ;
    oc:hasRationale "The underlying browser media APIs do not support reverse video decoding" ;
    oc:severityLevel "HIGH" .

oc:kn_97c8662e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When trimming video with trimBefore/trimAfter" ;
    oc:directiveContent "trimBefore and trimAfter values are in frames (not seconds); multiply seconds by fps from useVideoConfig()" ;
    oc:hasRationale "Remotion operates in frames, so time-based trimming requires conversion using the composition's FPS" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a50f9aab a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before embedding any video" ;
    oc:directiveContent "Install @remotion/media via `npx remotion add @remotion/media` (or equivalent for bun/yarn/pnpm) before using <Video>" ;
    oc:hasRationale "The <Video> component is exported from @remotion/media, not from the core remotion package" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c0337827 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When looping video with dynamic volume" ;
    oc:directiveContent "Use loopVolumeCurveBehavior='extend' with a volume callback when you want volume to fade across multiple loop iterations" ;
    oc:hasRationale "Default 'repeat' resets frame count each loop, preventing cross-loop fades; 'extend' allows continuous interpolation" .

oc:kn_d672b537 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using toneFrequency prop" ;
    oc:directiveContent "Pitch shifting (toneFrequency) only works during server-side rendering, NOT in Remotion Studio preview or <Player />" ;
    oc:hasRationale "Browser audio APIs cannot perform pitch shifting independent of playback rate; only SSR rendering supports it" ;
    oc:severityLevel "HIGH" .

oc:kn_e81e8feb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When needing to delay video start" ;
    oc:directiveContent "Use <Sequence from={delay * fps}> to wrap <Video> for delayed appearance rather than trying to manipulate the video timeline" ;
    oc:hasRationale "Sequences are Remotion's native way to offset components in time; they handle frame counting correctly" .

oc:kn_f99b676f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adjusting pitch via toneFrequency" ;
    oc:directiveContent "toneFrequency range is 0.01 to 2; values outside this range are invalid" ;
    oc:hasRationale "The pitch shifting algorithm has a limited frequency multiplier range" ;
    oc:severityLevel "MEDIUM" .

oc:req_07880c56 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "React and JSX/TSX syntax" .

oc:req_8e3216f4 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "@remotion/media package" .

oc:req_c4531000 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Remotion fundamentals (compositions, staticFile, useVideoConfig)" .

