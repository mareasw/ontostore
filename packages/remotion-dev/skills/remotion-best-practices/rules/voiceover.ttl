oc:kn_097d9c54 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before generating voiceover audio" ;
    oc:directiveContent "ELEVENLABS_API_KEY environment variable must be set. If user has not specified a TTS provider, recommend ElevenLabs and ask for their API key." ;
    oc:hasRationale "ElevenLabs API requires authentication; no fallback TTS is configured by default" ;
    oc:severityLevel "CRITICAL" .

oc:kn_0d6a8329 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When saving TTS output for use in compositions" ;
    oc:directiveContent "Write generated audio files to public/ directory so Remotion can access them via staticFile()." ;
    oc:hasRationale "Remotion's staticFile() only serves files from the public/ directory; other paths will fail at render time" .

oc:kn_1e7d4d57 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing calculateMetadata to set composition duration from voiceover audio lengths" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """const durations = await Promise.all(
  SCENE_AUDIO_FILES.map((file) => getAudioDuration(staticFile(file))),
);
const sceneDurations = durations.map((d) => d * FPS);
return {
  durationInFrames: Math.ceil(sceneDurations.reduce((sum, d) => sum + d, 0)),
};""" .

oc:kn_6a55eef4 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building a voiceover-enabled Remotion composition" ;
    oc:directiveContent "1. Create a generation script that reads scene config and calls ElevenLabs API for each scene. 2. Write MP3 files to public/voiceover/{compositionId}/{sceneId}.mp3. 3. Use calculateMetadata to measure audio durations via getAudioDuration(staticFile(...)). 4. Convert durations to frames (seconds × FPS). 5. Set durationInFrames to Math.ceil(sum of all scene frame durations). 6. Pass sceneDurations to the component via a voiceover prop." ;
    oc:hasRationale "Ensures audio files exist before rendering and composition duration exactly matches total voiceover length" ;
    oc:stepOrder 1 .

oc:kn_aeedfcc1 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before implementing dynamic duration calculation and audio playback" ;
    oc:directiveContent "Requires getAudioDuration utility to measure MP3 file lengths. Requires audio.md patterns for rendering and delaying audio in the component." .

oc:kn_bb296203 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user wants a non-ElevenLabs TTS provider" ;
    oc:directiveContent "Users may substitute any TTS service that produces an audio file; the integration pattern remains the same." ;
    oc:hasRationale "The architecture is provider-agnostic — only the audio generation step changes, not the calculateMetadata or rendering logic" .

oc:kn_cab8f567 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using calculateMetadata with TransitionSeries" ;
    oc:directiveContent "If the composition uses <TransitionSeries>, subtract the overlap frames from total duration to avoid incorrect length." ;
    oc:hasRationale "Transitions overlap between scenes; failing to subtract overlap inflates the total duration beyond actual content length" ;
    oc:severityLevel "HIGH" .

