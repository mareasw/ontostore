                            oc:contentOrder 1 ;
                            oc:textContent "Once parsed, the captions are in the `Caption` format and can be used with all `@remotion/captions` utilities." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Using imported captions" ] ;
