oc:kn_03acae6f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling the fetch response for .srt files" ;
    oc:directiveContent "Do not try to parse .srt files without first calling response.text() - parseSrt expects a string input, not a Response object" ;
    oc:hasRationale "Passing a Response object directly to parseSrt will cause a runtime error" ;
    oc:severityLevel "HIGH" .

oc:kn_0a44c92e a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before importing any .srt file" ;
    oc:directiveContent "Install @remotion/captions package: `npx remotion add @remotion/captions` (npm) or equivalent for bun/yarn/pnpm" ;
    oc:hasRationale "parseSrt() is provided by @remotion/captions and will not be available without installation" ;
    oc:severityLevel "CRITICAL" ;
    oc:stepOrder 1 .

oc:kn_19918b3d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When importing .srt subtitles into a Remotion component" ;
    oc:directiveContent "1. Place .srt file in public/ folder 2. Use staticFile() to get the path 3. fetch() the file and call .text() 4. Parse with parseSrt({ input: text }) 5. Use returned captions array with @remotion/captions utilities" ;
    oc:stepOrder 2 .

oc:kn_99474d94 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the .srt file is hosted remotely rather than in the public folder" ;
    oc:directiveContent "Remote URLs are also supported - use fetch() with a URL instead of staticFile() for remote .srt files" ;
    oc:hasRationale "staticFile() only works for files in the public/ directory; remote files need direct URL fetching" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e2176c31 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when fetching .srt files in a Remotion component" ;
    oc:directiveContent "Must use useDelayRender() when fetching captions asynchronously to prevent Remotion from rendering before data is ready" ;
    oc:hasRationale "Without delayRender, Remotion will render the frame before the fetch completes, resulting in missing captions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e3756ffc a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Core pattern for fetching and parsing .srt files in Remotion" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """const response = await fetch(staticFile("subtitles.srt"));
const text = await response.text();
const { captions } = parseSrt({ input: text });""" .

oc:kn_e7dfb0d6 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After parseSrt() completes" ;
    oc:directiveContent "Captions array is non-null and contains Caption objects with text and timing information" ;
    oc:hasRationale "A non-null captions array confirms successful parsing and the data is ready for rendering" .

