@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_light_leaks a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "light-leaks" ;
    skos:broader "Visual effect component" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "17d2f136f7bf2f438274a0ade43df017c360ae31175d8367ce476415c222dfca" ;
    oc:differentia "that renders WebGL-based light leak overlay transitions in Remotion videos" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:VersionMismatch ;
    oc:hasArgumentHint "seed, hueShift, durationInFrames" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "`<LightLeak>` can also be used outside of `<TransitionSeries>`, for example as a decorative overlay in any composition:" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """import { AbsoluteFill } from "remotion";
import { LightLeak } from "@remotion/light-leaks";

const MyComp: React.FC = () => (
  <AbsoluteFill>
    <MyContent />
    <LightLeak durationInFrames={60} seed={3} />
  </AbsoluteFill>
);
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 2 ;
                    oc:sourceLocation "lines 63-73" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 6 ;
            oc:sectionTitle "Standalone usage" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """import { LightLeak } from "@remotion/light-leaks";

// Blue-tinted light leak with a different pattern
<LightLeak seed={5} hueShift={240} />;

// Green-tinted light leak
<LightLeak seed={2} hueShift={120} />;
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 1 ;
                    oc:sourceLocation "lines 49-57" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 5 ;
            oc:sectionTitle "Customizing the look" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "`<LightLeak>` from `@remotion/light-leaks` renders a WebGL-based light leak effect. It reveals during the first half of its duration and retracts during the second half." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "Typically used inside a `<TransitionSeries.Overlay>` to play over the cut point between two scenes. See the **transitions** rule for `<TransitionSeries>` and overlay usage." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "This only works from Remotion 4.0.415 and up. Use `npx remotion versions` to check your Remotion version and `npx remotion upgrade` to upgrade your Remotion version." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Light Leaks" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: light-leaks
description: Light leak overlay effects for Remotion using @remotion/light-leaks.
metadata:
  tags: light-leaks, overlays, effects, transitions
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """npx remotion add @remotion/light-leaks
""" ;
                    oc:codeLanguage "bash" ;
                    oc:contentOrder 1 ;
                    oc:sourceLocation "lines 18-20" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Prerequisites" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 1 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "`hueShift?` — rotates the hue in degrees (`0`–`360`). Default: `0` (yellow-to-orange). `120` = green, `240` = blue." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "`seed?` — determines the shape of the light leak pattern. Different seeds produce different patterns. Default: `0`." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "`durationInFrames?` — defaults to the parent sequence/composition duration. The effect reveals during the first half and retracts during the second half." ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Props" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """import { TransitionSeries } from "@remotion/transitions";
import { LightLeak } from "@remotion/light-leaks";

<TransitionSeries>
  <TransitionSeries.Sequence durationInFrames={60}>
    <SceneA />
  </TransitionSeries.Sequence>
  <TransitionSeries.Overlay durationInFrames={30}>
    <LightLeak />
  </TransitionSeries.Overlay>
  <TransitionSeries.Sequence durationInFrames={60}>
    <SceneB />
  </TransitionSeries.Sequence>
</TransitionSeries>;
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 1 ;
                    oc:sourceLocation "lines 24-39" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Basic usage with TransitionSeries" ] ;
    oc:impartsKnowledge oc:kn_302c312c,
        oc:kn_492b909b,
        oc:kn_55e87e75,
        oc:kn_91f05933,
        oc:kn_aa9b26f1,
        oc:kn_b573ca1a ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:ToolInstalled ;
    oc:resolvesIntent "add light leak overlay effect",
        "create light leak transitions between scenes",
        "customize light leak color and pattern" ;
    oc:yieldsState oc:EffectApplied .

oc:kn_302c312c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting durationInFrames for LightLeak" ;
    oc:directiveContent "The LightLeak effect reveals during the first half of its duration and retracts during the second half." ;
    oc:hasRationale "Understanding the reveal/retract timing is essential for syncing the overlay with scene transitions." .

oc:kn_492b909b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using LightLeak as a transition overlay between two scenes" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """<TransitionSeries.Overlay durationInFrames={30}>
  <LightLeak />
</TransitionSeries.Overlay>""" .

oc:kn_55e87e75 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When adding ambient light effects to any composition" ;
    oc:directiveContent "LightLeak can be used standalone outside TransitionSeries as a decorative overlay via AbsoluteFill stacking." .

oc:kn_91f05933 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When adding light leak effects to a Remotion project" ;
    oc:directiveContent "1. Run `npx remotion add @remotion/light-leaks` 2. Import LightLeak from @remotion/light-leaks 3. Place inside <TransitionSeries.Overlay> with desired durationInFrames" ;
    oc:stepOrder 1 .

oc:kn_aa9b26f1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When customizing the light leak appearance" ;
    oc:directiveContent "Use seed prop to change the light leak pattern shape, and hueShift (0–360) to change color. Default hueShift=0 gives yellow-to-orange; 120=green; 240=blue." ;
    oc:hasRationale "The seed and hueShift props provide full visual control without needing custom shaders." .

oc:kn_b573ca1a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before using @remotion/light-leaks" ;
    oc:directiveContent "Requires Remotion 4.0.415 or later. Use `npx remotion versions` to check and `npx remotion upgrade` to upgrade." ;
    oc:hasRationale "The WebGL-based light leak effect was introduced in 4.0.415 and will not work in earlier versions." ;
    oc:severityLevel "CRITICAL" .

