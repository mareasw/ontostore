oc:kn_03e8ac77 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining defaultProps on a Composition or Still" ;
    oc:directiveContent "defaultProps values must be JSON-serializable. Date, Map, Set, and staticFile() are supported." ;
    oc:hasRationale "Non-serializable values cannot be serialized across the Remotion rendering pipeline, causing runtime errors." ;
    oc:severityLevel "HIGH" .

oc:kn_078567da a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining component props for compositions" ;
    oc:directiveContent "Use `type` declarations for props rather than `interface` to ensure defaultProps type safety." ;
    oc:hasRationale "Type declarations work correctly with the `satisfies` operator for defaultProps validation, while interfaces may not." ;
    oc:severityLevel "MEDIUM" .

oc:kn_14f94587 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing dynamic metadata calculation for compositions" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """const calculateMetadata: CalculateMetadataFunction<Props> = async ({ props, abortSignal }) => {
  const data = await fetch(url, { signal: abortSignal }).then(res => res.json());
  return { durationInFrames: Math.ceil(data.duration * fps), props: { ...props, extra: data.value } };
};""" .

oc:kn_38d83279 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining a full composition with props and dynamic metadata" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """<Composition
  id="MyComposition"
  component={MyComposition}
  durationInFrames={100}
  fps={30}
  width={1080}
  height={1080}
  defaultProps={{ key: "value" } satisfies MyProps}
  calculateMetadata={calculateMetadata}
/>""" .

oc:kn_6907b6f8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating non-animated image outputs" ;
    oc:directiveContent "Use `<Still>` instead of `<Composition>` for single-frame images. It does not require durationInFrames or fps." ;
    oc:hasRationale "Stills are optimized for single-frame rendering and omit unnecessary video-related configuration." ;
    oc:severityLevel "LOW" .

oc:kn_bc249268 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When composition metadata depends on external data or API responses" ;
    oc:directiveContent "Use `calculateMetadata` to make dimensions, duration, or props dynamic based on fetched data. It runs once before rendering begins and can override placeholder values." ;
    oc:hasRationale "Allows compositions to adapt their properties dynamically without hardcoding values, enabling data-driven video generation." ;
    oc:severityLevel "HIGH" .

oc:kn_cce5a515 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing multiple compositions into a single render" ;
    oc:directiveContent "When nesting a composition within another, use `<Sequence>` with `width` and `height` props rather than referencing `<Composition>` directly." ;
    oc:hasRationale "The Sequence component properly handles the timing and layout of nested compositions with explicit size control." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ce2e5945 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Import Composition/Still/Folder from 'remotion' and your components. 2. Define components in RemotionRoot with unique id, component, width, height. 3. Add fps and durationInFrames for videos (omit for Stills). 4. Provide defaultProps (JSON-serializable, use type + satisfies). 5. Optionally add calculateMetadata for dynamic props/dimensions. 6. Organize with Folder components as needed." ;
    oc:stepOrder 1 .

oc:kn_d741d35c a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """<Composition
  id="{uniqueId}"
  component={ComponentRef}
  durationInFrames={frames}
  fps={frameRate}
  width={pixels}
  height={pixels}
  defaultProps={jsonObject}
  calculateMetadata={fn}
/>""" ;
    oc:templateVariables "ComponentRef",
        "fn",
        "frameRate",
        "frames",
        "jsonObject",
        "pixels",
        "uniqueId" .

oc:kn_ffed54c3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming Folder components" ;
    oc:directiveContent "Folder names can only contain letters, numbers, and hyphens." ;
    oc:hasRationale "Invalid folder names break sidebar organization and may cause rendering issues." ;
    oc:severityLevel "MEDIUM" .

