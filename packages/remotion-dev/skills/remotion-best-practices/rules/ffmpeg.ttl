    oc:differentia "that provides FFmpeg and FFprobe access within the Remotion ecosystem without requiring external installation" ;
    oc:extends oc:skill_ontoskills_remotion_best_practices,
        oc:skill_remotion_dev_skills_remotion_best_practices ;
