oc:kn_09964b6e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using ffmpeg/ffprobe in a Remotion project" ;
    oc:directiveContent "FFmpeg and FFprobe do not need to be installed separately; they are available via 'bunx remotion ffmpeg' and 'bunx remotion ffprobe'." ;
    oc:hasRationale "Remotion bundles FFmpeg access so no system-level installation is required, ensuring consistent behavior across environments." ;
    oc:severityLevel "HIGH" .

oc:kn_3b648368 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When trimming video for use within a Remotion composition" ;
    oc:directiveContent "Prefer the <Video> component's trimBefore and trimAfter props over FFmpeg CLI for trimming when possible. It is non-destructive and the trim can be changed at any time." ;
    oc:hasRationale "Declarative trimming via component props preserves the original file and allows iterative changes without re-encoding." ;
    oc:severityLevel "MEDIUM" .

oc:kn_aa5f011e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using 'bunx remotion ffmpeg' to trim video with -ss and -to flags" ;
    oc:directiveContent "When trimming via FFmpeg CLI, you MUST re-encode the video (-c:v libx264 -c:a aac). Do NOT stream-copy, as it causes frozen frames at the start of the trimmed video." ;
    oc:hasRationale "Stream-copying (-c copy) does not re-encode from keyframes, leading to frozen/corrupt frames at the trim boundary." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ef36738c a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-encoding a trimmed segment of video via FFmpeg CLI" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "bunx remotion ffmpeg -ss 00:00:05 -i public/input.mp4 -to 00:00:10 -c:v libx264 -c:a aac public/output.mp4" .

_:ref_70b69f6231c1e458 a oc:WorkflowStep ;
    dcterms:description "Use the FFmpeg command line. You MUST re-encode the video to avoid frozen frames at the start of the video." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_f358bed43c530c6a a oc:WorkflowStep ;
    dcterms:description "Use the `trimBefore` and `trimAfter` props of the `<Video>` component. The benefit is that this is non-destructive and you can change the trim at any time." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

