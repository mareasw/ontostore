                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Re-encodes from the exact frame
bunx remotion ffmpeg -ss 00:00:05 -i public/input.mp4 -to 00:00:10 -c:v libx264 -c:a aac public/output.mp4
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 23-26" ],
                        _:ref_543ddab8053f04c5,
