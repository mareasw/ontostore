  trimBefore={5 * fps}
  trimAfter={10 * fps}
/>;
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 5 ;
                            oc:sourceLocation "lines 30-38" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "You have 2 options for trimming videos:" ] ;
