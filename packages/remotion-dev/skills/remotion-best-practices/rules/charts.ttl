    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "animate SVG path drawing",
        "create animated bar chart",
        "create animated line chart",
        "create animated pie chart",
        "create data-driven video animations",
        "create stock chart visualization" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_235af2b4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating animated pie/donut charts" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent "Use stroke-dashoffset with rotate(-90) transform to animate pie chart segments from 12 o'clock position. Calculate segment length as (value/total) * circumference." ;
    oc:hasRationale "SVG circles start drawing from 3 o'clock by default; rotate(-90) corrects to 12 o'clock. stroke-dashoffset animation provides smooth segment reveal." ;
    oc:severityLevel "HIGH" .

oc:kn_4c2e4240 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When animating bar chart heights with staggered entrance" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent "Use spring() with stagger delays for bar chart entrance animations: spring({ frame, fps, delay: i * STAGGER_DELAY, config: { damping: 200 } })" ;
    oc:hasRationale "Spring with high damping provides smooth, predictable bar growth; stagger delay creates cascading visual effect." ;
    oc:severityLevel "HIGH" .

oc:kn_5c0ead71 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating line charts, stock graphs, or any path-drawing animation" ;
    oc:directiveContent "1. Install @remotion/paths via `npx remotion add @remotion/paths` 2. Generate SVG path string from data points using M/L commands 3. Use evolvePath(progress, path) to get strokeDasharray/strokeDashoffset 4. Interpolate progress from 0 to 1 over desired duration 5. Apply strokeDasharray and strokeDashoffset to <path> element" ;
    oc:hasRationale "evolvePath handles the complex math of progressive path rendering; manual dash calculations are error-prone." ;
    oc:stepOrder 1 .

oc:kn_6d3a6c04 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using any animation library or CSS transitions in chart components" ;
    oc:directiveContent "Never use CSS animations, requestAnimationFrame, or third-party library animations in Remotion charts — they cause flickering. Drive all animations exclusively from useCurrentFrame()." ;
    oc:hasRationale "Remotion renders frames discretely; non-deterministic animations produce inconsistent frames and visual flickering." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8e6c5545 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting frame numbers to animation progress values" ;
    oc:directiveContent "Use interpolate() with extrapolateLeft/extrapolateRight clamp and easing functions for smooth, controlled animation progress." ;
    oc:hasRationale "Clamping prevents overshoot; easing provides natural-feeling motion curves." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a848dde1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, for any chart or visualization in Remotion" ;
    oc:directiveContent "All chart animations must be driven by useCurrentFrame() and useVideoConfig() — no other timing sources are valid in Remotion." ;
    oc:hasRationale "Remotion renders frames non-sequentially and at variable speed during preview; only useCurrentFrame() provides the correct frame context." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c95f3164 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating animated markers that follow a chart line or path" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent "Use getPointAtLength() and getTangentAtLength() from @remotion/paths to position markers/arrows along a path. Calculate rotation angle with Math.atan2(tangent.y, tangent.x)." ;
    oc:hasRationale "These utility functions abstract the complex SVG path math needed to place and orient objects along arbitrary curves." .

