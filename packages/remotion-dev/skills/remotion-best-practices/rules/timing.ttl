@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_remotion_dev_skills_remotion_best_practices_timing a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "timing" ;
    skos:broader "Animation technique" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "3bc19fff4fea55b16a68003d2723178e12bb60e61d0149c3d1bbb23c7389e8fe" ;
    oc:differentia "uses interpolation curves, spring physics, and easing functions to create motion in Remotion videos" ;
    oc:extends oc:skill_ontoskills_remotion_best_practices,
        oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:hasArgumentHint "null" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """import { interpolate } from "remotion";

const opacity = interpolate(frame, [0, 100], [0, 1]);
""" ;
                    oc:codeLanguage "ts" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 10-14" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "A simple linear interpolation is done using the `interpolate` function." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent """By default, the values are not clamped, so the value can go outside the range [0, 1].  
Here is how they can be clamped:""" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """const opacity = interpolate(frame, [0, 100], [0, 1], {
  extrapolateRight: "clamp",
  extrapolateLeft: "clamp",
});
""" ;
                    oc:codeLanguage "ts" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 19-24" ],
                [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: timing
description: Interpolation curves in Remotion - linear, easing, spring animations
metadata:
  tags: spring, bounce, easing, interpolation
""" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 6 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "`Easing.quad`" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "`Easing.circle`" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "`Easing.exp`" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "`Easing.sin`" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "and curves (sorted from most linear to most curved):" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """const value1 = interpolate(frame, [0, 100], [0, 1], {
  easing: Easing.inOut(Easing.quad),
  extrapolateLeft: "clamp",
  extrapolateRight: "clamp",
});
""" ;
                            oc:codeLanguage "ts" ;
                            oc:contentOrder 8 ;
                            oc:sourceLocation "lines 163-169" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "`Easing.inOut`" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "`Easing.out` for starting fast and slowing down" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "`Easing.in` for starting slow and accelerating" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 9 ;
                            oc:textContent "Cubic bezier curves are also supported:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """The default easing is `Easing.linear`.  
There are various other convexities:""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent "Convexities and curves need be combined for an easing function:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Easing can be added to the `interpolate` function:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """const value1 = interpolate(frame, [0, 100], [0, 1], {
  easing: Easing.bezier(0.8, 0.22, 0.96, 0.65),
  extrapolateLeft: "clamp",
  extrapolateRight: "clamp",
});
""" ;
                            oc:codeLanguage "ts" ;
                            oc:contentOrder 10 ;
                            oc:sourceLocation "lines 173-179" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { interpolate, Easing } from "remotion";

const value1 = interpolate(frame, [0, 100], [0, 1], {
  easing: Easing.inOut(Easing.quad),
  extrapolateLeft: "clamp",
  extrapolateRight: "clamp",
});
""" ;
                            oc:codeLanguage "ts" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 137-145" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Easing" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { spring, useCurrentFrame, useVideoConfig } from "remotion";

const frame = useCurrentFrame();
const { fps } = useVideoConfig();

const scale = spring({
  frame,
  fps,
});
""" ;
                            oc:codeLanguage "ts" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 31-41" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """Spring animations have a more natural motion.  
They go from 0 to 1 over time.""" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Map spring output (0-1) to custom ranges:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """const springProgress = spring({
  frame,
  fps,
});

// Map to rotation
const rotation = interpolate(springProgress, [0, 1], [0, 360]);

<div style={{ rotate: rotation + "deg" }} />;
""" ;
                                    oc:codeLanguage "tsx" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 99-109" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Combining spring() with interpolate()" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """The default configuration is: `mass: 1, damping: 10, stiffness: 100`.  
This leads to the animation having a bit of bounce before it settles.""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "Here are some common configurations:" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "The config can be overwritten like this:" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """const scale = spring({
  frame,
  fps,
  config: { damping: 200 },
});
""" ;
                                    oc:codeLanguage "ts" ;
                                    oc:contentOrder 3 ;
                                    oc:sourceLocation "lines 50-56" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """const smooth = { damping: 200 }; // Smooth, no bounce (subtle reveals)
const snappy = { damping: 20, stiffness: 200 }; // Snappy, minimal bounce (UI elements)
const bouncy = { damping: 8 }; // Bouncy entrance (playful animations)
const heavy = { damping: 15, stiffness: 80, mass: 2 }; // Heavy, slow, small bounce
""" ;
                                    oc:codeLanguage "tsx" ;
                                    oc:contentOrder 6 ;
                                    oc:sourceLocation "lines 62-67" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "The recommended configuration for a natural motion without a bounce is: `{ damping: 200 }`." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Physical properties" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """const frame = useCurrentFrame();
const { fps, durationInFrames } = useVideoConfig();

const inAnimation = spring({
  frame,
  fps,
});
const outAnimation = spring({
  frame,
  fps,
  durationInFrames: 1 * fps,
  delay: durationInFrames - 1 * fps,
});

const scale = inAnimation - outAnimation;
""" ;
                                    oc:codeLanguage "tsx" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 115-131" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Springs return just numbers, so math can be performed:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Adding springs" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """const spring = spring({
  frame,
  fps,
  durationInFrames: 40,
});
""" ;
                                    oc:codeLanguage "tsx" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 87-93" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """A `spring()` has a natural duration based on the physical properties.  
To stretch the animation to a specific duration, use the `durationInFrames` parameter.""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Duration" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """const entrance = spring({
  frame: frame - ENTRANCE_DELAY,
  fps,
  delay: 20,
});
""" ;
                                    oc:codeLanguage "tsx" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 74-80" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """The animation starts immediately by default.  
Use the `delay` parameter to delay the animation by a number of frames.""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Delay" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Spring animations" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:impartsKnowledge oc:kn_01060766,
        oc:kn_57abed01,
        oc:kn_6690a0c8,
        oc:kn_6b4ab815,
        oc:kn_aad4b7cb,
        oc:kn_b06b1744,
        oc:kn_b5eb1fe0,
        oc:kn_b63337e0,
        oc:kn_cb5e361b,
        oc:kn_ccabbf5c,
        oc:kn_ed5e29d9,
        oc:kn_f8e5b032 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "animate elements with spring physics",
        "apply easing curves to interpolation",
        "combine spring and interpolate for complex animations",
        "control animation timing and motion feel",
        "create natural motion animations in Remotion" ;
    oc:yieldsState oc:AnimationConfigured .

oc:kn_01060766 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using interpolate() for opacity, scale, or any bounded property" ;
    oc:directiveContent "Never use interpolate without clamping when you need values to stay within the output range — by default, values extrapolate beyond the range." ;
    oc:hasRationale "Without clamping, values outside the intended range can cause visual artifacts like negative opacity or extreme scale values." ;
    oc:severityLevel "HIGH" .

oc:kn_57abed01 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using spring() or interpolate()" ;
    oc:directiveContent "Requires useCurrentFrame() and useVideoConfig() hooks from remotion to get frame and fps values" .

oc:kn_6690a0c8 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Combining spring with interpolate for custom output ranges" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """const springProgress = spring({ frame, fps });
const rotation = interpolate(springProgress, [0, 1], [0, 360]);""" .

oc:kn_6b4ab815 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing any animation in Remotion" ;
    oc:directiveContent """1. Choose animation type: spring() for natural motion, interpolate() with easing for precise curves
2. For springs: set config (damping, stiffness, mass) to match desired feel
3. Add delay/durationInFrames as needed for timing
4. Clamp interpolate outputs with extrapolateLeft/extrapolateRight: 'clamp'
5. Compose multiple springs mathematically for multi-phase animations""" ;
    oc:stepOrder 1 .

oc:kn_aad4b7cb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When you need a spring-driven animation that maps to non-0-1 ranges" ;
    oc:directiveContent "Combine spring() output with interpolate() to map the 0-1 spring progress to custom value ranges (e.g., rotation degrees, pixel offsets)." ;
    oc:hasRationale "This pattern gives you spring physics feel with arbitrary output ranges, unlocking complex animations." ;
    oc:severityLevel "LOW" .

oc:kn_b06b1744 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between spring and interpolate animation approaches" ;
    oc:directiveContent "Prefer spring() over interpolate() for organic, natural-feeling motion. Use interpolate() with easing for precise, predictable timing curves." ;
    oc:hasRationale "Springs simulate physics and produce more lifelike motion; interpolate with easing gives deterministic, frame-exact control." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b5eb1fe0 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When building complex entrance/exit or multi-phase animations" ;
    oc:directiveContent "Springs return plain numbers, enabling mathematical composition — subtract two springs to create an in-then-out animation, add them for layered motion." ;
    oc:hasRationale "Mathematical composition of spring values enables sophisticated animation choreography without custom easing curves." ;
    oc:severityLevel "LOW" .

oc:kn_b63337e0 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Spring config presets" ;
    oc:directiveContent """const smooth = { damping: 200 }; // Smooth, no bounce
const snappy = { damping: 20, stiffness: 200 }; // Snappy, minimal bounce
const bouncy = { damping: 8 }; // Bouncy entrance
const heavy = { damping: 15, stiffness: 80, mass: 2 }; // Heavy, slow""" .

oc:kn_cb5e361b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Eased interpolation with clamping" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent "const value = interpolate(frame, [0, 100], [0, 1], { easing: Easing.inOut(Easing.quad), extrapolateLeft: \"clamp\", extrapolateRight: \"clamp\" });" .

oc:kn_ccabbf5c a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Smooth spring animation without bounce" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent "const scale = spring({ frame, fps, config: { damping: 200 } });" .

oc:kn_ed5e29d9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting spring config presets" ;
    oc:directiveContent "Use { damping: 200 } for smooth no-bounce reveals, { damping: 20, stiffness: 200 } for snappy UI elements, { damping: 8 } for bouncy playful animations, { damping: 15, stiffness: 80, mass: 2 } for heavy slow motion." ;
    oc:hasRationale "These presets cover the most common animation feels and prevent trial-and-error tweaking." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f8e5b032 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a spring animation must fit a specific time window" ;
    oc:directiveContent "Spring animations have a natural duration determined by their physical properties (mass, damping, stiffness). Use durationInFrames to override to an exact frame count." ;
    oc:hasRationale "Understanding that spring duration is emergent from physics config prevents mismatched animation timing." ;
    oc:severityLevel "MEDIUM" .

