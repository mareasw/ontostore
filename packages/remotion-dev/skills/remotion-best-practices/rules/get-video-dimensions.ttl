    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "ed1bb6e0ae742e4bfcb18e7c50af23fc782a9d699b90d367250437c7f6da7304" ;
    oc:differentia "Uses Mediabunny to read width and height of a video file from URLs, local files, or Remotion static files" ;
    oc:extends oc:skill_ontoskills_remotion_best_practices,
        oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "src: string (URL or file path to video)" ;
    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_65b36cfa,
        oc:req_887da35a ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: get-video-dimensions
description: Getting the width and height of a video file with Mediabunny
metadata:
  tags: dimensions, width, height, resolution, size, video
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Mediabunny can extract the width and height of a video file. It works in browser, Node.js, and Bun environments." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { staticFile } from "remotion";

const dimensions = await getVideoDimensions(staticFile("video.mp4"));
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 64-68" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Using with staticFile in Remotion" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """const dimensions = await getVideoDimensions("https://remotion.media/video.mp4");
console.log(dimensions.width); // e.g. 1920
console.log(dimensions.height); // e.g. 1080
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 39-43" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Usage" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { Input, ALL_FORMATS, UrlSource } from "mediabunny";

export const getVideoDimensions = async (src: string) => {
  const input = new Input({
    formats: ALL_FORMATS,
    source: new UrlSource(src, {
      getRetryDelay: () => null,
    }),
  });

  const videoTrack = await input.getPrimaryVideoTrack();
  if (!videoTrack) {
    throw new Error("No video track found");
  }

  return {
    width: videoTrack.displayWidth,
    height: videoTrack.displayHeight,
  };
};
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 14-35" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Getting video dimensions" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "For local files, use `FileSource` instead of `UrlSource`:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import { Input, ALL_FORMATS, FileSource } from "mediabunny";

const input = new Input({
  formats: ALL_FORMATS,
  source: new FileSource(file), // File object from input or drag-drop
});

const videoTrack = await input.getPrimaryVideoTrack();
const width = videoTrack.displayWidth;
const height = videoTrack.displayHeight;
""" ;
                            oc:codeLanguage "tsx" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 49-60" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Using with local files" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Getting video dimensions with Mediabunny" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Extract width and height from a video file using Mediabunny" ;
            oc:hasStep _:ref_00a714f62fe32fa2,
                _:ref_28a7fcaf044ddaa0,
                [ a oc:WorkflowStep ;
                    dcterms:description "Read displayWidth and displayHeight from the video track" ;
                    oc:expectedOutcome "Object with width and height properties" ;
                    oc:stepDependsOn _:ref_c91b5f3b053f2737 ;
                    oc:stepId "read-dimensions" ],
                _:ref_c91b5f3b053f2737 ;
            oc:workflowId "get-video-dimensions" ;
            oc:workflowName "Get Video Dimensions" ] ;
    oc:impartsKnowledge oc:kn_0676d50b,
