        oc:kn_40f32c64,
        oc:kn_5a1411ba,
        oc:kn_956747fd ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:FileExists ;
    oc:resolvesIntent "get video dimensions",
        "get video resolution",
        "get video width and height",
        "read video metadata" ;
    oc:yieldsState oc:VideoDimensionsRetrieved .

oc:kn_0676d50b a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always" ;
    oc:directiveContent "Reading video dimensions is a read-only, idempotent operation; calling it multiple times produces the same result without side effects." ;
    oc:hasRationale "No state is mutated; the function only reads metadata from the video file." .

oc:kn_35f00538 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing Mediabunny Input for video dimension extraction" ;
    oc:directiveContent "Use UrlSource for remote URLs and FileSource for local File objects; both require wrapping in an Input instance with ALL_FORMATS." ;
    oc:hasRationale "Mediabunny abstracts source types into UrlSource and FileSource; choosing the wrong one causes runtime errors." .

oc:kn_40f32c64 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting video dimensions from a URL source" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent "const input = new Input({ formats: ALL_FORMATS, source: new UrlSource(src, { getRetryDelay: () => null }) }); const videoTrack = await input.getPrimaryVideoTrack(); const { displayWidth, displayHeight } = videoTrack;" .

oc:kn_5a1411ba a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before extracting video dimensions" ;
    oc:directiveContent "Ensure the video source (URL or File) is accessible and not an audio-only file before calling getPrimaryVideoTrack." ;
    oc:hasRationale "Audio-only files have no video track and will cause the null-check to throw." .

oc:kn_956747fd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting video dimensions from any source" ;
    oc:directiveContent "Must check for null video track after calling getPrimaryVideoTrack(); throw if no video track is found." ;
    oc:hasRationale "A file may contain no video track (audio-only or corrupt), and accessing displayWidth/displayHeight on null will crash." ;
    oc:severityLevel "HIGH" .

oc:req_65b36cfa a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Remotion staticFile API" .

oc:req_887da35a a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "mediabunny" .

_:ref_00a714f62fe32fa2 a oc:WorkflowStep ;
    dcterms:description "Call input.getPrimaryVideoTrack() to retrieve the primary video track" ;
    oc:expectedOutcome "Video track object or null" ;
    oc:stepDependsOn _:ref_28a7fcaf044ddaa0 ;
    oc:stepId "get-video-track" .

_:ref_28a7fcaf044ddaa0 a oc:WorkflowStep ;
    dcterms:description "Create a Mediabunny Input instance with ALL_FORMATS and appropriate source (UrlSource for URLs, FileSource for local files)" ;
    oc:expectedOutcome "Input instance ready to read video metadata" ;
    oc:stepId "create-input" .

_:ref_c91b5f3b053f2737 a oc:WorkflowStep ;
    dcterms:description "Check if video track is null; throw error if no video track found" ;
    oc:expectedOutcome "Confirmed non-null video track" ;
    oc:stepDependsOn _:ref_00a714f62fe32fa2 ;
    oc:stepId "validate-track" .

