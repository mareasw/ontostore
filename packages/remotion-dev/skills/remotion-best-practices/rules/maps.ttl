        oc:Procedure ;
    oc:appliesToContext "When building a complete map animation" ;
    oc:directiveContent "1. Install mapbox-gl, @turf/turf, @types/mapbox-gl via appropriate package manager 2. Add REMOTION_MAPBOX_TOKEN to .env 3. Create map component with useDelayRender, Mapbox Map, interactive:false, fadeDuration:0 4. Hide all basemap features 5. Add line source/layer with coordinates 6. Animate camera using turf.along + interpolate + useCurrentFrame 7. Animate lines using linear interpolation (straight) or turf.lineSliceAlong (curved) 8. Add markers with appropriately scaled labels 9. Render with --gl=angle --concurrency=1" ;
    oc:stepOrder 1 .

oc:kn_3a0e5989 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When choosing map style" ;
    oc:directiveContent "By default, hide all features from the Mapbox Standard style (roads, transit, labels, POIs, 3D objects) and set road/trunk/motorway colors to transparent." ;
    oc:hasRationale "Provides a clean base map that puts focus on the animated route/lines" ;
    oc:severityLevel "MEDIUM" .

oc:kn_557503c2 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When initializing a Mapbox map in Remotion" ;
    oc:directiveContent "Always use useDelayRender() to delay rendering until the map is fully loaded. Set map to null until loaded." ;
    oc:hasRationale "The map tiles must be loaded before the frame can be captured; without delayRender, frames will render with blank maps" ;
    oc:severityLevel "CRITICAL" .

oc:kn_600e60ab a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing useEffect hooks for Mapbox maps" ;
    oc:directiveContent "Do NOT add a _map.remove() cleanup function in useEffect." ;
    oc:hasRationale "Cleaning up the map instance causes issues during Remotion's rendering process" ;
    oc:severityLevel "HIGH" .

oc:kn_7db2620a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When animating lines that should appear straight on a Mercator projection" ;
    oc:directiveContent "Do NOT use turf's lineSliceAlong or along for straight lines. Use linear interpolation between coordinates instead. Only use turf functions for curved/geodesic lines." ;
    oc:hasRationale "Turf uses geodesic (great circle) calculations which appear curved on Mercator projections" ;
    oc:severityLevel "HIGH" .

oc:kn_82f202f8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drawing lines on the map" ;
    oc:directiveContent "Do NOT add glow effects to lines or additional line points unless explicitly requested." ;
    oc:hasRationale "Keeps the visualization clean and uncluttered by default" ;
    oc:severityLevel "LOW" .

oc:kn_9e0182dd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting camera orientation" ;
    oc:directiveContent "Keep camera oriented so north is up by default. Do not jump between camera angles unless explicitly requested." ;
    oc:hasRationale "Maintains consistent spatial orientation for the viewer" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a6e7a3f2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating progress for line animations" ;
    oc:directiveContent "Clamp the line progress to a minimum value (e.g., 0.00001) to avoid empty lines which cause turf errors." ;
    oc:hasRationale "Zero-length lines cause turf.js calculation errors" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c9a12e32 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating multi-step camera or line animations" ;
    oc:directiveContent "For multi-step animations, set ALL properties at every stage (zoom, position, line progress) to prevent visual jumps. Override initial values explicitly." ;
    oc:hasRationale "Incomplete property specification causes discontinuities between animation stages" ;
    oc:severityLevel "HIGH" .

oc:kn_da4817cc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding any Mapbox map to a Remotion composition" ;
    oc:directiveContent "Never use Mapbox's built-in animations. Set fadeDuration to 0 and interactive to false. All animation must be driven by useCurrentFrame()." ;
    oc:hasRationale "Remotion requires deterministic frame-by-frame control; Mapbox's own animations would break rendering determinism" ;
    oc:severityLevel "CRITICAL" .

oc:kn_eb2fbfaa a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering a map animation video" ;
    oc:directiveContent "npx remotion render --gl=angle --concurrency=1" .

