    oc:resolvesIntent "animate elements in Remotion",
        "create fade-in transitions",
        "drive animations with frames" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_3c75674e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When animating elements in Remotion" ;
    oc:directiveContent "CSS transitions and CSS animations are FORBIDDEN — they will not render correctly in Remotion." ;
    oc:hasRationale "CSS-based animations rely on browser timing which does not map to discrete frame rendering." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4777d427 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using interpolate for any animated property" ;
    oc:directiveContent "Use interpolate() with extrapolateRight: 'clamp' to prevent animation values from exceeding intended ranges." ;
    oc:hasRationale "Clamping ensures animations don't overshoot or produce unexpected values past the defined keyframe range." .

oc:kn_a652cb97 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling animated elements in Remotion" ;
    oc:directiveContent "Tailwind animation class names (e.g., animate-spin, animate-pulse) are FORBIDDEN — they will not render correctly." ;
    oc:hasRationale "Tailwind animation classes use CSS keyframes internally, which suffer the same frame-rendering mismatch." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b502f839 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating any animation in Remotion" ;
    oc:directiveContent "All animations MUST be driven by the useCurrentFrame() hook." ;
    oc:hasRationale "Remotion renders frames individually; only frame-driven values produce correct video output." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ff566c10 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating animation timing" ;
    oc:directiveContent "Write animation durations in seconds and multiply by the fps value from useVideoConfig() to convert to frame counts." ;
    oc:hasRationale "Using seconds as the unit of thought is more intuitive and makes the code portable across different frame rates." .

