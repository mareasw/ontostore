oc:skill_remotion_dev_skills_remotion_best_practices_animations a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "animations" ;
    skos:broader "Animation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "4fbc3c908fa27725534a8bfeaf26c58a58750790bc0e98dc8745e27734a9abb2" ;
    oc:dependsOnSkill oc:skill_ontoskills_remotion_best_practices ;
    oc:differentia "that drives all visual transitions through Remotion's frame-based hooks rather than CSS animations" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """import { useCurrentFrame } from "remotion";

export const FadeIn = () => {
  const frame = useCurrentFrame();
  const { fps } = useVideoConfig();

  const opacity = interpolate(frame, [0, 2 * fps], [0, 1], {
    extrapolateRight: "clamp",
  });

  return <div style={{ opacity }}>Hello World!</div>;
};
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 11-24" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent """All animations MUST be driven by the `useCurrentFrame()` hook.  
Write animations in seconds and multiply them by the `fps` value from `useVideoConfig()`.""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent """CSS transitions or animations are FORBIDDEN - they will not render correctly.  
Tailwind animation class names are FORBIDDEN - they will not render correctly.""" ],
                [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: animations
description: Fundamental animation skills for Remotion
metadata:
  tags: animations, transitions, frames, useCurrentFrame
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Steps to create a frame-driven animation in Remotion." ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Define animation timing in seconds, multiply by fps to get frame-based keyframe array." ;
                    oc:expectedOutcome "Input range for interpolate() is computed as frame numbers." ;
                    oc:stepId "define-timing" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Apply the interpolated value to the JSX style attribute." ;
                    oc:expectedOutcome "Element renders with frame-accurate animation." ;
                    oc:stepId "apply-to-style" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Use interpolate() with the frame and computed ranges to derive animated property values; set extrapolateRight to 'clamp'." ;
                    oc:expectedOutcome "Smoothly interpolated value clamped to the output range." ;
                    oc:stepId "interpolate-values" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Call useCurrentFrame() to get the current frame and useVideoConfig() to get fps." ;
                    oc:expectedOutcome "Frame number and fps value are available for calculations." ;
                    oc:stepId "get-hooks" ] ;
            oc:workflowId "create-animation" ;
            oc:workflowName "Create a Remotion Animation" ] ;
    oc:impartsKnowledge oc:kn_3c75674e,
        oc:kn_4777d427,
        oc:kn_a652cb97,
        oc:kn_b502f839,
        oc:kn_ff566c10 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
