oc:skill_remotion_dev_skills_remotion_best_practices_parameters a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "parameters" ;
    skos:broader "Parameterization pattern" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "9de38837a07dc406052dfbb759c58ca5298ca331d86d9aa0f4e177b339e288b5" ;
    oc:dependsOnSkill oc:skill_ontoskills_remotion_best_practices ;
    oc:differentia "uses Zod schemas to make Remotion video compositions configurable with type-safe props and visual editing" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:hasArgumentHint "composition-file-path" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent "Then use it in the schema:" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """import { zColor } from "@remotion/zod-types";
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 5 ;
                    oc:sourceLocation "lines 99-101" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "If it is not installed, use the following command:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "Then import `zColor` from `@remotion/zod-types`:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "For adding a color picker, use `zColor()` from `@remotion/zod-types`." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """export const MyCompositionSchema = z.object({
  color: zColor(),
});
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 7 ;
                    oc:sourceLocation "lines 105-109" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """npx remotion add @remotion/zod-types # If project uses npm
bunx remotion add @remotion/zod-types # If project uses bun
yarn remotion add @remotion/zod-types # If project uses yarn
pnpm exec remotion add @remotion/zod-types # If project uses pnpm
""" ;
                    oc:codeLanguage "bash" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 90-95" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Color picker" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 15 ;
                    oc:textContent "In the root file, the schema can be passed to the composition:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 13 ;
                    oc:textContent "Then, a Zod schema can be defined alongside the component:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "To make a video parametrizable, a Zod schema can be added to a composition." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 5 ;
                    oc:textContent "If `package-lock.json` is found, use the following command:" ],
                [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: parameters
description: Make a video parametrizable by adding a Zod schema
metadata:
  tags: parameters, zod, schema
""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 18 ;
                    oc:textContent "All schemas that are supported by Zod are supported by Remotion." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """npm i zod
""" ;
                    oc:codeLanguage "bash" ;
                    oc:contentOrder 6 ;
                    oc:sourceLocation "lines 16-18" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "First, `zod` must be installed ." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "Search the project for lockfiles and run the correct command depending on the package manager:" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """yarn add zod
""" ;
                    oc:codeLanguage "bash" ;
                    oc:contentOrder 10 ;
                    oc:sourceLocation "lines 28-30" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 7 ;
                    oc:textContent "If `bun.lockb` is found, use the following command:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 11 ;
                    oc:textContent "If `pnpm-lock.yaml` is found, use the following command:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 17 ;
                    oc:textContent "Now, the user can edit the parameter visually in the sidebar." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """bun i zod
""" ;
                    oc:codeLanguage "bash" ;
                    oc:contentOrder 8 ;
                    oc:sourceLocation "lines 22-24" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """import { Composition } from "remotion";
import { MycComponent, MyCompositionSchema } from "./MyComposition";

export const RemotionRoot = () => {
  return (
    <Composition
      id="MyComposition"
      component={MyComponent}
      durationInFrames={100}
      fps={30}
      width={1080}
      height={1080}
      defaultProps={{ title: "Hello World" }}
      schema={MyCompositionSchema}
    />
  );
};
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 16 ;
                    oc:sourceLocation "lines 58-76" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 9 ;
                    oc:textContent "If `yarn.lock` is found, use the following command:" ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """pnpm i zod
""" ;
                    oc:codeLanguage "bash" ;
                    oc:contentOrder 12 ;
                    oc:sourceLocation "lines 34-36" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 19 ;
                    oc:textContent "Remotion requires that the top-level type is a z.object(), because the collection of props of a React component is always an object." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """import { z } from "zod";

export const MyCompositionSchema = z.object({
  title: z.string(),
});

const MyComponent: React.FC<z.infer<typeof MyCompositionSchema>> = () => {
  return (
    <div>
      <h1>{props.title}</h1>
    </div>
  );
};
""" ;
                    oc:codeLanguage "tsx" ;
                    oc:contentOrder 14 ;
                    oc:sourceLocation "lines 40-54" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
