    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:RemotionProjectExists,
        oc:ToolInstalled ;
    oc:resolvesIntent "add color picker to video parameters",
        "add parameters to video composition",
        "make video parametrizable with zod schema" ;
    oc:yieldsState oc:CompositionParameterized,
        oc:SchemaDefined .

oc:kn_507a8ef1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining any composition schema" ;
    oc:directiveContent "The top-level schema type must be z.object() because React component props are always an object." ;
    oc:hasRationale "Remotion requires z.object() at the top level since React component props are inherently object-shaped." ;
    oc:severityLevel "CRITICAL" .

oc:kn_68e0974a a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When registering a parametrized composition in the root file" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """<Composition
  id="MyComp"
  component={MyComp}
  schema={MySchema}
  defaultProps={{ title: "Hello" }}
  durationInFrames={100}
  fps={30}
  width={1080}
  height={1080}
/>""" ;
    oc:hasRationale "The schema prop enables visual editing in the Remotion sidebar; defaultProps provides initial values." .

oc:kn_780e3962 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining a parameterized composition component" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """export const MySchema = z.object({ title: z.string() });
const Comp: React.FC<z.infer<typeof MySchema>> = (props) => { ... };""" ;
    oc:hasRationale "Co-locating the schema with the component and using z.infer ensures type safety between schema and props." .

oc:kn_78e997e9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When installing any npm package in a Remotion project" ;
    oc:directiveContent "Detect the project's package manager by checking for lockfiles: package-lock.json (npm), bun.lockb (bun), yarn.lock (yarn), pnpm-lock.yaml (pnpm)." ;
    oc:hasRationale "Using the wrong package manager can corrupt the dependency tree or cause inconsistent installs." .

oc:kn_d3ec9bb0 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before adding parameterization" ;
    oc:directiveContent "zod must be installed as a dependency before defining schemas." .

oc:kn_f188235b a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "When adding color picker parameters" ;
    oc:directiveContent "@remotion/zod-types must be installed via 'npx/bunx/yarn/pnpm remotion add @remotion/zod-types' before using zColor()." .

oc:kn_f1a1c4db a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing schema field types" ;
    oc:directiveContent "All Zod types are supported by Remotion, but the top-level must always be z.object()." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fdc53c7d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When making any Remotion composition parametrizable" ;
    oc:directiveContent "1. Install zod (detect package manager from lockfile) 2. Define z.object() schema alongside component 3. Use z.infer<typeof Schema> for component props type 4. Pass schema prop to <Composition> with defaultProps 5. Optionally add zColor() from @remotion/zod-types for color pickers" ;
    oc:stepOrder 1 .

