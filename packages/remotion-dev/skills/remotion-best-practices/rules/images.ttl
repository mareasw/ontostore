        oc:kn_c9bcce54 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create dynamic image sequences",
        "display local images in video",
        "embed images in remotion video",
        "get image dimensions for composition sizing",
        "use remote images in remotion" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_48e835f0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using remote image URLs with <Img>" ;
    oc:directiveContent "Ensure remote images have CORS enabled when using URLs." ;
    oc:hasRationale "Without CORS, the browser will block the image request during rendering, causing failures in video export." ;
    oc:severityLevel "HIGH" .

oc:kn_561a5c94 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing videos around a primary image with unknown dimensions" ;
    oc:directiveContent "Use getImageDimensions() inside calculateMetadata() to dynamically size compositions based on actual image dimensions." ;
    oc:hasRationale "Hardcoding dimensions can lead to aspect ratio distortion; reading actual dimensions ensures pixel-perfect composition sizing." .

oc:kn_6351ad15 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When any <Img> component is rendered in a composition" ;
    oc:directiveContent "The <Img> component triggers an image preload that blocks rendering until the image is fully loaded." ;
    oc:hasRationale "This ensures no blank or partially loaded frames appear in the exported video, but may increase render time for large images." .

oc:kn_ba3a424e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When embedding animated GIF files" ;
    oc:directiveContent "Use <Gif> from @remotion/gif for animated GIFs instead of <Img>." ;
    oc:hasRationale "The <Img> component does not handle GIF animation playback; the dedicated <Gif> component provides proper frame-accurate animation control." .

oc:kn_c9bcce54 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When displaying any image in a Remotion composition" ;
    oc:directiveContent "Always use the <Img> component from 'remotion'. Never use native HTML <img>, Next.js <Image>, or CSS background-image." ;
    oc:hasRationale "The <Img> component ensures images are fully loaded before rendering, preventing flickering and blank frames during video export." ;
    oc:severityLevel "CRITICAL" .

oc:req_3386f180 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "remotion package (Img, staticFile, useCurrentFrame, getImageDimensions)" .

oc:req_3b0da1f1 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "staticFile() API for public folder references" .

oc:req_b45fb062 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Remotion framework and React" .

