        oc:CompositionPropsTransformed .

oc:kn_18b7b281 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Defining a calculateMetadata callback for a Composition" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """const calculateMetadata: CalculateMetadataFunction<Props> = async ({ props, abortSignal }) => {
  // compute metadata from props
  return { durationInFrames, width, height, fps, props, defaultOutName, defaultCodec };
};""" ;
    oc:hasRationale "Type-safe async callback pattern is the standard way to dynamically set composition metadata in Remotion" .

oc:kn_30449f7a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting video duration to frames" ;
    oc:directiveContent "Use Math.ceil(durationInSeconds * fps) to convert seconds to frames, ensuring the composition is never shorter than the source video." ;
    oc:hasRationale "Floor or truncation could cut off the last frame; ceiling ensures full coverage" ;
    oc:severityLevel "LOW" .

oc:kn_4af16b93 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Setting duration based on multiple videos in sequence" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """const metadataPromises = props.videos.map((video) => getVideoDuration(video.src));
const allMetadata = await Promise.all(metadataPromises);
const totalDuration = allMetadata.reduce((sum, dur) => sum + dur, 0);
return { durationInFrames: Math.ceil(totalDuration * fps) };""" ;
    oc:hasRationale "Promise.all enables parallel fetching of multiple video durations for efficiency, and reduce sums them for sequential playback" .

oc:kn_938d0731 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Always when using calculateMetadata" ;
    oc:directiveContent "1. Define calculateMetadata function with CalculateMetadataFunction<Props> type 2. Destructure { props, abortSignal } from callback argument 3. Fetch/compute needed metadata (video duration, dimensions, API data) 4. Return object with any combination: durationInFrames, width, height, fps, props, defaultOutName, defaultCodec 5. Attach to <Composition calculateMetadata={fn} />" ;
    oc:hasRationale "Structured approach ensures all metadata overrides are correctly applied before rendering begins" ;
    oc:stepOrder 1 .

oc:kn_9ceaff2a a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Return value of calculateMetadata callback" ;
    oc:directiveContent """{
  durationInFrames?: number;
  width?: number;
  height?: number;
  fps?: number;
  props?: Props;
  defaultOutName?: string;
  defaultCodec?: string;
}""" ;
    oc:templateVariables "defaultCodec",
        "defaultOutName",
        "durationInFrames",
        "fps",
        "height",
        "props",
        "width" .

oc:kn_abb21c24 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining calculateMetadata return type" ;
    oc:directiveContent "All fields in the calculateMetadata return value are optional. Returned values override the static props on the <Composition> element." ;
    oc:hasRationale "Understanding the override semantics prevents confusion about which values take priority" ;
    oc:severityLevel "HIGH" .

oc:kn_e6833170 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When fetching external data inside calculateMetadata" ;
    oc:directiveContent "Use abortSignal in fetch calls within calculateMetadata so stale requests are cancelled when props change in the Studio." ;
    oc:hasRationale "Without abortSignal, rapid prop changes in Studio can cause race conditions and unnecessary network traffic" ;
    oc:severityLevel "MEDIUM" .

