    oc:expectedOutcome "Input object configured for probing" ;
    oc:stepDependsOn _:ref_fd4e67c91ef8f1bd ;
    oc:stepId "create-input" .

_:ref_fd4e67c91ef8f1bd a oc:WorkflowStep ;
