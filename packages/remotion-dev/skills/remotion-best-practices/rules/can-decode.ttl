oc:kn_08fed568 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When probing media format metadata" ;
    oc:directiveContent "Wrap getFormat() in try/catch and return false on failure — this gracefully handles network errors, missing files, and unsupported formats." ;
    oc:hasRationale "getFormat() can fail for multiple reasons beyond codec support; catching and returning false provides a safe fallback." .

oc:kn_7648e0ab a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before playing any video or audio in the browser" ;
    oc:directiveContent "Check media decode capability before attempting playback to avoid silent failures or browser errors." ;
    oc:hasRationale "Browsers have varying codec support; decoding failures can cause poor UX if not caught early." ;
    oc:severityLevel "HIGH" .

oc:kn_c838fb99 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using canDecode functionality" ;
    oc:directiveContent "Mediabunny must be installed: run `npx remotion add mediabunny`" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c87063b0 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing media decode validation" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent "Use Input with ALL_FORMATS and UrlSource/BlobSource → call getFormat() to probe → then check videoTrack.canDecode() and audioTrack.canDecode() individually." ;
    oc:hasRationale "Both the container format and individual track codecs must be verified for full compatibility." .

oc:kn_ed3cbecf a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating media compatibility" ;
    oc:directiveContent "Check both video and audio tracks independently — a format may be decodable while individual tracks are not." ;
    oc:hasRationale "Partial decode support (video works but audio doesn't) can still cause playback failures." .

_:ref_6c76cb1fc64f3936 a oc:WorkflowStep ;
