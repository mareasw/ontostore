oc:kn_53e72fe1 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When handling any caption operation" ;
    oc:directiveContent "Caption tasks branch into three sub-workflows: (1) Generating captions → load transcribe-captions.md, (2) Displaying captions → load display-captions.md, (3) Importing from .srt → load import-srt-captions.md." ;
    oc:hasRationale "Each caption task has specialized instructions; loading the correct reference file avoids mistakes and ensures completeness" .

oc:kn_754477d9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing caption processing pipelines" ;
    oc:directiveContent "Caption data is represented as a flat array of Caption objects with start/end timestamps in milliseconds, optional original timestamp, and optional confidence score." ;
    oc:hasRationale "This flat, serializable format works naturally with JSON processing, caching, and React rendering" .

oc:kn_7817a4c8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When working with captions/subtitles in Remotion" ;
    oc:directiveContent "All captions must be processed in JSON using the Caption type from @remotion/captions." ;
    oc:hasRationale "Ensures type safety and consistent caption data structure across all caption operations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7a6821b2 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining or consuming caption data in Remotion" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """import type { Caption } from "@remotion/captions";

type Caption = {
  text: string;
  startMs: number;
  endMs: number;
  timestampMs: number | null;
  confidence: number | null;
};""" ;
    oc:hasRationale "This is the canonical schema for caption data; all caption operations must conform to this type" .

oc:kn_c82faba3 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before working with captions in a Remotion project" ;
    oc:directiveContent "The @remotion/captions package must be available in the project to use the Caption type." ;
    oc:hasRationale "The Caption type is imported from this package; it must be installed" .

