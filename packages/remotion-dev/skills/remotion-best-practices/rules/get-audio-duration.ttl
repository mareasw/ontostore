oc:kn_6b90b0f8 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When consuming the result of getAudioDuration" ;
    oc:directiveContent "Returns a number representing duration in seconds (e.g., 180.5)" ;
    oc:templateVariables "durationInSeconds" .

oc:kn_809e82f1 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "always" ;
    oc:directiveContent "Mediabunny must be installed as a dependency (npm install mediabunny)" .

oc:kn_9db0fb0b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When getting audio duration from a local file in Node.js or Bun" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent "const input = new Input({ formats: ALL_FORMATS, source: new FileSource(file) });" .

oc:kn_a25e2c42 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "always" ;
    oc:directiveContent "computeDuration() is a pure read operation that can be called multiple times without side effects" .

oc:kn_aaa301ed a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Import Input, ALL_FORMATS, and appropriate Source from mediabunny 2. Create Input instance with ALL_FORMATS and UrlSource/FileSource 3. Call input.computeDuration() to get duration in seconds" ;
    oc:stepOrder 1 .

oc:kn_adfb38bf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting the source adapter for audio input" ;
    oc:directiveContent "Use UrlSource for browser/Remotion environments and FileSource for Node.js/Bun environments" ;
    oc:hasRationale "Different runtime environments have different file access APIs; UrlSource works with URLs in browser, FileSource works with File objects server-side" .

oc:kn_df292941 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When getting audio duration from a URL in browser/Remotion" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent "const input = new Input({ formats: ALL_FORMATS, source: new UrlSource(src, { getRetryDelay: () => null }) }); const duration = await input.computeDuration();" .

oc:kn_e3c99559 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using local audio files in a Remotion project" ;
    oc:directiveContent "Always wrap static file paths with staticFile() when referencing local audio files in Remotion" ;
    oc:hasRationale "Remotion serves static files from the public folder; staticFile() resolves the correct URL path" ;
    oc:severityLevel "HIGH" .

