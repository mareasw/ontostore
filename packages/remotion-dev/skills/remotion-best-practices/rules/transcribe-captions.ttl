oc:skill_remotion_dev_skills_remotion_best_practices_transcribe_captions a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "transcribe-captions" ;
    skos:broader "Audio transcription utility" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/remotion-dev/skills/remotion-best-practices" ;
    oc:contentHash "ad1a62af35fe176b37ac4d98f796451ca66bcc9983207a9710ec3eca6e847738" ;
    oc:differentia "uses Whisper.cpp via Remotion to generate timed captions from audio" ;
    oc:extends oc:skill_remotion_dev_skills_remotion_best_practices ;
    oc:handlesFailure oc:FileNotFound,
        oc:ToolNotInstalled ;
    oc:hasArgumentHint "audio file path (WAV format)" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: transcribe-captions
description: Transcribing audio to generate captions in Remotion
metadata:
  tags: captions, transcribe, whisper, audio, speech-to-text
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "To transcribe audio to generate captions in Remotion, you can use the [`transcribe()`](https://www.remotion.dev/docs/install-whisper-cpp/transcribe) function from the [`@remotion/install-whisper-cpp`](https://www.remotion.dev/docs/install-whisper-cpp) package." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """First, the @remotion/install-whisper-cpp package needs to be installed.
If it is not installed, use the following command:""" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """npx remotion add @remotion/install-whisper-cpp
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 17-19" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Prerequisites" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Transcribe each clip individually and create multiple JSON files." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import path from "path";
import {
  downloadWhisperModel,
  installWhisperCpp,
  transcribe,
  toCaptions,
} from "@remotion/install-whisper-cpp";
import fs from "fs";

const to = path.join(process.cwd(), "whisper.cpp");

await installWhisperCpp({
  to,
  version: "1.5.5",
});

await downloadWhisperModel({
  model: "medium.en",
  folder: to,
});

// Convert the audio to a 16KHz wav file first if needed:
// import {execSync} from 'child_process';
// execSync('ffmpeg -i /path/to/audio.mp4 -ar 16000 /path/to/audio.wav -y');

const whisperCppOutput = await transcribe({
  model: "medium.en",
  whisperPath: to,
  whisperCppVersion: "1.5.5",
  inputPath: "/path/to/audio123.wav",
  tokenLevelTimestamps: true,
});

// Optional: Apply our recommended postprocessing
const { captions } = toCaptions({
  whisperCppOutput,
});

// Write it to the public/ folder so it can be fetched from Remotion
fs.writeFileSync("captions123.json", JSON.stringify(captions, null, 2));
""" ;
                            oc:codeLanguage "ts" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 25-66" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Make a Node.js script to download Whisper.cpp and a model, and transcribe the audio." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "See [Displaying captions](display-captions.md) for how to display the captions in Remotion." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Transcribing" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Transcribing audio" ] ;
    oc:impartsKnowledge oc:kn_129b7b75,
        oc:kn_2deff2aa,
        oc:kn_69cfbd89,
        oc:kn_8a4c237d,
        oc:kn_d49cabc9,
        oc:kn_d4e3058c,
        oc:kn_d9309012,
        oc:kn_db579866 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:FileExists,
        oc:ToolInstalled ;
    oc:resolvesIntent "convert speech to timed subtitle data",
        "generate captions from audio for video",
        "transcribe audio to captions" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_129b7b75 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When transcribing multiple audio clips" ;
    oc:directiveContent "Transcribe each clip individually and create separate JSON files per clip rather than one combined file" ;
    oc:hasRationale "Individual caption files map to individual clips for correct timing alignment" ;
    oc:severityLevel "MEDIUM" .

oc:kn_2deff2aa a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "On first run or when changing versions/models" ;
    oc:directiveContent "installWhisperCpp() downloads and compiles the Whisper.cpp binary; downloadWhisperModel() downloads model weights to disk — both consume network and disk space" ;
    oc:hasRationale "These operations are expensive and should be cached or run once, not per transcription" .

oc:kn_69cfbd89 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When selecting a Whisper model" ;
    oc:directiveContent "Whisper.cpp model 'medium.en' is used as the recommended model; larger models increase accuracy but significantly increase processing time" ;
    oc:hasRationale "Model size directly impacts transcription speed vs accuracy tradeoff" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8a4c237d a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before transcribing audio" ;
    oc:directiveContent "Install @remotion/install-whisper-cpp package: npx remotion add @remotion/install-whisper-cpp" ;
    oc:severityLevel "CRITICAL" ;
    oc:stepOrder 1 .

oc:kn_d49cabc9 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Install @remotion/install-whisper-cpp package 2. Install Whisper.cpp binary to local directory 3. Download transcription model (e.g. medium.en) 4. Convert audio to 16KHz WAV if needed 5. Call transcribe() with tokenLevelTimestamps: true 6. Apply toCaptions() postprocessing 7. Write captions JSON to public/ folder" ;
    oc:stepOrder 1 .

oc:kn_d4e3058c a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before calling transcribe()" ;
    oc:directiveContent "Audio must be converted to 16KHz WAV format before transcription (use ffmpeg -i input -ar 16000 output.wav)" ;
    oc:hasRationale "Whisper.cpp requires 16KHz WAV input for accurate transcription" ;
    oc:severityLevel "HIGH" .

oc:kn_d9309012 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After transcription completes" ;
    oc:directiveContent "Use the toCaptions() postprocessing function on raw whisperCppOutput for recommended caption formatting" ;
    oc:hasRationale "Remotion's toCaptions() applies recommended postprocessing for optimal caption display" .

oc:kn_db579866 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up a transcription script" ;
    oc:codeLanguage "typescript" ;
    oc:directiveContent """import { downloadWhisperModel, installWhisperCpp, transcribe, toCaptions } from "@remotion/install-whisper-cpp";

const to = path.join(process.cwd(), "whisper.cpp");
await installWhisperCpp({ to, version: "1.5.5" });
await downloadWhisperModel({ model: "medium.en", folder: to });
const whisperCppOutput = await transcribe({ model: "medium.en", whisperPath: to, whisperCppVersion: "1.5.5", inputPath: "/path/to/audio.wav", tokenLevelTimestamps: true });
const { captions } = toCaptions({ whisperCppOutput });""" ;
    oc:hasRationale "Complete pipeline: install Whisper.cpp → download model → transcribe → postprocess captions" .

