oc:kn_079821c5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sizing or positioning Lottie animations" ;
    oc:directiveContent "Use the `style` prop on <Lottie> to control width, height, and CSS transforms rather than wrapping in extra divs" ;
    oc:hasRationale "The Lottie component natively supports style passthrough, avoiding unnecessary DOM nesting" .

oc:kn_184b8f06 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When adding a Lottie animation to a Remotion composition" ;
    oc:directiveContent "1. Install @remotion/lottie via `npx remotion add @remotion/lottie` 2. Fetch the Lottie JSON asset 3. Wrap loading in delayRender()/continueRender() to prevent premature render 4. Store animation data in state 5. Render using <Lottie animationData={data} />" ;
    oc:hasRationale "Lottie animations are loaded asynchronously; delayRender ensures Remotion waits for the asset before rendering frames" ;
    oc:stepOrder 1 .

oc:kn_5d3121de a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When using remote Lottie URLs" ;
    oc:directiveContent "Fetching Lottie animations triggers network requests; delayRender() blocks the render pipeline until data loads or fails" ;
    oc:hasRationale "Network-dependent assets introduce non-deterministic load times and potential failure modes" .

oc:kn_7c2c4dc0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing the Lottie component" ;
    oc:directiveContent "Do not render the <Lottie> component before animationData is available; return null until data is loaded" ;
    oc:hasRationale "Passing null/undefined as animationData will cause a runtime error; guard with a null check" .

oc:kn_931db441 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Whenever fetching external Lottie JSON assets" ;
    oc:directiveContent "Always wrap Lottie asset fetching with delayRender() and continueRender(); call cancelRender() on fetch failure" ;
    oc:hasRationale "Without delayRender, Remotion may render frames before the animation data is loaded, producing blank or broken output" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e726c137 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When fetching and rendering any async Lottie asset in Remotion" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """const [handle] = useState(() => delayRender("Loading Lottie animation"));
const [animationData, setAnimationData] = useState<LottieAnimationData | null>(null);
useEffect(() => {
  fetch(url).then(r => r.json()).then(json => { setAnimationData(json); continueRender(handle); }).catch(err => cancelRender(err));
}, [handle]);""" .

