oc:kn_16518f5e a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before loading any font" ;
    oc:directiveContent "@remotion/google-fonts or @remotion/fonts package must be installed before loading fonts. Use 'npx remotion add @remotion/google-fonts' or 'npx remotion add @remotion/fonts'." .

oc:kn_18b07179 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between Google Fonts and local fonts" ;
    oc:directiveContent "Google Font loading via @remotion/google-fonts is type-safe and automatically blocks rendering until the font is ready." ;
    oc:hasRationale "Using the recommended package prevents flicker or missing-font frames in rendered video" ;
    oc:severityLevel "HIGH" .

oc:kn_2f6ae677 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Optimized Google Font loading with specific weights and subsets" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """import { loadFont } from "@remotion/google-fonts/Roboto";
const { fontFamily } = loadFont("normal", {
  weights: ["400", "700"],
  subsets: ["latin"],
});""" .

oc:kn_321fb9e7 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Basic Google Font loading pattern" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """import { loadFont } from "@remotion/google-fonts/Lobster";
const { fontFamily } = loadFont();""" .

oc:kn_32c69194 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling loadFont() for Google Fonts" ;
    oc:directiveContent "Do not load all font weights and subsets indiscriminately. Always specify only the weights and subsets you actually use." ;
    oc:hasRationale "Loading unused font variants wastes bandwidth and increases render time" ;
    oc:severityLevel "MEDIUM" .

oc:kn_50a959f6 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When loading local font files with @remotion/fonts" ;
    oc:directiveContent "Local fonts must be placed in the public/ folder and referenced via staticFile(). Direct URL imports will not work during rendering." ;
    oc:hasRationale "Remotion's rendering pipeline requires static assets to be in the public directory for correct resolution in both preview and render modes" ;
    oc:severityLevel "HIGH" .

oc:kn_62f2aba3 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When adding any font to a Remotion project" ;
    oc:directiveContent "1. Install @remotion/google-fonts (or @remotion/fonts for local) 2. Import loadFont from the specific font subpath 3. Call loadFont() with desired weights/subsets 4. Destructure fontFamily from the result 5. Apply fontFamily in CSS/style props" ;
    oc:stepOrder 1 .

oc:kn_6ed2a014 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling loadFont() from @remotion/google-fonts" ;
    oc:directiveContent "Specify only needed weights and subsets when loading Google Fonts to minimize bundle/file size." ;
    oc:hasRationale "Unnecessary weights and subsets increase download time and memory usage during rendering" .

oc:kn_a8aa8914 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring font loading in components" ;
    oc:directiveContent "Call loadFont() at the top level of your component or in a separate file that's imported early, not inside event handlers or conditional blocks." ;
    oc:hasRationale "Top-level loading ensures the font is registered before the component renders, avoiding flash-of-unstyled-text" .

oc:kn_d55a7892 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Loading local font files placed in the public/ directory" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """import { loadFont } from "@remotion/fonts";
import { staticFile } from "remotion";

await loadFont({
  family: "MyFont",
  url: staticFile("MyFont-Regular.woff2"),
});""" .

