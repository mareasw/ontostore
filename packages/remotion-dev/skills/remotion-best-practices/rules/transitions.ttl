        oc:kn_b71b1969,
        oc:kn_d435ced7,
        oc:kn_fc65880c,
        oc:kn_ff723301 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ToolInstalled ;
    oc:resolvesIntent "add overlays at scene cut points",
        "add transitions between video scenes",
        "calculate composition duration with transitions",
        "mix transitions and overlays in a video composition" ;
    oc:yieldsState oc:VideoTransitionConfigured .

oc:kn_06e8f5a6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing timing options for transitions" ;
    oc:directiveContent "Use springTiming for organic, natural-feeling motion and linearTiming for constant-speed, predictable transitions." ;
    oc:hasRationale "Spring timing uses physics-based animation that feels more natural; linear timing offers precise control" ;
    oc:severityLevel "LOW" .

oc:kn_26a4bff2 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When using TransitionSeries.Overlay" ;
    oc:directiveContent "Overlays do NOT affect total composition duration — they render on top of the cut point without shortening the timeline." ;
    oc:hasRationale "Overlays are purely visual effects layered on top; they don't consume timeline frames" ;
    oc:severityLevel "MEDIUM" .

oc:kn_87049bd5 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before any transition or overlay code" ;
    oc:directiveContent "Run `npx remotion add @remotion/transitions` before using TransitionSeries, transition presentations, or timing utilities." ;
    oc:hasRationale "The @remotion/transitions package is a separate dependency from core Remotion" ;
    oc:severityLevel "CRITICAL" .

oc:kn_98fcb151 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding a basic fade transition between two scenes" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """import { TransitionSeries, linearTiming } from "@remotion/transitions";
import { fade } from "@remotion/transitions/fade";

<TransitionSeries>
  <TransitionSeries.Sequence durationInFrames={60}>
    <SceneA />
  </TransitionSeries.Sequence>
  <TransitionSeries.Transition
    presentation={fade()}
    timing={linearTiming({ durationInFrames: 15 })}
  />
  <TransitionSeries.Sequence durationInFrames={60}>
    <SceneB />
  </TransitionSeries.Sequence>
</TransitionSeries>""" .

oc:kn_a717d1b0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using springTiming" ;
    oc:directiveContent "For springTiming without explicit durationInFrames, the duration depends on fps because it calculates when the spring animation settles." ;
    oc:hasRationale "Spring physics are frame-rate dependent; the settling time varies with fps" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b3737f84 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """TransitionSeries composition structure:
[Sequence durationInFrames=N] → [Transition presentation={effect} timing={timing}] → [Sequence durationInFrames=N] → [Overlay durationInFrames=N] → [Sequence durationInFrames=N]

Available presentations: fade(), slide({direction}), wipe(), flip(), clockWipe()
Timing: linearTiming({durationInFrames}), springTiming({config, durationInFrames?})""" ;
    oc:templateVariables "N",
        "direction",
        "effect",
        "timing" .

oc:kn_b71b1969 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating total composition duration" ;
    oc:directiveContent "Transitions shorten the total composition duration because both scenes play simultaneously during the transition overlap." ;
    oc:hasRationale "Each transition's durationInFrames is subtracted from the sum of all sequence durations" ;
    oc:severityLevel "HIGH" .

oc:kn_d435ced7 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building a video with scene transitions" ;
    oc:directiveContent "1. Install @remotion/transitions 2. Import TransitionSeries and desired transition (fade, slide, wipe, flip, clockWipe) 3. Wrap scenes in TransitionSeries.Sequence with durationInFrames 4. Insert TransitionSeries.Transition between sequences with presentation and timing props 5. Optionally add TransitionSeries.Overlay between sequences (not adjacent to transitions) 6. Calculate total duration: sum of sequence durations minus transition durations" ;
    oc:stepOrder 1 .

oc:kn_fc65880c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mixing transitions and overlays in the same TransitionSeries" ;
    oc:directiveContent "An overlay cannot be adjacent to a transition or another overlay within a TransitionSeries." ;
    oc:hasRationale "Adjacent overlays/transitions create conflicting render orders and undefined behavior" ;
    oc:severityLevel "CRITICAL" .

oc:kn_ff723301 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating total composition duration with multiple transitions" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent "const totalDuration = scene1Duration + scene2Duration + scene3Duration - transition1Duration - transition2Duration;" .

