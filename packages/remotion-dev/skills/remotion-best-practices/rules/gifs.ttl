    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "add gif to video composition",
        "control animated image playback speed and looping",
        "display animated images in remotion",
        "get gif duration for composition timing" ;
    oc:yieldsState oc:AnimatedImageDisplayed .

oc:kn_266fb093 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When <AnimatedImage> fails due to browser compatibility" ;
    oc:directiveContent "If <AnimatedImage> is not supported in the target browser, fall back to <Gif> from @remotion/gif which only supports GIF files." ;
    oc:hasRationale "<Gif> provides a narrower but more compatible alternative for GIF-only use cases." ;
    oc:severityLevel "LOW" .

oc:kn_755ccc95 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When rendering compositions with animated images" ;
    oc:directiveContent "<AnimatedImage> is only supported in Chrome and Firefox browsers." ;
    oc:hasRationale "Browser compatibility limits where this component works; use <Gif> from @remotion/gif as a fallback." ;
    oc:severityLevel "HIGH" .

oc:kn_88505710 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using remote image URLs with AnimatedImage" ;
    oc:directiveContent "Remote URLs for animated images must have CORS enabled." ;
    oc:hasRationale "Without CORS headers, the browser will block the cross-origin request and the image will fail to load." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8b09755d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which component to use for animated images" ;
    oc:directiveContent "Do not use <Gif> from @remotion/gif as the primary approach; prefer <AnimatedImage> which supports GIF, APNG, AVIF, and WebP." ;
    oc:hasRationale "<AnimatedImage> is more versatile and supports multiple animated image formats beyond just GIF." ;
    oc:severityLevel "MEDIUM" .

oc:kn_dc023074 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting composition duration for GIF-based content" ;
    oc:directiveContent "Use getGifDurationInSeconds() to dynamically set the composition durationInFrames to match the animated image duration." ;
    oc:hasRationale "Ensures the video timeline matches the animation length, preventing premature cutoff or excessive empty frames." ;
    oc:severityLevel "MEDIUM" .

