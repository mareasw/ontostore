oc:kn_5739ebbb a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When installing any @remotion/* package" ;
    oc:directiveContent "Use `npx remotion add @remotion/<package>` to install Remotion packages rather than direct npm install, as it handles peer dependencies correctly." ;
    oc:hasRationale "The remotion CLI ensures correct version alignment across the Remotion ecosystem" .

oc:kn_64e68a16 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating composition duration with TransitionSeries" ;
    oc:directiveContent "Transitions overlap adjacent scenes, so total composition length equals sum of scene durations minus transition durations. Overlays do NOT affect total duration." ;
    oc:hasRationale "Incorrect duration calculation causes cut-off or extra blank frames at the end of the video" .

oc:kn_6c9727eb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating charts or data visualizations in Remotion" ;
    oc:directiveContent "Disable all animations from third-party chart libraries. Drive all chart animations from useCurrentFrame()." ;
    oc:hasRationale "Third-party library animations are not frame-accurate and will flicker during Remotion's server-side rendering" ;
    oc:severityLevel "HIGH" .

oc:kn_74d8760a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When parameterizing compositions with Zod schemas" ;
    oc:directiveContent "Remotion requires the top-level Zod schema type to be z.object(). Use `type` declarations for props rather than `interface` to ensure defaultProps type safety." ;
    oc:hasRationale "React component props are always objects; using type instead of interface ensures the satisfies operator works correctly with defaultProps" .

oc:kn_7ec463d6 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When using toneFrequency on Audio or Video components" ;
    oc:directiveContent "Pitch shifting via toneFrequency only works during server-side rendering, not in the Remotion Studio preview or in the <Player /> component." ;
    oc:hasRationale "The Web Audio API pitch shifting is only available during Remotion's server-side rendering pipeline" .

oc:kn_89710324 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When animating any element in a Remotion composition" ;
    oc:directiveContent "CSS transitions, CSS animations, and Tailwind animate-* classes are FORBIDDEN — they will not render correctly in Remotion. All animations must be driven by useCurrentFrame()." ;
    oc:hasRationale "Remotion renders frames individually on the server; CSS animations rely on real-time browser timing which is non-deterministic per-frame" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9d361f11 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using <Sequence> to delay elements" ;
    oc:directiveContent "Always premount any <Sequence> using premountFor={1 * fps} to preload components before they appear on the timeline." ;
    oc:hasRationale "Premounting ensures components (especially those with async loading) are ready before their first visible frame" .

oc:kn_a0691d2b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using Sequences with offset timing or audio visualization" ;
    oc:directiveContent "Inside a <Sequence>, useCurrentFrame() returns the local frame starting from 0, not the global composition frame. When passing audioData to child components inside <Sequence>, also pass the parent's frame value." ;
    oc:hasRationale "Local frames prevent frame-offset bugs; passing parent frame to children prevents discontinuous visualization" .

oc:kn_a3d57e2a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When displaying images in a Remotion composition" ;
    oc:directiveContent "Do not use native HTML <img>, Next.js <Image>, or CSS background-image for images. Always use the <Img> component from 'remotion'." ;
    oc:hasRationale "The Remotion <Img> component ensures images are fully loaded before rendering, preventing flickering and blank frames during video export" ;
    oc:severityLevel "CRITICAL" .

oc:kn_bb217031 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any animation timing in Remotion" ;
    oc:directiveContent "Write animation durations in seconds and multiply by the fps value from useVideoConfig(). Use `interpolate()` with `extrapolateLeft: 'clamp'` and `extrapolateRight: 'clamp'` to prevent values from exceeding bounds." ;
    oc:hasRationale "Frame counts vary by FPS; using seconds * fps ensures animations are resolution-independent and clamping prevents unexpected overshoot" .

oc:kn_bc787498 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before installing any Remotion package or dependency" ;
    oc:directiveContent "Detect the project's package manager by searching for lockfiles: package-lock.json (npm), bun.lockb (bun), yarn.lock (yarn), pnpm-lock.yaml (pnpm). Use matching install commands for all Remotion packages." .

oc:kn_be15a167 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using Three.js/React Three Fiber in Remotion" ;
    oc:directiveContent "Using useFrame() from @react-three/fiber is forbidden. All 3D animations must be driven by useCurrentFrame() from 'remotion'." ;
    oc:hasRationale "Self-animating shaders or models cause flickering during rendering because Remotion captures discrete frames" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e0a3a41a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating typewriter text animation effects" ;
    oc:directiveContent "Always use string slicing for typewriter effects. Never use per-character opacity to simulate typing." ;
    oc:hasRationale "String slicing is simpler, more performant, and produces a cleaner visual result than managing individual character opacity states" .

oc:kn_eb3b8611 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When importing any local asset (image, video, audio, font)" ;
    oc:directiveContent "You MUST use staticFile() to reference files from the public/ folder. Never use relative paths directly." ;
    oc:hasRationale "staticFile() returns an encoded URL that works correctly when deploying to subdirectories" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f60dfcd7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing spring animation parameters" ;
    oc:directiveContent "Use spring config { damping: 200 } for smooth no-bounce animations; { damping: 20, stiffness: 200 } for snappy UI; { damping: 8 } for bouncy entrances; { damping: 15, stiffness: 80, mass: 2 } for heavy slow motion." ;
    oc:hasRationale "These presets cover the most common motion design needs and prevent trial-and-error tuning" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fc65880c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mixing transitions and overlays in TransitionSeries" ;
    oc:directiveContent "An overlay cannot be adjacent to a transition or another overlay within a TransitionSeries." ;
    oc:hasRationale "Adjacent overlays/transitions create ambiguous rendering state between scenes" ;
    oc:severityLevel "HIGH" .

