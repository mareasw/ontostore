oc:skill_coreyhaines31_marketingskills_email_sequence a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "email-sequence" ;
    skos:broader "Email marketing skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/email-sequence" ;
    oc:contentHash "1d75060649bed0489004cdbb5261b3ce323dd3fed83a157d2e8115e0e2b77556" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "creates and optimizes multi-email automated sequences (drip campaigns, lifecycle flows, nurture sequences) with structured copy, timing strategy, and conversion-focused design" ;
    oc:handlesFailure oc:ConflictingEmailSchedules,
        oc:InsufficientAudienceContext ;
    oc:hasArgumentHint "sequence type and goal (e.g., 'welcome sequence for SaaS trial users' or 're-engagement for inactive subscribers')\"" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to create or optimize an email sequence, drip campaign, automated email flow, or lifecycle email program. Also use when the user mentions \"email sequence,\" \"drip campaign,\" \"nurture sequence,\" \"onboarding emails,\" \"welcome sequence,\" \"re-engagement emails,\" \"email automation,\" \"lifecycle emails,\" \"trigger-based emails,\" \"email funnel,\" \"email workflow,\" \"what emails should I send,\" \"welcome series,\" or \"email cadence.\" Use this for any multi-email automated flow. For cold outreach emails, see cold-email. For in-app onboarding, see onboarding-cro." ;
    oc:hasName "email-sequence" ;
    oc:hasRequirement oc:req_324fd831,
        oc:req_f138b84f,
        oc:req_f6c95758 ;
    oc:impartsKnowledge oc:kn_23660649,
        oc:kn_95edc676,
        oc:kn_9614f89e,
        oc:kn_c8219478,
        oc:kn_cf1f2298,
        oc:kn_fa163a83 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:ProductMarketingContextAvailable ;
    oc:resolvesIntent "build welcome sequence",
        "create email sequence",
        "create lead nurture sequence",
        "create re-engagement sequence",
        "design drip campaign",
        "design onboarding emails",
        "improve email open rates",
        "optimize email sequence",
        "plan email automation",
        "structure email cadence" ;
    oc:yieldsState oc:EmailCopyGenerated,
        oc:EmailSequenceDesigned,
        oc:SequenceMetricsPlanReady .

oc:kn_23660649 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any email sequence design task" ;
    oc:directiveContent "Check for product-marketing-context.md before asking questions — use existing context and only ask for information not already covered." ;
    oc:hasRationale "Leveraging existing product marketing context avoids redundant questions and ensures sequences are aligned with positioning" ;
    oc:severityLevel "HIGH" .

oc:kn_95edc676 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining sequence order and email content" ;
    oc:directiveContent "Lead with value and usefulness before making any ask — earn the right to sell through trust-building content." ;
    oc:hasRationale "Subscribers who receive value first are significantly more likely to convert when the ask arrives" ;
    oc:severityLevel "HIGH" .

oc:kn_9614f89e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any email in a sequence" ;
    oc:directiveContent "Each email must have exactly one primary purpose and one main CTA — never try to accomplish multiple goals in a single email." ;
    oc:hasRationale "Multiple CTAs dilute focus and reduce click-through rates; subscribers need a single clear path forward" ;
    oc:severityLevel "HIGH" .

oc:kn_c8219478 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating onboarding email sequences for product users" ;
    oc:directiveContent "Never duplicate in-app onboarding content in email sequences — email should support and complement, not repeat what the product already shows." ;
    oc:hasRationale "Duplicating in-app messages creates a disjointed experience and wastes the email channel on redundant information" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cf1f2298 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When writing subject lines for any email" ;
    oc:directiveContent "Subject lines should prioritize clarity over cleverness — clear, specific, benefit-driven subject lines (40-60 characters) consistently outperform vague or witty ones." ;
    oc:hasRationale "Subscribers scan subject lines in fractions of a second; clarity ensures they understand the value proposition immediately" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fa163a83 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing re-engagement or win-back sequences" ;
    oc:directiveContent "Re-engagement sequences must include a sunset policy — non-responders should be removed from the list after the sequence completes to protect sender reputation and deliverability." ;
    oc:hasRationale "Keeping inactive subscribers degrades deliverability metrics and inflates costs without generating revenue" ;
    oc:severityLevel "HIGH" .

oc:req_324fd831 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "Email service provider (Customer.io, Mailchimp, etc.)" .

