oc:kn_0ba8ba59 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting sequence design" ;
    oc:directiveContent "Before creating any sequence, check for product marketing context file (.agents/product-marketing-context.md or .claude/product-marketing-context.md). Read it first and only ask for information not already covered." ;
    oc:hasRationale "Leveraging existing product context ensures consistency and avoids redundant questioning" ;
    oc:severityLevel "HIGH" .

oc:kn_1829fc7b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating onboarding email sequences" ;
    oc:directiveContent "Never duplicate in-app onboarding content in email sequences. Email should support and reinforce in-app flows, not replicate them." ;
    oc:hasRationale "Duplication creates disjointed user experience and wastes the email channel" ;
    oc:severityLevel "HIGH" .

oc:kn_246108d7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any email in a sequence" ;
    oc:directiveContent "One email, one job: each email must have one primary purpose and one main CTA. Don't overload a single email with multiple objectives." ;
    oc:hasRationale "Focused emails have higher engagement and clearer conversion paths" ;
    oc:severityLevel "HIGH" .

oc:kn_391e2a6c a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any email body copy" ;
    oc:directiveContent "Email copy structure: 1. Hook (first line grabs attention) 2. Context (why this matters) 3. Value (useful content) 4. CTA (what to do next) 5. Sign-off (human, warm close). Keep paragraphs 1-3 sentences. Mobile-first. 50-125 words transactional, 150-300 educational, 300-500 story-driven." .

oc:kn_455f1295 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When outputting the final sequence design" ;
    oc:directiveContent "Sequence Overview: Sequence Name, Trigger, Goal, Length, Timing, Exit Conditions. For Each Email: Email number/name, Send timing, Subject line, Preview text, Full body copy, CTA button text + link destination, Segment/Conditions if applicable." ;
    oc:templateVariables "Body",
        "CTA",
        "Exit Conditions",
        "Goal",
        "Length",
        "Preview",
        "Sequence Name",
        "Subject",
        "Timing",
        "Trigger" .

oc:kn_532cc2ad a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sequencing emails across a campaign" ;
    oc:directiveContent "Value before ask: lead with usefulness, build trust through content, earn the right to sell." ;
    oc:hasRationale "Subscribers who receive value first convert at higher rates than those immediately pitched" ;
    oc:severityLevel "HIGH" .

oc:kn_67a5a689 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding sequence length and frequency" ;
    oc:directiveContent "Relevance over volume: fewer, better emails win. Segment for relevance. Quality beats frequency." ;
    oc:hasRationale "Over-emailing leads to unsubscribes and fatigue; targeted relevance drives engagement" ;
    oc:severityLevel "MEDIUM" .

oc:kn_72fbbf22 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any email sequence" ;
    oc:directiveContent "1. Check for product-marketing-context.md and read it. 2. Identify sequence type (welcome, nurture, re-engagement, onboarding, etc.). 3. Clarify audience context (who, trigger, current knowledge). 4. Define primary conversion goal and success metrics. 5. Determine sequence length and timing based on type. 6. Write each email following hook → context → value → CTA → sign-off structure. 7. Apply subject line and preview text strategy. 8. Output in structured format with metrics plan." ;
    oc:stepOrder 1 .

oc:kn_805c9777 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing email copy and CTAs" ;
    oc:directiveContent "Clear path forward: every email must move the recipient somewhere. Links should do something useful and next steps must be obvious." ;
    oc:hasRationale "Emails without clear direction waste attention and lower sequence effectiveness" ;
    oc:severityLevel "MEDIUM" .

oc:kn_96d27f17 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When troubleshooting poor email performance" ;
    oc:directiveContent "Declining open rates may indicate sender reputation issues, list hygiene problems, or subject line fatigue — not just bad subject lines. Diagnose broadly before optimizing narrowly." ;
    oc:hasRationale "Narrow optimization wastes time if the root cause is deliverability or list quality" ;
    oc:severityLevel "HIGH" .

oc:kn_ade8aa1a a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When measuring sequence performance" ;
    oc:directiveContent "Key metrics: Open rate benchmark 20-40%, click rate 2-5%, unsubscribe rate under 0.5%, conversion rate specific to sequence goal, revenue per email if applicable." ;
    oc:hasRationale "These benchmarks provide guardrails for evaluating whether a sequence is performing adequately" .

oc:kn_cb81fd06 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting subject lines and preview text" ;
    oc:directiveContent "Subject line patterns that work: Question ('Still struggling with X?'), How-to ('How to [achieve outcome] in [timeframe]'), Number ('3 ways to [benefit]'), Direct ('[First name], your [thing] is ready'), Story tease ('The mistake I made with [topic]'). Preview text: extends subject line, 90-140 chars, don't repeat subject." .

oc:kn_cc4daef6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting send delays for sequence emails" ;
    oc:directiveContent "Timing guidelines: Welcome email immediately, early sequence 1-2 days apart, nurture 2-4 days apart, long-term weekly/bi-weekly. B2B avoid weekends; B2C test weekends. Send at local time." ;
    oc:hasRationale "Timing affects open rates and engagement; industry patterns provide reliable starting points" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cf465907 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When subscribers are inactive 30-90 days" ;
    oc:directiveContent "For re-engagement sequences: escalate from genuine check-in → value reminder → incentive offer → last chance with clear stay-or-go option. Implement sunset policy to remove non-responders and protect deliverability." ;
    oc:hasRationale "Keeping inactive subscribers harms sender reputation and deliverability for the entire list" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e2f78d76 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning a new sequence" ;
    oc:directiveContent "Sequence length guidelines: Welcome 3-7 emails, Lead nurture 5-10 emails, Onboarding 5-10 emails, Re-engagement 3-5 emails. Length depends on sales cycle, product complexity, and relationship stage." ;
    oc:hasRationale "Overly long sequences cause fatigue; too-short sequences fail to nurture adequately" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ea8fb0e9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing subject lines for any email" ;
    oc:directiveContent "Subject line strategy: clear beats clever, specific beats vague. Use benefit or curiosity-driven patterns. Keep to 40-60 characters. Test emoji cautiously." ;
    oc:hasRationale "Subject lines are the single highest-impact element for open rates" ;
    oc:severityLevel "HIGH" .

