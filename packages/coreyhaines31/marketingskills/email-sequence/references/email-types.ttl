    oc:contentHash "a5dd4f0555a7b21d2ff426948d15657825b9d16265652563f5e272d2e1879bfd" ;
    oc:dependsOnSkill oc:skill_email_sequence ;
    oc:differentia "that catalogs all lifecycle and campaign email types with triggers, goals, sequence structures, copy approaches, and an audit checklist for comprehensive email program coverage" ;
