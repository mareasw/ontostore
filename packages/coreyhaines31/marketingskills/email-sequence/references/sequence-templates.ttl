        oc:SequenceTemplateSelected .

oc:kn_2e1610f0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building re-engagement sequences" ;
    oc:directiveContent "Re-engagement sequences should include an explicit 'last chance' email that gives recipients a clear opt-in/opt-out choice, enabling list hygiene." ;
    oc:hasRationale "Honest unsubscribe options improve deliverability and list health more than retaining disengaged subscribers." .

oc:kn_47a3a62e a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When user hasn't completed onboarding step 1" ;
    oc:directiveContent "If a user hasn't completed the first onboarding step by Day 1, send a targeted help email with a quick tip or video and a clear support option." ;
    oc:hasRationale "Early intervention at the first drop-off point recovers the highest percentage of users." .

oc:kn_67e5c70e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing pre-sale lead nurture sequences" ;
    oc:directiveContent "Lead nurture sequences must be educational first, salesy last: front-load expertise and value, build preference through differentiation, then close with a direct offer." ;
    oc:hasRationale "Premature selling erodes trust; establishing expertise before the ask increases conversion by positioning the brand as an authority." .

oc:kn_683726fd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any sequence email" ;
    oc:directiveContent "Each email in a sequence must have exactly one clear purpose and one primary CTA — never bundle multiple asks into a single email." ;
    oc:hasRationale "Single-focus emails dramatically outperform multi-purpose emails in click-through and conversion rates." .

oc:kn_afe148cb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating onboarding sequences for product users" ;
    oc:directiveContent "Do NOT duplicate in-app onboarding content in email. Onboarding emails should support and complement the in-app experience, not repeat it." ;
    oc:hasRationale "Duplicating content wastes attention and signals the brand doesn't coordinate channels, reducing trust." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b45d0e09 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning sequence timing and cadence" ;
    oc:directiveContent "Sequence timing should follow a compressed early cadence (daily for first 3-5 days) then taper to wider spacing (2-3 days). Urgency/offer emails come at the end." ;
    oc:hasRationale "Early engagement is highest; tapering prevents unsubscribes while maintaining presence through the decision window." .

oc:kn_caeb64a7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building welcome/post-signup sequences" ;
    oc:directiveContent "Welcome sequences should deliver what was promised immediately (lead magnet, access), provide a quick win within 48 hours, then build to a conversion ask by day 12-14." ;
    oc:hasRationale "Delivering promised value first builds trust; quick wins create momentum toward the conversion ask." .

