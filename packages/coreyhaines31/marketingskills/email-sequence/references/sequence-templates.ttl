@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_email_sequence_sequence_templates a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "sequence-templates" ;
    skos:broader "Template library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/email-sequence" ;
    oc:contentHash "d47b12e263ad52b72ab741c490bbc98d8bf8034d61faccc50b7dbb2650a9fba0" ;
    oc:differentia "provides ready-made email copy frameworks for four common lifecycle sequences (welcome, lead nurture, re-engagement, onboarding) with timing, subject lines, and structural guidance per email" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_email_sequence ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "sequence_type (welcome|lead-nurture|re-engagement|onboarding)" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_23999016,
        oc:kn_48822397,
        oc:kn_61cc25a4,
        oc:kn_b107a413,
        oc:kn_c59e054e ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:AudienceIdentified,
        oc:EmailPlatformReady ;
    oc:resolvesIntent "create lead nurture email sequence",
        "create onboarding email sequence",
        "create re-engagement email sequence",
        "create welcome email sequence",
        "get email sequence templates",
        "plan email sequence structure and timing" ;
    oc:yieldsState oc:EmailSequenceDrafted .

oc:kn_23999016 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating product onboarding sequences" ;
    oc:directiveContent "Onboarding emails must coordinate with in-app onboarding flows — email should support and reinforce, not duplicate, what the user sees in the product." ;
    oc:hasRationale "Duplicating in-app messaging creates redundancy and annoyance; coordinated sequencing reinforces learning and drives deeper engagement." ;
    oc:severityLevel "HIGH" .

oc:kn_48822397 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any email sequence" ;
    oc:directiveContent "Each email in a sequence should have a single, clear purpose — deliver value, build trust, or drive action — rather than trying to accomplish multiple goals at once." ;
    oc:hasRationale "Single-purpose emails keep the reader focused and make the next action obvious, which improves click-through and conversion rates." ;
    oc:severityLevel "HIGH" .

oc:kn_61cc25a4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the first email in any opt-in sequence" ;
    oc:directiveContent "Never skip the 'deliver what was promised' step in Email 1 of welcome or lead nurture sequences. Opening with a pitch instead of value delivery breaks trust immediately." ;
    oc:hasRationale "The first email sets the tone for the entire relationship; failing to deliver the promised value (lead magnet, access, etc.) signals bad faith and drives unsubscribes." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b107a413 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining sequence length and cadence" ;
    oc:directiveContent "Welcome sequences should span 12-14 days with 7 emails; lead nurture sequences 19-21 days with 8 emails; re-engagement sequences 10-14 days with 4 emails." ;
    oc:hasRationale "These timings balance sustained engagement against unsubscribe fatigue, and are calibrated to the specific intent of each sequence type." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c59e054e a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When structuring any multi-email sequence" ;
    oc:directiveContent "Follow the escalation pattern across each sequence: start with immediate delivery/value, build trust through stories and proof, address objections, then close with a direct offer or CTA." ;
    oc:hasRationale "This psychological progression (deliver → educate → prove → overcome → convert) mirrors how trust is built over time and matches buyer readiness stages." ;
    oc:severityLevel "MEDIUM" .

