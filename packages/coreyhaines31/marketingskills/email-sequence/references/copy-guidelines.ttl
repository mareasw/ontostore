oc:kn_20e2958b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining email length" ;
    oc:directiveContent "Target 50-125 words for transactional emails, 150-300 for educational, 300-500 for story-driven. Shorter is usually better." ;
    oc:hasRationale "Word count targets prevent overwriting; longer emails only work if the content justifies the length." ;
    oc:severityLevel "MEDIUM" .

oc:kn_75a3aa73 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When personalizing email content" ;
    oc:directiveContent "Use merge fields with fallbacks (e.g., first name fallback to 'there' or 'friend'), and leverage dynamic content based on segment, behavior, and stage." ;
    oc:hasRationale "Broken merge fields destroy trust; fallbacks prevent awkward personalization failures." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8144204d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running email optimization tests" ;
    oc:directiveContent "Always A/B test one variable at a time with sufficient sample size and statistical significance. Document learnings." ;
    oc:hasRationale "Testing multiple variables simultaneously produces unreliable results; documented learnings build institutional knowledge." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bfca105b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When measuring email sequence performance" ;
    oc:directiveContent "Target open rate 20-40%, click rate 2-5%, unsubscribe rate under 0.5%. Track conversion rate and revenue per email for sequence-specific goals." ;
    oc:hasRationale "Benchmarks provide objective criteria for evaluating whether copy changes improved or hurt performance." ;
    oc:severityLevel "LOW" .

oc:kn_c139629f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing email CTAs" ;
    oc:directiveContent "Keep one clear primary CTA per email. Use buttons for primary actions and in-text links for secondary actions." ;
    oc:hasRationale "Multiple competing CTAs dilute click-through rates and confuse the reader." ;
    oc:severityLevel "HIGH" .

oc:kn_c37c5aeb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting email copy" ;
    oc:directiveContent "Avoid long paragraphs, formal tone, and passive voice. Never write emails that don't sound human when read aloud." ;
    oc:hasRationale "Emails are read on mobile first; dense blocks get skipped. Conversational, active-voice copy performs better." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cda0d354 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before sending or scheduling any email" ;
    oc:directiveContent "Verify merge field fallbacks are set, primary CTA is singular and clear, and copy reads naturally when spoken aloud." ;
    oc:hasRationale "These checks catch the most common email copy failures before they reach subscribers." ;
    oc:severityLevel "HIGH" .

oc:kn_fb885c4a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any email in a sequence" ;
    oc:directiveContent "Follow the Hook → Context → Value → CTA → Sign-off structure for every email." ;
    oc:hasRationale "This 5-part structure ensures emails grab attention, provide relevance, deliver value, and drive action." ;
    oc:severityLevel "HIGH" .

