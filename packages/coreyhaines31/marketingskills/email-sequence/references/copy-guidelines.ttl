oc:skill_coreyhaines31_marketingskills_email_sequence_copy_guidelines a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "copy-guidelines" ;
    skos:broader "Style guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/email-sequence" ;
    oc:contentHash "02f08897e4aa99ecc4ec1893d61d0c26d0c5e62e09af26f175087455e9b68e01" ;
    oc:differentia "that codifies email copywriting structure, tone, formatting, personalization, segmentation, and testing standards for email sequences" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_email_sequence ;
    oc:hasCategory "marketing" ;
    oc:hasRequirement oc:req_5672a201,
        oc:req_701f564a ;
    oc:impartsKnowledge oc:kn_0785d102,
        oc:kn_3ceb4dc9,
        oc:kn_811ee707,
        oc:kn_8fa2a685,
        oc:kn_92e61789,
        oc:kn_981cfe75,
        oc:kn_ab5fc676,
        oc:kn_c457c4ab ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:SequencePlanned ;
    oc:resolvesIntent "apply personalization and segmentation strategies to email sequences",
        "design CTAs that drive conversions in email sequences",
        "format email copy for mobile-first readability",
        "optimize email copy through testing and metrics tracking",
        "write email copy that follows proven structure and tone" ;
    oc:yieldsState oc:CopyGuidelinesApplied .

oc:kn_0785d102 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing personalization and segmentation in email sequences" ;
    oc:directiveContent "Use merge fields with fallbacks (e.g., first name with fallback to 'there' or 'friend'), and leverage dynamic content based on segment, behavior, and stage. Prefer action-based triggered emails over time-based sends." ;
    oc:hasRationale "Behavioral triggers and dynamic personalization dramatically increase relevance, which drives higher open and click rates" ;
    oc:severityLevel "HIGH" .

oc:kn_3ceb4dc9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting tone and voice for email copy" ;
    oc:directiveContent "Never write formal, stiff, or corporate-sounding email copy. Use conversational tone, first-person (I/we) and second-person (you), active voice. Read it aloud to verify it sounds human." ;
    oc:hasRationale "Formal tone creates distance between sender and reader; conversational copy builds trust and feels personal" ;
    oc:severityLevel "MEDIUM" .

oc:kn_811ee707 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When placing calls-to-action in email copy" ;
    oc:directiveContent "Always include exactly one clear primary CTA per email. Use buttons for primary actions and in-text links for secondary actions. Button text must combine action + outcome." ;
    oc:hasRationale "Multiple competing CTAs dilute focus and reduce click-through rates; a single clear CTA maximizes conversion" ;
    oc:severityLevel "HIGH" .

oc:kn_8fa2a685 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When measuring email sequence performance" ;
    oc:directiveContent "Track these benchmarks: open rate 20-40%, click rate 2-5%, unsubscribe rate under 0.5%, plus conversion rate and revenue per email specific to sequence goals." ;
    oc:hasRationale "Benchmarks provide objective criteria for evaluating whether copy changes improved or hurt performance" ;
    oc:severityLevel "MEDIUM" .

oc:kn_92e61789 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining email length for any sequence email" ;
    oc:directiveContent "Keep emails short: 50-125 words for transactional, 150-300 for educational, 300-500 for story-driven. If going long, the content must be exceptionally compelling." ;
    oc:hasRationale "Shorter emails respect reader attention and drive higher engagement; mobile readers especially skim" ;
    oc:severityLevel "MEDIUM" .

oc:kn_981cfe75 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When optimizing email copy performance" ;
    oc:directiveContent "A/B test one variable at a time with sufficient sample size and statistical significance. Always document learnings. Prioritize subject line testing as highest-impact variable." ;
    oc:hasRationale "Isolating variables ensures valid conclusions; subject lines have the largest single impact on open rates" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ab5fc676 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any email in a sequence" ;
    oc:directiveContent "Follow the Hook → Context → Value → CTA → Sign-off structure for every email. This five-part structure ensures each email grabs attention, explains relevance, delivers value, drives action, and closes warmly." ;
    oc:hasRationale "Consistent structure creates reader expectations and maximizes conversion at every touchpoint" ;
    oc:severityLevel "HIGH" .

oc:kn_c457c4ab a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before finalizing any email copy" ;
    oc:directiveContent "Format for mobile-first: short paragraphs (1-3 sentences), white space between sections, bullet points for scanability, bold for emphasis (sparingly)." ;
    oc:hasRationale "Most emails are read on mobile devices; poor mobile formatting leads to immediate deletion" ;
    oc:severityLevel "HIGH" .

oc:req_5672a201 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of email marketing fundamentals" .

oc:req_701f564a a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Familiarity with A/B testing methodology" .

