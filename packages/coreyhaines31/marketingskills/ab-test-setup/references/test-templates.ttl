        oc:kn_e7ed4632 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:ExperimentPlanned ;
    oc:resolvesIntent "communicate test status to stakeholders",
        "document a/b test plans",
        "maintain a test repository",
        "prioritize experiment ideas",
        "record experiment results" ;
    oc:yieldsState oc:ResultsRecorded,
        oc:TestDocumented .

oc:kn_1afc9d53 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting or communicating results" ;
    oc:directiveContent "Never declare a test result without reporting statistical significance (p-value) and practical significance (business impact) together." ;
    oc:hasRationale "Statistical significance alone can be misleading if the effect size is too small to matter practically" ;
    oc:severityLevel "HIGH" .

oc:kn_286c3bda a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing test metrics" ;
    oc:directiveContent "Always define guardrail metrics alongside primary and secondary metrics to catch unintended negative effects." ;
    oc:hasRationale "Optimizing one metric can degrade others; guardrails protect overall business health" ;
    oc:severityLevel "MEDIUM" .

oc:kn_62f70096 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "When recording test results" ;
    oc:directiveContent "After test completion, always document: what happened, why it happened, caveats/limitations, decision, learnings, and follow-up test ideas." ;
    oc:hasRationale "Capturing institutional knowledge prevents repeating failed tests and builds cumulative learning" ;
    oc:severityLevel "MEDIUM" .

oc:kn_716cdfe3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning any A/B test" ;
    oc:directiveContent "Every A/B test must have a documented hypothesis using the format: Because [observation], we believe [change] will cause [outcome] for [audience]. We'll know this is true when [metrics]." ;
    oc:hasRationale "Forces data-driven reasoning and prevents testing random ideas without justification" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9a8dfd21 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When running any A/B test experiment end-to-end" ;
    oc:directiveContent "1. Document hypothesis using structured format → 2. Define primary, secondary, and guardrail metrics → 3. Calculate sample size and duration → 4. Fill pre-launch checklist → 5. Run experiment → 6. Record results with statistical and practical significance → 7. Add entry to test repository → 8. Communicate learnings and next tests" ;
    oc:stepOrder 1 .

oc:kn_aba30946 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before launching an A/B test" ;
    oc:directiveContent "Before launching any test, verify: hypothesis documented, primary metric trackable, sample size calculated, test duration estimated, variants QA'd, tracking verified, stakeholders informed." ;
    oc:hasRationale "Incomplete test setup wastes traffic and produces unreliable results" ;
    oc:severityLevel "HIGH" .

oc:kn_b3d45d73 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When starting documentation for a new test" ;
    oc:directiveContent "Match the template to test complexity: use Quick Test Brief for simple tests, full Test Plan for complex experiments." ;
    oc:hasRationale "Right-sizing documentation effort avoids bureaucracy for trivial tests while ensuring rigor for important ones" ;
    oc:severityLevel "LOW" .

oc:kn_e7ed4632 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which experiments to run" ;
    oc:directiveContent "Use the prioritization scorecard (impact 30%, confidence 25%, ease 20%, risk 15%, alignment 10%) to rank tests before committing resources." ;
    oc:hasRationale "Prevents low-value tests from consuming traffic and team time" ;
    oc:severityLevel "MEDIUM" .

