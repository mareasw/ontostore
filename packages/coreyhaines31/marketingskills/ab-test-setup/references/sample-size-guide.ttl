_:ref_e8d1b7e1c69f96f6 a oc:WorkflowStep ;
    dcterms:description "**Reduce variants**: Test only the most promising variant" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_f0dacf1f7ee623e9 a oc:WorkflowStep ;
    dcterms:description "**Don't test**: Make decision based on qualitative data instead" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_fa388171ba444fdb a oc:WorkflowStep ;
