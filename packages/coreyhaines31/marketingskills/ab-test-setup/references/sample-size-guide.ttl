_:ref_a595aa66ba54b60f a oc:WorkflowStep ;
    dcterms:description "**Test upstream**: Test earlier in funnel where traffic is higher" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_b09a2290c04837b2 a oc:WorkflowStep ;
    dcterms:description "**Statistical power**: Usually 80% (β = 0.20)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_b16a5fb2af6a8a73 a oc:WorkflowStep ;
