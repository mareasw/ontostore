            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Evaluate: <7 days = easy (extend to 14), <14 days = feasible, <30 days = acceptable for high-impact, >30 days = consider alternatives, >60 days = strongly consider alternatives" ;
                    oc:expectedOutcome "Go/no-go decision on test feasibility" ;
                    oc:stepId "assess-feasibility" ],
