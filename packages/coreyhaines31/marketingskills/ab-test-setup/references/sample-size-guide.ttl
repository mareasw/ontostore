_:ref_d8ce7fb01928ddab a oc:WorkflowStep ;
    dcterms:description "**Increase MDE**: Accept only detecting larger effects (20%+ lift)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_e549534b71d7b49f a oc:WorkflowStep ;
