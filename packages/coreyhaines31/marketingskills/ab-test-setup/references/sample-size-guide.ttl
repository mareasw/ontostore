@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_ab_test_setup_sample_size_guide a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "sample-size-guide" ;
    skos:broader "Statistical reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/ab-test-setup" ;
    oc:contentHash "96aef9d20c4607662beb924fa31260dee4c0db0c1dd6b607cdb3c4c701f9efd2" ;
    oc:differentia "that provides sample size calculation tables, duration formulas, and decision frameworks for A/B testing experiments" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_ab_test_setup ;
    oc:handlesFailure oc:InsufficientTraffic,
        oc:InvalidInput ;
    oc:hasArgumentHint "baseline conversion rate and minimum detectable effect" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_427a5342,
        oc:kn_6ed0a0f0,
        oc:kn_818462e2,
        oc:kn_ccd107ea,
        oc:kn_d7c33616,
        oc:kn_ddffc3ea ;
    oc:isUserInvocable true ;
    oc:nature "Reference" ;
    oc:requiresState oc:BaselineMetricsKnown ;
    oc:resolvesIntent "adjust sample size for multiple variants",
        "avoid common sample size mistakes",
        "calculate sample size for A/B test",
        "determine if enough traffic exists to run a test",
        "estimate test duration" ;
    oc:yieldsState oc:SampleSizeCalculated,
        oc:TestDurationEstimated,
        oc:TestFeasibilityAssessed .

oc:kn_427a5342 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating test duration, even if sample size is reached earlier" ;
    oc:directiveContent "Run A/B tests for at least 1 full week to capture day-of-week variation, 2 business cycles for B2B, and through paydays for e-commerce." ;
    oc:hasRationale "Daily and cyclical variation in user behavior can skew results if the test doesn't cover a full representative period." ;
    oc:severityLevel "HIGH" .

oc:kn_6ed0a0f0 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When calculated duration exceeds 60 days or required traffic exceeds available traffic" ;
    oc:directiveContent "When sample size requirements are too high, consider: increasing MDE to 20%+ lifts, reducing variants, combining traffic across similar pages, testing upstream in the funnel, or relying on qualitative data instead." ;
    oc:hasRationale "Low-traffic pages can still generate insights through alternative approaches rather than running underpowered or excessively long tests." ;
    oc:severityLevel "MEDIUM" .

oc:kn_818462e2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning A/B tests with segment analysis" ;
    oc:directiveContent "If you plan to analyze segments (e.g., mobile vs desktop), calculate sample size for the smallest segment you care about, not total traffic." ;
    oc:hasRationale "Segment-level analysis requires each segment to individually meet sample size thresholds; total traffic may be sufficient while segments are underpowered." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ccd107ea a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining baseline conversion rate for sample size calculation" ;
    oc:directiveContent "Never calculate sample size using site-wide average conversion rates; always use the specific metric and page being tested." ;
    oc:hasRationale "Site-wide averages dilute or inflate the actual page-level conversion rate, leading to dramatically wrong sample size estimates." ;
    oc:severityLevel "HIGH" .

oc:kn_d7c33616 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before committing to any A/B test execution" ;
    oc:directiveContent "Before running a test, confirm: daily traffic to page, baseline conversion rate for that specific page, MDE worth detecting, and that duration falls within feasible range (ideally < 30 days, max 60 days)." ;
    oc:hasRationale "Pre-test feasibility assessment prevents wasted engineering effort on tests that cannot reach statistical significance." ;
    oc:severityLevel "HIGH" .

oc:kn_ddffc3ea a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating test feasibility and duration estimates" ;
    oc:directiveContent "Avoid running tests longer than 4-8 weeks due to novelty effects wearing off, external factors intervening, and the opportunity cost of other tests." ;
    oc:hasRationale "Extended test durations introduce confounding variables and block the testing pipeline, reducing overall experimentation throughput." ;
    oc:severityLevel "MEDIUM" .

