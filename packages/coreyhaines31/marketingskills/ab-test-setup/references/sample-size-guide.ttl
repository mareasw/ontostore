                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Through paydays**: If e-commerce (beginning/end of month)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**2 business cycles**: If B2B (weekday vs. weekend patterns)" ] ] ;
