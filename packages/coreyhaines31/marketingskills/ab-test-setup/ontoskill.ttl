oc:skill_coreyhaines31_marketingskills_ab_test_setup a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ab-test-setup" ;
    skos:broader "experimentation methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/ab-test-setup" ;
    oc:contentHash "87df829239576297a417b2683c14fee97f48cfc38ce225be806f7a70e8a77712" ;
    oc:differentia "that guides the design, execution, and analysis of A/B tests with statistical rigor to produce actionable business decisions" ;
    oc:handlesFailure oc:InsufficientTraffic,
        oc:InvalidInput,
        oc:StatisticalInconclusive ;
    oc:hasAlias "ab test",
        "experiment design",
        "multivariate test",
        "split test" ;
    oc:hasAllowedTool "Glob",
        "Read",
        "Write" ;
    oc:hasArgumentHint "test description, current conversion rate, traffic volume, and change being considered" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to plan, design, or implement an A/B test or experiment. Also use when the user mentions \"A/B test,\" \"split test,\" \"experiment,\" \"test this change,\" \"variant copy,\" \"multivariate test,\" \"hypothesis,\" \"should I test this,\" \"which version is better,\" \"test two versions,\" \"statistical significance,\" or \"how long should I run this test.\" Use this whenever someone is comparing two approaches and wants to measure which performs better. For tracking implementation, see analytics-tracking. For page-level conversion optimization, see page-cro." ;
    oc:hasName "ab-test-setup" ;
    oc:impartsKnowledge oc:kn_012dc648,
        oc:kn_12367f15,
        oc:kn_346d036e,
        oc:kn_91fc5537,
        oc:kn_bf37f80e,
        oc:kn_c6254852,
        oc:kn_c9094698 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "analyze A/B test results for statistical significance",
        "calculate sample size for experiments",
        "design A/B test experiments",
        "determine test duration and traffic requirements",
        "plan split tests with proper hypothesis",
        "structure test documentation and tracking" ;
    oc:yieldsState oc:ExperimentDesigned,
        oc:TestPlanDocumented .

oc:kn_012dc648 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When sample size calculations show the test would take longer than 60 days to complete" ;
    oc:directiveContent "When traffic is insufficient for the desired test: increase the minimum detectable effect (accept detecting only larger lifts), reduce number of variants, combine traffic across similar pages, test upstream in the funnel where traffic is higher, or make decisions based on qualitative data instead." ;
    oc:hasRationale "Many marketing pages lack the traffic for statistically rigorous testing. Having predefined alternatives prevents paralysis or running underpowered tests that waste time." ;
    oc:severityLevel "MEDIUM" .

oc:kn_12367f15 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting metrics and calculating sample size for any experiment" ;
    oc:directiveContent "Use a three-tier metrics framework: one primary metric tied directly to the hypothesis, secondary metrics for context and explanation, and guardrail metrics to prevent harm. Pre-determine sample size using baseline rate and minimum detectable effect before launching." ;
    oc:hasRationale "This tiered approach ensures tests measure what matters, can explain why results occurred, and prevent unintended negative consequences on other parts of the business." ;
    oc:severityLevel "MEDIUM" .

oc:kn_346d036e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Immediately before launching any A/B test" ;
    oc:directiveContent "Before launching, verify: hypothesis documented, primary metric defined and trackable, sample size calculated, variants implemented and QA'd, tracking verified on all variants, and test duration estimated. Also check for product-marketing-context.md to avoid asking redundant questions." ;
    oc:hasRationale "Skipping pre-launch checks is the primary cause of wasted test runs where data is unreliable or uncollectable, requiring the test to be restarted." ;
    oc:severityLevel "HIGH" .

oc:kn_91fc5537 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before designing any A/B test experiment" ;
    oc:directiveContent "Always start with a structured hypothesis: 'Because [observation/data], we believe [change] will cause [expected outcome] for [audience]. We'll know this is true when [metrics].' Test one variable at a time to isolate causation." ;
    oc:hasRationale "A clear hypothesis ensures tests are purposeful, measurable, and produce learnings even when the variant loses. Single-variable testing enables clear attribution of cause and effect." ;
    oc:severityLevel "HIGH" .

oc:kn_bf37f80e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user requests testing multiple elements simultaneously" ;
    oc:directiveContent "MVT (Multivariate Testing) requires combinatorially more traffic than A/B tests (e.g., 2 headlines × 2 images × 2 CTAs = 8 combinations). Each additional variant multiplies sample size requirements by ~1.5x." ;
    oc:hasRationale "Most sites lack sufficient traffic for MVT. Without adequate sample, tests run for months or produce inconclusive results, wasting time and opportunity cost." ;
    oc:severityLevel "HIGH" .

oc:kn_c6254852 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining test duration after calculating sample size" ;
    oc:directiveContent "Run tests for at least 1 full week to capture day-of-week variation, 2 business cycles for B2B, and through paydays for e-commerce. Avoid running tests longer than 4-8 weeks due to novelty effects and external factor drift." ;
    oc:hasRationale "Even with sufficient sample, too-short tests miss cyclical patterns and too-long tests suffer from novelty effects wearing off and external confounders." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c9094698 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When monitoring or analyzing an actively running A/B test" ;
    oc:directiveContent "Never stop an A/B test early by peeking at results before reaching the predetermined sample size. Early significance is misleading due to regression to the mean, day-of-week effects, and audience mix shifts, which inflates false positive rates." ;
    oc:hasRationale "The peeking problem is the single most common cause of invalid experiment conclusions. Stopping early because results look promising leads to shipping changes that may actually hurt performance." ;
    oc:severityLevel "CRITICAL" .

