oc:kn_0aa61a93 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When analyzing test results" ;
    oc:directiveContent "A valid test reaches pre-calculated sample size, shows 95% statistical significance, and produces effect size large enough to be practically meaningful." ;
    oc:hasRationale "All three conditions must be met for reliable, actionable decision-making" .

oc:kn_50c5fb35 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing test variants" ;
    oc:directiveContent "Test one variable at a time. Multiple simultaneous changes make it impossible to isolate what caused the effect." ;
    oc:hasRationale "Without isolation, you cannot attribute results to specific changes and cannot generate reliable learnings" ;
    oc:severityLevel "HIGH" .

oc:kn_82b6091f a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When considering multivariate testing" ;
    oc:directiveContent "MVT tests require very high traffic because combinations multiply (e.g., 2×2×2 = 8 variants). Sequential A/B tests are usually more practical." ;
    oc:hasRationale "Most pages lack traffic for meaningful MVT results; sequential A/B tests achieve similar insights faster" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8688c04c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before launching any test" ;
    oc:directiveContent "Pre-determine sample size before launching and commit to running the test until that sample is reached." ;
    oc:hasRationale "Pre-commitment prevents confirmation bias and ensures statistical validity of results" ;
    oc:severityLevel "HIGH" .

oc:kn_883d1372 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting metrics for any test" ;
    oc:directiveContent "Use three metric tiers: one primary metric (calls the test), secondary metrics (explain why), and guardrail metrics (prevent harm)." ;
    oc:hasRationale "Multiple metric tiers ensure business value is measured while protecting against unintended negative consequences" ;
    oc:severityLevel "HIGH" .

oc:kn_8d27a13e a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When traffic is insufficient for desired test sensitivity" ;
    oc:directiveContent "When sample size requirements are too high: increase MDE, reduce variants, test upstream in the funnel, or rely on qualitative data instead." ;
    oc:hasRationale "Low-traffic pages can still produce insights through alternative approaches rather than running underpowered tests" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cc7cfc1a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During test execution, always" ;
    oc:directiveContent "Never peek at results before reaching pre-calculated sample size and stop early. This inflates false positive rates and leads to wrong decisions." ;
    oc:hasRationale "Early significance is often misleading due to regression to the mean, day-of-week effects, and audience mix shifts" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e0de67df a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calculating test duration" ;
    oc:directiveContent "Even with sufficient sample size reached early, run tests for at least 1 full week to capture day-of-week variation, and 2 business cycles for B2B." ;
    oc:hasRationale "Traffic quality and behavior vary by day and time; shorter tests may capture unrepresentative samples" ;
    oc:severityLevel "MEDIUM" .

oc:req_54f15bbd a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Understanding of statistical significance, p-values, and confidence intervals" .

oc:req_e7e58f21 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Familiarity with testing tools (PostHog, Optimizely, VWO, LaunchDarkly)" .

