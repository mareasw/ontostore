oc:skill_coreyhaines31_marketingskills_form_cro a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "form-cro" ;
    skos:broader "Conversion Rate Optimization skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/form-cro" ;
    oc:contentHash "00b350c84359332b14b5dc3a28afada9dee56bb98d990d6f8dae1814a64fd661" ;
    oc:contradicts oc:skill_popup_cro,
        oc:skill_signup_flow_cro ;
    oc:differentia "Specializes in maximizing completion rates for non-signup forms through field reduction, layout optimization, error handling, and mobile UX" ;
    oc:extends oc:skill_page_cro ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "Edit",
        "Read",
        "Write" ;
    oc:hasArgumentHint "form URL or description of current form (type, fields, completion rate)" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to optimize any form that is NOT signup/registration — including lead capture forms, contact forms, demo request forms, application forms, survey forms, or checkout forms. Also use when the user mentions \"form optimization,\" \"lead form conversions,\" \"form friction,\" \"form fields,\" \"form completion rate,\" \"contact form,\" \"nobody fills out our form,\" \"form abandonment,\" \"too many fields,\" \"demo request form,\" or \"lead form isn't converting.\" Use this for any non-signup form that captures information. For signup/registration forms, see signup-flow-cro. For popups containing forms, see popup-cro." ;
    oc:hasName "form-cro" ;
    oc:hasRequirement oc:req_0c1f1ef6,
        oc:req_4968c2c8,
        oc:req_a46d8eb1 ;
    oc:impartsKnowledge oc:kn_192c9f83,
        oc:kn_6517d015,
        oc:kn_674a87c9,
        oc:kn_6ac772a0,
        oc:kn_7674b0c3,
        oc:kn_89b76fb9,
        oc:kn_ac911b9d,
        oc:kn_ee97e576 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:NetworkAvailable ;
    oc:resolvesIntent "audit form for conversion issues",
        "choose single-step vs multi-step form",
        "design high-converting form layout",
        "handle form validation errors",
        "improve mobile form experience",
        "optimize form conversion rate",
        "optimize form fields and order",
        "optimize form submit button",
        "reduce form abandonment" ;
    oc:yieldsState oc:FormAuditComplete .

oc:kn_192c9f83 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When auditing or designing any form" ;
    oc:directiveContent "Every field has a cost — 3 fields is baseline, 4-6 fields reduces completion 10-25%, 7+ fields reduces completion 25-50%+. For each field, ask if it's absolutely necessary, if the data can be obtained another way, or if it can be asked later." ;
    oc:hasRationale "Field count is the single strongest predictor of form abandonment; each additional field exponentially increases cognitive load and physical effort" ;
    oc:severityLevel "CRITICAL" .

oc:kn_6517d015 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing the submit/CTA button" ;
    oc:directiveContent "Submit button copy should follow the pattern '[Action] + [What they get]' (e.g., 'Get My Free Quote', 'Download the Guide') instead of generic labels like 'Submit' or 'Send'. Place the button immediately after the last field, left-aligned, with high contrast." ;
    oc:hasRationale "Specific, benefit-oriented button text sets clear expectations and reinforces the value exchange, significantly increasing click-through rates" ;
    oc:severityLevel "MEDIUM" .

oc:kn_674a87c9 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When designing form field labels and placeholders" ;
    oc:directiveContent "Use labels that remain visible at all times — never rely solely on placeholder text since it disappears when the user starts typing. Placeholders should only show examples, not act as labels." ;
    oc:hasRationale "Placeholder-only labels disappear on focus, leaving users confused about what field they're filling in, increasing errors and abandonment" ;
    oc:severityLevel "HIGH" .

oc:kn_6ac772a0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing form validation and error handling" ;
    oc:directiveContent "Never validate too aggressively while the user is still typing, never clear form data on error, and never show generic error messages like 'Invalid input'. Always provide specific, actionable error messages positioned near the relevant field." ;
    oc:hasRationale "Aggressive inline validation frustrates users, clearing data forces re-entry, and generic errors leave users helpless — all major drivers of form abandonment" ;
    oc:severityLevel "HIGH" .

oc:kn_7674b0c3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing form layout and mobile experience" ;
    oc:directiveContent "Use single-column layouts for forms by default, with mobile-first design: 44px+ touch targets, appropriate keyboard types (email, tel, number), autofill support, sticky submit buttons, and minimal typing via dropdowns and toggles." ;
    oc:hasRationale "Single-column forms have higher completion rates and are universally mobile-friendly; multi-column forms create eye-tracking zigzag patterns that increase cognitive load" ;
    oc:severityLevel "MEDIUM" .

oc:kn_89b76fb9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user requests form optimization" ;
    oc:directiveContent "This skill applies ONLY to non-signup/registration forms. For signup and account creation forms, defer to signup-flow-cro. For forms inside popups/modals, defer to popup-cro." ;
    oc:hasRationale "Signup forms and popup forms have distinct UX patterns and optimization strategies that differ from general form CRO" ;
    oc:severityLevel "HIGH" .

oc:kn_ac911b9d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between single-step and multi-step form architecture" ;
    oc:directiveContent "Use multi-step forms when you have more than 5-6 fields, logically distinct sections, conditional paths, or complex forms like applications and quotes. Always include a progress indicator (step X of Y), start with easy fields, and allow back navigation." ;
    oc:hasRationale "Multi-step forms reduce perceived effort for complex data collection and can actually increase completion rates despite more total fields" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ee97e576 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any form CRO engagement" ;
    oc:directiveContent "Before providing recommendations, always check for and read product-marketing-context.md (.agents/ or .claude/) to leverage existing business context, then identify the form type, current state (field count, completion rate, mobile/desktop split, abandonment points), and business context (what happens with submissions, which fields are actually used)." ;
    oc:hasRationale "Context-aware recommendations are dramatically more actionable; without knowing which fields are actually used in follow-up, you can't recommend which to remove" ;
    oc:severityLevel "HIGH" .

oc:req_0c1f1ef6 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "product-marketing-context.md for business context" .

oc:req_4968c2c8 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Current form completion rate and field-level analytics" .

oc:req_a46d8eb1 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Mobile vs desktop traffic split data" .

