oc:kn_047b748e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating or designing any form" ;
    oc:directiveContent "Every field has a cost: 3 fields is baseline, 4-6 fields reduces completion 10-25%, 7+ fields reduces completion 25-50%+." ;
    oc:hasRationale "Each additional field increases cognitive load and physical effort, directly reducing the likelihood of submission." ;
    oc:severityLevel "CRITICAL" .

oc:kn_423bd2d7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling form validation errors" ;
    oc:directiveContent "Do not clear the form on error. Focus on the first error field, preserve all entered data, and show specific error messages near the relevant field." ;
    oc:hasRationale "Clearing form data forces users to re-enter everything, causing massive frustration and abandonment." ;
    oc:severityLevel "CRITICAL" .

oc:kn_483fdee2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or auditing any form" ;
    oc:directiveContent "Value must exceed effort: show clear value proposition above the form, make what they get obvious, and reduce perceived effort through fewer fields and clearer labels." ;
    oc:hasRationale "Users weigh the benefit of completing a form against the effort required; if effort exceeds perceived value, they abandon." ;
    oc:severityLevel "HIGH" .

oc:kn_7c111e50 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing multi-step or progressive forms" ;
    oc:directiveContent "Use progressive commitment: start with low-friction fields (email), then add detail (name, company), then qualifying questions, then contact preferences." ;
    oc:hasRationale "Building commitment incrementally leverages the sunk cost fallacy and reduces initial friction." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7ec32c77 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before providing any form optimization recommendations" ;
    oc:directiveContent "Check for .agents/product-marketing-context.md or .claude/product-marketing-context.md and read it before asking questions — use existing context and only ask for information not already covered." ;
    oc:hasRationale "Product marketing context contains business-specific information that eliminates redundant questions and improves recommendation relevance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8c6f8cd9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring longer forms" ;
    oc:directiveContent "Switch to multi-step forms when you have more than 5-6 fields, logically distinct sections, or conditional paths." ;
    oc:hasRationale "Multi-step forms reduce perceived effort through progressive disclosure and maintain momentum with progress indicators." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bf5ab1f2 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When a user asks about signup, registration, or account creation form optimization" ;
    oc:directiveContent "This skill does NOT cover signup/registration forms — defer to signup-flow-cro for those. Similarly, forms inside popups should use popup-cro." ;
    oc:hasRationale "Signup flows have distinct psychological dynamics (account creation anxiety, password selection) that warrant specialized guidance." ;
    oc:severityLevel "HIGH" .

oc:kn_d7ef4903 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing form field labels and placeholders" ;
    oc:directiveContent "Never use placeholder text as the only label — placeholders disappear when typing, leaving users unsure what they're filling in." ;
    oc:hasRationale "Placeholder-only labels create disorientation mid-completion and especially hurt accessibility and form review." ;
    oc:severityLevel "HIGH" .

oc:kn_dde8d356 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding form layout" ;
    oc:directiveContent "Use single-column layout for forms. Default to single column; use multi-column only for short related fields like First/Last name." ;
    oc:hasRationale "Single-column forms have higher completion rates and are mobile-friendly; multi-column layouts cause eye-tracking zigzag patterns." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e4827786 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing submit button copy" ;
    oc:directiveContent "Button copy should use '[Action] + [What they get]' format (e.g., 'Get My Free Quote', 'Download the Guide') instead of generic 'Submit' or 'Send'." ;
    oc:hasRationale "Specific action-oriented button text reinforces the value exchange and reduces ambiguity about what happens next." ;
    oc:severityLevel "MEDIUM" .

