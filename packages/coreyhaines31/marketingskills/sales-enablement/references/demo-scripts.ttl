@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_sales_enablement_demo_scripts a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "demo-scripts" ;
    skos:broader "Sales enablement script generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/sales-enablement" ;
    oc:contentHash "505616ebf73d30fe84a844540727ab8f3aeae29ebcda8c8ace28a18ada003da3" ;
    oc:differentia "provides scene-by-scene demo script templates for four call types — discovery, first demo, technical deep-dive, and executive overview — with timing, talk tracks, interaction guidance, and objection handling" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_sales_enablement ;
    oc:hasArgumentHint "call_type (discovery | demo | technical | executive)" ;
    oc:hasCategory "sales-enablement" ;
    oc:impartsKnowledge oc:kn_37cd286b,
        oc:kn_3b8bb373,
        oc:kn_459eb112,
        oc:kn_4b77e954,
        oc:kn_56a5f9e0,
        oc:kn_674de8ac,
        oc:kn_ac09daa7 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:resolvesIntent "create demo script for discovery call",
        "create demo script for executive overview",
        "create demo script for first product demo",
        "create demo script for technical deep-dive",
        "prepare talk tracks and interaction guidance for sales calls",
        "structure a sales call with timing and scene breakdown" .

oc:kn_37cd286b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before joining a demo, technical deep-dive, or executive overview call" ;
    oc:directiveContent "Before any demo call, prepare: (1) the prospect's specific pain points from discovery, (2) a matched case study, (3) a ROI calculation using their numbers, and (4) a specific next-step proposal with date." ;
    oc:hasRationale "Unprepared demos waste the prospect's time and lose deals. Customized preparation dramatically increases conversion rates." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3b8bb373 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any sales demo or discovery call" ;
    oc:directiveContent "Structure every sales call into timed scenes with clear goals, talk tracks, and interaction points — never wing it." ;
    oc:hasRationale "Timed scene structure keeps calls on track, ensures all qualification criteria are covered, and prevents rambling or feature-dumping." ;
    oc:severityLevel "HIGH" .

oc:kn_459eb112 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning a demo, technical deep-dive, or executive overview after a prior discovery call" ;
    oc:directiveContent "Always recap the prospect's stated pain points at the opening of follow-up calls to demonstrate active listening and confirm priorities haven't shifted." ;
    oc:hasRationale "Recapping pain points builds trust, shows preparation, and ensures the demo addresses their actual needs rather than generic features." ;
    oc:severityLevel "HIGH" .

oc:kn_4b77e954 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When demonstrating any product workflow during a demo call" ;
    oc:directiveContent "For each workflow shown in a demo: (1) restate the pain, (2) show the solution step-by-step, (3) highlight the specific outcome. Then ask a comparison question." ;
    oc:hasRationale "The pain-solution-outcome structure connects features to the prospect's real problems and makes benefits tangible rather than abstract." ;
    oc:severityLevel "MEDIUM" .

oc:kn_56a5f9e0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When delivering any product demo or walkthrough" ;
    oc:directiveContent "Never talk for more than 3 minutes without asking a question during a demo." ;
    oc:hasRationale "Monologuing loses prospect attention and prevents you from reading buying signals or objections in real time." ;
    oc:severityLevel "HIGH" .

oc:kn_674de8ac a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During any demo or sales call interaction" ;
    oc:directiveContent "Never ask 'Does that make sense?', 'Are you still with me?', or 'Isn't that cool?' during demos — these are patronizing, imply confusion, or sound salesy." ;
    oc:hasRationale "These questions shut down genuine dialogue and make the prospect feel talked down to, destroying rapport." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ac09daa7 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When handling ad-hoc requests during a live demo" ;
    oc:directiveContent "When a prospect asks to see something unplanned: show it if quick, defer it if it's a tangent, or explain the alternative if not possible. Never say 'I'll get back to you' without writing it down and following up within 24 hours." ;
    oc:hasRationale "Properly handling tangential requests maintains call flow while demonstrating responsiveness and trustworthiness." ;
    oc:severityLevel "MEDIUM" .

