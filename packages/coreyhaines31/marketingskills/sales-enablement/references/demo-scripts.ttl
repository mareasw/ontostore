oc:kn_18aa37b2 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When demonstrating any workflow during a demo" ;
    oc:directiveContent "1. Restate the pain point the prospect mentioned. 2. Show the solution workflow step by step. 3. Highlight the specific outcome benefit." ;
    oc:stepOrder 1 .

oc:kn_32b24573 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing for any sales call" ;
    oc:directiveContent "Structure every call as scenes with explicit time allocations, talk tracks, and interaction points. Never run a demo without a scene-by-scene plan." ;
    oc:hasRationale "Time-boxed scenes prevent rambling, ensure all critical topics are covered, and create natural interaction checkpoints." ;
    oc:severityLevel "HIGH" .

oc:kn_50e0de44 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting to executives" ;
    oc:directiveContent "For executive overviews, use their numbers not generic benchmarks, show the ROI math not just the conclusion, use conservative estimates, and reference one strong case study instead of multiple weak ones." ;
    oc:hasRationale "Executives punish rambling and inflated numbers. Credibility comes from using their own data and conservative projections." ;
    oc:severityLevel "HIGH" .

oc:kn_65c1ebea a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When closing any sales call" ;
    oc:directiveContent "Always propose a specific next step with a concrete date, not open-ended language like 'let me know'. Send recap email within 2 hours of demo, technical docs within 24 hours." ;
    oc:hasRationale "Specific next steps maintain momentum. Delayed follow-up kills deal velocity." ;
    oc:severityLevel "MEDIUM" .

oc:kn_70e7dfbe a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating new demo script templates" ;
    oc:directiveContent """## [Call Type] Script
**Duration:** [X] minutes
**Goal:** [Objective]
### Scene [N]: [Name] ([X] min)
**Talk track:** "[Scripted opening]"
**Questions to ask:** [List]
**What you're listening for:** [List]
**Interaction point:** [Check-in question]""" ;
    oc:templateVariables "Call Type",
        "Duration",
        "Goal",
        "Interaction Point",
        "Listening For",
        "Questions",
        "Scene Name",
        "Talk Track" .

oc:kn_77201d19 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When prospect asks 'Can you show me X?' during a demo" ;
    oc:directiveContent "1. If request is quick → show now, return to flow. 2. If request is a tangent → note it, address after main flow. 3. If request is not possible → explain alternative approach." ;
    oc:stepOrder 2 .

oc:kn_87dd48b7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When conducting discovery calls" ;
    oc:directiveContent "Discovery calls must identify at minimum: specific quantifiable pain points, budget signals, decision-making process/stakeholders, and timeline for decision." ;
    oc:hasRationale "Without these four elements, you cannot properly qualify the opportunity or tailor the subsequent demo." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d1aeebda a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When handling off-script questions during demos" ;
    oc:directiveContent "When a prospect asks to see something unplanned: if quick, show it now; if a tangent, note it and return after main flow; if impossible, explain alternatives. Never say 'I'll get back to you' without writing it down and following up within 24 hours." ;
    oc:hasRationale "Improper handling of ad-hoc requests derails the demo or erodes trust if follow-through fails." .

oc:kn_eca04eeb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When delivering any demo or sales call" ;
    oc:directiveContent "Never talk for more than 3 minutes without asking a question during a demo. Avoid asking 'Does that make sense?', 'Are you still with me?', or 'Isn't that cool?'" ;
    oc:hasRationale "Monologue stretches lose prospect engagement. Patronizing or salesy questions damage rapport and trust." ;
    oc:severityLevel "HIGH" .

_:ref_08c054f84f98b308 a oc:WorkflowStep ;
    dcterms:description "**If it's quick** — show it now, then return to your flow" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_0ec6def8bec54911 a oc:WorkflowStep ;
    dcterms:description "**If it's not possible** — \"We don't do that today. Here's how customers handle it: [alternative].\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_59b1806d1330c49c a oc:WorkflowStep ;
    dcterms:description "Highlight the outcome: \"This means [specific benefit]...\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_72f988aa66dd13da a oc:WorkflowStep ;
    dcterms:description "Restate the pain: \"You mentioned [specific problem]...\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_9a51cb71de6f6dc2 a oc:WorkflowStep ;
    dcterms:description "Show the solution: Walk through the workflow step by step" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_a72a53ef9633109b a oc:WorkflowStep ;
    dcterms:description "**If it's a tangent** — \"Great question. Let me note that and show you after the main flow so we stay on track.\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

