                                    oc:quoteContent "\"What does your team's capacity look like for implementation? That helps me scope the right timeline.\"" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Scene 5: Implementation & Migration (5 min)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
