                                            oc:itemOrder 1 ;
                                            oc:itemText "Answer directly — if you don't know, say so and follow up" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Propose next step (security review, proof of concept, pilot)" ] ],
                                [ a oc:BlockQuote ;
