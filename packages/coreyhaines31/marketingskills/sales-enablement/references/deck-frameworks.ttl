                                    oc:textContent "Trying to address every persona, every use case, every feature in one deck. The result is a 40-slide monster that nobody wants to sit through." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "The Kitchen Sink" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Every slide is a feature with a screenshot. No story, no \"so what,\" no connection to the buyer's world. Reps click through it; prospects tune out." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "The Feature Dump" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Jumping to product features before establishing the problem. The buyer has no frame of reference for why your features matter." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "The Premature Demo" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Product screenshots without callouts, annotations, or context. The prospect can't tell what they're looking at or why it matters." ] ;
