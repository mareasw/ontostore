@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_sales_enablement_deck_frameworks a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "deck-frameworks" ;
    skos:broader "Sales deck construction guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/sales-enablement" ;
    oc:contentHash "265eea6c1b358d10f2dd22fd987789a9d115c14d30bf77a9086734ac60659336" ;
    oc:differentia "Provides an 11-slide narrative storytelling framework (Situation → Complication → Resolution) with persona-specific customization rules and anti-pattern warnings for building sales presentations that close deals" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_sales_enablement ;
    oc:handlesFailure oc:InsufficientProofPoints,
        oc:MissingBuyerContext ;
    oc:hasArgumentHint "product context, target audience, or existing deck to restructure" ;
    oc:hasCategory "sales-enablement" ;
    oc:impartsKnowledge oc:kn_463ec708,
        oc:kn_a5b3f1d7,
        oc:kn_a6461cf6,
        oc:kn_ab5ca839,
        oc:kn_d9e669a9,
        oc:kn_dc37131d ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProductMarketingContextReady ;
    oc:resolvesIntent "build slide-by-slide sales presentation",
        "create a sales deck",
        "customize sales deck for different buyer personas",
        "design a pitch deck for sales meetings",
        "structure a sales presentation with narrative arc" ;
    oc:yieldsState oc:SalesDeckStructured .

oc:kn_463ec708 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding how many slides and what content to include in a sales deck" ;
    oc:directiveContent "Limit the deck to 11 slides following the prescribed sequence: Problem, Cost of Problem, Market Shift, Your Approach, Product Walkthrough, Proof Points, Case Study, Implementation Timeline, ROI, Pricing, and CTA. Each slide should have one core message." ;
    oc:hasRationale "Too many slides (the 'Kitchen Sink' anti-pattern) creates a 40-slide monster nobody wants to sit through. One message per slide keeps the presentation focused and conversational." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a5b3f1d7 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When preparing a deck for a specific audience or stakeholder type" ;
    oc:directiveContent "Customize the deck for the specific buyer persona: add architecture/security details and remove ROI calculations for Technical Buyers; add detailed ROI/TCO and remove technical details for Economic Buyers; add internal-selling slides and objection pre-handling for Champion decks." ;
    oc:hasRationale "Different personas evaluate on completely different criteria. A technical buyer wants capability proof; an economic buyer wants financial justification; a champion needs ammunition to sell internally." ;
    oc:severityLevel "HIGH" .

oc:kn_a6461cf6 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning deck construction" ;
    oc:directiveContent "Before building the deck, verify you have: a quantified buyer problem with data points, specific proof metrics (3 numbers that prove the product works), a relevant case study with before/after metrics, clear implementation timeline, and ROI calculations tied to the buyer's situation." ;
    oc:hasRationale "Each slide template requires specific evidence. Starting without these inputs leads to vague, generic content that fails to persuade." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ab5ca839 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or building any sales deck" ;
    oc:directiveContent "Avoid six critical deck anti-patterns: The Feature Dump (feature per slide with no story), The Wall of Text (200+ words per slide), The Missing Story Arc (isolated slides with no narrative flow), The Generic Screenshot (product shots without callouts), The Premature Demo (features before problem), and The Kitchen Sink (addressing every persona/use case in one deck)." ;
    oc:hasRationale "These six patterns are the most common reasons sales decks fail to engage buyers. Each one breaks the fundamental principle that a deck should be a guided conversation, not an information dump." ;
    oc:severityLevel "HIGH" .

oc:kn_d9e669a9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the opening slides of any sales deck" ;
    oc:directiveContent "Never start the deck with your company or product. Slides 1-3 must focus entirely on the buyer's world — their problem, the cost of that problem, and the market shift creating urgency." ;
    oc:hasRationale "Starting with your company signals self-interest rather than buyer empathy. The buyer has no frame of reference for why your features matter until they see their own problem reflected back." ;
    oc:severityLevel "HIGH" .

oc:kn_dc37131d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring any sales deck from scratch" ;
    oc:directiveContent "Every sales deck must follow a narrative arc: Situation → Complication → Resolution. The goal is to make the buyer feel understood first, then show them a better way — not to present features." ;
    oc:hasRationale "Without a narrative arc, slides exist in isolation and the deck feels like a brochure rather than a conversation. Buyers connect through story, not feature lists." ;
    oc:severityLevel "CRITICAL" .

