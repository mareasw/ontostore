oc:skill_coreyhaines31_marketingskills_sales_enablement_deck_frameworks a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "deck-frameworks" ;
    skos:broader "Sales deck framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/sales-enablement" ;
    oc:contentHash "265eea6c1b358d10f2dd22fd987789a9d115c14d30bf77a9086734ac60659336" ;
    oc:differentia "that provides slide-by-slide narrative structure following a storytelling arc from problem to resolution with persona-specific customization" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_sales_enablement ;
    oc:hasArgumentHint "buyer persona (technical, economic, or champion) or slide number for guidance" ;
    oc:hasCategory "marketing" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Detailed slide-by-slide guidance for building sales decks that tell a story and close deals." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "The goal is not to present features. The goal is to make the buyer feel understood, then show them a better way." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Every great deck follows a narrative structure: **Situation → Complication → Resolution.**" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Complication** (Slides 2-3): Why the status quo is no longer sustainable. Create urgency." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Situation** (Slides 1-3): The world your buyer lives in. Establish shared understanding." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Resolution** (Slides 4-11): Your approach, proof, and path forward." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "The Storytelling Arc" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**What to include:**" ],
