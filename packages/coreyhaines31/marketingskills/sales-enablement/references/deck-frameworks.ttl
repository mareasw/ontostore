                                            oc:itemOrder 2 ;
                                            oc:itemText "Time impact (hours wasted, delays)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Specific numbers wherever possible" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 5 ;
                                    oc:textContent "**Copy prompt:** \"If your buyer does nothing for the next 12 months, what does it cost them?\"" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Slide 2: Cost of the Problem" ],
