        oc:kn_d2cbe605 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "build a sales deck",
        "create a pitch presentation",
        "customize sales deck for different buyer personas",
        "design slide-by-slide sales deck structure",
        "write sales deck copy for each slide" .

oc:kn_06d608fe a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adapting a sales deck for a specific audience" ;
    oc:directiveContent "Customize the deck for the buyer persona: Technical buyers need architecture diagrams, security details, and API capabilities with precise tone. Economic buyers need detailed ROI with calculations, TCO comparison, and executive summary in business-focused tone. Champion buyers need internal-selling slides, quick-win proof, peer proof, and objection pre-handling in an empowering tone." ;
    oc:hasRationale "Different personas evaluate purchases on different criteria — technical buyers assess capability, economic buyers assess ROI, champions need ammunition to sell internally" ;
    oc:severityLevel "HIGH" .

oc:kn_5182eeab a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any sales deck from scratch" ;
    oc:directiveContent "Every sales deck must follow the storytelling arc: Situation → Complication → Resolution. Slides 1-3 establish the buyer's world and why the status quo is unsustainable; Slides 4-11 deliver your approach, proof, and path forward." ;
    oc:hasRationale "Narrative structure creates emotional engagement and makes the buyer feel understood before presenting a solution" ;
    oc:severityLevel "CRITICAL" .

oc:kn_97812850 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or building any sales deck" ;
    oc:directiveContent "Avoid the Feature Dump: every slide showing a feature with a screenshot, no story, no 'so what,' no connection to buyer pain. Avoid the Wall of Text: slides with 200+ words that nobody reads during presentation. Avoid the Missing Story Arc: slides in isolation without narrative flow. Avoid the Premature Demo: jumping to product features before establishing the problem." ;
    oc:hasRationale "These anti-patterns cause prospects to tune out, fail to create urgency, and make the deck feel like a brochure instead of a conversation" ;
    oc:severityLevel "HIGH" .

oc:kn_cbed4978 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When auditing or revising an existing sales deck" ;
    oc:directiveContent "If the deck exceeds 15 slides, apply the Kitchen Sink check: remove slides that don't directly support the single core narrative. If a slide requires reading, move it to a leave-behind document. If product screenshots lack callouts or annotations, add visual context showing why the feature matters." ;
    oc:hasRationale "Trimming to essential slides keeps the audience engaged; annotated visuals prevent confusion about what the prospect is seeing" .

oc:kn_d2cbe605 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing content for individual slides" ;
    oc:directiveContent "Each slide should address exactly one core idea. Use specific numbers and data points rather than vague claims. Limit pricing to 3 tiers maximum. Never claim to be 'the only' or 'the first' unless provably true." ;
    oc:hasRationale "Focused slides with credible data build trust; overloading slides or making unsubstantiated claims destroys credibility" ;
    oc:severityLevel "MEDIUM" .

_:ref_06e1244812cf0156 a oc:WorkflowStep ;
    dcterms:description "Slide 5: Product Walkthrough — show 3-4 key workflows mapped to Slide 1 pain points with annotated visuals" ;
    oc:expectedOutcome "Buyer can visualize using the product" ;
    oc:stepDependsOn _:ref_2053f79467fa10d3 ;
    oc:stepId "slide5-product" .

_:ref_2053f79467fa10d3 a oc:WorkflowStep ;
    dcterms:description "Slide 4: Your Approach — present your unique philosophy or POV on solving the problem" ;
    oc:expectedOutcome "Buyer sees a fundamentally different way forward" ;
    oc:stepDependsOn _:ref_f83cfd26dba5efbb ;
    oc:stepId "slide4-approach" .

_:ref_23825e42cee1eecf a oc:WorkflowStep ;
    dcterms:description "Remove or minimize slides irrelevant to the persona: skip deep tech for economic buyers, skip ROI detail for technical buyers" ;
    oc:expectedOutcome "Deck is lean and focused on persona priorities" ;
    oc:stepDependsOn _:ref_d2777667dbc2af6b ;
    oc:stepId "remove-irrelevant" .

_:ref_38e689b9fc1caa19 a oc:WorkflowStep ;
    dcterms:description "Slide 1: Current World Problem — define the one core challenge your buyer faces daily with a quantifying stat" ;
    oc:expectedOutcome "Buyer recognizes their situation immediately" ;
    oc:stepId "slide1-problem" .

_:ref_5ea133ec53f9d3bb a oc:WorkflowStep ;
    dcterms:description "Slide 9: ROI/Value — expected return with payback period and 1-3 year total value vs. cost of inaction" ;
    oc:expectedOutcome "Buyer understands the financial case" ;
    oc:stepDependsOn _:ref_8a7d7248cbf9b972 ;
    oc:stepId "slide9-roi" .

_:ref_5eb85389f1f96f16 a oc:WorkflowStep ;
    dcterms:description "Slide 7: Case Study — one customer story with before/after metrics and a quote from a similar industry" ;
    oc:expectedOutcome "Buyer relates to a peer's success story" ;
    oc:stepDependsOn _:ref_8335fcb689866800 ;
    oc:stepId "slide7-case-study" .

_:ref_8335fcb689866800 a oc:WorkflowStep ;
    dcterms:description "Slide 6: Proof Points — customer logos, key metrics, analyst recognition tied to buyer's pain" ;
    oc:expectedOutcome "Buyer sees credible evidence the product works" ;
    oc:stepDependsOn _:ref_06e1244812cf0156 ;
    oc:stepId "slide6-proof" .

_:ref_8a7d7248cbf9b972 a oc:WorkflowStep ;
    dcterms:description "Slide 8: Implementation/Timeline — clear phases from signing to live with responsibilities defined" ;
    oc:expectedOutcome "Buyer sees a realistic, manageable path forward" ;
    oc:stepDependsOn _:ref_5eb85389f1f96f16 ;
    oc:stepId "slide8-implementation" .

_:ref_cb7e782b421794d3 a oc:WorkflowStep ;
    dcterms:description "Slide 11: Next Steps/CTA — one specific next action with timeline and contact information" ;
    oc:expectedOutcome "Buyer agrees to a concrete next step" ;
    oc:stepDependsOn _:ref_d8580d3dd243675a ;
    oc:stepId "slide11-cta" .

_:ref_d35f268727edf7d0 a oc:WorkflowStep ;
    dcterms:description "Slide 2: Cost of the Problem — quantify financial, time, and risk impact of inaction with 2-3 hard-hitting metrics" ;
    oc:expectedOutcome "Buyer feels urgency about the status quo" ;
    oc:stepDependsOn _:ref_38e689b9fc1caa19 ;
    oc:stepId "slide2-cost" .

_:ref_d8580d3dd243675a a oc:WorkflowStep ;
    dcterms:description "Slide 10: Pricing Overview — transparent tiers with what's included and a recommended plan" ;
    oc:expectedOutcome "Buyer knows exact cost and can make a buying decision" ;
    oc:stepDependsOn _:ref_5ea133ec53f9d3bb ;
    oc:stepId "slide10-pricing" .

_:ref_f83cfd26dba5efbb a oc:WorkflowStep ;
    dcterms:description "Slide 3: The Shift Happening — show the market trend making the old approach unsustainable" ;
    oc:expectedOutcome "Buyer understands why now is the right time to act" ;
    oc:stepDependsOn _:ref_d35f268727edf7d0 ;
    oc:stepId "slide3-shift" .

_:ref_d2777667dbc2af6b a oc:WorkflowStep ;
    dcterms:description "Identify the primary buyer persona: technical buyer, economic buyer, or champion" ;
    oc:expectedOutcome "Clear understanding of who will receive the deck" ;
    oc:stepId "identify-persona" .

