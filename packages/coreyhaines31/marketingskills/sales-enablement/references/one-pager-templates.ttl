oc:kn_08d225d9 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When creating post-meeting leave-behinds" ;
    oc:directiveContent "Send post-meeting leave-behinds within 24 hours. Reference specific things the prospect said to demonstrate active listening." ;
    oc:hasRationale "Timeliness and personalization dramatically increase the chance the document gets forwarded internally." .

oc:kn_1ee69446 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When structuring any one-pager content" ;
    oc:directiveContent "HEADLINE → PROBLEM/CHALLENGE → SOLUTION/HOW IT WORKS → PROOF/RESULTS → CTA. Each section uses bullet points over paragraphs. Metrics and quotes visually stand out." .

oc:kn_35a79158 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any one-pager" ;
    oc:directiveContent "Every one-pager must have a strong headline, clear problem/challenge section, solution explanation, proof elements (quotes + metrics), and a prominent CTA." ;
    oc:hasRationale "These five elements form the minimum viable persuasion structure for a single-page sales document." .

oc:kn_938c89be a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When finalizing one-pager deliverables" ;
    oc:directiveContent "Always deliver one-pagers in both PDF (clean, for prospects) and editable Google Slides/PowerPoint (for reps to customize)." ;
    oc:hasRationale "Reps need to tailor content per prospect while maintaining a polished format for external sharing." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a0e9db7b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating champion enablement one-pagers" ;
    oc:directiveContent "Write champion enablement one-pagers in the champion's voice using 'we' and 'our' language, not vendor language." ;
    oc:hasRationale "The champion needs to look smart internally; vendor-speak undermines their credibility with leadership." .

oc:kn_d4242f75 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When laying out any one-pager" ;
    oc:directiveContent "Never shrink font below 9pt. If the page feels crowded, cut content rather than reducing font size." ;
    oc:hasRationale "Readability is non-negotiable; a cramped one-pager signals desperation, not value." ;
    oc:severityLevel "HIGH" .

