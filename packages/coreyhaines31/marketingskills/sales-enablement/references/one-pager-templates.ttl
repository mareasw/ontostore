@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_sales_enablement_one_pager_templates a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "one-pager-templates" ;
    skos:broader "Template collection" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/sales-enablement" ;
    oc:contentHash "2197326faff4ede03fb40e332e9c80a4e084d8efd48c74df8720d70817ac5ded" ;
    oc:differentia "provides structured layouts, copy prompts, and visual design guidance for four distinct one-pager types used in B2B sales enablement" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_sales_enablement ;
    oc:handlesFailure oc:ContentOverflow,
        oc:InvalidInput ;
    oc:hasArgumentHint "one-pager type (product-overview, use-case, leave-behind, champion-enablement)" ;
    oc:hasCategory "sales-enablement" ;
    oc:impartsKnowledge oc:kn_1b831574,
        oc:kn_2dfdb954,
        oc:kn_53bf7bdb,
        oc:kn_7a94fd6e,
        oc:kn_7d83333f,
        oc:kn_d295fc41,
        oc:kn_ef1a757b ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:ProductMarketingContextReady ;
    oc:resolvesIntent "create champion enablement one-pager",
        "create post-meeting leave-behind",
        "create product overview one-pager",
        "create use-case specific one-pager",
        "design one-pager layout and visual hierarchy" ;
    oc:yieldsState oc:OnePagerCreated .

oc:kn_1b831574 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating a champion enablement one-pager" ;
    oc:directiveContent "Use the champion's voice ('we'/'our') rather than vendor language when writing champion enablement one-pagers, so the champion can forward it without rewriting." ;
    oc:hasRationale "Champions need materials they can share internally without it looking like vendor marketing; they need to look smart to their leadership." ;
    oc:severityLevel "HIGH" .

oc:kn_2dfdb954 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When delivering final one-pager files" ;
    oc:directiveContent "Always provide both PDF and editable formats (Google Slides/PowerPoint): reps customize the editable version, prospects receive the clean PDF." ;
    oc:hasRationale "Sales reps need to tailor content per prospect while prospects expect polished, non-editable assets." ;
    oc:severityLevel "MEDIUM" .

oc:kn_53bf7bdb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing one-pager visual style" ;
    oc:directiveContent "Limit accent colors to 1-2, keep body text dark on white, and use color strategically to draw attention to metrics and CTAs." ;
    oc:hasRationale "Visual consistency and restraint improve scannability and professionalism; too many colors distract from the message." ;
    oc:severityLevel "LOW" .

oc:kn_7a94fd6e a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "After any sales meeting where a leave-behind is appropriate" ;
    oc:directiveContent "Send post-meeting leave-behinds within 24 hours, referencing specific things the prospect said to show active listening." ;
    oc:hasRationale "Timeliness and personalization reinforce the conversation and demonstrate responsiveness; the champion will forward this to their boss." ;
    oc:severityLevel "HIGH" .

oc:kn_7d83333f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before delivering any one-pager" ;
    oc:directiveContent "Before finalizing a one-pager, verify the visual hierarchy: headline is largest, section headers are bold anchors, proof elements stand out, and CTA is prominent at the bottom." ;
    oc:hasRationale "Readers scan rather than read; proper visual hierarchy ensures the most important information is absorbed even with a 5-second glance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d295fc41 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When laying out any one-pager" ;
    oc:directiveContent "Never shrink font below 9pt. If the one-pager feels crowded, cut content rather than reducing font size or margins (minimum 0.75 inches)." ;
    oc:hasRationale "Crammed content signals poor editing and reduces readability; a one-pager must be scannable at a glance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ef1a757b a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When a product serves multiple personas or verticals" ;
    oc:directiveContent "Create separate use-case-specific one-pagers for different buyer personas, industries, or workflows rather than a single generic version." ;
    oc:hasRationale "Targeted one-pagers convert better because they speak directly to the specific pain points and outcomes of each audience segment." ;
    oc:severityLevel "MEDIUM" .

