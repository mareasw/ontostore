                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Differentiators: \"If you could only tell them 3 things, what would make them choose you?\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Headline: \"What do you do, in one sentence, that makes someone say 'tell me more'?\"" ] ] ;
