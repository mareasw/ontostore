                                            oc:itemText "Limit accent colors to 1-2 for visual consistency" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Use color to draw attention to metrics and CTAs" ],
                                        [ a oc:BulletItem ;
