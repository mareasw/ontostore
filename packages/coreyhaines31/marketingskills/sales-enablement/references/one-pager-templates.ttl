                                    oc:tableCaption "### Font Sizing" ;
                                    oc:tableMarkdown """| Element | Suggested Size |
|---------|---------------|
| Headline | 18-24pt |
| Section headers | 12-14pt bold |
| Body text | 10-11pt |
| Fine print / footer | 8-9pt |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Font Sizing" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
