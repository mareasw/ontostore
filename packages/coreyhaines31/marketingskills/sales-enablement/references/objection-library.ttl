                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**Why they say it:** Integration is a real requirement. They need to know your product fits their stack." ],
                                        [ a oc:Paragraph ;
