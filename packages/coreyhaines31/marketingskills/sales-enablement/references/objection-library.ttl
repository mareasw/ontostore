                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 6 ;
                                            oc:textContent "**Proof point:** Multi-stakeholder case study showing how different personas were addressed." ],
                                        _:ref_c58ad017abda5c54,
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**Why they say it:** Enterprise buying involves multiple stakeholders. Genuine process, not a brush-off." ],
                                        [ a oc:BlockQuote ;
                                            oc:blockType "blockquote" ;
                                            oc:contentOrder 5 ;
                                            oc:quoteContent "\"That makes sense. Can you walk me through who's on the committee and what each person cares about? I can tailor materials for each stakeholder so you're not doing all the heavy lifting. I've also got a deck designed for executive presentations if that would be useful.\"" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 7 ;
                                            oc:textContent "**Follow-up question:** \"Who on the committee is most likely to push back, and what would their concern be?\"" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 16 ;
                                    oc:sectionTitle "\"A committee decides this\"" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 14 ;
                            oc:sectionTitle "Authority Objections" ],
                        [ a oc:Section ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent _:ref_05d8e7797a2ced21,
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 2 ;
                                            oc:textContent "**Response approach:**" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 4 ;
                                            oc:textContent "**Talk track:**" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 7 ;
                                            oc:textContent "**Follow-up question:** \"What would need to change for this to move up in priority?\"" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**Why they say it:** Competing priorities, organizational change, genuine capacity constraint, or lack of urgency." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 6 ;
                                            oc:textContent "**Proof point:** Cost-of-delay calculation based on their specific numbers." ],
                                        [ a oc:BlockQuote ;
                                            oc:blockType "blockquote" ;
                                            oc:contentOrder 5 ;
                                            oc:quoteContent "\"I get it — timing matters. Can I ask what's taking priority right now? The reason I bring up timing is that every month of [problem], based on our earlier conversation, costs your team roughly [$ amount]. A 3-month delay is [$ amount]. What if we mapped out a start date that works with your calendar so you're not losing that value?\"" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 9 ;
                                    oc:sectionTitle "\"Not the right time\"" ],
                                [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**Why they say it:** Genuine scheduling, or a polite way of saying \"not interested enough right now.\"" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 2 ;
                                            oc:textContent "**Response approach:**" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 6 ;
                                            oc:textContent "**Proof point:** Customer who started the evaluation process early and was live by their target date." ],
                                        _:ref_73b4720c2c76ac32,
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
