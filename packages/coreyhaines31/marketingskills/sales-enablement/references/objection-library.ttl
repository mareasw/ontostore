                                            oc:contentOrder 7 ;
                                            oc:quoteContent "\"We don't have a native integration with [X] today. Here's what customers typically do: [alternative]. We also have an open API that [description]. Would it help to get our technical team on a call to explore options?\"" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 8 ;
                                            oc:textContent "**Proof point:** Customer using the same tech stack, integration documentation." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
