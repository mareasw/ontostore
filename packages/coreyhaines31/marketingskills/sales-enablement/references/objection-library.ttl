oc:skill_coreyhaines31_marketingskills_sales_enablement_objection_library a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "objection-library" ;
    skos:broader "Reference library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/sales-enablement" ;
    oc:contentHash "e0cdfeffc41afbdbe2c014bcd9b3c024318eac9bd23159e871ec796aba29e0b2" ;
    oc:dependsOnSkill oc:skill_sales_enablement ;
    oc:differentia "organizes common B2B SaaS sales objections by category with response frameworks, talk tracks, and proof points for live sales conversations" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_sales_enablement ;
    oc:handlesFailure oc:ProspectStalled,
        oc:TrustLost ;
    oc:hasArgumentHint "objection type or category (e.g., \"price\", \"timing\", \"competition\", \"authority\", \"status quo\", \"technical\")" ;
    oc:hasCategory "sales-enablement" ;
    oc:impartsKnowledge oc:kn_1b191258,
        oc:kn_58a2bf6d,
        oc:kn_cf5a7daf,
        oc:kn_dfbb79ed,
        oc:kn_f16e1f05 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:SalesCallScheduled ;
    oc:resolvesIntent "equip sales champions with talking points",
        "handle sales objections",
        "prepare objection responses",
        "rehearse sales call responses",
        "respond to competition objections",
        "respond to price objections",
        "respond to status quo objections",
        "respond to timing objections" ;
    oc:yieldsState oc:ChampionEquipped,
        oc:ObjectionsHandled .

oc:kn_1b191258 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When preparing for or conducting a sales call" ;
    oc:directiveContent "Use the quick-reference table for live calls (scan and respond) and the detailed sections for pre-call preparation (study and rehearse)." ;
    oc:hasRationale "The two-tier structure optimizes for different cognitive loads: fast pattern matching during live calls vs. deep learning during preparation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_58a2bf6d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting or delivering any objection response" ;
    oc:directiveContent "Every objection response should follow the structure: validate the concern → ask a diagnostic question → reframe with value → provide a proof point → ask a follow-up question." ;
    oc:hasRationale "This five-part structure keeps the conversation collaborative rather than combative, uncovers the real objection, and advances the deal." ;
    oc:severityLevel "HIGH" .

oc:kn_cf5a7daf a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before conducting a sales call or demo" ;
    oc:directiveContent "Before any sales call, identify which objection categories are most likely for this prospect based on their industry, company size, and stage in the buying process, and review the relevant talk tracks." ;
    oc:hasRationale "Pre-call objection preparation enables faster, more confident responses during live conversations and prevents being caught off guard." ;
    oc:severityLevel "HIGH" .

oc:kn_dfbb79ed a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling any price or competition objection on a live sales call" ;
    oc:directiveContent "Never immediately defend the price or trash a competitor when handling objections. Instead, ask clarifying questions and reframe the conversation around value and ROI." ;
    oc:hasRationale "Premature defense signals insecurity and erodes trust. Buyers respond better to curiosity-driven reframing that shifts focus from cost to value." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f16e1f05 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When handling technical objections about integrations, security, or compliance" ;
    oc:directiveContent "Never bluff on technical questions like integrations or security. If you don't know the answer, commit to a specific follow-up time." ;
    oc:hasRationale "Bluffing on technical capabilities will be exposed during evaluation, destroying credibility. Honest commitment to follow-up builds trust." ;
    oc:severityLevel "CRITICAL" .

