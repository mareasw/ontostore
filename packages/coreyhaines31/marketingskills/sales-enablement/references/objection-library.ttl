                                            oc:contentOrder 5 ;
                                            oc:quoteContent "\"Yes, we integrate with [X] natively. It takes about [time] to set up. [Customer] runs the same stack and here's how they have it configured.\"" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 20 ;
                                    oc:sectionTitle "\"Does it integrate with X?\"" ],
                                [ a oc:Section ;
                                    oc:hasContent _:ref_0e9eb4c36e1d3405,
                                        [ a oc:BlockQuote ;
                                            oc:blockType "blockquote" ;
                                            oc:contentOrder 5 ;
                                            oc:quoteContent "\"That's exactly the right question to ask. Here's our security overview — we're [SOC 2 Type II / ISO 27001 / etc.] certified, and I can share our full security documentation. We also have a security team that's happy to do a review call with your infosec team. What are your specific requirements?\"" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 6 ;
                                            oc:textContent "**Proof point:** Security certifications, compliance documentation, customers in regulated industries." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 4 ;
                                            oc:textContent "**Talk track:**" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**Why they say it:** Legitimate concern, especially in regulated industries or enterprise. Non-negotiable for many buyers." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 2 ;
                                            oc:textContent "**Response approach:**" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 7 ;
                                            oc:textContent "**Follow-up question:** \"Do you have a security questionnaire you'd like us to fill out?\"" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 21 ;
                                    oc:sectionTitle "\"We have security concerns\"" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 19 ;
                            oc:sectionTitle "Technical Objections" ],
