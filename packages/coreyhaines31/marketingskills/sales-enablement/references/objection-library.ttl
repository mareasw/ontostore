                                            oc:contentOrder 4 ;
                                            oc:textContent "**Talk track:**" ],
                                        [ a oc:BlockQuote ;
                                            oc:blockType "blockquote" ;
                                            oc:contentOrder 5 ;
                                            oc:quoteContent "\"Next quarter works. To make sure we hit the ground running, would it make sense to do [small next step] now? That way when Q[X] starts, you're not starting from scratch. I'll also send over [relevant content] in the meantime. Can we lock in [specific date] to reconnect?\"" ] ;
                                    oc:sectionLevel 4 ;
                                    oc:sectionOrder 10 ;
                                    oc:sectionTitle "\"Maybe next quarter\"" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 8 ;
                            oc:sectionTitle "Timing Objections" ],
                        [ a oc:Section ;
                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 2 ;
                                            oc:textContent "**Response approach:**" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**Why they say it:** They're evaluating options and want a clear differentiator. Sometimes a genuine question, sometimes a test." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 4 ;
                                            oc:textContent "**Talk track:**" ],
