                            oc:hasSubsection [ a oc:Section ;
                                    oc:hasContent [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 7 ;
                                            oc:textContent "**Follow-up question:** \"What questions do you think your boss will ask?\"" ],
                                        [ a oc:BlockQuote ;
                                            oc:blockType "blockquote" ;
                                            oc:contentOrder 5 ;
                                            oc:quoteContent "\"Absolutely — what would help you make the case? I can put together a one-pager that covers the ROI and addresses the concerns your boss is likely to have. Also happy to jump on a quick call with them if that would be helpful. What does your boss typically prioritize — cost savings, risk reduction, or efficiency?\"" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 2 ;
                                            oc:textContent "**Response approach:**" ],
                                        _:ref_9a36f1e40da542fb,
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 1 ;
                                            oc:textContent "**Why they say it:** They may not be the decision maker, or they need internal buy-in to proceed. Could also be a stall tactic." ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 4 ;
                                            oc:textContent "**Talk track:**" ],
                                        [ a oc:Paragraph ;
                                            oc:blockType "paragraph" ;
                                            oc:contentOrder 6 ;
                                            oc:textContent "**Proof point:** Champion enablement one-pager, ROI calculator." ] ;
                                    oc:sectionLevel 4 ;
