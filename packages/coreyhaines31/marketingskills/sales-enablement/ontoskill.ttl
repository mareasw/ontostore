oc:skill_coreyhaines31_marketingskills_sales_enablement a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "sales-enablement" ;
    skos:broader "B2B sales enablement collateral generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/sales-enablement" ;
    oc:contentHash "926cc52d528b00e401db3fdd9071a9787d304faaa32c180604e24191b03ed879" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "that creates deal-closing assets — pitch decks, one-pagers, objection handling docs, demo scripts, ROI calculators, buyer persona cards, proposal templates, and sales playbooks — using structured frameworks, persona-specific customization, and field-tested sales principles" ;
    oc:handlesFailure oc:InsufficientProductContext ;
    oc:hasAlias "demo-script",
        "objection-handling",
        "one-pager",
        "pitch-deck",
        "sales-collateral",
        "sales-deck",
        "sales-playbook" ;
    oc:hasArgumentHint "asset type (deck, one-pager, objection doc, demo script, ROI calculator, playbook, persona card, proposal) and target buyer context" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to create sales collateral, pitch decks, one-pagers, objection handling docs, or demo scripts. Also use when the user mentions 'sales deck,' 'pitch deck,' 'one-pager,' 'leave-behind,' 'objection handling,' 'deal-specific ROI analysis,' 'demo script,' 'talk track,' 'sales playbook,' 'proposal template,' 'buyer persona card,' 'help my sales team,' 'sales materials,' or 'what should I give my sales reps.' Use this for any document or asset that helps a sales team close deals. For competitor comparison pages and battle cards, see competitor-alternatives. For marketing website copy, see copywriting. For cold outreach emails, see cold-email." ;
    oc:hasName "sales-enablement" ;
    oc:hasRequirement oc:req_01fa9a82,
        oc:req_466bb818,
        oc:req_5c8dc866 ;
    oc:impartsKnowledge oc:kn_0b0a7bf2,
        oc:kn_0cd8e198,
        oc:kn_48d794de,
        oc:kn_56703a06,
        oc:kn_6eeabeeb,
        oc:kn_945d8a9e,
        oc:kn_a7a53e8f,
        oc:kn_d5bb1594 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:ProductMarketingContextAvailable ;
    oc:resolvesIntent "create ROI calculator or value proposition",
        "create buyer persona card",
        "create case study brief for sales use",
        "create demo script or talk track",
        "create objection handling document",
        "create one-pager or leave-behind document",
        "create proposal template",
        "create sales deck or pitch deck",
        "create sales playbook",
        "help sales team with materials and collateral" ;
    oc:yieldsState oc:SalesCollateralCreated,
        oc:SalesPlaybookCreated .

oc:kn_0b0a7bf2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating sales decks or pitch decks" ;
    oc:directiveContent "Never build a deck as a feature tour. Follow the storytelling arc: Situation → Complication → Resolution. Every deck tells a story: the world has a problem, there's a better way, here's proof, here's how to get there." ;
    oc:hasRationale "Feature-dump decks cause prospects to disengage because they lack narrative connection to the buyer's specific problems and desired outcomes." ;
    oc:severityLevel "CRITICAL" .

oc:kn_0cd8e198 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing copy for any sales asset" ;
    oc:directiveContent "Every claim must connect to revenue, efficiency, or risk reduction. Replace feature descriptions with outcome statements: 'AI-powered analytics' becomes 'cut reporting time by 80%.'" ;
    oc:hasRationale "Buyers evaluate solutions based on business outcomes, not features. Feature-centric materials fail to create urgency or demonstrate value." ;
    oc:severityLevel "HIGH" .

oc:kn_48d794de a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating proposal templates" ;
    oc:directiveContent "Avoid generic proposals over 10 pages, templated proposals without customized executive summaries, and burying pricing information. Aim for 5-7 pages, transparent pricing, and mirrored language from discovery calls." ;
    oc:hasRationale "Long, generic proposals signal low effort and don't get read. Prospects lose trust when pricing is hidden." ;
    oc:severityLevel "HIGH" .

oc:kn_56703a06 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When customizing any sales asset for a specific buyer or situation" ;
    oc:directiveContent "Tailor all collateral to persona, deal stage, and use case. A deck for a CTO should look different from one for a VP of Sales. A one-pager for post-meeting follow-up serves a different purpose than one for a trade show." ;
    oc:hasRationale "Generic sales materials fail because they don't address the specific concerns, language, and decision criteria of different buyer types." ;
    oc:severityLevel "HIGH" .

oc:kn_6eeabeeb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any sales collateral asset" ;
    oc:directiveContent "Involve sales reps in collateral creation and use their language, not marketing's. If reps rewrite your deck before sending it, you wrote the wrong deck. Test drafts with top performers first." ;
    oc:hasRationale "Sales reps are the end users of enablement materials. Materials that don't match how reps actually sell get abandoned, wasting creation effort." ;
    oc:severityLevel "HIGH" .

oc:kn_945d8a9e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user requests competitor comparison content" ;
    oc:directiveContent "Public-facing competitor comparison pages belong to the competitor-alternatives skill, not sales-enablement. This skill covers internal materials (battle cards, objection handling)." ;
    oc:hasRationale "Public SEO-focused comparison pages require different frameworks than internal sales battle cards and objection handling documents." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a7a53e8f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When designing layout and formatting for any sales document" ;
    oc:directiveContent "Make materials scannable in 3 seconds, not 30. Use bold headers, short bullets, and visual hierarchy. If a rep can't find the answer mid-call, the doc has failed." ;
    oc:hasRationale "Reps use collateral during live conversations. They need instant access to key information without breaking conversational flow." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d5bb1594 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any sales enablement asset creation" ;
    oc:directiveContent "Check for product-marketing-context.md (.agents/ or .claude/) before asking questions. Use existing context and only ask for information not already covered or specific to this task." ;
    oc:hasRationale "Avoids duplicative questions and ensures consistency with existing positioning, messaging, and value propositions already documented." ;
    oc:severityLevel "MEDIUM" .

oc:req_01fa9a82 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Product marketing context (value proposition, differentiators, target personas)" .

oc:req_466bb818 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "B2B sales motions (self-serve, inside sales, field sales)" .

oc:req_5c8dc866 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "file reader for product-marketing-context.md" .

