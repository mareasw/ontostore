                                    oc:contentOrder 1 ;
                                    oc:textContent "Every claim connects to revenue, efficiency, or risk reduction. Features mean nothing without the \"so what.\" Replace \"AI-powered analytics\" with \"cut reporting time by 80%.\"" ] ;
