                                    oc:itemText "**product-marketing-context**: For foundational positioning and messaging" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**pricing-strategy**: For pricing decisions and packaging" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**competitor-alternatives**: For public-facing comparison and alternative pages" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**revops**: For lead lifecycle, scoring, routing, and pipeline management" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**cold-email**: For outbound prospecting emails" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**copywriting**: For marketing website copy" ] ] ;
                    oc:sectionLevel 2 ;
