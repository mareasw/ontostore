oc:kn_18da4099 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing popup functionality" ;
    oc:directiveContent "Popups must be keyboard navigable (Tab, Enter, Esc), implement focus trap while open, be screen reader compatible, and have sufficient color contrast." ;
    oc:hasRationale "Accessibility is both a legal requirement and a conversion factor — excluding users means excluding revenue." ;
    oc:severityLevel "HIGH" .

oc:kn_2806e7c1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting frequency capping rules" ;
    oc:directiveContent "Never show a popup more than once per session. Remember dismissals for 7-30 days before showing again." ;
    oc:hasRationale "Repetitive popups are the number one driver of user complaints and directly increase close rates on subsequent impressions." ;
    oc:severityLevel "HIGH" .

oc:kn_45151a53 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing popup trigger strategy" ;
    oc:directiveContent "Click-triggered popups have the highest conversion rates (10%+) because the user self-selects. Use them for lead magnets, gated content, and demo requests." ;
    oc:hasRationale "Self-initiated popups have zero annoyance factor and attract high-intent users who are already engaged." ;
    oc:severityLevel "MEDIUM" .

oc:kn_56a9ba3c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting page display rules" ;
    oc:directiveContent "Always exclude popups from checkout/conversion flows. Showing popups during purchase increases cart abandonment." ;
    oc:hasRationale "Interrupting a user mid-purchase is the worst possible moment to divert attention from the primary conversion." ;
    oc:severityLevel "CRITICAL" .

oc:kn_853b897f a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When configuring exit-intent popups for mobile users" ;
    oc:directiveContent "Exit intent detection does not work on mobile. Use back-button intercept or scroll-up detection as mobile alternatives." ;
    oc:hasRationale "Mobile devices lack mouse cursor movement, so the standard exit-intent JavaScript detection cannot fire." ;
    oc:severityLevel "HIGH" .

oc:kn_9cf2d286 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring time-based or scroll-based popup triggers" ;
    oc:directiveContent "Never show popups before 30 seconds or at less than 25% scroll depth — early interruption destroys user trust and increases bounce rate." ;
    oc:hasRationale "Too-early triggers signal to users that the site cares more about capturing their data than delivering value." ;
    oc:severityLevel "HIGH" .

oc:kn_a9927679 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing popup decline/dismiss copy" ;
    oc:directiveContent "Never use manipulative decline text like 'No, I don't want to save money' — use neutral language like 'No thanks' or 'Maybe later'." ;
    oc:hasRationale "Guilt-tripping users damages brand perception and erodes trust even among those who convert." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bdb0002c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing CTA button text for popups" ;
    oc:directiveContent "CTA copy should use first person ('Get My Discount' not 'Get Your Discount'), be specific ('Send Me the Guide' not 'Submit'), and be value-focused." ;
    oc:hasRationale "First-person language creates ownership feeling, specific language sets clear expectations, and value-focused copy reinforces the benefit." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c2b027ab a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any popup layout" ;
    oc:directiveContent "The popup visual hierarchy must follow: Headline → Value proposition → Form/CTA → Close option. The close button must always be visible and accessible." ;
    oc:hasRationale "Users who cannot find the close button will bounce from the entire page, not just the popup." ;
    oc:severityLevel "HIGH" .

oc:kn_ddec675e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing mobile popup experiences" ;
    oc:directiveContent "Full-screen overlays on mobile are treated as intrusive interstitials by Google and hurt SEO rankings. Use bottom slide-ups or non-blocking formats instead." ;
    oc:hasRationale "Google penalizes sites that block content access on mobile with full-screen popups before the user can engage." ;
    oc:severityLevel "CRITICAL" .

oc:req_2267b6b2 a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "Popup implementation tool or platform (e.g., OptinMonster, Hello Bar, custom implementation)" .

oc:req_8903859d a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Conversion rate optimization fundamentals" .

