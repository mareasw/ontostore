@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_popup_cro a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "popup-cro" ;
    skos:broader "Conversion rate optimization methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/popup-cro" ;
    oc:contentHash "fc66c252ad3e8b2e0321c405a7be70266e6345c5e7d6966f6b7d32a61e1347f7" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "specializes in popup, modal, overlay, slide-in, and banner design with trigger strategies, copy formulas, and frequency rules that maximize conversions without degrading user experience" ;
    oc:extends oc:skill_page_cro ;
    oc:handlesFailure oc:InsufficientContext,
        oc:InvalidInput ;
    oc:hasArgumentHint "popup type, trigger strategy, and conversion goal (e.g., 'exit-intent email capture popup for SaaS landing page')" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to create or optimize popups, modals, overlays, slide-ins, or banners for conversion purposes. Also use when the user mentions \"exit intent,\" \"popup conversions,\" \"modal optimization,\" \"lead capture popup,\" \"email popup,\" \"announcement banner,\" \"overlay,\" \"collect emails with a popup,\" \"exit popup,\" \"scroll trigger,\" \"sticky bar,\" or \"notification bar.\" Use this for any overlay or interrupt-style conversion element. For forms outside of popups, see form-cro. For general page conversion optimization, see page-cro." ;
    oc:hasName "popup-cro" ;
    oc:impartsKnowledge oc:kn_111d10ac,
        oc:kn_2ddb117e,
        oc:kn_53d41b8d,
        oc:kn_73a3c464,
        oc:kn_993fcba0,
        oc:kn_a1b0d04e,
        oc:kn_accc1b6c,
        oc:kn_ca9411fb ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProductMarketingContextAvailable,
        oc:TrafficSourcesKnown ;
    oc:resolvesIntent "A/B test popup variations",
        "balance popup conversions with user experience",
        "configure popup trigger strategies and frequency capping",
        "create announcement banners and notification bars",
        "create popup for email capture or lead generation",
        "design exit-intent popups to recover abandoning visitors",
        "ensure popup compliance with GDPR and accessibility standards",
        "optimize existing popup conversion rates" ;
    oc:yieldsState oc:ConversionOptimized,
        oc:PopupDesignSpecified .

oc:kn_111d10ac a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting popup trigger strategy" ;
    oc:directiveContent "Match popup trigger type to user intent: scroll-based for blog content, exit-intent for e-commerce, click-triggered for lead magnets, and page-count for multi-page journeys." ;
    oc:hasRationale "Trigger-user intent alignment is the single biggest lever for popup effectiveness — a well-timed popup feels helpful, a mistimed one feels spammy." ;
    oc:severityLevel "HIGH" .

oc:kn_2ddb117e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before providing popup recommendations" ;
    oc:directiveContent "Check for product marketing context file (.agents/product-marketing-context.md or .claude/product-marketing-context.md) before asking the user questions — use existing context and only ask for gaps." ;
    oc:hasRationale "Leveraging existing product marketing context avoids redundant questions and ensures popup copy aligns with established positioning, value props, and audience definitions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_53d41b8d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When configuring popup display rules and audience targeting" ;
    oc:directiveContent "Frequency-cap popups to once per session, remember dismissals for 7-30 days via cookie/localStorage, and exclude already-converted users from seeing popups." ;
    oc:hasRationale "Re-showing popups to users who dismissed or converted is the primary driver of popup annoyance complaints while providing negligible additional conversions." ;
    oc:severityLevel "HIGH" .

oc:kn_73a3c464 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing popup CTA button copy" ;
    oc:directiveContent "Use first-person CTA language ('Get My Discount' not 'Get Your Discount') and specific action-oriented text ('Send Me the Guide' not 'Submit') for higher click-through." ;
    oc:hasRationale "First-person phrasing creates ownership psychology and specific language reduces cognitive friction, both proven to lift popup conversion rates." ;
    oc:severityLevel "MEDIUM" .

oc:kn_993fcba0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring time-based popup triggers" ;
    oc:directiveContent "Never show a popup within the first 5 seconds of page load — this is perceived as aggressive interruption and dramatically increases bounce rates." ;
    oc:hasRationale "Users haven't had time to understand the page value yet; premature popups signal spamminess and erode trust before value is established." ;
    oc:severityLevel "HIGH" .

oc:kn_a1b0d04e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing mobile popup experiences" ;
    oc:directiveContent "Full-screen overlays on mobile hurt Google rankings due to intrusive interstitial penalties — use bottom slide-ups or banners instead." ;
    oc:hasRationale "Google explicitly penalizes sites that show full-screen popups before content is accessible on mobile, directly impacting organic search traffic." ;
    oc:severityLevel "CRITICAL" .

oc:kn_accc1b6c a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When evaluating popup performance or setting targets" ;
    oc:directiveContent "Benchmark popup conversion rates: email capture popups typically 2-5%, exit-intent popups 3-10%, click-triggered popups 10%+ (self-selected audience)." ;
    oc:hasRationale "Without benchmarks, teams either over-optimise working popups or under-invest in broken ones — these ranges provide realistic expectation-setting." ;
    oc:severityLevel "LOW" .

oc:kn_ca9411fb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing popup decline/close copy" ;
    oc:directiveContent "Never use manipulative decline options like 'No, I don't want to save money' — use neutral, respectful text like 'No thanks' or 'Maybe later'." ;
    oc:hasRationale "Guilt-tripping decline text damages brand perception and violates the core principle of respecting the user, even if it marginally improves short-term conversion." ;
    oc:severityLevel "MEDIUM" .

