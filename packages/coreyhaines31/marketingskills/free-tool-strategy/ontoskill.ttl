oc:skill_coreyhaines31_marketingskills_free_tool_strategy a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "free-tool-strategy" ;
    skos:broader "Marketing strategy" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/free-tool-strategy" ;
    oc:contentHash "44cd63c635b984f5bfafaa5bae4967a38f124f19e8af8971f0d8accb44314772" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "plans and evaluates free tools built for lead generation, SEO traffic, and brand awareness using engineering-as-marketing principles" ;
    oc:handlesFailure oc:InsufficientBusinessContext,
        oc:InvalidInput ;
    oc:hasArgumentHint "tool concept or business context for tool planning" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to plan, evaluate, or build a free tool for marketing purposes — lead generation, SEO value, or brand awareness. Also use when the user mentions \"engineering as marketing,\" \"free tool,\" \"marketing tool,\" \"calculator,\" \"generator,\" \"interactive tool,\" \"lead gen tool,\" \"build a tool for leads,\" \"free resource,\" \"ROI calculator,\" \"grader tool,\" \"audit tool,\" \"should I build a free tool,\" or \"tools for lead gen.\" Use this whenever someone wants to build something useful and give it away to attract leads or earn links. For downloadable content lead magnets (ebooks, checklists, templates), see lead-magnets." ;
    oc:hasName "free-tool-strategy" ;
    oc:impartsKnowledge oc:kn_0c8fdda3,
        oc:kn_0f068c7f,
        oc:kn_3a29d87b,
        oc:kn_3a3b1d53,
        oc:kn_3b66273f,
        oc:kn_5ac4b78c,
        oc:kn_d4099f98 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProductContextAvailable ;
    oc:resolvesIntent "build a free tool for lead generation",
        "choose between build vs buy for a free tool",
        "decide on tool gating strategy",
        "evaluate free tool ideas",
        "generate free tool ideas for marketing",
        "optimize free tool for SEO and leads",
        "plan a free marketing tool",
        "score a free tool concept for viability" ;
    oc:yieldsState oc:FreeToolStrategyDefined,
        oc:ToolConceptValidated .

oc:kn_0c8fdda3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding on lead capture gating strategy for a free tool" ;
    oc:directiveContent "Prefer partial gating (basic results free, detailed report requires email) as the default lead capture approach. It balances usage volume with lead capture, unlike fully gated (kills usage) or fully ungated (no leads)." ;
    oc:hasRationale "Partial gating lets users experience enough value to trust the tool, creating a natural motivation to exchange their email for the deeper insights." ;
    oc:severityLevel "MEDIUM" .

oc:kn_0f068c7f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to pursue a specific free tool idea" ;
    oc:directiveContent "Use the 8-factor evaluation scorecard (search demand, audience match, uniqueness, product path, build feasibility, maintenance burden, link-building potential, share-worthiness) rated 1-5 each. Scores 25+ are strong candidates, 15-24 are promising, below 15 should be reconsidered." ;
    oc:hasRationale "A structured scorecard prevents subjective bias and ensures all critical viability dimensions are weighed before investing engineering resources." ;
    oc:severityLevel "HIGH" .

oc:kn_3a29d87b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user asks about lead generation content that is not an interactive tool" ;
    oc:directiveContent "Distinguish between downloadable content lead magnets (ebooks, checklists, templates) and interactive free tools. This skill covers interactive tools; refer to lead-magnets for downloadable content." ;
    oc:hasRationale "Conflating lead magnets with free tools leads to wrong strategic advice — they have different build requirements, SEO profiles, and conversion mechanisms." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3a3b1d53 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When brainstorming free tool concepts from scratch" ;
    oc:directiveContent "Start ideation from audience pain points: what they Google, what manual processes are tedious, what they need before buying, and what information they wish they had. Then validate against search demand, uniqueness, lead quality, and build feasibility." ;
    oc:hasRationale "Pain-point-driven ideation ensures the tool addresses real demand rather than being a vanity project; validation prevents building something nobody uses." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3b66273f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoping the first version of a free marketing tool" ;
    oc:directiveContent "Do not include account creation, saving results, advanced features, perfect design, or every edge case in the initial MVP of a free tool. Ship only core functionality, essential UX, and basic lead capture." ;
    oc:hasRationale "Over-scoping the MVP delays launch, increases maintenance burden, and postpones the learning that comes from real user interaction with the tool." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5ac4b78c a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any free tool strategy consultation" ;
    oc:directiveContent "Check for and read the product marketing context file (.agents/product-marketing-context.md or .claude/product-marketing-context.md) before asking questions. Use that context and only ask for information not already covered." ;
    oc:hasRationale "Leveraging existing product context avoids redundant questions and ensures tool strategy is grounded in the product's actual positioning and audience." ;
    oc:severityLevel "HIGH" .

oc:kn_d4099f98 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating or ideating any free tool concept" ;
    oc:directiveContent "A free tool must solve a real problem, be adjacent to the core product, do one thing well, and justify its investment via lead value × expected leads > build cost + maintenance." ;
    oc:hasRationale "Tools that fail any of these four principles either don't attract users, don't convert to customers, are too complex to adopt, or aren't worth the engineering investment." ;
    oc:severityLevel "HIGH" .

