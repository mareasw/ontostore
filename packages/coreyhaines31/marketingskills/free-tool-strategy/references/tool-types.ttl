oc:kn_65971439 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When brainstorming tool concepts for a specific industry" ;
    oc:directiveContent "For SaaS: build ROI calculators or readiness assessments. For Agencies: build benchmark tools or scoping calculators. For E-commerce: build product finders or size calculators. For Developer Tools: build code snippet libraries or API playgrounds. For Finance: build financial calculators or comparison tools." ;
    oc:hasRationale "Industry-specific patterns align tool functionality with what users in that vertical actually need and search for." .

oc:kn_83f70b26 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which free tool type to build" ;
    oc:directiveContent "Match tool type to user intent: Calculators for numeric decisions, Generators for tangible outputs, Analyzers for evaluations, Testers for pass/fail checks, Libraries for reference, Interactive Educational for learning." ;
    oc:hasRationale "Each tool type has distinct strengths — mismatching type to intent reduces engagement and conversion." .

oc:kn_975291a0 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When evaluating whether a tool concept fits its type" ;
    oc:directiveContent "Successful free tools produce: personalized output (calculators), immediately usable output (generators), curiosity-driven engagement (analyzers), bookmark-worthy repeat usage (testers), sustained SEO traffic (libraries), and deep engagement (interactive educational)." ;
    oc:hasRationale "These are the proven engagement patterns for each category — if your concept doesn't deliver these, it may be the wrong type." .

oc:kn_9fdfba68 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When implementing tool features for lead capture and brand building" ;
    oc:directiveContent "Always include 'powered by' branding on calculators, email gating for premium generator outputs, actionable recommendations in analyzers, fix instructions in testers, and community submissions in libraries." ;
    oc:hasRationale "These tactical additions convert tool utility into marketing outcomes — brand impressions, email captures, and authority signals." .

oc:kn_a388aaa2 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When choosing a free tool type for a marketing project" ;
    oc:directiveContent "1. Identify user intent (decide, create, evaluate, check, reference, learn) 2. Match to tool type (Calculator, Generator, Analyzer, Tester, Library, Interactive Educational) 3. Validate with industry-specific examples 4. Apply type-specific implementation tips" ;
    oc:stepOrder 1 .

oc:kn_b1d7d743 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When documenting or presenting a tool concept" ;
    oc:directiveContent """## {ToolType}
**Best for**: {use_case}
**Examples**: {example_list}
**Why it works**: {value_props}
**Implementation tips**: {tips}
**Industry fit**: {industries}""" ;
    oc:templateVariables "ToolType",
        "example_list",
        "industries",
        "tips",
        "use_case",
        "value_props" .

oc:kn_e56501bd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any free tool type" ;
    oc:directiveContent "Avoid complex inputs in calculators, non-shareable results, slow testers, or libraries that aren't searchable/filterable." ;
    oc:hasRationale "These implementation failures directly undermine the core value props of each tool type — simplicity, shareability, speed, and discoverability." ;
    oc:severityLevel "HIGH" .

oc:req_45db1483 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Marketing funnel basics" .

