oc:skill_coreyhaines31_marketingskills_free_tool_strategy_tool_types a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "tool-types" ;
    skos:broader "taxonomy of marketing tool archetypes" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/free-tool-strategy" ;
    oc:contentHash "3869418a784ec94e95528dbe3f39cd2571cff6f7649e5e0be28d675be61d5a3f" ;
    oc:differentia "categorizes free marketing tools into six types (calculators, generators, analyzers, testers, libraries, interactive educational) with industry-specific examples and implementation guidance" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_free_tool_strategy ;
    oc:hasArgumentHint "industry or use case context (e.g., 'SaaS', 'e-commerce', 'finance')" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_06e26ab0,
        oc:kn_766446ee,
        oc:kn_bb332622,
        oc:kn_d60c9f62,
        oc:kn_fe4efe8f ;
    oc:isUserInvocable true ;
    oc:nature "reference" ;
    oc:resolvesIntent "brainstorm free tool ideas by industry",
        "choose the right free tool type for marketing",
        "evaluate which tool archetype fits a marketing goal",
        "get tool type examples and implementation tips" ;
    oc:yieldsState oc:ToolTypeSelected .

oc:kn_06e26ab0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing calculators, generators, or analyzers" ;
    oc:directiveContent "Avoid building tools with overly complex inputs, opaque calculations, or outputs that require further work before being useful." ;
    oc:hasRationale "Friction in input or output kills conversion; users abandon tools that feel complicated or don't deliver immediate value." ;
    oc:severityLevel "HIGH" .

oc:kn_766446ee a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating or designing any free marketing tool" ;
    oc:directiveContent "Prioritize tools with personalized output, shareability, and repeat usage potential — these qualities drive organic distribution and sustained traffic." ;
    oc:hasRationale "Tools that produce personalized, share-worthy results generate backlinks, word-of-mouth, and return visits — compounding their marketing value." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bb332622 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a library/resource tool type" ;
    oc:directiveContent "Libraries and resource tools require ongoing maintenance (regular updates, community submissions) to retain SEO value and traffic." ;
    oc:hasRationale "Stale libraries lose search rankings and user trust; the commitment to maintenance must be factored into the decision." ;
    oc:severityLevel "LOW" .

oc:kn_d60c9f62 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When brainstorming free tool concepts for a specific industry vertical" ;
    oc:directiveContent "Use industry-specific tool archetypes as ideation starting points: SaaS favors ROI calculators and readiness quizzes; agencies favor benchmark tools and proposal generators; e-commerce favors product finders and size calculators; developer tools favor code playgrounds and snippet libraries; finance favors financial calculators and planners." ;
    oc:hasRationale "Industry-aligned tool types resonate with target audiences because they address familiar, high-frequency pain points in that domain." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fe4efe8f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which type of free tool to build" ;
    oc:directiveContent "Match tool type to user intent: calculators for numeric decisions, generators for tangible output, analyzers for evaluating existing assets, testers for validation, libraries for reference, interactive educational for learning." ;
    oc:hasRationale "Each tool type aligns with a distinct psychological driver and use case; mismatching type to intent reduces engagement and conversion." ;
    oc:severityLevel "HIGH" .

