oc:skill_coreyhaines31_marketingskills_ad_creative a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ad-creative" ;
    skos:broader "Creative production framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/ad-creative" ;
    oc:contentHash "edf1a6b1498c370e51d289b49342c479a01b46b82ad628d3030f94bbecb3d0ff" ;
    oc:dependsOnSkill oc:skill_paid_ads ;
    oc:differentia "Generates, iterates, and scales ad copy and visual assets across multiple paid advertising platforms using angle-based variation and performance-data-driven optimization" ;
    oc:handlesFailure oc:InvalidInput,
        oc:PlatformSpecViolation ;
    oc:hasAlias "Facebook ad copy",
        "Google ad headlines",
        "LinkedIn ad text",
        "RSA headlines",
        "ad copy",
        "ad iterations",
        "ad variations",
        "bulk ad copy",
        "creative testing" ;
    oc:hasAllowedTool "Bash",
        "Glob",
        "Read",
        "Write" ;
    oc:hasArgumentHint "platform, product/offer description, audience, and optionally performance data for iteration" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to generate, iterate, or scale ad creative — headlines, descriptions, primary text, or full ad variations — for any paid advertising platform. Also use when the user mentions 'ad copy variations,' 'ad creative,' 'generate headlines,' 'RSA headlines,' 'bulk ad copy,' 'ad iterations,' 'creative testing,' 'ad performance optimization,' 'write me some ads,' 'Facebook ad copy,' 'Google ad headlines,' 'LinkedIn ad text,' or 'I need more ad variations.' Use this whenever someone needs to produce ad copy at scale or iterate on existing ads. For campaign strategy and targeting, see paid-ads. For landing page copy, see copywriting." ;
    oc:hasName "ad-creative" ;
    oc:hasRequirement oc:req_0fa8c9c0,
        oc:req_55d50894,
        oc:req_6c8b3939,
        oc:req_7c3b5f32,
        oc:req_cffb64d3,
        oc:req_fe48f4bb ;
    oc:impartsKnowledge oc:kn_191a98db,
        oc:kn_29614e28,
        oc:kn_4832e97d,
        oc:kn_56e72128,
        oc:kn_5b969b7a,
        oc:kn_6dbe1167,
        oc:kn_783c379c,
        oc:kn_b9bb1699,
        oc:kn_cc6faaec,
        oc:kn_ee5d3f7a ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:ProductContextAvailable ;
    oc:resolvesIntent "analyze winning and losing ad patterns",
        "create Meta Facebook Instagram ad copy",
        "create TikTok and Twitter X ad creative",
        "create ad copy variations for any platform",
        "create ad visual concepts with generative AI tools",
        "generate Google RSA headlines and descriptions",
        "generate ad headlines and descriptions",
        "iterate on ad creative from performance data",
        "produce bulk ad creative at scale",
        "validate ad copy against platform character limits",
        "write LinkedIn ad text for B2B audiences" ;
    oc:yieldsState oc:AdCopyValidated,
        oc:AdCreativeGenerated .

oc:kn_191a98db a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating multi-platform ad creative" ;
    oc:directiveContent "When creating for multiple platforms simultaneously, start with the most restrictive format (Google Search headlines at 30 chars) to force the tightest messaging, then expand to Meta headlines (40 chars), LinkedIn intro text (150 chars), and Meta primary text (125+ chars). This cascading approach ensures the core message works everywhere." ;
    oc:hasRationale "Starting with the tightest constraint ensures the core value proposition is sharp enough for any platform. Expanding from tight to loose is easier than cutting down verbose copy." ;
    oc:severityLevel "MEDIUM" .

oc:kn_29614e28 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating ad copy variations" ;
    oc:directiveContent "Do not generate variations that all sound the same with minor word swaps. Vary angles, not just word choice. Avoid generic descriptions like 'Learn more about our solution' which waste the slot." ;
    oc:hasRationale "Near-identical variations test nothing meaningful and waste creative slots. Each variation should test a distinct hypothesis about what motivates the audience." ;
    oc:severityLevel "HIGH" .

oc:kn_4832e97d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating ad creative from scratch" ;
    oc:directiveContent "Before writing individual headlines, establish 3-5 distinct angles — each tapping into a different motivation (pain point, outcome, social proof, curiosity, comparison, urgency, identity, contrarian). Then generate multiple variations per angle varying word choice, specificity, tone, and structure." ;
    oc:hasRationale "Angle-based variation ensures creative diversity that tests different psychological motivations rather than superficially different wording of the same message, leading to more meaningful test results." ;
    oc:severityLevel "HIGH" .

oc:kn_56e72128 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating ad creative test results" ;
    oc:directiveContent "Allow 1,000+ impressions before judging creative performance. Do not retire ads too early. Change only one variable per test cycle to isolate what drives performance changes." ;
    oc:hasRationale "Low-impression data is statistically unreliable. Changing multiple variables simultaneously makes it impossible to attribute performance differences to specific creative choices." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5b969b7a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before delivering any ad creative output" ;
    oc:directiveContent "Every piece of ad copy must be validated against the target platform's character limits before delivery. Platforms truncate without warning. Google RSA headlines: 30 chars, descriptions: 90 chars. Meta primary text: 125 visible, headline: 40, description: 30. LinkedIn intro: 150, headline: 70, description: 100. TikTok ad text: 80 recommended. Twitter/X tweet: 280." ;
    oc:hasRationale "Oversized copy gets silently truncated by platforms, breaking the message and wasting ad spend on incomplete or nonsensical text." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6dbe1167 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating Google Responsive Search Ads" ;
    oc:directiveContent "RSA headlines must make sense independently and in any combination. Never write headlines that only work when paired with specific other headlines. Google randomly combines any 3 headlines from the pool." ;
    oc:hasRationale "Google's machine learning assembles headline combinations algorithmically. Headlines that depend on context from other headlines will produce nonsensical ads in many combinations." ;
    oc:severityLevel "CRITICAL" .

oc:kn_783c379c a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When the user's request scope extends beyond creative generation" ;
    oc:directiveContent "This skill is for ad creative generation and iteration only. Campaign strategy, targeting, budgets, and platform optimization belong to the paid-ads skill. Landing page copy belongs to the copywriting skill. When users request strategy, defer to paid-ads rather than attempting campaign planning." ;
    oc:hasRationale "Keeping skill boundaries clear ensures users get specialized expertise for each aspect of their advertising rather than diluted guidance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b9bb1699 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any ad copy" ;
    oc:directiveContent "Strong headlines use specificity over vagueness ('Cut reporting time 75%' not 'Save time'), benefits over features ('Ship code faster' not 'CI/CD pipeline'), active voice, and include numbers when possible. Include at least 2-3 CTA headlines in RSA sets. Descriptions should complement headlines, not repeat them — add proof points, handle objections, reinforce CTAs." ;
    oc:hasRationale "Specific, benefit-driven, active copy consistently outperforms vague feature lists in click-through and conversion rates across all platforms." ;
    oc:severityLevel "HIGH" .

oc:kn_cc6faaec a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "At the beginning of every ad creative task" ;
    oc:directiveContent "Before starting, check if .agents/product-marketing-context.md or .claude/product-marketing-context.md exists and read it for product context. Then gather platform/format, product/offer, audience/intent, performance data (if iterating), and constraints (brand voice, compliance, mandatory elements)." ;
    oc:hasRationale "The product marketing context file contains essential brand positioning, voice guidelines, and value propositions that ensure ad creative is on-brand without requiring redundant user input." ;
    oc:severityLevel "HIGH" .

oc:kn_ee5d3f7a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When the user provides performance data for existing ads" ;
    oc:directiveContent "When iterating from performance data, follow this loop: analyze top performers to identify winning themes/structures/word patterns, analyze worst performers to find patterns that fail, then generate new variations that double down on winners with fresh phrasing, extend winning angles, test 1-2 new angles, and avoid patterns from underperformers." ;
    oc:hasRationale "Data-driven iteration systematically amplifies what works and eliminates what doesn't, rather than relying on gut feelings which are less reliable than metrics." ;
    oc:severityLevel "HIGH" .

