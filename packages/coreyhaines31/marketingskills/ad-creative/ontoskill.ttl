                                            oc:itemOrder 2 ;
                                            oc:itemText "Benefits (\"Ship code faster\") over features (\"CI/CD pipeline\")" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Specific (\"Cut reporting time 75%\") over vague (\"Save time\")" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
