    dcterms:description "**Build templates** in Remotion based on winning creative patterns" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_9f75b0abfbdbf15c a oc:WorkflowStep ;
