        oc:Skill ;
    dcterms:identifier "platform-specs" ;
    skos:broader "specification reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/ad-creative" ;
    oc:contentHash "de69753161071a8d3e4d244280562810a6c4d6ae2696c5a21940f983abd0aa8e" ;
    oc:differentia "catalogs character limits, format requirements, and creative best practices for major ad platforms (Google, Meta, LinkedIn, TikTok, Twitter/X)" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_ad_creative ;
    oc:hasArgumentHint "platform name (e.g., \"google\", \"meta\", \"linkedin\", \"tiktok\", \"twitter\")" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_83f021ab,
        oc:kn_855359ae,
        oc:kn_90816229,
        oc:kn_91d5767d,
        oc:kn_920ca578,
        oc:kn_c8614414 ;
    oc:isUserInvocable false ;
    oc:nature "reference" ;
    oc:resolvesIntent "adapt ad creative across multiple platforms",
        "look up ad character limits for any platform",
        "plan headline and description mix for responsive search ads",
        "understand platform-specific creative guidelines",
        "validate ad copy against platform constraints" ;
    oc:yieldsState oc:PlatformConstraintsLoaded .

oc:kn_83f021ab a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring Google Responsive Search Ads" ;
    oc:directiveContent "Do not over-pin headlines in Google RSAs. Pinning reduces Google's ability to machine-learn optimal combinations. Only pin brand name to position 1 if required by brand guidelines, and pin strongest CTA to position 2 or 3. Leave most headlines unpinned." ;
    oc:hasRationale "Over-pinning constrains Google's ML optimization, reducing ad performance by limiting the combinations the system can test." ;
    oc:severityLevel "MEDIUM" .

oc:kn_855359ae a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing ad copy for any platform" ;
    oc:directiveContent "Adapt tone to platform norms: LinkedIn favors professional language with job-specific terminology and data points (avoid consumer hype); Twitter/X favors conversational, casual tone with short sentences; TikTok favors native, unpolished content over polished ads." ;
    oc:hasRationale "Tone mismatch with platform culture causes audience disengagement and wasted ad spend." ;
    oc:severityLevel "MEDIUM" .

oc:kn_90816229 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating ad copy for multiple platforms simultaneously" ;
    oc:directiveContent "When creating for multiple platforms, start with the most restrictive format (Google Search headlines at 30 chars) and cascade outward to less restrictive formats. This ensures the core message works everywhere before being enriched for platforms with more space." ;
    oc:hasRationale "Starting with the tightest constraint guarantees message clarity and portability; expanding is easier than compressing." ;
    oc:severityLevel "HIGH" .

oc:kn_91d5767d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating Meta or TikTok ad creative" ;
    oc:directiveContent "Front-load the hook in Meta primary text within the first 125 characters (truncation point). For TikTok, the first 2 seconds of video determine whether users keep watching. For Meta Stories/Reels, keep text under 72 characters." ;
    oc:hasRationale "Platform truncation and user attention spans mean only the earliest visible content reliably reaches the audience." ;
    oc:severityLevel "HIGH" .

oc:kn_920ca578 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when writing or validating ad copy" ;
    oc:directiveContent "Spaces count as characters on all platforms. Emojis count as 1-2 characters. URLs in body text count against limits. Dynamic keyword insertion ({KeyWord:default}) can exceed limits — always set safe defaults." ;
    oc:hasRationale "Unexpected character counting can cause ads to be truncated or rejected, wasting creative effort and campaign time." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c8614414 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Google Responsive Search Ad copy" ;
    oc:directiveContent "Use a balanced headline mix for Google RSAs: 3-4 keyword-focused, 3-4 benefit-focused, 2-3 social proof, 2-3 CTA-focused, 1-2 differentiators, and 1 brand name across 15 headlines. Descriptions should pair benefit+proof, feature+outcome, social proof+CTA, and urgency+CTA." ;
    oc:hasRationale "A diverse asset mix gives Google's ML more combinations to test, improving optimization and relevance across different search queries." ;
    oc:severityLevel "HIGH" .

