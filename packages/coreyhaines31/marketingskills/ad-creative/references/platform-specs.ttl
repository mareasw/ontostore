oc:kn_513ae0f7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When counting characters for any platform" ;
    oc:directiveContent "Spaces count as characters on all platforms. Emojis count as 1-2 chars depending on platform. Dynamic keyword insertion {KeyWord:default} can exceed limits — set safe defaults. Always verify in platform ad preview before launching." ;
    oc:hasRationale "Hidden character costs from spaces, emojis, and dynamic insertion can cause unexpected truncation or rejection" ;
    oc:severityLevel "HIGH" .

oc:kn_6a476a6c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building Google Responsive Search Ads" ;
    oc:directiveContent "For Google RSA headline mix (15 total): 3-4 keyword-focused, 3-4 benefit-focused, 2-3 social proof, 2-3 CTA-focused, 1-2 differentiators, 1 brand name. Pin sparingly — only brand to position 1 or strongest CTA to position 2-3." ;
    oc:hasRationale "A diverse headline mix gives Google's ML more optimization surface; pinning reduces machine learning flexibility" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7f4a7519 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating Google Responsive Search Ads" ;
    oc:directiveContent "Google RSA headlines: 30 chars max, 3 minimum, 15 max. Descriptions: 90 chars max, 2 minimum, 4 max. Google selects up to 3 headlines and 2 descriptions per auction." ;
    oc:hasRationale "Exceeding character limits causes rejection; insufficient assets limit Google's ability to optimize combinations" ;
    oc:severityLevel "CRITICAL" .

oc:kn_8a52c0f8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating Meta (Facebook/Instagram) ads" ;
    oc:directiveContent "Meta primary text is truncated after ~125 chars (max 2,200). Headline truncated after ~40 chars (max 255). Stories/Reels overlay text should be under 72 chars." ;
    oc:hasRationale "Text beyond truncation points is invisible in most placements, so the hook must be front-loaded within the first 125 characters" ;
    oc:severityLevel "HIGH" .

oc:kn_9c24a3c3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating platform-specific creative" ;
    oc:directiveContent "LinkedIn requires professional tone with job-specific language, statistics, and data points. Avoid consumer-style hype. First-person peer testimonials resonate. TikTok requires native-feeling content, vertical video (9:16), text overlays for sound-off viewers, and trending formats. Twitter/X favors conversational casual tone with 1-2 hashtags max." ;
    oc:hasRationale "Each platform has distinct audience expectations; tone mismatch causes ad fatigue and low engagement" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c8ea52ec a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adapting creative across multiple platforms simultaneously" ;
    oc:directiveContent "When creating for multiple platforms, start with the most restrictive format (Google Search headlines at 30 chars), then expand to Meta headlines (40), LinkedIn intro text (150), and Meta primary text (125+)." ;
    oc:hasRationale "This cascading approach ensures the core message works everywhere before being enriched for platforms with more space" ;
    oc:severityLevel "HIGH" .

_:ref_125af3f6d2366558 a oc:WorkflowStep ;
    dcterms:description "**Expand to LinkedIn intro text** (150 chars) — add context and proof" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

