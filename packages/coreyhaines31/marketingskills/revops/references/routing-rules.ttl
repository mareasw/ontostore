@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_revops_routing_rules a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "routing-rules" ;
    skos:broader "Revenue operations reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/revops" ;
    oc:contentHash "9057c207550ff289e84d6b25ca9d38b436c98a517e0aa4f30c2ff8f09f5d8370" ;
    oc:differentia "Provides decision trees, platform-specific configurations, territory routing, ABM routing, and speed-to-lead benchmarks for lead assignment" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_revops ;
    oc:handlesFailure oc:NoRepAvailable,
        oc:RoutingConflict,
        oc:SLABreached ;
    oc:hasArgumentHint "platform (e.g., hubspot, salesforce) and routing type (round-robin, territory, ABM)" ;
    oc:hasCategory "revops" ;
    oc:impartsKnowledge oc:kn_3d25498d,
        oc:kn_6c2489e3,
        oc:kn_7b3381d1,
        oc:kn_8b40e5ed,
        oc:kn_a34a5aba ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CRMConfigured,
        oc:SalesTeamDefined ;
    oc:resolvesIntent "configure lead routing rules",
        "create territory-based routing",
        "design lead assignment decision trees",
        "implement ABM routing for named accounts",
        "optimize speed-to-lead response times",
        "set up round-robin assignment" ;
    oc:yieldsState oc:LeadRoutingConfigured,
        oc:SpeedToLeadEnabled .

oc:kn_3d25498d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring round-robin or territory routing in any CRM" ;
    oc:directiveContent "Never route leads to reps who are on PTO, at capacity, or have a full pipeline without an exclusion mechanism." ;
    oc:hasRationale "Assigning leads to unavailable reps directly destroys speed-to-lead performance and lets leads go cold." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6c2489e3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up speed-to-lead automation in any CRM platform" ;
    oc:directiveContent "Implement an escalation chain for uncontacted MQLs: 5 min alert original rep → 15 min alert backup → 30 min alert manager → 60 min reassign to next available rep." ;
    oc:hasRationale "Leads contacted within 5 minutes are 21x more likely to qualify. Escalation chains ensure no lead exceeds the SLA window without action." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7b3381d1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or configuring any lead routing decision tree" ;
    oc:directiveContent "Route to the most specific match first, then fall back to general assignment. Named accounts → enterprise by ACV → PLG specialists → territory → round-robin default." ;
    oc:hasRationale "Specific routing ensures high-value leads get specialized handling while ensuring no lead falls through the cracks via general fallback." ;
    oc:severityLevel "HIGH" .

oc:kn_8b40e5ed a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "Ongoing measurement after routing rules are live" ;
    oc:directiveContent "Track speed-to-lead weekly using: average time to first contact, median time to first contact, % leads contacted within SLA (target 90%+), and conversion rate by response time." ;
    oc:hasRationale "Without weekly measurement, SLA degradation goes unnoticed. Response time beyond 24 hours results in 60% lower qualification than baseline, making weekly monitoring essential." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a34a5aba a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring ABM/named account routing rules" ;
    oc:directiveContent "When multiple contacts from the same ABM target account engage, all contacts must route to the same account owner. Trigger a buying committee alert at 3+ contacts." ;
    oc:hasRationale "Splitting account contacts across multiple reps fragments the deal, creates confusion, and signals disorganization to the prospect. Multiple contacts engaging simultaneously is a strong buying signal." ;
    oc:severityLevel "HIGH" .

