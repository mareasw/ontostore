oc:skill_coreyhaines31_marketingskills_revops_scoring_models a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "scoring-models" ;
    skos:broader "lead scoring knowledge base" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/revops" ;
    oc:contentHash "923062ddfd0e0eab5fbdb51286c484afd3fee6d42b10eb91b40a39e764b1beb5" ;
    oc:dependsOnSkill oc:skill_revops ;
    oc:differentia "provides explicit scoring templates, example models by business type, negative signals, and threshold calibration guidance for building and maintaining lead scoring systems" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_revops ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_3d441251,
        oc:kn_57b11fd1,
        oc:kn_9e5e2fce,
        oc:kn_a18f0de0,
        oc:kn_a43ac55e,
        oc:kn_d284f498 ;
    oc:isUserInvocable false ;
    oc:nature "reference" ;
    oc:resolvesIntent "assign point values to lead attributes",
        "build fit and engagement scoring criteria",
        "calibrate lead scoring thresholds",
        "design lead scoring model",
        "diagnose lead scoring model problems" .

oc:kn_3d441251 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining engagement signal scoring" ;
    oc:directiveContent "Engagement scores must include time-based decay rules (e.g., -5 per week for pricing page visit, -5 per month for webinar attendance) to prevent stale signals from inflating scores." ;
    oc:hasRationale "Without decay, a lead who visited the pricing page 6 months ago would retain the same score as one who visited yesterday, misrepresenting actual buying intent." ;
    oc:severityLevel "MEDIUM" .

oc:kn_57b11fd1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting initial scoring thresholds" ;
    oc:directiveContent "Set the MQL threshold at the score just below where 80% of closed-won deals would have been captured, then validate against closed-lost to check for false positives." ;
    oc:hasRationale "Data-driven threshold setting based on historical win/loss data prevents arbitrary cutoffs that either flood sales with low-quality leads or filter out good ones." ;
    oc:severityLevel "HIGH" .

oc:kn_9e5e2fce a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building scoring criteria for B2B leads" ;
    oc:directiveContent "Apply negative scoring to disqualify low-value leads: -50 for competitor domains, -30 for careers-page-only visitors, -30 for student emails, -100 for spam complaints." ;
    oc:hasRationale "Negative signals prevent sales waste on leads that will never convert; spam complaints also create compliance and deliverability risks." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a18f0de0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing a new lead scoring model" ;
    oc:directiveContent "Weight fit vs. engagement based on go-to-market motion: PLG should weight engagement 70/30, enterprise should weight fit 60/40, mid-market should balance 50/50." ;
    oc:hasRationale "The relative importance of fit versus engagement varies dramatically by sales motion and ACV; misweighting leads to false positives or missed opportunities." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a43ac55e a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When monitoring scoring model health" ;
    oc:directiveContent "If MQL-to-SQL acceptance drops below 30%, sales consistently rejects MQLs, or high-scoring leads don't convert while low-scoring ones do, the model needs immediate recalibration." ;
    oc:hasRationale "These warning signs indicate the scoring model has drifted from reality and is producing unreliable signals for the sales team." ;
    oc:severityLevel "HIGH" .

oc:kn_d284f498 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Ongoing scoring model maintenance" ;
    oc:directiveContent "Never set and forget a scoring model — recalibrate monthly for PLG, quarterly for mid-market and enterprise based on actual MQL-to-closed outcomes." ;
    oc:hasRationale "Scoring models decay as markets, products, and buyer behaviors change; stale models produce misleading lead quality signals." ;
    oc:severityLevel "HIGH" .

