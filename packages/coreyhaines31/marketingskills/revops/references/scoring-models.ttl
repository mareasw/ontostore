oc:kn_15189495 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing score calculation logic" ;
    oc:directiveContent "Engagement scores decay over time (e.g., pricing page visit -5 per week, webinar -5 per month). Product usage signals also decay on inactivity. Only top-of-funnel actions like demo requests and trial signups carry no decay." ;
    oc:hasRationale "Decay ensures leads who showed interest but went cold don't retain artificially high scores, keeping the model responsive to current engagement." ;
    oc:severityLevel "HIGH" .

oc:kn_1b275211 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When documenting a scoring model" ;
    oc:directiveContent """## {Model Name} ({ACV Range})
**Weight: {fit_pct}% fit / {engagement_pct}% engagement**
**Fit criteria:** {fit_attributes_and_points}
**Engagement criteria:** {engagement_signals_and_points}
**Negative:** {negative_signals}
**MQL threshold:** {threshold} points
**Recalibration:** {frequency}""" ;
    oc:templateVariables "ACV Range",
        "Model Name",
        "engagement_pct",
        "engagement_signals_and_points",
        "fit_attributes_and_points",
        "fit_pct",
        "frequency",
        "negative_signals",
        "threshold" .

oc:kn_2d87989d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When establishing a new scoring model's threshold" ;
    oc:directiveContent "Set the initial MQL threshold just below where 80% of closed-won deals would have scored based on retroactive analysis." ;
    oc:hasRationale "This balances capturing most good leads (recall) with filtering out poor leads (precision)." .

oc:kn_531fa976 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing a new lead scoring model" ;
    oc:directiveContent "Lead scoring models must weight fit vs. engagement differently based on ACV: PLG favors 30% fit / 70% engagement; Enterprise favors 60% fit / 40% engagement; Mid-market is balanced 50/50." ;
    oc:hasRationale "Higher ACV deals require stronger fit signals because the cost of pursuing unqualified leads is much greater; PLG relies on product usage as the primary conversion signal." ;
    oc:severityLevel "HIGH" .

oc:kn_548de885 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When setting initial scoring thresholds" ;
    oc:directiveContent "1. Pull closed-won data from last 6-12 months 2. Retroactively score each deal using proposed model 3. Find natural breakpoint separating wins from losses 4. Set threshold just below where 80% of closed-won would qualify 5. Validate against closed-lost and tighten if many false positives" ;
    oc:stepOrder 1 .

oc:kn_580c1b8c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning scoring model maintenance" ;
    oc:directiveContent "Recalibration frequency must match business type: monthly for PLG/high-volume, quarterly for mid-market, quarterly-to-semi-annually for enterprise." ;
    oc:hasRationale "Calibration frequency must align with deal cycle length and data volume — enterprise has fewer deals and longer cycles, so more frequent calibration yields unreliable insights." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b520d2c0 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before setting or calibrating scoring thresholds" ;
    oc:directiveContent "Requires access to CRM closed-won/closed-lost deal data from the last 6-12 months for threshold calibration" .

oc:kn_cdeff19e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When recalibrating an existing scoring model" ;
    oc:directiveContent "1. Pull MQL-to-closed data for calibration period 2. Compare scored MQLs vs actual outcomes (identify false positives and false negatives) 3. Adjust attribute weights based on correlation with wins 4. Adjust threshold based on MQL volume (raise if too high, lower if too low) 5. Document changes and communicate to sales team" ;
    oc:stepOrder 2 .

oc:kn_ce8eaf65 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "During ongoing scoring model operation" ;
    oc:directiveContent "Warning signs requiring recalibration: MQL-to-SQL rate below 30%, sales rejecting MQLs consistently, high-scoring leads not converting, MQL volume spiking without revenue, or new product/market changes." ;
    oc:hasRationale "These signals indicate the model has drifted from reality and is no longer predictive of outcomes." ;
    oc:severityLevel "HIGH" .

oc:kn_cff421e5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting initial MQL thresholds or during recalibration" ;
    oc:directiveContent "Do not set scoring thresholds without retroactively validating against historical closed-won and closed-lost data. Do not treat scoring as set-and-forget." ;
    oc:hasRationale "Unvalidated thresholds lead to high false positive/negative rates, causing sales to distrust the scoring system and ignore MQLs." ;
    oc:severityLevel "CRITICAL" .

oc:kn_db558002 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building any scoring model" ;
    oc:directiveContent "Always include negative scoring signals: competitor email domain (-50), student email (-30), spam complaint (-100), hard bounce (-50), careers-page-only visitor (-30). These prevent unqualified leads from inflating scores." ;
    oc:hasRationale "Negative signals are critical for filtering out noise — job seekers, competitors researching you, students, and bad data all inflate pipeline if not penalized." ;
    oc:severityLevel "HIGH" .

