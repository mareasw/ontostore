@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_revops_lifecycle_definitions a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "lifecycle-definitions" ;
    skos:broader "Reference template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/revops" ;
    oc:contentHash "210c730e815b82f6c06d67482e667c40f9ae2179886e318ccb25f1e31e09ca1f" ;
    oc:differentia "defines lead lifecycle stages with entry/exit criteria, MQL scoring models by business type, SLAs, and rejection/recycling workflows for revenue operations" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_revops ;
    oc:handlesFailure oc:ConfigurationConflict,
        oc:InvalidInput ;
    oc:hasArgumentHint "business-type (PLG, Sales-Led, Mid-Market) or lifecycle-stage-name" ;
    oc:hasCategory "revops" ;
    oc:impartsKnowledge oc:kn_23a79244,
        oc:kn_6b419d5f,
        oc:kn_ab3b20fc,
        oc:kn_cd8210a9,
        oc:kn_fea00fd7 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CRMAvailable,
        oc:SalesTeamDefined ;
    oc:resolvesIntent "build lifecycle stage definitions for CRM",
        "configure MQL scoring criteria",
        "define lead lifecycle stages",
        "establish lead rejection and recycling workflows",
        "set SLA targets for lead handoffs" ;
    oc:yieldsState oc:LifecycleStagesDefined,
        oc:MQLCriteriaConfigured,
        oc:SLATemplatesReady .

oc:kn_23a79244 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-engaging recycled leads that show renewed intent" ;
    oc:directiveContent "When a recycled lead re-crosses the MQL threshold, it must be flagged as 'Recycled MQL' and tracked separately from first-time MQLs." ;
    oc:hasRationale "Separate tracking prevents inflated MQL counts and reveals whether recycling workflows actually recover revenue." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6b419d5f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When a sales rep rejects or disqualifies a lead" ;
    oc:directiveContent "Every rejected MQL must include a reason code from a predefined taxonomy (FIT, ENG, QUAL) that determines the recycle action." ;
    oc:hasRationale "Structured rejection codes enable systematic recycling, prevent re-sending unqualified leads to sales, and reveal pipeline quality patterns." ;
    oc:severityLevel "HIGH" .

oc:kn_ab3b20fc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting or customizing MQL scoring templates" ;
    oc:directiveContent "Weight fit score at 60% for enterprise/sales-led motions and engagement score at 60% for PLG motions when configuring MQL criteria." ;
    oc:hasRationale "Enterprise deals require stronger firmographic fit before sales investment; PLG deals indicate intent through product usage signals." ;
    oc:severityLevel "HIGH" .

oc:kn_cd8210a9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a lead transitions from MQL to SQL or gets rejected" ;
    oc:directiveContent "Marketing nurture sequences must be paused upon MQL creation and replaced with sales-owned outreach; resuming nurture requires explicit recycling." ;
    oc:hasRationale "Concurrent marketing and sales outreach creates disjointed customer experience and makes attribution impossible." ;
    oc:severityLevel "HIGH" .

oc:kn_fea00fd7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining or modifying any lifecycle stage" ;
    oc:directiveContent "Lifecycle stages must have explicit, mutually exclusive entry and exit criteria so no lead can exist in multiple stages simultaneously." ;
    oc:hasRationale "Ambiguous stage boundaries cause CRM data corruption, misaligned handoffs, and inaccurate pipeline reporting." ;
    oc:severityLevel "CRITICAL" .

