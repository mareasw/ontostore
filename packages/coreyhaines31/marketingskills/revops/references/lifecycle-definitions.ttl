oc:kn_35592224 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before implementing lifecycle definitions" ;
    oc:directiveContent "Verify CRM is configured with lifecycle stage field, scoring fields, and SLA escalation rules before deploying these definitions." ;
    oc:hasRationale "Missing CRM fields or automation rules will cause silent failures in stage transitions" .

oc:kn_37a227fe a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing rejection and recycling workflows" ;
    oc:directiveContent "When a lead is recycled, reset the engagement score to baseline but preserve the fit score. Track recycled MQL conversion rate separately." ;
    oc:hasRationale "Preserving fit score avoids re-enrichment costs while resetting engagement prevents stale signals from inflating scores" .

oc:kn_4a1060a1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting MQL qualification thresholds" ;
    oc:directiveContent "MQL thresholds differ: PLG = 65 points, Sales-Led = 70 points, Mid-Market = 60 points." ;
    oc:hasRationale "Threshold calibration accounts for different pipeline volumes and deal sizes across business models" .

oc:kn_633dc72d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring MQL scoring for a business type" ;
    oc:directiveContent "PLG models weight engagement at 60% and fit at 40%; Sales-Led/Enterprise inverts this to 60% fit / 40% engagement; Mid-Market balances at 50/50." ;
    oc:hasRationale "Scoring weight alignment with go-to-market motion prevents over- or under-qualifying leads" ;
    oc:severityLevel "HIGH" .

oc:kn_6b4c9ec2 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When handling rejected leads" ;
    oc:directiveContent "Leads rejected with FIT-02 (wrong industry) or QUAL-03 (not a real project) should be archived, not recycled." ;
    oc:hasRationale "Recycling fundamentally unqualified leads wastes nurture capacity and distorts recycled-MQL metrics" .

oc:kn_ad47bfb2 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-deploying or updating lifecycle definitions" ;
    oc:directiveContent "Lifecycle stage definitions are declarative templates — applying them multiple times produces the same configuration." ;
    oc:hasRationale "Safe to re-run setup without corrupting existing data" .

oc:kn_f77d7723 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining or modifying any lifecycle stage" ;
    oc:directiveContent "Every lifecycle stage must have explicit entry criteria, exit criteria, owner, and actions on entry." ;
    oc:hasRationale "Ambiguous stage definitions cause CRM data corruption and broken reporting" .

