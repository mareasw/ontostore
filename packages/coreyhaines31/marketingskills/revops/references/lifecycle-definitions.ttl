    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Complete templates for lead lifecycle stages, MQL criteria by business type, SLAs, and rejection/recycling workflows." ] ;
            oc:hasSubsection [ a oc:Section ;
