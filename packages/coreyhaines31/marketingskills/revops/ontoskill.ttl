oc:skill_coreyhaines31_marketingskills_revops a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "revops" ;
    skos:broader "Revenue operations framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/revops" ;
    oc:contentHash "5072b5b86eca69a8802341b9dfdf81effd13c649123d78d777c0dad2af77b6bf" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "that designs and optimizes the systems connecting marketing, sales, and customer success into a unified revenue engine through lead lifecycle management, scoring, routing, pipeline governance, and CRM automation" ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput,
        oc:MissingContext ;
    oc:hasArgumentHint "description of RevOps problem area (e.g., lead scoring, pipeline management, handoff process, data hygiene)" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "When the user wants help with revenue operations, lead lifecycle management, or marketing-to-sales handoff processes. Also use when the user mentions 'RevOps,' 'revenue operations,' 'lead scoring,' 'lead routing,' 'MQL,' 'SQL,' 'pipeline stages,' 'deal desk,' 'CRM automation,' 'marketing-to-sales handoff,' 'data hygiene,' 'leads aren't getting to sales,' 'pipeline management,' 'lead qualification,' or 'when should marketing hand off to sales.' Use this for anything involving the systems and processes that connect marketing to revenue. For cold outreach emails, see cold-email. For email drip campaigns, see email-sequence. For pricing decisions, see pricing-strategy." ;
    oc:hasName "revops" ;
    oc:impartsKnowledge oc:kn_5e005993,
        oc:kn_62d7cae2,
        oc:kn_63091a0f,
        oc:kn_75d5d7b9,
        oc:kn_7f1e5aad,
        oc:kn_8854434d,
        oc:kn_9a8c9b0c,
        oc:kn_a9488dfa,
        oc:kn_cffb523b,
        oc:kn_e844f4d1 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady,
        oc:ProductContextAvailable ;
    oc:resolvesIntent "build RevOps metrics dashboards",
        "build lead scoring models",
        "configure lead routing rules",
        "create deal desk approval processes",
        "design lead lifecycle stages",
        "establish SLAs between marketing and sales",
        "fix data hygiene and enrichment",
        "manage pipeline stages and hygiene",
        "optimize marketing-to-sales handoff",
        "set up CRM automation workflows" ;
    oc:yieldsState oc:LeadLifecycleDefined,
        oc:PipelineStagesEstablished,
        oc:RevOpsFrameworkDesigned,
        oc:RoutingRulesConfigured,
        oc:ScoringModelCreated .

oc:kn_5e005993 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "At the beginning of every RevOps task" ;
    oc:directiveContent "Before starting any RevOps engagement, gather: GTM motion, ACV range, sales cycle length, current tech stack, current lead management state, and specific goals." ;
    oc:hasRationale "RevOps solutions are highly context-dependent — PLG vs. sales-led, $500 ACV vs. $50K ACV require fundamentally different lifecycle designs, scoring weights, and routing rules." ;
    oc:severityLevel "HIGH" .

oc:kn_62d7cae2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting speed-to-lead SLAs and routing automation" ;
    oc:directiveContent "Contact leads within 5 minutes for 21x higher qualification likelihood. After 30 minutes, conversion drops 10x; after 24 hours, leads are effectively cold." ;
    oc:hasRationale "Response time is the single biggest factor in lead conversion. Fast follow-up captures buyers at peak interest." ;
    oc:severityLevel "HIGH" .

oc:kn_63091a0f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "After launching a scoring model and on an ongoing basis" ;
    oc:directiveContent "Recalibrate lead scoring models quarterly (monthly for PLG/high-volume). Track false positive and false negative rates to detect model drift." ;
    oc:hasRationale "Buyer behavior changes over time; a static scoring model becomes progressively less accurate, leading to declining MQL-to-SQL conversion rates." ;
    oc:severityLevel "MEDIUM" .

oc:kn_75d5d7b9 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After deploying lifecycle, scoring, or routing changes to CRM" ;
    oc:directiveContent "After implementing RevOps changes, validate by checking: stage conversion rates improved, SLA compliance above 90%, pipeline coverage at 3-4x quota, and MQL-to-SQL acceptance rate above 30%." ;
    oc:hasRationale "These benchmarks indicate whether the system is functioning correctly; deviations signal configuration errors or flawed assumptions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7f1e5aad a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any RevOps architecture or data flow" ;
    oc:directiveContent "Establish a single source of truth — one CRM as the canonical system of record for every lead and account. All other systems sync to it." ;
    oc:hasRationale "If data lives in multiple places, it will conflict, leading to duplicated efforts, misrouted leads, and inaccurate reporting." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8854434d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining MQL criteria and thresholds" ;
    oc:directiveContent "An MQL requires BOTH fit score AND engagement score — neither alone is sufficient. A perfect-fit company that never engages is not an MQL." ;
    oc:hasRationale "Single-dimension qualification produces false positives (engaged non-buyers) or false negatives (silent high-value accounts), wasting sales effort." ;
    oc:severityLevel "HIGH" .

oc:kn_9a8c9b0c a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When sales rejects an MQL or a lead fails to qualify" ;
    oc:directiveContent "Rejected MQLs should be recycled to a separate nurture sequence (not the original one) with reason codes. Reset engagement score but preserve fit score. Track recycled-to-MQL conversion separately." ;
    oc:hasRationale "Recycling with reason codes enables targeted re-engagement and prevents wasting high-fit leads that simply had bad timing." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a9488dfa a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing lifecycle stage transitions and team workflows" ;
    oc:directiveContent "Measure every handoff between teams with an SLA, a tracking mechanism, and someone accountable for follow-through. Marketing-to-sales, SDR-to-AE, AE-to-CS — each handoff is a potential revenue leak." ;
    oc:hasRationale "Unmeasured handoffs are where revenue leaks occur silently. Without accountability and tracking, leads fall through cracks between teams." ;
    oc:severityLevel "HIGH" .

oc:kn_cffb523b a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Before implementing any automation or CRM workflow" ;
    oc:directiveContent "Define stage definitions, scoring criteria, and routing rules on paper before building any CRM workflows. Automating a broken process just creates broken results faster." ;
    oc:hasRationale "Premature automation encodes flawed logic into systems, making it harder to diagnose and fix root cause issues later." ;
    oc:severityLevel "HIGH" .

oc:kn_e844f4d1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building or recalibrating lead scoring models" ;
    oc:directiveContent "Never weight content downloads equally with high-intent signals like pricing page visits or demo requests. Research behavior (downloading ebooks) is not buying intent." ;
    oc:hasRationale "Over-weighting top-of-funnel engagement inflates MQL volume with low-quality leads that sales will reject, eroding trust in the scoring system." ;
    oc:severityLevel "HIGH" .

