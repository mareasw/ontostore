@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_page_cro a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "page-cro" ;
    skos:broader "Conversion rate optimization framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/page-cro" ;
    oc:contentHash "c3c991b6c4f8c2abe00b199d8b73263758245d1b43626b67377ccff2a7c3ac2e" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "that systematically analyzes marketing pages across seven dimensions to provide prioritized, actionable recommendations for improving conversion rates" ;
    oc:handlesFailure oc:InsufficientPageInfo,
        oc:UnclearConversionGoal,
        oc:WrongSkillScope ;
    oc:hasArgumentHint "page URL or page description with conversion goal" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to optimize, improve, or increase conversions on any marketing page — including homepage, landing pages, pricing pages, feature pages, or blog posts. Also use when the user says \"CRO,\" \"conversion rate optimization,\" \"this page isn't converting,\" \"improve conversions,\" \"why isn't this page working,\" \"my landing page sucks,\" \"nobody's converting,\" \"low conversion rate,\" \"bounce rate is too high,\" \"people leave without signing up,\" or \"this page needs work.\" Use this even if the user just shares a URL and asks for feedback — they probably want conversion help. For signup/registration flows, see signup-flow-cro. For post-signup activation, see onboarding-cro. For forms outside of signup, see form-cro. For popups/modals, see popup-cro." ;
    oc:hasName "page-cro" ;
    oc:impartsKnowledge oc:kn_055e31a5,
        oc:kn_1f085c32,
        oc:kn_a0b3bc5f,
        oc:kn_a27ebd9f,
        oc:kn_a5f44db0,
        oc:kn_cb8240f9,
        oc:kn_f31e5a71 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:PageIdentified,
        oc:ProductMarketingContextLoaded ;
    oc:resolvesIntent "analyze landing page performance",
        "audit pricing page effectiveness",
        "diagnose conversion rate drops",
        "get CRO recommendations for a marketing page",
        "improve blog post CTAs",
        "improve homepage conversions",
        "optimize feature page conversions",
        "optimize page conversion rate" ;
    oc:yieldsState oc:CRORecommendationsGenerated,
        oc:ExperimentHypothesesGenerated,
        oc:PageCROAnalysisComplete .

oc:kn_055e31a5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining skill scope for a CRO request" ;
    oc:directiveContent "This skill covers homepage, landing page, pricing, feature, and blog page CRO. It does NOT cover signup/registration flows (use signup-flow-cro), post-signup activation (use onboarding-cro), non-signup forms (use form-cro), or popups/modals (use popup-cro)." ;
    oc:hasRationale "Specific CRO domains have specialized frameworks. Using the wrong skill produces generic, less actionable advice." ;
    oc:severityLevel "HIGH" .

oc:kn_1f085c32 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user reports a conversion rate decline after a change" ;
    oc:directiveContent "For diagnostic situations (e.g., conversions dropped after redesign), systematically compare against all seven framework dimensions to identify regression causes, and recommend reverting high-risk changes while testing others." ;
    oc:hasRationale "Redesigns often regress multiple dimensions simultaneously. A systematic comparison ensures no regression cause is missed, and reverting high-risk changes prevents further loss while testing." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a0b3bc5f a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When validating CRO analysis completeness" ;
    oc:directiveContent "Successful output includes: page type and conversion goal identification, analysis across all applicable framework dimensions, structured recommendations in four tiers, specific copy alternatives with rationale, and cross-references to specialized CRO skills when appropriate." ;
    oc:hasRationale "Incomplete analysis misses conversion opportunities. These indicators ensure the output is thorough, actionable, and properly scoped." .

oc:kn_a27ebd9f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any page CRO analysis" ;
    oc:directiveContent "Analyze pages across seven dimensions in strict priority order: Value Proposition Clarity > Headline Effectiveness > CTA Placement/Copy/Hierarchy > Visual Hierarchy > Trust Signals > Objection Handling > Friction Points." ;
    oc:hasRationale "Impact decreases from top to bottom. Value proposition clarity and headline effectiveness drive the largest conversion gains, so they must be assessed first." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a5f44db0 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When delivering CRO recommendations" ;
    oc:directiveContent "Structure output into four tiers: Quick Wins (easy, immediate impact), High-Impact Changes (bigger effort, significant improvement), Test Ideas (A/B test hypotheses), and Copy Alternatives (2-3 options for headlines/CTAs with rationale)." ;
    oc:hasRationale "Tiered output lets the user prioritize effort and gives them both immediate actions and long-term experiment ideas, rather than an unstructured list of suggestions." .

oc:kn_cb8240f9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any CRO analysis" ;
    oc:directiveContent "Always check for product marketing context file (.agents/product-marketing-context.md) before asking questions. Use existing context and only request information not already covered." ;
    oc:hasRationale "Avoids redundant questions and leverages already-documented product knowledge for more relevant recommendations." ;
    oc:severityLevel "HIGH" .

oc:kn_f31e5a71 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning a CRO engagement" ;
    oc:directiveContent "Never recommend changes without first identifying the page type, primary conversion goal, and traffic source context. These three inputs fundamentally shape the analysis." ;
    oc:hasRationale "A homepage for cold organic traffic requires a completely different approach than a landing page for paid traffic. Skipping this step leads to misaligned recommendations." ;
    oc:severityLevel "CRITICAL" .

