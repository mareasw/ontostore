            oc:workflowId "page-cro-regression-diagnosis" ;
            oc:workflowName "Conversion Regression Diagnosis" ] ;
    oc:impartsKnowledge oc:kn_104f2de0,
        oc:kn_1a007faf,
        oc:kn_2c9e7c7e,
        oc:kn_2eb4b395,
        oc:kn_423a959b,
        oc:kn_5be53b40,
        oc:kn_6bf6a423,
        oc:kn_d4d3bac3,
        oc:kn_e9cea8cf ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:PageContentAccessible ;
    oc:resolvesIntent "analyze marketing page for conversion issues",
        "diagnose why a page isn't converting",
        "get CRO recommendations for any marketing page",
        "improve landing page conversion rate",
        "optimize page conversions",
        "review page for conversion friction" ;
    oc:yieldsState oc:CROAnalysisComplete,
        oc:RecommendationsPrioritized .

oc:kn_104f2de0 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "At the start of every CRO engagement" ;
    oc:directiveContent "Before analyzing, identify three critical inputs: (1) Page Type (homepage, landing, pricing, feature, blog, about), (2) Primary Conversion Goal (signup, demo, purchase, subscribe, download, contact sales), (3) Traffic Context (organic, paid, email, social)." ;
    oc:hasRationale "Page type determines which specific CRO framework to apply; conversion goal and traffic source shape all recommendations" ;
    oc:severityLevel "HIGH" .

oc:kn_1a007faf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying page-specific CRO strategies" ;
    oc:directiveContent "Each page type has a distinct CRO strategy: Homepage — serve both 'ready to buy' and 'still researching' visitors; Landing Page — message match with traffic source, single CTA, remove navigation; Pricing — recommended plan indication, clear comparison; Feature — connect feature to benefit with use cases; Blog — contextual CTAs matching content topic." ;
    oc:hasRationale "Generic CRO advice fails because each page type serves a different visitor intent and context" ;
    oc:severityLevel "MEDIUM" .

oc:kn_2c9e7c7e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or evaluating CTA buttons" ;
    oc:directiveContent "CTA button copy should communicate value, not just action. Weak: 'Submit', 'Sign Up', 'Learn More'. Strong: 'Start Free Trial', 'Get My Report', 'See Pricing'." ;
    oc:hasRationale "Value-oriented CTA copy reduces ambiguity and increases click-through by telling visitors what they get, not what they must do" ;
    oc:severityLevel "MEDIUM" .

oc:kn_2eb4b395 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When diagnosing a conversion regression after page changes" ;
    oc:directiveContent "When conversions drop after a redesign, systematically check for: lost trust signals, weakened value proposition, CTA hierarchy changes, added friction, and broken message match with traffic sources. Recommend reverting high-risk changes while testing others." ;
    oc:hasRationale "Redesigns often break what was working; systematic comparison against the 7-dimension framework identifies regression causes" ;
    oc:severityLevel "MEDIUM" .

oc:kn_423a959b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any CRO analysis" ;
    oc:directiveContent "Analyze pages in strict order of impact: (1) Value Proposition Clarity, (2) Headline Effectiveness, (3) CTA Placement/Copy/Hierarchy, (4) Visual Hierarchy, (5) Trust Signals, (6) Objection Handling, (7) Friction Points." ;
    oc:hasRationale "Value proposition clarity has the highest impact on conversions; ordering ensures most impactful issues are addressed first" ;
    oc:severityLevel "HIGH" .

oc:kn_5be53b40 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When placing social proof on any page" ;
    oc:directiveContent "Place trust signals (logos, testimonials, case study numbers, review scores) near CTAs and after benefit claims to reinforce decisions at critical moments." ;
    oc:hasRationale "Trust signals are most effective when they appear at decision points where visitors need reassurance" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6bf6a423 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user's problem extends beyond page-level CRO" ;
    oc:directiveContent "Defer to specialized skills when scope crosses boundaries: signup-flow-cro for signup processes, form-cro for non-signup forms, popup-cro for modals/overlays, copywriting for complete rewrites." ;
    oc:hasRationale "Specialized skills have deeper frameworks for their specific domains; wrong skill produces shallow advice" ;
    oc:severityLevel "HIGH" .

oc:kn_d4d3bac3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating value proposition and headlines" ;
    oc:directiveContent "Avoid feature-focused messaging, vague cleverness, and trying to say everything at once — always prioritize benefit-focused, specific, clear value propositions." ;
    oc:hasRationale "Visitors decide within 5 seconds whether to stay; clarity beats cleverness for conversion" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e9cea8cf a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any CRO analysis" ;
    oc:directiveContent "Never provide CRO recommendations without first checking for product-marketing-context.md (.agents/ or .claude/) — read existing context before asking questions." ;
    oc:hasRationale "Avoids redundant questions and ensures recommendations align with existing product positioning" ;
    oc:severityLevel "HIGH" .

