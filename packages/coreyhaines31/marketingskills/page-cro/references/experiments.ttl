oc:skill_coreyhaines31_marketingskills_page_cro_experiments a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "experiments" ;
    skos:broader "experiment idea catalog" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/page-cro" ;
    oc:contentHash "bbcc356c0af36cfaa4556bf9e929deac30c65cafb37f909d7c51d4777fe254ca" ;
    oc:differentia "organizes CRO A/B test hypotheses by page type for systematic conversion optimization" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_page_cro ;
    oc:handlesFailure oc:InsufficientTrafficForTesting,
        oc:NoConversionBaseline ;
    oc:hasArgumentHint "page-type (e.g., homepage, pricing, demo-request, landing-page, feature-page, resource-page, cross-page)" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_39eb79fe,
        oc:kn_4621f486,
        oc:kn_7a983615,
        oc:kn_85c68e69,
        oc:kn_944985c0 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:AnalyticsBaselineEstablished,
        oc:PageTypeIdentified ;
    oc:resolvesIntent "find A/B test hypotheses for specific page types",
        "generate experiment ideas for page CRO",
        "identify CRO tests for homepage, pricing, demo, landing, feature pages",
        "plan conversion optimization experiments" ;
    oc:yieldsState oc:ExperimentHypothesesGenerated,
        oc:TestPlanCreated .

oc:kn_39eb79fe a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When selecting or proposing any A/B test from this catalog" ;
    oc:directiveContent "Every experiment must have a clear hypothesis tied to a measurable conversion metric — never test without a stated hypothesis." ;
    oc:hasRationale "Hypothesis-driven testing ensures learnings accumulate over time rather than producing random, uninterpretable results." ;
    oc:severityLevel "HIGH" .

oc:kn_4621f486 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning experiments for any page type" ;
    oc:directiveContent "Start with hero section and CTA experiments before testing secondary elements like trust badges or footer optimization." ;
    oc:hasRationale "Above-the-fold elements and primary CTAs have the highest visibility and typically the largest impact on conversion rates." .

oc:kn_7a983615 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning multiple experiments from this catalog for the same page" ;
    oc:directiveContent "Do not run multiple experiments on the same page section simultaneously — isolate variables to attribute results correctly." ;
    oc:hasRationale "Concurrent tests on the same section create interaction effects that make it impossible to determine which change caused the observed result." ;
    oc:severityLevel "HIGH" .

oc:kn_85c68e69 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building an experiment roadmap from this catalog" ;
    oc:directiveContent "Prioritize experiments by page type and section based on traffic volume and current conversion rate — high-traffic, low-conversion areas yield the biggest impact." ;
    oc:hasRationale "Statistical significance is reached faster on high-traffic pages, and low-conversion areas have the most room for improvement." .

oc:kn_944985c0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting experiments from the Cross-Page Experiments section" ;
    oc:directiveContent "Cross-page (site-wide) experiments require significantly more traffic to reach statistical significance than single-page tests — plan traffic requirements accordingly." ;
    oc:hasRationale "Site-wide tests affect all visitors and may dilute measured impact across diverse page contexts, requiring larger sample sizes." ;
    oc:severityLevel "MEDIUM" .

