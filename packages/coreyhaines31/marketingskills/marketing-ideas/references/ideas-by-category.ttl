@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_marketing_ideas_ideas_by_category a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ideas-by-category" ;
    skos:broader "Marketing idea taxonomy" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/marketing-ideas" ;
    oc:contentHash "fac44ef0ea24a3035d85bd11096adef408497ea073ad156933f2d356d482dde2" ;
    oc:differentia "Organizes 139 proven marketing approaches into 18 categories for ideation and strategy selection" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_marketing_ideas ;
    oc:hasArgumentHint "optional category name or tactic number (1-139)" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_538e2825,
        oc:kn_8cff0a7c,
        oc:kn_93bea5c9,
        oc:kn_9ebed4ac,
        oc:kn_eadb9c2d ;
    oc:isUserInvocable true ;
    oc:nature "Reference" ;
    oc:resolvesIntent "browse marketing ideas by category",
        "discover unconventional marketing approaches",
        "find marketing tactics for a specific channel",
        "get marketing inspiration organized by type",
        "identify marketing strategies for specific contexts" .

oc:kn_538e2825 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user wants to 'do all the marketing ideas'" ;
    oc:directiveContent "Do not attempt to execute all 139 ideas simultaneously — prioritize based on available resources, audience fit, and stage of company." ;
    oc:hasRationale "Resource dilution across too many tactics leads to poor execution everywhere; focused effort on 3-5 well-chosen tactics outperforms scattered attempts at all 139" ;
    oc:severityLevel "HIGH" .

oc:kn_8cff0a7c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting marketing tactics from the taxonomy" ;
    oc:directiveContent "Marketing ideas should be evaluated by category fit — match the tactic to the channel and audience context rather than applying tactics randomly." ;
    oc:hasRationale "The 18-category structure exists to help agents and users navigate 139 ideas efficiently by narrowing to relevant domains" ;
    oc:severityLevel "MEDIUM" .

oc:kn_93bea5c9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using ideas from this list to build marketing plans" ;
    oc:directiveContent "This is a reference catalog, not a playbook — each of the 139 items is a starting point that requires separate strategic planning and execution skill." ;
    oc:hasRationale "Users may mistake listing an idea as equivalent to having a strategy; each idea needs its own implementation plan" ;
    oc:severityLevel "HIGH" .

oc:kn_9ebed4ac a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When discussing or documentating specific marketing ideas" ;
    oc:directiveContent "Use the numbered reference system (1-139) for precise cross-referencing and tracking — each number maps to exactly one tactic in exactly one category." ;
    oc:hasRationale "The numeric ID system enables unambiguous communication about specific tactics without confusion from similar names" ;
    oc:severityLevel "LOW" .

oc:kn_eadb9c2d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building a multi-channel marketing strategy" ;
    oc:directiveContent "Combine ideas across categories for compound effect — e.g., pair Programmatic SEO (#4) with Template Marketing (#98), or Free Tools (#15) with Chrome Extensions (#19)." ;
    oc:hasRationale "The most effective marketing programs stack complementary tactics from different categories rather than relying on a single approach" ;
    oc:severityLevel "MEDIUM" .

