oc:kn_317960f5 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying ideas to non-SaaS contexts" ;
    oc:directiveContent "All 139 ideas assume a software/SaaS product context with digital distribution. Physical products, brick-and-mortar, or highly regulated industries may require adaptation." ;
    oc:hasRationale "The catalog was built for SaaS marketing and its tactics reference digital channels, subscription metrics, and software-specific growth patterns" ;
    oc:severityLevel "MEDIUM" .

oc:kn_5c36dc1e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user has no specific channel preference" ;
    oc:directiveContent "The densest categories by idea count are Paid Advertising (12 ideas), Product-Led Growth (10 ideas), Content Formats (13 ideas), and Unconventional & Creative (13 ideas) — these represent the broadest tactical surface areas for marketing." ;
    oc:hasRationale "Larger categories indicate more proven variations exist, offering more options to test" .

oc:kn_7e0c8021 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When recommending or browsing marketing ideas" ;
    oc:directiveContent "Ideas are organized into 17 distinct categories spanning Content & SEO (#1-10), Competitor & Comparison (#11-13), Free Tools & Engineering (#14-22), Paid Advertising (#23-34), Social Media & Community (#35-44), Email Marketing (#45-53), Partnerships & Programs (#54-64), Events & Speaking (#65-72), PR & Media (#73-76), Launches & Promotions (#77-86), Product-Led Growth (#87-96), Content Formats (#97-109), Unconventional & Creative (#110-122), Platforms & Marketplaces (#123-130), International & Localization (#131-132), Developer & Technical (#133-136), and Audience-Specific (#137-139)." ;
    oc:hasRationale "Category structure enables rapid filtering by channel type and strategic approach, matching user intent to relevant tactics" .

oc:kn_90f35f19 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When presenting ideas from this catalog to users" ;
    oc:directiveContent "Each idea follows a consistent format: **[Idea Name]** - [One-sentence description]. [Optional elaboration sentence with specific examples or tools]." ;
    oc:hasRationale "Consistent formatting enables quick scanning and comparison across all 139 ideas" ;
    oc:templateVariables "Idea Name",
        "description",
        "elaboration" .

oc:kn_9c884466 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When referencing specific ideas from this catalog" ;
    oc:directiveContent "Each of the 139 ideas has a unique number (1-139) used for cross-referencing across the parent skill's stage, budget, and use-case guidance." ;
    oc:hasRationale "Numbered references allow concise citations (e.g., '#93 Viral Loops') without repeating full descriptions" ;
    oc:severityLevel "MEDIUM" .

