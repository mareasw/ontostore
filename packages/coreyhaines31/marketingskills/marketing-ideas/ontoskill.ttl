@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_marketing_ideas a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "marketing-ideas" ;
    skos:broader "Marketing strategy advisor" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/marketing-ideas" ;
    oc:contentHash "44796a5f5dc66e8ff5c249d670667d3030bfc132299b7a56c2b7643aee19fa9b" ;
    oc:differentia "that curates and recommends from a library of 139 proven marketing ideas organized by category, stage, budget, and use case for SaaS products" ;
    oc:extends oc:skill_product_marketing_context ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "product description, stage, budget, and growth goal" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user needs marketing ideas, inspiration, or strategies for their SaaS or software product. Also use when the user asks for 'marketing ideas,' 'growth ideas,' 'how to market,' 'marketing strategies,' 'marketing tactics,' 'ways to promote,' 'ideas to grow,' 'what else can I try,' 'I don't know how to market this,' 'brainstorm marketing,' or 'what marketing should I do.' Use this as a starting point whenever someone is stuck or looking for inspiration on how to grow. For specific channel execution, see the relevant skill (paid-ads, social-content, email-sequence, etc.)." ;
    oc:hasName "marketing-ideas" ;
    oc:impartsKnowledge oc:kn_19f6fa48,
        oc:kn_339e3d21,
        oc:kn_49670726,
        oc:kn_4e228499,
        oc:kn_ea6790e6 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "brainstorm marketing ideas",
        "discover unconventional marketing approaches",
        "find growth strategies for SaaS",
        "get marketing inspiration by stage or budget",
        "identify marketing tactics for specific use cases" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_19f6fa48 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When product-marketing-context.md is not available or incomplete" ;
    oc:directiveContent "Before generating ideas, gather or confirm: product type, target audience, current stage, marketing budget, team size, what has already been tried, and competitor tactics they admire." ;
    oc:hasRationale "Sufficient context is required to filter 139 ideas down to the most relevant 3-5 recommendations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_339e3d21 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user expresses a specific growth goal or use case" ;
    oc:directiveContent "For 'need leads fast' scenarios, prioritize paid channels (Google Ads, LinkedIn Ads) and outbound tactics. For authority building, recommend longer-term plays (conference speaking, podcasts, original research). For PLG companies, focus on viral loops, referral programs, and product-embedded growth." ;
    oc:hasRationale "Matching idea categories to stated goals dramatically improves relevance and likelihood of execution." ;
    oc:severityLevel "MEDIUM" .

oc:kn_49670726 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user's request overlaps with a specialized skill's domain" ;
    oc:directiveContent "Do not attempt detailed execution of ideas that have dedicated skills (referral-program, email-sequence, programmatic-seo, competitor-alternatives, free-tool-strategy, paid-ads, social-content). Instead, recommend the idea briefly and defer to the specialized skill for implementation." ;
    oc:hasRationale "Specialized skills contain deeper implementation guidance; this skill's role is curation and recommendation, not detailed execution of every tactic." ;
    oc:severityLevel "HIGH" .

oc:kn_4e228499 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When selecting which marketing ideas to recommend" ;
    oc:directiveContent "Filter ideas by the user's specific constraints: stage (pre-launch, early, growth, scale), budget (free, low, medium, high), and timeline (quick wins, medium-term, long-term). Suggest 3-5 most relevant ideas rather than overwhelming with the full catalog." ;
    oc:hasRationale "Contextual filtering ensures recommendations are actionable and realistic for the user's actual resources and situation." ;
    oc:severityLevel "HIGH" .

oc:kn_ea6790e6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before generating any marketing ideas" ;
    oc:directiveContent "Always check for product-marketing-context.md (.agents/ or .claude/) before asking questions. Use existing context and only ask for information not already covered." ;
    oc:hasRationale "Avoids redundant questions and leverages already-documented product knowledge for more relevant recommendations." ;
    oc:severityLevel "HIGH" .

