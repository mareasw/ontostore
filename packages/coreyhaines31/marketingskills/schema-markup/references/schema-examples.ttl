oc:kn_25dfe481 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any JSON-LD schema markup" ;
    oc:directiveContent "Always include @context: 'https://schema.org' and @type as the two required fields in every JSON-LD block. Use specific types over generic ones (e.g., BlogPosting or NewsArticle over Article when applicable)." .

oc:kn_526cc50f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling in schema markup properties" ;
    oc:directiveContent "All URLs in schema markup (url, @id, logo, image, sameAs) must be absolute URLs including protocol. Dates must use ISO 8601 format (e.g., 2024-01-15T08:00:00+00:00)." ;
    oc:severityLevel "HIGH" .

oc:kn_564c4ffe a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a page needs multiple schema types (e.g., homepage with Organization + WebSite + BreadcrumbList)" ;
    oc:codeLanguage "json" ;
    oc:directiveContent """Use @graph to combine multiple schema types on a single page, referencing entities by @id to avoid duplication:
{"@context": "https://schema.org", "@graph": [{"@type": "Organization", "@id": "https://example.com/#organization", ...}, {"@type": "WebSite", "publisher": {"@id": "https://example.com/#organization"}}]}""" .

oc:kn_7fbf2c6e a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-deploying or updating schema markup" ;
    oc:directiveContent "Adding JSON-LD schema markup is idempotent — re-running with the same schema produces no change. However, duplicate script tags for the same schema type on a page should be avoided." .

oc:kn_b33ebae9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which schema type to implement for a given page" ;
    oc:directiveContent "Match schema type to page purpose: Organization for homepage/about, WebSite+SearchAction for homepage search, Article/BlogPosting for blog posts, Product for e-commerce/SaaS product pages, SoftwareApplication for app landing pages, FAQPage for FAQ pages, HowTo for tutorials, BreadcrumbList for any page with breadcrumbs, LocalBusiness for location pages, Event for webinars/conferences." .

oc:kn_ba9f6b7d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing schema in Next.js or React applications" ;
    oc:codeLanguage "jsx" ;
    oc:directiveContent """Inject JSON-LD via a <script type="application/ld+json"> tag in the page <head>, using dangerouslySetInnerHTML (React/Next.js) or equivalent:
<script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify(schema) }} />""" .

