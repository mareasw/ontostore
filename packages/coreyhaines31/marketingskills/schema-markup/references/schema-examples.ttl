@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_schema_markup_schema_examples a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "schema-examples" ;
    skos:broader "JSON-LD template library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/schema-markup" ;
    oc:contentHash "5d55c96ae9859a5fb84cb18828c4a96dcd468e7aeec667c88fdf9032558ab318" ;
    oc:differentia "provides complete, copy-pasteable schema.org structured data examples for 11 common types plus a Next.js integration pattern" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_schema_markup ;
    oc:hasCategory "document" ;
    oc:impartsKnowledge oc:kn_038aad77,
        oc:kn_417b127a,
        oc:kn_545412c1,
        oc:kn_d76e0cf1,
        oc:kn_d9ee97ca ;
    oc:isUserInvocable false ;
    oc:nature "reference" ;
    oc:requiresState oc:SchemaTypeIdentified ;
    oc:resolvesIntent "combine multiple schema types using @graph",
        "find template code for Organization, Product, Article, FAQ, SoftwareApplication schema",
        "get JSON-LD examples for schema markup types",
        "see how to implement structured data for common page types" ;
    oc:yieldsState oc:SchemaTemplateReady .

oc:kn_038aad77 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which schema type to implement for a given page." ;
    oc:directiveContent "Map page types to the most impactful schema type: homepage → Organization + WebSite, blog post → Article, product page → Product, FAQ page → FAQPage, tutorial → HowTo, SaaS landing page → SoftwareApplication, event page → Event." ;
    oc:hasRationale "Using the correct primary schema type ensures eligibility for the most valuable rich results for that page type." ;
    oc:severityLevel "MEDIUM" .

oc:kn_417b127a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When implementing schema in React-based frameworks." ;
    oc:directiveContent "For dynamic sites (React/Next.js), serialize schema as a JavaScript object and inject via a script tag with type='application/ld+json' in the Head component, using dangerouslySetInnerHTML for hydration compatibility." ;
    oc:hasRationale "Server-side rendering of JSON-LD in the head ensures search engine crawlers can read the structured data without executing JavaScript." ;
    oc:severityLevel "HIGH" .

oc:kn_545412c1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating date, URL, or enumeration fields in any schema type." ;
    oc:directiveContent "All dates must use ISO 8601 format (e.g., '2024-01-15T08:00:00+00:00'), all URLs must be fully qualified, and all schema.org enumeration values must be exact URIs (e.g., 'https://schema.org/InStock')." ;
    oc:hasRationale "Invalid date formats or relative URLs will cause validation failures and prevent rich results from appearing." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d76e0cf1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adapting these templates for a real site." ;
    oc:directiveContent "Never use placeholder or example URLs (example.com), company names (Example Company), or dummy ratings in production schema markup." ;
    oc:hasRationale "Placeholder data in production schema misrepresents page content to search engines and violates Google's structured data guidelines, risking manual actions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d9ee97ca a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing more than one schema type on a page (e.g., Organization + WebSite + BreadcrumbList on a homepage)." ;
    oc:directiveContent "Always use @graph to combine multiple schema types on a single page, using @id references to link entities rather than duplicating data." ;
    oc:hasRationale "Using @graph with @id references creates a coherent linked-data graph and avoids redundant nested objects, which Google's parser handles more reliably." ;
    oc:severityLevel "HIGH" .

