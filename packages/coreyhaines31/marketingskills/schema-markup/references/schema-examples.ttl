    {
      "@type": "Question",
      "name": "How do I implement schema?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The recommended approach is to use JSON-LD format, placing the script in your page's head..."
      }
    }
  ]
}
""" ;
                            oc:codeLanguage "json" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 167-190" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
