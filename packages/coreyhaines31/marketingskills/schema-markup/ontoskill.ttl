oc:kn_0c33b1b7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When implementing any schema markup" ;
    oc:directiveContent "Always use JSON-LD format for schema markup — it is Google's recommended format, easier to implement and maintain than Microdata or RDFa." ;
    oc:hasRationale "JSON-LD is the modern standard endorsed by Google and is cleanly separated from HTML content." ;
    oc:severityLevel "HIGH" .

oc:kn_53352d89 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When delivering completed schema markup" ;
    oc:directiveContent """## Schema Implementation
```json
{"@context": "https://schema.org", "@type": "{SchemaType}", ...}
```
## Testing Checklist
- [ ] Validates in Rich Results Test
- [ ] No errors or warnings
- [ ] Matches page content
- [ ] All required properties included""" ;
    oc:templateVariables "SchemaType" .

oc:kn_8b3e9192 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating schema properties" ;
    oc:directiveContent "Never mark up content that does not exist on the visible page. Schema must accurately represent actual page content." ;
    oc:hasRationale "Mismatched schema violates Google's guidelines and can result in manual action penalties." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8cf919e5 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After implementing schema markup" ;
    oc:directiveContent "Validate all schema using Google Rich Results Test (search.google.com/test/rich-results) and Schema.org Validator (validator.schema.org). Check Search Console Enhancements reports for errors." ;
    oc:hasRationale "Validation catches syntax errors, missing required properties, and guideline violations before deployment." ;
    oc:severityLevel "HIGH" .

oc:kn_90eeabe7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a page needs multiple schema types (e.g., homepage with organization + site + breadcrumb)" ;
    oc:directiveContent "Combine multiple schema types on a single page using the @graph property to bundle Organization, WebSite, BreadcrumbList, and content-specific schemas together." ;
    oc:hasRationale "@graph provides a clean, maintainable way to serve multiple schemas without duplicate @context declarations." .

oc:kn_9b7dc47f a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When debugging why rich results are not showing" ;
    oc:directiveContent "Valid schema does not guarantee rich results will appear — Google chooses when and whether to display them. Missing rich results may indicate eligibility issues, not schema errors." ;
    oc:hasRationale "Setting correct expectations prevents unnecessary schema rewrites when the markup is already correct." .

oc:kn_b178100c a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When combining multiple schema types on a single page" ;
    oc:codeLanguage "json" ;
    oc:directiveContent "{\"@context\": \"https://schema.org\", \"@graph\": [{\"@type\": \"Organization\", ...}, {\"@type\": \"WebSite\", ...}, {\"@type\": \"BreadcrumbList\", ...}]}" .

oc:kn_d29062da a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any schema implementation" ;
    oc:directiveContent "Before implementing schema, check for product-marketing-context.md (.agents/ or .claude/) to gather existing brand/company context, then assess page type, current schema state, and target rich results." ;
    oc:hasRationale "Leveraging existing context reduces redundant questions and ensures consistency with brand information." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d52e3cca a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting schema property values" ;
    oc:directiveContent "Dates must use ISO 8601 format, URLs must be fully qualified, and enumeration values must match schema.org exactly." ;
    oc:hasRationale "Invalid value formats cause validation errors and prevent rich results from appearing." ;
    oc:severityLevel "HIGH" .

oc:kn_df2789ea a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before beginning schema implementation" ;
    oc:directiveContent "Access to Google Rich Results Test and Schema.org Validator for validation. Understanding of the page's content and tech stack (static HTML, React/Next.js, or CMS/WordPress)." .

oc:kn_fcbf8e73 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing schema markup from scratch" ;
    oc:directiveContent "1. Check product-marketing-context.md for existing context → 2. Identify page type and target rich results → 3. Gather required data (name, URL, dates, images, offers) → 4. Build JSON-LD markup with required and recommended properties → 5. Use @graph if multiple schema types needed → 6. Validate with Rich Results Test and Schema.org Validator → 7. Provide testing checklist" ;
    oc:stepOrder 1 .

