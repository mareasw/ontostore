@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_schema_markup a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "schema-markup" ;
    skos:broader "Structured data implementation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/schema-markup" ;
    oc:contentHash "e959e5042af521a251920c1ab275738512b03d30e09bb9d5fcf810625de59151" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "that generates schema.org JSON-LD markup to enable rich search results and help search engines understand page content" ;
    oc:extends oc:skill_seo_audit ;
    oc:handlesFailure oc:InvalidSchema,
        oc:MissingRequiredProperties,
        oc:SchemaContentMismatch ;
    oc:hasAllowedTool "Edit",
        "Read",
        "Write" ;
    oc:hasArgumentHint "page URL or page type (e.g., homepage, blog post, product page, FAQ page)" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to add, fix, or optimize schema markup and structured data on their site. Also use when the user mentions \"schema markup,\" \"structured data,\" \"JSON-LD,\" \"rich snippets,\" \"schema.org,\" \"FAQ schema,\" \"product schema,\" \"review schema,\" \"breadcrumb schema,\" \"Google rich results,\" \"knowledge panel,\" \"star ratings in search,\" or \"add structured data.\" Use this whenever someone wants their pages to show enhanced results in Google. For broader SEO issues, see seo-audit. For AI search optimization, see ai-seo." ;
    oc:hasName "schema-markup" ;
    oc:impartsKnowledge oc:kn_0bcd4208,
        oc:kn_43af15a7,
        oc:kn_6338c466,
        oc:kn_8d3a24fa,
        oc:kn_bde44223,
        oc:kn_c7065572 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:NetworkAvailable,
        oc:PageTypeIdentified ;
    oc:resolvesIntent "add schema markup to a webpage",
        "debug schema markup that isn't showing rich results",
        "fix existing schema markup errors",
        "generate JSON-LD for specific page types",
        "implement FAQ, Product, Article, or other schema types",
        "optimize structured data for rich results" ;
    oc:yieldsState oc:RichResultsEligible,
        oc:SchemaMarkupGenerated .

oc:kn_0bcd4208 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating schema markup for any page" ;
    oc:directiveContent "Never mark up content that does not exist on the page or use schema properties that don't match the visible page content." ;
    oc:hasRationale "Mismatched schema violates Google's guidelines and can result in manual actions or loss of rich result eligibility" ;
    oc:severityLevel "CRITICAL" .

oc:kn_43af15a7 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When a page needs multiple schema types (e.g., Organization + WebSite + BreadcrumbList on a homepage)" ;
    oc:directiveContent "Combine multiple schema types on a single page using the @graph array structure rather than separate script tags." ;
    oc:hasRationale "@graph creates a single coherent linked data graph, enables cross-referencing via @id, and is cleaner to maintain than multiple disconnected script blocks" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6338c466 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When populating schema property values" ;
    oc:directiveContent "Dates must be ISO 8601 format, URLs must be fully qualified, and enumeration values must match schema.org exactly." ;
    oc:hasRationale "Invalid date/URL/enum formats cause validation errors and prevent rich results eligibility" ;
    oc:severityLevel "HIGH" .

oc:kn_8d3a24fa a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any schema markup" ;
    oc:directiveContent "Always use JSON-LD format for schema markup, placed in the <head> or end of <body>. Google explicitly recommends JSON-LD over microdata or RDFa." ;
    oc:hasRationale "JSON-LD is easier to implement, maintain, and modify without touching HTML structure, and is Google's preferred format" ;
    oc:severityLevel "HIGH" .

oc:kn_bde44223 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When debugging why schema markup isn't producing rich snippets" ;
    oc:directiveContent "Valid schema does not guarantee rich results will appear. Google chooses when and whether to display rich results based on its own algorithms and quality thresholds." ;
    oc:hasRationale "Setting correct expectations prevents frustration; schema is a necessary but not sufficient condition for rich results" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c7065572 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before deploying any schema markup implementation" ;
    oc:directiveContent "Always validate schema markup using Google Rich Results Test (search.google.com/test/rich-results) and Schema.org Validator before deploying to production." ;
    oc:hasRationale "Invalid schema silently fails — it won't produce rich results and may generate Search Console errors" ;
    oc:severityLevel "HIGH" .

