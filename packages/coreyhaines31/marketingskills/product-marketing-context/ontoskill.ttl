oc:kn_1bc3869a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using the start-from-scratch workflow" ;
    oc:directiveContent "Do not dump all section questions at once — walk through sections conversationally, one at a time." ;
    oc:hasRationale "Overwhelming users with all questions reduces answer quality and increases abandonment." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2e89207c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When walking through sections for non-standard products" ;
    oc:directiveContent "Skip sections that don't apply rather than forcing all 12 — e.g., Personas for B2C, Proof Points for early-stage products." ;
    oc:hasRationale "Forcing irrelevant sections wastes time and produces low-quality filler content." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3089fb70 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating an existing context document" ;
    oc:directiveContent "Running this skill multiple times is safe — it reads existing context and only updates specified sections, preserving unchanged content." ;
    oc:hasRationale "Users should feel comfortable re-running without fear of losing existing work." ;
    oc:severityLevel "LOW" .

oc:kn_36d2e6ff a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no existing context document is found" ;
    oc:directiveContent "Prioritize auto-drafting from codebase over starting from scratch — most users prefer faster iteration on an existing draft." ;
    oc:hasRationale "Starting from a draft reduces cognitive load and speeds up the process vs. answering all sections from blank." ;
    oc:severityLevel "MEDIUM" .

oc:kn_63fa393a a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After gathering all information" ;
    oc:directiveContent "Show the completed document to the user, ask if anything needs adjustment, then save to .agents/product-marketing-context.md." ;
    oc:hasRationale "User validation prevents errors from propagating to all downstream marketing skills." ;
    oc:severityLevel "HIGH" .

oc:kn_6a53270d a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When checking for existing context document" ;
    oc:directiveContent "If context found at legacy path .claude/product-marketing-context.md but not .agents/, offer to migrate it to the new location." ;
    oc:hasRationale "Ensures continuity for users who set up context before the path migration." ;
    oc:severityLevel "LOW" .

oc:kn_b084db61 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When gathering pain points and problem information" ;
    oc:directiveContent "Ask specific questions like 'What's the #1 frustration that brings them to you?' rather than generic ones like 'What problem do they solve?'" ;
    oc:hasRationale "Specific questions yield concrete, actionable answers; generic questions produce vague responses." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b3b1afc6 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always, on successful completion" ;
    oc:directiveContent "Creates or updates .agents/product-marketing-context.md — this file is read by all other marketing skills for product, audience, and positioning context." ;
    oc:hasRationale "Other skills depend on this file existing and being current; changes here propagate to all downstream marketing tasks." ;
    oc:severityLevel "CRITICAL" .

oc:kn_be962422 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When gathering customer language and pain points" ;
    oc:directiveContent "Capture verbatim customer language over polished descriptions — exact phrases reflect how customers actually think and speak, making downstream copy more resonant." ;
    oc:hasRationale "Verbatim language preserves the emotional texture and specificity that gets lost in paraphrasing." ;
    oc:severityLevel "HIGH" .

oc:kn_c740f6bf a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any context creation or update workflow" ;
    oc:directiveContent "Check both .agents/product-marketing-context.md and .claude/product-marketing-context.md for existing context before starting." ;
    oc:hasRationale "Avoids duplicating effort and ensures existing context is preserved or updated rather than overwritten." ;
    oc:severityLevel "HIGH" .

