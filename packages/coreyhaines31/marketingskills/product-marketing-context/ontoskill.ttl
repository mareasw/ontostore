@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_product_marketing_context a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "product-marketing-context" ;
    skos:broader "Marketing foundation builder" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/product-marketing-context" ;
    oc:contentHash "3aae1646309ed3817fd9cd9532c146133cf5995c81e7c61d023542544963c3ba" ;
    oc:differentia "that creates a shared context document capturing product positioning, audience, competitive landscape, and brand voice for reuse across all marketing skills" ;
    oc:handlesFailure oc:FileNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "optional: 'update' to modify existing context, or describe product/market details to draft from" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to create or update their product marketing context document. Also use when the user mentions 'product context,' 'marketing context,' 'set up context,' 'positioning,' 'who is my target audience,' 'describe my product,' 'ICP,' 'ideal customer profile,' or wants to avoid repeating foundational information across marketing tasks. Use this at the start of any new project before using other marketing skills — it creates `.agents/product-marketing-context.md` that all other skills reference for product, audience, and positioning context." ;
    oc:hasName "product-marketing-context" ;
    oc:impartsKnowledge oc:kn_0479763b,
        oc:kn_1ead6b4a,
        oc:kn_27cc1573,
        oc:kn_322f190e,
        oc:kn_808bac41,
        oc:kn_bb77478e,
        oc:kn_fdaaa26a ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DirectoryWritable ;
    oc:resolvesIntent "capture brand voice and customer language",
        "create product marketing context document",
        "define ideal customer profile and positioning",
        "set up marketing context before starting marketing projects",
        "update product marketing context" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_0479763b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before creating or updating a product marketing context document" ;
    oc:directiveContent "Always check for existing .agents/product-marketing-context.md (and legacy .claude/product-marketing-context.md) before starting. If a legacy file exists, offer to migrate it." ;
    oc:hasRationale "Prevents overwriting existing context and preserves any prior work. Legacy path migration ensures continuity." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1ead6b4a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When gathering information for any section, especially Problems & Pain Points and Customer Language sections" ;
    oc:directiveContent "Capture verbatim customer language — exact phrases customers use to describe their problems and solutions. These are more valuable than polished descriptions." ;
    oc:hasRationale "Verbatim customer language reflects how customers actually think and speak, making all downstream marketing copy more resonant and authentic." .

oc:kn_27cc1573 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When using the start-from-scratch creation mode" ;
    oc:directiveContent "Walk through sections conversationally one at a time. Briefly explain what each section captures, ask relevant questions, confirm accuracy, then move to the next. Never dump all questions at once." ;
    oc:hasRationale "Conversational, one-section-at-a-time progression reduces cognitive overload and produces higher-quality, more thoughtful answers than presenting all questions simultaneously." .

oc:kn_322f190e a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When an existing .agents/product-marketing-context.md is found and the user wants to update it" ;
    oc:directiveContent "When updating an existing context document, only modify the sections the user wants changed. Preserve all unchanged sections exactly as they are." ;
    oc:hasRationale "The context document accumulates institutional knowledge over time. Accidental deletion of unchanged sections would lose valuable, previously validated information." ;
    oc:severityLevel "CRITICAL" .

oc:kn_808bac41 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After gathering all information and drafting the document" ;
    oc:directiveContent "After creating or updating the document, show the completed output to the user and ask if anything needs adjustment before saving to .agents/product-marketing-context.md." ;
    oc:hasRationale "Final review catches errors, omissions, and misinterpretations before the document becomes the shared source of truth for all other marketing skills." ;
    oc:severityLevel "HIGH" .

oc:kn_bb77478e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no existing context document is found" ;
    oc:directiveContent "Offer two creation modes: auto-draft from codebase (recommended) or conversational start-from-scratch. Auto-draft reads README, landing pages, marketing copy, package.json, and docs to build a V1 draft for user review." ;
    oc:hasRationale "Auto-drafting from existing materials is faster and less effort for the user than answering 12 sections of questions from scratch." .

oc:kn_fdaaa26a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When walking through sections with the user, especially for early-stage or B2C products" ;
    oc:directiveContent "Not all 12 sections apply to every product. Skip non-applicable sections rather than forcing them (e.g., Personas is B2B-focused, Proof Points may be sparse for early-stage products). Accept lighter answers where appropriate." ;
    oc:hasRationale "Forcing inapplicable sections wastes the user's time and produces filler content that degrades downstream marketing quality." ;
    oc:severityLevel "HIGH" .

