                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Field labels: minimal vs. descriptive" ],
                                        [ a oc:BulletItem ;
