@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_signup_flow_cro a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "signup-flow-cro" ;
    skos:broader "Conversion Rate Optimization methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/signup-flow-cro" ;
    oc:contentHash "208f90bd5530a9fe4ebdcda3fd6ca5dac9408ec70865235c9d84449319e4929a" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "specializes in reducing friction and increasing completion rates for signup, registration, and trial activation flows through field optimization, trust elements, and experiment design" ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput ;
    oc:hasAllowedTool "Read" ;
    oc:hasArgumentHint "signup flow URL, current completion rate, or description of signup steps" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to optimize signup, registration, account creation, or trial activation flows. Also use when the user mentions \"signup conversions,\" \"registration friction,\" \"signup form optimization,\" \"free trial signup,\" \"reduce signup dropoff,\" \"account creation flow,\" \"people aren't signing up,\" \"signup abandonment,\" \"trial conversion rate,\" \"nobody completes registration,\" \"too many steps to sign up,\" or \"simplify our signup.\" Use this whenever the user has a signup or registration flow that isn't performing. For post-signup onboarding, see onboarding-cro. For lead capture forms (not account creation), see form-cro." ;
    oc:hasName "signup-flow-cro" ;
    oc:impartsKnowledge oc:kn_0df4fa23,
        oc:kn_2b3f3f1d,
        oc:kn_301de837,
        oc:kn_75ef13e4,
        oc:kn_a62a1d97,
        oc:kn_cf0bb7de,
        oc:kn_d397779e,
        oc:kn_e3c7e3c5 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "audit signup flow for conversion issues",
        "design signup flow for B2B or B2C product",
        "improve trial signup conversion rate",
        "optimize signup form fields and order",
        "plan signup flow A/B tests and experiments",
        "reduce signup abandonment and drop-off" ;
    oc:yieldsState oc:SignupFlowAudited,
        oc:SignupFlowOptimized .

oc:kn_0df4fa23 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing the relationship between product experience and signup gate" ;
    oc:directiveContent "Show value before asking for commitment. Let users experience the product before requiring account creation. Reverse the order: value first, signup second." ;
    oc:hasRationale "Users who've already experienced product value have much higher motivation to complete signup, reducing abandonment" ;
    oc:severityLevel "HIGH" .

oc:kn_2b3f3f1d a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When designing email verification flows" ;
    oc:directiveContent "Requiring email verification before product access creates significant friction and likely reduces activation. Delay verification until necessary or let users explore the product while verification is pending." ;
    oc:hasRationale "Forcing users to leave the product experience to check email breaks momentum and many users never return" ;
    oc:severityLevel "HIGH" .

oc:kn_301de837 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding social authentication to signup flows" ;
    oc:directiveContent "Social auth options must match the audience: B2C products should offer Google, Apple, Facebook; B2B products should offer Google, Microsoft, SSO. Place social auth prominently with clear visual separation from email signup." ;
    oc:hasRationale "Wrong social auth options create friction rather than reducing it — irrelevant options add noise, missing options force email signup" ;
    oc:severityLevel "MEDIUM" .

oc:kn_75ef13e4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing microcopy for signup forms" ;
    oc:directiveContent "Never use placeholder text as the sole label for form fields. Placeholders disappear when users start typing, leaving them unsure what they're filling in." ;
    oc:hasRationale "Users who forget what field they're in after typing will abandon rather than delete text to see the label" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a62a1d97 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating or designing any signup form" ;
    oc:directiveContent "Every additional field in a signup form reduces conversion. For each field, ask: is this absolutely needed before the user can use the product, can it be collected later via progressive profiling, or can it be inferred from other data?" ;
    oc:hasRationale "Field count is the single strongest predictor of signup form abandonment — each unnecessary field compounds friction" ;
    oc:severityLevel "HIGH" .

oc:kn_cf0bb7de a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When measuring signup flow performance and improvement" ;
    oc:directiveContent "Key signup metrics to track: form start rate (landed → started), form completion rate (started → submitted), field-level drop-off, time to complete, error rate by field, mobile vs desktop completion, and social auth vs email signup ratio." ;
    oc:hasRationale "Granular metrics enable identifying exactly where and why users drop off, making optimization targeted rather than guesswork" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d397779e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any signup flow audit or optimization task" ;
    oc:directiveContent "Before providing signup flow recommendations, check if .agents/product-marketing-context.md (or .claude/product-marketing-context.md) exists and read it. Use that context to avoid asking questions already covered there." ;
    oc:hasRationale "Product marketing context contains essential business and product information that prevents redundant questions and improves recommendation quality" ;
    oc:severityLevel "HIGH" .

oc:kn_e3c7e3c5 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing multi-step signup flows with more than 3-4 required fields" ;
    oc:directiveContent "For multi-step signup flows, lead with easy questions (email, name) first and put harder or more personal questions later, after psychological commitment has been established. Show a progress indicator and allow back navigation." ;
    oc:hasRationale "Users who've already committed to earlier easy steps are less likely to abandon when faced with harder questions due to sunk cost commitment" ;
    oc:severityLevel "MEDIUM" .

