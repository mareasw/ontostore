oc:skill_coreyhaines31_marketingskills_pricing_strategy a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "pricing-strategy" ;
    skos:broader "SaaS monetization strategy framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/pricing-strategy" ;
    oc:contentHash "406dabaa5a2a818bd546b8cb886fb6ba4520e4c832964af5d941fe9879e0e57f" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "that guides pricing decisions including value metric selection, tier structure design, pricing research, and price optimization for software products" ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput ;
    oc:hasArgumentHint "product description, current pricing, target market, and pricing goals" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants help with pricing decisions, packaging, or monetization strategy. Also use when the user mentions 'pricing,' 'pricing tiers,' 'freemium,' 'free trial,' 'packaging,' 'price increase,' 'value metric,' 'Van Westendorp,' 'willingness to pay,' 'monetization,' 'how much should I charge,' 'my pricing is wrong,' 'pricing page,' 'annual vs monthly,' 'per seat pricing,' or 'should I offer a free plan.' Use this whenever someone is figuring out what to charge or how to structure their plans. For in-app upgrade screens, see paywall-upgrade-cro." ;
    oc:hasName "pricing-strategy" ;
    oc:impartsKnowledge oc:kn_083131d6,
        oc:kn_1eb9be3e,
        oc:kn_26676fca,
        oc:kn_3888743b,
        oc:kn_6293ec43,
        oc:kn_c0f54e9d,
        oc:kn_ed077ad9 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:MarketIdentified,
        oc:ProductDefined ;
    oc:resolvesIntent "build enterprise pricing",
        "choose a value metric",
        "conduct pricing research",
        "create packaging strategy",
        "design pricing tiers",
        "optimize pricing page psychology",
        "plan a price increase",
        "set price points",
        "structure freemium vs free trial" ;
    oc:yieldsState oc:PricePointsSet,
        oc:PricingStrategyDefined,
        oc:TierStructureDesigned .

oc:kn_083131d6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting or evaluating any price point" ;
    oc:directiveContent "Price between the next best alternative and the customer's perceived value — never based on cost to serve." ;
    oc:hasRationale "Value-based pricing captures the maximum willingness to pay without anchoring to internal costs, which are invisible to customers." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1eb9be3e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any pricing strategy session" ;
    oc:directiveContent "Check for product-marketing-context.md before asking the user questions — use existing context and only ask for gaps." ;
    oc:hasRationale "Avoids redundant questions and demonstrates awareness of the product context, leading to faster and more relevant recommendations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_26676fca a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning and communicating a price increase" ;
    oc:directiveContent "When raising prices, grandfather existing customers or provide 3-6 months advance notice, and tie the increase to demonstrable new value." ;
    oc:hasRationale "Abrupt price increases without perceived additional value cause churn and damage trust. Grandfathering reduces backlash while still capturing new revenue." ;
    oc:severityLevel "HIGH" .

oc:kn_3888743b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring pricing plans for most SaaS products" ;
    oc:directiveContent "Use the Good-Better-Best framework with 3 tiers where the middle tier is the recommended anchor and the premium tier is 2-3x the middle price." ;
    oc:hasRationale "Three tiers provide enough segmentation to capture different willingness-to-pay levels while keeping choice simple. The decoy effect makes the middle tier most attractive." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6293ec43 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When choosing or evaluating a pricing metric (per seat, per usage, flat fee, etc.)" ;
    oc:directiveContent "The value metric (what you charge for) must scale with the value customers receive and be easy to understand." ;
    oc:hasRationale "A misaligned value metric means price grows without value or value grows without price — both destroy growth." ;
    oc:severityLevel "HIGH" .

oc:kn_c0f54e9d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing tier structures" ;
    oc:directiveContent "Do not create 4+ tiers without clear persona-based differentiation — more options can cause decision paralysis and reduce conversion." ;
    oc:hasRationale "Hick's Law applies to pricing: excessive choice increases cognitive load and delays or prevents purchase decisions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ed077ad9 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user asks about pricing page design, conversion rates, or page layout" ;
    oc:directiveContent "If the user's request is primarily about pricing page conversion optimization rather than pricing decisions, defer to the page-cro skill." ;
    oc:hasRationale "Pricing strategy covers what to charge and how to package; page conversion optimization is a distinct discipline with different methods." ;
    oc:severityLevel "MEDIUM" .

