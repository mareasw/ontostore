                            oc:sectionOrder 1 ;
                            oc:sectionTitle "The Three Pricing Axes" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
