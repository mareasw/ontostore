oc:kn_004b6d71 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When conducting MaxDiff analysis for feature prioritization" ;
    oc:directiveContent "1. List 8-15 features 2. Show respondents sets of 4-5 features 3. Ask most/least important 4. Repeat until all features compared 5. Rank by utility score" ;
    oc:stepOrder 2 .

oc:kn_296dc68a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating MaxDiff results into pricing tier packaging" ;
    oc:directiveContent "For MaxDiff packaging decisions: Top 20% utility features → all tiers (table stakes); 20-50% → differentiate tiers; 50-80% → higher tiers only; Bottom 20% → cut or premium add-on." ;
    oc:hasRationale "Features valued by everyone must be in base to avoid churn; mid-value features create upgrade motivation; low-value features won't drive upgrades" ;
    oc:severityLevel "HIGH" .

oc:kn_38bc49e2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing and fielding Van Westendorp price sensitivity surveys" ;
    oc:directiveContent "Van Westendorp surveys need 100-300 respondents for reliable data. Segment responses by persona to account for different willingness-to-pay levels." ;
    oc:hasRationale "Too few respondents produces unreliable intersection points; persona segmentation reveals hidden price sensitivity differences between customer segments" ;
    oc:severityLevel "HIGH" .

oc:kn_5646cadd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a willingness-to-pay survey methodology" ;
    oc:directiveContent "Direct WTP questions ('How much would you pay?') are biased. Use Gabor-Granger (binary yes/no at varied prices) or conjoint analysis (bundle choices at different prices) for more accurate results." ;
    oc:hasRationale "Direct questions elicit strategic responses (lowballing); indirect methods reveal true price sensitivity through behavioral choice modeling" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6fce5060 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When using internal usage data to inform pricing decisions" ;
    oc:directiveContent "Correlate product usage data (feature frequency, volume metrics, outcome metrics) with retention, expansion, and revenue to identify value thresholds that justify price increases or tier gates." ;
    oc:hasRationale "Usage-value correlation reveals what customers actually pay for, not what they say they want, grounding pricing in behavioral evidence" .

oc:kn_96a8d8cd a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When analyzing Van Westendorp survey data" ;
    oc:directiveContent "1. Plot cumulative distributions for all four Van Westendorp questions 2. Find PMC (Too cheap × Expensive), PME (Too expensive × Cheap), OPP (Too cheap × Too expensive), IDP (Expensive × Cheap) 3. Acceptable range = PMC to PME 4. Optimal zone = OPP to IDP" ;
    oc:stepOrder 1 .

oc:kn_aa47f57d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing usage-value correlation analysis" ;
    oc:directiveContent "1. Instrument usage tracking (feature frequency, volume, outcomes) 2. Correlate with retention and expansion patterns 3. Identify value thresholds for adoption, expansion, and price increase triggers" ;
    oc:stepOrder 3 .

oc:kn_e6c487d1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When conducting pricing research" ;
    oc:directiveContent "Do not rely on a single pricing research method. Triangulate Van Westendorp (price range), MaxDiff (feature value), and usage data (behavioral evidence) for robust pricing decisions." ;
    oc:hasRationale "Each method has blind spots: surveys suffer from stated vs. revealed preference gaps; usage data lacks competitive context; combining methods compensates for individual weaknesses" ;
    oc:severityLevel "MEDIUM" .

_:ref_0b2623f407eea9ae a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 3 ;
            oc:itemText "**Optimal Price Point (OPP):** \"Too cheap\" crosses \"Too expensive\"" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 4 ;
            oc:itemText "**Indifference Price Point (IDP):** \"Expensive\" crosses \"Cheap\"" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 1 ;
            oc:itemText "**Point of Marginal Cheapness (PMC):** \"Too cheap\" crosses \"Expensive\"" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 2 ;
            oc:itemText "**Point of Marginal Expensiveness (PME):** \"Too expensive\" crosses \"Cheap\"" ] .

