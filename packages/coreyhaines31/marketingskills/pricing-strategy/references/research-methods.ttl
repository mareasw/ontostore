oc:skill_coreyhaines31_marketingskills_pricing_strategy_research_methods a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "research-methods" ;
    skos:broader "pricing research toolkit" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/pricing-strategy" ;
    oc:contentHash "b6aab09860dbab2f11d69cc9c179cc7f6e1a100ede28e5c49b59070a2caaeb15" ;
    oc:differentia "provides four structured methodologies (Van Westendorp, MaxDiff, WTP surveys, usage-value correlation) for gathering and analyzing pricing data from customers" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_pricing_strategy ;
    oc:handlesFailure oc:InconsistentSurveyData,
        oc:InsufficientSampleSize,
        oc:NoClearValueCorrelation ;
    oc:hasArgumentHint "research method name or pricing question (e.g., 'van westendorp', 'maxdiff', 'willingness to pay', 'usage-value correlation')" ;
    oc:hasCategory "marketing" ;
    oc:hasRequirement oc:req_1fdcd4c3,
        oc:req_9aa2c34b,
        oc:req_e2d9edbf ;
    oc:impartsKnowledge oc:kn_43543d66,
        oc:kn_59547e35,
        oc:kn_841bfac0,
        oc:kn_a28264ff,
        oc:kn_c3aeae07,
        oc:kn_cfe582ee ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProductDefined,
        oc:TargetAudienceIdentified ;
    oc:resolvesIntent "conduct pricing research",
        "correlate usage data with pricing tiers",
        "determine feature value for packaging decisions",
        "find optimal price point",
        "identify willingness to pay",
        "run van westendorp price sensitivity analysis" ;
    oc:yieldsState oc:FeatureValueRanked,
        oc:PriceRangeIdentified,
        oc:UsageValueCorrelated .

oc:kn_43543d66 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When setting or adjusting usage-based pricing tiers" ;
    oc:directiveContent "Correlate product usage data (feature frequency, volume metrics, outcome metrics) with customer success signals (retention, expansion, LTV) to identify natural value thresholds that should drive pricing boundaries." ;
    oc:hasRationale "Usage-value correlation grounds pricing in actual customer behavior rather than assumptions, revealing the points at which customers derive enough value to pay more or churn." ;
    oc:severityLevel "MEDIUM" .

oc:kn_59547e35 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a pricing research method" ;
    oc:directiveContent "Use Van Westendorp when you need to find an acceptable price range; use MaxDiff when you need to decide which features belong in which pricing tier; use conjoint analysis when you need to understand price sensitivity per feature." ;
    oc:hasRationale "Each method answers a different pricing question — choosing the wrong method yields irrelevant data and wasted research budget." ;
    oc:severityLevel "HIGH" .

oc:kn_841bfac0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing willingness-to-pay surveys" ;
    oc:directiveContent "Never rely on direct willingness-to-pay questions ('How much would you pay?') as they produce heavily biased data. Prefer Gabor-Granger or conjoint analysis." ;
    oc:hasRationale "Direct WTP questions trigger anchoring bias and social desirability bias, making responses unreliable for pricing decisions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a28264ff a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When translating MaxDiff results into packaging decisions" ;
    oc:directiveContent "Map MaxDiff utility scores to packaging tiers: top 20% are table stakes for all tiers, 20-50% differentiate tiers, 50-80% belong in higher tiers only, bottom 20% should be cut or offered as premium add-ons." ;
    oc:hasRationale "This systematic mapping prevents the common mistake of putting high-value features in the wrong tier, which either leaves money on the table or creates unappealing packages." ;
    oc:severityLevel "HIGH" .

oc:kn_c3aeae07 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing Van Westendorp analysis" ;
    oc:directiveContent "After running a Van Westendorp analysis, validate that the recommended price range (OPP to IDP) falls between PMC and PME; if it does not, the survey data may be inconsistent or the product description was unclear to respondents." ;
    oc:hasRationale "The internal consistency of the four intersection points is a built-in sanity check for the methodology — inconsistent results signal bad data, not a pricing insight." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cfe582ee a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or validating a Van Westendorp price sensitivity meter study" ;
    oc:directiveContent "Van Westendorp surveys require 100-300 respondents segmented by persona for statistically reliable results." ;
    oc:hasRationale "Too few respondents produces noisy intersection points; lack of segmentation masks differences in willingness-to-pay across customer types." ;
    oc:severityLevel "HIGH" .

oc:req_1fdcd4c3 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "basic statistical analysis" .

oc:req_9aa2c34b a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "product usage metrics" .

oc:req_e2d9edbf a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "survey design methodology" .

