    oc:handlesFailure oc:FeatureGapsDetected,
        oc:InsufficientSegmentData ;
    oc:hasArgumentHint "product details, target customer segments, feature set" ;
    oc:hasCategory "pricing-strategy" ;
    oc:impartsKnowledge oc:kn_1a8ddeae,
        oc:kn_4e97771a,
        oc:kn_6db83e72,
        oc:kn_86fdc301,
        oc:kn_bbf7e963,
        oc:kn_f0bf56ac ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CustomerSegmentsIdentified,
        oc:ProductFeaturesDefined ;
    oc:resolvesIntent "create good-better-best pricing",
        "decide between freemium and free trial",
        "design pricing tiers",
        "map features to customer segments",
        "package features for different personas",
        "plan tier differentiation strategy",
        "set up enterprise pricing tiers",
        "structure pricing packages" ;
    oc:yieldsState oc:PackagingStrategyDefined,
        oc:PricingTiersDesigned .

oc:kn_1a8ddeae a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When determining what differs between pricing tiers" ;
    oc:directiveContent "Differentiate tiers across four dimensions — feature gating, usage limits, support level, and access/customization — choosing the primary dimension based on how customer value scales with the product." ;
    oc:hasRationale "Aligning differentiation with how customers derive value ensures higher tiers feel worth the upgrade rather than arbitrary or punitive." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4e97771a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between freemium and free trial go-to-market strategies" ;
    oc:directiveContent "Choose freemium when the product has viral/network effects and low marginal cost to serve free users; choose free trial when the product needs time to demonstrate value and is sticky once configured." ;
    oc:hasRationale "Freemium leverages network effects and large market volume with low conversion rates, while free trial creates urgency and higher per-user conversion, especially for B2B products with buying committees." ;
    oc:severityLevel "HIGH" .

oc:kn_6db83e72 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to publish enterprise pricing or use sales-led pricing" ;
    oc:directiveContent "Add 'Contact Sales' for enterprise/custom pricing when deal sizes exceed $10k+ ARR, customers need custom contracts, implementation is required, or procurement processes are involved." ;
    oc:hasRationale "Self-serve pricing breaks down at high ARR due to custom requirements, negotiation expectations, and the need for human-guided implementation planning." ;
    oc:severityLevel "MEDIUM" .

oc:kn_86fdc301 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing enterprise pricing tiers" ;
    oc:directiveContent "Enterprise tier must include SSO/SAML, audit logs, admin controls, uptime SLA, and security certifications as table stakes before any value-add pricing." ;
    oc:hasRationale "Enterprise buyers have mandatory compliance and security requirements; without these features, no amount of value-add pricing will close the deal." ;
    oc:severityLevel "CRITICAL" .

oc:kn_bbf7e963 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding how many pricing tiers to offer" ;
    oc:directiveContent "Avoid creating 4+ pricing tiers as this leads to decision paralysis and operational complexity without proportional revenue gains." ;
    oc:hasRationale "More tiers increase cognitive load for buyers and internal complexity for billing, support, and feature management. The marginal revenue from added granularity rarely justifies the cost." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f0bf56ac a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing pricing tiers for SaaS products" ;
    oc:directiveContent "Use the Good-Better-Best framework with 3 tiers as the industry standard: Good for entry/barrier removal, Better as the recommended anchor where most customers land, and Best to capture high-value customers at 2-3x the Better price." ;
    oc:hasRationale "Three-tier structure balances simplicity of choice with revenue capture across willingness-to-pay segments, and anchors mid-tier as the default selection." ;
    oc:severityLevel "HIGH" .

