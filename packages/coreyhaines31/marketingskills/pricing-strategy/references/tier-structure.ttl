        oc:Skill ;
    dcterms:identifier "tier-structure" ;
    skos:broader "Pricing framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/pricing-strategy" ;
    oc:contentHash "b59910d37cceb74484f28b065963daa60f5c4fb1ffc36a0584d0f3cad11f3e30" ;
    oc:differentia "structures product tiers and packaging to maximize revenue across customer segments using good-better-best frameworks, persona-based packaging, freemium/trial strategies, and enterprise pricing" ;
