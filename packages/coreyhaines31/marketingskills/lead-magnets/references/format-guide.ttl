oc:skill_coreyhaines31_marketingskills_lead_magnets_format_guide a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "format-guide" ;
    skos:broader "Lead magnet format guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/lead-magnets" ;
    oc:contentHash "160b34c4c0d19e67fcc032181fdfbf1d5cae6dac94937f2333e8e21815ce9732" ;
    oc:differentia "Provides detailed creation guidance, structure, and best practices for 8 distinct lead magnet formats (ebooks, checklists, cheat sheets, templates, swipe files, mini-courses, quizzes, webinars)" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_lead_magnets ;
    oc:handlesFailure oc:InvalidFormatType ;
    oc:hasArgumentHint "format type (e.g., \"checklist\", \"ebook\", \"quiz\", \"webinar\")" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_01e33a3a,
        oc:kn_a2b8b8a4,
        oc:kn_ce7273cc,
        oc:kn_d35c2296,
        oc:kn_e79fa8ae ;
    oc:isUserInvocable true ;
    oc:nature "Reference" ;
    oc:requiresState oc:LeadMagnetFormatSelected ;
    oc:resolvesIntent "choose lead magnet format",
        "create cheat sheet lead magnet",
        "create checklist lead magnet",
        "create ebook or guide lead magnet",
        "create mini-course lead magnet",
        "create quiz or assessment lead magnet",
        "create swipe file lead magnet",
        "create template or spreadsheet lead magnet",
        "create webinar or workshop lead magnet",
        "get format-specific best practices for lead magnets" ;
    oc:yieldsState oc:LeadMagnetCreationGuidanceReady,
        oc:LeadMagnetFormatStructured .

oc:kn_01e33a3a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating ebook or guide lead magnets" ;
    oc:directiveContent "For ebooks, density beats length — keep to 10-25 pages and avoid padding. Include visuals, callout boxes, and end each chapter with a takeaway." ;
    oc:hasRationale "Readers value actionable density over page count; padded content signals low quality and reduces completion rates." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a2b8b8a4 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building quiz or assessment lead magnets" ;
    oc:directiveContent "For quizzes: gate only the personalized results behind email capture, not the quiz itself. Use 5-10 multiple-choice questions (sweet spot: 7) and create 3-5 share-worthy result categories." ;
    oc:hasRationale "Letting users experience the quiz before gating maximizes engagement and completion rates; sharing results extends organic reach." ;
    oc:severityLevel "HIGH" .

oc:kn_ce7273cc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning webinars or workshops as lead magnets" ;
    oc:directiveContent "Never create a webinar that is just a sales pitch. Teach something genuinely useful — a pure pitch webinar will damage trust and brand reputation." ;
    oc:hasRationale "Trust is the foundation of lead magnet conversion; bait-and-switch content erodes the relationship and increases unsubscribe rates." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d35c2296 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating template or spreadsheet lead magnets" ;
    oc:directiveContent "For templates and spreadsheets: the lead magnet should be usable within 5 minutes of downloading. Pre-fill with example data, include instructions, and lock formula cells while leaving input cells editable." ;
    oc:hasRationale "Immediate usability is the primary value proposition of templates; friction in setup causes drop-off and reduces perceived value." ;
    oc:severityLevel "HIGH" .

oc:kn_e79fa8ae a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing email or video mini-course lead magnets" ;
    oc:directiveContent "For mini-courses: each lesson should deliver standalone value. If someone only engages with lesson 2, they should still learn something useful. Deliver 3-5 lessons over 5-7 days with progressive difficulty." ;
    oc:hasRationale "Standalone value prevents attrition and ensures every touchpoint builds trust, since not all users will complete the full sequence." ;
    oc:severityLevel "HIGH" .

