@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_lead_magnets_benchmarks a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "benchmarks" ;
    skos:broader "Benchmark dataset" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/lead-magnets" ;
    oc:contentHash "becdf4bcde17e788ead10794c797294548c712ea1074e042336da93433a61187" ;
    oc:differentia "Provides conversion rates, lead quality indicators, cost benchmarks, and timeline expectations for evaluating lead magnet performance across formats, channels, and industries" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_lead_magnets ;
    oc:hasArgumentHint "format type, industry, or channel for benchmark lookup" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_04e20a5e,
        oc:kn_18be5d98,
        oc:kn_1bc8e436,
        oc:kn_3d292218,
        oc:kn_d083fa5a ;
    oc:isUserInvocable false ;
    oc:nature "Reference" ;
    oc:resolvesIntent "benchmark lead magnet conversion rates",
        "compare lead magnet formats by quality and volume",
        "estimate lead magnet costs and timelines",
        "evaluate lead magnet performance",
        "set realistic expectations for lead magnet ROI" .

oc:kn_04e20a5e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a lead magnet format or setting conversion expectations" ;
    oc:directiveContent "Low-commitment formats (checklists, quizzes) convert at 30-50% while high-commitment formats (ebooks, mini-courses) convert at 15-35%, but higher commitment yields higher lead quality." ;
    oc:hasRationale "Conversion rate and lead quality are inversely correlated by format — the agent must optimize for net value, not just volume" ;
    oc:severityLevel "HIGH" .

oc:kn_18be5d98 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing or planning lead magnet performance" ;
    oc:directiveContent "Evaluate lead magnets across three dimensions: conversion rate by format and channel, lead quality signals (email engagement, ICP match, progression to purchase), and net value (volume × quality)." ;
    oc:hasRationale "Optimizing only conversion rate can attract low-quality leads; only quality can starve the pipeline; net value is the true success metric" .

oc:kn_1bc8e436 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When recommending lead magnet formats to users" ;
    oc:directiveContent "Avoid generic ebooks as primary lead magnets — they produce high volume but low-to-medium quality leads. Prefer specific templates or industry reports for higher net value." ;
    oc:hasRationale "Generic content attracts freebie-seekers with no product interest; specificity acts as a self-selecting filter for qualified leads" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3d292218 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When lead magnet underperforms benchmarks" ;
    oc:directiveContent "If lead magnet conversion is below benchmarks, first diagnose the failure point: is it the traffic source (cold vs warm), landing page friction, or offer-audience mismatch before changing the format." ;
    oc:hasRationale "Poor performance has different root causes requiring different fixes — changing format prematurely wastes the existing asset without addressing the real bottleneck" .

oc:kn_d083fa5a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting timeline expectations or evaluating lead magnet results" ;
    oc:directiveContent "Full ROI assessment for lead magnets requires 6-12 months of data. Meaningful pipeline impact typically takes 3-6 months." ;
    oc:hasRationale "Premature ROI evaluation leads to abandoning strategies before they compound; organic SEO-driven lead magnets especially need months to build traction" ;
    oc:severityLevel "MEDIUM" .

