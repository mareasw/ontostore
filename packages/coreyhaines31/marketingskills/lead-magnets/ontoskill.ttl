                                            oc:itemOrder 2 ;
                                            oc:itemText "**Format**: Checklist vs. guide on same topic" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "**Headline**: Benefit-focused vs. curiosity-driven" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Gate level**: Full gate vs. partial preview" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "**CTA copy**: \"Download Free Guide\" vs. \"Get Your Copy\"" ],
                                        [ a oc:BulletItem ;
