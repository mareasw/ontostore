oc:kn_3fd0d3f9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing the lead capture form" ;
    oc:directiveContent "Never ask for more form fields than necessary. Every extra field beyond email reduces conversion by 5-10%. Multi-field forms only for high-value offers like webinars or demos." ;
    oc:hasRationale "Friction from additional form fields directly reduces conversion rate and undermines the lead magnet's purpose" ;
    oc:severityLevel "CRITICAL" .

oc:kn_51e01c59 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When aligning lead magnet topic with business goals" ;
    oc:directiveContent "Lead magnets must create a natural path to product: solve a problem the product also solves, create awareness of a gap the product fills, or demonstrate expertise in the product's space." ;
    oc:hasRationale "Lead magnets that don't naturally connect to the product generate unqualified leads that never convert to customers" ;
    oc:severityLevel "HIGH" .

oc:kn_66c8dda7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning blog-based lead capture" ;
    oc:directiveContent "Content upgrades convert 2-5x better than generic sidebar CTAs. Create post-specific bonus content tied to the blog topic." ;
    oc:hasRationale "Contextual relevance dramatically increases opt-in intent because the offer matches the reader's current interest" .

oc:kn_81d6a19f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting or planning any lead magnet topic" ;
    oc:directiveContent "Lead magnets must solve one specific problem, not a broad topic. Specificity drives conversion — 'How to write cold emails that get replies' outperforms 'Marketing guide'." ;
    oc:hasRationale "Specific problems create clear value propositions that resonate with the target audience and justify the email exchange" ;
    oc:severityLevel "HIGH" .

oc:kn_961b65ea a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When setting targets or evaluating lead magnet performance" ;
    oc:directiveContent "Landing page conversion benchmarks: warm traffic 20-40%, cold traffic 5-15%. By format: checklists 30-50%, templates 25-45%, ebooks 20-35%, quizzes 30-50%. Cost per lead: organic $0-5, Facebook $3-15, Google $10-50, LinkedIn $25-75." ;
    oc:hasRationale "Benchmark data prevents unrealistic expectations and helps identify underperforming lead magnets for optimization" .

oc:kn_9975c85f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing lead magnet deliverable" ;
    oc:directiveContent "Each lead magnet should use one clear format only — do not mix ebook + video + spreadsheet. It must work on mobile with no special software required." ;
    oc:hasRationale "Mixed formats create confusion and technical barriers; single-format content is easier to consume and has higher completion rates" .

oc:kn_af860006 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting lead magnet planning" ;
    oc:directiveContent "Assumes the business has or can build a website with email capture capability, has existing content or expertise to package, and has defined their ideal customer profile." ;
    oc:hasRationale "Without these foundations, lead magnet strategy cannot be meaningfully tied to business outcomes" .

oc:kn_b31276d4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining scope and depth of any lead magnet" ;
    oc:directiveContent "Lead magnets should be high perceived value but consumable in under 30 minutes (ideally under 10), with immediate actionable takeaways." ;
    oc:hasRationale "Quick-consumption content delivers value fast, building trust before the prospect loses interest or forgets the download" ;
    oc:severityLevel "HIGH" .

oc:kn_f32f30b8 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When measuring lead magnet effectiveness post-launch" ;
    oc:directiveContent "Good lead magnet quality is indicated by: higher-than-average email engagement, leads progressing to trial/demo at expected rates, low unsubscribe rate after delivery, leads matching ICP demographics." ;
    oc:hasRationale "Volume alone doesn't indicate success; these signals confirm the lead magnet is attracting the right audience" .

oc:kn_ff45c48b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting lead magnet format for a specific audience segment" ;
    oc:directiveContent "Match lead magnet format to buyer stage: awareness → education (checklists, cheat sheets, ebooks), consideration → evaluation tools (comparison templates, assessments), decision → implementation help (templates, free trials, migration guides)." ;
    oc:hasRationale "Content that aligns with where the buyer is in their journey generates higher quality leads and better downstream conversion" .

oc:req_1e5e6f8e a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of marketing funnel stages (awareness, consideration, decision)" .

oc:req_597b4efc a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Familiarity with email marketing and CRM systems" .

oc:req_79b2c721 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Basic understanding of conversion rate optimization" .

