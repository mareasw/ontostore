                                            oc:itemOrder 6 ;
                                            oc:itemText "**Delivery**: Instant download vs. email delivery" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "**Form fields**: Email-only vs. email + name" ] ] ;
