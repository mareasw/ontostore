                                            oc:itemOrder 1 ;
                                            oc:itemText "**Email only** — highest conversion, lowest friction" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "**Email + name** — enables personalization, slight friction increase" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "**Email + company/role** — better lead qualification, more friction" ],
