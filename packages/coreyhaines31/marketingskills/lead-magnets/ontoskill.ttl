oc:skill_coreyhaines31_marketingskills_lead_magnets a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "lead-magnets" ;
    skos:broader "Marketing strategy framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/lead-magnets" ;
    oc:contentHash "0f5d2e24cf78c1864a6f7c2caee78e8c4d247859b294f1ae8d3303f53cc70384" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "plans, creates, and optimizes gated content offers for email capture and lead generation across buyer stages" ;
    oc:handlesFailure oc:InsufficientBusinessContext,
        oc:InvalidInput ;
    oc:hasAllowedTool "Read" ;
    oc:hasArgumentHint "description of business, audience, and lead generation goals" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to create, plan, or optimize a lead magnet for email capture or lead generation. Also use when the user mentions \"lead magnet,\" \"gated content,\" \"content upgrade,\" \"downloadable,\" \"ebook,\" \"cheat sheet,\" \"checklist,\" \"template download,\" \"opt-in,\" \"freebie,\" \"PDF download,\" \"resource library,\" \"content offer,\" \"email capture content,\" \"Notion template,\" \"spreadsheet template,\" or \"what should I give away for emails.\" Use this for planning what to create and how to distribute it. For interactive tools as lead magnets, see free-tool-strategy. For writing the actual content, see copywriting. For the email sequence after capture, see email-sequence." ;
    oc:hasName "lead-magnets" ;
    oc:impartsKnowledge oc:kn_4a2dbc13,
        oc:kn_76208b6c,
        oc:kn_79b082c7,
        oc:kn_7ccd2f77,
        oc:kn_7e4fcf70,
        oc:kn_e6f86458,
        oc:kn_fe4aff0f ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProductMarketingContextAvailable ;
    oc:resolvesIntent "choose lead magnet format for target audience",
        "create lead magnet strategy",
        "design gating and capture strategy for content offers",
        "optimize lead magnet conversion rates",
        "plan lead magnet distribution and promotion",
        "plan lead magnets for email capture" ;
    oc:yieldsState oc:ContentOfferPlanned,
        oc:LeadMagnetStrategyCreated .

oc:kn_4a2dbc13 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When setting KPI targets and evaluating lead magnet performance" ;
    oc:directiveContent "Benchmark landing page conversion rates: 20-40% for warm traffic, 5-15% for cold traffic. Checklists achieve 30-50%, ebooks 20-35%, quizzes 30-50%. Lead-to-customer rate typically 1-5% for B2B." ;
    oc:hasRationale "Realistic benchmarks prevent setting unachievable goals and help identify underperforming lead magnets that need optimization" ;
    oc:severityLevel "LOW" .

oc:kn_76208b6c a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any lead magnet planning or strategy work" ;
    oc:directiveContent "Check for .agents/product-marketing-context.md or .claude/product-marketing-context.md before asking questions. Use existing context and only ask for gaps." ;
    oc:hasRationale "Leveraging existing product marketing context prevents redundant questions and ensures the lead magnet strategy is aligned with the product positioning" ;
    oc:severityLevel "MEDIUM" .

oc:kn_79b082c7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining lead magnet scope, length, and form capture fields" ;
    oc:directiveContent "Lead magnets should be consumable in under 30 minutes, ideally under 10. Every extra form field beyond email reduces conversion by 5-10%." ;
    oc:hasRationale "High perceived value with low time investment maximizes downloads. Friction in form fields directly reduces conversion rates." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7ccd2f77 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting or designing any lead magnet topic and scope" ;
    oc:directiveContent "Lead magnets must solve one specific problem, not address a broad topic. Specificity drives conversion; generic content gets ignored." ;
    oc:hasRationale "Specific problem-solving creates immediate perceived value and qualifies leads by relevance to their actual pain point" ;
    oc:severityLevel "HIGH" .

oc:kn_7e4fcf70 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning promotion and distribution strategy for lead magnets" ;
    oc:directiveContent "Content upgrades (blog-specific bonuses) convert 2-5x better than generic sidebar CTAs. Always prefer contextual offers over generic ones." ;
    oc:hasRationale "Contextual relevance dramatically increases conversion because the visitor's intent is already aligned with the offer" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e6f86458 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting lead magnet type and content approach" ;
    oc:directiveContent "Match the lead magnet format and content depth to the buyer stage: awareness needs education, consideration needs evaluation help, decision needs implementation support." ;
    oc:hasRationale "Mismatched stage content either overwhelms awareness-stage leads or underwhelms decision-stage leads, reducing both conversion and lead quality" ;
    oc:severityLevel "HIGH" .

oc:kn_fe4aff0f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting lead magnet topics and content direction" ;
    oc:directiveContent "Never create a lead magnet that doesn't naturally create a path to your product. If the content solves a problem unrelated to your product, leads won't convert to customers." ;
    oc:hasRationale "The lead magnet's purpose is not just list growth but qualified lead generation that feeds the sales pipeline. Disconnected content attracts unqualified leads." ;
    oc:severityLevel "HIGH" .

