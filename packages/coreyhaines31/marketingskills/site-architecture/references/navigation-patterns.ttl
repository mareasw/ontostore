oc:skill_coreyhaines31_marketingskills_site_architecture_navigation_patterns a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "navigation-patterns" ;
    skos:broader "navigation pattern library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/site-architecture" ;
    oc:contentHash "2efa772709b753e33d5018c007147ca30aaa95a04b04dc0df6227ea5a053078b" ;
    oc:differentia "provides structured templates and rules for header, footer, sidebar, breadcrumb, and mobile navigation across site types with SEO considerations" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_site_architecture ;
    oc:hasArgumentHint "site-type or navigation-context (e.g., \"SaaS\", \"documentation\", \"e-commerce\")" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_45c9808f,
        oc:kn_89b8bfd3,
        oc:kn_a3c058fb,
        oc:kn_b0c9af9b,
        oc:kn_c0db8811 ;
    oc:isUserInvocable true ;
    oc:nature "reference" ;
    oc:resolvesIntent "choose navigation pattern for site type",
        "design site navigation",
        "fix navigation anti-patterns",
        "optimize navigation for SEO",
        "plan navigation structure" .

oc:kn_45c9808f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting navigation patterns during site architecture planning" ;
    oc:directiveContent "Match navigation pattern to site type: simple headers for small business/SaaS, mega menus for feature-rich products, split navigation for apps with marketing+product contexts, column-based footers for most sites, and documentation sidebars with collapsible sections and sticky positioning for docs." ;
    oc:hasRationale "Different site types have different information density and user task flows; matching pattern to context reduces cognitive load and improves task completion." ;
    oc:severityLevel "MEDIUM" .

oc:kn_89b8bfd3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any navigation pattern" ;
    oc:directiveContent "Avoid nested dropdowns (dropdowns inside dropdowns), mystery icons without labels, hiding primary nav in hamburger menus on desktop, inconsistent navigation across pages, and breadcrumbs that don't match URL structure." ;
    oc:hasRationale "These anti-patterns cause user confusion, reduce discoverability, break accessibility, and send conflicting signals to search engines." ;
    oc:severityLevel "HIGH" .

oc:kn_a3c058fb a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When optimizing navigation for SEO impact" ;
    oc:directiveContent "Header nav links pass the strongest PageRank — place most important pages there. Footer links pass less value but are good for comparison/location pages. Implement breadcrumbs with Schema.org BreadcrumbList markup (JSON-LD preferred). Use descriptive anchor text like 'Analytics Features' instead of generic labels." ;
    oc:hasRationale "Navigation links are internal link signals that search engines use to understand site hierarchy and pass authority; structured markup enhances rich results." ;
    oc:severityLevel "HIGH" .

oc:kn_b0c9af9b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing header navigation for any site" ;
    oc:directiveContent "Limit header navigation to 4-6 items for simple sites; use mega menus with 2-4 columns max for complex sites. Order items by priority with CTA rightmost and visually distinct." ;
    oc:hasRationale "Excessive nav items cause decision paralysis and break on smaller screens; mega menus organize complexity without overwhelming users." ;
    oc:severityLevel "HIGH" .

oc:kn_c0db8811 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building navigation that must be both crawlable and mobile-friendly" ;
    oc:directiveContent "Never use JavaScript-only navigation — search engines need crawlable HTML links. Mobile navigation must include a visible CTA button without opening the hamburger menu, and bottom tab bars are limited to 3-5 items with icons and labels." ;
    oc:hasRationale "JS-only nav blocks crawler access to linked pages; mobile users need persistent access to primary actions without extra taps." ;
    oc:severityLevel "CRITICAL" .

