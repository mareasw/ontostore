    oc:yieldsState oc:NavigationPatternsSelected .

oc:kn_161330a9 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When laying out any navigation component" ;
    oc:directiveContent """Header: [Logo]   {Nav Items by Priority}   [CTA Button]
Mega Menu: 2-4 columns, grouped logically, "See all" link at bottom
Footer: 3-5 themed columns + logo + copyright + social links
Sidebar: Collapsible sections, current page highlighted, search at top
Breadcrumbs: {Home} > {Category} > {Current Page (not linked)}""" ;
    oc:templateVariables "Category",
        "Current Page",
        "Nav Items",
        "columns" .

oc:kn_242e265f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing navigation for search engine accessibility" ;
    oc:directiveContent "Navigation must use crawlable HTML links, not JavaScript-only rendering. Use descriptive anchor text (e.g., 'Analytics Features' not just 'Features'). Breadcrumbs must match the URL structure." ;
    oc:hasRationale "Search engines need crawlable HTML to discover and index pages; JS-only nav blocks crawling and descriptive anchors improve relevance signals." ;
    oc:severityLevel "CRITICAL" .

oc:kn_35bf5f53 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When planning site navigation from scratch" ;
    oc:directiveContent "1. Identify site type (simple SaaS, e-commerce, docs, blog) 2. Select header pattern (simple, mega menu, split) 3. Define footer columns (3-5 themed groups) 4. Add breadcrumbs with schema markup 5. Plan mobile adaptation (hamburger or bottom tab) 6. Verify nav matches URL structure 7. Confirm all links use crawlable HTML" ;
    oc:stepOrder 1 .

oc:kn_48f182f0 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing microdata breadcrumb schema as an alternative to JSON-LD" ;
    oc:codeLanguage "html" ;
    oc:directiveContent """<nav aria-label="Breadcrumb">
  <ol itemscope itemtype="https://schema.org/BreadcrumbList">
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a itemprop="item" href="/"><span itemprop="name">Home</span></a>
      <meta itemprop="position" content="1" />
    </li>
  </ol>
</nav>""" ;
    oc:hasRationale "Microdata breadcrumb markup can be used when JSON-LD is not feasible; includes aria-label for accessibility." .

oc:kn_826265f6 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When implementing any navigation component" ;
    oc:directiveContent "Logo always links to homepage. CTA button is rightmost and visually distinct. Active page gets a visual indicator. Breadcrumbs: every segment is a link except the current page. Footer: 3-5 themed columns." ;
    oc:hasRationale "Consistent conventions reduce cognitive load and match user expectations across the web." ;
    oc:severityLevel "MEDIUM" .

oc:kn_88a0d120 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing navigation for sites with both marketing and app contexts" ;
    oc:directiveContent "For split navigation, left side handles marketing/page navigation and right side handles authentication actions. For mobile, keep CTA visible without opening hamburger menu and ensure search is accessible from mobile menu." ;
    oc:hasRationale "Separating concerns between marketing and auth reduces clutter and keeps conversion actions always visible." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8d420e8e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing navigation for SEO" ;
    oc:directiveContent "Header nav links pass the strongest PageRank — place most important pages there. Footer links pass less value but are good for comparison and location pages. Sidebar links build section-level authority. Breadcrumbs with schema markup provide structural signals to search engines." ;
    oc:hasRationale "Internal links in navigation are a primary mechanism for distributing PageRank and signaling site hierarchy to search engines." ;
    oc:severityLevel "HIGH" .

oc:kn_b9211b96 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any site navigation" ;
    oc:directiveContent "Never have 8+ header items, nested dropdowns inside dropdowns, icon-only labels, hidden primary nav on desktop, inconsistent nav across pages, or 50+ unorganized footer links." ;
    oc:hasRationale "These patterns cause decision paralysis, poor discoverability, accessibility failures, and crawlability issues." ;
    oc:severityLevel "HIGH" .

oc:kn_efb153af a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting navigation complexity based on site type" ;
    oc:directiveContent "Simple sites: 4-6 header items. Mega menus: 2-4 columns max with logical grouping, no nested dropdowns. Mobile bottom tab bars: 3-5 items with icons+labels, most important action centered." ;
    oc:hasRationale "Matching navigation complexity to site complexity prevents overwhelming users on simple sites or under-serving them on complex ones." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fece58d4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing breadcrumb schema markup for SEO" ;
    oc:codeLanguage "json" ;
    oc:directiveContent """{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://example.com/" },
    { "@type": "ListItem", "position": 2, "name": "Features", "item": "https://example.com/features" },
    { "@type": "ListItem", "position": 3, "name": "Analytics" }
  ]
}""" ;
    oc:hasRationale "JSON-LD is the recommended format for breadcrumb structured data and provides clear structural signals to search engines." .

