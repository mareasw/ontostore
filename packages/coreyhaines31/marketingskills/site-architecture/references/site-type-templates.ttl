oc:kn_23a05a2a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When placing high-priority pages in navigation" ;
    oc:directiveContent "Do not bury critical pages (pricing, signup, contact) in dropdowns or sub-navigation. They must be directly visible in the primary header." ;
    oc:hasRationale "Critical conversion pages lose 50%+ traffic when hidden behind interactions; direct visibility maximizes conversion" ;
    oc:severityLevel "HIGH" .

oc:kn_3b308147 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When documenting a site page hierarchy" ;
    oc:directiveContent """Homepage (/)
├── Section (/section-slug)
│   ├── Sub-section (/section-slug/sub-slug)
│   └── [Dynamic items] (/section-slug/{item-slug})
├── About (/about)
└── Contact (/contact)""" ;
    oc:templateVariables "item-slug",
        "section-slug",
        "sub-slug" .

oc:kn_6643a120 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When planning any site architecture" ;
    oc:directiveContent "Every site must include /privacy and /terms pages accessible from the footer, regardless of site type or complexity." ;
    oc:hasRationale "Legal compliance (GDPR, CCPA) requires accessible privacy policy and terms of service pages" ;
    oc:severityLevel "CRITICAL" .

oc:kn_66f1650f a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When creating a URL map for site planning" ;
    oc:directiveContent """| Page | URL | Nav Location | Priority |
|------|-----|-------------|----------|
| {page_name} | /{url_path} | {nav_placement} | {priority} |""" ;
    oc:templateVariables "nav_placement",
        "page_name",
        "priority",
        "url_path" .

oc:kn_899b081b a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before selecting a template, confirm the site type" ;
    oc:directiveContent "The six supported site types are: SaaS Marketing Site, Content/Blog Site, E-Commerce, Documentation Site, Hybrid SaaS+Content, and Small Business/Local." .

oc:kn_be840bef a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing footer navigation for SaaS or hybrid sites" ;
    oc:directiveContent "Use footer columns to organize Product, Resources, Company, and Legal links as a secondary navigation layer for pages not in the header." ;
    oc:hasRationale "Footers serve as catch-all navigation and SEO internal linking without cluttering the primary header" .

oc:kn_c6093758 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When planning a new site's architecture" ;
    oc:directiveContent "1. Identify the site type from the six templates 2. Use the matching ASCII hierarchy as the starting structure 3. Customize page slugs and names for the specific brand 4. Apply the URL map patterns for nav placement and priority 5. Adapt the header/footer navigation recommendations to the brand's needs" ;
    oc:stepOrder 1 .

oc:kn_ccf1f169 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any site's header navigation" ;
    oc:directiveContent "Header navigation should contain 4-7 primary items plus a prominent CTA button. Never exceed 7 top-level nav items." ;
    oc:hasRationale "Cognitive load research shows users struggle to process more than 7 nav items; the CTA must stand out visually from navigation links" ;
    oc:severityLevel "HIGH" .

oc:kn_cdcfcd6f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining URL structures for a specific site type" ;
    oc:directiveContent "Match URL depth to site type complexity: SaaS sites can go 3 levels deep, small business sites should stay at 1-2 levels max." ;
    oc:hasRationale "URL depth correlates with navigation complexity; simpler businesses need simpler sites to avoid confusing visitors" .

