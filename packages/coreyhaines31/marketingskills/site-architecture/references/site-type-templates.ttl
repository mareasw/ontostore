@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_site_architecture_site_type_templates a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "site-type-templates" ;
    skos:broader "Site architecture template collection" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/site-architecture" ;
    oc:contentHash "3c3cd7ce5e31c502dc071baf82bb58cb30f5edf4a2fd8ca052fbc8f3777db140" ;
    oc:differentia "Provides complete page hierarchy templates with ASCII trees, URL maps, and navigation specs for six common site types: SaaS marketing, Content/Blog, E-Commerce, Documentation, Hybrid SaaS+Content, and Small Business/Local" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_site_architecture ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "site-type (saas | content | ecommerce | docs | hybrid | small-business)" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_1c1854ea,
        oc:kn_5375db82,
        oc:kn_cd68a740,
        oc:kn_ed128fc0,
        oc:kn_f8e76f4c ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:requiresState oc:SiteTypeIdentified ;
    oc:resolvesIntent "find example page hierarchy for SaaS marketing site",
        "find example page hierarchy for blog/content site",
        "find example page hierarchy for documentation site",
        "find example page hierarchy for e-commerce site",
        "find example page hierarchy for small business site",
        "get site structure template for a specific site type",
        "reference URL patterns and navigation layout for common site types" ;
    oc:yieldsState oc:NavigationSpecified,
        oc:PageHierarchyDefined,
        oc:URLMapGenerated .

oc:kn_1c1854ea a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When validating a completed site architecture plan against a template" ;
    oc:directiveContent "A well-applied template should produce a URL map where every page has a clear nav location (header, dropdown, sidebar, or footer), a priority level, and a consistent URL pattern that mirrors the hierarchy." ;
    oc:hasRationale "The URL map and navigation spec are the verification artifacts — missing nav locations or inconsistent URLs indicate gaps" ;
    oc:severityLevel "LOW" .

oc:kn_5375db82 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing navigation for any site type" ;
    oc:directiveContent "Match the navigation complexity to the site type: SaaS uses 6-7 header items with dropdowns, content sites use sidebars on blog, e-commerce uses mega menus, docs use persistent left sidebars, small business uses simple flat nav." ;
    oc:hasRationale "Navigation patterns that don't match the site type create friction and reduce findability" ;
    oc:severityLevel "MEDIUM" .

oc:kn_cd68a740 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning a small business or local site architecture" ;
    oc:directiveContent "Small business sites must stay flat (1-2 levels max) with every page reachable from the header. Do not add unnecessary depth." ;
    oc:hasRationale "Small sites with few pages become confusing if over-structured; flat hierarchy ensures visitors find everything quickly" ;
    oc:severityLevel "HIGH" .

oc:kn_ed128fc0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which template to use as a starting point" ;
    oc:directiveContent "Never apply the SaaS or Hybrid template to a small business site, or the Documentation template to an e-commerce site. Site type mismatch leads to bloated navigation and unnecessary pages." ;
    oc:hasRationale "Using the wrong template creates pages that serve no purpose and navigation that overwhelms users instead of guiding them" ;
    oc:severityLevel "HIGH" .

oc:kn_f8e76f4c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a site type template for a new project" ;
    oc:directiveContent "Use these templates as starting points, not rigid prescriptions. Adapt the hierarchy, URL patterns, and navigation to the specific business context and audience needs." ;
    oc:hasRationale "Every business has unique requirements; templates provide structure but must be customized to be effective" ;
    oc:severityLevel "MEDIUM" .

