    oc:isUserInvocable true ;
    oc:nature "Template" ;
    oc:resolvesIntent "create site architecture diagram",
        "document navigation zones",
        "generate visual sitemap",
        "map internal linking",
        "plan site restructuring",
        "visualize site hierarchy" .

oc:kn_1da1f3c7 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When grouping pages by navigation zone using subgraphs" ;
    oc:codeLanguage "mermaid" ;
    oc:directiveContent """subgraph "Header Nav"
    HOME["Homepage"]
    FEAT["Features"]
end
subgraph "Footer Nav"
    ABOUT["About"]
end
HOME --> FEAT
HOME --> ABOUT""" .

oc:kn_28f5bb52 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When illustrating hub-and-spoke content model with cross-links" ;
    oc:codeLanguage "mermaid" ;
    oc:directiveContent """HUB["SEO Guide<br/>(Hub Page)"]
HUB --> S1["Keyword Research"]
HUB --> S2["On-Page SEO"]
S1 -.-> S2
S2 -.-> S3
style HUB fill:#f9f,stroke:#333,stroke-width:2px""" .

oc:kn_33124c10 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating a basic top-down page hierarchy diagram" ;
    oc:codeLanguage "mermaid" ;
    oc:directiveContent """graph TD
    HOME["Homepage<br/>/"] --> FEAT["Features<br/>/features"]
    HOME --> PRICE["Pricing<br/>/pricing"]
    FEAT --> F1["Analytics<br/>/features/analytics"]""" .

oc:kn_7902e501 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When comparing current vs proposed site structures side by side" ;
    oc:directiveContent """graph TD
    subgraph "Before"
        B_HOME["Homepage"] --> B_P1["Page 1"]
    end
    subgraph "After"
        A_HOME["Homepage"] --> A_S1["Features"]
        A_S1 --> A_P1["Feature A"]
    end""" ;
    oc:templateVariables "After pages",
        "After sections",
        "Before pages" .

oc:kn_97329843 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating sitemaps for implementation teams" ;
    oc:directiveContent "Include URL paths in diagram nodes using <small> HTML tags so the sitemap doubles as a URL reference document." ;
    oc:hasRationale "Developers and stakeholders need both the visual hierarchy and the actual URL paths to implement the architecture" .

oc:kn_bec69b44 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When showing URL paths alongside page names in diagram nodes" ;
    oc:codeLanguage "mermaid" ;
    oc:directiveContent """HOME["Homepage<br/><small>/</small>"] --> PROD["Product<br/><small>/product</small>"]
PROD --> P1["Analytics<br/><small>/product/analytics</small>"]""" .

oc:kn_ee8ed08f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When color-coding pages by status: green=existing, blue=new, red=remove, yellow=restructure, purple=high-priority" ;
    oc:codeLanguage "mermaid" ;
    oc:directiveContent """style HOME fill:#4CAF50,color:#fff
style NEW fill:#2196F3,color:#fff
style REMOVE fill:#f44336,color:#fff""" .

oc:kn_eee75d8f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing diagram direction and line style" ;
    oc:directiveContent "Use graph TD for hierarchy diagrams, graph LR for internal linking flows between site sections. Use solid lines for primary relationships and dashed lines (--) for cross-links." ;
    oc:hasRationale "TD emphasizes parent-child hierarchy; LR emphasizes lateral relationships between peer sections" .

