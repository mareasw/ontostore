@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_site_architecture_mermaid_templates a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "mermaid-templates" ;
    skos:broader "Template library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/site-architecture" ;
    oc:contentHash "362190c7d3f419d5f445170f1fb17beecc163937d2068922893b7a69eeb25f0f" ;
    oc:differentia "provides copy-paste-ready Mermaid diagram patterns for visualizing site architecture as sitemaps, navigation zones, internal linking flows, and restructuring comparisons" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_site_architecture ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "site-structure-type (e.g., 'basic hierarchy', 'navigation zones', 'hub-and-spoke', 'internal linking', 'before-after restructuring')" ;
    oc:hasCategory "document" ;
    oc:hasRequirement oc:req_95d43325,
        oc:req_de9e9355 ;
    oc:impartsKnowledge oc:kn_0ad18a30,
        oc:kn_1821e309,
        oc:kn_2a241223,
        oc:kn_77cc3fc7,
        oc:kn_a0b782d8 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:SiteStructurePlanned ;
    oc:resolvesIntent "compare before and after site restructuring",
        "create mermaid site structure diagram",
        "generate visual sitemap diagram",
        "illustrate hub-and-spoke content model",
        "show internal linking flow visually",
        "visualize navigation zones in a diagram" ;
    oc:yieldsState oc:VisualSitemapGenerated .

oc:kn_0ad18a30 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When visualizing content cluster or topic pillar architecture in Mermaid" ;
    oc:directiveContent "For hub-and-spoke diagrams, use solid lines (--) for primary hub-spoke links and dashed lines (-.->) for cross-links between spokes, and always style the hub node distinctly to visually anchor the cluster." ;
    oc:hasRationale "Distinguishing link types visually prevents misinterpretation of which relationships are primary hierarchical connections vs. supplementary cross-references, which have different SEO and UX implications." ;
    oc:severityLevel "LOW" .

oc:kn_1821e309 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning a site restructure or presenting architectural changes for approval" ;
    oc:directiveContent "For restructuring projects, always produce a before/after comparison using paired subgraphs so stakeholders can see what changes, rather than only showing the proposed new structure." ;
    oc:hasRationale "Before/after comparison makes the delta explicit, reducing the risk of stakeholders misunderstanding the scope of changes and making it easier to identify pages that need redirects." ;
    oc:severityLevel "HIGH" .

oc:kn_2a241223 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating Mermaid diagrams that need to communicate navigation design decisions" ;
    oc:directiveContent "Use subgraphs to group pages by navigation zone (Header Nav, Footer Nav, Feature Pages) rather than by hierarchy level alone, since stakeholders primarily think in terms of where pages appear in navigation." ;
    oc:hasRationale "Navigation zone grouping maps directly to implementation decisions (which nav component renders which links), making the diagram actionable for both design and development teams." ;
    oc:severityLevel "MEDIUM" .

oc:kn_77cc3fc7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a Mermaid diagram template for a site architecture deliverable" ;
    oc:directiveContent "Choose the appropriate Mermaid template based on what aspect of site architecture you need to communicate: basic hierarchy for structure, subgraphs for navigation zones, graph LR for cross-section linking flows, and side-by-side subgraphs for restructuring comparisons." ;
    oc:hasRationale "Different architectural concerns (hierarchy, navigation placement, linking, restructuring) are best communicated with distinct visual layouts, and using the wrong template obscures the intended insight." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a0b782d8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When adding visual styling to Mermaid site diagrams to indicate page status or priority" ;
    oc:directiveContent "Use consistent color-coding conventions across all Mermaid sitemaps: green (#4CAF50) for existing pages, blue (#2196F3) for new pages, red (#f44336) for pages to remove, yellow (#FFC107) for pages to restructure, and purple (#9C27B0) for high-priority or CTA pages." ;
    oc:hasRationale "Standardized color conventions allow stakeholders to instantly interpret page status without a legend, making diagrams self-documenting and consistent across projects." ;
    oc:severityLevel "MEDIUM" .

oc:req_95d43325 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Site architecture concepts (hierarchy, navigation, internal linking)" .

oc:req_de9e9355 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Mermaid graph syntax (graph TD, graph LR, subgraph, style)" .

