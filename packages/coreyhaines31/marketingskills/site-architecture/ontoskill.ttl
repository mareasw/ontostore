@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_site_architecture a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "site-architecture" ;
    skos:broader "Information architecture planning framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/site-architecture" ;
    oc:contentHash "e190f2d7fa36ba271e8a47a92e5ccbeed8bb67e2273146e22a71e91375ce3fea" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "produces page hierarchies, navigation specs, URL structures, and internal linking plans for websites organized by site type" ;
    oc:handlesFailure oc:InsufficientContext,
        oc:InvalidInput ;
    oc:hasArgumentHint "site type, current/renewal status, page count, key pages" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to plan, map, or restructure their website's page hierarchy, navigation, URL structure, or internal linking. Also use when the user mentions \"sitemap,\" \"site map,\" \"visual sitemap,\" \"site structure,\" \"page hierarchy,\" \"information architecture,\" \"IA,\" \"navigation design,\" \"URL structure,\" \"breadcrumbs,\" \"internal linking strategy,\" \"website planning,\" \"what pages do I need,\" \"how should I organize my site,\" or \"site navigation.\" Use this whenever someone is planning what pages a website should have and how they connect. NOT for XML sitemaps (that's technical SEO — see seo-audit). For SEO audits, see seo-audit. For structured data, see schema-markup." ;
    oc:hasName "site-architecture" ;
    oc:impartsKnowledge oc:kn_039a7b68,
        oc:kn_1db449fe,
        oc:kn_6a7ad846,
        oc:kn_9797a0a3,
        oc:kn_a512eabb,
        oc:kn_d01e1cfd,
        oc:kn_dd0668b9,
        oc:kn_f231033e ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProductMarketingContextAvailable ;
    oc:resolvesIntent "create visual sitemaps",
        "design internal linking strategy",
        "design site navigation and URL patterns",
        "map URL structure for site sections",
        "organize pages for new website",
        "plan website page hierarchy and structure",
        "restructure existing website architecture" ;
    oc:yieldsState oc:InternalLinkingPlanCreated,
        oc:NavigationSpecified,
        oc:PageHierarchyDefined,
        oc:URLStructureMapped .

oc:kn_039a7b68 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When users ask about XML sitemaps, crawl errors, or Search Console issues" ;
    oc:directiveContent "This skill handles site structure design (page hierarchy, navigation, URL patterns) — NOT XML sitemaps, crawl errors, or technical SEO troubleshooting. Defer technical SEO tasks to seo-audit." ;
    oc:hasRationale "Clear scope boundary prevents misapplication; XML sitemaps and crawl diagnostics are technical SEO, not information architecture" ;
    oc:severityLevel "HIGH" .

oc:kn_1db449fe a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing header navigation for any site type" ;
    oc:directiveContent "Limit primary header navigation to 4-7 items maximum. More items cause decision paralysis and become unreadable on smaller screens." ;
    oc:hasRationale "Hick's Law applies — more choices increase decision time and reduce conversion on navigation" ;
    oc:severityLevel "HIGH" .

oc:kn_6a7ad846 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any site architecture planning" ;
    oc:directiveContent "Check for product-marketing-context.md (.agents/ or .claude/) before asking questions. Use existing context and only ask for gaps not already covered." ;
    oc:hasRationale "Leveraging existing product context avoids redundant questions and ensures architecture aligns with product positioning" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9797a0a3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning site architecture for programmatic SEO or large content sections" ;
    oc:directiveContent "Organize scaled content (200+ pages) around hub pages using the hub-and-spoke model: hub pages link to all spokes, spokes link back to hub, spokes cross-link where relevant. Keep programmatic pages out of primary navigation." ;
    oc:hasRationale "Hub-and-spoke distributes link equity efficiently, establishes topical authority, and prevents nav clutter from scaled content" ;
    oc:severityLevel "HIGH" .

oc:kn_a512eabb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining URL patterns for any page type" ;
    oc:directiveContent "URLs must be human-readable, use hyphens not underscores, reflect the hierarchy, be lowercase, and consistently use or omit trailing slashes." ;
    oc:hasRationale "Clean URLs improve click-through rates, are easier to share, and provide SEO signals about content hierarchy" ;
    oc:severityLevel "HIGH" .

oc:kn_d01e1cfd a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating internal linking plans" ;
    oc:directiveContent "Every page must have at least one internal link pointing to it, use descriptive anchor text (not 'click here'), and important pages should receive the most inbound internal links." ;
    oc:hasRationale "Orphan pages can't be discovered by users or crawlers; strategic internal linking distributes PageRank and guides user journeys" ;
    oc:severityLevel "MEDIUM" .

oc:kn_dd0668b9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining URL structure or restructuring an existing site" ;
    oc:directiveContent "Never change URLs without setting up 301 redirects from every old URL to its new URL. Avoid dates in blog URLs, IDs in URLs, over-nesting, and inconsistent parent patterns." ;
    oc:hasRationale "Missing redirects lose backlink equity and create broken pages; poor URL patterns harm SEO and readability" ;
    oc:severityLevel "CRITICAL" .

oc:kn_f231033e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any page hierarchy" ;
    oc:directiveContent "Users should reach any important page within 3 clicks from the homepage. If critical pages are buried 4+ levels deep, the hierarchy needs flattening." ;
    oc:hasRationale "Deep hierarchies reduce findability and increase user frustration; 3 clicks balances depth with discoverability" ;
    oc:severityLevel "HIGH" .

