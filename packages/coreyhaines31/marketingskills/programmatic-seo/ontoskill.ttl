oc:skill_coreyhaines31_marketingskills_programmatic_seo a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "programmatic-seo" ;
    skos:broader "SEO strategy framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/programmatic-seo" ;
    oc:contentHash "84ef922039d71e69954cb154b4cb982857f5c2b8738af257090460326d9f5d45" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "systematically creates SEO-optimized pages at scale using templates and data to target many keyword variations without incurring thin content penalties" ;
    oc:extends oc:skill_seo_audit ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAllowedTool "Glob",
        "Read",
        "Write" ;
    oc:hasArgumentHint "keyword pattern, data sources, target page count" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to create SEO-driven pages at scale using templates and data. Also use when the user mentions \"programmatic SEO,\" \"template pages,\" \"pages at scale,\" \"directory pages,\" \"location pages,\" \"[keyword] + [city] pages,\" \"comparison pages,\" \"integration pages,\" \"building many pages for SEO,\" \"pSEO,\" \"generate 100 pages,\" \"data-driven pages,\" or \"templated landing pages.\" Use this whenever someone wants to create many similar pages targeting different keywords or locations. For auditing existing SEO issues, see seo-audit. For content strategy planning, see content-strategy." ;
    oc:hasName "programmatic-seo" ;
    oc:impartsKnowledge oc:kn_2f468bd1,
        oc:kn_76a3d6db,
        oc:kn_8a45b977,
        oc:kn_a947cd16,
        oc:kn_ea5fc1c7,
        oc:kn_f8497ef0 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "audit and improve existing programmatic SEO page quality",
        "build directory, location, comparison, or integration pages for SEO",
        "create programmatic SEO pages at scale",
        "design template-driven landing page strategies",
        "plan SEO page generation using data" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_2f468bd1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any programmatic SEO template or generating pages at scale" ;
    oc:directiveContent "Never create pages by simply swapping variable names (e.g., city names) in an identical template—each page must provide genuinely unique value beyond variable substitution." ;
    oc:hasRationale "Google penalizes thin/doorway pages that lack unique value; variable-swap pages appear as duplicate content and risk manual actions or deindexing." ;
    oc:severityLevel "CRITICAL" .

oc:kn_76a3d6db a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Pre-launch quality assurance for any programmatic SEO implementation" ;
    oc:directiveContent "Before generating programmatic pages, verify: each page provides unique value, unique titles and meta descriptions exist, pages are connected via internal links and included in the XML sitemap, and no conflicting noindex directives are present." ;
    oc:hasRationale "Skipping pre-launch checks risks indexation failures, crawl budget waste, and potential Google penalties that are hard to reverse." ;
    oc:severityLevel "HIGH" .

oc:kn_8a45b977 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When selecting which of the 12 programmatic SEO playbooks to implement" ;
    oc:directiveContent "Match the playbook type to your available assets: Templates/Examples for creative products, Locations for local presence, Integrations for connected products, Personas for multi-segment audiences, Comparisons for competitive landscapes." ;
    oc:hasRationale "Choosing the wrong playbook wastes resources on pages that don't leverage existing data advantages or align with search intent patterns." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a947cd16 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting data sources to populate programmatic SEO pages" ;
    oc:directiveContent "Prioritize proprietary or product-derived data over public data sources—data defensibility follows a hierarchy: proprietary > product-derived > user-generated > licensed > public." ;
    oc:hasRationale "Proprietary data creates unique content that competitors cannot replicate, improving rankings and providing genuine user value. Public data alone yields undifferentiated pages." ;
    oc:severityLevel "HIGH" .

oc:kn_ea5fc1c7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining URL structure for programmatic SEO pages" ;
    oc:directiveContent "Use subfolders (yoursite.com/path/) rather than subdomains (path.yoursite.com/) for programmatic pages to consolidate domain authority." ;
    oc:hasRationale "Subdomains are treated as separate sites by search engines, splitting link equity and domain authority. Subfolders inherit and reinforce the root domain's authority." ;
    oc:severityLevel "HIGH" .

oc:kn_f8497ef0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining the scale and scope of programmatic SEO page generation" ;
    oc:directiveContent "Quality over quantity: it is better to have 100 great programmatic pages than 10,000 thin ones. Do not generate pages for keyword variations with zero search demand." ;
    oc:hasRationale "Over-generating thin pages dilutes site quality signals, wastes crawl budget, and can trigger Google's quality algorithms to suppress the entire site." ;
    oc:severityLevel "CRITICAL" .

