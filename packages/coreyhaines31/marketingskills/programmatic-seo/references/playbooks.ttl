oc:kn_025da206 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which programmatic SEO playbook to pursue" ;
    oc:directiveContent "Match your playbook to your existing business assets — proprietary data → Directories/Profiles, integrations → Integrations pages, design product → Templates/Examples, multi-segment audience → Personas, local presence → Locations, utility product → Conversions, content expertise → Glossary/Curation, international potential → Translations, competitor landscape → Comparisons." ;
    oc:hasRationale "The best playbook is the one your business already has natural assets to support, reducing content creation cost and increasing authenticity." .

oc:kn_12ff0923 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating programmatic content at scale" ;
    oc:directiveContent "Avoid affiliate-driven rankings without genuine evaluation, Wikipedia rehash for profiles, vaporware integrations, and thin city-swap location pages — these are the specific failure modes called out for each playbook." ;
    oc:hasRationale "These anti-patterns are the most common reasons programmatic SEO pages get penalized or ignored by search engines." ;
    oc:severityLevel "HIGH" .

oc:kn_96b7ecd8 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing URL architecture for programmatic SEO pages" ;
    oc:directiveContent "Use consistent, descriptive URL structures per playbook: /templates/[type]/, /best/[category]/, /convert/[from]-to-[to]/, /compare/[x]-vs-[y]/, /examples/[type]/, /[service]/[city]/, /for/[persona]/, /integrations/[product]/, /glossary/[term]/, /[lang]/[page]/, /directory/[category]/, /people/[name]/." ;
    oc:hasRationale "Consistent URL patterns improve crawlability, user comprehension, and make programmatic generation predictable." .

oc:kn_aaa6d938 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning a programmatic SEO strategy beyond a single playbook" ;
    oc:directiveContent "Layer multiple playbooks together for compound reach: Locations + Personas, Curation + Locations, Integrations + Personas, Glossary + Translations." ;
    oc:hasRationale "Combining playbooks multiplies page count and captures longer-tail search queries without proportionally more effort." .

oc:kn_ab35fa62 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing any of the 12 playbooks" ;
    oc:directiveContent "Every playbook has minimum value requirements that must be met — e.g., Templates must be actually usable (not previews), Comparisons need honest balanced analysis with real feature data, Locations need actual local data (not just city name swaps), Translations need native speaker review (not just Google Translate)." ;
    oc:hasRationale "Thin or low-quality programmatic pages trigger Google quality penalties and erode brand trust." ;
    oc:severityLevel "HIGH" .

