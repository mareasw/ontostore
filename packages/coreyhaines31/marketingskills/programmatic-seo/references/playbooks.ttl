oc:skill_coreyhaines31_marketingskills_programmatic_seo_playbooks a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "playbooks" ;
    skos:broader "Reference catalog of proven programmatic SEO page-generation patterns" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/programmatic-seo" ;
    oc:contentHash "b2edf9b9434729630f746fec2f228e50aa5b6fe1bf753e0d4d46ecf8a3137274" ;
    oc:differentia "Defines 12 distinct playbook archetypes (Templates, Curation, Conversions, Comparisons, Examples, Locations, Personas, Integrations, Glossary, Translations, Directory, Profiles) with URL structures, value requirements, and asset-matching guidance for selecting and combining them" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_programmatic_seo ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "business context or asset type (e.g. 'we have a design tool' or 'SaaS with integrations')" ;
    oc:hasCategory "marketing" ;
    oc:hasRequirement oc:req_5cb12cc6,
        oc:req_b49e9785 ;
    oc:impartsKnowledge oc:kn_1075122c,
        oc:kn_1cfb461d,
        oc:kn_245a3088,
        oc:kn_702981fb,
        oc:kn_92e49fec,
        oc:kn_b5cde2de,
        oc:kn_bf49d9d8 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProductContextUnderstood ;
    oc:resolvesIntent "choose the right programmatic SEO playbook for a product",
        "combine multiple programmatic SEO playbooks together",
        "design URL structures for programmatic SEO pages",
        "match business assets to the best pSEO playbook",
        "understand what programmatic SEO playbooks are available" ;
    oc:yieldsState oc:PlaybookSelected,
        oc:PlaybookStrategyDefined .

oc:kn_1075122c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning programmatic SEO strategy" ;
    oc:directiveContent "Do not launch all 12 playbooks simultaneously — start with the 1-2 playbooks that best match your strongest assets and expand only after validating traction." ;
    oc:hasRationale "Spreading effort across too many playbooks before validating any produces mediocrity across the board and makes it impossible to diagnose what works." ;
    oc:severityLevel "HIGH" .

oc:kn_1cfb461d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing the Locations playbook" ;
    oc:directiveContent "Location playbook pages must include actual local data and location-specific insights — never just swap city names into a template with identical content." ;
    oc:hasRationale "Thin location pages with no local differentiation are a well-known spam signal and can trigger sitewide quality penalties." ;
    oc:severityLevel "CRITICAL" .

oc:kn_245a3088 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Post-launch maintenance of programmatic SEO pages" ;
    oc:directiveContent "Most playbook content requires regular updates to maintain ranking: curation lists need freshness signals, comparisons need product change updates, glossary terms need accuracy reviews." ;
    oc:hasRationale "Stale content loses rankings over time as competitors publish fresher alternatives and Google favors recently-updated pages for many of these query types." ;
    oc:severityLevel "MEDIUM" .

oc:kn_702981fb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a single playbook has been validated and you want to expand scope" ;
    oc:directiveContent "Combine playbooks to compound coverage: Locations + Personas, Curation + Locations, Integrations + Personas, or Glossary + Translations create unique intersection pages with lower competition." ;
    oc:hasRationale "Combined playbooks create more specific, long-tail page targets that competitors rarely cover, multiplying reachable keyword space." ;
    oc:severityLevel "MEDIUM" .

oc:kn_92e49fec a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which programmatic SEO playbook(s) to implement" ;
    oc:directiveContent "Match your playbook choice to your existing business assets — proprietary data favors Stats/Directories/Profiles, design products favor Templates/Examples, multi-segment audiences favor Personas, local presence favors Locations." ;
    oc:hasRationale "Forcing a playbook that doesn't align with available assets leads to thin, low-value pages that won't rank or convert." ;
    oc:severityLevel "HIGH" .

oc:kn_b5cde2de a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing site architecture for programmatic SEO pages" ;
    oc:directiveContent "Follow consistent URL patterns per playbook type: /templates/[type]/, /best/[category]/, /convert/[from]-to-[to]/, /compare/[x]-vs-[y]/, /[service]/[city]/, /for/[persona]/, /integrations/[product]/, /glossary/[term]/, /[lang]/[page]/, /directory/[category]/, /people/[name]/." ;
    oc:hasRationale "Predictable URL structures improve crawlability, enable internal linking patterns, and create clear topical silos that reinforce topical authority." ;
    oc:severityLevel "HIGH" .

oc:kn_bf49d9d8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building pages for any of the 12 playbooks" ;
    oc:directiveContent "Every playbook page must deliver genuine value: real data, usable templates, honest evaluations, accurate conversions, or actionable insights — not just keyword-stuffed permutations." ;
    oc:hasRationale "Google's Helpful Content System penalizes pages that exist solely for search traffic without providing real utility to users." ;
    oc:severityLevel "CRITICAL" .

oc:req_5cb12cc6 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Familiarity with the parent programmatic-seo skill concepts" .

oc:req_b49e9785 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of SEO fundamentals and search intent" .

