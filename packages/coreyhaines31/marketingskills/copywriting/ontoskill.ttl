                                            oc:itemOrder 2 ;
                                            oc:itemText "What makes it different from alternatives?" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "What are you selling or offering?" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "3. Product/Offer" ],
