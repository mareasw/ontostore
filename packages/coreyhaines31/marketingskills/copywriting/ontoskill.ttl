                            oc:contentOrder 6 ;
                            oc:textContent "Maintain consistency, but adjust intensity:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Before writing, establish:" ],
                        [ a oc:BulletList ;
