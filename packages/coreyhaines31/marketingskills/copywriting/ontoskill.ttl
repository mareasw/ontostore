                            oc:contentOrder 4 ;
                            oc:textContent "**Brand personality:**" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 7 ;
                            oc:hasItem [ a oc:BulletItem ;
