oc:skill_coreyhaines31_marketingskills_copywriting a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "copywriting" ;
    skos:broader "Conversion copywriting methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/copywriting" ;
    oc:contentHash "b15fdd74e1dae1ac536fb89bed08dcae7caf56f7844104b471a3d4c2b37003ae" ;
    oc:differentia "that produces persuasive marketing copy for web pages through structured frameworks, voice-of-customer principles, and page-type-specific guidance" ;
    oc:extends oc:skill_product_marketing_context ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAlias "cta copy",
        "headline help",
        "hero copy",
        "marketing copy",
        "rewrite copy",
        "tagline",
        "value proposition",
        "write copy" ;
    oc:hasArgumentHint "page type (homepage, landing page, pricing, feature, about) and target audience" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to write, rewrite, or improve marketing copy for any page — including homepage, landing pages, pricing pages, feature pages, about pages, or product pages. Also use when the user says \"write copy for,\" \"improve this copy,\" \"rewrite this page,\" \"marketing copy,\" \"headline help,\" \"CTA copy,\" \"value proposition,\" \"tagline,\" \"subheadline,\" \"hero section copy,\" \"above the fold,\" \"this copy is weak,\" \"make this more compelling,\" or \"help me describe my product.\" Use this whenever someone is working on website text that needs to persuade or convert. For email copy, see email-sequence. For popup copy, see popup-cro. For editing existing copy, see copy-editing." ;
    oc:hasName "copywriting" ;
    oc:impartsKnowledge oc:kn_016dbee5,
        oc:kn_0efcdf1b,
        oc:kn_1b1fd8a2,
        oc:kn_49394b14,
        oc:kn_4a028f8a,
        oc:kn_67029802,
        oc:kn_951fa6fe,
        oc:kn_c8626f3e ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "create value propositions",
        "rewrite or improve existing copy",
        "write about page copy",
        "write feature page copy",
        "write headlines and CTAs",
        "write homepage copy",
        "write landing page copy",
        "write marketing copy for a page",
        "write pricing page copy" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_016dbee5 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When outputting final copy" ;
    oc:directiveContent "This skill produces annotated copy with alternatives for key elements (headlines, CTAs) and meta content for SEO. It does not modify files directly." ;
    oc:hasRationale "Annotations and alternatives help stakeholders evaluate and choose between options without needing multiple rounds of revision." ;
    oc:severityLevel "MEDIUM" .

oc:kn_0efcdf1b a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When the user requests email sequences, popup copy, or line-by-line editing" ;
    oc:directiveContent "This skill handles page copywriting, not email sequences or popup copy. Defer to email-sequence for email work and popup-cro for popup copy. Use copy-editing for polishing existing drafts." ;
    oc:hasRationale "Each of those tasks has specialized skills with domain-specific frameworks that produce better results than generalized copywriting." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1b1fd8a2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any marketing copy" ;
    oc:directiveContent "Always prioritize clarity over cleverness, benefits over features, specificity over vagueness, and customer language over company language." ;
    oc:hasRationale "These four principles form the foundation of conversion copywriting — clear, benefit-oriented, specific, customer-mirroring copy consistently outperforms clever or feature-heavy alternatives." ;
    oc:severityLevel "CRITICAL" .

oc:kn_49394b14 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any call-to-action button or link copy" ;
    oc:directiveContent "Use the CTA formula: [Action Verb] + [What They Get] + [Qualifier if needed]. Avoid weak CTAs like 'Submit,' 'Sign Up,' 'Learn More,' or 'Click Here'." ;
    oc:hasRationale "CTAs that communicate what the user gets ('Start Free Trial,' 'See the Dashboard in Action') dramatically outperform vague action-only CTAs." ;
    oc:severityLevel "HIGH" .

oc:kn_4a028f8a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing copy for a specific page type" ;
    oc:directiveContent "Each page type has distinct copy requirements: landing pages need single-message focus, pricing pages must reduce plan-selection anxiety, feature pages must connect feature→benefit→outcome, about pages must tell origin stories with CTAs." ;
    oc:hasRationale "Different page types serve different visitor intents and stages of awareness; applying the wrong framework reduces conversion effectiveness." ;
    oc:severityLevel "HIGH" .

oc:kn_67029802 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or reviewing copy" ;
    oc:directiveContent "Never fabricate statistics, testimonials, or case studies. Never use jargon like 'innovative,' 'streamlined,' 'cutting-edge,' or 'optimize' without concrete substance. Remove exclamation points." ;
    oc:hasRationale "Fabricated proof points erode trust and create legal liability. Hollow buzzwords signal low-value content and reduce credibility." ;
    oc:severityLevel "CRITICAL" .

oc:kn_951fa6fe a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before writing any copy" ;
    oc:directiveContent "Check for product-marketing-context.md (.agents/ or .claude/) before asking questions. Use that context and only ask for information not already covered." ;
    oc:hasRationale "Leveraging existing product marketing context avoids redundant questions and ensures copy aligns with established positioning." ;
    oc:severityLevel "HIGH" .

oc:kn_c8626f3e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any copywriting task" ;
    oc:directiveContent "Before writing, establish: page purpose and primary CTA, audience and their objections, product differentiators and proof points, and traffic source context." ;
    oc:hasRationale "Without these four context anchors, copy will be generic and fail to address the specific conversion scenario." ;
    oc:severityLevel "HIGH" .

