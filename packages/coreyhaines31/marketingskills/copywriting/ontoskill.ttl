oc:skill_coreyhaines31_marketingskills_copywriting a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "copywriting" ;
    skos:broader "Conversion copywriting framework" ;
    prov:wasDerivedFrom "../.agents/skills/coreyhaines31/marketingskills/copywriting" ;
    oc:contentHash "b15fdd74e1dae1ac536fb89bed08dcae7caf56f7844104b471a3d4c2b37003ae" ;
    oc:dependsOnSkill oc:skill_ontoskills_product_marketing_context ;
    oc:differentia "Generates clear, compelling marketing copy for web pages using structured principles, page-type-specific templates, and headline/CTA formulas that drive action" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAlias "conversion-copy",
        "marketing-copy",
        "page-copy",
        "write-copy" ;
    oc:hasAllowedTool "Read" ;
    oc:hasArgumentHint "page-type and product/service description" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to write, rewrite, or improve marketing copy for any page — including homepage, landing pages, pricing pages, feature pages, about pages, or product pages. Also use when the user says \"write copy for,\" \"improve this copy,\" \"rewrite this page,\" \"marketing copy,\" \"headline help,\" \"CTA copy,\" \"value proposition,\" \"tagline,\" \"subheadline,\" \"hero section copy,\" \"above the fold,\" \"this copy is weak,\" \"make this more compelling,\" or \"help me describe my product.\" Use this whenever someone is working on website text that needs to persuade or convert. For email copy, see email-sequence. For popup copy, see popup-cro. For editing existing copy, see copy-editing." ;
    oc:hasName "copywriting" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "You are an expert conversion copywriter. Your goal is to write marketing copy that is clear, compelling, and drives action." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Casual/conversational" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Professional but friendly" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Formal/enterprise" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Formality level:**" ],
                        [ a oc:Paragraph ;
