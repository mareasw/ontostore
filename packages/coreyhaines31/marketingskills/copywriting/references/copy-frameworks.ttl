        oc:Skill ;
    dcterms:identifier "copy-frameworks" ;
    skos:broader "Copywriting reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/copywriting" ;
    oc:contentHash "f387b6ed4b510efa9f0d3c459f4898971c8b0176e8c34185040cb264eca50186" ;
    oc:dependsOnSkill oc:skill_copywriting ;
    oc:differentia "provides headline formulas, landing page section typologies, structural page templates, and section writing guidelines for composing persuasive marketing pages" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_copywriting ;
    oc:handlesFailure oc:InsufficientContext ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_15dfb6ab,
        oc:kn_21118e40,
        oc:kn_4eb170b6,
        oc:kn_8c6eba6f,
        oc:kn_b06dae11,
        oc:kn_cf5e94bc ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:AudienceContextEstablished,
        oc:ProductContextEstablished ;
    oc:resolvesIntent "choose effective testimonials",
        "select appropriate page section types for different page goals",
        "structure landing pages with persuasive section order",
        "write compelling headlines using proven formulas",
        "write problem sections and benefit sections" ;
    oc:yieldsState oc:HeadlinesGenerated,
        oc:PageStructureDefined .

oc:kn_15dfb6ab a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a headline formula for any page" ;
    oc:directiveContent "Match headline formula category to the page's primary persuasive strategy: outcome-focused for benefit-driven pages, problem-focused for pain-aware audiences, audience-focused for niche targeting, differentiation-focused for competitive markets, proof-focused when social proof is strong." ;
    oc:hasRationale "Aligning the headline type to the audience's awareness level and the product's strongest angle dramatically improves resonance and conversion." .

oc:kn_21118e40 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which testimonials to feature on any page" ;
    oc:directiveContent "For testimonial selection, prioritize quotes with specific results ('increased conversions by 32%') and before/after context over vague praise ('Great product!'). Always include role + company for credibility." ;
    oc:hasRationale "Specific, credible testimonials create trust through concreteness. Vague praise reads as inauthentic and unpersuasive." .

oc:kn_4eb170b6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing benefits sections for any marketing page" ;
    oc:directiveContent "Limit the Solution/Benefits section to 3-5 key benefits, not 10. Each benefit should have a headline + explanation + proof point." ;
    oc:hasRationale "Cognitive overload reduces persuasion. Three well-supported benefits are more convincing than ten shallow ones." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8c6eba6f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing any marketing page layout" ;
    oc:directiveContent "Never structure a page as a flat feature list (Hero → Feature 1 → Feature 2 → Feature 3 → CTA). This is a list, not a persuasive narrative." ;
    oc:hasRationale "Feature-heavy pages fail to address objections, tell a story, or build emotional connection — they read like documentation, not persuasion." ;
    oc:severityLevel "HIGH" .

oc:kn_b06dae11 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing the How It Works section" ;
    oc:directiveContent "Each How It Works step must be numbered, use a simple action verb ('Connect,' 'Set up,' 'Get'), and describe the outcome the user gets from that step." ;
    oc:hasRationale "Numbering creates perceived simplicity and progress. Action verbs with outcomes reduce cognitive load and help users visualize the path to value." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cf5e94bc a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning page architecture before writing copy" ;
    oc:directiveContent "Use page structure templates as starting blueprints: Compact Landing Page for ad campaigns, Enterprise/B2B for complex sales, Product Launch for announcements, and Varied Engaging Page as the default strong pattern." ;
    oc:hasRationale "Starting with a proven structural template ensures all critical persuasion elements (social proof, problem articulation, objection handling, risk reversal) are included in the right narrative order." .

