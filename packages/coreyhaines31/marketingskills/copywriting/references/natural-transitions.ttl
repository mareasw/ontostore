oc:skill_coreyhaines31_marketingskills_copywriting_natural_transitions a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "natural-transitions" ;
    skos:broader "Reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/copywriting" ;
    oc:contentHash "4ff23f8943af2f65b072f26f1c53ce55f19cc26d7be211c11cae8e34b43e859f" ;
    oc:differentia "catalogues transitional phrases and signposting techniques for natural-sounding marketing copy" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_copywriting ;
    oc:hasCategory "document" ;
    oc:impartsKnowledge oc:kn_28effb6a,
        oc:kn_47993c2e,
        oc:kn_7f0a75f1,
        oc:kn_bddcd432,
        oc:kn_edb2eccb ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "add signposting to marketing content",
        "avoid AI-sounding transition phrases",
        "improve content flow with transitions",
        "write natural transitional copy" .

oc:kn_28effb6a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or editing draft copy for natural flow" ;
    oc:directiveContent "Read transitions aloud — if they sound forced, simplify. Front-load key information early in the transition phrase for scannability." ;
    oc:hasRationale "The read-aloud test is the most reliable way to catch unnatural phrasing, and front-loading helps skimmers who scan paragraph starts." ;
    oc:severityLevel "LOW" .

oc:kn_47993c2e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting transitional phrases for any content" ;
    oc:directiveContent "Match tone to audience (B2B can be slightly more formal, B2C benefits from conversational), vary transitions to avoid repetition, and don't over-signpost — trust the reader." ;
    oc:hasRationale "Over-signposting every sentence disrupts flow; variety and audience-appropriateness are what distinguish professional copy from robotic output." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7f0a75f1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making claims in marketing copy that are not definitively proven" ;
    oc:directiveContent "Use hedging language (may, might, tends to, evidence suggests) for claims that aren't absolute, to maintain credibility and avoid overstatement." ;
    oc:hasRationale "Overconfident claims damage trust; hedging signals intellectual honesty and protects against regulatory issues in advertising copy." ;
    oc:severityLevel "MEDIUM" .

oc:kn_bddcd432 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When indicating addition or concluding content" ;
    oc:directiveContent "Use 'moreover' and 'furthermore' sparingly, and avoid 'In conclusion' at the start of a paragraph — both are overused and sound AI-generated." ;
    oc:hasRationale "These specific markers are among the most commonly flagged phrases in AI content detection, making copy feel formulaic rather than natural." ;
    oc:severityLevel "MEDIUM" .

oc:kn_edb2eccb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any marketing copy or transitional content" ;
    oc:directiveContent "Avoid overused AI-sounding transitions such as 'That being said', 'It's worth noting that', 'At its core', 'In today's digital landscape', and 'Let's delve into'." ;
    oc:hasRationale "These phrases are well-known AI writing tells that erode reader trust and signal machine-generated content to both audiences and detection tools." ;
    oc:severityLevel "HIGH" .

