                            oc:sectionTitle "GA4 Configuration Tag" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Common Tag Configurations" ],
                [ a oc:Section ;
