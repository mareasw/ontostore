oc:kn_1c72dbae a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming any GTM container component" ;
    oc:directiveContent "Use the naming convention [Type] - [Description] - [Detail] for all tags, triggers, and variables (e.g., GA4 - Event - Signup Completed, DL - user_id)." ;
    oc:hasRationale "Consistent naming makes containers maintainable across team members and enables quick filtering." ;
    oc:severityLevel "MEDIUM" .

oc:kn_34e31022 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up data layer on any page" ;
    oc:directiveContent "Always initialize window.dataLayer before the GTM container snippet in the <head> section using window.dataLayer = window.dataLayer || []." ;
    oc:hasRationale "GTM reads the dataLayer at load time; if not initialized first, early pushes may be lost." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3803413f a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring tag sequencing in Advanced Settings" ;
    oc:directiveContent "Tag sequencing should fire config/initialization tags before event tags to ensure base setup completes before dependent events." ;
    oc:hasRationale "Without proper sequencing, event tags may fire before the configuration tag loads, losing data." ;
    oc:severityLevel "HIGH" .

oc:kn_4a60d7d3 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When implementing consent management" ;
    oc:directiveContent "Set consent defaults to denied for analytics_storage and ad_storage before any tags load, then update via gtag consent API on user action." ;
    oc:hasRationale "Default-denied ensures compliance with GDPR and similar regulations; tags respect consent state automatically once GTM Consent Overview is configured." ;
    oc:severityLevel "CRITICAL" .

oc:kn_bd5da496 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When debugging GTM tag firing issues" ;
    oc:directiveContent "When a tag is not firing, check trigger conditions first, then verify the dataLayer push timing and structure, then check tag sequencing." ;
    oc:hasRationale "These three causes account for the vast majority of GTM firing failures, in order of frequency." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f41aa050 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When pushing any e-commerce dataLayer event (view_item, add_to_cart, purchase)" ;
    oc:directiveContent "Never push e-commerce events without first clearing previous ecommerce data via dataLayer.push({ ecommerce: null })." ;
    oc:hasRationale "Stale ecommerce objects from previous events can corrupt the current event's data in GA4." ;
    oc:severityLevel "HIGH" .

oc:kn_fb201480 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When managing GTM versioning and team collaboration" ;
    oc:directiveContent "Use separate GTM workspaces for large changes, version every publish with descriptive notes listing added/modified tags, triggers, and variables, and test across browsers before publishing." ;
    oc:hasRationale "Workspaces prevent conflicting changes; detailed version notes enable rapid rollback and audit trails." ;
    oc:severityLevel "MEDIUM" .

