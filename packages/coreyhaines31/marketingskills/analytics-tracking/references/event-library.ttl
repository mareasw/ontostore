oc:skill_coreyhaines31_marketingskills_analytics_tracking_event_library a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "event-library" ;
    skos:broader "reference catalog" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/analytics-tracking" ;
    oc:contentHash "efc7bdb0a7b3efdea9e67ff0d1bc894dcf89ec9b9b8f3414f123d12bee109412" ;
    oc:differentia "categorizes analytics tracking events by business domain with properties and funnel sequences" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_analytics_tracking ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "business-type (e.g., saas, ecommerce, b2b, marketing-site)" ;
    oc:hasCategory "analytics-tracking" ;
    oc:impartsKnowledge oc:kn_1d31d4f8,
        oc:kn_574e8c19,
        oc:kn_659db702,
        oc:kn_8e0012a4,
        oc:kn_c0db2500 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "define event naming conventions and properties",
        "design funnel event sequences",
        "identify which events to implement for tracking",
        "plan analytics events to track",
        "select appropriate events by business type" ;
    oc:yieldsState oc:EventLibraryDefined .

oc:kn_1d31d4f8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When planning conversion tracking for signup, purchase, or e-commerce flows" ;
    oc:directiveContent "Design events as funnel sequences with clear progression steps (e.g., signup_started → signup_step_completed → signup_completed → onboarding_started) so that drop-off points can be precisely identified." ;
    oc:hasRationale "Granular step-level events enable funnel analysis that pinpoints exactly where users abandon, which is far more actionable than tracking only the final conversion event." ;
    oc:severityLevel "MEDIUM" .

oc:kn_574e8c19 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which event categories to implement for a given product" ;
    oc:directiveContent "Select events appropriate to the business model — use E-commerce events for transactional products, B2B/SaaS events for subscription products, and Monetization events for freemium conversions — do not mix vocabularies across incompatible business types." ;
    oc:hasRationale "Mixing event categories from incompatible business models creates noisy data, irrelevant events, and confusion in analytics dashboards." ;
    oc:severityLevel "MEDIUM" .

oc:kn_659db702 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming any analytics event" ;
    oc:directiveContent "Name events using a consistent snake_case verb_noun pattern (e.g., signup_completed, product_viewed, checkout_started) to maintain clarity and predictability across the entire tracking implementation." ;
    oc:hasRationale "Consistent naming enables reliable funnel analysis, reduces naming collisions, and makes events discoverable across teams and tools." ;
    oc:severityLevel "HIGH" .

oc:kn_8e0012a4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing conversion tracking of any kind" ;
    oc:directiveContent "Never track only the final conversion event (e.g., purchase_completed) without also tracking the preceding steps in the funnel; always instrument the full sequence from initial interest through completion." ;
    oc:hasRationale "Without step-level events, you cannot diagnose where users drop off, making optimization impossible. The diagnostic value of analytics comes from step granularity, not endpoint tracking alone." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c0db2500 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining properties for any tracked event" ;
    oc:directiveContent "Always attach user context (user_id, user_type, account_id, plan_type), session context (session_id, session_number, page, referrer), and campaign context (source, medium, campaign, content) as standard properties to every event." ;
    oc:hasRationale "Standard properties enable segmentation and attribution analysis across all events without requiring per-event custom property definitions." ;
    oc:severityLevel "HIGH" .

