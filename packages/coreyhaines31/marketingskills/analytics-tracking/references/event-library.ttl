oc:kn_33aaa90f a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When documenting a tracking event specification" ;
    oc:directiveContent """Event Name: {event_name} (snake_case)
Properties: {property_name}: {type} — {description}
Funnel Position: Step {n} of {funnel_name}""" ;
    oc:hasRationale "Standardized event documentation format ensures developers and marketers share a common understanding of what is tracked." ;
    oc:templateVariables "description",
        "event_name",
        "funnel_name",
        "n",
        "property_name",
        "type" .

oc:kn_726ade54 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing analytics tracking from this library" ;
    oc:directiveContent "1. Identify the business context (marketing site, product/app, monetization, e-commerce, B2B/SaaS). 2. Select relevant events from that category's table. 3. Attach standard properties (user, session, campaign, product, timing). 4. Map events into funnel sequences. 5. Validate that each funnel step has a corresponding tracking event." ;
    oc:hasRationale "Following a structured approach ensures complete coverage without missing critical touchpoints." ;
    oc:stepOrder 1 .

oc:kn_85cc8781 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any tracking event" ;
    oc:directiveContent "Every tracking event must include a consistent event name (snake_case) and a defined set of properties. Use the standard property groups — user context, session context, campaign context, product context, and timing — as baseline parameters on all events." ;
    oc:hasRationale "Consistent naming and properties enable reliable funnel analysis, segmentation, and cross-event correlation across the analytics stack." ;
    oc:severityLevel "HIGH" .

oc:kn_9064d191 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining new tracking events" ;
    oc:directiveContent "Do not create custom event names when a standard one from this library already exists for the same user action. Reuse existing event names and extend with additional properties if needed." ;
    oc:hasRationale "Duplicate events with different names for the same action fragment data and make funnel analysis unreliable." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cb453173 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing conversion funnels" ;
    oc:directiveContent "Use the funnel event sequences (signup: 5 steps, purchase: 5 steps, e-commerce: 7 steps) as templates — map them to your product and measure drop-off at each step to find optimization opportunities." ;
    oc:hasRationale "Pre-built funnel sequences provide proven starting points for measuring conversion and identifying where users drop off." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e0160d78 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When planning or auditing a complete analytics implementation" ;
    oc:directiveContent "Track the full user lifecycle with events covering: marketing site engagement → signup/onboarding → core product usage → monetization/subscription → retention/expansion. Each stage has its own event set." ;
    oc:hasRationale "Gaps in lifecycle tracking create blind spots in funnel analysis and prevent accurate attribution of revenue to user behaviors." ;
    oc:severityLevel "HIGH" .

