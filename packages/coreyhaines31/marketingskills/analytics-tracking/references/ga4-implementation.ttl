@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_analytics_tracking_ga4_implementation a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ga4-implementation" ;
    skos:broader "Implementation guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/analytics-tracking" ;
    oc:contentHash "f33fd6db0cbdb1bdc183af5f52bedd956d14680e54bca2e2c3917de29698636e" ;
    oc:differentia "provides detailed GA4 configuration, custom events, conversions, debugging, and data quality patterns for Google Analytics 4 tracking" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_analytics_tracking ;
    oc:handlesFailure oc:ConversionsNotRecording,
        oc:EventsNotFiring,
        oc:ParametersMissing ;
    oc:hasArgumentHint "GA4 property or measurement ID, implementation method (gtag.js or GTM)" ;
    oc:hasCategory "analytics" ;
    oc:impartsKnowledge oc:kn_102b4d3f,
        oc:kn_2a9b4fde,
        oc:kn_3227262f,
        oc:kn_59c472d5,
        oc:kn_b4afcd5d,
        oc:kn_be711b8b ;
    oc:isUserInvocable true ;
    oc:nature "Reference" ;
    oc:requiresState oc:GA4PropertyCreated,
        oc:MeasurementIDAvailable ;
    oc:resolvesIntent "configure GA4 data streams and enhanced measurement",
        "configure cross-domain tracking in GA4",
        "create GA4 custom dimensions metrics and audiences",
        "debug GA4 implementation issues",
        "implement GA4 tracking",
        "integrate GA4 with Google Ads",
        "set up GA4 custom events and conversions" ;
    oc:yieldsState oc:ConversionsTracked,
        oc:CustomEventsImplemented,
        oc:DataQualityConfigured,
        oc:GA4Configured .

oc:kn_102b4d3f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When starting a new GA4 implementation or adding tracking" ;
    oc:directiveContent "Before implementing custom GA4 events, first verify that enhanced measurement events are enabled and cover the needed tracking use case. Then check DebugView to confirm automatic events are firing before adding custom ones." ;
    oc:hasRationale "GA4's enhanced measurement automatically tracks page views, scrolls, outbound clicks, site search, video engagement, and file downloads. Duplicating these with custom events creates data conflicts and inflated counts." ;
    oc:severityLevel "HIGH" .

oc:kn_2a9b4fde a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting event names for GA4 tracking implementation" ;
    oc:directiveContent "Use Google's predefined recommended events (login, sign_up, purchase, etc.) whenever possible instead of fully custom event names, as they enable enhanced reporting and integrations out of the box." ;
    oc:hasRationale "Google's recommended events are pre-integrated with GA4's built-in reports, exploration templates, and Google Ads, reducing manual configuration and improving reporting quality." ;
    oc:severityLevel "HIGH" .

oc:kn_3227262f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When initially configuring a GA4 property and data stream" ;
    oc:directiveContent "Set data retention to 14 months (maximum) instead of the 2-month default to preserve historical data for year-over-year comparisons and audience building." ;
    oc:hasRationale "The default 2-month retention window destroys granular event data after 60 days, making long-term funnel analysis and audience definition impossible with historical data." ;
    oc:severityLevel "MEDIUM" .

oc:kn_59c472d5 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When implementing GA4 ecommerce tracking via Google Tag Manager dataLayer" ;
    oc:directiveContent "Always clear the ecommerce data layer object before pushing a new ecommerce event: dataLayer.push({ ecommerce: null }). This prevents stale product data from contaminating subsequent events." ;
    oc:hasRationale "Ecommerce data persists in the dataLayer, so without clearing it, previous item arrays can merge with new events, producing inflated or incorrect product data." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b4afcd5d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating GA4 custom dimensions or metrics and verifying they work" ;
    oc:directiveContent "Do not assume custom dimensions or metrics will appear immediately after creation. Custom parameter data requires 24-48 hours to process and only populates for events collected after the dimension is created." ;
    oc:hasRationale "GA4 processes custom definitions asynchronously and does not backfill historical data. Testing immediately after creation yields false negatives, leading to unnecessary reimplementation." ;
    oc:severityLevel "HIGH" .

oc:kn_be711b8b a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When troubleshooting GA4 conversion tracking" ;
    oc:directiveContent "Conversions may fail to record if the event is not explicitly marked as a conversion in GA4 Admin, or if the counting method is set to 'once per session' but the event fires multiple times." ;
    oc:hasRationale "GA4 requires manual conversion marking separate from event implementation. The counting method determines whether repeat events are captured, which commonly causes underreporting for high-frequency conversion actions." ;
    oc:severityLevel "MEDIUM" .

