oc:kn_38c5b2c9 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When configuring GA4 data quality filters" ;
    oc:directiveContent "Exclude internal IP addresses, developer traffic, and testing environments from GA4 data streams to prevent contamination of production analytics data." ;
    oc:hasRationale "Internal traffic inflates metrics and distorts conversion rates, leading to poor marketing decisions based on corrupted data" ;
    oc:severityLevel "MEDIUM" .

oc:kn_4bdb9203 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting event names for GA4 tracking" ;
    oc:directiveContent "Prefer Google's predefined/recommended events (login, sign_up, share, view_item, add_to_cart, purchase, etc.) over fully custom events when possible for enhanced reporting compatibility." ;
    oc:hasRationale "Using Google's recommended events enables built-in reporting features and ensures compatibility with GA4's standard reports and Google Ads integration" .

oc:kn_72807e28 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring GA4 property data streams" ;
    oc:directiveContent "Use one data stream per platform (web, iOS, Android). Configure data retention (2 months default, 14 months max). Enable Google Signals only if user consent is available." ;
    oc:hasRationale "Proper stream configuration ensures accurate cross-platform tracking and compliance with data retention policies" ;
    oc:severityLevel "HIGH" .

oc:kn_94c5ef4c a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating custom definitions" ;
    oc:directiveContent "GA4 custom dimension and metric changes are not retroactive — they only apply to data collected after creation. Plan dimensions before launching tracking." ;
    oc:hasRationale "Historical data cannot be reprocessed with new dimensions, meaning missed tracking windows result in permanent data gaps" ;
    oc:severityLevel "HIGH" .

oc:kn_a489823c a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When debugging GA4 tracking issues" ;
    oc:directiveContent "When events are not appearing: check DebugView first, verify gtag/GTM is firing, check filter exclusions. When parameter values are missing: verify custom dimension is created, check parameter name match, wait 24-48 hrs for processing. When conversions aren't recording: verify event is marked as conversion, check event name match, verify counting method." ;
    oc:hasRationale "Systematic debugging follows the most common failure causes in order of likelihood, reducing resolution time" .

oc:kn_c009e75c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating custom dimensions and metrics in GA4" ;
    oc:directiveContent "Choose the correct scope for custom dimensions: Event scope for per-event properties (content_type), User scope for per-user attributes (account_type), Item scope for per-product properties (product_category). Parameter names must exactly match event parameters." ;
    oc:hasRationale "Incorrect scope or parameter name mismatch results in missing or aggregated data that doesn't answer the intended questions" .

oc:kn_cd8739ee a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing GTM e-commerce tracking with dataLayer" ;
    oc:directiveContent "Never send e-commerce dataLayer pushes without first clearing the ecommerce object: dataLayer.push({ ecommerce: null }). This prevents stale data from previous pushes contaminating new events." ;
    oc:hasRationale "GTM persists dataLayer state between pushes; without clearing, previous e-commerce items bleed into subsequent events causing inflated or incorrect data" ;
    oc:severityLevel "CRITICAL" .

