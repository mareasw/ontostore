oc:kn_124b5419 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing e-commerce purchase tracking via GTM" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """dataLayer.push({ ecommerce: null });
dataLayer.push({
  'event': 'purchase',
  'ecommerce': {
    'transaction_id': 'T12345',
    'value': 99.99,
    'currency': 'USD',
    'items': [{
      'item_id': 'SKU123',
      'item_name': 'Product Name',
      'price': 99.99,
      'quantity': 1
    }]
  }
});""" .

oc:kn_1aea67f0 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """# {Site/Product} Tracking Plan

## Overview
- Tools: {tools}
- Last updated: {date}

## Events

| Event Name | Description | Properties | Trigger |
|------------|-------------|------------|--------|
| {event} | {description} | {properties} | {trigger} |

## Custom Dimensions

| Name | Scope | Parameter |
|------|-------|----------|
| {dimension} | {scope} | {parameter} |

## Conversions

| Conversion | Event | Counting |
|------------|-------|----------|
| {conversion} | {event} | {counting} |""" ;
    oc:templateVariables "Site/Product",
        "conversion",
        "counting",
        "date",
        "description",
        "dimension",
        "event",
        "parameter",
        "properties",
        "scope",
        "tools",
        "trigger" .

oc:kn_438415c7 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When setting up GA4 from scratch" ;
    oc:directiveContent "GA4 Quick Setup: 1. Create GA4 property and data stream. 2. Install gtag.js or GTM. 3. Enable enhanced measurement. 4. Configure custom events. 5. Mark conversions in Admin." ;
    oc:stepOrder 2 .

oc:kn_4526c777 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When firing custom events via GA4 gtag.js" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """gtag('event', 'signup_completed', {
  'method': 'email',
  'plan': 'free'
});""" .

oc:kn_4abff6ef a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring any analytics tool, especially with EU/UK/CA users" ;
    oc:directiveContent "Never include PII (personally identifiable information) in analytics properties or event parameters. Use consent mode and conditional tag loading for GDPR/CCPA compliance." ;
    oc:hasRationale "PII leaks violate GDPR, CCPA, and other privacy regulations, exposing the company to legal liability." ;
    oc:severityLevel "CRITICAL" .

oc:kn_992db9b2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming any event, property, or custom dimension" ;
    oc:directiveContent "Use object_action naming convention with lowercase and underscores (e.g., signup_completed, cta_hero_clicked). Include context in properties, not the event name." ;
    oc:hasRationale "Consistent naming prevents data fragmentation, enables team-wide understanding, and supports reliable filtering across analytics tools." ;
    oc:severityLevel "HIGH" .

oc:kn_a2a43436 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "After implementing any tracking, before going live" ;
    oc:directiveContent "Validation Checklist: 1. Events firing on correct triggers. 2. Property values populating correctly. 3. No duplicate events. 4. Works across browsers and mobile. 5. Conversions recorded correctly. 6. No PII leaking." ;
    oc:stepOrder 3 .

oc:kn_a8929124 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When pushing events via GTM dataLayer" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """dataLayer.push({
  'event': 'form_submitted',
  'form_name': 'contact',
  'form_location': 'footer'
});""" .

oc:kn_b66defdf a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any tracking plan" ;
    oc:directiveContent "Never track events that don't inform a decision. Avoid vanity metrics and prefer quality over quantity of events." ;
    oc:hasRationale "Tracking everything creates noise, increases maintenance burden, and obscures actionable signals." ;
    oc:severityLevel "HIGH" .

oc:kn_be48535d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any analytics implementation begins" ;
    oc:directiveContent "Before implementing tracking, answer: What decisions will this data inform? What key conversions matter? What tools are already in use? What privacy/compliance requirements exist?" ;
    oc:hasRationale "Starting with business questions ensures tracking serves decisions rather than collecting unused data." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c18b8c49 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Full analytics tracking implementation workflow" ;
    oc:directiveContent "1. Check for product-marketing-context.md and read existing context. 2. Assess business questions, current tracking state, and tech stack. 3. Define event naming conventions. 4. Build tracking plan with events, properties, triggers, and conversions. 5. Implement via GA4 gtag.js or GTM dataLayer. 6. Validate with DebugView/GTM Preview. 7. Document the tracking plan." ;
    oc:stepOrder 1 .

oc:kn_c8d65560 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When debugging analytics issues or discrepancies between GA4 and backend data" ;
    oc:directiveContent "When events aren't firing: 1) Check GA4 DebugView, 2) Verify GTM Preview mode shows tag firing, 3) Inspect trigger conditions and variable paths, 4) Check for duplicate containers or double-triggering." ;
    oc:hasRationale "Systematic debugging prevents guesswork and quickly identifies the root cause among common failure points." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ddbe973e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing e-commerce tracking via GTM dataLayer" ;
    oc:directiveContent "Clear the ecommerce dataLayer object before each push using `dataLayer.push({ ecommerce: null })`. This prevents stale e-commerce data from bleeding into subsequent events." ;
    oc:hasRationale "E-commerce data persists in the dataLayer; failing to clear causes previous transaction data to contaminate new events." ;
    oc:severityLevel "HIGH" .

oc:kn_de20b3db a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "At the start of every analytics tracking task" ;
    oc:directiveContent "Check for product-marketing-context.md (.agents/ or .claude/) before asking questions. Use existing context and only ask for information not already covered." ;
    oc:hasRationale "Leveraging existing product context avoids redundant questions and produces tracking plans aligned with business goals." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e88b38e8 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before implementing any tracking" ;
    oc:directiveContent "Requires an analytics platform (GA4, Mixpanel, Segment, Amplitude, or PostHog) and optionally GTM for tag management." .

