oc:skill_coreyhaines31_marketingskills_analytics_tracking a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "analytics-tracking" ;
    skos:broader "analytics implementation methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/analytics-tracking" ;
    oc:contentHash "26b61a36c6702438e00e5dde1f6903563db50ed707765d8dc1ae6cacd6f630c3" ;
    oc:differentia "provides a structured framework for planning, implementing, debugging, and validating event tracking across web analytics platforms (GA4, GTM, Mixpanel, Segment) with standardized naming conventions, tracking plans, UTM strategies, and privacy compliance" ;
    oc:extends oc:skill_product_marketing_context ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "tracking question or analytics task description (e.g., 'set up GA4 tracking for SaaS signup funnel')" ;
    oc:hasCategory "automation" ;
    oc:hasDescription "When the user wants to set up, improve, or audit analytics tracking and measurement. Also use when the user mentions \"set up tracking,\" \"GA4,\" \"Google Analytics,\" \"conversion tracking,\" \"event tracking,\" \"UTM parameters,\" \"tag manager,\" \"GTM,\" \"analytics implementation,\" \"tracking plan,\" \"how do I measure this,\" \"track conversions,\" \"attribution,\" \"Mixpanel,\" \"Segment,\" \"are my events firing,\" or \"analytics isn't working.\" Use this whenever someone asks how to know if something is working or wants to measure marketing results. For A/B test measurement, see ab-test-setup." ;
    oc:hasName "analytics-tracking" ;
    oc:impartsKnowledge oc:kn_13a742b1,
        oc:kn_1976f93f,
        oc:kn_35489c2d,
        oc:kn_5d1d44d7,
        oc:kn_63a894e7,
        oc:kn_81938236,
        oc:kn_acf4aa48 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "audit existing tracking implementation",
        "configure GA4 events and conversions",
        "create a tracking plan",
        "debug broken analytics or event firing issues",
        "define UTM parameter strategy",
        "ensure GDPR/privacy compliance for analytics",
        "implement Google Tag Manager tags and triggers",
        "set up analytics tracking",
        "validate event tracking correctness" ;
    oc:yieldsState oc:AnalyticsConfigured,
        oc:ConversionsMeasured,
        oc:TrackingPlanCreated .

oc:kn_13a742b1 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When debugging discrepancies between GA4 reported conversions and database records" ;
    oc:directiveContent "GA4 conversion counts commonly disagree with backend database counts due to consent mode filtering, ad blockers, client-side vs server-side tracking differences, and session timeout configurations." ;
    oc:hasRationale "Understanding these systemic causes prevents wasted debugging time and sets correct expectations for data accuracy." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1976f93f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When naming any custom event or defining event taxonomy" ;
    oc:directiveContent "Use the object_action naming convention (lowercase with underscores) for all events — e.g., signup_completed, cta_hero_clicked, checkout_payment_completed — and include context in properties, not in the event name." ;
    oc:hasRationale "Consistent naming prevents confusion, enables filtering, and ensures team members can understand and maintain the tracking plan without ambiguity." ;
    oc:severityLevel "HIGH" .

oc:kn_35489c2d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining event properties and user properties for any analytics platform" ;
    oc:directiveContent "Never include PII (personally identifiable information) in analytics event properties — no email addresses, phone numbers, or full names in event parameters or user properties." ;
    oc:hasRationale "PII in analytics violates GDPR, CCPA, and other privacy regulations; it creates legal liability and can result in significant fines and loss of user trust." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5d1d44d7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning any tracking implementation or evaluating which events to track" ;
    oc:directiveContent "Track for decisions, not data — every event should map to a specific business decision or action someone will take based on the data." ;
    oc:hasRationale "Vanity metrics and excessive events create noise that obscures actionable insights; starting with the question 'what decision will this inform?' ensures every tracked event has purpose." ;
    oc:severityLevel "HIGH" .

oc:kn_63a894e7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any new analytics tracking implementation" ;
    oc:directiveContent "Before implementing tracking, verify three things: (1) what decisions the data will inform, (2) what tracking already exists and which tools are in use, (3) what privacy/compliance requirements apply." ;
    oc:hasRationale "Skipping initial assessment leads to duplicate tracking, inconsistent implementations, and compliance violations that are expensive to fix retroactively." ;
    oc:severityLevel "HIGH" .

oc:kn_81938236 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing GTM dataLayer pushes for e-commerce tracking" ;
    oc:directiveContent "Always clear the ecommerce dataLayer object before pushing new ecommerce events (dataLayer.push({ ecommerce: null })) to prevent stale product data from contaminating subsequent events." ;
    oc:hasRationale "E-commerce dataLayer data persists across events; without clearing, previous items bleed into subsequent events, corrupting purchase and product data." ;
    oc:severityLevel "MEDIUM" .

oc:kn_acf4aa48 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When creating a tracking plan from scratch or expanding existing tracking" ;
    oc:directiveContent "Start tracking design by working backwards from the business question — define what you need to know, what actions you'll take based on answers, then determine which events and properties to track." ;
    oc:hasRationale "Working backwards prevents over-tracking and ensures complete coverage of the decision-critical data points, rather than tracking everything 'just in case'." ;
    oc:severityLevel "MEDIUM" .

