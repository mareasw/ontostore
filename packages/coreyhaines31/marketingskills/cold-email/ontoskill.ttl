oc:skill_coreyhaines31_marketingskills_cold_email a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "cold-email" ;
    skos:broader "Email writing skill" ;
    prov:wasDerivedFrom "../.agents/skills/coreyhaines31/marketingskills/cold-email" ;
    oc:contentHash "9e0358e98fe4bb86b2b64e958f81920974f9cd32309fbc9e0eaa592b7d1e5523" ;
    oc:dependsOnSkill oc:skill_ontoskills_product_marketing_context ;
    oc:differentia "that crafts B2B cold outreach emails and follow-up sequences optimized for reply rates using data-backed frameworks, personalization, and voice calibration" ;
    oc:extends oc:skill_ontoskills_copywriting ;
    oc:handlesFailure oc:InvalidInput,
        oc:MissingContext ;
    oc:hasArgumentHint "target persona (role, company) and value proposition or outcome sought" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Write B2B cold emails and follow-up sequences that get replies. Use when the user wants to write cold outreach emails, prospecting emails, cold email campaigns, sales development emails, or SDR emails. Also use when the user mentions \"cold outreach,\" \"prospecting email,\" \"outbound email,\" \"email to leads,\" \"reach out to prospects,\" \"sales email,\" \"follow-up email sequence,\" \"nobody's replying to my emails,\" or \"how do I write a cold email.\" Covers subject lines, opening lines, body copy, CTAs, personalization, and multi-touch follow-up sequences. For warm/lifecycle email sequences, see email-sequence. For sales collateral beyond emails, see sales-enablement." ;
    oc:hasName "cold-email" ;
    oc:hasRequirement oc:req_6093c66e ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: cold-email
description: Write B2B cold emails and follow-up sequences that get replies. Use when the user wants to write cold outreach emails, prospecting emails, cold email campaigns, sales development emails, or SDR emails. Also use when the user mentions "cold outreach," "prospecting email," "outbound email," "email to leads," "reach out to prospects," "sales email," "follow-up email sequence," "nobody's replying to my emails," or "how do I write a cold email." Covers subject lines, opening lines, body copy, CTAs, personalization, and multi-touch follow-up sequences. For warm/lifecycle email sequences, see email-sequence. For sales collateral beyond emails, see sales-enablement.
metadata:
  version: 1.1.0
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "You are an expert cold email writer. Your goal is to write emails that sound like they came from a sharp, thoughtful human — not a sales machine following a template." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
