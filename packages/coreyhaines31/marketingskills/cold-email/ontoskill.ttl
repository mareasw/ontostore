_:ref_a15474f46524eb4f a oc:WorkflowStep ;
    dcterms:description "**What do you want?** — The outcome (meeting, reply, intro, demo)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_a161cf75db06c2d3 a oc:WorkflowStep ;
    dcterms:description "**Who are you writing to?** — Role, company, why them specifically" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_c1fc9bdc6819cb00 a oc:WorkflowStep ;
    dcterms:description "**What's the value?** — The specific problem you solve for people like them" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_30fffe254914e9cd a oc:WorkflowStep ;
    dcterms:description "Write each follow-up as a standalone email adding one new value proposition, progressively shorter" ;
    oc:expectedOutcome "Each email works even if previous ones weren't read" ;
    oc:stepDependsOn _:ref_98e99be0f54fb8ce ;
    oc:stepId "write-follow-ups" .

_:ref_33f7fa1449c794c4 a oc:WorkflowStep ;
    dcterms:description "Review the initial email's angle and value prop to ensure follow-ups don't repeat" ;
    oc:expectedOutcome "Clear understanding of what ground the first email covered" ;
    oc:stepId "review-initial" .

_:ref_34b15f9af8bdd46b a oc:WorkflowStep ;
    dcterms:description "Gather who (role, company), what outcome, what value prop, what proof, any research signals" ;
    oc:expectedOutcome "Sufficient inputs to write — use what's available, don't block on missing info" ;
    oc:stepDependsOn _:ref_ad8c0ef45ba2662f ;
    oc:stepId "gather-inputs" .

_:ref_3867b3a66a428eca a oc:WorkflowStep ;
    dcterms:description "Plan 3–4 distinct angles: new value piece, social proof, industry insight, breakup" ;
    oc:expectedOutcome "Each follow-up has a unique value-add mapped out" ;
    oc:stepDependsOn _:ref_33f7fa1449c794c4 ;
    oc:stepId "plan-angles" .

_:ref_57318ab867088fc6 a oc:WorkflowStep ;
    dcterms:description "Write 25–75 word body with peer voice, you/your-dominant, one proof point, interest-based CTA" ;
    oc:expectedOutcome "Concise email that reads like a colleague, not a vendor" ;
    oc:stepDependsOn _:ref_0b4fd4c4ba5f6f1a ;
    oc:stepId "write-body" .

_:ref_8e9eae56e92cd8ba a oc:WorkflowStep ;
    dcterms:description "Write 2–4 word lowercase subject line that looks internal, not like marketing" ;
    oc:expectedOutcome "Subject line that bypasses promotional filters and triggers curiosity" ;
    oc:stepDependsOn _:ref_0b4fd4c4ba5f6f1a ;
    oc:stepId "write-subject" .

_:ref_98c050eb09bac8e9 a oc:WorkflowStep ;
    dcterms:description "Run 5-point gut check: sounds human? Would you reply? Every sentence serves reader? Personalization connected to problem? One clear ask?" ;
    oc:expectedOutcome "Email passes quality gate — rewrite any failing elements" ;
    oc:stepDependsOn _:ref_57318ab867088fc6,
        _:ref_8e9eae56e92cd8ba ;
    oc:stepId "quality-check" .

_:ref_98e99be0f54fb8ce a oc:WorkflowStep ;
    dcterms:description "Set timing: Day 3, Day 7–8, Day 14, Day 21–28 with increasing gaps" ;
    oc:expectedOutcome "Cadence that catches different timing windows without wearing out welcome" ;
    oc:stepDependsOn _:ref_3867b3a66a428eca ;
    oc:stepId "set-cadence" .

