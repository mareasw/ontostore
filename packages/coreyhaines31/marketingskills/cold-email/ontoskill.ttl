@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_cold_email a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "cold-email" ;
    skos:broader "Email copywriting skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/cold-email" ;
    oc:contentHash "9e0358e98fe4bb86b2b64e958f81920974f9cd32309fbc9e0eaa592b7d1e5523" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "specializes in unsolicited B2B cold outreach emails with data-driven frameworks, personalization systems, and multi-touch follow-up sequences optimized for reply rates" ;
    oc:extends oc:skill_copywriting ;
    oc:handlesFailure oc:InsufficientContext,
        oc:WrongEmailType ;
    oc:hasArgumentHint "recipient persona, value proposition, proof points, desired outcome" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "Write B2B cold emails and follow-up sequences that get replies. Use when the user wants to write cold outreach emails, prospecting emails, cold email campaigns, sales development emails, or SDR emails. Also use when the user mentions \"cold outreach,\" \"prospecting email,\" \"outbound email,\" \"email to leads,\" \"reach out to prospects,\" \"sales email,\" \"follow-up email sequence,\" \"nobody's replying to my emails,\" or \"how do I write a cold email.\" Covers subject lines, opening lines, body copy, CTAs, personalization, and multi-touch follow-up sequences. For warm/lifecycle email sequences, see email-sequence. For sales collateral beyond emails, see sales-enablement." ;
    oc:hasName "cold-email" ;
    oc:impartsKnowledge oc:kn_0f5a11e1,
        oc:kn_5af203c7,
        oc:kn_5af53eff,
        oc:kn_5f2f43df,
        oc:kn_76dbaafb,
        oc:kn_816cc01d,
        oc:kn_97a8e652 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:ProductMarketingContextAvailable ;
    oc:resolvesIntent "create follow-up email sequences",
        "generate cold email campaigns",
        "improve cold email reply rates",
        "optimize subject lines for cold outreach",
        "personalize cold emails at scale",
        "review and diagnose cold email problems",
        "write breakup emails",
        "write cold emails" ;
    oc:yieldsState oc:ColdEmailDrafted,
        oc:FollowUpSequenceCreated .

oc:kn_0f5a11e1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When personalizing any cold email" ;
    oc:directiveContent "Personalization must connect to the problem you solve. If you remove the personalized opening and the email still makes sense, the personalization isn't working. Use the 4-level system: basic merge tags < industry/segment < role-level < individual observation tied to the problem." ;
    oc:hasRationale "Personalization disconnected from the problem is just an attention hack. Connected personalization drives 50-250% more replies (Lavender data). The 'So What?' test ensures relevance." ;
    oc:severityLevel "HIGH" .

oc:kn_5af203c7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing cold email body copy and subject lines" ;
    oc:directiveContent "Keep cold emails under 75 words. Emails under 75 words get 83% more replies. Subject lines must be 2-4 words, lowercase, internal-looking (e.g., 'reply rates,' 'hiring ops')." ;
    oc:hasRationale "Brevity is the single strongest performance lever after personalization depth. Mobile truncation at 30-35 characters makes short subject lines a practical necessity." ;
    oc:severityLevel "HIGH" .

oc:kn_5af53eff a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any cold email" ;
    oc:directiveContent "Never open with 'I hope this email finds you well,' 'My name is X and I work at Y,' or any AI-tell phrases like 'leverage,' 'synergy,' 'best-in-class.' These instantly signal automated sales spam and destroy trust." ;
    oc:hasRationale "These phrases are the most common markers of mass-produced sales emails. Decision-makers filter them immediately, dropping reply rates significantly." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5f2f43df a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before writing any cold email" ;
    oc:directiveContent "Before writing, check for .agents/product-marketing-context.md (or .claude/product-marketing-context.md). If it exists, read it first and only ask for information not already covered. Then confirm: who (recipient role/company), what (desired outcome), value (specific problem solved), proof (case study/result), and research signals." ;
    oc:hasRationale "Product marketing context provides positioning, proof points, and audience intelligence that prevents generic emails. Missing inputs don't block writing — use what's available and note gaps." ;
    oc:severityLevel "HIGH" .

oc:kn_76dbaafb a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building multi-touch cold email sequences" ;
    oc:directiveContent "Use 3-5 total emails in a sequence with increasing gaps (Day 0, 3, 7-8, 14, 21-28). Each follow-up must add genuinely new value — a different angle, fresh proof, or useful resource. Never send 'just checking in' follow-ups. End with a breakup email that honors silence." ;
    oc:hasRationale "55% of replies come from follow-ups, yet 48% of salespeople never follow up. By the 4th follow-up, response rates drop 55% and spam complaints triple, so cap at 5 total emails with escalating cadence." ;
    oc:severityLevel "HIGH" .

oc:kn_816cc01d a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When setting expectations for cold email campaign performance" ;
    oc:directiveContent "Cold email reply rates have declined ~15% YoY from 7-8% (2020-2022) to 4-5.8% (2024-2025) due to inbox saturation, stricter anti-spam (Google's 0.1% complaint threshold), and AI email flood. The gap between average and excellent is widening — craft matters more, not less." ;
    oc:hasRationale "Understanding the declining baseline prevents unrealistic expectations and reinforces the need for quality over volume in cold outreach." ;
    oc:severityLevel "MEDIUM" .

oc:kn_97a8e652 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When establishing voice and tone for any cold email" ;
    oc:directiveContent "Write like a peer, not a vendor. Lead with the reader's world ('you/your' over 'I/we'). Use one low-friction interest-based CTA ('Worth exploring?') rather than meeting requests. Calibrate tone by seniority: C-suite gets ultra-brief peer-level writing; technical buyers get precision with no fluff." ;
    oc:hasRationale "Readers decide in seconds whether an email is from a peer or a sales machine. Vendor-sounding language triggers defensive filtering. Interest-based CTAs reduce friction to a one-line reply." ;
    oc:severityLevel "HIGH" .

