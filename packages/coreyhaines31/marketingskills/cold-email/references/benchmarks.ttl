        oc:Skill ;
    dcterms:identifier "benchmarks" ;
    skos:broader "Performance data and expert methodology compendium" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/cold-email" ;
    oc:contentHash "3dc1d38a2d1f4fbb2706be7ca3d40156b66a3d7078c183a930ff373c3bb04c09" ;
    oc:differentia "Aggregates cold email benchmarks, funnel metrics, performance levers, common mistakes, cultural calibration, and expert frameworks to ground cold outreach strategy in empirical evidence" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_cold_email ;
    oc:hasArgumentHint "metric or topic to look up (e.g., \"reply rate benchmarks\", \"mistakes\", \"cultural calibration\")" ;
    oc:hasCategory "marketing" ;
