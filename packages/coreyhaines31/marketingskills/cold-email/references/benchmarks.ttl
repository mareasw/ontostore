    oc:isUserInvocable true ;
    oc:nature "Reference" ;
    oc:resolvesIntent "calibrate cold email tone by region",
        "identify top cold email mistakes to avoid",
        "look up cold email performance benchmarks",
        "reference expert cold email methodologies",
        "set realistic cold email campaign targets",
        "understand cold email response rate trends" ;
    oc:yieldsState oc:BenchmarksLoaded .

oc:kn_06b8dbe6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When personalizing cold email outreach" ;
    oc:directiveContent "Never use generic templates with only {{FirstName}} merge tags, self-focused openings ('We are a leading...'), or false personalization ('Loved your post!') — recipients detect these instantly and it destroys trust." ;
    oc:hasRationale "Generic and false personalization rank as #4 and #6 top mistakes; 71% of decision-makers ignore irrelevant emails." ;
    oc:severityLevel "HIGH" .

oc:kn_07a81311 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When targeting recipients in different geographic regions" ;
    oc:directiveContent "Calibrate tone and length by region: US favors short/direct/casual, UK prefers longer/insight-led/professional, Germany/DACH expects precise/data-driven, Scandinavia values fact-based/egalitarian communication." ;
    oc:hasRationale "Response rates vary significantly by region (North America 4.1%, Europe 3.1%, Asia-Pacific 2.8%) and cultural misalignment reduces engagement." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1b3c0f27 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When setting long-term cold email strategy and expectations" ;
    oc:directiveContent "Cold email effectiveness is declining ~15% YoY; the gap between average (4–5.8% reply) and excellent (15–25%+ reply) is widening, meaning writing craft matters more over time, not less." ;
    oc:hasRationale "Inbox saturation (10+ cold emails/week per recipient, 20% say none relevant), stricter spam filters, and AI-generated email volume are driving average performance down while rewarding quality." ;
    oc:severityLevel "HIGH" .

oc:kn_78de1f17 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building contact lists and segmenting campaigns" ;
    oc:directiveContent "Keep campaigns to ≤50 contacts per campaign and 1–2 contacts per company; exceeding this drops reply rates from 7.8% to 3.8% per company and significantly reduces per-contact reply rates." ;
    oc:hasRationale "Targeting precision is the #4 performance lever; smaller, more targeted lists dramatically outperform large batch sends." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7f421b82 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When planning cold email campaign targets and forecasting results" ;
    oc:directiveContent "Set realistic funnel expectations: 500 emails typically yield ~100 opens (20%), ~25 replies (5%), ~8 positive replies, ~4 meetings, and ~1 client — roughly 0.2% end-to-end conversion for average performers." ;
    oc:hasRationale "Reply rates have declined ~15% YoY from 7–8% (2020–2022) to 4–5.8% (2024–2025) due to inbox saturation, stricter anti-spam (Google's 0.1% complaint threshold), and AI email flooding." ;
    oc:severityLevel "HIGH" .

oc:kn_b9dab773 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When designing follow-up sequences after initial outreach" ;
    oc:directiveContent "First follow-up adds 49% more replies; avoid 'just checking in' language ('I never heard back' = 12% drop in bookings) and instead provide new value or a different angle." ;
    oc:hasRationale "Follow-up strategy is the #5 performance lever, but the #10 mistake is sending empty check-in follow-ups that actively harm booking rates." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c5eeb22e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting or reviewing any cold email copy" ;
    oc:directiveContent "Cold emails must stay under 75 words and read at a 3rd–5th grade level; brevity yields 83% more replies and simpler language yields 67% more replies." ;
    oc:hasRationale "70% of cold emails are written above 10th-grade level and are too long, which are the #1 and most impactful mistakes reducing reply rates." ;
    oc:severityLevel "CRITICAL" .

