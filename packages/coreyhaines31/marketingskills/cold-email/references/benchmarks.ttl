oc:skill_coreyhaines31_marketingskills_cold_email_benchmarks a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "benchmarks" ;
    skos:broader "Reference dataset" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/cold-email" ;
    oc:contentHash "3dc1d38a2d1f4fbb2706be7ca3d40156b66a3d7078c183a930ff373c3bb04c09" ;
    oc:differentia "aggregates 2024–2025 cold email performance benchmarks, funnel models, performance levers, common mistakes, and expert methods to calibrate outreach strategy" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_cold_email ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "marketing" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 7 ;
                            oc:tableCaption "## Expert Quick Reference" ;
                            oc:tableMarkdown """| Expert         | Core Method                                                     | Best For                                        |
| -------------- | --------------------------------------------------------------- | ----------------------------------------------- |
| Alex Berman    | 3C's: Compliment → Case Study → CTA                             | High-ticket B2B services, agencies              |
| Josh Braun     | "Poke the Bear" — neutral questions exposing invisible problems | Empathy-driven consultative selling             |
| Kyle Coleman   | Systematic research + AI personalization at scale               | Bridging mass outreach and deep personalization |
| Becc Holland   | Psychographic personalization, Premise Buckets                  | Combining personalization with relevance        |
| Will Allred    | Data-driven coaching, Mouse Trap, Vanilla Ice Cream             | Any context; universal frameworks               |
| Justin Michael | 1–3 sentence hyper-brevity, quote their own words               | High-velocity SDR teams at scale                |
| Sam Nelson     | Agoge Sequence — Triple on Day 1 (email + LinkedIn + call)      | Multi-channel, tiered personalization           |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 9 ;
                    oc:sectionTitle "Expert Quick Reference" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Heads of Sales:** 6.60% (most targeted role, highest saturation)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Entry-level:** Highest engagement at 8% reply, 50% open" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**CTOs/VP Tech:** 7.68% reply" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**CEOs/Founders:** 7.63% reply" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**C-level:** 23% more likely to respond than non-C-suite when they engage (6.4% vs 5.2%)" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Response Rates by Seniority" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Highest responding:** Nonprofits (16.5%+), legal (10%), EdTech (7.8%), chemical (7.3%), manufacturing (6.1%).
**Lowest responding:** SaaS (3.5%), financial services (3.4%), IT services (3.5%).""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Industry Variation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "500 emails → 100 opens (20%) → 25 replies (5%) → 8 positive replies (30%) → 4 meetings (50%) → 1 client (25% close). ~**0.2% end-to-end conversion** for average performers." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Realistic Funnel Model" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 6 ;
                            oc:tableCaption "## Core Performance Metrics (2024–2025)" ;
                            oc:tableMarkdown """| Metric                     | Average | Good   | Excellent | Source                   |
| -------------------------- | ------- | ------ | --------- | ------------------------ |
| Open rate                  | 27.7%   | 40–45% | 50%+      | Belkins, Snov.io         |
| Reply rate                 | 4–5.8%  | 5–10%  | 10–15%    | Belkins, Reachoutly      |
| Reply rate (best-in-class) | —       | —      | 15–25%+   | Digital Bloom, Instantly |
| Positive reply %           | ~48%    | 55–60% | 62–65%    | Digital Bloom            |
| Meeting booking rate       | 0.5–1%  | 1–2%   | 2.3%+     | Reachoutly               |
| Bounce rate                | 7.5%    | <4%    | <2%       | Belkins                  |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Performance Metrics (2024–2025)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Reply rates dropped from 7–8% (2020–2022) to 4–5.8% (2024–2025), ~15% YoY decline. Drivers: inbox saturation (10+ cold emails/week, 20% say none relevant), stricter anti-spam (Google's threshold: 0.1% complaints), AI email flood (more volume, less quality signal). Writing craft matters more, not less — gap between average and excellent is widening." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Declining Effectiveness Trend" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 3 ;
                            oc:tableCaption "## Cultural Calibration" ;
                            oc:tableMarkdown """| Factor       | US              | UK                       | Germany/DACH         | Scandinavia             |
| ------------ | --------------- | ------------------------ | -------------------- | ----------------------- |
| Tone         | Direct, casual  | Polite, professional     | Precise, data-driven | Fact-based, egalitarian |
| Length       | Shorter, blunt  | Longer, insight-led      | Detail-oriented      | Concise but substantive |
| Social proof | Outcome numbers | Research-led credibility | Technical precision  | Shared values           |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "North America: 4.1% response. Europe: 3.1%. Asia-Pacific: 2.8%. Shorter, more direct sequences work better in US. UK needs more insight/personality. GDPR affects European tone." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Cultural Calibration" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_7ff9c8236ecb72f0 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Performance Levers (ranked by impact)" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_176bd7cef3880d54 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Top 15 Mistakes (ranked by impact)" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Benchmarks, Data & Expert Methods" ] ;
    oc:hasWorkflow _:ref_176bd7cef3880d54,
