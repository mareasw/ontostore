@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_cold_email_subject_lines a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "subject-lines" ;
    skos:broader "Subject line optimization strategy" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/cold-email" ;
    oc:contentHash "f71f31b1151d972bb19ff03791ffb9d24941a8ccea8b913e5a5c7aca439b45ce" ;
    oc:differentia "uses data-driven patterns for cold email subject lines that maximize open and reply rates through brevity, internal camouflage, and contextual personalization" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_cold_email ;
    oc:handlesFailure oc:LowOpenRate,
        oc:SubjectLineRejected ;
    oc:hasArgumentHint "email context or target audience" ;
    oc:hasCategory "marketing" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "The subject line determines whether the email gets read. The data is counterintuitive: **short, boring, internal-looking subject lines win decisively.**" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Data conflicts: Belkins says questions perform well (46% open rate). Lavender says questions lower opens by **56%**. Resolution: **specific pain questions work** (\"Need help with {{challenge}}?\"), **generic questions fail** (\"Quick question?\" / \"Have 15 minutes?\"). Default to statements." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Questions: only when highly specific" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Use {{painPoint}}, {{competitor}}, {{commonGround}} — not {{firstName}}." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**First name in subject line → 12% fewer replies.** Signals automation." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Contextual personalization works:** pain points, competitors, trigger events, industry challenges." ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Personalized subject lines boost opens **26–50%**, but type matters:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Personalization: context over name" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "All-lowercase has highest open rates (Gong, 85M+ emails). Lowercase looks more personal/internal. For cold outreach specifically, lowercase beats title case." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Capitalization: lowercase wins" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "What works: ultra-concise, human, understated. \"{{companyInitiative}}\" · \"thank you\" · \"an update\" · \"a question\" · reference to a specific project or trigger event." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Anything \"salesy\" is immediately rejected." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Executives receive 300–400 emails daily, decide in seconds. They respond **23% more often** than non-C-suite when emails pass their filter (6.4% reply rate)." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "C-Suite Subject Lines" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Mobile truncates at 30–35 characters — brevity is practical necessity." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Going from 2 to 4 words reduces replies by **17.5%**." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "2-word subject lines get **60% more opens** than 5-word (Lavender)." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "2–4 words yield **46% open rates** vs 34% for 10 words (Belkins, 5.5M emails)." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Length: 2–4 words" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 8 ;
                            oc:tableCaption "## What to Avoid" ;
                            oc:tableMarkdown """| Anti-pattern                                   | Impact                      |
| ---------------------------------------------- | --------------------------- |
| Salesy language ("increase," "boost," "ROI")   | -17.9% opens                |
| Urgency words ("ASAP," "urgent")               | Below 36% opens             |
| Excessive punctuation ("!!!" or "??")          | -36% opens                  |
| Numbers and percentages                        | -46% opens                  |
| Emojis                                         | Hurt B2B professionalism    |
| Pitching product in subject                    | -57% replies                |
| Empty/no subject line                          | +30% opens but -12% replies |
| Spam triggers ("free," "guarantee," "act now") | Deliverability risk         |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "What to Avoid" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Subject lines that look like they came from a colleague, not a vendor, double open rates (Gong). Buyers mentally categorize before opening — if it looks like sales, it's filtered." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**High-performing examples:** \"reply rates\" · \"trial delays\" · \"hiring ops\" · \"employee turnover\" · \"Q2 forecast\" · \"new patients\" · \"personalization issue\" · \"second page\"" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Internal Camouflage Principle" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Subject Line Optimization" ] ;
    oc:impartsKnowledge oc:kn_146e9ff7,
        oc:kn_3710d19f,
        oc:kn_4e82ba45,
        oc:kn_583b779c,
        oc:kn_843a7a59,
        oc:kn_a6a225f5,
        oc:kn_b44d4666,
        oc:kn_b6120632,
        oc:kn_df20f37e ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ColdEmailDrafted ;
    oc:resolvesIntent "craft B2B subject lines that avoid spam filters",
        "create C-suite targeted subject lines",
        "optimize email open rates",
        "write subject lines for cold emails" ;
    oc:yieldsState oc:SubjectLineOptimized .

oc:kn_146e9ff7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding between question vs statement subject lines" ;
    oc:directiveContent "Default to statement subject lines. Only use questions when highly specific to a pain point ('Need help with {{challenge}}?'). Generic questions ('Quick question?', 'Have 15 minutes?') lower opens by 56%." ;
    oc:hasRationale "Data conflicts between studies (Belkins vs Lavender), but the resolution is that specificity determines success — specific pain questions work, generic ones fail badly" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3710d19f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing cold email subject lines" ;
    oc:directiveContent "Use all-lowercase subject lines. Lowercase has highest open rates and looks more personal/internal." ;
    oc:hasRationale "Gong analysis of 85M+ emails shows lowercase beats title case for cold outreach because it signals personal/internal communication" ;
    oc:severityLevel "HIGH" .

oc:kn_4e82ba45 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When considering sending without a subject line" ;
    oc:directiveContent "Empty/no subject lines increase opens by 30% but decrease replies by 12% — net negative for cold outreach goals." ;
    oc:hasRationale "Curiosity drives opens but lack of context reduces the quality of engagement and reply intent" ;
    oc:severityLevel "LOW" .

oc:kn_583b779c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting subject lines for cold B2B outreach" ;
    oc:directiveContent "Subject lines should look like internal colleague emails, not vendor outreach. Examples: 'reply rates', 'trial delays', 'hiring ops', 'Q2 forecast'." ;
    oc:hasRationale "Buyers mentally categorize emails before opening — if it looks like sales, it gets filtered. Internal-looking lines double open rates (Gong)." ;
    oc:severityLevel "CRITICAL" .

oc:kn_843a7a59 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any cold email subject line" ;
    oc:directiveContent "Subject lines must be 2–4 words. 2-word subject lines get 60% more opens than 5-word. Mobile truncates at 30–35 characters." ;
    oc:hasRationale "Brevity is both statistically superior and practically necessary for mobile rendering" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a6a225f5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When personalizing cold email subject lines" ;
    oc:directiveContent "Never use first name personalization ({{firstName}}) in subject lines — it reduces replies by 12% and signals automation. Use contextual variables instead: {{painPoint}}, {{competitor}}, {{commonGround}}." ;
    oc:hasRationale "Name-based personalization feels automated; contextual personalization referencing real business challenges boosts opens 26–50%" ;
    oc:severityLevel "HIGH" .

oc:kn_b44d4666 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing cold email subject lines" ;
    oc:directiveContent "Avoid: salesy language (increase, boost, ROI: -17.9% opens), urgency words (ASAP, urgent: below 36% opens), excessive punctuation (-36% opens), numbers/percentages (-46% opens), emojis, pitching product in subject (-57% replies), and spam triggers (free, guarantee, act now)." ;
    oc:hasRationale "These patterns trigger sales-detection mental filters and spam filters, destroying both deliverability and open rates" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b6120632 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating subject line options" ;
    oc:directiveContent "{{2-4 word internal-looking phrase}} · optionally with {{painPoint}} or {{competitor}} or {{companyInitiative}} context variable" ;
    oc:hasRationale "This template combines the top-performing patterns: brevity, internal camouflage, and contextual personalization" ;
    oc:templateVariables "companyInitiative",
        "competitor",
        "painPoint" .

oc:kn_df20f37e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When targeting executives who receive 300–400 emails daily" ;
    oc:directiveContent "For C-suite targets: use ultra-concise, human, understated subject lines like '{{companyInitiative}}', 'thank you', 'an update', 'a question', or references to specific projects/trigger events. C-suite responds 23% more when emails pass their filter." ;
    oc:hasRationale "Executives decide on emails in seconds and immediately reject anything that looks salesy; understated human subject lines pass their mental filter" ;
    oc:severityLevel "HIGH" .

