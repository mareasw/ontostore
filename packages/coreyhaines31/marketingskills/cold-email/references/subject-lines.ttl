    oc:yieldsState oc:SubjectLinesGenerated .

oc:kn_21697bfd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing cold email subject lines" ;
    oc:directiveContent "Never use salesy language ('increase', 'boost', 'ROI'), urgency words ('ASAP', 'urgent'), excessive punctuation, numbers/percentages, emojis, or spam triggers ('free', 'guarantee', 'act now') in subject lines." ;
    oc:hasRationale "Salesy language causes -17.9% opens, urgency words below 36% opens, excessive punctuation -36% opens, numbers/percentages -46% opens, and pitching product in subject line causes -57% replies." ;
    oc:severityLevel "CRITICAL" .

oc:kn_2c1e7653 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When deciding between question vs statement subject line format" ;
    oc:directiveContent "Default to statement-format subject lines. Only use question format when the question is highly specific to a pain point (e.g., 'Need help with {{challenge}}?'). Generic questions like 'Quick question?' lower opens by 56%." ;
    oc:hasRationale "Data is conflicting: Belkins shows questions at 46% open rate, Lavender shows questions lower opens by 56%. The resolution is specificity — specific pain questions work, generic questions fail decisively." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b689a0cf a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When personalizing subject lines for cold outreach" ;
    oc:directiveContent "Use contextual personalization (pain points, competitors, trigger events, industry challenges) — never first name personalization in subject lines. First name in the subject line signals automation and reduces replies by 12%." ;
    oc:hasRationale "Personalized subject lines boost opens 26–50%, but the type matters: contextual personalization ({{painPoint}}, {{competitor}}, {{commonGround}}) signals relevance, while {{firstName}} signals mass automation." ;
    oc:severityLevel "HIGH" .

oc:kn_ccfe5e72 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting subject lines for any cold outreach" ;
    oc:directiveContent "Use the Internal Camouflage Principle: subject lines should look like they came from a colleague, not a vendor. Use lowercase, reference internal topics (e.g., 'reply rates', 'Q2 forecast', 'hiring ops')." ;
    oc:hasRationale "Subject lines that look internal/colleague-sourced double open rates (Gong). Buyers mentally categorize before opening — if it looks like sales, it's filtered immediately." ;
    oc:severityLevel "HIGH" .

oc:kn_cff35a0c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any cold email subject line" ;
    oc:directiveContent "Subject lines must be 2–4 words. 2-word subject lines get 60% more opens than 5-word. Mobile truncates at 30–35 characters, making brevity a practical necessity." ;
    oc:hasRationale "Data from Lavender and Belkins (5.5M emails) shows 2–4 words yield 46% open rates vs 34% for 10-word subject lines; every additional word beyond 2 reduces replies by 17.5%." ;
    oc:severityLevel "CRITICAL" .

