oc:skill_coreyhaines31_marketingskills_cold_email_personalization a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "personalization" ;
    skos:broader "Cold email personalization framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/cold-email" ;
    oc:contentHash "08f18652938e14143402786fbdb8e1a6269650bb5eef9106898f1cdf31e47e36" ;
    oc:differentia "structures prospect research and message customization into four escalation levels with a 3-minute production system and trigger-based templates that tie observations to the seller's value proposition" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_cold_email ;
    oc:handlesFailure oc:InsufficientProspectData,
        oc:PersonalizationDisconnected ;
    oc:hasArgumentHint "prospect details (name, company, role) or target segment description" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_013f64b8,
        oc:kn_11bfc288,
        oc:kn_28625877,
        oc:kn_ade80225,
        oc:kn_c7743705,
        oc:kn_f449bbdd ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProspectIdentified ;
    oc:resolvesIntent "avoid fake or creepy personalization in emails",
        "create trigger-event personalization templates",
        "personalize cold emails at scale",
        "research prospects for cold outreach",
        "write observation-based email openers" ;
    oc:yieldsState oc:EmailPersonalized .

oc:kn_013f64b8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or editing any personalized email opener" ;
    oc:directiveContent "Apply the 'So What?' test after writing any opening line — read it from the prospect's perspective and ask 'So what? Why would I care?' If the answer is nothing, rewrite it." ;
    oc:hasRationale "This quick self-check catches the most common personalization failure: observations that are technically accurate but emotionally irrelevant to the recipient." ;
    oc:severityLevel "HIGH" .

oc:kn_11bfc288 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning personalization depth for a cold email sequence" ;
    oc:directiveContent "Escalate through four personalization levels: Level 1 (merge tags, ~5% lift) → Level 2 (industry/segment pain) → Level 3 (role-level challenges) → Level 4 (individual observation tied to problem). Aim for Level 3–4 whenever possible." ;
    oc:hasRationale "Higher personalization levels produce significantly better response rates. Level 1 is table stakes and no longer differentiating. Levels 3–4 are where meaningful reply lifts occur." ;
    oc:severityLevel "MEDIUM" .

oc:kn_28625877 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting cold email personalization" ;
    oc:directiveContent "Never use generic AI-sounding openers like 'I hope this email finds you well,' mention LinkedIn profile views as a reason for outreach, or over-personalize to the point of creepiness." ;
    oc:hasRationale "These patterns signal mass automation and immediately trigger spam/ignore reflexes in recipients. They undermine the entire purpose of personalization." ;
    oc:severityLevel "HIGH" .

oc:kn_ade80225 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any personalized cold email opener or observation" ;
    oc:directiveContent "Personalization must logically connect to the problem you solve — if it doesn't, it's just an attention hack, not relevant personalization." ;
    oc:hasRationale "Disconnected personalization (e.g., mentioning alma mater then pitching unrelated software) signals mass automation and erodes trust. Connected personalization drives 50–250% more replies." ;
    oc:severityLevel "CRITICAL" .

oc:kn_c7743705 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before drafting personalized cold emails" ;
    oc:directiveContent "Before personalizing, gather signals from the research stack: recent funding, job postings, tech stack, LinkedIn activity, company news, podcast/talks, and website changes. Stack-rank top 10 buying signals (5 company, 5 person)." ;
    oc:hasRationale "The quality of personalization is bounded by the quality of research signals. A structured signal stack ensures consistent, research-backed personalization rather than generic assumptions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f449bbdd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing a personalization system for outbound campaigns" ;
    oc:directiveContent "Use the 3x3 template structure: (1) personalization attached to a problem, (2) the problem you solve, (3) one-sentence solution + low-friction CTA. Build 5 trigger templates for reusable personalization paragraphs." ;
    oc:hasRationale "This structure keeps the email constant while swapping only the personalization trigger, enabling a top SDR to write a genuinely personalized email in under 3 minutes." ;
    oc:severityLevel "HIGH" .

