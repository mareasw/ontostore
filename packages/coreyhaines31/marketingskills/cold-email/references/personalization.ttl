@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_cold_email_personalization a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "personalization" ;
    skos:broader "Personalization framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/cold-email" ;
    oc:contentHash "08f18652938e14143402786fbdb8e1a6269650bb5eef9106898f1cdf31e47e36" ;
    oc:differentia "that categorizes cold email personalization into four levels and provides a systematic research-to-template workflow for crafting relevant, problem-connected outreach at scale" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_cold_email ;
    oc:hasCategory "marketing" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Personalization drives **50–250% more replies** (Lavender). The key insight: **if your personalization has nothing to do with the problem you solve, it's just an attention hack** (Clay)." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Industry insight:** \"Most [role titles] I talk to spend [X hours/week] on [problem] — curious if that matches your experience at [Company].\"" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Trigger-event:** \"Congrats on the recent funding round — scaling the team from here is exciting, and I imagine [challenge] is top of mind.\"" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Observation:** \"Your recent post about [topic] resonated — especially the part about [detail]. Got me thinking about how that applies to [challenge].\"" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Observation-Based Openers (highest performing)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "\"I saw your LinkedIn profile and wanted to reach out\" — signals mass automation" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "AI-generated emails with similar phrasing (\"I hope this email finds you well\")" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Over-personalizing to creepiness" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Generic attention hacks disconnected from problem (\"Cool that you went to UCLA!\" → pitch)" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "What Feels Fake (avoid)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Demographic** — Age, profession, background" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Psychographic** — Values, passions, beliefs (highest-impact dimension)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Firmographic** — Company size, funding, industry, growth stage" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Technographic** — Tech stack, tools used" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Tapping into what prospects are passionate about drives significantly higher response rates." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "The Four -Graphic Principles (Becc Holland)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "From \"30 Minutes to President's Club\":" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**Step 3:** Create 5 \"trigger templates\" — pre-written personalization paragraphs for each trigger, with a smooth segue into the problem." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Step 1:** Build a research stack of top 10 buying signals — 5 company triggers, 5 person triggers. Stack-rank by relevance." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Step 2:** Build a 3x3 template: (1) personalization attached to a problem, (2) problem you solve, (3) one-sentence solution + low-friction CTA." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "The personalization must logically connect to the problem. This creates 5 reusable triggers with the rest of the email constant. A top SDR writes a personalized email in **under 3 minutes**." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "The 3-Minute Personalization System" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "After writing any opening line, read from prospect's perspective: \"So what? Why would I care?\" If the answer is nothing, rewrite." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "The \"So What?\" Test" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BlockQuote ;
                                    oc:blockType "blockquote" ;
                                    oc:contentOrder 2 ;
                                    oc:quoteContent "Noticed you're hiring 3 SDRs — sounds like you're scaling outbound fast. Most teams hit follow-up fatigue during onboarding." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Specific, timely observations about that person connected to the problem you solve." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Level 4 — Individual (gold standard)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BlockQuote ;
                                    oc:blockType "blockquote" ;
                                    oc:contentOrder 2 ;
                                    oc:quoteContent "Most {{industry}} teams struggle with {{lead gen problem}}, which often leads to wasted effort." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Industry-specific pain points, trends, regulatory challenges. Scalable via micro-segmentation." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Level 2 — Industry/segment" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Challenges specific to their role and seniority." ],
                                [ a oc:BlockQuote ;
                                    oc:blockType "blockquote" ;
                                    oc:contentOrder 2 ;
                                    oc:quoteContent "As Head of Sales, keeping pipeline steady is probably your biggest headache. Your RevOps team is small, so you're likely wearing multiple hats during scaling." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Level 3 — Role-level" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "First name, company name, job title. Table stakes, no longer differentiating. ~5% lift." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Level 1 — Basic (merge tags)" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Four Levels of Personalization" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 7 ;
                            oc:tableCaption "## Research Signal Stack" ;
                            oc:tableMarkdown """| Signal            | Where to find it                   | How to use it                                                                |
| ----------------- | ---------------------------------- | ---------------------------------------------------------------------------- |
| Recent funding    | Crunchbase, LinkedIn, press        | "Congrats on Series B — scaling teams fast usually creates X challenge"      |
| Job postings      | LinkedIn Jobs, careers page        | "Noticed you're hiring 3 SDRs — sounds like you're scaling outbound"         |
| Tech stack        | BuiltWith, Wappalyzer, HG Insights | "I see you're using HubSpot — most teams at your stage hit a ceiling with X" |
| LinkedIn activity | Posts, comments, job changes       | "Really enjoyed your post about X"                                           |
| Company news      | Google News, press releases        | "Congrats on acquiring X — integrating teams usually creates Y challenge"    |
| Podcast/talks     | Google, YouTube, podcasts          | "Caught your talk at SaaStr on X — really insightful"                        |
| Website changes   | Manual review                      | "Your new pricing page caught my eye — curious how it's converting"          |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Research Signal Stack" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Personalization at Scale" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "A systematic approach to writing personalized cold emails in under 3 minutes using pre-built trigger templates" ;
            oc:hasStep _:ref_0e04bc0687a3c431,
                _:ref_3ad5d9a5fa936fb3,
                [ a oc:WorkflowStep ;
                    dcterms:description "Create 5 trigger templates — pre-written personalization paragraphs for each research trigger, with a smooth segue into the problem statement." ;
                    oc:expectedOutcome "5 reusable personalization paragraphs that connect common buying signals to your value proposition" ;
                    oc:stepDependsOn _:ref_0e04bc0687a3c431,
                        _:ref_3ad5d9a5fa936fb3 ;
                    oc:stepId "create-trigger-templates" ] ;
            oc:workflowId "three-minute-personalization" ;
            oc:workflowName "3-Minute Personalization System" ] ;
    oc:impartsKnowledge oc:kn_06bc4b95,
        oc:kn_0fb4a254,
        oc:kn_2afc6226,
        oc:kn_7d3db252,
        oc:kn_f8df0d70 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "avoid generic personalization in outreach",
        "personalize cold emails",
        "research prospects for outreach",
        "scale personalization in cold email campaigns",
        "write personalized email openers" .

oc:kn_06bc4b95 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or editing personalized email openers" ;
    oc:directiveContent "Apply the 'So What?' Test: after writing any opening line, read it from the prospect's perspective. If the answer to 'So what? Why would I care?' is nothing, rewrite." ;
    oc:hasRationale "This filter catches self-indulgent personalization that doesn't create value for the prospect" ;
    oc:severityLevel "HIGH" .

oc:kn_0fb4a254 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing cold email personalization" ;
    oc:directiveContent "Avoid: AI-generated phrasing like 'I hope this email finds you well,' generic attention hacks disconnected from your pitch, over-personalizing to creepiness, and 'I saw your LinkedIn profile' openers that signal mass automation." ;
    oc:hasRationale "These patterns are widely recognized as spam signals and reduce reply rates" ;
    oc:severityLevel "HIGH" .

oc:kn_2afc6226 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When deciding how deeply to personalize outreach" ;
    oc:directiveContent "Personalization has four levels of increasing impact: Level 1 (merge tags: name, company, title — ~5% lift, table stakes), Level 2 (industry/segment pain points), Level 3 (role-level challenges tied to seniority), Level 4 (individual, timely observations connected to the problem you solve — gold standard)." ;
    oc:hasRationale "Higher personalization levels drive significantly more replies (50–250% per Lavender), but require more research investment per prospect" .

oc:kn_7d3db252 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any personalized cold email line" ;
    oc:directiveContent "Personalization must logically connect to the problem you solve. If it has nothing to do with the problem, it's just an attention hack." ;
    oc:hasRationale "Disconnected personalization (e.g., mentioning alma mater then pitching unrelated product) signals mass automation and erodes trust" ;
    oc:severityLevel "CRITICAL" .

oc:kn_f8df0d70 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building prospect research frameworks" ;
    oc:directiveContent "The four -graphic dimensions for prospect research are: Demographic (age, profession, background), Technographic (tech stack, tools), Firmographic (company size, funding, industry, growth stage), and Psychographic (values, passions, beliefs — highest-impact dimension)." ;
    oc:hasRationale "Psychographic alignment taps into what prospects are passionate about, driving the highest response rates (Becc Holland)" ;
    oc:severityLevel "MEDIUM" .

_:ref_0e04bc0687a3c431 a oc:WorkflowStep ;
    dcterms:description "Build a research stack of top 10 buying signals: 5 company triggers and 5 person triggers. Stack-rank by relevance." ;
    oc:expectedOutcome "Prioritized list of 10 research signals to look for in prospects" ;
    oc:stepId "build-signal-stack" .

_:ref_3ad5d9a5fa936fb3 a oc:WorkflowStep ;
    dcterms:description "Build a 3x3 email template: (1) personalization attached to a problem, (2) problem you solve, (3) one-sentence solution + low-friction CTA." ;
    oc:expectedOutcome "A reusable email skeleton with slots for personalized openers" ;
    oc:stepId "build-3x3-template" .

