oc:skill_coreyhaines31_marketingskills_cold_email_follow_up_sequences a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "follow-up-sequences" ;
    skos:broader "email sequence framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/cold-email" ;
    oc:contentHash "87e14749104b0c5bcd865e55d33513a161edb8e6773b2a2d9802b5460f2f7369" ;
    oc:differentia "optimizes multi-touch cold outreach cadence, angle rotation, and breakup emails using data-backed reply-rate patterns" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_cold_email ;
    oc:handlesFailure oc:ProspectUnresponsive,
        oc:SpamComplaintRisk ;
    oc:hasArgumentHint "context about the prospect, product, and campaign goal" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_01c1bc5b,
        oc:kn_0f7b6550,
        oc:kn_4d9f98df,
        oc:kn_5842262c,
        oc:kn_7693fd88,
        oc:kn_992c9c4b ;
    oc:isUserInvocable true ;
    oc:nature "strategy" ;
    oc:requiresState oc:ColdEmailDrafted,
        oc:ProspectIdentified ;
    oc:resolvesIntent "increase cold email reply rates",
        "optimize cold email cadence timing",
        "plan follow-up email sequences",
        "rotate angles across follow-up emails",
        "write breakup emails" ;
    oc:yieldsState oc:CadenceScheduled,
        oc:FollowUpSequencePlanned .

oc:kn_01c1bc5b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting the call-to-action for each follow-up email" ;
    oc:directiveContent "Adjust CTA friction inversely with seniority: executives get ultra-low-effort CTAs ('Curious?', 'Worth 2 min?'), mid-level managers get specific value CTAs ('Want me to walk through how [Company] saved 15 hours/week?')." ;
    oc:hasRationale "Higher in the org chart = less friction you can ask for. Matching CTA effort to seniority increases reply probability." ;
    oc:severityLevel "MEDIUM" .

oc:kn_0f7b6550 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any follow-up email copy" ;
    oc:directiveContent "Never use phrases like 'just checking in', 'bumping this to the top of your inbox', 'did you see my last email?', 'I never heard back', or 'following up on my previous message'." ;
    oc:hasRationale "'I never heard back' causes a 12% drop in meeting booking rate (Gong). These phrases signal laziness, add zero value, are presumptuous, or guilt-trip the prospect." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4d9f98df a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any cold email follow-up sequence" ;
    oc:directiveContent "Cap sequences at 5 total emails (1 initial + 4 follow-ups). Each follow-up must add genuinely new value — never send a naked bump." ;
    oc:hasRationale "By the 4th follow-up, response rates drop 55% and spam complaints triple. Longer sequences catch different timing windows but diminishing returns set in quickly." ;
    oc:severityLevel "HIGH" .

oc:kn_5842262c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sending the final email in a breakup sequence" ;
    oc:directiveContent "If you send a breakup email, you must honor it — do not contact the prospect again. The breakup email must acknowledge multiple outreaches, validate their potential lack of interest, state this is the final email, and leave the door open." ;
    oc:hasRationale "Breakup emails achieve 10–15% response rates with cold prospects by leveraging loss aversion. Violating the breakup promise destroys trust and credibility permanently." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7693fd88 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scheduling follow-up sequence sends" ;
    oc:directiveContent "Increase the gap between each touch: Day 0 (initial), Day 3 (FU1), Day 7–8 (FU2), Day 14 (FU3), Day 21–28 (FU4). Send Tuesday–Thursday between 9–11 AM or 1–3 PM in the prospect's local time." ;
    oc:hasRationale "Waiting 3 days between first and second email increases response by up to 31%. Thursday peaks at 6.87% reply rate. Monday mornings and Friday afternoons underperform." ;
    oc:severityLevel "HIGH" .

oc:kn_992c9c4b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing the content for each follow-up in a sequence" ;
    oc:directiveContent "Rotate angles across the sequence: Initial = personalized hook + value prop, FU1 = new value piece, FU2 = social proof/case study, FU3 = new insight/trend, FU4 = breakup email. Add only one new value proposition per email." ;
    oc:hasRationale "55% of replies come from follow-ups, not the initial email. Each touch must stand alone while building toward the goal. Single value-adds per email prevent overwhelm and naturally force different angles." ;
    oc:severityLevel "HIGH" .

