@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_cold_email_follow_up_sequences a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "follow-up-sequences" ;
    skos:broader "Follow-up sequence strategy" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/cold-email" ;
    oc:contentHash "87e14749104b0c5bcd865e55d33513a161edb8e6773b2a2d9802b5460f2f7369" ;
    oc:differentia "optimizes cold email reply rates through cadenced multi-touch outreach with angle rotation and psychological triggers" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_cold_email ;
    oc:handlesFailure oc:ProspectUnresponsive,
        oc:SpamComplaintRisk ;
    oc:hasArgumentHint "prospect-context, campaign-goal" ;
    oc:hasCategory "marketing" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "55% of replies come from follow-ups, not the initial email. Yet 48% of salespeople never follow up even once." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 5 ;
                            oc:tableCaption "Increase the gap between each touch" ;
                            oc:tableMarkdown """| Touch         | Day   | Notes                                          |
| ------------- | ----- | ---------------------------------------------- |
| Initial email | 0     | Maximum personalization investment             |
| Follow-up 1   | 3     | Waiting 3 days increases response by up to 31% |
| Follow-up 2   | 7–8   | Different angle                                |
| Follow-up 3   | 14    | New value piece                                |
| Follow-up 4   | 21–28 | Breakup email                                  |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**Best days:** Tuesday–Thursday (Thursday peaks at 6.87% reply rate).
**Best times:** 9–11 AM or 1–3 PM in prospect's local time.
**Avoid:** Monday mornings (inbox overload), Friday afternoons (checked out).""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Increase the gap between each touch:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Optimal Cadence" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 5 ;
                            oc:tableCaption "Each follow-up must stand alone while building toward the goal. Never just \"bump this up.\"" ;
                            oc:tableMarkdown """| Email       | Angle                                                      | Purpose                    |
| ----------- | ---------------------------------------------------------- | -------------------------- |
| Initial     | Personalized hook + core value prop + soft CTA             | Introduce problem/solution |
| Follow-up 1 | Different angle, new value piece (stat, insight, resource) | Show additional benefit    |
| Follow-up 2 | Social proof / case study from similar company             | Build credibility          |
| Follow-up 3 | New insight, industry trend, or relevant resource          | Demonstrate expertise      |
| Follow-up 4 | Breakup — acknowledge silence, leave door open             | Trigger loss aversion      |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Add only **one new value proposition per email** (SalesBread). This naturally forces different angles." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Each follow-up must stand alone while building toward the goal. Never just \"bump this up.\"" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Angle Rotation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Resolution: longer sequences catch different timing windows. Cap at 4 follow-ups (5 total emails). Each must add genuinely new value." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Highest single-email reply rate: **8.4%** (Belkins)." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "By 4th follow-up, response rates drop **55%** and spam complaints **triple**." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "4–7 email campaigns achieve **27% reply rates** vs 9% for 1–3 emails (Woodpecker, 20M emails)." ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "How Many: 3–5 Total Emails" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 5 ;
                            oc:quoteContent "I haven't heard back, so I'll assume now isn't the right time. Before I close the loop: [1-sentence insight or resource]. If that changes things, feel free to reply. Otherwise, no hard feelings — good luck with [their goal]." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Leverages loss aversion — removing pressure while creating scarcity through withdrawal. Close.com reports **10–15% response rates** from breakup emails with cold prospects." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 8 ;
                            oc:textContent "**Critical rule:** If you send a breakup email, honor it. Do not contact the prospect again." ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 7 ;
                            oc:quoteContent """Since I haven't heard back, I'll keep it simple. Reply with a number:

1 — Interested, let's talk
2 — Not now, check back in 3 months
3 — Not interested, please stop""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**Example:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "**1-2-3 Format** (reduces friction to near zero):" ],
                        _:ref_ba497e679fb5f63f,
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Structure:**" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "The Breakup Email" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "\"Bumping this to the top of your inbox\" → Presumptuous" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "\"Following up on my previous message\" → Generic, adds nothing" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\"I never heard back\" → **12% drop** in meeting booking rate (Gong)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "\"Did you see my last email?\" → Guilt-tripping" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\"Just checking in\" → Zero value, signals laziness" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Phrases That Kill Response Rates" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Mid-level managers:** More specific value. \"Want me to walk through how [Company] saved 15 hours/week?\"" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Higher in the org chart = less friction you can ask for." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Executives/founders:** Ultra-low-effort, curiosity-driven. \"Curious?\" or \"Worth 2 min?\"" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "CTA Adjustment by Seniority" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Follow-Up Sequences" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Execute a 5-email follow-up sequence with progressive cadence and angle rotation" ;
            oc:hasStep _:ref_1b7d13b25528b85c,
                [ a oc:WorkflowStep ;
                    dcterms:description "Day 21–28: Send breakup email acknowledging silence, validating lack of interest, leaving door open" ;
                    oc:expectedOutcome "Trigger loss aversion; 10–15% of cold prospects respond. Honor the breakup — do not contact again." ;
                    oc:stepDependsOn _:ref_d9083af10da6a3ea ;
                    oc:stepId "follow-up-4-breakup" ],
                _:ref_bbb4b0d859c72f3d,
                _:ref_cfef73f6bbccdc34,
                _:ref_d9083af10da6a3ea ;
            oc:workflowId "follow-up-sequence" ;
            oc:workflowName "Cold Email Follow-Up Sequence" ],
        _:ref_ba497e679fb5f63f ;
    oc:impartsKnowledge oc:kn_2ae76f91,
        oc:kn_2cae94cb,
        oc:kn_98988c23,
        oc:kn_a3aa4536,
        oc:kn_a8b39839,
        oc:kn_ad7b6382,
        oc:kn_d0bd5d1a,
        oc:kn_d4d9f994 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:InitialEmailSent ;
    oc:resolvesIntent "create follow-up email sequence",
        "design multi-touch outreach sequence",
        "optimize follow-up reply rates",
        "plan cold email cadence",
        "write breakup email" ;
    oc:yieldsState oc:BreakupEmailSent,
        oc:FollowUpSequenceExecuted .

oc:kn_2ae76f91 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any follow-up sequence" ;
    oc:directiveContent "Cap sequences at 4 follow-ups (5 total emails). Each email must add genuinely new value — never just bump or check in." ;
    oc:hasRationale "By the 4th follow-up, response rates drop 55% and spam complaints triple. Longer sequences catch different timing windows but diminishing returns set in quickly." ;
    oc:severityLevel "HIGH" .

oc:kn_2cae94cb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any follow-up email copy" ;
    oc:directiveContent "Never use phrases like 'just checking in', 'bumping this to the top of your inbox', 'did you see my last email?', or 'I never heard back'." ;
    oc:hasRationale "'I never heard back' causes a 12% drop in meeting booking rate (Gong). These phrases signal laziness, presumption, or guilt-tripping and add zero value." ;
    oc:severityLevel "CRITICAL" .

oc:kn_98988c23 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scheduling follow-up emails" ;
    oc:directiveContent "Increase the gap between each touch: Day 0 (initial), Day 3, Day 7–8, Day 14, Day 21–28. Send Tuesday–Thursday between 9–11 AM or 1–3 PM in the prospect's local time." ;
    oc:hasRationale "Waiting 3 days increases response by up to 31%. Thursday peaks at 6.87% reply rate. Monday mornings and Friday afternoons underperform." ;
    oc:severityLevel "HIGH" .

oc:kn_a3aa4536 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting calls-to-action for follow-up emails" ;
    oc:directiveContent "Adjust CTA friction by seniority: executives/founders get ultra-low-effort CTAs ('Curious?', 'Worth 2 min?'); mid-level managers get more specific value CTAs." ;
    oc:hasRationale "Higher in the org chart = less friction you can ask for. Executive attention requires minimal effort to engage." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a8b39839 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using the 1-2-3 breakup format for reducing friction to near zero" ;
    oc:directiveContent """Since I haven't heard back, I'll keep it simple. Reply with a number:
1 — Interested, let's talk
2 — Not now, check back in 3 months
3 — Not interested, please stop""" ;
    oc:hasRationale "Reduces reply friction to near zero by giving prospects clear, low-effort options to respond." .

oc:kn_ad7b6382 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When writing the final follow-up in a sequence" ;
    oc:directiveContent "Structure a breakup email: 1) Acknowledge multiple outreach attempts, 2) Validate their potential lack of interest, 3) State this is your final email for now, 4) Leave the door open with a brief insight or resource." ;
    oc:hasRationale "This structure leverages loss aversion by removing pressure while creating scarcity through withdrawal, yielding 10–15% response rates." ;
    oc:severityLevel "HIGH" ;
    oc:stepOrder 1 .

oc:kn_d0bd5d1a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After sending a breakup/final follow-up email" ;
    oc:directiveContent "If you send a breakup email, honor it — do not contact the prospect again." ;
    oc:hasRationale "Breakup emails leverage loss aversion and achieve 10–15% response rates with cold prospects. Violating this commitment destroys trust and triggers spam complaints." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d4d9f994 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the content of each follow-up in a sequence" ;
    oc:directiveContent "Rotate angles across emails: Initial (personalized hook + value prop), FU1 (new value piece), FU2 (social proof/case study), FU3 (new insight/industry trend), FU4 (breakup email). Add only one new value proposition per email." ;
    oc:hasRationale "Each follow-up must stand alone while building toward the goal. One new value proposition per email naturally forces different angles and avoids repetition." ;
    oc:severityLevel "HIGH" .

_:ref_89f4eb1993d9c044 a oc:WorkflowStep ;
    dcterms:description "Acknowledge you've reached out multiple times" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_91ec02a4826e1c0d a oc:WorkflowStep ;
    dcterms:description "Validate their potential lack of interest" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_a89d4f4bfad31ce7 a oc:WorkflowStep ;
    dcterms:description "Leave the door open" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_ad43b92a5fbf4188 a oc:WorkflowStep ;
    dcterms:description "State this is your final email for now" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_1b7d13b25528b85c a oc:WorkflowStep ;
    dcterms:description "Day 7–8: Send follow-up with social proof or case study from similar company" ;
    oc:expectedOutcome "Build credibility through third-party validation" ;
    oc:stepDependsOn _:ref_bbb4b0d859c72f3d ;
    oc:stepId "follow-up-2" .

_:ref_ba497e679fb5f63f a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 3 ;
    oc:hasStep _:ref_89f4eb1993d9c044,
        _:ref_91ec02a4826e1c0d,
        _:ref_a89d4f4bfad31ce7,
        _:ref_ad43b92a5fbf4188 ;
    oc:workflowId "procedure_3" ;
    oc:workflowName "Ordered Procedure" .

_:ref_bbb4b0d859c72f3d a oc:WorkflowStep ;
    dcterms:description "Day 3: Send follow-up with a different angle and new value piece (stat, insight, resource)" ;
    oc:expectedOutcome "Show additional benefit from a new perspective" ;
    oc:stepDependsOn _:ref_cfef73f6bbccdc34 ;
    oc:stepId "follow-up-1" .

_:ref_cfef73f6bbccdc34 a oc:WorkflowStep ;
    dcterms:description "Send initial email with personalized hook + core value prop + soft CTA" ;
    oc:expectedOutcome "Prospect receives first touch; some may reply immediately" ;
    oc:stepId "send-initial" .

_:ref_d9083af10da6a3ea a oc:WorkflowStep ;
    dcterms:description "Day 14: Send follow-up with new insight, industry trend, or relevant resource" ;
    oc:expectedOutcome "Demonstrate expertise and provide fresh value" ;
    oc:stepDependsOn _:ref_1b7d13b25528b85c ;
    oc:stepId "follow-up-3" .

