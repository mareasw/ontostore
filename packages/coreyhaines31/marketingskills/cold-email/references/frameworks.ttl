@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_cold_email_frameworks a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "frameworks" ;
    skos:broader "copywriting framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/cold-email" ;
    oc:contentHash "b29fb89922f96ae1c6911675a7e173a8f7c6a40999c9a18b14ac7f357b5f5a03" ;
    oc:differentia "that provides structured persuasion patterns for cold email composition, teaching reusable thinking models rather than static templates" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_cold_email ;
    oc:handlesFailure oc:FrameworkMismatch,
        oc:InvalidInput ;
    oc:hasArgumentHint "prospect persona or email context (e.g., 'C-suite', 'problem-aware prospect', 'agency outreach')" ;
    oc:hasCategory "marketing" ;
    oc:hasRequirement oc:req_79e11914,
        oc:req_aecc38dc ;
    oc:impartsKnowledge oc:kn_28a15e62,
        oc:kn_543a40a6,
        oc:kn_5773e3d7,
        oc:kn_8a270fca,
        oc:kn_b58f9f69,
        oc:kn_b71ba40c ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProductContextEstablished,
        oc:ProspectIdentified ;
    oc:resolvesIntent "apply PAS BAB AIDA or other frameworks to cold email",
        "choose a cold email copywriting framework",
        "learn cold email copywriting frameworks",
        "select the right framework for a cold email prospect",
        "write cold emails using proven persuasion structures" ;
    oc:yieldsState oc:ColdEmailDrafted,
        oc:FrameworkSelected .

oc:kn_28a15e62 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When no specific prospect context suggests an alternative framework" ;
    oc:directiveContent "Use PAS (Problem, Agitate, Solution) as the default framework — it is the workhorse for most cold email scenarios and works best for problem-aware but not solution-aware prospects." ;
    oc:hasRationale "PAS covers the widest range of cold email situations and aligns with how buyers naturally process pain-to-solution narratives." ;
    oc:severityLevel "MEDIUM" .

oc:kn_543a40a6 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When closing any cold email regardless of framework" ;
    oc:directiveContent "Every framework must end with a clear, low-friction CTA — preferably a binary question ('Worth a 10-minute demo?', 'Would it make sense to see how?') rather than an open-ended ask." ;
    oc:hasRationale "Binary CTAs reduce cognitive load for the recipient and dramatically increase reply rates compared to open-ended requests." ;
    oc:severityLevel "HIGH" .

oc:kn_5773e3d7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a framework for a specific cold email" ;
    oc:directiveContent "Match framework to prospect type: QVC and Mouse Trap for C-suite (brevity), AIDA and ACCA for analytical/data-driven buyers, PPP for senior relationship-oriented prospects, Star-Story-Solution for strong customer success stories." ;
    oc:hasRationale "Different personas respond to different persuasion structures; mismatching framework to audience reduces reply rates." ;
    oc:severityLevel "HIGH" .

oc:kn_8a270fca a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When personalizing cold emails at scale vs. targeting high-value accounts" ;
    oc:directiveContent "Spend max 1 minute on personalization per email using industry/persona-level signals. For top-tier prospects only, quote their own words from interviews or public content." ;
    oc:hasRationale "Over-investing in personalization per email destroys sender volume; industry-level signals provide 80% of the personalization impact for 5% of the effort." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b58f9f69 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when composing cold emails using any framework" ;
    oc:directiveContent "Never use these frameworks as copy-paste templates — apply the structural thinking pattern to craft genuinely relevant, personalized emails." ;
    oc:hasRationale "Templates produce generic-sounding emails that prospects ignore; frameworks teach the underlying persuasion logic that scales across contexts." ;
    oc:severityLevel "HIGH" .

oc:kn_b71ba40c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using ultra-short frameworks for SDR teams or high-volume outreach" ;
    oc:directiveContent "The Justin Michael Method and Mouse Trap frameworks must stay under 1–3 sentences total with a binary (yes/no) CTA — they are deliberately designed for mobile-optimized, high-velocity sending." ;
    oc:hasRationale "These frameworks rely on brevity-driven curiosity; adding length defeats their core mechanism of impulse-driven replies." ;
    oc:severityLevel "MEDIUM" .

oc:req_79e11914 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of the target prospect's persona and pain points" .

oc:req_aecc38dc a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Awareness of the product/service value proposition" .

