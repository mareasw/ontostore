@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_cold_email_frameworks a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "frameworks" ;
    skos:broader "Cold email copywriting framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/cold-email" ;
    oc:contentHash "b29fb89922f96ae1c6911675a7e173a8f7c6a40999c9a18b14ac7f357b5f5a03" ;
    oc:differentia "that provides structured thinking patterns for composing persuasive cold outreach emails using proven persuasion models" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_cold_email ;
    oc:handlesFailure oc:InsufficientProspectContext,
        oc:NoMatchingFramework ;
    oc:hasArgumentHint "framework name or prospect context (e.g., 'PAS for VP Sales', 'brief framework for C-suite')" ;
    oc:hasCategory "marketing" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Frameworks beat templates — they teach thinking patterns, not copy-paste shortcuts." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent "Companies in pharma lose 30% of leads due to manual outreach. Given {{Company}}'s growth this quarter, pipeline velocity is likely top of mind. Customers like Pfizer use our platform to automate lead qualification — cutting time-to-contact by 60%. Worth a 15-minute call?" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Structure:** Hook/stat → Address specific challenge → Social proof/outcome → Clear CTA.
**Best for:** Data-driven prospects, high-ticket pitches with strong stats.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "AIDA — Attention, Interest, Desire, Action" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent "Your team doubled this year. That usually means onboarding is eating into selling time. How are you handling ramp for new hires?" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Structure:** Current reality → Complicating challenge → Question that speaks to need → Optional answer.
**Best for:** Consultative selling. Mirrors how professionals present to leadership.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "SCQ — Situation, Complication, Question" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Spend max 1 minute on personalization. Use industry/persona-level signals. For top-tier prospects, quote their own words from interviews — they almost always respond." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Structure:** Trigger/Pain → Solution hint → Binary CTA. 1–3 sentences, no intro.
**Best for:** High-velocity SDR teams. Mobile-optimized. Deliberately polarizing.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 11 ;
                    oc:sectionTitle "Justin Michael Method" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent "Looks like you're hiring reps. Would it be helpful to get a more granular look at how they're ramping on email?" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Structure:** Observation + Binary value-prop question. 1–2 sentences total.
**Best for:** Maximum brevity. Impulsive reply based on curiosity.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 10 ;
                    oc:sectionTitle "Mouse Trap (Lavender/Will Allred)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Structure:** Observation → Problem/Insight → Credibility → Solution → Call-to-Conversation.
**Best for:** Universal "base" framework that works everywhere. Five parts.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 12 ;
                    oc:sectionTitle "Vanilla Ice Cream (Lavender)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Structure:** Problem → Amplify → Story → Testimony → Offer → Response.
**Best for:** Longer-form or multi-email sequences. Consulting, education, complex B2B services. Each element can be developed across separate touches.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 13 ;
                    oc:sectionTitle "PASTOR (Ray Edwards)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Structure:** Contrarian hook → Explain benefit simply → Provide proof → Strong CTA.
**Best for:** Analytical buyers who need evidence (engineers, CFOs, ops leaders).""" ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent "Most sales teams measure rep activity. The top 5% measure rep efficiency instead. When Acme switched, they booked 40% more meetings with fewer emails. Worth seeing how?" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "ACCA — Awareness, Comprehension, Conviction, Action" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent "Your keynote on scaling SDR teams was spot-on — especially on ramp time as the hidden cost. What if you could cut that in half? Our in-inbox coach helps new reps write effective emails from day one with real-time scoring. Open to a quick chat about how this could support your growth?" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Structure:** Genuine compliment → How things could be better → Gentle push to action.
**Best for:** Senior prospects who respond to relationship-building. Requires genuine trigger.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "PPP — Praise, Picture, Push" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Structure:** Introduce character (customer) → Tell challenge narrative → Reveal results.
**Best for:** Strong customer success stories. Humanizes the pitch.""" ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent "Last year, Sarah — VP Sales at a Series B startup — had 5 SDRs competing against a rival with 20. Her team was getting crushed on volume. They adopted our AI prospecting tool and sent hyper-personalized emails at 3x pace without losing quality. Within 90 days, they booked more meetings than their competitor's entire team. Happy to share how this could work for {{Company}}." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Star-Story-Solution" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Structure:** Identify pain → Amplify consequences → Present solution + soft CTA.
**Best for:** Problem-aware but not solution-aware prospects. The workhorse framework.""" ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent "Most VP Sales at companies your size spend 5+ hours/week on manual CRM reporting. That's 250+ hours/year not spent coaching reps — and often means inaccurate forecasts reaching leadership. We built a tool that auto-generates CRM reports in real time. Teams like Datadog reduced reporting time by 80%. Would it make sense to see how?" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "PAS — Problem, Agitate, Solution (default)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent "Right now, your team is likely spending hours manually sourcing leads — feast or famine each quarter. Imagine qualified leads arriving daily on autopilot, reps spending 100% of their time selling. That's what our platform does. Companies like HubSpot saw a 40% pipeline increase within 90 days. Can I show you how?" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Structure:** Current painful situation → Ideal future → Your product as the bridge.
**Best for:** Transformation-driven offers with clear before/after. Emotional decision-makers.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "BAB — Before, After, Bridge" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent "Big fan of [Company]. We just built an app for [Competitor] that does XYZ. I have a few more ideas. Interested?" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Structure:** Compliment → Case Study → CTA.
**Best for:** Agency/services cold outreach. Case study does the heavy lifting.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 9 ;
                    oc:sectionTitle "3C's (Alex Berman)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 2 ;
                            oc:quoteContent "Are your SDRs spending more time researching than selling? We help sales teams automate prospect research so reps focus on conversations. Clients see 3x more meetings per rep per week. Worth a 10-minute demo?" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Structure:** Targeted pain question → Brief value → Direct next step.
**Best for:** C-suite prospects who prefer brevity. Qualify interest immediately.""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "QVC — Question, Value, CTA" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Cold Email Copywriting Frameworks" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Choose and apply the right copywriting framework based on prospect context" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Verify CTA is appropriate (soft/binary, not aggressive) and email length suits the channel" ;
                    oc:expectedOutcome "Validated email ready to send" ;
                    oc:stepDependsOn _:ref_e4ed12064b922242 ;
                    oc:stepId "validate-cta" ],
                _:ref_53f635fbd45a4fee,
                _:ref_e4ed12064b922242,
                _:ref_fc8eeffa11ec3271 ;
            oc:workflowId "framework-selection" ;
            oc:workflowName "Select Cold Email Framework" ] ;
    oc:impartsKnowledge oc:kn_1b52c4a3,
        oc:kn_2d720883,
        oc:kn_474a0d1d,
        oc:kn_8ac7864b,
        oc:kn_c8359084,
        oc:kn_d7f060fb,
        oc:kn_e51a6cbd,
        oc:kn_f652a141,
        oc:kn_fdfb5364 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProspectIdentified,
        oc:ValuePropositionDefined ;
    oc:resolvesIntent "apply copywriting framework to cold outreach",
        "choose email framework",
        "structure persuasive email",
        "write cold email copy" ;
    oc:yieldsState oc:EmailCopyDrafted,
        oc:FrameworkSelected .

oc:kn_1b52c4a3 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When composing any cold email" ;
    oc:directiveContent "1. Identify prospect's awareness level (problem-aware vs solution-aware) 2. Match persona type to framework (C-suite→QVC, analytical→ACCA, consultative→SCQ) 3. Draft using framework structure 4. Verify CTAs are binary/soft (not aggressive) 5. Limit personalization to 1 minute" ;
    oc:stepOrder 1 .

oc:kn_2d720883 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing a PAS-framework cold email" ;
    oc:directiveContent "Most {persona} at companies your size spend {pain_point_quantified}. That's {amplified_consequence}. We built {solution}. Teams like {social_proof} {result}. Would it make sense to {soft_CTA}?" ;
    oc:templateVariables "amplified_consequence",
        "pain_point_quantified",
        "persona",
        "result",
        "social_proof",
        "soft_CTA",
        "solution" .

oc:kn_474a0d1d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When personalizing cold emails at scale" ;
    oc:directiveContent "Spend max 1 minute on personalization. Use industry/persona-level signals. For top-tier prospects only, quote their own words from interviews." ;
    oc:hasRationale "Over-personalization wastes time and often feels creepy; under-personalization feels generic" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8ac7864b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting or applying any cold email framework" ;
    oc:directiveContent "Frameworks beat templates — they teach thinking patterns, not copy-paste shortcuts. Always adapt the framework to the prospect's context rather than filling in blanks." ;
    oc:hasRationale "Templates produce generic emails that get ignored; frameworks develop genuine persuasion skill" ;
    oc:severityLevel "HIGH" .

oc:kn_c8359084 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When uncertain which framework to use" ;
    oc:directiveContent "PAS (Problem, Agitate, Solution) is the default workhorse framework. Use it unless you have a specific reason to choose another." ;
    oc:hasRationale "PAS maps most directly to how humans process problems and solutions, making it broadly effective" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d7f060fb a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When presenting a framework selection to the user or documenting an email draft" ;
    oc:directiveContent """## {Framework Name} — {Tagline}
**Structure:** {Step 1} → {Step 2} → {Step 3}
**Best for:** {Persona/situation}
> {Filled example applying framework to prospect's context}""" ;
    oc:templateVariables "Filled example",
        "Framework Name",
        "Persona/situation",
        "Step 1",
        "Step 2",
        "Step 3",
        "Tagline" .

oc:kn_e51a6cbd a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When optimizing for reply rates across different channels and sequences" ;
    oc:directiveContent "Shorter frameworks (QVC, Mouse Trap, Justin Michael Method) perform better for mobile-reading C-suite and high-volume SDR teams. Longer frameworks (PASTOR, Star-Story-Solution) suit multi-email sequences and complex B2B services." ;
    oc:hasRationale "Mobile readers scan in 3-5 seconds; complex offers need more narrative to build conviction" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f652a141 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When considering the PPP framework" ;
    oc:directiveContent "Do not use PPP (Praise, Picture, Push) without a genuine trigger for the compliment — forced praise destroys credibility immediately." ;
    oc:hasRationale "Inauthentic flattery signals spam and triggers defensive rejection" ;
    oc:severityLevel "HIGH" .

oc:kn_fdfb5364 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which framework to use for a specific prospect" ;
    oc:directiveContent "Match framework to buyer awareness level and persona: PAS for problem-aware prospects, QVC for C-suite brevity, AIDA for data-driven prospects, PPP for relationship-building with senior leaders, SCQ for consultative selling, ACCA for analytical buyers." ;
    oc:hasRationale "Different decision-making styles respond to different persuasion structures" ;
    oc:severityLevel "HIGH" .

_:ref_53f635fbd45a4fee a oc:WorkflowStep ;
    dcterms:description "Match prospect profile to best-fitting framework (default: PAS)" ;
    oc:expectedOutcome "Selected framework with rationale" ;
    oc:stepDependsOn _:ref_fc8eeffa11ec3271 ;
    oc:stepId "match-framework" .

_:ref_e4ed12064b922242 a oc:WorkflowStep ;
    dcterms:description "Draft email following the framework's structure with prospect-specific details" ;
    oc:expectedOutcome "Complete cold email draft" ;
    oc:stepDependsOn _:ref_53f635fbd45a4fee ;
    oc:stepId "draft-email" .

_:ref_fc8eeffa11ec3271 a oc:WorkflowStep ;
    dcterms:description "Identify prospect's awareness level, persona type, and decision-making style" ;
    oc:expectedOutcome "Prospect profile with awareness level and persona tags" ;
    oc:stepId "assess-prospect" .

