oc:kn_272f4de2 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When maintaining ongoing social presence" ;
    oc:directiveContent "Evergreen content can be updated and reshared. Repurposing old high-performing content is a valid strategy when stuck." ;
    oc:hasRationale "Not all content needs to be net-new; proven content can be refreshed and redistributed for continued value." ;
    oc:severityLevel "LOW" .

oc:kn_3332fe18 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before creating any social content" ;
    oc:directiveContent "Always check for product-marketing-context.md (.agents/ or .claude/) before asking questions. Use that context and only ask for information not already covered." ;
    oc:hasRationale "Avoids redundant questions and ensures brand-consistent output by leveraging existing context." ;
    oc:severityLevel "HIGH" .

oc:kn_3605d5e8 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When social content underperforms" ;
    oc:directiveContent "If engagement is low: test new hooks, post at different times, try different formats (carousels, video), and increase engagement with others' content. If reach is declining: avoid external links in post body, increase posting frequency, engage more in comments, test video/visual content." ;
    oc:hasRationale "Engagement and reach issues have distinct causes requiring different optimization levers." ;
    oc:severityLevel "MEDIUM" .

oc:kn_757e34a3 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any social content creation session" ;
    oc:directiveContent "Before creating content, gather context on: goals (awareness/leads/traffic/community), audience (who/platforms/engagement preferences), brand voice (tone/topics to avoid/style), and resources (time/existing content/video capability)." ;
    oc:hasRationale "Without context alignment, content may be off-brand, mistargeted, or unsustainable." ;
    oc:severityLevel "HIGH" .

oc:kn_80b17976 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating LinkedIn posts" ;
    oc:directiveContent "Never put external links in the main LinkedIn post body — always put them in comments. Links in the post body kill reach." ;
    oc:hasRationale "LinkedIn's algorithm deprioritizes posts with external links in the body, dramatically reducing impressions." ;
    oc:severityLevel "HIGH" .

oc:kn_b71d8a74 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning weekly content production" ;
    oc:directiveContent "Batch content creation into 2-3 hour weekly sessions: review pillar topics → write LinkedIn posts → write Twitter threads → create Instagram ideas → schedule everything → leave room for real-time engagement." ;
    oc:hasRationale "Batching reduces context-switching overhead and ensures consistent output without daily creation pressure." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b7c3d076 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any social media post" ;
    oc:directiveContent "The first line determines whether anyone reads the rest. Use curiosity, story, value, or contrarian hook formulas to grab attention before the 'see more' cutoff." ;
    oc:hasRationale "Platform algorithms and human attention both reward strong hooks — without them, even great content gets scrolled past." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f067f1fb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning any social media strategy" ;
    oc:directiveContent "Build content around 3-5 pillars that align with expertise and audience interests. Allocate percentages (e.g., 30% industry insights, 25% behind-the-scenes, 25% educational, 15% personal, 5% promotional)." ;
    oc:hasRationale "Content pillars ensure variety, consistency, and strategic alignment with business goals while avoiding over-promotion." ;
    oc:severityLevel "MEDIUM" .

