        oc:kn_c4221317,
        oc:kn_eb897c78,
        oc:kn_f748b232 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:MarketingContextAvailable ;
    oc:resolvesIntent "analyze and improve social media performance",
        "build a content calendar and posting strategy",
        "create LinkedIn posts, Twitter threads, Instagram carousels",
        "create social media posts for specific platforms",
        "optimize social media engagement and reach",
        "repurpose existing content across social platforms",
        "reverse engineer viral content patterns",
        "write platform-specific hooks and post formats" ;
    oc:yieldsState oc:ContentCalendarPlanned,
        oc:ContentRepurposed,
        oc:SocialContentCreated .

oc:kn_17861549 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any social media post or thread" ;
    oc:directiveContent "The first line (hook) determines whether anyone reads the rest of the post. Use curiosity, story, value, contrarian, or social proof hook formulas to create pattern interrupts." ;
    oc:hasRationale "Social platforms truncate content behind 'see more' clicks. The hook is the only thing visible in the feed — if it doesn't stop the scroll, nothing else matters." ;
    oc:severityLevel "HIGH" .

oc:kn_2c7ac87a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any social media content strategy" ;
    oc:directiveContent "Build content around 3-5 content pillars that align with expertise and audience interests, distributing percentages across pillars like industry insights (30%), behind-the-scenes (25%), educational (25%), personal (15%), and promotional (5%)." ;
    oc:hasRationale "Content pillars ensure consistent coverage of topics that matter to the audience while maintaining a sustainable creation cadence and avoiding over-promotion." ;
    oc:severityLevel "HIGH" .

oc:kn_3b66766d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining posting cadence for any platform" ;
    oc:directiveContent "Different platforms have different optimal posting frequencies and content formats: LinkedIn 3-5x/week (carousels, stories), Twitter/X 3-10x/day (threads, hot takes), Instagram 1-2 posts + Stories daily (Reels, carousels), TikTok 1-4x/day (short-form video)." ;
    oc:hasRationale "Each platform's algorithm rewards different posting frequencies and format types. Under- or over-posting on a platform reduces reach and engagement." ;
    oc:severityLevel "HIGH" .

oc:kn_899ceabf a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When user requests cross over into email sequences, broader content strategy, or paid ads" ;
    oc:directiveContent "Recognize scope boundaries: writing email sequences should defer to the email-sequence skill, and broader content strategy should reference the content-strategy skill. Do not attempt to fulfill adjacent skill tasks using social content patterns alone." ;
    oc:hasRationale "Each marketing discipline has its own specialized frameworks and best practices. Using social content patterns for email sequences or other channels produces suboptimal results." ;
    oc:severityLevel "MEDIUM" .

oc:kn_94fb5cc1 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When social media content underperforms" ;
    oc:directiveContent "If engagement is low, test new hook formulas, post at different times, try different content formats (carousels, video, polls), and increase engagement with other accounts. If reach is declining, avoid external links in post body, increase posting frequency, and engage more in comments." ;
    oc:hasRationale "Platform algorithms reward different signals over time. Systematic testing of hooks, timing, formats, and engagement patterns identifies what the current algorithm favors." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b4b72b3d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning weekly social media content production" ;
    oc:directiveContent "Batch content creation into 2-3 hours weekly: write 5 LinkedIn posts, 3 Twitter threads plus daily tweets, Instagram carousel and Reel ideas, then schedule everything while leaving room for real-time engagement." ;
    oc:hasRationale "Batching reduces context-switching costs and ensures consistent output, which is the single biggest factor in social media growth." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c362827e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When developing a new social media strategy or entering a new niche" ;
    oc:directiveContent "Reverse-engineer viral content systematically: find 10-20 top creators, collect 500+ posts, analyze patterns (hooks, formats, CTAs, topics), codify a playbook of repeatable patterns, then layer your authentic voice on top." ;
    oc:hasRationale "Data-driven pattern extraction from proven content outperforms creative guessing. The combination of proven patterns with authentic voice produces the highest-performing content." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c4221317 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating any social media content" ;
    oc:directiveContent "Always check for product-marketing-context.md (.agents/ or .claude/) before creating content. Use existing context and only ask for information not already covered." ;
    oc:hasRationale "Product marketing context contains brand voice, target audience, positioning, and messaging that ensures social content aligns with overall marketing strategy." ;
    oc:severityLevel "HIGH" .

oc:kn_eb897c78 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When posting content on LinkedIn or Facebook" ;
    oc:directiveContent "Never put external links in the main post body on LinkedIn or Facebook — always place links in comments instead. This applies across platforms where the algorithm penalizes outbound links." ;
    oc:hasRationale "Platform algorithms suppress posts with external links in the body because they want to keep users on-platform. Putting links in comments dramatically increases reach." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f748b232 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When repurposing blog posts, videos, or other long-form content" ;
    oc:directiveContent "One piece of pillar content should be repurposed into 5+ platform-specific formats: LinkedIn key insight post, LinkedIn carousel, Twitter thread, Instagram carousel, and Instagram Reel summary." ;
    oc:hasRationale "Repurposing maximizes ROI on content creation effort while adapting format and tone to each platform's native conventions and algorithm preferences." ;
    oc:severityLevel "MEDIUM" .

