oc:skill_coreyhaines31_marketingskills_social_content a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "social-content" ;
    skos:broader "Social media content creation and optimization framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/social-content" ;
    oc:contentHash "ed34ccc28ae19e804a658a1fc78620e34a318aed577cc0bf3399ef8a1bf57669" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "Provides platform-specific strategies, content pillar systems, hook formulas, repurposing workflows, engagement routines, and reverse engineering methods for multi-platform social media content generation" ;
    oc:extends oc:skill_copywriting ;
    oc:handlesFailure oc:InsufficientContext,
        oc:MissingBrandVoice,
        oc:PlatformNotSupported ;
    oc:hasAlias "content calendar",
        "instagram carousel",
        "linkedin post",
        "social media",
        "social posts",
        "social scheduling",
        "twitter thread" ;
    oc:hasAllowedTool "Glob",
        "Read",
        "Write" ;
    oc:hasArgumentHint "platform, content type, or social media task (e.g., 'LinkedIn post about X', 'Twitter thread', 'repurpose blog post', 'content calendar')" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants help creating, scheduling, or optimizing social media content for LinkedIn, Twitter/X, Instagram, TikTok, Facebook, or other platforms. Also use when the user mentions 'LinkedIn post,' 'Twitter thread,' 'social media,' 'content calendar,' 'social scheduling,' 'engagement,' 'viral content,' 'what should I post,' 'repurpose this content,' 'tweet ideas,' 'LinkedIn carousel,' 'social media strategy,' or 'grow my following.' Use this for any social media content creation, repurposing, or scheduling task. For broader content strategy, see content-strategy." ;
    oc:hasName "social-content" ;
    oc:impartsKnowledge oc:kn_17861549,
        oc:kn_2c7ac87a,
