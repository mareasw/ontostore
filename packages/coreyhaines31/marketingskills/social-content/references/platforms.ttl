@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_social_content_platforms a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "platforms" ;
    skos:broader "Platform-specific strategy guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/social-content" ;
    oc:contentHash "3c4e1b15717a3bcd4ed0cf29dc167dac28aa88bbf01723fde53815122396090f" ;
    oc:differentia "provides tailored content, format, and algorithm optimization tactics for LinkedIn, Twitter/X, Instagram, TikTok, and Facebook" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_social_content ;
    oc:hasArgumentHint "platform name (linkedin, twitter, instagram, tiktok, facebook)" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_0ab4aa27,
        oc:kn_22eebb51,
        oc:kn_2ba2dc89,
        oc:kn_318bd1fd,
        oc:kn_88f808cb,
        oc:kn_9817e3b8 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "choose the right social platform for content goals",
        "format social media posts for maximum engagement per platform",
        "optimize content for each social platform's algorithm",
        "plan platform-specific social media content" .

oc:kn_0ab4aa27 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting content for a specific platform" ;
    oc:directiveContent "Respect platform-specific format requirements: TikTok requires vertical 9:16 video, LinkedIn carousels use document format, Instagram Reels get 2x reach over static posts, tweets under 100 characters get more engagement." ;
    oc:hasRationale "Each platform's algorithm and UI are optimized for native formats — non-native content gets deprioritized" ;
    oc:severityLevel "MEDIUM" .

oc:kn_22eebb51 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When publishing any social media post" ;
    oc:directiveContent "Optimize the first 30-60 minutes after posting for engagement — this is when algorithms evaluate content quality and determine reach." ;
    oc:hasRationale "All major platforms use early engagement as a primary signal for distributing content to broader audiences" ;
    oc:severityLevel "HIGH" .

oc:kn_2ba2dc89 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting content for any social platform" ;
    oc:directiveContent "Lead every post with a strong hook visible before the truncation point: LinkedIn first line, TikTok first 1-2 seconds, Twitter first tweet, Instagram first frame." ;
    oc:hasRationale "The hook determines whether users engage or scroll past; platform-specific truncation (see more, video loop, feed preview) makes the opening the most valuable real estate" ;
    oc:severityLevel "HIGH" .

oc:kn_318bd1fd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When posting on LinkedIn or Facebook" ;
    oc:directiveContent "Never include external links in LinkedIn or Facebook post bodies — they kill organic reach. Place links in comments instead." ;
    oc:hasRationale "Platform algorithms penalize content that drives users off-platform, dramatically reducing reach" ;
    oc:severityLevel "CRITICAL" .

oc:kn_88f808cb a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When planning a social content calendar" ;
    oc:directiveContent "Adjust posting frequency per platform: LinkedIn 3-5x/week, Twitter 3-10x/day, Instagram 1-2 feed posts + 3-10 Stories/day, TikTok 1-4x/day, Facebook 1-2x/day." ;
    oc:hasRationale "Each platform has a different content velocity expectation — posting too little means invisibility, posting too much means fatigue" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9817e3b8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating content for TikTok, Twitter/X, or LinkedIn" ;
    oc:directiveContent "Avoid overly polished/produced content on TikTok and pure self-promotional content on any platform — both perform poorly." ;
    oc:hasRationale "Audiences on these platforms value authenticity and value-delivery over production quality or sales pitches" ;
    oc:severityLevel "HIGH" .

