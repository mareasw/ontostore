oc:kn_1cea158f a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When planning social media content calendars" ;
    oc:directiveContent "Optimal posting frequency varies dramatically: Twitter/X 3-10x/day, TikTok 1-4x/day, Instagram 1-2 feed posts + 3-10 Stories/day, LinkedIn 3-5x/week, Facebook 1-2x/day." ;
    oc:hasRationale "Each platform's algorithm and audience expectations demand different posting cadences — mismatching frequency wastes content or misses distribution windows" .

oc:kn_31aaa746 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning content distribution across platforms" ;
    oc:directiveContent "Match content format to platform strengths: carousels/documents on LinkedIn, threads on Twitter/X, Reels on Instagram, native vertical video on TikTok, groups/community on Facebook." ;
    oc:hasRationale "Each platform algorithmically rewards its native content format — fighting the algorithm wastes effort" .

oc:kn_4cd1a02a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing social media post openings" ;
    oc:directiveContent "Hook within first line on LinkedIn (before 'see more' cutoff), first 100 characters on Twitter, first frame on Instagram Reels, first 1-2 seconds on TikTok." ;
    oc:hasRationale "Platform UI truncates content at these breakpoints — if the hook doesn't land, users scroll past" .

oc:kn_66c8a959 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When publishing new social media posts" ;
    oc:directiveContent "First hour engagement matters most on LinkedIn and first 30 minutes on Twitter/X. Prioritize timing and immediate engagement tactics." ;
    oc:hasRationale "Platform algorithms use early engagement velocity as a primary signal for broader distribution" ;
    oc:severityLevel "HIGH" .

oc:kn_c7ab40fc a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating TikTok content" ;
    oc:directiveContent "TikTok content must be vertical (9:16), native/unpolished, and use trending sounds. Never repurpose horizontal video." ;
    oc:hasRationale "TikTok's algorithm and audience strongly penalize non-native content formats" ;
    oc:severityLevel "HIGH" .

oc:kn_d9c86574 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating LinkedIn posts" ;
    oc:directiveContent "Never include external links in LinkedIn post body — always put them in comments. Links in the main post kill reach." ;
    oc:hasRationale "LinkedIn's algorithm penalizes posts with external links because they drive users off-platform" ;
    oc:severityLevel "CRITICAL" .

oc:kn_dd0035d7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When measuring content success across platforms" ;
    oc:directiveContent "Instagram saves and shares matter more than likes. LinkedIn comments > reactions > clicks. TikTok trains its algorithm with consistent posting frequency." ;
    oc:hasRationale "Each platform weights different engagement signals in its algorithm — optimizing for the wrong metric reduces distribution" .

oc:kn_e7475f6f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating content for any social platform" ;
    oc:directiveContent "Avoid overly promotional content, generic motivational quotes, corporate speak without personality, and hard selling across all platforms." ;
    oc:hasRationale "Social media audiences in 2024+ distrust inauthentic, salesy, or generic content — it destroys engagement and brand credibility" ;
    oc:severityLevel "HIGH" .

