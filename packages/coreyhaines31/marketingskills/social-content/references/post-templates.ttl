@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_social_content_post_templates a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "post-templates" ;
    skos:broader "Content template library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/social-content" ;
    oc:contentHash "db6525e51a690b61faf97a0acf51a2a57526de90da01c6bb37679d056c18c7f4" ;
    oc:differentia "provides ready-to-use post format templates for LinkedIn, Twitter/X, and Instagram with hook formulas for social media content creation" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_social_content ;
    oc:hasArgumentHint "platform and content type (e.g., 'LinkedIn story post', 'Twitter tutorial thread', 'Instagram reel script')" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_03cdd1c1,
        oc:kn_48bb84d9,
        oc:kn_59beb547,
        oc:kn_c72eab38,
        oc:kn_db098de2 ;
    oc:isUserInvocable true ;
    oc:nature "Template" ;
    oc:resolvesIntent "create social media post from template",
        "generate hooks for social media content",
        "structure social media posts for engagement",
        "write Instagram carousel or reel script",
        "write LinkedIn post",
        "write Twitter/X thread" .

oc:kn_03cdd1c1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any social media post across all platforms" ;
    oc:directiveContent "The first line (hook) determines whether anyone reads the rest of the post — invest the most creative effort in the opening line." ;
    oc:hasRationale "Social media platforms truncate content in feeds; the hook is the only thing visible before the user decides to engage, making it the highest-leverage element." ;
    oc:severityLevel "CRITICAL" .

oc:kn_48bb84d9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finalizing any social media post" ;
    oc:directiveContent "Always end posts with an engagement prompt — a question, 'Am I wrong?', or 'Which resonates most?' — to signal the algorithm that the post invites conversation." ;
    oc:hasRationale "Engagement signals (comments, replies) amplify distribution on all major platforms; explicit prompts dramatically increase comment rates compared to statements alone." ;
    oc:severityLevel "MEDIUM" .

oc:kn_59beb547 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting the opening line of any social media post" ;
    oc:directiveContent "Use one of five hook categories based on content goal: curiosity (challenge beliefs), story (unexpected events), value (deliver outcome), contrarian (bold stance), or social proof (demonstrated results)." ;
    oc:hasRationale "Hook formulas are proven patterns that exploit cognitive biases (curiosity gap, narrative transportation, loss aversion) to stop the scroll." ;
    oc:severityLevel "HIGH" .

oc:kn_c72eab38 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When selecting a post template for a target platform" ;
    oc:directiveContent "Match template structure to platform conventions: LinkedIn favors story/contrarian/list formats, Twitter/X uses thread-based tutorial/breakdown formats, Instagram uses carousel and short-form video scripts." ;
    oc:hasRationale "Each platform's algorithm and audience expectations reward different content structures; using platform-appropriate formats maximizes reach and engagement." ;
    oc:severityLevel "HIGH" .

oc:kn_db098de2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Instagram Reel scripts" ;
    oc:directiveContent "Instagram Reels must follow a strict time structure: hook (0-2 sec), setup (2-5 sec), value (5-25 sec), CTA (25-30 sec) — total under 30 seconds." ;
    oc:hasRationale "Short-form video algorithms favor content with strong early retention signals; the first 2 seconds determine whether viewers stay, and exceeding 30 seconds reduces completion rate." ;
    oc:severityLevel "MEDIUM" .

