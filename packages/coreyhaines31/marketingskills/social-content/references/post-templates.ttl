        "write LinkedIn post",
        "write Twitter/X thread" ;
    oc:yieldsState oc:PostDrafted .

oc:kn_2446ec20 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any social media post" ;
    oc:directiveContent "The first line (hook) determines whether anyone reads the rest of the post — it is the most critical element of any social media content." ;
    oc:hasRationale "Platform algorithms and human attention both prioritize the opening line; without a strong hook, content is skipped regardless of quality." ;
    oc:severityLevel "CRITICAL" .

oc:kn_72eebc60 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When selecting a LinkedIn post template" ;
    oc:directiveContent "Match template structure to content goal: Story Post for lessons learned, Contrarian Take for sparking debate, List Post for sharing knowledge, How-To for instructional content." ;
    oc:hasRationale "Each template leverages a different psychological trigger and engagement pattern; mismatching template to goal reduces effectiveness." ;
    oc:severityLevel "HIGH" .

oc:kn_77ed5d6c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Twitter/X threads" ;
    oc:directiveContent "Twitter/X threads should use one step per tweet (tweets 2-7) with a distinct hook tweet and a summary/CTA final tweet." ;
    oc:hasRationale "Thread structure must balance information density with readability; overloading single tweets loses readers mid-thread." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b25d47ef a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating Instagram content" ;
    oc:directiveContent "Instagram carousels should have one point per slide (slides 2-9) with a bold hook on slide 1 and summary + CTA on the final slide; reels should deliver value in the 5-25 second window." ;
    oc:hasRationale "Instagram users scroll rapidly; carousels need visual simplicity per slide and reels must front-load value before the viewer swipes away." ;
    oc:severityLevel "HIGH" .

oc:kn_cdfdd800 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting any social media post" ;
    oc:directiveContent "Never write a social post without selecting an appropriate hook formula first — curiosity, story, value, contrarian, or social proof." ;
    oc:hasRationale "Skipping hook selection leads to generic openings that fail to capture attention in crowded feeds." ;
    oc:severityLevel "HIGH" .

_:ref_6e4d0ddf863dd04b a oc:WorkflowStep ;
    dcterms:description "Select the appropriate post template based on the content goal (story, contrarian, list, how-to, thread, carousel, reel)." ;
    oc:expectedOutcome "Template structure selected" ;
    oc:stepDependsOn _:ref_cafb8368a1491062 ;
    oc:stepId "choose-template" .

_:ref_8abc9bb4c3332c6c a oc:WorkflowStep ;
    dcterms:description "Choose a hook formula (curiosity, story, value, contrarian, social proof) that matches the content angle." ;
    oc:expectedOutcome "Hook formula selected" ;
    oc:stepDependsOn _:ref_6e4d0ddf863dd04b ;
    oc:stepId "select-hook" .

_:ref_cafb8368a1491062 a oc:WorkflowStep ;
