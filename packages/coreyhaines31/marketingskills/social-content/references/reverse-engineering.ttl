oc:skill_coreyhaines31_marketingskills_social_content_reverse_engineering a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "reverse-engineering" ;
    skos:broader "Content analysis methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/social-content" ;
    oc:contentHash "c27bef59d463b3b11331c1770f4a23e9e6bbce7d7c8db1e7f7f4f14ba206243f" ;
    oc:differentia "systematically extracts proven viral patterns from top-performing social media posts to replicate success" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_social_content ;
    oc:handlesFailure oc:CreatorNotFound,
        oc:InsufficientData,
        oc:NoPatternsFound ;
    oc:hasArgumentHint "niche or industry focus" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_13f60e0e,
        oc:kn_1eda170d,
        oc:kn_48db31b3,
        oc:kn_9ae2548d,
        oc:kn_e29fe0b8 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:NetworkAvailable,
        oc:NicheIdentified ;
    oc:resolvesIntent "analyze viral content patterns",
        "build a content playbook from competitor analysis",
        "extract hook and format patterns from top creators",
        "reverse engineer successful social media posts" ;
    oc:yieldsState oc:ContentPlaybookCreated,
        oc:ViralPatternsExtracted .

oc:kn_13f60e0e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying discovered patterns to your own content creation" ;
    oc:directiveContent "Never copy viral content directly — extract the structural pattern (hook type, format, CTA) and layer your authentic voice on top." ;
    oc:hasRationale "Direct copying damages credibility and audience trust; authentic voice applied to proven structures is the correct approach." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1eda170d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scraping and collecting data for analysis" ;
    oc:directiveContent "Always analyze at least 500 posts from 10-20 creators before drawing conclusions — smaller datasets produce unreliable pattern signals." ;
    oc:hasRationale "Statistical significance in pattern recognition requires a substantial corpus; 500+ posts ensures patterns are real, not coincidental." ;
    oc:severityLevel "HIGH" .

oc:kn_48db31b3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building the content playbook from analysis" ;
    oc:directiveContent "Codify patterns into three categories: hook patterns, format patterns, and CTA patterns — each documented with the pattern formula, an example, and why it works." ;
    oc:hasRationale "Structured codification makes patterns actionable and repeatable, turning intuition into a system." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9ae2548d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When layering voice onto proven patterns" ;
    oc:directiveContent "Prioritize the 'smart friend who figured something out' voice — share discoveries, not lectures; use 'I found that...' not 'You should...'" ;
    oc:hasRationale "This tone matches how people naturally consume social content — as peers exchanging advice, not experts lecturing." ;
    oc:severityLevel "HIGH" .

oc:kn_e29fe0b8 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before transitioning from analysis to content creation" ;
    oc:directiveContent "Verify you have completed the full checklist before creating content: identified creators, collected 500+ posts, ranked by engagement, documented hook/format/CTA patterns, created voice guidelines, and built a template library." ;
    oc:hasRationale "Skipping steps leads to incomplete pattern extraction and weak playbooks that don't actually reflect what works." ;
    oc:severityLevel "MEDIUM" .

