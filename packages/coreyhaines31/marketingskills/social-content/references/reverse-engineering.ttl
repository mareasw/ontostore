oc:kn_22e2dcc5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying extracted patterns to your own content" ;
    oc:directiveContent "Layer your authentic voice on top of proven patterns rather than copying directly — write like a 'smart friend who figured something out.'" ;
    oc:hasRationale "Direct copying lacks authenticity and won't sustain engagement; voice-layering makes proven structures feel original and genuine." ;
    oc:severityLevel "HIGH" .

oc:kn_2c6a52ab a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When planning time allocation for reverse engineering" ;
    oc:directiveContent "The initial scrape-and-analyze phase is a one-time investment of several hours; the resulting playbook can be reused indefinitely and refined iteratively." ;
    oc:hasRationale "Treat reverse engineering as a capital investment — high upfront effort, compounding returns over time." .

oc:kn_60ec2ee8 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When executing the full reverse engineering process" ;
    oc:directiveContent "Follow the 6-step sequence: Niche ID → Scrape → Analyze → Playbook → Layer Voice → Convert. Each step builds on the previous." ;
    oc:hasRationale "Skipping steps (e.g., analyzing without scraping enough data, or writing without codifying patterns) produces weak outputs." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7207789b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing hooks for social posts" ;
    oc:directiveContent """Pattern: "I [unexpected action] and [surprising result]"
Pattern: "[Specific number] [things] that [outcome]:"
Pattern: "[Controversial take]\"""" .

oc:kn_7322ac20 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scraping content for reverse engineering analysis" ;
    oc:directiveContent "Collect a minimum of 500-1000 posts from 10-20 creators to have statistically meaningful pattern data." ;
    oc:hasRationale "Small datasets produce misleading patterns; 500+ posts across multiple creators reveals robust, repeatable trends." ;
    oc:severityLevel "MEDIUM" .

oc:kn_826e04a5 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing the full reverse engineering workflow" ;
    oc:directiveContent "1. Identify 10-20 top creators (3+ posts/week, high engagement rate, audience overlap). 2. Scrape 500-1000+ posts collecting text, engagement metrics, format, timing, hooks, CTAs, topics. 3. Analyze quantitatively (rank by engagement, top 10%, format/timing patterns) and qualitatively (hook types, length, emotional triggers, recurring topics). 4. Codify patterns into hook templates, format structures, and CTA types. 5. Layer your authentic voice using specificity, brevity, and emotion. 6. Bridge to conversions via newsletter signups, DM triggers, case study posts, and contextual product mentions." ;
    oc:stepOrder 1 .

oc:kn_8a833ed1 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When validating completion of the reverse engineering process" ;
    oc:directiveContent "You have a usable playbook when you've documented 10+ hook patterns, 5+ format patterns, 5+ CTA patterns, and created voice guidelines with a template library." .

oc:kn_97710c33 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before starting the reverse engineering process" ;
    oc:directiveContent "Access to scraping tools (Apify, PhantomBuster) or ability to manually collect social posts; spreadsheet tool for data analysis." .

oc:kn_c6411a6b a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When completing the reverse engineering process" ;
    oc:directiveContent """## Reverse Engineering Checklist
- [ ] Identified 10-20 top creators in niche
- [ ] Collected 500+ posts for analysis
- [ ] Ranked by engagement rate
- [ ] Documented top 10 hook patterns
- [ ] Documented top 5 format patterns
- [ ] Documented top 5 CTA patterns
- [ ] Created voice guidelines (specificity, brevity, emotion)
- [ ] Built template library from patterns
- [ ] Set up tracking for own content performance""" ;
    oc:templateVariables "CTA_patterns",
        "format_patterns",
        "hook_patterns",
        "niche",
        "voice_guidelines" .

oc:kn_e7029319 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before creating any social content strategy" ;
    oc:directiveContent "Never create content from scratch without analyzing what already works in your niche first — always start with proven patterns." ;
    oc:hasRationale "Guessing what works wastes time and resources; data-driven pattern extraction dramatically increases hit rate." ;
    oc:severityLevel "HIGH" .

oc:kn_eb97773a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing hooks, stories, or CTAs" ;
    oc:directiveContent "Prioritize specificity over vagueness: use exact numbers, concrete timeframes, and named outcomes in all content." ;
    oc:hasRationale "Specificity builds credibility and triggers curiosity gaps that drive engagement." ;
    oc:severityLevel "MEDIUM" .

_:ref_073460d4ac3efbdf a oc:WorkflowStep ;
    dcterms:description "Identify 10-20 top creators in the niche with high engagement rates and audience overlap" ;
    oc:expectedOutcome "A curated list of 10-20 creators with consistent posting and high engagement" ;
    oc:stepId "niche-id" .

_:ref_23784d4e5b9b34b6 a oc:WorkflowStep ;
    dcterms:description "Quantitatively rank by engagement and identify top 10%; qualitatively extract hook types, lengths, emotional triggers, formats, topics" ;
    oc:expectedOutcome "Clear ranking of top performers and documented answers to key pattern questions" ;
    oc:stepDependsOn _:ref_ca105f28c29d6c36 ;
    oc:stepId "analyze" .

_:ref_34716191a7355f1a a oc:WorkflowStep ;
    dcterms:description "Apply direct response voice principles: specificity, brevity (one idea per sentence), emotion-first writing, and 'smart friend' tone" ;
    oc:expectedOutcome "Voice guidelines that make proven patterns feel authentic and original" ;
    oc:stepDependsOn _:ref_e08cb8dbab096437 ;
    oc:stepId "layer-voice" .

_:ref_ca105f28c29d6c36 a oc:WorkflowStep ;
    dcterms:description "Collect 500-1000+ posts from identified creators with full metadata (text, metrics, format, timing, hooks, CTAs)" ;
    oc:expectedOutcome "A dataset of 500+ posts in a structured spreadsheet with all relevant fields" ;
    oc:stepDependsOn _:ref_073460d4ac3efbdf ;
    oc:stepId "scrape" .

_:ref_e08cb8dbab096437 a oc:WorkflowStep ;
    dcterms:description "Codify repeatable patterns: hook templates, format structures, and CTA types from top-performing content" ;
    oc:expectedOutcome "A documented playbook with hook patterns, format patterns, and CTA patterns" ;
    oc:stepDependsOn _:ref_23784d4e5b9b34b6 ;
    oc:stepId "playbook" .

