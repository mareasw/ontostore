@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_marketing_psychology a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "marketing-psychology" ;
    skos:broader "Psychological principle reference framework" ;
    prov:wasDerivedFrom "../.agents/skills/coreyhaines31/marketingskills/marketing-psychology" ;
    oc:contentHash "46aebbc8154ba56e5e2c71f48e7fe17a337761d3f77486ed21204786e84edc0a" ;
    oc:dependsOnSkill oc:skill_ontoskills_product_marketing_context ;
    oc:differentia "organizes behavioral science and cognitive bias models into marketing-application categories with specific actionable guidance for each" ;
    oc:extends oc:skill_ontoskills_copywriting,
        oc:skill_ontoskills_page_cro,
        oc:skill_ontoskills_popup_cro ;
    oc:handlesFailure oc:FileNotFound ;
    oc:hasArgumentHint "marketing challenge or psychological principle name (e.g., 'scarcity', 'anchoring', 'low conversions')" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to apply psychological principles, mental models, or behavioral science to marketing. Also use when the user mentions 'psychology,' 'mental models,' 'cognitive bias,' 'persuasion,' 'behavioral science,' 'why people buy,' 'decision-making,' 'consumer behavior,' 'anchoring,' 'social proof,' 'scarcity,' 'loss aversion,' 'framing,' or 'nudge.' Use this whenever someone wants to understand or leverage how people think and make decisions in a marketing context." ;
    oc:hasName "marketing-psychology" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "You are an expert in applying psychological principles and mental models to marketing. Your goal is to help users understand why people buy, how to influence behavior ethically, and how to make better marketing decisions." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "When facing a marketing challenge, consider:" ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 8 ;
                            oc:tableCaption "When facing a marketing challenge, consider" ;
                            oc:tableMarkdown """| Challenge | Relevant Models |
|-----------|-----------------|
| Low conversions | Hick's Law, Activation Energy, BJ Fogg, Friction |
| Price objections | Anchoring, Framing, Mental Accounting, Loss Aversion |
| Building trust | Authority, Social Proof, Reciprocity, Pratfall Effect |
| Increasing urgency | Scarcity, Loss Aversion, Zeigarnik Effect |
| Retention/churn | Endowment Effect, Switching Costs, Status-Quo Bias |
| Growth stalling | Theory of Constraints, Local vs Global Optima, Compounding |
| Decision paralysis | Paradox of Choice, Default Effect, Nudge Theory |
| Onboarding | Goal-Gradient, IKEA Effect, Commitment & Consistency |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 81 ;
                    oc:sectionTitle "Quick Reference" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "These models explain how customers think, decide, and behave." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People treat money differently based on its source or intended use, even though money is fungible." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Frame costs in favorable mental accounts. \"$3/day\" feels different than \"$90/month\" even though it's the same." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 38 ;
                            oc:sectionTitle "Mental Accounting" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Competent people become more likable when they show a small flaw. Perfection is less relatable." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Admitting a weakness (\"We're not the cheapest, but...\") can increase trust and differentiation." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 36 ;
                            oc:sectionTitle "Pratfall Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Once you know something, you can't imagine not knowing it. Experts struggle to explain simply." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Your product seems obvious to you but confusing to newcomers. Test copy with people unfamiliar with your space." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 37 ;
                            oc:sectionTitle "Curse of Knowledge" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: \"You're 80% done\" creates pull to finish. Incomplete profiles, abandoned carts, and cliffhangers leverage this." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Unfinished tasks occupy the mind more than completed ones. Open loops create tension." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 35 ;
                            oc:sectionTitle "Zeigarnik Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Emphasize immediate benefits (\"Start saving time today\") over future ones (\"You'll see ROI in 6 months\")." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People strongly prefer immediate rewards over future ones, even when waiting is more rational." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 29 ;
                            oc:sectionTitle "Hyperbolic Discounting / Present Bias" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People attribute others' behavior to character, not circumstances. \"They didn't buy because they're not serious\" vs. \"The checkout was confusing.\"" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: When customers don't convert, examine your process before blaming them. The problem is usually situational, not personal." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 19 ;
                            oc:sectionTitle "Fundamental Attribution Error" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Let customers customize, configure, or build something. Their investment increases perceived value and commitment." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People value things more when they've put effort into creating them." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 27 ;
                            oc:sectionTitle "IKEA Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Reduce friction to switch. Make the transition feel safe and easy. \"Import your data in one click.\"" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People prefer the current state of affairs. Change requires effort and feels risky." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 30 ;
                            oc:sectionTitle "Status-Quo Bias" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Proven marketing principles (clear value props, social proof) outlast trendy tactics. Don't abandon fundamentals for fads." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "The longer something has survived, the longer it's likely to continue. Old ideas often outlast new ones." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 23 ;
                            oc:sectionTitle "The Lindy Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Show progress bars, completion percentages, and \"almost there\" messaging to drive completion." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People accelerate effort as they approach a goal. Progress visualization motivates action." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 33 ;
                            oc:sectionTitle "Goal-Gradient Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Understand what your audience already believes and align messaging accordingly. Fighting beliefs head-on rarely works." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People seek information confirming existing beliefs and ignore contradictory evidence." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 22 ;
                            oc:sectionTitle "Confirmation Bias" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Show customer counts, testimonials, logos, reviews, and \"trending\" indicators. Numbers create confidence." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People follow what others are doing. Popularity signals quality and safety." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 40 ;
                            oc:sectionTitle "Bandwagon Effect / Social Proof" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People judge likelihood by how easily examples come to mind. Recent or vivid events seem more common." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Case studies and testimonials make success feel more achievable. Make positive outcomes easy to imagine." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 21 ;
                            oc:sectionTitle "Availability Heuristic" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Design memorable peaks (surprise upgrades, delightful moments) and strong endings (thank you pages, follow-up emails)." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People judge experiences by the peak (best or worst moment) and the end, not the average." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 34 ;
                            oc:sectionTitle "Peak-End Rule" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Limit options. Three pricing tiers beat seven. Recommend a single \"best for most\" option." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Too many options overwhelm and paralyze. Fewer choices often lead to more decisions." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 32 ;
                            oc:sectionTitle "Paradox of Choice" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People value things more once they own them." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Free trials, samples, and freemium models let customers \"own\" the product, making them reluctant to give it up." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 26 ;
                            oc:sectionTitle "Endowment Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Consistent brand presence builds preference over time. Repetition across channels creates comfort and trust." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People prefer things they've seen before. Familiarity breeds liking." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 20 ;
                            oc:sectionTitle "Mere Exposure Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People want things because others want them. Desire is socially contagious." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Show that desirable people want your product. Waitlists, exclusivity, and social proof trigger mimetic desire." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 24 ;
                            oc:sectionTitle "Mimetic Desire" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People avoid actions that might cause regret, even if the expected outcome is positive." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Address regret directly. Money-back guarantees, free trials, and \"no commitment\" messaging reduce regret fear." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 39 ;
                            oc:sectionTitle "Regret Aversion" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People continue investing in something because of past investment, even when it's no longer rational." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Know when to kill underperforming campaigns. Past spend shouldn't justify future spend if results aren't there." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 25 ;
                            oc:sectionTitle "Sunk Cost Fallacy" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People tend to accept pre-selected options. Defaults are powerful." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Pre-select the plan you want customers to choose. Opt-out beats opt-in for subscriptions (ethically applied)." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 31 ;
                            oc:sectionTitle "Default Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Free tiers, free trials, and free shipping have disproportionate appeal. The jump from $1 to $0 is bigger than $2 to $1." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Free isn't just a low price—it's psychologically different. \"Free\" triggers irrational preference." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 28 ;
                            oc:sectionTitle "Zero-Price Effect" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 18 ;
                    oc:sectionTitle "Understanding Buyers & Human Psychology" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**page-cro**: Apply psychology to page optimization" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**pricing-page optimization**: See page-cro for pricing psychology" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**ab-test-setup**: Test psychological hypotheses" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**popup-cro**: Use triggers and psychology in popups" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**copywriting**: Write copy using psychological principles" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 83 ;
                    oc:sectionTitle "Related Skills" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "These models help you ethically influence customer decisions." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "The first number people see heavily influences subsequent judgments." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Show the higher price first (original price, competitor price, enterprise tier) to anchor expectations." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 51 ;
                            oc:sectionTitle "Anchoring Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Shared identity drives influence. \"One of us\" is powerful." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Position your brand as part of the customer's tribe. Use insider language and shared values." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 46 ;
                            oc:sectionTitle "Unity Principle" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Limited-time offers, low-stock warnings, and exclusive access create urgency. Only use when genuine." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Limited availability increases perceived value. Scarcity signals desirability." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 47 ;
                            oc:sectionTitle "Scarcity / Urgency Heuristic" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Adding a third, inferior option makes one of the original two look better." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: A \"decoy\" pricing tier that's clearly worse value makes your preferred tier look like the obvious choice." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 52 ;
                            oc:sectionTitle "Decoy Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Start with a small request, then escalate. Compliance with small requests leads to compliance with larger ones." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Free trial → paid plan → annual plan → enterprise. Each step builds on the last." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 48 ;
                            oc:sectionTitle "Foot-in-the-Door Technique" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: \"90% success rate\" vs. \"10% failure rate\" are identical but feel different. Frame positively." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "How something is presented changes how it's perceived. Same facts, different frames." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 53 ;
                            oc:sectionTitle "Framing Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Free content, free tools, and generous free tiers create reciprocal obligation. Give value before asking for anything." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People feel obligated to return favors. Give first, and people want to give back." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 42 ;
                            oc:sectionTitle "Reciprocity Principle" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Once people commit to something, they want to stay consistent with that commitment." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Get small commitments first (email signup, free trial). People who've taken one step are more likely to take the next." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 43 ;
                            oc:sectionTitle "Commitment & Consistency" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Show the \"before\" state clearly. The contrast with your \"after\" makes improvements vivid." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Things seem different depending on what they're compared to." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 54 ;
                            oc:sectionTitle "Contrast Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Start with an unreasonably large request, then retreat to what you actually want. The contrast makes the second request seem reasonable." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Show enterprise pricing first, then reveal the affordable starter plan. The contrast makes it feel like a deal." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 49 ;
                            oc:sectionTitle "Door-in-the-Face Technique" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Losses feel roughly twice as painful as equivalent gains feel good. People will work harder to avoid losing than to gain." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Frame in terms of what they'll lose by not acting. \"Don't miss out\" beats \"You could gain.\"" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 50 ;
                            oc:sectionTitle "Loss Aversion / Prospect Theory" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Use relatable spokespeople, founder stories, and community language. \"Built by marketers for marketers\" signals similarity." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People say yes to those they like and those similar to themselves." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 45 ;
                            oc:sectionTitle "Liking / Similarity Bias" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People defer to experts and authority figures. Credentials and expertise create trust." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Feature expert endorsements, certifications, \"featured in\" logos, and thought leadership content." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 44 ;
                            oc:sectionTitle "Authority Bias" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 41 ;
                    oc:sectionTitle "Influencing Behavior & Persuasion" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "These models explain how marketing compounds and scales." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Don't abandon working channels for shiny new ones, but allocate some budget to experiments." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Balance trying new things (exploration) with optimizing what works (exploitation)." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 78 ;
                            oc:sectionTitle "Exploration vs. Exploitation" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Build virtuous cycles: more users → more content → better SEO → more users. Identify and strengthen positive loops." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Output becomes input, creating cycles. Positive loops accelerate growth; negative loops create decline." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 73 ;
                            oc:sectionTitle "Feedback Loops" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Focusing on successes while ignoring failures that aren't visible." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Study failed campaigns, not just successful ones. The viral hit you're copying had 99 failures you didn't see." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 80 ;
                            oc:sectionTitle "Survivorship Bias" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "A product becomes more valuable as more people use it." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Design features that improve with more users: shared workspaces, integrations, marketplaces, communities." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 75 ;
                            oc:sectionTitle "Network Effects" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Small, consistent gains accumulate into large results over time. Early gains matter most." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Consistent content, SEO, and brand building compound. Start early; benefits accumulate exponentially." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 74 ;
                            oc:sectionTitle "Compounding" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Content → traffic → leads → customers → case studies → more content. Each element powers the next." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Sustained effort creates momentum that eventually maintains itself. Hard to start, easy to maintain." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 76 ;
                            oc:sectionTitle "Flywheel Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "The threshold after which growth becomes self-sustaining." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Focus resources on reaching critical mass in one segment before expanding. Depth before breadth." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 79 ;
                            oc:sectionTitle "Critical Mass / Tipping Point" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "The price (time, money, effort, data) of changing to a competitor. High switching costs create retention." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Increase switching costs ethically: integrations, data accumulation, workflow customization, team adoption." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 77 ;
                            oc:sectionTitle "Switching Costs" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 72 ;
                    oc:sectionTitle "Growth & Scaling Models" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "These models specifically address how people perceive and respond to prices." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Round numbers feel premium and are easier to process. $100 signals quality; $99 signals value." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Use round prices for premium products ($500/month), charm prices for value products ($497/month)." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 57 ;
                            oc:sectionTitle "Rounded-Price (Fluency) Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Framing the same price differently changes perception." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: \"$1/day\" feels cheaper than \"$30/month.\" \"Less than your morning coffee\" reframes the expense." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 60 ;
                            oc:sectionTitle "Mental Accounting (Pricing)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Prices ending in 9 seem significantly lower than the next round number. $99 feels much cheaper than $100." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Use .99 or .95 endings for value-focused products. The left digit dominates perception." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 56 ;
                            oc:sectionTitle "Charm Pricing / Left-Digit Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Three tiers where the middle is your target. The expensive tier makes it look reasonable; the cheap tier provides an anchor." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People judge prices relative to options presented. A middle tier seems reasonable between cheap and expensive." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 59 ;
                            oc:sectionTitle "Price Relativity / Good-Better-Best" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "For prices under $100, percentage discounts seem larger (\"20% off\"). For prices over $100, absolute discounts seem larger (\"$50 off\")." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: $80 product: \"20% off\" beats \"$16 off.\" $500 product: \"$100 off\" beats \"20% off.\"" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 58 ;
                            oc:sectionTitle "Rule of 100" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 55 ;
                    oc:sectionTitle "Pricing Psychology" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "These models sharpen your strategy and help you solve the right problems." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Consider not just immediate effects, but the effects of those effects." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: A flash sale boosts revenue (first order) but may train customers to wait for discounts (second order)." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 14 ;
                            oc:sectionTitle "Second-Order Thinking" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Your customer persona is a useful model, but real customers are more complex. Stay in touch with actual users." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Models and data represent reality but aren't reality itself. Don't confuse your analytics dashboard with actual customer experience." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 15 ;
                            oc:sectionTitle "Map ≠ Territory" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Every choice has a cost—what you give up by not choosing alternatives. Consider what you're saying no to." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Time spent on a low-ROI channel is time not spent on high-ROI activities. Always compare against alternatives." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 12 ;
                            oc:sectionTitle "Opportunity Cost" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Find the 20% of channels, customers, or content driving 80% of results. Cut or reduce the rest." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Roughly 80% of results come from 20% of efforts. Identify and focus on the vital few." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 9 ;
                            oc:sectionTitle "Pareto Principle (80/20 Rule)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Every system has one bottleneck limiting throughput. Find and fix that constraint before optimizing elsewhere." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: If your funnel converts well but traffic is low, more conversion optimization won't help. Fix the traffic bottleneck first." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 11 ;
                            oc:sectionTitle "Theory of Constraints" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: List everything that would make your campaign fail—confusing messaging, wrong audience, slow landing page—then systematically prevent each." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Instead of asking \"How do I succeed?\", ask \"What would guarantee failure?\" Then avoid those things." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 7 ;
                            oc:sectionTitle "Inversion" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "People don't buy products—they \"hire\" them to get a job done. Focus on the outcome customers want, not features." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: A drill buyer doesn't want a drill—they want a hole. Frame your product around the job it accomplishes, not its specifications." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Jobs to Be Done" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: If conversions dropped, check the obvious first (broken form, page speed) before assuming complex attribution issues." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "The simplest explanation is usually correct. Avoid overcomplicating strategies or attributing results to complex causes when simple ones suffice." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 8 ;
                            oc:sectionTitle "Occam's Razor" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Don't chase every channel. Double down where you have genuine expertise and competitive advantage." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Know what you're good at and stay within it. Venture outside only with proper learning or expert help." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "Circle of Competence" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Optimizing email subject lines (local) won't help if email isn't the right channel (global). Zoom out before zooming in." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "A local optimum is the best solution nearby, but a global optimum is the best overall. Don't get stuck optimizing the wrong thing." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 10 ;
                            oc:sectionTitle "Local vs. Global Optima" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Think in probabilities, not certainties. Estimate likelihoods and plan for multiple outcomes." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Don't bet everything on one campaign. Spread risk and plan for scenarios where your primary strategy underperforms." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 16 ;
                            oc:sectionTitle "Probabilistic Thinking" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "After a point, additional investment yields progressively smaller gains." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: The 10th blog post won't have the same impact as the first. Know when to diversify rather than double down." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 13 ;
                            oc:sectionTitle "Law of Diminishing Returns" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Put 80% of budget into proven channels, 20% into experimental bets. Avoid moderate-risk, moderate-reward middle." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Combine extreme safety with small high-risk/high-reward bets. Avoid the mediocre middle." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 17 ;
                            oc:sectionTitle "Barbell Strategy" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Don't assume you need content marketing because competitors do. Ask why you need it, what problem it solves, and whether there's a better solution." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Break problems down to basic truths and build solutions from there. Instead of copying competitors, ask \"why\" repeatedly to find root causes. Use the 5 Whys technique to tunnel down to what really matters." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "First Principles" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Foundational Thinking Models" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_ebc2c18d63a94f64 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 82 ;
                    oc:sectionTitle "Task-Specific Questions" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Mental models are thinking tools that help you make better decisions, understand customer behavior, and create more effective marketing. When helping users:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Check for product marketing context first:**
If `.agents/product-marketing-context.md` exists (or `.claude/product-marketing-context.md` in older setups), read it before applying mental models. Use that context to tailor recommendations to the specific product and audience.""" ],
                        _:ref_d17d25a9c0f047b4 ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "How to Use This Skill" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "These models help you design effective marketing systems." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Attention → Interest → Desire → Action. The classic customer journey model." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Structure pages and campaigns to move through each stage. Capture attention before building desire." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 63 ;
                            oc:sectionTitle "AIDA Funnel" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Test incentive structures. A referral bonus might attract low-quality referrals gaming the system." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "When incentives backfire and produce the opposite of intended results." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 71 ;
                            oc:sectionTitle "The Cobra Effect" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Prospects need roughly 7 touchpoints before converting. One ad rarely converts; sustained presence does." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Build multi-touch campaigns across channels. Retargeting, email sequences, and consistent presence compound." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 64 ;
                            oc:sectionTitle "Rule of 7" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Reduce friction (easy), make it appealing (attractive), show others doing it (social), ask at the right moment (timely)." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Make desired behaviors: Easy, Attractive, Social, Timely." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 67 ;
                            oc:sectionTitle "EAST Framework" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Behavior requires: Capability, Opportunity, Motivation." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Can they do it (capability)? Is the path clear (opportunity)? Do they want to (motivation)? Address all three." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 68 ;
                            oc:sectionTitle "COM-B Model" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Simplify choices. One clear CTA beats three. Fewer form fields beat more." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Decision time increases with the number and complexity of choices. More options = slower decisions = more abandonment." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 62 ;
                            oc:sectionTitle "Hick's Law" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "One metric that best captures the value you deliver to customers. Focus creates alignment." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Identify your North Star (active users, completed projects, revenue per customer) and align all efforts toward it." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 70 ;
                            oc:sectionTitle "North Star Metric" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "The initial energy required to start something. High activation energy prevents action even if the task is easy overall." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Reduce starting friction. Pre-fill forms, offer templates, show quick wins. Make the first step trivially easy." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 69 ;
                            oc:sectionTitle "Activation Energy" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: Default selections, strategic ordering, and friction reduction guide behavior without restricting choice." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Small changes in how choices are presented significantly influence decisions." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 65 ;
                            oc:sectionTitle "Nudge Theory / Choice Architecture" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Marketing application**: High motivation but hard to do = won't happen. Easy to do but no prompt = won't happen. Design for all three." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Behavior = Motivation × Ability × Prompt. All three must be present for action." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 66 ;
                            oc:sectionTitle "BJ Fogg Behavior Model" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 61 ;
                    oc:sectionTitle "Design & Delivery Models" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Marketing Psychology & Mental Models" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: marketing-psychology
description: "When the user wants to apply psychological principles, mental models, or behavioral science to marketing. Also use when the user mentions 'psychology,' 'mental models,' 'cognitive bias,' 'persuasion,' 'behavioral science,' 'why people buy,' 'decision-making,' 'consumer behavior,' 'anchoring,' 'social proof,' 'scarcity,' 'loss aversion,' 'framing,' or 'nudge.' Use this whenever someone wants to understand or leverage how people think and make decisions in a marketing context."
metadata:
  version: 1.1.0
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
