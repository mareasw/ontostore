oc:skill_coreyhaines31_marketingskills_marketing_psychology a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "marketing-psychology" ;
    skos:broader "Knowledge framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/marketing-psychology" ;
    oc:contentHash "46aebbc8154ba56e5e2c71f48e7fe17a337761d3f77486ed21204786e84edc0a" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "maps psychological principles, cognitive biases, and behavioral science mental models to specific marketing applications for ethical customer influence" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAlias "behavioral-science",
        "cognitive-bias",
        "consumer-psychology",
        "mental-models",
        "persuasion" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to apply psychological principles, mental models, or behavioral science to marketing. Also use when the user mentions 'psychology,' 'mental models,' 'cognitive bias,' 'persuasion,' 'behavioral science,' 'why people buy,' 'decision-making,' 'consumer behavior,' 'anchoring,' 'social proof,' 'scarcity,' 'loss aversion,' 'framing,' or 'nudge.' Use this whenever someone wants to understand or leverage how people think and make decisions in a marketing context." ;
    oc:hasName "marketing-psychology" ;
    oc:impartsKnowledge oc:kn_29d8be8d,
        oc:kn_3b27940d,
        oc:kn_5560fcaf,
        oc:kn_5c09ff68,
        oc:kn_acbfd9f2,
        oc:kn_b297b796,
        oc:kn_e2bb9472 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:FileExists ;
    oc:resolvesIntent "apply pricing psychology",
        "apply psychological principles to marketing",
        "choose relevant mental models for marketing challenges",
        "improve persuasion in marketing copy and design",
        "influence customer behavior ethically",
        "optimize onboarding with psychological models",
        "reduce churn using behavioral science",
        "understand why people buy" ;
    oc:yieldsState oc:StrategyDefined .

oc:kn_29d8be8d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying Scarcity, Loss Aversion, or Social Proof models" ;
    oc:directiveContent "Only use scarcity, urgency, and persuasion techniques when they reflect genuine constraints — never manufacture fake countdown timers, artificial limits, or deceptive social proof." ;
    oc:hasRationale "Manufactured urgency destroys trust and brand credibility; ethical application of psychology sustains long-term customer relationships and avoids reputational damage." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3b27940d a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When the user asks to test or validate psychological principles experimentally" ;
    oc:directiveContent "When a user's request crosses into A/B test design territory, defer to the ab-test-setup skill for experiment methodology while providing the psychological context (hypotheses, relevant models) as supporting input." ;
    oc:hasRationale "Psychology provides hypotheses; A/B testing provides validation. Each skill handles its domain of expertise, preventing the psychology skill from overstepping into experimental design." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5560fcaf a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When responding to any marketing psychology query" ;
    oc:directiveContent "Use the four-step process: (1) Identify which mental models apply to the situation, (2) Explain the psychology behind the model, (3) Provide specific marketing applications, (4) Suggest ethical implementation — always ground recommendations in the user's specific context." ;
    oc:hasRationale "A structured approach ensures recommendations are relevant, educational, actionable, and ethically sound rather than a scattershot list of techniques." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5c09ff68 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When the user describes a marketing challenge without naming a specific model" ;
    oc:directiveContent "When facing a marketing challenge, use the quick-reference mapping to identify relevant models: low conversions → Hick's Law/Activation Energy/BJ Fogg; price objections → Anchoring/Framing/Loss Aversion; trust → Authority/Social Proof/Reciprocity; urgency → Scarcity/Zeigarnik; churn → Endowment Effect/Switching Costs; decision paralysis → Paradox of Choice/Default Effect." ;
    oc:hasRationale "The quick-reference table provides a diagnostic shortcut from common marketing problems to the most applicable psychological models, reducing cognitive search time." ;
    oc:severityLevel "MEDIUM" .

oc:kn_acbfd9f2 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When providing recommendations based on any mental model" ;
    oc:directiveContent "These mental models represent tendencies and heuristics, not deterministic laws — always recommend testing with real customers and validate assumptions rather than treating models as guaranteed outcomes." ;
    oc:hasRationale "Cognitive biases are probabilistic tendencies that vary by individual, culture, and context; presenting them as guarantees leads to overconfidence and untested strategies." ;
    oc:severityLevel "HIGH" .

oc:kn_b297b796 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before generating any psychology-based marketing recommendations" ;
    oc:directiveContent "Always check for and read product-marketing-context.md (.agents/ or .claude/) before applying mental models, so recommendations are tailored to the specific product and audience." ;
    oc:hasRationale "Generic psychological advice lacks the specificity needed for effective marketing; product context ensures mental models are applied to the right audience, market, and competitive landscape." ;
    oc:severityLevel "HIGH" .

oc:kn_e2bb9472 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When recommending any psychological technique or strategy" ;
    oc:directiveContent "Do not apply mental models in isolation — consider second-order effects (e.g., flash sales boost short-term revenue but train customers to wait for discounts) and interaction between models (e.g., Paradox of Choice + Hick's Law compound friction)." ;
    oc:hasRationale "Mental models interact in complex ways; ignoring second-order consequences leads to strategies that solve one problem while creating worse ones downstream." ;
    oc:severityLevel "HIGH" .

