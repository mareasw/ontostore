@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_customer_research a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "customer-research" ;
    skos:broader "Research methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/customer-research" ;
    oc:contentHash "e0476bfadb8627f586ecfbad9f7505b50cc37b992c9541c19ec9c44f347ba864" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "that extracts customer insights from existing research assets and online community sources using structured extraction frameworks and confidence-scored synthesis" ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput,
        oc:SourceUnavailable ;
    oc:hasAllowedTool "Glob",
        "Grep",
        "Read",
        "WebFetch",
        "WebSearch" ;
    oc:hasArgumentHint "goal or research asset type (e.g., 'analyze transcripts', 'mine Reddit for competitor insights', 'build personas')" ;
    oc:hasCategory "research" ;
    oc:hasDescription "When the user wants to conduct, analyze, or synthesize customer research. Use when the user mentions \"customer research,\" \"ICP research,\" \"talk to customers,\" \"analyze transcripts,\" \"customer interviews,\" \"survey analysis,\" \"support ticket analysis,\" \"voice of customer,\" \"VOC,\" \"build personas,\" \"customer personas,\" \"jobs to be done,\" \"JTBD,\" \"what do customers say,\" \"what are customers struggling with,\" \"Reddit mining,\" \"G2 reviews,\" \"review mining,\" \"digital watering holes,\" \"community research,\" \"forum research,\" \"competitor reviews,\" \"customer sentiment,\" or \"find out why customers churn/convert/buy.\" Use for both analyzing existing research assets AND gathering new research from online sources. For writing copy informed by research, see copywriting. For acting on research to improve pages, see page-cro." ;
    oc:hasName "customer-research" ;
    oc:impartsKnowledge oc:kn_3a2ef3f8,
        oc:kn_4ddbc27e,
        oc:kn_52ac5c65,
        oc:kn_5dc3a9c0,
        oc:kn_6c395b34,
        oc:kn_8756f303,
        oc:kn_8e45155b,
        oc:kn_c6381798,
        oc:kn_de873745,
        oc:kn_e05ca4a8 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "analyze customer research data",
        "analyze support tickets for customer insights",
        "build research-backed customer personas",
        "conduct customer interviews analysis",
        "conduct digital watering hole research",
        "create VOC quote banks",
        "extract jobs to be done from customer data",
        "mine competitor reviews for intelligence",
        "mine online communities for customer intelligence",
        "synthesize voice of customer insights" ;
    oc:yieldsState oc:CustomerInsightsExtracted,
        oc:PersonasGenerated,
        oc:ResearchSynthesized .

oc:kn_3a2ef3f8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating personas or making research-based claims" ;
    oc:directiveContent "Do not build personas or draw messaging conclusions from fewer than 5 independent data points per segment." ;
    oc:hasRationale "Below this threshold, findings are anecdotal and risk leading to decisions based on outliers rather than patterns." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4ddbc27e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building customer personas" ;
    oc:directiveContent "Never invent persona details — if you don't have data on something, leave it blank rather than filling it in with assumptions." ;
    oc:hasRationale "Fabricated persona details create false confidence and can mislead messaging, product, and positioning decisions." ;
    oc:severityLevel "HIGH" .

oc:kn_52ac5c65 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing and presenting research findings" ;
    oc:directiveContent "Label every insight with a confidence level (High/Medium/Low) based on source count, spontaneity, and cross-segment consistency before presenting it." ;
    oc:hasRationale "Confidence labels prevent stakeholders from treating anecdotal findings as established facts and guide where more validation is needed." ;
    oc:severityLevel "HIGH" .

oc:kn_5dc3a9c0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating research source recency" ;
    oc:directiveContent "Weight sources from the last 12 months most heavily; use 12-24 month data with caution; treat 2+ year old data as baseline context only." ;
    oc:hasRationale "Markets, products, and buyer expectations shift rapidly — stale data can lead to messaging that addresses yesterday's problems." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6c395b34 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mining G2, Capterra, app store, or similar review platforms" ;
    oc:directiveContent "For review mining, read 3-star reviews first (most honest), then 1-star (failure modes), then 5-star (proof points), then 4-star (buried 'I wish' feedback). For competitors, focus on their 4-star reviews for hidden complaints." ;
    oc:hasRationale "This reading order maximizes signal extraction by prioritizing the most balanced and insightful reviews before extreme-positive or extreme-negative bias." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8756f303 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When drawing conclusions from online and community research sources" ;
    oc:directiveContent "Account for source bias: online reviewers skew toward power users and strong opinions; support tickets skew toward problems not value; Reddit skews technical and skeptical vs. mainstream buyers." ;
    oc:hasRationale "Unfiltered sources have systematic biases that, if unaccounted for, lead to conclusions about 'all customers' that actually represent a vocal minority." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8e45155b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When analyzing churn data, win/loss interviews, or support tickets" ;
    oc:directiveContent "Segment churn reasons before analyzing — never average across different churn causes. Separate bugs from confusion from missing features from expectation mismatches." ;
    oc:hasRationale "Averaging across different failure reasons obscures the specific, actionable patterns that drive improvement." ;
    oc:severityLevel "HIGH" .

oc:kn_c6381798 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting language and vocabulary from any research source" ;
    oc:directiveContent "Extract exact customer verbatim quotes rather than paraphrases — 'We were drowning in spreadsheets' is more valuable than 'manual process inefficiency'." ;
    oc:hasRationale "Customer language is gold for copy; paraphrasing loses the emotional resonance and specificity that makes VOC insights actionable for messaging." ;
    oc:severityLevel "HIGH" .

oc:kn_de873745 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any customer research engagement" ;
    oc:directiveContent "Always check for product-marketing-context.md before asking questions — use existing context to skip questions already answered." ;
    oc:hasRationale "Avoids redundant questions and grounds research in known product/market context, speeding up the engagement." ;
    oc:severityLevel "HIGH" .

oc:kn_e05ca4a8 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "At the start of every customer research engagement" ;
    oc:directiveContent "Establish which research mode applies first: Mode 1 (analyze existing assets) or Mode 2 (gather from online sources). Most engagements combine both." ;
    oc:hasRationale "Clarifying the mode upfront ensures the right tools, frameworks, and expectations are set before investing effort in the wrong direction." ;
    oc:severityLevel "MEDIUM" .

