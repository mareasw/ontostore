oc:skill_coreyhaines31_marketingskills_customer_research_source_guides a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "source-guides" ;
    skos:broader "Research playbook" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/customer-research" ;
    oc:contentHash "7dcef3740d5d30d65d07a4099a8907d4d9ee0976dc585fb1a0249c89e542e0c4" ;
    oc:differentia "that provides source-specific playbooks for gathering customer intelligence from online communities and review platforms" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_customer_research ;
    oc:handlesFailure oc:InsufficientDataForConfidence,
        oc:NoRelevantSourcesFound ;
    oc:hasArgumentHint "source-platform (e.g., 'reddit', 'g2', 'linkedin', 'youtube', 'twitter', 'app-stores')" ;
    oc:hasCategory "research" ;
    oc:impartsKnowledge oc:kn_3a6da47b,
        oc:kn_3de62b8f,
        oc:kn_51179001,
        oc:kn_580420f0,
        oc:kn_654ece70,
        oc:kn_7fb4ee2a,
        oc:kn_dbf9de50 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:ICPDefined ;
    oc:resolvesIntent "conduct B2C consumer app research across app stores and social media",
        "discover customer pain points from online communities",
        "extract customer language and buying signals from social platforms",
        "mine competitor reviews on G2 and review sites",
        "organize and confidence-score customer research from multiple sources",
        "research customer opinions on Reddit" ;
    oc:yieldsState oc:CompetitorIntelligenceCollected,
        oc:CustomerInsightsGathered,
        oc:VoiceOfCustomerDocumented .

oc:kn_3a6da47b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When analyzing competitor reviews on G2, Capterra, or similar platforms" ;
    oc:directiveContent "Mine competitor 4-star reviews specifically — these customers like the product enough to stay but still have complaints, revealing your best entry points for positioning." ;
    oc:hasRationale "4-star reviews contain 'the only thing I wish...' buried in praise, which directly maps to competitive gaps you can exploit in messaging and product development." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3de62b8f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing and presenting customer research insights" ;
    oc:directiveContent "Always assign confidence labels (HIGH/MEDIUM/LOW) to insights based on source weighting and cross-source triangulation, and lead with confidence when presenting findings." ;
    oc:hasRationale "Not all sources carry equal signal strength. Customer interviews have very high signal but small samples; surveys have medium signal but are primed by question framing. Confidence labels prevent over-investment in weak signals." ;
    oc:severityLevel "MEDIUM" .

oc:kn_51179001 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When identifying which online communities and subreddits to research" ;
    oc:directiveContent "Search for where your ICP spends time, not where your product is discussed — look for problem-space communities and job-title-specific conversations rather than product-category forums." ;
    oc:hasRationale "Product-specific communities attract existing users and competitors, not prospects. Problem-space communities reveal how people describe needs before they know your category exists — this is the language that converts." ;
    oc:severityLevel "MEDIUM" .

oc:kn_580420f0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When conducting review mining on any platform (G2, App Store, Capterra, Amazon)" ;
    oc:directiveContent "Always read 3-star reviews first when mining G2 or app store reviews — they are the most honest, containing both appreciation and frustration without extreme bias." ;
    oc:hasRationale "1-star reviews are often about singular bad experiences, 5-star reviews are often enthusiasts — 3-star reviewers are balanced and reveal genuine tradeoffs that inform positioning." ;
    oc:severityLevel "HIGH" .

oc:kn_654ece70 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When organizing research from any online source" ;
    oc:directiveContent "Use a consistent tagging system (#pain, #trigger, #outcome, #language, #alternative, #objection, #competitor) across all research sources and maintain a running document with columns: Source | Date | Quote | Tags | Notes." ;
    oc:hasRationale "Without a unified tagging system, cross-source patterns remain invisible. After 20-30 tagged entries, recurring themes emerge with high confidence." ;
    oc:severityLevel "HIGH" .

oc:kn_7fb4ee2a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating recency of customer research data from any source" ;
    oc:directiveContent "Treat data older than 12 months as primary, 12-24 months with caution, and 2+ years as baseline context only. When a theme appears consistently across old and new data, that signals durable insight." ;
    oc:hasRationale "Products and markets shift rapidly. Old complaints may already be resolved; old praise may no longer differentiate. Durable themes across time windows are the most reliable signals." ;
    oc:severityLevel "MEDIUM" .

oc:kn_dbf9de50 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drawing conclusions from customer research" ;
    oc:directiveContent "Never rely on a single source type for customer research conclusions — always triangulate across at least 2-3 different source types before treating an insight as actionable." ;
    oc:hasRationale "Every source has inherent bias: Reddit skews technical and skeptical, G2 skews toward strong opinions, surveys are primed by framing. Cross-source triangulation filters out source-specific bias." ;
    oc:severityLevel "HIGH" .

