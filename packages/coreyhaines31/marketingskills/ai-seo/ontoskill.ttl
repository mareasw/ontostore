                                    oc:itemOrder 5 ;
                                    oc:itemText "PDF-only content (harder for AI to parse)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Underperformers for AI citation:**" ] ;
