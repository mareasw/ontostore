        oc:kn_d8fb4e98,
        oc:kn_f3cdaff5,
        oc:kn_f5e17c09 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady,
        oc:NetworkAvailable ;
    oc:resolvesIntent "appear in Google AI Overviews",
        "audit AI visibility across platforms",
        "configure robots.txt for AI bot access",
        "create AI-extractable content",
        "get cited by LLMs and AI assistants",
        "improve AI answer engine optimization",
        "monitor AI citation presence",
        "optimize content for AI search engines" ;
    oc:yieldsState oc:AIBotAccessConfigured,
        oc:AIVisibilityAudited,
        oc:ContentOptimizedForAI .

oc:kn_37f55e09 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When developing any AI SEO strategy" ;
    oc:directiveContent "Apply the three-pillar framework: Structure (make it extractable), Authority (make it citable), Presence (be where AI looks). Low-ranking sites benefit up to 115% visibility increase with proper citation formatting." ;
    oc:hasRationale "These three pillars address the full citation pipeline — AI must be able to read, trust, and find your content. The Princeton GEO research validates that combining fluency + statistics yields maximum boost" ;
    oc:severityLevel "CRITICAL" .

oc:kn_55c77c64 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After implementing AI SEO recommendations" ;
    oc:directiveContent "After AI SEO optimization, verify: AI bots are allowed in robots.txt, schema markup is implemented (FAQPage, Article, Organization minimum), content includes cited statistics, heading structure matches query patterns, and key passages are self-contained at 40-60 words." ;
    oc:hasRationale "These checks confirm the three pillars are properly addressed before publishing, catching common omissions that would undermine AI citation potential" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6e65ee1f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "At the start of every AI SEO engagement" ;
    oc:directiveContent "Before starting AI SEO work, check for product-marketing-context.md at .agents/product-marketing-context.md or .claude/product-marketing-context.md. Gather AI visibility data, content type information, goals, and competitive landscape before making recommendations." ;
    oc:hasRationale "Context from the product marketing document reduces redundant questions and ensures recommendations are grounded in the actual product and competitive positioning" ;
    oc:severityLevel "MEDIUM" .

oc:kn_90c70dd1 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When configuring robots.txt or advising on AI crawler access" ;
    oc:directiveContent "Blocking AI bots (GPTBot, PerplexityBot, ClaudeBot, Google-Extended, Bingbot) in robots.txt prevents those platforms from citing your content. The tradeoff must be explicitly evaluated: blocking prevents AI training but also prevents citation." ;
    oc:hasRationale "Businesses blocking AI bots lose AI search visibility entirely. A middle ground is blocking training-only crawlers (CCBot/Common Crawl) while allowing search-capable bots" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a6477dd8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating or optimizing content for AI citation" ;
    oc:directiveContent "Include specific statistics with named sources (+37-40% citation boost), expert quotes with attribution (+30% boost), and maintain freshness signals with 'last updated' dates. Content with proper schema markup shows 30-40% higher AI visibility." ;
    oc:hasRationale "The Princeton GEO research (KDD 2024) quantified these boosts across Perplexity.ai. These signals address the Authority pillar and are the strongest individual optimization levers" ;
    oc:severityLevel "HIGH" .

oc:kn_bccf661d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or editing content blocks intended for AI citation" ;
    oc:directiveContent "Keep key answer passages to 40-60 words for optimal AI snippet extraction. Every paragraph should convey one clear idea, and every key claim should work as a standalone statement." ;
    oc:hasRationale "AI systems extract passages, not pages. Self-contained, concise answer blocks are more likely to be pulled as citations than buried or verbose content" ;
    oc:severityLevel "HIGH" .

oc:kn_c372070a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning AI visibility strategy and content distribution" ;
    oc:directiveContent "Prioritize third-party presence (Wikipedia, Reddit, review sites, industry publications) because brands are 6.5x more likely to be cited via third-party sources than their own domains. Wikipedia alone accounts for 7.8% of ChatGPT citations." ;
    oc:hasRationale "AI systems aggregate information from multiple authoritative sources; third-party mentions carry more trust weight than self-published content" ;
    oc:severityLevel "HIGH" .

oc:kn_d8fb4e98 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When setting AI SEO goals and expectations" ;
    oc:directiveContent "AI Overviews reduce clicks to websites by up to 58% and appear in ~45% of Google searches. Content appearing in AI Overviews may get cited but receive less traffic than traditional organic results." ;
    oc:hasRationale "Users should understand the zero-click nature of AI search — the value is brand visibility and authority, not necessarily direct click-through" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f3cdaff5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing any content for AI search engines" ;
    oc:directiveContent "Never keyword-stuff content intended for AI citation. The Princeton GEO study shows keyword stuffing actively reduces AI visibility by 10%, unlike traditional SEO where it's merely ineffective." ;
    oc:hasRationale "AI systems evaluate semantic quality and coherence; keyword stuffing signals low-quality content that AI assistants avoid citing" ;
    oc:severityLevel "HIGH" .

oc:kn_f5e17c09 a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user's request is better served by traditional SEO or schema markup skills" ;
    oc:directiveContent "If a request is a traditional SEO audit (crawlability, technical foundations, on-page optimization), defer to the seo-audit skill. If the request involves structured data implementation, defer to schema-markup. AI SEO builds on these foundations." ;
    oc:hasRationale "AI SEO is additive to traditional SEO, not a replacement. Good traditional SEO is the foundation; AI SEO adds structure and authority optimization on top" ;
    oc:severityLevel "MEDIUM" .

