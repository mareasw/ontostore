oc:req_9f363e04 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Familiarity with AI search platforms (ChatGPT, Perplexity, Google AI Overviews, Claude, Gemini, Copilot)" .

