    oc:requiresState oc:ContentTopicDefined ;
    oc:resolvesIntent "create comparison tables for search snippets",
        "format answer engine optimization (AEO) content blocks",
        "format generative engine optimization (GEO) content blocks",
        "optimize content for AI citation by ChatGPT/Claude/Perplexity",
