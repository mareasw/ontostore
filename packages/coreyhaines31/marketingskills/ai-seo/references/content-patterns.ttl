                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Include question words: what, how, why, when, where, who, which" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Use natural question phrasing (\"How do I...\" not \"How does one...\")" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Match \"People Also Ask\" queries from search results" ],
                                        [ a oc:BulletItem ;
