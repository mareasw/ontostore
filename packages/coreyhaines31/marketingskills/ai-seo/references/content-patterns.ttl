oc:skill_coreyhaines31_marketingskills_ai_seo_content_patterns a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "content-patterns" ;
    skos:broader "Content template library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/ai-seo" ;
    oc:contentHash "7f32aab75574788fbee572dac9fe177e63b21fce672ef863246bd4778fc29a3b" ;
    oc:differentia "provides reusable AEO and GEO content block patterns optimized for answer engine extraction and AI citation" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_ai_seo ;
    oc:handlesFailure oc:InvalidQueryType ;
    oc:hasArgumentHint "content topic or query type (e.g., 'definition', 'how-to', 'comparison', 'FAQ', 'listicle')" ;
    oc:hasCategory "marketing" ;
    oc:hasRequirement oc:req_4687a805,
        oc:req_e11fa604 ;
    oc:impartsKnowledge oc:kn_108c4130,
        oc:kn_33cf740a,
        oc:kn_7b45d5e2,
        oc:kn_8685e018,
        oc:kn_b86e10ef,
        oc:kn_f000c3b4 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:QueryIntentClassified,
        oc:TopicIdentified ;
    oc:resolvesIntent "apply domain-specific GEO tactics for technology, health, financial, legal, and business content",
        "create self-contained quotable answers for AI extraction",
        "format answer engine content blocks",
        "optimize content for AI citation by ChatGPT, Claude, Perplexity, and Gemini",
        "optimize content for voice search results",
        "structure content for featured snippets" ;
    oc:yieldsState oc:AEOStructureReady,
        oc:ContentPatternApplied .

oc:kn_108c4130 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating GEO content for a specific industry or knowledge domain" ;
    oc:directiveContent "Adapt content authority signals to the domain: technology needs version numbers and docs; health needs peer-reviewed citations and credentials; finance needs regulatory references; legal needs statutes and jurisdiction; business needs case studies with measurable results." ;
    oc:hasRationale "Different AI citation models weight different trust signals based on domain; generic authority signals underperform domain-specific ones" ;
    oc:severityLevel "MEDIUM" .

oc:kn_33cf740a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing authoritative or persuasive content intended for AI citation" ;
    oc:directiveContent "Structure claims using the Evidence Sandwich pattern: open with the claim, list 2-3 sourced data points, then close with an actionable insight connecting the evidence." ;
    oc:hasRationale "This three-part structure maximizes both AI extractability and reader credibility simultaneously" .

oc:kn_7b45d5e2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which content pattern to apply for any given piece of content" ;
    oc:directiveContent "Each content block pattern must be self-contained and directly answer a specific query type (definition, how-to, comparison, evaluation, FAQ, listicle). Match the block pattern to the searcher's intent." ;
    oc:hasRationale "Answer engines and AI systems extract content at the block level; mismatched patterns reduce citation likelihood and snippet capture" ;
    oc:severityLevel "HIGH" .

oc:kn_8685e018 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating FAQ content blocks for topic pages" ;
    oc:directiveContent "Phrase FAQ questions exactly as users search them, using natural phrasing and matching 'People Also Ask' queries. Keep answers between 50-100 words." ;
    oc:hasRationale "Exact-match question phrasing increases FAQ schema triggering and featured snippet capture for conversational queries" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b86e10ef a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any AEO-patterned content block" ;
    oc:directiveContent "Never use vague or generic answers in content blocks. Every answer must lead with a direct, concise response (40-60 words for paragraph snippets, under 30 words for voice) before expanding with context." ;
    oc:hasRationale "Answer engines extract the first sentence as the featured answer; burying the answer in context causes the content to lose snippet eligibility" ;
    oc:severityLevel "CRITICAL" .

oc:kn_f000c3b4 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing any GEO-optimized content block, especially Statistic Citation and Evidence Sandwich blocks" ;
    oc:directiveContent "Always include specific statistics with named sources and timeframes. Statistics increase AI citation rates by 15-30% when properly attributed." ;
    oc:hasRationale "AI models weight statistically-backed claims more heavily and unsourced statistics reduce trustworthiness signals" ;
    oc:severityLevel "HIGH" .

oc:req_4687a805 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Familiarity with schema markup and structured data principles" .

oc:req_e11fa604 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of AEO (Answer Engine Optimization) and GEO (Generative Engine Optimization) concepts" .

