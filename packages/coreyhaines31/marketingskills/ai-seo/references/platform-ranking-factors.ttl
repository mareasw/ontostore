oc:skill_coreyhaines31_marketingskills_ai_seo_platform_ranking_factors a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "platform-ranking-factors" ;
    skos:broader "Reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/ai-seo" ;
    oc:contentHash "4004b3d9d562f98273a0048c48af6a46040ed800b1a1ccb958b299217860a623" ;
    oc:differentia "documents how each AI search platform (Google AI Overviews, ChatGPT, Perplexity, Microsoft Copilot, Claude) selects and ranks sources for citation, enabling platform-specific optimization strategies" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_ai_seo ;
    oc:handlesFailure oc:BotBlockedByRobotsTxt,
        oc:ContentNotExtractable,
        oc:PlatformNotIndexed ;
    oc:hasArgumentHint "platform name (e.g., 'ChatGPT', 'Perplexity', 'Google AI Overviews', 'Copilot', 'Claude') or 'all' for cross-platform comparison" ;
    oc:hasCategory "marketing" ;
    oc:hasRequirement oc:req_ebc7d864 ;
    oc:impartsKnowledge oc:kn_3f4b64db,
        oc:kn_4c398d62,
        oc:kn_5837ac8e,
        oc:kn_67b56bc3,
        oc:kn_6d1675b4,
        oc:kn_8de781f1,
        oc:kn_a186812e,
        oc:kn_b08059f6,
        oc:kn_c89abed4 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ContentPublished,
        oc:SiteLive ;
    oc:resolvesIntent "compare ranking factors across Google AI Overviews, ChatGPT, Perplexity, Copilot, and Claude",
        "configure robots.txt for AI bot access",
        "determine which AI platform to prioritize for optimization",
        "optimize content for specific AI search platforms",
        "understand how AI platforms rank and cite sources" ;
    oc:yieldsState oc:AIBotAccessConfigured,
        oc:PlatformRankingFactorsIdentified .

oc:kn_3f4b64db a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring robots.txt for any site targeting AI search visibility" ;
    oc:directiveContent "Do not block AI bot user agents (GPTBot, ChatGPT-User, PerplexityBot, ClaudeBot, anthropic-ai, Google-Extended, Bingbot) in robots.txt if you want to be cited by AI platforms." ;
    oc:hasRationale "Blocking an AI bot completely prevents that platform from accessing and citing your content, regardless of how well-optimized your content otherwise is." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4c398d62 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any AI SEO optimization effort" ;
    oc:directiveContent "Before optimizing for any AI platform, verify: (1) your content appears in that platform's search backend index, (2) relevant AI bots are allowed in robots.txt, and (3) content is structured with extractable paragraphs and schema markup." ;
    oc:hasRationale "Skipping these checks means you may invest in content optimization while remaining invisible to the target platform at the infrastructure level." .

oc:kn_5837ac8e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing structured data for AI search optimization" ;
    oc:directiveContent "Schema markup is the single biggest lever for Google AI Overviews (30-40% visibility boost), while FAQPage schema specifically boosts Perplexity citations, and Article schema with timestamps signals freshness across platforms." ;
    oc:hasRationale "Structured data gives AI platforms machine-readable context that dramatically improves extractability and citation likelihood, especially for Google and Perplexity." .

oc:kn_67b56bc3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning an AI SEO optimization roadmap for the first time" ;
    oc:directiveContent "Prioritize optimization in this order: Google AI Overviews (largest reach at 45%+ of searches) → ChatGPT (most-used standalone AI search) → Perplexity (research-oriented audiences) → Copilot/Claude (niche audiences)." ;
    oc:hasRationale "This sequencing maximizes audience reach by starting where the most users are, while building foundations (schema, structured content) that benefit all platforms simultaneously." .

oc:kn_6d1675b4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When troubleshooting why a specific AI platform is not citing your content" ;
    oc:directiveContent "Each platform uses a different search index: Google AI Overviews uses Google's index, ChatGPT uses Bing, Perplexity uses its own + Google, Copilot uses Bing, Claude uses Brave Search. You must be indexed in each platform's specific backend." ;
    oc:hasRationale "A page ranking well in Google may be invisible to Claude (which uses Brave) or Copilot (which uses Bing) if not indexed in those respective backends." ;
    oc:severityLevel "HIGH" .

oc:kn_8de781f1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing content specifically for ChatGPT citations" ;
    oc:directiveContent "For ChatGPT specifically, the content-answer fit (how well your content's style matches ChatGPT's own response format) accounts for ~55% of citation likelihood, far outweighing domain authority (~12%) or on-page structure (~14%) alone. Write the way ChatGPT would answer." ;
    oc:hasRationale "ZipTie's analysis of 400,000 pages shows structural mimicry of ChatGPT's conversational, direct answer style is the strongest single predictor of citation." ;
    oc:severityLevel "HIGH" .

oc:kn_a186812e a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making changes to site configuration for AI SEO" ;
    oc:directiveContent "robots.txt bot allowances and schema markup implementations should be verified as additive changes — blocking a previously-allowed bot or removing schema will immediately degrade AI citation performance." ;
    oc:hasRationale "These configurations are not idempotent in the destructive direction — removing access or structure causes immediate and potentially lasting harm to AI visibility." ;
    oc:severityLevel "HIGH" .

oc:kn_b08059f6 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When maintaining competitive content targeting ChatGPT or Perplexity citations" ;
    oc:directiveContent "Freshness of content significantly impacts citation rates: ChatGPT cites content updated within 30 days 3.2x more often, and Perplexity uses a time-decay algorithm that favors recently published content." ;
    oc:hasRationale "AI platforms explicitly weight recency in their ranking algorithms, making regular content updates a high-ROI optimization tactic." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c89abed4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing for any AI search platform" ;
    oc:directiveContent "Every AI platform shares three baseline requirements: content must be indexed by that platform's search backend, crawlable by AI bots via robots.txt, and extractable in clear, self-contained passages rather than whole-page reads." ;
    oc:hasRationale "Without these fundamentals, no platform-specific optimization can produce results — you must be discoverable before you can be cited." ;
    oc:severityLevel "CRITICAL" .

oc:req_ebc7d864 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Basic SEO concepts (schema markup, domain authority, indexing)" .

