        oc:kn_a8df13a8,
        oc:kn_a9ae0827,
        oc:kn_d7093ed1,
        oc:kn_df6d8b7a,
        oc:kn_fd495f4e ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ContentPublished,
        oc:SiteCrawlable ;
    oc:resolvesIntent "configure robots.txt for AI bots",
        "get cited by AI search engines",
        "improve visibility in AI overviews",
        "optimize content for AI search citations",
        "understand AI platform ranking factors" ;
    oc:yieldsState oc:AISearchOptimized,
        oc:PlatformVisibilityKnown .

oc:kn_07169765 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When optimizing for Google AI Overviews" ;
    oc:directiveContent "Google AI Overviews do not just recycle the traditional Top 10 — only ~15% overlap with organic results. Pages outside page 1 can still be cited with strong structured data and extractable answers." ;
    oc:hasRationale "This means traditional SEO rankings alone are insufficient; structured data and answer clarity are independent ranking paths." .

oc:kn_0bd973b6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing for ChatGPT citations" ;
    oc:directiveContent "For ChatGPT, content-answer fit (55% of citation likelihood) matters far more than domain authority (12%) or on-page structure (14%). Write content in the conversational, direct, well-organized format ChatGPT would use to answer." ;
    oc:hasRationale "ZipTie analysis of 400,000 pages found content-answer fit to be the dominant signal by a wide margin." .

oc:kn_2fd6f574 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Always — these are cross-platform optimizations" ;
    oc:directiveContent "Universal actions that help across all platforms: 1) Allow all AI bots in robots.txt 2) Implement schema markup (FAQPage, Article, Organization minimum) 3) Include statistics with named sources 4) Update content monthly for competitive topics 5) Use clear heading hierarchy (H1>H2>H3) 6) Keep page load under 2 seconds 7) Add author bios with credentials" ;
    oc:stepOrder 1 .

oc:kn_4162e44d a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When deciding which bots to allow/block" ;
    oc:directiveContent "GPTBot is used for both training and search citation — you cannot block training without also blocking citations. However, CCBot (Common Crawl) can be safely blocked without affecting any AI search citations." ;
    oc:hasRationale "Some organizations want to prevent training use while maintaining citation visibility, but this tradeoff is limited for OpenAI." .

oc:kn_79071ec9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When maintaining content for AI search visibility" ;
    oc:directiveContent "Content updated within the last 30 days gets cited ~3.2x more often by ChatGPT. Update competitive content at least monthly." ;
    oc:hasRationale "Freshness is a major differentiator for ChatGPT's citation algorithm." .

oc:kn_971f3b1e a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When implementing structured data for AI search" ;
    oc:directiveContent """Schema markup types to implement by priority:
- Google AI Overviews: Article, FAQPage, HowTo, Product (30-40% visibility boost)
- Perplexity: FAQPage (JSON-LD), Article with timestamps
- All platforms: Organization schema""" .

oc:kn_980d827f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring robots.txt to allow AI bot access for citation" ;
    oc:codeLanguage "robots.txt" ;
    oc:directiveContent """User-agent: GPTBot
User-agent: ChatGPT-User
User-agent: PerplexityBot
User-agent: ClaudeBot
User-agent: anthropic-ai
User-agent: Google-Extended
User-agent: Bingbot
Allow: /""" .

oc:kn_9aa4fe6e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing for Claude citations" ;
    oc:directiveContent "Claude uses Brave Search as its backend — not Google or Bing. Your Brave Search visibility directly determines whether Claude can cite you. Verify content appears at search.brave.com." ;
    oc:hasRationale "Claude uses a completely different index from other platforms; Google/Bing optimization alone won't help." ;
    oc:severityLevel "HIGH" .

oc:kn_a8df13a8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning AI search optimization" ;
    oc:directiveContent "Prioritize platforms by audience reach: start with Google AI Overviews (45%+ of searches), then ChatGPT (largest standalone AI search), then Perplexity (research audiences). Copilot and Claude are lower priority unless audience is enterprise or developer." ;
    oc:hasRationale "Effort should follow audience size and existing SEO foundation leverage." .

oc:kn_a9ae0827 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring robots.txt" ;
    oc:directiveContent "Do NOT block AI bot user agents in robots.txt if you want to be cited. Blocking GPTBot, PerplexityBot, ClaudeBot, anthropic-ai, Google-Extended, or Bingbot prevents citation entirely." ;
    oc:hasRationale "If an AI bot can't crawl your content, the platform cannot cite it regardless of content quality." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d7093ed1 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When optimizing for Perplexity citations" ;
    oc:directiveContent "Perplexity uniquely prioritizes FAQ schema (JSON-LD), publicly accessible PDFs, publishing velocity, and self-contained paragraphs. Implement FAQPage schema on Q&A content and host PDF resources publicly." ;
    oc:hasRationale "Perplexity runs multiple reranking passes and has unique content format preferences unlike other platforms." .

oc:kn_df6d8b7a a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Content must be published and indexed by the relevant platform's search backend (Google, Bing, Brave, or proprietary) before AI citation is possible." .

oc:kn_fd495f4e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before optimizing for any AI search platform" ;
    oc:directiveContent "Your content must be in each platform's index, crawlable by AI bots, and extractable as self-contained passages. Without all three, citation is impossible." ;
    oc:hasRationale "These are the three baseline requirements shared by every AI platform — indexing, crawlability, and extractability." ;
    oc:severityLevel "CRITICAL" .

