oc:skill_coreyhaines31_marketingskills_competitor_alternatives_content_architecture a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "content-architecture" ;
    skos:broader "Content architecture framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/competitor-alternatives" ;
    oc:contentHash "9fbc1793b63f3e0302ff4f05ec74fb9944792a5f878a890aba47bab5b2ac4d35" ;
    oc:differentia "structures centralized competitor data and index page hierarchies for scalable comparison page generation" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_competitor_alternatives ;
    oc:handlesFailure oc:InsufficientData,
        oc:InvalidInput ;
    oc:hasArgumentHint "product-name, competitor-list" ;
    oc:hasCategory "marketing" ;
    oc:hasRequirement oc:req_392df425,
        oc:req_54257b0a,
        oc:req_b6a4d4e6 ;
    oc:impartsKnowledge oc:kn_0d0b979c,
        oc:kn_1cfa1846,
        oc:kn_5f6ea5de,
        oc:kn_bf5ac95a,
        oc:kn_ef3a3e28 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CompetitiveLandscapeResearched ;
    oc:resolvesIntent "build comparison page index and hub architecture",
        "create centralized competitor data templates",
        "design footer navigation for competitor content",
        "maintain scalable competitor content at scale",
        "structure competitor data for comparison pages" ;
    oc:yieldsState oc:ComparisonIndexArchitected,
        oc:CompetitorDataStructured .

oc:kn_0d0b979c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating or updating any competitor comparison page" ;
    oc:directiveContent "Never duplicate competitor data across individual page files; instead, always pull from the centralized competitor_data/ directory" ;
    oc:hasRationale "Duplicated data creates maintenance debt—updating pricing in one place but missing another leads to inaccurate pages and lost trust with evaluators" ;
    oc:severityLevel "HIGH" .

oc:kn_1cfa1846 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring any competitor comparison content system" ;
    oc:directiveContent "Maintain a single source of truth for each competitor in a centralized data directory; each competitor gets one YAML file that feeds all page formats" ;
    oc:hasRationale "Centralized data ensures that pricing updates, feature changes, or positioning shifts propagate to all pages simultaneously, preventing inconsistency across dozens of comparison pages" ;
    oc:severityLevel "CRITICAL" .

oc:kn_5f6ea5de a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing footer navigation for competitor content" ;
    oc:directiveContent "Limit footer columns to 8 links per format column, prioritized by search volume, with a 'View all' link to the full index page" ;
    oc:hasRationale "Too many footer links dilute link equity and create clutter; 8 top links by search volume captures the highest-traffic terms while keeping the footer clean and mobile-friendly" ;
    oc:severityLevel "MEDIUM" .

oc:kn_bf5ac95a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building comparison page index structures and navigation" ;
    oc:directiveContent "Create bidirectional internal links: index pages link to individual comparison pages, individual pages link back to index, and related comparisons cross-link" ;
    oc:hasRationale "Bidirectional linking maximizes crawl efficiency, passes link equity throughout the comparison hub, and helps users discover related comparisons they may not have considered" ;
    oc:severityLevel "HIGH" .

oc:kn_ef3a3e28 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting any competitor profile" ;
    oc:directiveContent "Each competitor data file must include honest weaknesses and 'not ideal for' sections alongside strengths, using the standardized YAML template" ;
    oc:hasRationale "Honest, balanced competitor data ensures that generated comparison pages build trust with evaluators who are actively verifying claims against multiple sources" ;
    oc:severityLevel "HIGH" .

oc:req_392df425 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Competitor research methodology" .

oc:req_54257b0a a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "YAML structured data format" .

oc:req_b6a4d4e6 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "SEO internal linking principles" .

