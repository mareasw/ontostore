@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_competitor_alternatives_templates a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "templates" ;
    skos:broader "Section template library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/competitor-alternatives" ;
    oc:contentHash "8f367433afe78d532f81e0da757514cdbeaa3ea39689ce158c1c963079a93046" ;
    oc:differentia "provides ready-to-use markdown templates for each section of competitor comparison pages, including TL;DR summaries, feature comparisons, pricing tables, support comparisons, migration guides, and social proof sections" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_competitor_alternatives ;
    oc:handlesFailure oc:IncompleteProductInfo,
        oc:MissingCompetitorData ;
    oc:hasArgumentHint "competitor-name, product-name, section-type" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_877d6b9d,
        oc:kn_899e38f5,
        oc:kn_a4106dde,
        oc:kn_c5d92957,
        oc:kn_f2b8b46d,
        oc:kn_ff8f2d82 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:CompetitorIdentified,
        oc:ProductContextSet ;
    oc:resolvesIntent "build competitor alternative page content section by section",
        "create structured alternative pages using templates",
        "generate competitor comparison page sections",
        "write competitive comparison content from templates" ;
    oc:yieldsState oc:CompetitorPageSectionsGenerated .

oc:kn_877d6b9d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When filling in any comparison template" ;
    oc:directiveContent "Every section must include honest limitations and tradeoffs for both your product and the competitor." ;
    oc:hasRationale "One-sided comparisons destroy credibility; honest acknowledgment of tradeoffs builds trust and pre-qualifies leads who are genuinely a good fit." ;
    oc:severityLevel "CRITICAL" .

oc:kn_899e38f5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring feature comparison tables" ;
    oc:directiveContent "Organize feature comparisons by meaningful categories (core functionality, collaboration, integrations, security, support) rather than a flat feature list." ;
    oc:hasRationale "Categorized comparisons help readers find what matters to them faster and demonstrate thorough understanding of the product space." .

oc:kn_a4106dde a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building competitor pages targeting users of that competitor" ;
    oc:directiveContent "Include a migration section and switcher-focused social proof to reduce switching cost anxiety and provide a clear transition path." ;
    oc:hasRationale "Switching cost is the #1 barrier to conversion from competitors; addressing migration explicitly with proof points from real switchers overcomes this objection." ;
    oc:severityLevel "HIGH" .

oc:kn_c5d92957 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring any competitor alternative page" ;
    oc:directiveContent "Always start competitor comparison pages with a TL;DR summary that gives scanners the bottom line before diving into details." ;
    oc:hasRationale "Most visitors scan rather than read; a TL;DR immediately communicates your positioning and helps users self-select." ;
    oc:severityLevel "HIGH" .

oc:kn_f2b8b46d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating feature comparison sections" ;
    oc:directiveContent "Never use simple checkmark/cross feature comparison tables. Replace them with descriptive capability text that shows depth of support." ;
    oc:hasRationale "Checkmarks hide meaningful differences in implementation quality and depth; descriptive comparisons surface real differentiators and build trust through nuance." ;
    oc:severityLevel "HIGH" .

oc:kn_ff8f2d82 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When explaining competitive differences beyond surface-level features" ;
    oc:directiveContent "Write paragraph-style comparisons for each major dimension (features, pricing, support) rather than relying solely on tables." ;
    oc:hasRationale "Paragraphs provide context, nuance, and honest tradeoffs that tables cannot convey, improving both SEO value and reader trust." .

