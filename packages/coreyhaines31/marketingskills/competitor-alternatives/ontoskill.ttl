@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_competitor_alternatives a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "competitor-alternatives" ;
    skos:broader "Marketing content generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/competitor-alternatives" ;
    oc:contentHash "445acc304b8bf868e008ed1d9925898f18e6520509dbd1f947bd08d0cf8a8f64" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "that creates competitor comparison and alternative pages across four distinct formats (singular alternative, plural alternatives, head-to-head vs, and competitor-vs-competitor) for SEO traffic capture and competitive positioning" ;
    oc:extends oc:skill_copywriting ;
    oc:handlesFailure oc:InsufficientCompetitorData,
        oc:ProductMarketingContextMissing ;
    oc:hasAllowedTool "Glob",
        "Read",
        "Write" ;
    oc:hasArgumentHint "competitor name and page format (singular alternative, plural alternatives, you vs competitor, competitor vs competitor)" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to create competitor comparison or alternative pages for SEO and sales enablement. Also use when the user mentions 'alternative page,' 'vs page,' 'competitor comparison,' 'comparison page,' '[Product] vs [Product],' '[Product] alternative,' 'competitive landing pages,' 'how do we compare to X,' 'battle card,' or 'competitor teardown.' Use this for any content that positions your product against competitors. Covers four formats: singular alternative, plural alternatives, you vs competitor, and competitor vs competitor. For sales-specific competitor docs, see sales-enablement." ;
    oc:hasName "competitor-alternatives" ;
    oc:impartsKnowledge oc:kn_0292922d,
        oc:kn_6918c2d5,
        oc:kn_7f738eb7,
        oc:kn_8c76c545,
        oc:kn_965fd1eb,
        oc:kn_a11a109f,
        oc:kn_fc2bedf0 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:ProductMarketingContextAvailable ;
    oc:resolvesIntent "build alternative landing pages for SEO",
        "create competitor comparison pages",
        "create product alternative pages",
        "design competitor content hub",
        "generate competitive positioning content",
        "write vs comparison pages" ;
    oc:yieldsState oc:ComparisonContentReady,
        oc:CompetitorDataFileGenerated,
        oc:CompetitorPageCreated .

oc:kn_0292922d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "After competitor pages are published and live" ;
    oc:directiveContent "Schedule quarterly pricing verification, react to customer-mentioned competitor changes, and do annual full refreshes of all competitor data to maintain accuracy." ;
    oc:hasRationale "Stale competitor data undermines credibility; pricing and features change frequently and inaccurate comparisons damage trust." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6918c2d5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building multiple competitor comparison pages or a comparison content hub" ;
    oc:directiveContent "Use a centralized competitor data architecture: create a single source of truth file per competitor that all comparison pages pull from, so updates propagate everywhere." ;
    oc:hasRationale "Decentralized competitor data leads to inconsistencies across pages; centralized data enables scalable maintenance and ensures accuracy." ;
    oc:severityLevel "HIGH" .

oc:kn_7f738eb7 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating feature comparison sections on any competitor page" ;
    oc:directiveContent "Go beyond feature checkmarks in comparison tables. For each dimension, write paragraph explanations of differences, when each matters, and provide bottom-line recommendations." ;
    oc:hasRationale "Surface-level checklists don't help evaluators make decisions; depth differentiates your content and ranks better in search." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8c76c545 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating plural '[Competitor] Alternatives' format pages" ;
    oc:directiveContent "For plural alternatives pages, include 4-7 real alternatives beyond your own product. Being genuinely helpful with multiple options builds trust and ranks better." ;
    oc:hasRationale "Including only yourself as an alternative looks biased and provides poor user experience; genuine breadth signals authority." ;
    oc:severityLevel "HIGH" .

oc:kn_965fd1eb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any competitor comparison or alternative page" ;
    oc:directiveContent "Always acknowledge competitor strengths and be accurate about your own limitations in comparison pages. Readers are actively comparing and will verify claims." ;
    oc:hasRationale "Honesty builds trust with evaluators who are conducting due diligence; misrepresentation damages credibility and brand trust." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a11a109f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any competitor page creation" ;
    oc:directiveContent "Check for product-marketing-context.md (.agents/ or .claude/) before asking questions. Use existing context and only request information not already covered or specific to the current task." ;
    oc:hasRationale "Leveraging existing product context reduces redundant questions and ensures consistency with established positioning." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fc2bedf0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user requests competitive content for internal sales team use" ;
    oc:directiveContent "Do not use this skill to create internal battle cards, objection handling docs, or sales collateral—those belong in the sales-enablement skill." ;
    oc:hasRationale "Public comparison pages and internal battle cards serve fundamentally different audiences and have different tone, detail, and honesty requirements." ;
    oc:severityLevel "HIGH" .

