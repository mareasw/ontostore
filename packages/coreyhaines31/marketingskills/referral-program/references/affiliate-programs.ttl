@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_referral_program_affiliate_programs a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "affiliate-programs" ;
    skos:broader "program design guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/referral-program" ;
    oc:contentHash "3479ba24987c24654191f02bbf57fa5ff89eecde8e93cf22c65538bed2c356b4" ;
    oc:differentia "that provides comprehensive frameworks for building and managing affiliate programs including commission structures, recruitment, enablement, tool selection, and fraud prevention" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_referral_program ;
    oc:handlesFailure oc:FraudDetected,
        oc:InvalidCommissionStructure,
        oc:ToolIntegrationFailed ;
    oc:hasArgumentHint "product details including pricing model, target audience, and goals" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_4f5814b4,
        oc:kn_7ccfd357,
        oc:kn_7f07d503,
        oc:kn_8b7c08e8,
        oc:kn_a6c2f847 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:PricingModelDefined,
        oc:ProductLaunched ;
    oc:resolvesIntent "design affiliate program commission structures",
        "enable affiliates with resources and assets",
        "prevent affiliate and referral fraud",
        "recruit affiliates for a product",
        "select affiliate program tools and platforms" ;
    oc:yieldsState oc:AffiliateProgramDesigned,
        oc:AffiliateRecruitmentReady,
        oc:FraudPreventionConfigured .

oc:kn_4f5814b4 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When setting up any affiliate or referral program" ;
    oc:directiveContent "Implement multi-layer fraud prevention combining technical measures (email verification, device fingerprinting, IP monitoring), policy controls (clear ToS, reward clawbacks, caps), and structural safeguards (meaningful action requirements, delayed payouts)." ;
    oc:hasRationale "Affiliate fraud (self-referrals, referral rings, coupon abuse, VPN spoofing) can drain program budgets and distort conversion data if not proactively addressed." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7ccfd357 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing affiliate commission structures" ;
    oc:directiveContent "Match commission structure to business model: percentage-of-sale for e-commerce/SaaS, flat-fee for lead gen/freemium, recurring for subscriptions, and tiered for motivating high performers." ;
    oc:hasRationale "Misaligned commission structures either fail to motivate affiliates or erode margins unnecessarily." ;
    oc:severityLevel "HIGH" .

oc:kn_7f07d503 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building an initial affiliate network" ;
    oc:directiveContent "Recruit affiliates from high-value sources first: existing content-creating customers, niche bloggers/reviewers, YouTubers, newsletter writers, complementary tool companies, and agencies." ;
    oc:hasRationale "Affiliates with existing audience trust and topical relevance convert far better than cold outreach to generic influencers." .

oc:kn_8b7c08e8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring affiliate tracking cookie duration" ;
    oc:directiveContent "Set cookie duration proportional to sales cycle length: 24h for impulse purchases, 7-14 days for standard e-commerce, 30 days for SaaS/B2B, 60-90 days for enterprise." ;
    oc:hasRationale "Too-short cookies cheat affiliates of rightful credit; too-long cookies create attribution confusion and increase fraud risk." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a6c2f847 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before recruiting any affiliates" ;
    oc:directiveContent "Never launch an affiliate program without a complete enablement kit including tracking links, product overview, competitor comparisons, creative assets, sample copy, and objection handling." ;
    oc:hasRationale "Under-equipped affiliates produce poor-quality promotions that damage brand perception and waste recruitment effort." ;
    oc:severityLevel "HIGH" .

