oc:kn_2e8f4994 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building or launching any affiliate program" ;
    oc:directiveContent "Never launch an affiliate program without fraud prevention measures in place: self-referrals, referral rings, coupon-site abuse, fake emails, and VPN spoofing are all common attack vectors." ;
    oc:hasRationale "Affiliate fraud can drain marketing budgets rapidly through fabricated referrals that never convert to real customers." ;
    oc:severityLevel "CRITICAL" ;
    oc:stepOrder 5 .

oc:kn_2fa7159c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When onboarding or supporting affiliates" ;
    oc:directiveContent "Affiliate enablement should provide all materials affiliates need to succeed: tracking links, product overview, audience description, competitor comparisons, creative assets, sample copy, case studies, demo access, FAQ, and payment terms." ;
    oc:hasRationale "Well-equipped affiliates produce higher-quality referrals and are more likely to actively promote your product." ;
    oc:severityLevel "HIGH" ;
    oc:stepOrder 4 .

oc:kn_5117d70a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When selecting affiliate program platforms" ;
    oc:directiveContent "When choosing an affiliate tool, evaluate integration with payment system, fraud detection, payout management, reporting, customization, and price relative to program scale." ;
    oc:hasRationale "Tool selection determines operational efficiency and fraud protection capability for the entire program lifecycle." ;
    oc:severityLevel "MEDIUM" ;
    oc:stepOrder 3 .

oc:kn_5f06a0b4 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before launching or scaling an affiliate program" ;
    oc:directiveContent "Verify fraud prevention is in place before launch: email verification, device fingerprinting, IP monitoring, delayed payouts, minimum activity thresholds, clear ToS, and reward clawback policies." ;
    oc:hasRationale "Proactive fraud prevention is far cheaper than retroactive cleanup and dispute resolution." ;
    oc:severityLevel "HIGH" .

oc:kn_678f92fb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing affiliate commission structures" ;
    oc:directiveContent "Commission structures must align with business model: percentage-of-sale for e-commerce/SaaS, flat-fee for lead gen/freemium, recurring for subscriptions, tiered for motivating high performers." ;
    oc:hasRationale "Mismatched commission models either fail to motivate affiliates or destroy unit economics." ;
    oc:severityLevel "HIGH" ;
    oc:stepOrder 1 .

oc:kn_7c06b2db a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting cookie/tracking duration" ;
    oc:directiveContent "Cookie duration should match the sales cycle: 24h for impulse purchases, 7-14 days for e-commerce, 30 days for SaaS/B2B, 60-90 days for enterprise, lifetime for premium partner relationships." ;
    oc:hasRationale "Too-short cookies cheat affiliates of earned commissions; too-long cookies create attribution bloat and fraud risk." ;
    oc:severityLevel "MEDIUM" ;
    oc:stepOrder 2 .

