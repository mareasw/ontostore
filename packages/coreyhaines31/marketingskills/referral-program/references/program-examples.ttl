oc:skill_coreyhaines31_marketingskills_referral_program_program_examples a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "program-examples" ;
    skos:broader "knowledge base" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/referral-program" ;
    oc:contentHash "2baad60cdb251414ea559bd4dcf23d6c394ff66e593ae9392453f2e24f585c8a" ;
    oc:differentia "provides real-world referral program examples, incentive frameworks, and viral coefficient metrics for designing and benchmarking referral programs" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_referral_program ;
    oc:hasArgumentHint "query about referral program examples, incentive types, or metrics" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_056a59c2,
        oc:kn_9ab32263,
        oc:kn_e7e51379,
        oc:kn_f02b9957,
        oc:kn_f65e33e9 ;
    oc:isUserInvocable false ;
    oc:nature "reference" ;
    oc:requiresState oc:CustomerLTVKnown,
        oc:ProductMarketFitEstablished ;
    oc:resolvesIntent "benchmark referral program performance",
        "calculate referral incentive sizing",
        "compare incentive types for referral programs",
        "find referral program examples",
        "understand viral coefficient and referral metrics" ;
    oc:yieldsState oc:IncentiveStructureDesigned,
        oc:ReferralProgramBenchmarked .

oc:kn_056a59c2 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before launching or recommending a referral program" ;
    oc:directiveContent "Before finalizing a referral program design, verify you have accurate LTV, gross margin, and target CAC figures to properly size incentives and project ROI." ;
    oc:hasRationale "Incentive sizing without accurate unit economics leads to either underperforming programs (rewards too low) or unprofitable ones (rewards too high)." ;
    oc:severityLevel "HIGH" .

oc:kn_9ab32263 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When determining referral incentive amounts" ;
    oc:directiveContent "Size referral rewards using the formula: Max Referral Reward = (Customer LTV × Gross Margin) - Target CAC, ensuring the reward never exceeds the net value a referred customer brings." ;
    oc:hasRationale "Without a mathematical ceiling, referral rewards can exceed the economic value of a referred customer, making the program unprofitable." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e7e51379 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating referral program performance metrics" ;
    oc:directiveContent "Target a viral coefficient (K-factor) greater than 1 for viral growth; even K < 1 provides meaningful amplified growth that supplements other acquisition channels." ;
    oc:hasRationale "The K-factor determines whether the program is self-sustaining (K>1) or serves as a multiplier on top of existing acquisition efforts (K<1)." .

oc:kn_f02b9957 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing incentive type for SaaS or subscription referral programs" ;
    oc:directiveContent "Do not use transactional cash incentives for products where the reward could instead be product-embedded value (credit, features, storage), as cash feels impersonal and attracts bargain-seekers rather than engaged users." ;
    oc:hasRationale "Product-embedded rewards reinforce usage and retention, while pure cash rewards feel transactional and may attract low-quality referrals." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f65e33e9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing referral incentive structures" ;
    oc:directiveContent "Use double-sided incentives where both the referrer and the referred user benefit equally, as seen in Dropbox (500MB/500MB) and Uber ($10/$10), to maximize sharing motivation." ;
    oc:hasRationale "Double-sided incentives remove the social awkwardness of referral and create mutual benefit, dramatically increasing participation rates." .

