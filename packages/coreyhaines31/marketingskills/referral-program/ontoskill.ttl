oc:skill_coreyhaines31_marketingskills_referral_program a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "referral-program" ;
    skos:broader "Marketing strategy framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/referral-program" ;
    oc:contentHash "260ff6612dc799ebaa2490816e102d49453cf093c6bdd453b6b33a47a68a893f" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "designs and optimizes referral and affiliate programs that turn customers into growth engines through incentivized word-of-mouth" ;
    oc:handlesFailure oc:InsufficientContext,
        oc:InvalidInput ;
    oc:hasArgumentHint "program type (referral/affiliate), customer LTV, current CAC, existing program status" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to create, optimize, or analyze a referral program, affiliate program, or word-of-mouth strategy. Also use when the user mentions 'referral,' 'affiliate,' 'ambassador,' 'word of mouth,' 'viral loop,' 'refer a friend,' 'partner program,' 'referral incentive,' 'how to get referrals,' 'customers referring customers,' or 'affiliate payout.' Use this whenever someone wants existing users or partners to bring in new customers. For launch-specific virality, see launch-strategy." ;
    oc:hasName "referral-program" ;
    oc:impartsKnowledge oc:kn_13c04ba2,
        oc:kn_25e52eee,
        oc:kn_29b897ce,
        oc:kn_6cf826ab,
        oc:kn_7d06d75c,
        oc:kn_9bdca06c,
        oc:kn_e81c00e8 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProductMarketingContextAvailable ;
    oc:resolvesIntent "analyze referral program performance",
        "choose between referral and affiliate models",
        "create a referral program",
        "design an affiliate program",
        "launch a referral program",
        "optimize an existing referral program",
        "prevent referral fraud",
        "size referral incentives" ;
    oc:yieldsState oc:IncentiveStructureDefined,
        oc:LaunchPlanReady,
        oc:ReferralProgramDesigned .

oc:kn_13c04ba2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user asks about 'referral' or 'affiliate' without distinguishing between them" ;
    oc:directiveContent "Do not treat referral and affiliate programs as interchangeable. Referral programs leverage existing customers (higher trust, lower volume); affiliate programs leverage external promoters (higher volume, variable trust)." ;
    oc:hasRationale "Confusing these models leads to wrong tool choices, misaligned incentive structures, and poor program performance. Each has distinct characteristics, audiences, and success metrics." ;
    oc:severityLevel "HIGH" .

oc:kn_25e52eee a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When launching or auditing a referral/affiliate program" ;
    oc:directiveContent "Common referral fraud patterns include self-referrals (fake accounts), referral rings (groups referring each other), coupon sites posting referral codes, and VPN/device spoofing." ;
    oc:hasRationale "Without proactive fraud prevention, bad actors can drain incentive budgets. Use email verification, device fingerprinting, delayed payouts, minimum activity thresholds, and IP monitoring." ;
    oc:severityLevel "HIGH" .

oc:kn_29b897ce a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any referral/affiliate program task" ;
    oc:directiveContent "Always check for product-marketing-context.md (.agents/ or .claude/) before asking the user questions. Only ask for information not already covered in that context document." ;
    oc:hasRationale "Product marketing context contains essential data (LTV, CAC, product positioning, audience) that prevents redundant questions and enables more tailored recommendations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6cf826ab a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding when to prompt users for referrals" ;
    oc:directiveContent "Time referral asks at high-intent moments: right after the first 'aha' moment, after achieving a milestone, after exceptional support, or after renewing/upgrading." ;
    oc:hasRationale "Customers are most likely to refer when they're experiencing peak satisfaction or value realization. Asking at random times yields far lower participation." ;
    oc:severityLevel "HIGH" .

oc:kn_7d06d75c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any referral program from scratch" ;
    oc:directiveContent "Design the referral loop as a complete cycle: Trigger Moment → Share Action → Convert Referred → Reward → Loop. Every element must be optimized, not just the incentive." ;
    oc:hasRationale "A referral program is a loop, not a one-shot campaign. Weakness at any stage collapses the entire loop's effectiveness." ;
    oc:severityLevel "HIGH" .

oc:kn_9bdca06c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing an incentive structure for a referral program" ;
    oc:directiveContent "Use double-sided incentives (both referrer and referred benefit) over single-sided rewards for higher conversion rates and win-win framing." ;
    oc:hasRationale "Double-sided incentives create a social contract where the referrer feels good about sharing and the referred feels welcomed, increasing both share rate and conversion rate." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e81c00e8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sizing referral incentives or commission structures" ;
    oc:directiveContent "Maximum referral reward should be calculated as (Customer LTV × Gross Margin) - Target CAC. Never exceed this ceiling without explicit business justification." ;
    oc:hasRationale "Exceeding this threshold means the referral channel costs more than it earns, making the program economically unsustainable. Typical ranges: B2C $10-50, B2B SaaS $50-500, Enterprise custom." ;
    oc:severityLevel "CRITICAL" .

