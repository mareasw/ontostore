    oc:stepId "configure-smart-retries" .

_:ref_c3507c638cb42517 a oc:WorkflowStep ;
    dcterms:description "Enable smart retries, configure 4-email dunning sequence (Day 0, 3, 7, 10), and set up card expiry pre-dunning alerts" ;
