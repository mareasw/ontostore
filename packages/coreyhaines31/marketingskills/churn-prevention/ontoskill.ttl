oc:skill_coreyhaines31_marketingskills_churn_prevention a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "churn-prevention" ;
    skos:broader "Retention strategy framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/churn-prevention" ;
    oc:contentHash "7d017750153ba4e57243f483df7997bbfbcd358b4bd7b6805bbff7ac69982198" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "combines cancel flow design, dynamic save offers, dunning/payment recovery, and proactive health-score-based intervention to reduce both voluntary and involuntary SaaS subscriber churn" ;
    oc:handlesFailure oc:BillingIntegrationNotSupported,
        oc:InsufficientChurnData ;
    oc:hasArgumentHint "churn situation description, billing provider, cancel flow goals" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to reduce churn, build cancellation flows, set up save offers, recover failed payments, or implement retention strategies. Also use when the user mentions 'churn,' 'cancel flow,' 'offboarding,' 'save offer,' 'dunning,' 'failed payment recovery,' 'win-back,' 'retention,' 'exit survey,' 'pause subscription,' 'involuntary churn,' 'people keep canceling,' 'churn rate is too high,' 'how do I keep users,' or 'customers are leaving.' Use this whenever someone is losing subscribers or wants to build systems to prevent it. For post-cancel win-back email sequences, see email-sequence. For in-app upgrade paywalls, see paywall-upgrade-cro." ;
    oc:hasName "churn-prevention" ;
    oc:impartsKnowledge oc:kn_21ba33a3,
        oc:kn_2cf5ac40,
        oc:kn_5d684cb0,
        oc:kn_8b58545d,
        oc:kn_d40ad902,
        oc:kn_da86ba5b,
        oc:kn_e16611e3,
        oc:kn_e9492f25 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:BillingProviderIdentified,
        oc:ProductMarketingContextAvailable ;
    oc:resolvesIntent "build a cancel flow",
        "create exit surveys",
        "design save offers",
        "implement retention strategy",
        "optimize cancel flow save rates",
        "predict churn risk",
        "prevent involuntary churn",
        "recover failed payments",
        "reduce churn rate",
        "set up dunning emails" ;
    oc:yieldsState oc:CancelFlowDesigned,
        oc:DunningSequenceCreated,
        oc:HealthScoreModelCreated,
        oc:RetentionStrategyDefined .

oc:kn_21ba33a3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing discount save offers" ;
    oc:directiveContent "Never offer discounts exceeding 30% or time-unlimited discounts, as this trains customers to cancel-and-return for deals. Limit discount offers to 2-3 months maximum." ;
    oc:hasRationale "Deep or perpetual discounts devalue the product and create a segment of customers who repeatedly cancel to get deals, eroding MRR and LTV." ;
    oc:severityLevel "HIGH" .

oc:kn_2cf5ac40 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning churn prevention implementation from scratch" ;
    oc:directiveContent "Implement churn prevention in three phases: Phase 1 — Foundation (basic cancel flow with survey + 1 offer + confirmation, pre-dunning card expiry emails); Phase 2 — Optimization (fallback offers, pause option, dunning email sequence, smart retries, MRR-based routing); Phase 3 — Advanced (health scores, proactive interventions, A/B testing, cohort analysis, win-back sequences)." ;
    oc:hasRationale "A phased approach ensures quick wins (Phase 1 saves 10-15% alone) while building toward sophisticated retention infrastructure that maximizes long-term recovery rates." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5d684cb0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining save strategy based on customer value" ;
    oc:directiveContent "For high-value accounts (top 10-20% by MRR), route cancellations to personal outreach from customer success or founders rather than relying solely on automated flows." ;
    oc:hasRationale "Personal outreach has significantly higher save rates (30-45%) compared to automated flows (20-30%), making it cost-effective for high-MRR accounts." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8b58545d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing pause subscription save offers" ;
    oc:directiveContent "Pause subscriptions for a maximum of 3 months. Pauses beyond 3 months rarely result in reactivation. Limit to 1 pause per 12-month period." ;
    oc:hasRationale "Extended pauses indicate the customer has moved on. Short pauses maintain the relationship while the customer has a temporary gap in need." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d40ad902 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting save offers in the cancel flow" ;
    oc:directiveContent "Match the save offer to the cancellation reason. A discount won't save someone who isn't using the product; a feature roadmap won't save someone who can't afford it. Use reason-to-offer mapping for dynamic save offers." ;
    oc:hasRationale "Generic offers have low conversion. Targeted offers based on exit survey responses dramatically improve save rates because they address the actual cause of cancellation." ;
    oc:severityLevel "HIGH" .

oc:kn_da86ba5b a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When measuring cancel flow effectiveness" ;
    oc:directiveContent "Saved customers who churn again within 30 days were not truly saved. Track post-save LTV and don't re-offer the same discount to repeat cancellers." ;
    oc:hasRationale "Save rate alone is a vanity metric if saved customers cancel shortly after. True retention measurement requires tracking post-save behavior over 60-90 days." ;
    oc:severityLevel "HIGH" .

oc:kn_e16611e3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building a comprehensive churn prevention strategy" ;
    oc:directiveContent "Always address both voluntary churn (cancel flows, save offers) and involuntary churn (dunning, smart retries). Voluntary churn is typically 50-70% of total, but involuntary churn (30-50%) is often easier to fix with proper dunning infrastructure." ;
    oc:hasRationale "Ignoring either type of churn leaves significant recoverable revenue on the table. Involuntary churn recovery often has higher ROI than voluntary churn interventions." ;
    oc:severityLevel "HIGH" .

oc:kn_e9492f25 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any cancel flow" ;
    oc:directiveContent "Never use dark patterns like hiding the cancel button, requiring a phone call for online signups, or adding excessive steps to discourage cancellation. Always show a clear 'continue cancelling' option at every step." ;
    oc:hasRationale "Dark patterns breed resentment, generate bad reviews, and may violate FTC Click-to-Cancel regulations. They also damage long-term brand trust and word-of-mouth." ;
    oc:severityLevel "CRITICAL" .

