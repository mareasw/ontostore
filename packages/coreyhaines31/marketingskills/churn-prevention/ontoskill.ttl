    oc:stepDependsOn _:ref_fce63f575ed534f4 ;
    oc:stepId "setup-dunning" .

_:ref_c5622e65d8116a22 a oc:WorkflowStep ;
    dcterms:description "Write 4-email dunning sequence with escalating urgency: friendly alert (Day 0), reminder (Day 3), urgency (Day 7), final warning (Day 10). Use plain text, direct payment links, and no-blame language." ;
    oc:expectedOutcome "Dunning email sequence driving 50-60% overall payment recovery" ;
    oc:stepDependsOn _:ref_5039a44b715a65ad ;
    oc:stepId "create-dunning-emails" .

_:ref_6f85c42a3762997f a oc:WorkflowStep ;
    dcterms:description "Add fallback offers, implement pause subscription, enable MRR-based routing for high-value accounts, and segment flows by plan/tenure/usage" ;
