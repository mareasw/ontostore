oc:skill_coreyhaines31_marketingskills_churn_prevention_cancel_flow_patterns a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "cancel-flow-patterns" ;
    skos:broader "Reference pattern library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/churn-prevention" ;
    oc:contentHash "bd4f9eb09757189e4fe4f849c708731a307508e8765c3345639480c222378120" ;
    oc:dependsOnSkill oc:skill_churn_prevention ;
    oc:differentia "provides detailed cancel flow designs segmented by business type, billing interval, save offer strategy, and customer segment with compliance guidance" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_churn_prevention ;
    oc:handlesFailure oc:ComplianceViolation,
        oc:InvalidBusinessType ;
    oc:hasArgumentHint "business type (B2C, B2B, freemium) or cancel flow component (save offer, post-cancel, segmentation)" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_5629a7f4,
        oc:kn_6f69d2dd,
        oc:kn_70b7641c,
        oc:kn_a11cc8a7,
        oc:kn_a126f5e3,
        oc:kn_c12135c0,
        oc:kn_ddc656d2 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:CancellationIntent,
        oc:SubscriptionActive ;
    oc:resolvesIntent "build post-cancel win-back experience",
        "create save offer strategy for cancellations",
        "design cancel flow by business type",
        "ensure cancel flow compliance with FTC and GDPR",
        "handle competitor switch cancellations",
        "implement discount ladder for retention",
        "segment cancel flows by customer profile",
        "set up pause subscription option" ;
    oc:yieldsState oc:CancelFlowDesigned,
        oc:PostCancelSequencePlanned,
        oc:SaveOffersMapped .

oc:kn_5629a7f4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When segmenting cancel flow responses by customer lifecycle stage" ;
    oc:directiveContent "For new customers (<30 days), the save is onboarding not discounts — offer free onboarding calls, setup help, or extended trials. For dormant customers (30+ days no login), offer pause rather than discount since they forgot about the product." ;
    oc:hasRationale "New customers haven't activated yet so price isn't the issue. Dormant customers won't be saved by discounts because the core problem is lack of engagement." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6f69d2dd a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning cancel flow implementation timeline" ;
    oc:directiveContent "Implement cancel flows in 3 phases: Foundation (week 1 — survey + 1 offer + tracking), Optimization (weeks 2-4 — fallback offers + pause + dunning + MRR routing), Advanced (month 2+ — health scores + A/B testing + segmentation + win-back sequences)." ;
    oc:hasRationale "Progressive rollout avoids over-engineering on day one while ensuring basic retention data is captured immediately. Optimization and advanced features build on foundational learning." ;
    oc:severityLevel "MEDIUM" .

oc:kn_70b7641c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any cancellation flow" ;
    oc:directiveContent "Never hide the cancel button, require a phone call for online signups, add excessive steps, or fail to show a clear 'continue cancelling' option at every step of the save flow." ;
    oc:hasRationale "Dark patterns violate FTC click-to-cancel rules, create vocal detractors, and damage brand trust. Compliance violations can result in regulatory action." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a11cc8a7 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When configuring pause options and error handling in cancel flows" ;
    oc:directiveContent "Pause durations longer than 3 months rarely result in reactivation. Repeat discount offers to the same customer train cancel-for-discount behavior. Process cancellation even if the save flow has errors." ;
    oc:hasRationale "Long pauses indicate disengagement unlikely to reverse. Re-offering discounts to repeat cancellers is economically wasteful. Save flow errors must never block a legitimate cancellation request." ;
    oc:severityLevel "HIGH" .

oc:kn_a126f5e3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing save offers for any cancel flow" ;
    oc:directiveContent "Never lead with your biggest discount. Use a discount ladder that escalates from a smaller offer (15%) to a larger one (25%), with a maximum of 2 discount offers per cancel session and never exceeding 30%." ;
    oc:hasRationale "Leading with the biggest discount trains customers to cancel-for-discount behavior and devalues the product. Escalation preserves margin while still attempting to save." ;
    oc:severityLevel "HIGH" .

oc:kn_c12135c0 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When designing the post-cancel customer experience" ;
    oc:directiveContent "Post-cancel experience directly impacts win-back potential, word of mouth, and review sentiment. Preserve data for 90 days post-cancel and send a structured re-engagement sequence at days 7, 30, 60, and 90." ;
    oc:hasRationale "A positive post-cancel experience preserves the relationship for future win-back. The day-60 message addressing their specific cancel reason is the highest-converting win-back touchpoint." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ddc656d2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing B2B or team plan cancel flows" ;
    oc:directiveContent "Route accounts above $500 MRR to customer success before cancel completes, and block self-serve cancel entirely for accounts above $2,000 MRR. Only allow admin/owner roles to cancel team plans." ;
    oc:hasRationale "Higher-value accounts justify personal outreach with 30-45% save rates. Self-serve cancellation by non-admin team members creates operational chaos." ;
    oc:severityLevel "HIGH" .

