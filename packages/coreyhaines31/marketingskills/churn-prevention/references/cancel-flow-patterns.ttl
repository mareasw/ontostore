                                    oc:rowCount 4 ;
                                    oc:tableCaption "**MRR-based routing:**" ;
                                    oc:tableMarkdown """| Account MRR | Cancel Flow |
|-------------|-------------|
| <$100/mo | Automated flow with offers |
| $100-$500/mo | Automated + flag for CS follow-up |
| $500-$2,000/mo | Route to CS before cancel completes |
| $2,000+/mo | Block self-serve cancel, require CS call |
""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Lower volume, higher stakes. Personal outreach is worth the cost." ],
