                                    oc:sourceLocation "lines 69-71" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Users cancelling paid to return to free tier. Different psychology — they're not leaving, they're downgrading." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 4 ;
                                    oc:textContent "**Characteristics:**" ],
