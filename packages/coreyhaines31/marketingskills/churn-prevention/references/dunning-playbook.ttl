oc:skill_coreyhaines31_marketingskills_churn_prevention_dunning_playbook a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "dunning-playbook" ;
    skos:broader "playbook" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/churn-prevention" ;
    oc:contentHash "95afe21035cb81769ef0024de08806fec31073eb507a806f05b6b18b70e259a1" ;
    oc:differentia "provides a structured timeline, email templates, retry strategies, and provider-specific configurations for recovering failed subscription payments and reducing involuntary churn" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_churn_prevention ;
    oc:handlesFailure oc:HardDeclineUnrecoverable,
        oc:PaymentRecoveryFailed ;
    oc:hasArgumentHint "payment provider (e.g., Stripe, Chargebee, Recurly, Paddle)" ;
    oc:hasCategory "finance" ;
    oc:impartsKnowledge oc:kn_18bab9a8,
        oc:kn_23bb8356,
        oc:kn_27184fea,
        oc:kn_4a009136,
        oc:kn_696058b0,
        oc:kn_8d65c579,
        oc:kn_bca940c9,
        oc:kn_dd94b806 ;
    oc:isUserInvocable true ;
    oc:nature "concept" ;
    oc:requiresState oc:SubscriptionActive ;
    oc:resolvesIntent "configure smart retry strategies",
        "implement pre-dunning prevention",
        "manage grace periods after payment failure",
        "measure dunning performance",
        "recover failed payments",
        "reduce involuntary churn",
        "set up dunning email sequences" ;
    oc:yieldsState oc:DunningConfigured,
        oc:FailedPaymentRecoveryPlanReady .

oc:kn_18bab9a8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "During pre-dunning prevention setup" ;
    oc:directiveContent "Enable card updater services (Visa Account Updater, Mastercard ABU, Amex Cardrefresher) to automatically update stored card numbers and expiry dates. Pair with pre-dunning emails at 30, 15, 7, and 3 days before card expiry." ;
    oc:hasRationale "Card updater services reduce hard declines from expired/replaced cards by 30-50%, preventing failures before they occur." ;
    oc:severityLevel "HIGH" .

oc:kn_23bb8356 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When measuring dunning campaign performance" ;
    oc:directiveContent "Track recovery rate (target 50-60%), time to recovery (target <5 days), dunning email open rate (target 60%+), and involuntary churn as % of MRR (target 0.3-2% depending on company stage)." ;
    oc:hasRationale "Without these metrics, you cannot diagnose whether dunning is underperforming due to timing, messaging, or access policy issues." ;
    oc:severityLevel "MEDIUM" .

oc:kn_27184fea a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing the complete dunning communication strategy" ;
    oc:directiveContent "Supplement email dunning with in-app banners (every page load during dunning) and modals (final warning), always with a direct 'Update Payment Method' link requiring the fewest possible clicks." ;
    oc:hasRationale "Email open rates alone cannot drive maximum recovery; in-app notifications capture users who are actively engaged with the product." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4a009136 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any dunning system" ;
    oc:directiveContent "Use a graduated 14-day dunning timeline: pre-dunning prevention (Day -30 to -7), smart retries with escalating emails (Day 0-10), grace period (Day 10-14), then win-back (Day 14+)." ;
    oc:hasRationale "Failed payments cause 30-50% of all subscription churn, and a structured timeline recovers 50-60% of failed payments vs. ad-hoc approaches." ;
    oc:severityLevel "CRITICAL" .

oc:kn_696058b0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When processing payment failure response codes from payment providers" ;
    oc:directiveContent "Classify decline codes into soft (retry: insufficient_funds, generic card_declined, processing_error) vs. hard (stop retrying: expired_card, stolen_card) and handle authentication_required separately via SCA/3DS." ;
    oc:hasRationale "Retrying hard declines wastes attempts and damages the relationship; soft declines are recoverable with optimal timing." ;
    oc:severityLevel "HIGH" .

oc:kn_8d65c579 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before implementing a dunning system" ;
    oc:directiveContent "Before launching dunning, ensure webhook handlers are configured for invoice.payment_failed, invoice.paid, and customer.subscription.deleted events on your payment provider." ;
    oc:hasRationale "Webhooks are the trigger mechanism for dunning workflows; missing events means missed recovery opportunities or stale account states." ;
    oc:severityLevel "CRITICAL" .

oc:kn_bca940c9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring retry schedules" ;
    oc:directiveContent "Use provider smart retry features (e.g., Stripe Smart Retries) over fixed schedules. If manual, retry on same day of month as original success, after paydays (1st/15th), on weekdays, and in the morning (8-10am local time)." ;
    oc:hasRationale "ML-based smart retries recover ~15% more than fixed-schedule retries by leveraging billions of transaction patterns." ;
    oc:severityLevel "MEDIUM" .

oc:kn_dd94b806 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding access degradation strategy during grace period" ;
    oc:directiveContent "Never immediately lock out users on payment failure. Instead, provide full access during grace period (B2B) or read-only access (B2C), with in-app banners and direct update links." ;
    oc:hasRationale "Immediate lockout is aggressive, damages the customer relationship, and yields lower recovery rates. Degraded access maintains trust while creating urgency." ;
    oc:severityLevel "HIGH" .

