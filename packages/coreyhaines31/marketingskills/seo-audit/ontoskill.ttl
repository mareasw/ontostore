oc:skill_coreyhaines31_marketingskills_seo_audit a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "seo-audit" ;
    skos:broader "Diagnostic framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/seo-audit" ;
    oc:contentHash "aba537a6a9ef5c9dfeecd995023c1d072e34da31534e55b8ae22b7a6f53c917d" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "that systematically evaluates a website's search engine optimization across technical, on-page, content, and authority dimensions to identify issues and produce a prioritized remediation plan" ;
    oc:handlesFailure oc:InsufficientAccess,
        oc:PermissionDenied,
        oc:SiteUnreachable ;
    oc:hasAlias "seo-health-check",
        "seo-review",
        "technical-seo-audit" ;
    oc:hasAllowedTool "Bash",
        "Glob",
        "Read",
        "Write",
        "web_fetch" ;
    oc:hasArgumentHint "site-url or domain to audit, optionally with specific pages or focus areas" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to audit, review, or diagnose SEO issues on their site. Also use when the user mentions \"SEO audit,\" \"technical SEO,\" \"why am I not ranking,\" \"SEO issues,\" \"on-page SEO,\" \"meta tags review,\" \"SEO health check,\" \"my traffic dropped,\" \"lost rankings,\" \"not showing up in Google,\" \"site isn't ranking,\" \"Google update hit me,\" \"page speed,\" \"core web vitals,\" \"crawl errors,\" or \"indexing issues.\" Use this even if the user just says something vague like \"my SEO is bad\" or \"help with SEO\" — start with an audit. For building pages at scale to target keywords, see programmatic-seo. For adding structured data, see schema-markup. For AI search optimization, see ai-seo." ;
    oc:hasName "seo-audit" ;
    oc:impartsKnowledge oc:kn_0863a83f,
        oc:kn_589c7911,
        oc:kn_6c044d4c,
        oc:kn_adea9f5f,
        oc:kn_b5358fd1,
        oc:kn_da22f40d,
        oc:kn_e0a61502 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:NetworkAvailable,
        oc:SiteUrlProvided ;
    oc:resolvesIntent "assess Core Web Vitals and page speed",
        "audit site SEO health",
        "check crawlability and indexation",
        "diagnose ranking problems",
        "diagnose traffic drops",
        "evaluate content quality and E-E-A-T signals",
        "identify on-page SEO issues",
        "review meta tags and heading structure",
        "review technical SEO issues" ;
    oc:yieldsState oc:PrioritizedActionPlanCreated,
        oc:SEOAuditCompleted .

oc:kn_0863a83f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When checking for structured data / schema markup during any SEO audit" ;
    oc:directiveContent "Never report 'no schema found' based solely on web_fetch or curl output. These tools strip <script> tags including JSON-LD and cannot detect JS-injected schema markup." ;
    oc:hasRationale "Many CMS plugins inject JSON-LD client-side via JavaScript, which static HTML fetches cannot see. Reporting false negatives undermines audit credibility and leads to incorrect recommendations." ;
    oc:severityLevel "CRITICAL" .

oc:kn_589c7911 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When considering re-running audits or scheduling periodic checks" ;
    oc:directiveContent "SEO audits are read-only diagnostic procedures. Running the audit multiple times does not modify the target site. However, findings may change as the site evolves between runs." ;
    oc:hasRationale "Understanding that audits are non-destructive allows safe re-execution for tracking progress over time, but agents should know results may vary." ;
    oc:severityLevel "LOW" .

oc:kn_6c044d4c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When formatting and delivering audit results" ;
    oc:directiveContent "Structure audit findings with five components per issue: Issue (what's wrong), Impact (High/Medium/Low), Evidence (how you found it), Fix (specific recommendation), and Priority level." ;
    oc:hasRationale "Structured findings enable stakeholders to understand severity, validate the diagnosis, take specific action, and prioritize work — rather than receiving a vague list of problems without clear next steps." ;
    oc:severityLevel "MEDIUM" .

oc:kn_adea9f5f a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When schema detection is part of the audit scope" ;
    oc:directiveContent "For schema markup validation, use Google Rich Results Test, browser tool document.querySelectorAll, or Screaming Frog exports instead of relying on web_fetch or curl." ;
    oc:hasRationale "These alternative methods render JavaScript and can capture dynamically-injected JSON-LD, providing accurate schema detection where static fetch tools fail." ;
    oc:severityLevel "HIGH" .

oc:kn_b5358fd1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When tailoring the audit to the client's specific site type" ;
    oc:directiveContent "Apply site-type-specific audit frameworks: SaaS sites need comparison/alternative pages and feature page depth; e-commerce needs faceted navigation control and product schema; blogs need topical clustering and author pages; local businesses need NAP consistency and location pages." ;
    oc:hasRationale "Generic audits miss critical issues unique to each site type. Site-type-specific patterns account for the most common and impactful problems seen in practice for each category." ;
    oc:severityLevel "MEDIUM" .

oc:kn_da22f40d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When conducting any SEO audit, regardless of site type or scope" ;
    oc:directiveContent "Always follow the priority order: Crawlability & Indexation → Technical Foundations → On-Page Optimization → Content Quality → Authority & Links. Fix blocking issues before optimizing further down the chain." ;
    oc:hasRationale "If Google cannot crawl or index the site, no amount of on-page optimization or content improvement will matter. The priority order reflects the dependency chain of SEO effectiveness." ;
    oc:severityLevel "HIGH" .

oc:kn_e0a61502 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any SEO audit" ;
    oc:directiveContent "Check for product-marketing-context.md (.agents/ or .claude/) before starting the audit. Read it to avoid asking questions already answered there." ;
    oc:hasRationale "Product marketing context provides essential business context (site type, goals, target keywords, competitors) that reduces redundant questions and enables more targeted audit recommendations." ;
    oc:severityLevel "HIGH" .

