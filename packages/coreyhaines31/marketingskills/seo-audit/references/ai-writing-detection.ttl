                                            oc:itemOrder 3 ;
                                            oc:itemText "\"By [doing X], you can [achieve Y]...\"" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Concluding Phrases to Avoid" ],
