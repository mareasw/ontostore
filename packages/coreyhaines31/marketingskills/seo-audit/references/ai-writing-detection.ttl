    oc:requiresState oc:ContentDrafted ;
    oc:resolvesIntent "avoid common AI writing tells",
        "detect AI writing patterns",
        "identify AI-generated text markers",
        "improve writing to sound more human" ;
    oc:yieldsState oc:ContentReviewed .

oc:kn_4719c4b6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or editing academic, technical, or formal content" ;
    oc:directiveContent "Academic writing has additional AI tells: avoid 'shed light on', 'pave the way for', 'a myriad of', 'a plethora of', 'paramount', 'pertaining to', 'prior to', 'subsequent to', 'in light of', 'with respect to', 'in terms of', 'the fact that'. Use plain alternatives." ;
    oc:hasRationale "AI models default to these inflated academic phrases when generating formal content, making them strong detection signals in scholarly contexts" ;
    oc:severityLevel "MEDIUM" .

oc:kn_5784bebc a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When self-checking content for AI-sounding patterns" ;
    oc:directiveContent "1. Read text aloud — if phrases sound unnatural in speech, revise. 2. Ask 'Would I say this to a colleague?' 3. Check for repetitive sentence structures. 4. Look for clusters of AI-typical words. 5. Ensure varied sentence lengths. 6. Verify each intensifier adds genuine meaning." ;
    oc:hasRationale "Human speech patterns are the most reliable benchmark for natural-sounding writing" ;
    oc:severityLevel "HIGH" ;
    oc:stepOrder 1 .

oc:kn_6b79de93 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or editing any content" ;
    oc:directiveContent "Avoid these AI-typical verbs: delve, leverage, optimise, utilise, facilitate, foster, bolster, underscore, unveil, navigate, streamline, enhance, endeavour, ascertain, elucidate. Use plain alternatives like explore, use, improve, help, explain." ;
    oc:hasRationale "These verbs are statistically overrepresented in AI output and immediately signal machine-written text" ;
    oc:severityLevel "HIGH" .

oc:kn_8c0d2e0b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or editing any content" ;
    oc:directiveContent "Avoid AI-typical adjectives: robust, comprehensive, pivotal, crucial, vital, transformative, cutting-edge, groundbreaking, innovative, seamless, intricate, nuanced, multifaceted, holistic. Use simpler, specific alternatives." ;
    oc:hasRationale "These adjectives are filler words that AI defaults to when being emphatic, making text sound generic and machine-generated" ;
    oc:severityLevel "HIGH" .

oc:kn_ae876417 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing and trimming content" ;
    oc:directiveContent "Remove filler words and empty intensifiers that add no meaning: absolutely, actually, basically, certainly, clearly, definitely, essentially, extremely, fundamentally, incredibly, interestingly, naturally, obviously, quite, really, significantly, simply, surely, truly, ultimately, undoubtedly, very." ;
    oc:hasRationale "These words inflate text without adding information, a hallmark of AI padding output to meet length requirements" ;
    oc:severityLevel "MEDIUM" .

oc:kn_affaaaa6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or editing any content" ;
    oc:directiveContent "Avoid formulaic opening phrases ('In today's fast-paced world...', 'Imagine a world where...'), transitional crutches ('That being said...', 'At its core...'), concluding patterns ('In conclusion...', 'All things considered...'), and structural patterns like three-item 'Whether you're X, Y, or Z' constructions." ;
    oc:hasRationale "These phrase templates are among the most recognizable AI writing signatures and make text feel templated rather than authentic" ;
    oc:severityLevel "HIGH" .

oc:kn_b145d771 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or editing any content" ;
    oc:directiveContent "Em dashes (—) are the single most reliable marker of AI-generated text. AI models drastically overuse them. Use commas, colons, or parentheses instead. Reserve em dashes for rare, deliberate emphasis — no more than one per page." ;
    oc:hasRationale "AI models overuse em dashes as a shortcut for sentence variety, making them an unofficial signature of ChatGPT writing" ;
    oc:severityLevel "CRITICAL" .

_:ref_19d3082af7ac4400 a oc:WorkflowStep ;
    dcterms:description "Look for clusters of the words listed above" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_372488e92525928c a oc:WorkflowStep ;
    dcterms:description "Ask: \"Would I say this in a conversation with a colleague?\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_9f6b34154eedee18 a oc:WorkflowStep ;
    dcterms:description "Check for repetitive sentence structures" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

