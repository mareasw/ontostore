@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_seo_audit_ai_writing_detection a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ai-writing-detection" ;
    skos:broader "Writing quality reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/seo-audit" ;
    oc:contentHash "f1e273f56ce7e2215ff218bf903680ddcec0fd026ab90c3ebfb3439ed0edfaa4" ;
    oc:differentia "catalogs AI-generated text patterns (em dashes, overused verbs, filler phrases) with human alternatives to ensure natural-sounding content during SEO audits" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_seo_audit ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "text content to check for AI writing patterns" ;
    oc:hasCategory "research" ;
    oc:impartsKnowledge oc:kn_0bf75c09,
        oc:kn_43f547a8,
        oc:kn_cf23df54,
        oc:kn_eec4d7d7,
        oc:kn_f20ec78a ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "detect AI writing patterns in content",
        "improve writing naturalness for SEO content",
        "replace AI-sounding phrases with natural alternatives",
        "self-check content for AI-generated tells" ;
    oc:yieldsState oc:ContentReviewed .

oc:kn_0bf75c09 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting or editing any marketing or SEO content" ;
    oc:directiveContent "Never use the following AI-signature verbs: delve, leverage, utilise, facilitate, foster, bolster, underscore, unveil, streamline, elucidate. Replace with simpler, more direct alternatives (explore, use, help, encourage, strengthen, highlight, reveal, simplify, explain)." ;
    oc:hasRationale "These Latinate verbs are statistically overrepresented in LLM output and immediately signal AI authorship to readers and detection tools." ;
    oc:severityLevel "HIGH" .

oc:kn_43f547a8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After drafting or before publishing any content" ;
    oc:directiveContent "Self-check content using these tests: (1) Read aloud — if phrases sound unnatural in speech, revise them. (2) Ask 'Would I say this to a colleague?' (3) Check for repetitive sentence structures. (4) Look for clusters of AI-typical words. (5) Ensure varied sentence lengths. (6) Verify each intensifier adds genuine meaning." ;
    oc:hasRationale "These heuristic checks catch the subtle patterns that make AI-generated text feel mechanical, even when individual words are changed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cf23df54 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing or proofreading any content" ;
    oc:directiveContent "Eliminate filler words and empty intensifiers that add no meaning: absolutely, basically, certainly, clearly, definitely, essentially, fundamentally, incredibly, obviously, really, significantly, simply, truly, ultimately, undoubtedly, very. Verify each intensifier adds genuine meaning or remove it." ;
    oc:hasRationale "LLMs pad output with these intensifiers to sound authoritative, but they dilute meaning and make text sound bloated and unnatural. Human writers who are concise are more persuasive." ;
    oc:severityLevel "MEDIUM" .

oc:kn_eec4d7d7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or editing any content intended to sound human" ;
    oc:directiveContent "Avoid em dashes as a primary punctuation device — they are the most reliable single marker of AI-generated content. Use commas, colons, or parentheses instead. Reserve em dashes for rare, deliberate emphasis only, never more than one per page." ;
    oc:hasRationale "AI models overuse em dashes as a shortcut for sentence variety because their training data (edited books, academic papers) features them heavily. Most human writers rarely use em dashes since they lack a dedicated keyboard key." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f20ec78a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing introductions, transitions, or conclusions in any content" ;
    oc:directiveContent "Avoid AI-typical opening, transitional, and concluding phrases: 'In today's fast-paced world...', 'That being said...', 'In conclusion...', 'Imagine a world where...', 'It's worth mentioning that...', 'At the end of the day...'. Also avoid structural patterns like 'Whether you're a [X], [Y], or [Z]...' and 'By [gerund], you can [achieve Y]...'" ;
    oc:hasRationale "These phrases are generated with high frequency by LLMs and are widely recognized as AI tells. They make writing sound formulaic rather than authentic." ;
    oc:severityLevel "HIGH" .

