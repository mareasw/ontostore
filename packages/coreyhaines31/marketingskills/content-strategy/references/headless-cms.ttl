oc:kn_06fb6769 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any page-level content type" ;
    oc:directiveContent "Every page-level content type must include SEO fields: metaTitle (50-60 chars), metaDescription (150-160 chars), ogImage (1200x630px), slug, canonicalUrl, noIndex, and optional structuredData JSON-LD." ;
    oc:hasRationale "Missing SEO fields cause pages to be unoptimizable at the template level, creating retrofitting debt" ;
    oc:severityLevel "HIGH" .

oc:kn_1d55bb5d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When setting up editorial workflows" ;
    oc:directiveContent "1. Draft — Author creates or edits content 2. Review — Editor reviews for accuracy, brand voice, SEO 3. Approve — Stakeholder signs off 4. Schedule — Set publish date/time 5. Publish — Content goes live via API" ;
    oc:stepOrder 2 .

oc:kn_2f68fb40 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing content models for any headless CMS" ;
    oc:directiveContent "Think in types, not pages. A Landing Page is a content type with fields, not an HTML file. This enables component reuse across pages." ;
    oc:hasRationale "Content types enable structured querying, programmatic page generation, and multi-channel content reuse" .

oc:kn_30aefb7b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When implementing a headless CMS for marketing content" ;
    oc:directiveContent "1. Define content types based on page types and reusable blocks 2. Add SEO fields to every page-level content type 3. Set up preview/draft mode in frontend 4. Configure roles and permissions for team 5. Create sample content for each type before building frontend 6. Set up webhook notifications for content changes 7. Document content guidelines for editors 8. Test content delivery performance (CDN, caching, ISR) 9. Plan migration strategy if moving from existing CMS" ;
    oc:stepOrder 1 .

oc:kn_45de066e a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When evaluating headless CMS platforms" ;
    oc:directiveContent "Sanity has steeper learning curve for non-developers and vendor lock-in on GROQ queries. Contentful pricing scales with content types/locales and rate limits are tight on lower plans. Strapi self-hosting requires handling infrastructure and V5 migration from V4 can be significant." ;
    oc:hasRationale "Understanding trade-offs before committing prevents costly platform migrations later" ;
    oc:severityLevel "MEDIUM" .

oc:kn_74db8ba9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining content schemas" ;
    oc:directiveContent "Separate content from presentation. Store headline text, not styled headline. Keep models flat — prefer references over deep nesting." ;
    oc:hasRationale "Flat reference-based models are easier to query, maintain, and reuse across different frontends and channels" .

oc:kn_9d8ce35a a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When configuring CMS roles and permissions" ;
    oc:directiveContent """Role permissions matrix:
| Role | Can Create | Can Edit | Can Publish | Can Delete |
| Author | Yes | Own | No | Own drafts |
| Editor | Yes | All | Yes | Drafts |
| Admin | Yes | All | Yes | All |""" ;
    oc:templateVariables "Can Create",
        "Can Delete",
        "Can Edit",
        "Can Publish",
        "Role" .

oc:kn_a12a5f13 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining content type schemas for marketing sites" ;
    oc:codeLanguage "json" ;
    oc:directiveContent """Landing Page: {title, slug, hero, sections[], seo}
Blog Post: {title, slug, body, author, category, tags, publishedAt, seo}
Case Study: {title, customer, challenge, solution, results, metrics[], logo}
Testimonial: {quote, author, role, company, avatar, rating}
FAQ: {question, answer, category}
Author: {name, bio, avatar, socialLinks}
CTA Block: {heading, body, buttonText, buttonUrl, variant}""" .

oc:kn_c75416c8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a CMS platform for a new project" ;
    oc:directiveContent "Choose headless when: multiple frontends consume same content, developer wants full frontend control, content reuse across channels, modern framework in use. Choose traditional when: small team with no developers, simple brochure site, WYSIWYG is required, budget is tight." ;
    oc:hasRationale "Headless CMS adds complexity and longer time-to-launch; traditional CMS is faster for simple needs" .

oc:kn_f4e18d1c a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "When configuring preview/draft mode" ;
    oc:directiveContent "Sanity preview uses useLiveQuery or Presentation tool. Contentful uses preview.contentful.com with separate access token. Strapi uses status=draft query parameter (v5). Set up /api/preview route in frontend for draft rendering." .

_:ref_01455e61ad9b32e2 a oc:WorkflowStep ;
    dcterms:description "**Draft** — Author creates or edits content" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_1b7593d04c7bb2f7 a oc:WorkflowStep ;
    dcterms:description "**Design for reuse.** If testimonials appear on 5 pages, create a Testimonial type and reference it — don't duplicate." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_205eba915d27dccf a oc:WorkflowStep ;
    dcterms:description "**Publish** — Content goes live via API" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_37857e51e008f743 a oc:WorkflowStep ;
    dcterms:description "**Approve** — Stakeholder signs off" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_4d10ff7459859de9 a oc:WorkflowStep ;
    dcterms:description "**Think in types, not pages.** A \"Landing Page\" is a content type with fields — not an HTML file. This lets you reuse components across pages." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_8f2be596ba7f259d a oc:WorkflowStep ;
    dcterms:description "**Schedule** — Set publish date/time" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_93d7f40b0e281976 a oc:WorkflowStep ;
    dcterms:description "**Review** — Editor reviews for accuracy, brand voice, SEO" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_9a08d53f3d0b952a a oc:WorkflowStep ;
    dcterms:description "**Separate content from presentation.** Store the headline text, not the styled headline. Presentation belongs in the frontend." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_d950af8c5bf881dc a oc:WorkflowStep ;
    dcterms:description "**Keep models flat.** Deeply nested structures are hard to query and maintain. Prefer references over nesting." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

