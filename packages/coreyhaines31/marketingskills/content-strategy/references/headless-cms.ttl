oc:skill_coreyhaines31_marketingskills_content_strategy_headless_cms a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "headless-cms" ;
    skos:broader "Content management guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/content-strategy" ;
    oc:contentHash "5434e226fd593a2e1174264c37b7cba589e60a82739deec0c29107b48f1ffae5" ;
    oc:differentia "that provides decision frameworks, content modeling patterns, and platform comparisons for headless CMS selection and implementation in marketing contexts" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_content_strategy ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_3198a715,
        oc:kn_46f762cc,
        oc:kn_7be0443d,
        oc:kn_7df715d6,
        oc:kn_c0ed55af,
