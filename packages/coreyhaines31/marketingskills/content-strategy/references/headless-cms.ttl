    oc:isUserInvocable true ;
    oc:nature "reference" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "choose a headless CMS platform",
        "compare headless CMS platforms",
        "design content models for marketing sites",
        "integrate headless CMS with programmatic SEO",
        "plan CMS migration strategy",
        "set up editorial workflows in a headless CMS",
        "structure SEO fields in a CMS content model" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_3198a715 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When preparing to launch a headless CMS implementation" ;
    oc:directiveContent "Before launch, verify: preview/draft mode works in frontend, roles and permissions match team structure, webhooks trigger rebuilds, content delivery is performant via CDN/caching/ISR, and migration strategy is documented." ;
    oc:hasRationale "These operational concerns are easy to overlook during development but cause immediate problems in production if missing" ;
    oc:severityLevel "MEDIUM" .

oc:kn_46f762cc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining field types and content structures" ;
    oc:directiveContent "Never store styled content or presentation markup in CMS fields. Store raw content (plain text, structured data) and let the frontend handle presentation." ;
    oc:hasRationale "Mixing content and presentation defeats the multi-channel purpose of headless CMS and creates maintenance burden when design changes" ;
    oc:severityLevel "HIGH" .

oc:kn_7be0443d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing content models for any headless CMS" ;
    oc:directiveContent "Think in content types, not pages. A 'Landing Page' is a content type with fields — not an HTML file. This enables component reuse across pages." ;
    oc:hasRationale "Content types decouple structure from presentation, enabling multi-channel delivery and programmatic page generation" ;
    oc:severityLevel "HIGH" .

oc:kn_7df715d6 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When implementing a new headless CMS for a marketing site" ;
    oc:directiveContent "Create sample content for each content type before building the frontend. Define all types based on page templates and reusable blocks first." ;
    oc:hasRationale "Building frontend against real content shapes catches modeling gaps early and prevents costly schema migrations after development is underway" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c0ed55af a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a CMS platform for a new project" ;
    oc:directiveContent "Choose headless CMS when multi-channel content delivery, developer frontend control, or content reuse are priorities. Choose traditional CMS when the team is small, non-technical, or needs fast time-to-launch." ;
    oc:hasRationale "Headless CMS adds complexity (separate frontend, preview setup, editorial workflow configuration) that only pays off when its strengths are actually needed" ;
    oc:severityLevel "HIGH" .

oc:kn_c2f515d8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring content relationships in a headless CMS" ;
    oc:directiveContent "Keep content models flat. Use references between types instead of deeply nested structures. If testimonials appear on multiple pages, create a Testimonial type and reference it." ;
    oc:hasRationale "Deeply nested structures are hard to query, maintain, and reuse across channels. Flat models with references are more flexible and performant" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e10226f5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining any content type that renders as a page" ;
    oc:directiveContent "Every page-level content type must include SEO fields: metaTitle (50-60 chars), metaDescription (150-160 chars), ogImage (1200x630px), slug, canonicalUrl, noIndex, and structuredData." ;
    oc:hasRationale "Missing SEO fields create invisible gaps that hurt search rankings and social sharing after content is already published" ;
    oc:severityLevel "CRITICAL" .

