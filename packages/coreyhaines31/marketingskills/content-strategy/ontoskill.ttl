oc:kn_25f341c3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning URL structure for content clusters" ;
    oc:directiveContent "Most content works fine under /blog. Only use dedicated hub/spoke URL structures for major topics with layered depth." ;
    oc:hasRationale "Over-engineering URL structures for thin topic clusters creates maintenance burden without SEO benefit." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4b8e1c5f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When performing keyword research or planning topic clusters" ;
    oc:directiveContent "Map topics to the buyer's journey: Awareness (what is, how to, guide) → Consideration (best, vs, alternatives) → Decision (pricing, reviews, demo) → Implementation (templates, tutorial, setup)." ;
    oc:hasRationale "Content that matches buyer intent at each stage moves prospects through the funnel." ;
    oc:severityLevel "HIGH" .

oc:kn_73d79888 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing forum and competitor research for content ideation" ;
    oc:directiveContent """Reddit: site:reddit.com [topic]
Quora: site:quora.com [topic]
Competitor: site:competitor.com/blog""" ;
    oc:hasRationale "These search operators surface real questions, frustrations, and content gaps from target audiences." .

oc:kn_7dfa66dc a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When outputting a content strategy" ;
    oc:directiveContent """## Content Pillars
{pillar_name} — {rationale}
  Subtopics: {subtopic_1}, {subtopic_2}, {subtopic_3}
  Product connection: {connection}

## Priority Topics
| Topic/Title | Type (Searchable/Shareable/Both) | Content Type | Target Keyword | Buyer Stage | Why This Topic |

## Topic Cluster Map
{visual or structured representation of content interconnections}""" ;
    oc:templateVariables "connection",
        "pillar_name",
        "rationale",
        "subtopic_1",
        "subtopic_2",
        "subtopic_3" .

oc:kn_8cdc35d1 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When running content ideation from multiple sources" ;
    oc:directiveContent "1. Analyze keyword exports for topic clusters, buyer stage, search intent, quick wins, and content gaps 2. Extract voice-of-customer from call transcripts (questions → FAQs, pain points → blog posts, objections → proactive content) 3. Mine survey responses for themes (30%+ mention = high priority) 4. Research forums (Reddit, Quora, HN) for FAQs, misconceptions, debates 5. Analyze competitor content for gaps and angles 6. Gather sales/support input on objections, questions, ticket patterns" ;
    oc:hasRationale "Multi-source ideation prevents echo chambers and surfaces high-impact topics from real customer signals." ;
    oc:stepOrder 2 .

oc:kn_94546309 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When scoring and prioritizing content ideas" ;
    oc:directiveContent """| Idea | Customer Impact (40%) | Content-Market Fit (30%) | Search Potential (20%) | Resources (10%) | Total |
|------|----------------------|-------------------------|----------------------|-----------------|-------|""" ;
    oc:templateVariables "Content-Market Fit",
        "Customer Impact",
        "Idea",
        "Resources",
        "Search Potential",
        "Total" .

oc:kn_970ceca9 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a full content strategy" ;
    oc:directiveContent "1. Check for product-marketing-context.md 2. Gather business context, customer research, current state, competitive landscape 3. Identify 3-5 content pillars using product-led, audience-led, search-led, or competitor-led approaches 4. Map topic clusters under each pillar using hub-and-spoke model 5. Score and prioritize ideas using weighted framework 6. Output pillars, priority topics, and topic cluster map" ;
    oc:hasRationale "Structured approach ensures strategy is research-backed and prioritized by business impact." ;
    oc:stepOrder 1 .

oc:kn_a59fa03c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating or planning any content piece" ;
    oc:directiveContent "Every piece of content must be searchable, shareable, or both. Prioritize in that order — search traffic is the foundation." ;
    oc:hasRationale "Searchable content captures existing demand; shareable creates demand. Search provides compounding returns." ;
    oc:severityLevel "HIGH" .

oc:kn_b877201e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user requests writing a specific blog post or content piece" ;
    oc:directiveContent "Do NOT write individual content pieces when using this skill — defer to copywriting skill for actual content creation." ;
    oc:hasRationale "This skill is for strategy and planning, not execution. Writing without strategy context leads to random content." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b91da8cc a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Before beginning any content strategy work" ;
    oc:directiveContent "Always check for product-marketing-context.md (.agents/ or .claude/) before asking questions. Use that context and only ask for information not already covered." ;
    oc:hasRationale "Avoids redundant questions and ensures strategy is grounded in existing product positioning." ;
    oc:severityLevel "HIGH" .

oc:kn_deb012a2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When prioritizing content ideas from any ideation source" ;
    oc:directiveContent "Score content ideas using weighted framework: Customer Impact (40%), Content-Market Fit (30%), Search Potential (20%), Resource Requirements (10%)." ;
    oc:hasRationale "Customer-validated ideas outperform purely SEO-driven ideas. Weighting reflects impact on business outcomes." ;
    oc:severityLevel "HIGH" .

