                                            oc:itemOrder 2 ;
                                            oc:itemText "Angles they're missing" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Find their content:** `site:competitor.com/blog`" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "5. Competitor Analysis" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
