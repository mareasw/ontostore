                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Common themes (30%+ mention = high priority)" ],
                                        [ a oc:BulletItem ;
