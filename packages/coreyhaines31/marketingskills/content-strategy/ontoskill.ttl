                                    oc:contentOrder 4 ;
                                    oc:textContent "**Quora:** `site:quora.com [topic]`" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Reddit:** `site:reddit.com [topic]`" ],
                                [ a oc:BulletList ;
