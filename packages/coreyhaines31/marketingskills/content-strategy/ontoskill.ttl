oc:skill_coreyhaines31_marketingskills_content_strategy a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "content-strategy" ;
    skos:broader "Marketing strategy skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/content-strategy" ;
    oc:contentHash "46cd88262d8cae5f9f23a5aee1489fbeaad52b4e78bc0a426cb27c8f9bf0f1ae" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "Plans content pillars, topic clusters, and editorial priorities by mapping searchable and shareable content types to buyer stages with a weighted prioritization framework" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasAlias "blog-strategy",
        "content-planning",
        "content-roadmap",
        "editorial-calendar",
        "topic-clusters" ;
    oc:hasAllowedTool "Glob",
        "Read",
        "WebSearch" ;
    oc:hasArgumentHint "business description, audience, or content goals (or product-marketing-context.md file)" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to plan a content strategy, decide what content to create, or figure out what topics to cover. Also use when the user mentions \"content strategy,\" \"what should I write about,\" \"content ideas,\" \"blog strategy,\" \"topic clusters,\" \"content planning,\" \"editorial calendar,\" \"content marketing,\" \"content roadmap,\" \"what content should I create,\" \"blog topics,\" \"content pillars,\" or \"I don't know what to write.\" Use this whenever someone needs help deciding what content to produce, not just writing it. For writing individual pieces, see copywriting. For SEO-specific audits, see seo-audit. For social media content specifically, see social-content." ;
    oc:hasName "content-strategy" ;
    oc:hasRequirement oc:req_083dd2eb,
        oc:req_29be7cba,
        oc:req_78f3086b,
        oc:req_c4aa48dd ;
    oc:impartsKnowledge oc:kn_1945a0cc,
        oc:kn_1bade737,
        oc:kn_8ba41f57,
        oc:kn_8bd1de89,
        oc:kn_a0f30a2b,
        oc:kn_a37fbf7d,
        oc:kn_e5fbf52b ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "audit and restructure existing content",
        "build editorial calendar and content roadmap",
        "decide what content to create",
        "identify content pillars and topic clusters",
        "map content to buyer journey stages",
        "plan content strategy",
        "prioritize content ideas by impact",
        "research content ideation sources" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_1945a0cc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When establishing the foundational content strategy" ;
    oc:directiveContent "Identify 3-5 content pillars using four lenses: product-led (problems solved), audience-led (ICP learning needs), search-led (topic volume), and competitor-led (rival coverage)." ;
    oc:hasRationale "Multi-lens pillar identification ensures pillars are simultaneously commercially relevant, audience-aligned, discoverable, and differentiated from competitors." ;
    oc:severityLevel "HIGH" .

oc:kn_1bade737 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When prioritizing a list of content ideas or topics" ;
    oc:directiveContent "Score content ideas using the weighted framework: Customer Impact (40%), Content-Market Fit (30%), Search Potential (20%), Resource Requirements (10%)." ;
    oc:hasRationale "This weighting reflects that content serving real customer needs with product alignment outweighs pure search volume or resource convenience, producing higher-ROI content." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8ba41f57 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing URL structures and content hierarchy" ;
    oc:directiveContent "Most content works fine under /blog with good internal linking. Dedicated pillar pages with custom URL structures (like /guides/topic) are only needed for major topics with multiple layers of depth." ;
    oc:hasRationale "Over-engineering URL structures for small topic sets creates unnecessary complexity. Reserve custom structures for genuinely deep, multi-layer content resources." ;
    oc:severityLevel "LOW" .

oc:kn_8bd1de89 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any content strategy planning" ;
    oc:directiveContent "Always check for .agents/product-marketing-context.md (or .claude/product-marketing-context.md) before asking questions. Use that context and only ask for information not already covered." ;
    oc:hasRationale "Product marketing context contains business, audience, and competitive information that prevents redundant questions and ensures strategy is grounded in existing organizational knowledge." ;
    oc:severityLevel "HIGH" .

oc:kn_a0f30a2b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating or planning any content piece" ;
    oc:directiveContent "Every piece of content must be searchable, shareable, or both. Prioritize searchable content first since search traffic is the foundation." ;
    oc:hasRationale "Searchable content captures existing demand with compounding returns; shareable content creates demand but is less predictable. Building on a search foundation ensures sustainable traffic." ;
    oc:severityLevel "HIGH" .

oc:kn_a37fbf7d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When building topic clusters or editorial calendars" ;
    oc:directiveContent "Map every content topic to a buyer stage using keyword modifiers: awareness (what is, how to), consideration (best, vs, alternatives), decision (pricing, reviews), implementation (templates, tutorial)." ;
    oc:hasRationale "Buyer-stage mapping ensures content coverage across the full customer journey, preventing gaps where prospects lose interest or can't find decision-stage content." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e5fbf52b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a user asks to write a specific blog post or content piece" ;
    oc:directiveContent "Do not write individual content pieces when using this skill. Defer to the copywriting skill for actual content creation. This skill plans strategy, not production." ;
    oc:hasRationale "Content strategy determines what to create and why; copywriting determines how to write it. Mixing the two leads to either shallow strategy or unfocused writing." ;
    oc:severityLevel "MEDIUM" .

oc:req_083dd2eb a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Buyer journey stages (awareness, consideration, decision, implementation)" .

oc:req_29be7cba a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "SEO keyword research concepts" .

oc:req_78f3086b a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Content pillar and hub-and-spoke methodology" .

oc:req_c4aa48dd a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "Web search for competitor and forum research" .

