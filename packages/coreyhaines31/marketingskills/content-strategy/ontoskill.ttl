                                            oc:itemOrder 3 ;
                                            oc:itemText "Support ticket patterns" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Repeated questions" ] ] ;
                            oc:sectionLevel 3 ;
