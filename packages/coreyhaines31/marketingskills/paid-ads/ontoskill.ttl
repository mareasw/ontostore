@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_paid_ads a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "paid-ads" ;
    skos:broader "performance marketing methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/paid-ads" ;
    oc:contentHash "6732502d53652fc0b7e44502142d4572da4ccd93c5224c609d444ae216e31297" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "provides campaign strategy, platform selection, audience targeting, bidding optimization, and retargeting frameworks for paid advertising across Google Ads, Meta, LinkedIn, Twitter/X, and TikTok" ;
    oc:handlesFailure oc:ConversionTrackingMissing,
        oc:InsufficientBudget,
        oc:InvalidTargeting,
        oc:LandingPageNotReady ;
    oc:hasArgumentHint "platform, budget, campaign objective, landing page URL" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants help with paid advertising campaigns on Google Ads, Meta (Facebook/Instagram), LinkedIn, Twitter/X, or other ad platforms. Also use when the user mentions 'PPC,' 'paid media,' 'ROAS,' 'CPA,' 'ad campaign,' 'retargeting,' 'audience targeting,' 'Google Ads,' 'Facebook ads,' 'LinkedIn ads,' 'ad budget,' 'cost per click,' 'ad spend,' or 'should I run ads.' Use this for campaign strategy, audience targeting, bidding, and optimization. For bulk ad creative generation and iteration, see ad-creative. For landing page optimization, see page-cro." ;
    oc:hasName "paid-ads" ;
    oc:impartsKnowledge oc:kn_180ee441,
        oc:kn_77b495b1,
        oc:kn_81ae498e,
        oc:kn_86c7405a,
        oc:kn_8e5a71ff,
        oc:kn_f5ab85c2,
        oc:kn_f91175c4,
        oc:kn_f94e25e7 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady,
        oc:ProductMarketingContextAvailable ;
    oc:resolvesIntent "create paid ad campaign strategy",
        "optimize existing ad campaigns for better ROAS and lower CPA",
        "plan ad budgets and bid strategies",
        "select the right ad platform for a target audience",
        "set up audience targeting and retargeting strategies",
        "set up conversion tracking and pre-launch checklists",
        "structure ad campaigns with proper account organization and naming conventions",
        "troubleshoot underperforming ad campaigns" ;
    oc:yieldsState oc:AdCampaignLaunched,
        oc:AudienceTargetingConfigured,
        oc:CampaignStrategyCreated .

oc:kn_180ee441 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the user requests generating many ad copy variations or creative at scale" ;
    oc:directiveContent "Do not attempt bulk ad creative generation (headlines, descriptions, primary text for multiple angles) within this skill — delegate to the ad-creative skill which is purpose-built for that task." ;
    oc:hasRationale "This skill covers campaign strategy and optimization; bulk creative generation has its own dedicated skill with platform-specific templates and character limits." ;
    oc:severityLevel "LOW" .

oc:kn_77b495b1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing ad campaign budgets and structure" ;
    oc:directiveContent "Never launch campaigns without conversion tracking, fragment budget across too many campaigns, make large budget changes that disrupt algorithm learning, or stop campaigns during the learning phase." ;
    oc:hasRationale "These mistakes prevent the platform algorithms from optimizing and produce unreliable performance data, leading to poor decisions." ;
    oc:severityLevel "HIGH" .

oc:kn_81ae498e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When troubleshooting campaign performance issues" ;
    oc:directiveContent "Diagnose underperforming campaigns systematically: high CPA → check landing page first (post-click problem), then tighten targeting, then test new creative; low CTR → creative/audience mismatch; high CPM → audience too narrow or high competition." ;
    oc:hasRationale "Most performance issues follow predictable patterns; systematic diagnosis avoids wasted time and incorrect optimizations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_86c7405a a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When analyzing ad campaign reporting and attribution" ;
    oc:directiveContent "Platform-reported attribution is inflated. Always use UTM parameters consistently, compare platform data against GA4, and evaluate blended CAC rather than relying solely on platform-reported CPA." ;
    oc:hasRationale "Platforms take credit for conversions they influenced but did not solely cause, leading to over-optimistic ROI calculations and poor budget allocation decisions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8e5a71ff a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring audience targeting on any ad platform" ;
    oc:directiveContent "Always exclude existing customers, recent converters (7-14 days), bounced visitors (<10 sec), and irrelevant page visitors (careers, support) from prospecting campaigns. Build lookalike audiences based on highest-LTV customers, not all customers." ;
    oc:hasRationale "Failure to exclude wastes spend on non-converting or already-converted users. Lookalikes based on low-value customers produce low-value leads." ;
    oc:severityLevel "HIGH" .

oc:kn_f5ab85c2 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before launching any paid ad campaign on any platform" ;
    oc:directiveContent "Always verify conversion tracking is tested with a real conversion, landing page loads in under 3 seconds, landing page is mobile-friendly, UTM parameters are working, budget is set correctly, and targeting matches the intended audience before launching any campaign." ;
    oc:hasRationale "Launching without proper tracking or landing page readiness wastes ad spend and produces unreliable data that cannot be optimized." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f91175c4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scaling or testing ad campaigns" ;
    oc:directiveContent "Increase budgets by only 20-30% at a time and wait 3-5 days between increases to allow algorithm learning. During testing phase (first 2-4 weeks), allocate 70% to proven campaigns and 30% to testing new audiences/creative." ;
    oc:hasRationale "Gradual budget increases prevent algorithm reset; the 70/30 split balances risk while enabling discovery of winning combinations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f94e25e7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing which ad platform(s) to advertise on" ;
    oc:directiveContent "Select platforms based on audience-intent alignment: Google Ads for high-intent search traffic, Meta for demand generation and visual products, LinkedIn for B2B decision-maker targeting, TikTok for younger demographics (18-34) with video capacity." ;
    oc:hasRationale "Platform-audience mismatch is the most expensive mistake in paid advertising; choosing the right platform multiplies every downstream optimization." ;
    oc:severityLevel "HIGH" .

