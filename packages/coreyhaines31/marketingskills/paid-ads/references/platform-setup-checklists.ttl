oc:skill_coreyhaines31_marketingskills_paid_ads_platform_setup_checklists a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "platform-setup-checklists" ;
    skos:broader "Operational checklist generator" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/paid-ads" ;
    oc:contentHash "b86e206f8c7233c235d7d385a69e17fac16ac001ab130242b7700fe650752f69" ;
    oc:dependsOnSkill oc:skill_paid_ads ;
    oc:differentia "provides comprehensive platform-specific setup verification checklists for Google Ads, Meta Ads, LinkedIn Ads, Twitter/X Ads, and TikTok Ads including account foundation, tracking, audience configuration, creative assets, and compliance requirements" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_paid_ads ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "platform name (google, meta, linkedin, twitter, tiktok) or 'universal' for pre-launch" ;
    oc:hasCategory "marketing" ;
    oc:hasRequirement oc:req_19a050b6,
        oc:req_19dfac2a,
        oc:req_e6355fad ;
    oc:impartsKnowledge oc:kn_10adb80c,
        oc:kn_3f472fc4,
        oc:kn_3f8249e4,
        oc:kn_5577f94f,
        oc:kn_ee839f1a ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "audit ad platform tracking and conversion setup",
        "create platform setup checklist",
        "prepare ad platform for campaign launch",
        "set up ad platform account",
        "verify ad platform configuration" ;
    oc:yieldsState oc:AdPlatformConfigured,
        oc:CampaignLaunchReady,
        oc:ConversionTrackingVerified .

oc:kn_10adb80c a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before launching any ad campaign on any platform" ;
    oc:directiveContent "Always verify conversion tracking with a real conversion before launching any campaign. This is the single most critical pre-launch step." ;
    oc:hasRationale "Without verified conversion tracking, you cannot measure ROI or optimize campaigns, making all spend effectively blind." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3f472fc4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up any ad platform for the first time" ;
    oc:directiveContent "Complete every checklist section in order: Account Foundation → Tracking → Analytics → Audiences → Campaign Readiness → Extensions → Brand Protection. Do not skip steps." ;
    oc:hasRationale "Each section builds on the previous one; audiences require tracking, campaign readiness requires audiences, and extensions require campaign structure." ;
    oc:severityLevel "HIGH" .

oc:kn_3f8249e4 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When planning LinkedIn Ads campaigns" ;
    oc:directiveContent "LinkedIn CPCs are typically $8-15+ and require audiences of 50K+ for effective delivery. Budget accordingly and validate audience size before launch." ;
    oc:hasRationale "LinkedIn's premium B2B targeting comes at significantly higher costs than other platforms; underbudgeting leads to insufficient data for optimization." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5577f94f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring Meta Pixel and Conversions API" ;
    oc:directiveContent "For Meta Ads, the top 8 events must be prioritized in Aggregated Event Measurement due to iOS 14+ tracking limitations. Event Match Quality score should be > 6." ;
    oc:hasRationale "iOS 14+ App Tracking Transparency limits the events Meta can optimize for; proper prioritization and CAPI setup are essential for campaign performance." ;
    oc:severityLevel "HIGH" .

oc:kn_ee839f1a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before launching campaigns on any platform" ;
    oc:directiveContent "Never launch campaigns without first completing the Universal Pre-Launch Checklist: test conversion tracking, verify landing page speed (<3 sec), confirm mobile-friendliness, validate UTM parameters, and ensure reporting dashboards are ready." ;
    oc:hasRationale "Skipping pre-launch verification is the most common cause of wasted ad spend and irrecoverable data gaps in early campaign performance." ;
    oc:severityLevel "CRITICAL" .

oc:req_19a050b6 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of pixel/tag installation and conversion tracking" .

oc:req_19dfac2a a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Ad platform account access (Google Ads, Meta Business Manager, LinkedIn Campaign Manager, Twitter/X Ads, TikTok Ads Manager)" .

oc:req_e6355fad a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Familiarity with UTM parameters and analytics integration" .

