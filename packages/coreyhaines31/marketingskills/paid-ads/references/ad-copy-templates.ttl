oc:kn_4bc13566 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When writing platform-specific copy" ;
    oc:directiveContent "For Meta ads, front-load the hook in the first line (only 125 chars visible). For LinkedIn, use professional tone with specific job outcomes and stats. For Google, use all available headline slots and include numbers/stats when possible." ;
    oc:hasRationale "Each platform has unique display behaviors and audience expectations that affect copy performance." .

oc:kn_6f89623a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning ad copy tests" ;
    oc:directiveContent "When testing ad copy, prioritize elements in this order: 1) Hook/angle (biggest impact), 2) Headline, 3) Primary benefit, 4) CTA, 5) Supporting proof points. Test one element at a time for clean data." ;
    oc:hasRationale "The hook/angle has the largest impact on performance; testing one variable at a time ensures attributable results." ;
    oc:severityLevel "HIGH" .

oc:kn_7a969b45 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting CTAs for ad copy" ;
    oc:directiveContent "Match CTA intensity to funnel position: Soft CTAs (Learn More, See How It Works) for top-of-funnel/cold audiences; Hard CTAs (Start Free Trial, Get Started Free) for bottom-of-funnel/warm audiences; Urgency CTAs only when genuinely applicable." ;
    oc:hasRationale "CTA-audience mismatch causes either too much friction (hard CTA on cold audience) or too little urgency (soft CTA on warm audience)." .

oc:kn_7dfeff00 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing platform-specific ad copy" ;
    oc:directiveContent "Google Search Ads: 30 chars per headline (up to 15), 90 chars per description (up to 4). Meta Ads: 125 chars visible primary text, 40 char headline. LinkedIn: 600 chars intro text (150 recommended), 200 char headline (70 recommended)." ;
    oc:hasRationale "Exceeding character limits causes truncation or rejection, wasting ad spend and reducing click-through rates." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8f62b61b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing ad primary text" ;
    oc:directiveContent "Use one of 5 proven primary text formulas: Problem-Agitate-Solve (PAS), Before-After-Bridge (BAB), Social Proof Lead, Feature-Benefit Bridge, or Direct Response." ;
    oc:hasRationale "These formulas are validated frameworks that structure copy for maximum persuasion and conversion." .

oc:kn_d2aa9bde a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing urgency-driven ad copy" ;
    oc:directiveContent "Use urgency CTAs (Limited Time, Only X Spots Left, Last Chance) only when the urgency is genuine and truthful." ;
    oc:hasRationale "Fake urgency damages brand trust and can violate advertising platform policies." ;
    oc:severityLevel "HIGH" .

