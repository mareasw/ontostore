@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_paid_ads_ad_copy_templates a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "ad-copy-templates" ;
    skos:broader "ad copy template library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/paid-ads" ;
    oc:contentHash "853ab37e23b75aa3355bdbed9a1357948e635dbdf737be5a1a7aa0126d701206" ;
    oc:differentia "provides proven formulas and platform-specific guidelines for writing high-converting ad copy across search and social channels" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_paid_ads ;
    oc:handlesFailure oc:InvalidInput,
        oc:PlatformConstraintViolation ;
    oc:hasArgumentHint "ad-platform (google/meta/linkedin) and copy-element (headline/primary-text/cta)" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_59398ff4,
        oc:kn_65dace69,
        oc:kn_c03366dc,
        oc:kn_d830a25b,
        oc:kn_f663c3ce,
        oc:kn_f94eec9b ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProductOfferingKnown,
        oc:TargetAudienceDefined ;
    oc:resolvesIntent "apply platform-specific copy constraints for Google Meta and LinkedIn ads",
        "generate headlines for search and social ads",
        "prioritize ad copy testing elements",
        "select appropriate CTAs for ad campaigns",
        "write ad copy using proven formulas" ;
    oc:yieldsState oc:AdCopyGenerated .

oc:kn_59398ff4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any ad primary text" ;
    oc:directiveContent "Use one of the five proven primary text formulas — PAS, BAB, Social Proof Lead, Feature-Benefit Bridge, or Direct Response — as the structural backbone of all ad copy." ;
    oc:hasRationale "These formulas are validated frameworks that address distinct psychological triggers and ensure copy has a coherent persuasive arc." ;
    oc:severityLevel "HIGH" .

oc:kn_65dace69 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing social ad primary text, particularly Meta/Facebook/Instagram" ;
    oc:directiveContent "Front-load the hook or most compelling element in the first line of primary text, especially for Meta ads where truncation cuts off later content at 125 characters." ;
    oc:hasRationale "Users scroll rapidly; the first visible line determines whether they stop to read the rest of the ad." ;
    oc:severityLevel "HIGH" .

oc:kn_c03366dc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting or writing CTAs for any ad" ;
    oc:directiveContent "Match CTA intensity to funnel stage: soft CTAs (Learn More, Watch Demo) for top-of-funnel cold audiences, hard CTAs (Start Free Trial, Buy Now) for bottom-of-funnel warm audiences, and urgency CTAs only when genuine scarcity exists." ;
    oc:hasRationale "CTA-audience mismatch creates friction — too aggressive for cold audiences causes bounce, too passive for warm audiences leaves conversions on the table." ;
    oc:severityLevel "HIGH" .

oc:kn_d830a25b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing copy for Google Search, Meta, or LinkedIn ads" ;
    oc:directiveContent "Respect platform character limits strictly: Google headlines 30 chars, descriptions 90 chars; Meta primary text 125 visible chars, headlines 40 chars; LinkedIn intro text 600 max (150 recommended), headlines 200 max (70 recommended)." ;
    oc:hasRationale "Exceeding character limits causes truncation or disapproval, wasting ad spend and reducing click-through rates." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f663c3ce a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing CTAs for any ad platform" ;
    oc:directiveContent "Never use urgency or scarcity CTAs (Limited Time, Only X Spots Left) unless the urgency is genuine and truthful." ;
    oc:hasRationale "Fake urgency erodes trust, can violate platform advertising policies, and damages brand credibility long-term." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f94eec9b a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning ad copy A/B tests" ;
    oc:directiveContent "Prioritize copy testing in this order: hook/angle first (biggest impact), then headline, primary benefit, CTA, and supporting proof points — testing one element at a time for clean data." ;
    oc:hasRationale "The hook/angle drives the largest performance variance; testing lower-impact elements first wastes budget and delays learning." ;
    oc:severityLevel "MEDIUM" .

