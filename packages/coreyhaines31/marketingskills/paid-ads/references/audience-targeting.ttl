oc:skill_coreyhaines31_marketingskills_paid_ads_audience_targeting a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "audience-targeting" ;
    skos:broader "Reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/paid-ads" ;
    oc:contentHash "21ed7c99fb1124ca38635d6f313cc2f3ca49a192f390cd55293b7bd5a028e1b1" ;
    oc:differentia "provides detailed audience targeting strategies and specifications for each major ad platform including Google, Meta, LinkedIn, Twitter/X, and TikTok" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_paid_ads ;
    oc:handlesFailure oc:AudienceTooBroad,
        oc:AudienceTooNarrow,
        oc:InvalidTargetingCriteria ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_58e9810d,
        oc:kn_830ef782,
        oc:kn_835bea38,
        oc:kn_b4621296,
        oc:kn_f19d3462,
        oc:kn_fd4b49a1 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:AdCampaignCreated,
        oc:PlatformSelected ;
    oc:resolvesIntent "configure audience targeting for paid ads",
        "create lookalike audiences",
        "determine optimal audience sizes by platform",
        "select targeting options for Google Meta LinkedIn Twitter TikTok ads",
        "set up exclusion strategies for ad campaigns",
        "target audiences on ad platforms" ;
    oc:yieldsState oc:AudienceTargetingConfigured,
        oc:ExclusionsApplied .

oc:kn_58e9810d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring targeting on any ad platform" ;
    oc:directiveContent "Layer audience targeting with AND logic for precision — stack interests, demographics, behaviors, and job criteria rather than relying on a single dimension." ;
    oc:hasRationale "Single-dimension targeting is too broad and wastes spend; layering narrows the audience to high-intent users while maintaining sufficient reach." ;
    oc:severityLevel "HIGH" .

oc:kn_830ef782 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When setting up new audience targeting, especially on Google Ads" ;
    oc:directiveContent "Start audiences in 'observation' mode first to analyze performance by segment, then switch high-performing segments to 'targeting' mode. Start broad and let the algorithm optimize before narrowing." ;
    oc:hasRationale "Observation mode collects data without restricting delivery, enabling data-driven decisions about which audiences merit dedicated targeting budgets." ;
    oc:severityLevel "MEDIUM" .

oc:kn_835bea38 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up any ad campaign targeting" ;
    oc:directiveContent "Never skip exclusion strategy — always exclude existing customers (unless upselling), recent converters, bounced visitors, employees, and irrelevant page visitors." ;
    oc:hasRationale "Failing to exclude these groups wastes budget on people who won't convert or are already converted, inflating costs and distorting performance metrics." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b4621296 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining audience size for any ad campaign" ;
    oc:directiveContent "Respect minimum audience sizes per platform: Google Search 1K+ monthly searches, Meta 100K+, LinkedIn 50K+. Too narrow = expensive and slow learning; too broad = wasted spend." ;
    oc:hasRationale "Platforms need sufficient audience volume for their algorithms to optimize delivery; undersized audiences cause high CPMs and poor learning, while oversized audiences dilute relevance." ;
    oc:severityLevel "HIGH" .

oc:kn_f19d3462 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating lookalike or similar audiences on Meta, Google, or LinkedIn" ;
    oc:directiveContent "For lookalike audiences, use high-LTV customers as the source list (not all customers or visitors). Purchasers > leads > all visitors for source quality." ;
    oc:hasRationale "The quality of the source audience directly determines the quality of the lookalike; using low-value users as source produces low-value lookalikes." ;
    oc:severityLevel "HIGH" .

oc:kn_fd4b49a1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring TikTok ad campaigns" ;
    oc:directiveContent "On TikTok, creative matters more than targeting — use broad targeting and let the algorithm optimize rather than over-specifying audience criteria." ;
    oc:hasRationale "TikTok's algorithm is highly effective at finding the right audience based on creative engagement signals; narrow targeting on TikTok often underperforms broad." ;
    oc:severityLevel "MEDIUM" .

