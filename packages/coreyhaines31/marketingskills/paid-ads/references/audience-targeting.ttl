    oc:yieldsState oc:AudienceTargetingConfigured .

oc:kn_2649e08e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating lookalike/similar audiences on Meta or Google" ;
    oc:directiveContent "For lookalike audiences: use high-LTV customers as source (not all customers), ensure minimum 100 source users ideally 1,000+, start at 1% similarity for precision, and always exclude the source audience from the lookalike campaign." ;
    oc:hasRationale "Source audience quality directly determines lookalike quality; polluted sources produce poor-performing lookalikes" ;
    oc:severityLevel "MEDIUM" .

oc:kn_31cb2690 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When choosing platforms for campaign objectives" ;
    oc:directiveContent "LinkedIn is most precise for B2B but highest CPMs. Twitter/X has lower CPMs but less precision, better for awareness. TikTok skews 18-34 and creative matters more than targeting — use broad targeting and let the algorithm optimize." ;
    oc:hasRationale "Platform demographics and algorithm behavior should drive platform selection and targeting strategy" ;
    oc:severityLevel "MEDIUM" .

oc:kn_4225d267 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When optimizing Google Ads audience targeting over time" ;
    oc:directiveContent "For Google Ads audience layering: 1) Add audiences in observation mode, 2) Analyze performance by audience segment, 3) Switch high performers to targeting mode. For RLSA: bid higher on past visitors, show different ads to returning searchers, exclude converters from prospecting." ;
    oc:hasRationale "Data-driven audience refinement outperforms assumptions about which audiences will convert" ;
    oc:severityLevel "MEDIUM" .

oc:kn_6ee027bc a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring audience targeting on any ad platform" ;
    oc:directiveContent "Audience size must fall within platform-specific ideal ranges: Google Search 5K-50K, Google Display 500K-5M, Meta 500K-10M, LinkedIn 100K-500K, Twitter/X 100K-1M, TikTok 1M+. Too narrow = expensive and slow learning; too broad = wasted spend." ;
    oc:hasRationale "Audience size directly impacts cost efficiency and algorithm optimization capability" ;
    oc:severityLevel "HIGH" .

oc:kn_781c7c30 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up Google Ads search campaigns" ;
    oc:directiveContent "Do not use broad match keywords without smart bidding. Do not start with audience 'targeting' mode — always begin in 'observation' mode to analyze performance first." ;
    oc:hasRationale "Broad match without smart bidding wastes budget; observation mode prevents prematurely excluding valuable audience segments" ;
    oc:severityLevel "HIGH" .

oc:kn_a9d004da a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building audience definitions across platforms" ;
    oc:directiveContent "Layer targeting criteria with AND logic for precision: Meta interests + demographics, LinkedIn job function + seniority + company size, Google in-market + demographics. Start broad and let the algorithm optimize rather than over-constraining." ;
    oc:hasRationale "Layering narrows audiences meaningfully while giving algorithms sufficient data to optimize" ;
    oc:severityLevel "MEDIUM" .

oc:kn_bbdcd901 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When setting up any ad campaign audience" ;
    oc:directiveContent "Always exclude: existing customers (unless upsell), recent converters (7-14 days), bounced visitors (<10 sec), employees, irrelevant page visitors (careers, support), and identifiable competitors." ;
    oc:hasRationale "Exclusions prevent wasted spend on users who cannot or should not convert" ;
    oc:severityLevel "CRITICAL" .

