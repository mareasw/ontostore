oc:skill_coreyhaines31_marketingskills_launch_strategy a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "launch-strategy" ;
    skos:broader "strategic framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/launch-strategy" ;
    oc:contentHash "ed3f9ec22ee7ee3c6b9995ecbd717bd662669f6631a44b7abccac09fdd01363d" ;
    oc:differentia "structures product launches into five progressive phases using the ORB channel framework to build compounding momentum" ;
    oc:extends oc:skill_product_marketing_context ;
    oc:handlesFailure oc:InsufficientAudience,
        oc:LaunchUnderperformance ;
    oc:hasArgumentHint "product or feature to launch, timeline, and current audience/assets" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to plan a product launch, feature announcement, or release strategy. Also use when the user mentions 'launch,' 'Product Hunt,' 'feature release,' 'announcement,' 'go-to-market,' 'beta launch,' 'early access,' 'waitlist,' 'product update,' 'how do I launch this,' 'launch checklist,' 'GTM plan,' or 'we're about to ship.' Use this whenever someone is preparing to release something publicly. For ongoing marketing after launch, see marketing-ideas." ;
    oc:hasName "launch-strategy" ;
    oc:impartsKnowledge oc:kn_1d37dc38,
        oc:kn_67f95dfb,
        oc:kn_7f064a47,
        oc:kn_cae94451,
        oc:kn_d7a096f8 ;
    oc:isUserInvocable true ;
    oc:nature "concept" ;
    oc:requiresState oc:MarketingContextLoaded,
        oc:ProductReadyForLaunch ;
    oc:resolvesIntent "announce a feature release",
        "build a launch checklist",
        "create a go-to-market plan",
        "create a launch strategy",
        "plan a Product Hunt launch",
        "plan a beta or early access launch",
        "plan a product launch",
        "recover from a failed launch" ;
    oc:yieldsState oc:LaunchChecklistGenerated,
        oc:LaunchPlanCreated .

oc:kn_1d37dc38 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing any launch strategy" ;
    oc:directiveContent "Never rely on a single launch event or a single channel. Do not treat rented channels as your primary long-term strategy, and do not skip the post-launch phase—your launch isn't over when the announcement goes live." ;
    oc:hasRationale "Single-event launches waste momentum. Rented-only strategies are fragile due to algorithm changes. Post-launch neglect loses the adoption and retention window when interest is highest." ;
    oc:severityLevel "HIGH" .

oc:kn_67f95dfb a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning any product or major feature launch" ;
    oc:directiveContent "Use the five-phase launch approach: Internal → Alpha → Beta → Early Access → Full Launch. Each phase has distinct goals: validation, external feedback, buzz building, scale validation, and maximum visibility respectively." ;
    oc:hasRationale "Launching is not a one-day event but a phased momentum-building process. Skipping phases leads to public exposure of unvalidated products and lost launch energy." ;
    oc:severityLevel "HIGH" .

oc:kn_7f064a47 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any launch strategy task" ;
    oc:directiveContent "Before generating any launch plan, check for product-marketing-context.md in .agents/ or .claude/ directories. Read and use existing context, only asking for information not already covered." ;
    oc:hasRationale "Product marketing context contains pre-existing positioning, audience, and competitive information that prevents redundant questions and ensures consistency across all marketing outputs." ;
    oc:severityLevel "HIGH" .

oc:kn_cae94451 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding how to announce ongoing product updates post-launch" ;
    oc:directiveContent "Classify updates as major (full campaign), medium (targeted announcement), or minor (changelog only) and scale marketing effort accordingly. Space out releases to maintain momentum rather than shipping everything at once." ;
    oc:hasRationale "Not every update deserves the same marketing investment. Over-announcing minor updates dilutes attention; under-announcing major updates wastes opportunity." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d7a096f8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning any launch channel strategy" ;
    oc:directiveContent "Structure all launch marketing across three channel types using the ORB Framework: Owned (email, blog, community), Rented (social platforms, app stores), and Borrowed (guest content, partnerships, influencers). Everything should ultimately funnel back to owned channels." ;
    oc:hasRationale "Owned channels compound in value over time without algorithm dependency, while rented and borrowed channels provide speed and credibility but require conversion into owned relationships for sustainable growth." ;
    oc:severityLevel "HIGH" .

