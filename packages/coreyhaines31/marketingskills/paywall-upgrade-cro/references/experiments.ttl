oc:kn_67dafb16 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning the sequence of trial-related experiments" ;
    oc:directiveContent "Test trial structure (length, credit card requirement, access level) before optimizing trial expiration messaging — the fundamental trial design drives more conversion than expiration tactics." ;
    oc:hasRationale "A well-structured trial removes friction at the decision point, while expiration messaging only affects users already in the trial funnel." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9740c1b5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining any paywall A/B test" ;
    oc:directiveContent "Each experiment must isolate a single variable (trigger type, layout, pricing display, CTA wording) to produce actionable results." ;
    oc:hasRationale "Multi-variable tests require exponentially more traffic and produce ambiguous results that cannot guide clear design decisions." ;
    oc:severityLevel "HIGH" .

oc:kn_a1de8908 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning paywall A/B tests" ;
    oc:directiveContent "Never run multiple paywall experiments simultaneously that share the same user segment — results will confound each other." ;
    oc:hasRationale "Overlapping experiments on the same audience produce unreliable data, leading to wrong conclusions about what drives conversion." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d596ce7d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing paywall experiments that personalize content" ;
    oc:directiveContent "Combine personalization with usage-based triggers — showing the right value message at the right moment in the user journey maximizes conversion." ;
    oc:hasRationale "Generic paywalls underperform because they ignore the user's specific engagement context; personalization bridges the relevance gap." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d87919dd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which paywall experiments to run first" ;
    oc:directiveContent "Prioritize trigger and timing experiments first — when and how the paywall is shown often has larger impact than copy or design changes." ;
    oc:hasRationale "Trigger timing determines the user's emotional state and context, which fundamentally shapes conversion potential regardless of design quality." ;
    oc:severityLevel "HIGH" .

