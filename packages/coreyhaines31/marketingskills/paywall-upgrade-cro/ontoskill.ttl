oc:skill_coreyhaines31_marketingskills_paywall_upgrade_cro a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "paywall-upgrade-cro" ;
    skos:broader "Conversion optimization skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/paywall-upgrade-cro" ;
    oc:contentHash "295332ea04e876feb58e6e2a4ee5d5fbc7c1703366f69b37d165d3e98723944a" ;
    oc:dependsOnSkill oc:skill_onboarding_cro ;
    oc:differentia "specializes in in-app paywalls, upgrade screens, upsell modals, and feature gates for converting free/trial users to paid tiers" ;
    oc:extends oc:skill_page_cro ;
    oc:handlesFailure oc:InsufficientProductData,
        oc:InvalidPricingModel ;
    oc:hasAlias "feature gate",
        "freemium conversion",
        "in-app paywall",
        "upgrade screen",
        "upsell modal" ;
    oc:hasArgumentHint "upgrade context (freemium-to-paid, trial-to-paid, tier upgrade, or feature upsell) with product details" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to create or optimize in-app paywalls, upgrade screens, upsell modals, or feature gates. Also use when the user mentions \"paywall,\" \"upgrade screen,\" \"upgrade modal,\" \"upsell,\" \"feature gate,\" \"convert free to paid,\" \"freemium conversion,\" \"trial expiration screen,\" \"limit reached screen,\" \"plan upgrade prompt,\" \"in-app pricing,\" \"free users won't upgrade,\" \"trial to paid conversion,\" or \"how do I get users to pay.\" Use this for any in-product moment where you're asking users to upgrade. Distinct from public pricing pages (see page-cro) — this focuses on in-product upgrade moments where the user has already experienced value. For pricing decisions, see pricing-strategy." ;
    oc:hasName "paywall-upgrade-cro" ;
    oc:hasRequirement oc:req_ccbd8f44,
        oc:req_ccd0c197,
        oc:req_ea481ce3 ;
    oc:impartsKnowledge oc:kn_11912927,
        oc:kn_3ad39810,
        oc:kn_581c2021,
        oc:kn_a0f2cf50,
        oc:kn_b36b3e4e,
        oc:kn_b464570e,
        oc:kn_b9bc1421,
        oc:kn_dda5d333 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:ProductContextAvailable,
        oc:UserJourneyDefined ;
    oc:resolvesIntent "avoid dark patterns in upgrade flows",
        "create feature gate prompts",
        "design upgrade screens and modals",
        "design usage limit paywalls",
        "improve trial-to-paid conversion",
        "optimize paywall conversion rates",
        "plan paywall A/B tests" ;
    oc:yieldsState oc:PaywallDesigned,
        oc:UpgradeFlowSpecified .

oc:kn_11912927 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting paywall trigger strategy for a product" ;
    oc:directiveContent "Design paywalls around four essential trigger points — feature gates, usage limits, trial expiration, and time-based prompts — each with distinct copy and UX treatment matched to the user's emotional state." ;
    oc:hasRationale "Each trigger point captures a different conversion opportunity and user mindset; using the wrong template for a trigger reduces relevance and conversion" .

oc:kn_3ad39810 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After implementing paywall changes or running A/B tests" ;
    oc:directiveContent "Key metrics to track: paywall impression rate, click-through to upgrade, completion rate, revenue per user, and churn rate post-upgrade. Improvement in these metrics validates paywall changes." ;
    oc:hasRationale "These metrics form the complete conversion funnel from visibility to revenue to retention, ensuring optimizations improve real business outcomes rather than vanity metrics" .

oc:kn_581c2021 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting upgrade prompt frequency rules" ;
    oc:directiveContent "Always enforce frequency capping: limit prompts per session and implement cool-down periods measured in days (not hours) after dismissal. Track annoyance signals." ;
    oc:hasRationale "Overexposure to upgrade prompts causes banner blindness and active resentment; spaced repetition with cool-downs maintains effectiveness while preserving UX" ;
    oc:severityLevel "HIGH" .

oc:kn_a0f2cf50 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "At the start of every paywall optimization engagement" ;
    oc:directiveContent "Check for product-marketing-context.md before asking questions. Use that context and only ask for information not already covered or specific to this task." ;
    oc:hasRationale "Leveraging existing product context reduces back-and-forth with the user and produces more tailored, accurate recommendations faster" .

oc:kn_b36b3e4e a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When a user asks about pricing page design or general pricing strategy" ;
    oc:directiveContent "Public pricing page optimization is out of scope for this skill — defer to page-cro for pricing pages and pricing-strategy for pricing decisions. This skill only covers in-product upgrade moments." ;
    oc:hasRationale "Paywall-upgrade-cro focuses on in-product moments where users have already experienced value; public pricing pages serve a different audience (prospects) with different psychology" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b464570e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing trigger timing for any paywall or upgrade prompt" ;
    oc:directiveContent "Never show an upgrade prompt before the user has experienced the aha moment or real value from the product. Paywalls shown too early destroy trust and conversion potential." ;
    oc:hasRationale "Users who haven't experienced value interpret upgrade prompts as greedy rather than helpful, leading to negative brand perception and lower lifetime conversion" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b9bc1421 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any paywall screen, modal, or upgrade prompt" ;
    oc:directiveContent "Never use dark patterns: hiding close buttons, confusing plan selection, guilt-trip copy, or blocking critical user flows. Every paywall must include a clear escape hatch." ;
    oc:hasRationale "Dark patterns may produce short-term conversion lifts but destroy long-term trust, increase churn, and can damage brand reputation permanently" ;
    oc:severityLevel "CRITICAL" .

oc:kn_dda5d333 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or auditing any paywall screen" ;
    oc:directiveContent "Structure every paywall screen with seven components: benefit-focused headline, value demonstration, feature comparison, clear pricing, social proof, specific CTA, and escape hatch." ;
    oc:hasRationale "These seven components address the full decision-making journey from attention through value justification to action, while maintaining user trust through the escape hatch" ;
    oc:severityLevel "HIGH" .

oc:req_ccbd8f44 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Current free-to-paid conversion rate" .

oc:req_ccd0c197 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Product pricing model and tier structure" .

oc:req_ea481ce3 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Product marketing context file (.agents/product-marketing-context.md) for product-specific details" .

