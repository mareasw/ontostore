oc:skill_coreyhaines31_marketingskills_onboarding_cro_experiments a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "experiments" ;
    skos:broader "experiment catalog" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/onboarding-cro" ;
    oc:contentHash "b4caad0b50ca9483a6a79846d0b24a7bab62850b45a3f2232d73f78629468932" ;
    oc:differentia "catalogs A/B test ideas and hypotheses for optimizing user onboarding flows, activation, and retention" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_onboarding_cro ;
    oc:hasArgumentHint "area of onboarding to experiment on (e.g., 'flow simplification', 'email', 'personalization')" ;
    oc:hasCategory "marketing" ;
    oc:impartsKnowledge oc:kn_10755089,
        oc:kn_61384393,
        oc:kn_9c73c666,
        oc:kn_a8b3c48e,
        oc:kn_b5424891 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "design onboarding experiments by category",
        "generate onboarding experiment ideas",
        "identify hypothesis-driven tests for activation improvement",
        "plan A/B tests for onboarding optimization" .

oc:kn_10755089 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any onboarding experiment" ;
    oc:directiveContent "Every experiment must have a clear hypothesis stated before testing — the test idea alone is insufficient without a falsifiable hypothesis explaining the expected outcome." ;
    oc:hasRationale "Hypothesis-driven experimentation prevents confirmation bias and ensures learnings generalize beyond a single test result." ;
    oc:severityLevel "HIGH" .

oc:kn_61384393 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which experiments to run first" ;
    oc:directiveContent "Prioritize experiments that reduce friction (fewer steps, pre-filled data, skip options) and accelerate time-to-value (quick wins, success messages) before optimizing secondary elements." ;
    oc:hasRationale "Friction reduction and time-to-value compression have the highest demonstrated impact on activation rates in SaaS onboarding." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9c73c666 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When measuring any onboarding experiment outcome" ;
    oc:directiveContent "Track these eight core metrics across all onboarding experiments: activation rate, time to activation, step completion rate, drop-off points, return rate, Day 1/7/30 retention, feature adoption, and support requests." ;
    oc:hasRationale "Consistent metric tracking enables cross-experiment comparison and builds an institutional knowledge base of what works." ;
    oc:severityLevel "HIGH" .

oc:kn_a8b3c48e a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When planning or ideating onboarding experiments" ;
    oc:directiveContent "Organize onboarding experiments into seven categories: flow simplification, guided experience, personalization, quick wins & engagement, email & multi-channel, re-engagement, and technical/UX — covering the full onboarding lifecycle." ;
    oc:hasRationale "Categorical organization ensures comprehensive coverage of all onboarding touchpoints and prevents over-indexing on a single dimension." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b5424891 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before launching any onboarding experiment" ;
    oc:directiveContent "Do not run experiments in isolation without a measurement framework — testing without defining success metrics and a tracking plan wastes resources and produces unactionable results." ;
    oc:hasRationale "Experiments without pre-defined metrics lead to post-hoc rationalization and cannot reliably inform product decisions." ;
    oc:severityLevel "CRITICAL" .

