oc:kn_0d24242b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When users drop off during onboarding" ;
    oc:directiveContent "Consider re-engagement experiments (stalled user recovery, return experience) as a separate optimization layer distinct from initial onboarding flow." ;
    oc:hasRationale "Return users have different needs and context than first-time users; treating them the same wastes recovery opportunities" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3598f0fa a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning a comprehensive onboarding experimentation program" ;
    oc:directiveContent "Structure onboarding experiments across 8 categories: flow simplification, guided experience, personalization, quick wins, email/multi-channel, re-engagement, technical/UX, and metrics tracking." ;
    oc:hasRationale "Comprehensive coverage across categories ensures no optimization lever is overlooked" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3cfa38e9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When measuring any onboarding experiment's results" ;
    oc:directiveContent "Always track activation rate, time-to-activation, step completion rate, and drop-off points for every onboarding experiment." ;
    oc:hasRationale "Without consistent metrics across experiments, results cannot be compared or prioritized effectively" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c05a75d0 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When users abandon onboarding before completion" ;
    oc:directiveContent "For stalled users, test simplified return paths (reduced steps), personal outreach, progress resumption, and incentive offers as recovery mechanisms." ;
    oc:hasRationale "Multiple recovery tactics address different reasons for abandonment" ;
    oc:severityLevel "MEDIUM" .

oc:kn_eafbf0ab a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sequencing which onboarding experiments to run first" ;
    oc:directiveContent "Prioritize flow simplification experiments (friction reduction, step sequencing) before more complex experiments like personalization or gamification." ;
    oc:hasRationale "Reducing friction yields the highest impact with lowest implementation cost; complex features compound on a clean base flow" ;
    oc:severityLevel "HIGH" .

oc:kn_f31d6f0f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing onboarding A/B tests" ;
    oc:directiveContent "Do not test too many onboarding changes simultaneously; isolate variables to understand which change drove the result." ;
    oc:hasRationale "Conflating variables makes it impossible to attribute improvements to specific changes" ;
    oc:severityLevel "HIGH" .

_:ref_04ed5d8d5677966c a oc:WorkflowStep ;
    dcterms:description "Identify the specific onboarding problem area (friction, drop-off, activation, retention) using metrics" ;
    oc:expectedOutcome "Clear problem statement tied to a metric gap" ;
    oc:stepId "identify-problem-area" .

_:ref_6b7ea06fffc3272a a oc:WorkflowStep ;
    dcterms:description "Define success metrics from the metrics table for each selected experiment" ;
    oc:expectedOutcome "Primary and secondary metrics defined for each test" ;
    oc:stepDependsOn _:ref_cf81ee37c1a577cc ;
    oc:stepId "define-metrics" .

_:ref_773e69bd67232045 a oc:WorkflowStep ;
    dcterms:description "Match the problem to an experiment category (flow simplification, personalization, email, re-engagement, etc.)" ;
    oc:expectedOutcome "One or two experiment categories selected" ;
    oc:stepDependsOn _:ref_04ed5d8d5677966c ;
    oc:stepId "select-category" .

_:ref_cf81ee37c1a577cc a oc:WorkflowStep ;
    dcterms:description "Select 2-3 specific test ideas from the category tables that address the identified problem" ;
    oc:expectedOutcome "Shortlist of specific A/B tests to run" ;
    oc:stepDependsOn _:ref_773e69bd67232045 ;
    oc:stepId "choose-specific-tests" .

