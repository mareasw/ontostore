oc:skill_coreyhaines31_marketingskills_onboarding_cro a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "onboarding-cro" ;
    skos:broader "Conversion rate optimization methodology" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/onboarding-cro" ;
    oc:contentHash "cbed06276fbce3299342206712b9dfec03d6f7e7a2af6a5b8fa9e5a17f6eafe2" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "specializes in post-signup user activation, first-run experience design, and accelerating time-to-value" ;
    oc:extends oc:skill_signup_flow_cro ;
    oc:handlesFailure oc:InsufficientProductContext,
        oc:ScopeBoundaryViolation ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to optimize post-signup onboarding, user activation, first-run experience, or time-to-value. Also use when the user mentions \"onboarding flow,\" \"activation rate,\" \"user activation,\" \"first-run experience,\" \"empty states,\" \"onboarding checklist,\" \"aha moment,\" \"new user experience,\" \"users aren't activating,\" \"nobody completes setup,\" \"low activation rate,\" \"users sign up but don't use the product,\" \"time to value,\" or \"first session experience.\" Use this whenever users are signing up but not sticking around. For signup/registration optimization, see signup-flow-cro. For ongoing email sequences, see email-sequence." ;
    oc:hasName "onboarding-cro" ;
    oc:impartsKnowledge oc:kn_093724ca,
        oc:kn_17f2bf95,
        oc:kn_2060c781,
        oc:kn_85c64dda,
        oc:kn_86579fbd,
        oc:kn_bc266169,
        oc:kn_e60c6d7b,
        oc:kn_f89340f0 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProductMarketingContextAvailable ;
    oc:resolvesIntent "create onboarding checklist",
        "design first-run experience",
        "design multi-channel onboarding",
        "fix empty states in onboarding",
        "handle stalled users",
        "improve user activation rate",
        "optimize onboarding flow",
        "plan onboarding experiments",
        "reduce time to value" ;
    oc:yieldsState oc:ActivationMetricsDefined,
        oc:OnboardingFlowDesigned .

oc:kn_093724ca a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing tooltip or guided tour patterns" ;
    oc:directiveContent "Guided tours and tooltips must never repeat for returning users. Limit tours to 3-5 steps and make them dismissable at any time." ;
    oc:hasRationale "Repeated tours annoy engaged users and increase support requests rather than helping" ;
    oc:severityLevel "MEDIUM" .

oc:kn_17f2bf95 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating onboarding checklists for B2B self-serve products" ;
    oc:directiveContent "Onboarding checklists must contain 3-7 items ordered by value (most impactful first), starting with quick wins. Never trap users — always provide a dismiss option." ;
    oc:hasRationale "Too many items overwhelm users; ordering by value maximizes early momentum; forced completion creates resentment" ;
    oc:severityLevel "HIGH" .

oc:kn_2060c781 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any screen that could display empty content" ;
    oc:directiveContent "Do not treat empty states as dead ends. Empty states are onboarding opportunities — they should explain purpose, show populated examples, and provide a clear primary action." ;
    oc:hasRationale "Blank screens create confusion and abandonment; treating them as onboarding touchpoints converts a drop-off point into an engagement opportunity" ;
    oc:severityLevel "HIGH" .

oc:kn_85c64dda a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any post-signup onboarding flow" ;
    oc:directiveContent "Time-to-value is the single most important metric in onboarding. Remove every unnecessary step between signup and experiencing core product value." ;
    oc:hasRationale "The faster users experience value (the 'aha moment'), the higher the activation rate and long-term retention" ;
    oc:severityLevel "CRITICAL" .

oc:kn_86579fbd a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When establishing onboarding metrics and success criteria" ;
    oc:directiveContent "Define activation as the action that correlates most strongly with retention — what retained users do that churned users don't. Track activation rate, time to activation, steps to activation, and activation by cohort/source." ;
    oc:hasRationale "Without a clear activation definition tied to retention data, onboarding improvements cannot be measured or prioritized effectively" .

oc:kn_bc266169 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing first-run experience" ;
    oc:directiveContent "Focus the first session on one successful outcome using interactive 'doing' rather than passive tutorials. Doing the thing > Learning about the thing." ;
    oc:hasRationale "Interactive onboarding produces stronger engagement and learning than passive tutorial-based approaches" .

oc:kn_e60c6d7b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user asks about signup form optimization, field reduction, or registration flow design" ;
    oc:directiveContent "Do not attempt to optimize signup form fields or registration flows using onboarding patterns. Defer signup flow optimization to signup-flow-cro instead." ;
    oc:hasRationale "Onboarding CRO covers post-signup experience only; signup form optimization requires different patterns and belongs to signup-flow-cro" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f89340f0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "At the start of every onboarding CRO engagement" ;
    oc:directiveContent "Always check for product-marketing-context.md (.agents/ or .claude/) before asking questions. Use existing context and only ask for information not already covered." ;
    oc:hasRationale "Avoids redundant questions and leverages existing institutional knowledge about the product" .

