    oc:isUserInvocable true ;
    oc:nature "Reference" ;
    oc:requiresState oc:DocumentCreated ;
    oc:resolvesIntent "identify filler phrases to delete",
        "remove pompous language from copy",
        "replace jargon with plain English",
        "simplify complex words" ;
    oc:yieldsState oc:DocumentSimplified .

oc:kn_0ed91664 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When suggesting plain English replacements" ;
    oc:directiveContent "Sources are limited to Plain English Campaign A-Z (2001), Australian Government Style Manual (2024), and plainlanguage.gov. Do not invent alternatives not in these references." ;
    oc:hasRationale "Authority-backed alternatives ensure consistency and credibility rather than subjective preference." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7a440829 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When editing any marketing copy, landing page, or customer-facing text" ;
    oc:directiveContent "Replace complex or jargon words with their plain English equivalents (e.g., 'utilise' → 'use', 'commence' → 'start', 'facilitate' → 'help')." ;
    oc:hasRationale "Plain language improves readability, comprehension, and conversion rates by reducing cognitive load on the reader." ;
    oc:severityLevel "HIGH" .

oc:kn_90ff9015 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or writing any copy" ;
    oc:directiveContent "Never use filler phrases that add no meaning: 'a total of', 'basically', 'at the end of the day', 'in due course', 'to all intents and purposes', 'very', 'really', 'quite'." ;
    oc:hasRationale "These phrases inflate word count without adding information, weakening the message and reducing trust." ;
    oc:severityLevel "HIGH" .

oc:kn_aa99e610 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a complex word is found that has no direct entry in the alternatives tables" ;
    oc:directiveContent "When encountering a complex word not in the lookup table, apply the pattern: choose the shortest, most common everyday word that preserves the original meaning." ;
    oc:hasRationale "The table covers the most common offenders but cannot be exhaustive; the general principle of simplicity always applies." ;
    oc:severityLevel "MEDIUM" .

oc:kn_eb458ccc a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "After applying replacements to formal or regulated-industry copy" ;
    oc:directiveContent "Replacing jargon with plain English may shift the tone from formal/professional to casual. Verify the tone still matches the brand voice after substitution." ;
    oc:hasRationale "Some industries (legal, medical, finance) may require specific terminology for compliance even when plainer alternatives exist." ;
    oc:severityLevel "MEDIUM" .

