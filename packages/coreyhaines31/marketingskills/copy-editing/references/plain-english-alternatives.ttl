oc:skill_coreyhaines31_marketingskills_copy_editing_plain_english_alternatives a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "plain-english-alternatives" ;
    skos:broader "Reference lookup table" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/copy-editing" ;
    oc:contentHash "df4f820d4c63ae8a517c64a243c101658352cd07d002355bf3c97de0a00f3775" ;
    oc:differentia "that maps complex or jargon words to plain English alternatives for clearer writing" ;
    oc:extends oc:skill_coreyhaines31_marketingskills_copy_editing ;
    oc:handlesFailure oc:WordNotFound ;
    oc:hasArgumentHint "word or phrase to simplify" ;
    oc:hasCategory "document" ;
    oc:hasRequirement oc:req_17e3c72c ;
    oc:impartsKnowledge oc:kn_2ccca724,
        oc:kn_33ad0056,
        oc:kn_4a98708a,
        oc:kn_5b95cd15,
        oc:kn_b90c3fa8 ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:resolvesIntent "identify and remove filler phrases from text",
        "replace jargon with plain English",
        "simplify complex words in marketing copy" ;
    oc:yieldsState oc:TextSimplified .

oc:kn_2ccca724 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing or writing any marketing copy or customer-facing text" ;
    oc:directiveContent "Always prefer the simplest word that conveys the same meaning; e.g., 'use' instead of 'utilise', 'buy' instead of 'purchase', 'help' instead of 'facilitate'." ;
    oc:hasRationale "Plain language reduces cognitive load, increases comprehension, and builds trust with the reader — especially critical in marketing where attention spans are short." ;
    oc:severityLevel "HIGH" .

oc:kn_33ad0056 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing copy that includes regulated claims, legal disclaimers, or technical specifications" ;
    oc:directiveContent "Do not apply plain English substitutions mechanically to technical, legal, or regulated content where specific terminology carries precise legal or domain-specific meaning." ;
    oc:hasRationale "Some complex words exist because they have exact legal or technical definitions; replacing them with plain alternatives could change the meaning or create liability." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4a98708a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When copy-editing any marketing or customer-facing text" ;
    oc:directiveContent "Never allow filler phrases like 'at the end of the day', 'as a matter of fact', 'to all intents and purposes', or 'absolutely' to remain in copy — delete them entirely as they add no meaning." ;
    oc:hasRationale "Filler phrases inflate sentence length without adding information, diluting the message and reducing persuasion." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5b95cd15 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing a pass to simplify copy" ;
    oc:directiveContent "Replace multi-word pompous phrases ('in the event of' → 'if', 'due to the fact that' → 'because', 'in order to' → 'to') before tackling individual word replacements, as phrase simplification yields the largest clarity improvement per edit." ;
    oc:hasRationale "Verbose phrases are the biggest contributors to unclear writing; fixing them first gives the highest return on editing effort." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b90c3fa8 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "After applying plain English replacements to marketing copy" ;
    oc:directiveContent "Replacing jargon with plain alternatives may alter the brand voice or tone — always review the full passage after substitutions to ensure consistency with the intended brand personality." ;
    oc:hasRationale "Some brands deliberately use elevated language as part of their identity; blind substitution could undermine brand positioning." ;
    oc:severityLevel "LOW" .

oc:req_17e3c72c a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Plain English Campaign A-Z of Alternative Words" .

