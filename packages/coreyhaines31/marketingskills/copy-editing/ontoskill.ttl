@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_coreyhaines31_marketingskills_copy_editing a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "copy-editing" ;
    skos:broader "Systematic editing framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/coreyhaines31/marketingskills/copy-editing" ;
    oc:contentHash "54c9298e0dcdec7304e01c59fbd1aabbd670a0a2a8c48d1688b5edaa29bcf061" ;
    oc:dependsOnSkill oc:skill_product_marketing_context ;
    oc:differentia "Improves existing marketing copy through seven sequential focused sweeps (Clarity, Voice & Tone, So What, Prove It, Specificity, Heightened Emotion, Zero Risk) while preserving the core message" ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "existing copy text to edit" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to edit, review, or improve existing marketing copy. Also use when the user mentions 'edit this copy,' 'review my copy,' 'copy feedback,' 'proofread,' 'polish this,' 'make this better,' 'copy sweep,' 'tighten this up,' 'this reads awkwardly,' 'clean up this text,' 'too wordy,' or 'sharpen the messaging.' Use this when the user already has copy and wants it improved rather than rewritten from scratch. For writing new copy, see copywriting." ;
    oc:hasName "copy-editing" ;
    oc:impartsKnowledge oc:kn_2d044ddd,
        oc:kn_4f2e8d05,
        oc:kn_66fc1433,
        oc:kn_713e47a2,
        oc:kn_c4ccf7cf ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DocumentCreated ;
    oc:resolvesIntent "edit existing marketing copy",
        "identify and fix copy problems",
        "proofread and polish marketing text",
        "review and improve copy quality",
        "run copy editing sweeps on existing text",
        "sharpen messaging and tighten copy" ;
    oc:yieldsState oc:DocumentEdited .

oc:kn_2d044ddd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying the Prove It or Specificity sweeps and encountering unsupported claims" ;
    oc:directiveContent "Never fabricate specific numbers, testimonials, or statistics when editing copy. Flag unsupported claims and recommend the author add real proof points instead." ;
    oc:hasRationale "Invented proof destroys credibility. The editor's job is to identify gaps and recommend what real evidence should fill them, not to create fictional data" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4f2e8d05 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a full seven-sweep process isn't needed or the user requests a quick edit" ;
    oc:directiveContent "Use the Quick-Pass Editing Checks for faster reviews: cut weak intensifiers (very, really), replace jargon (utilize→use, leverage→use, implement→set up), enforce one idea per sentence, max 25 words per sentence, 2-4 sentences per paragraph for web copy." ;
    oc:hasRationale "Quick-pass checks address the most common copy problems efficiently when time or scope doesn't warrant the full framework" ;
    oc:severityLevel "MEDIUM" .

oc:kn_66fc1433 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When performing any full copy editing pass on marketing copy" ;
    oc:directiveContent "Apply the Seven Sweeps Framework sequentially: Clarity → Voice & Tone → So What → Prove It → Specificity → Heightened Emotion → Zero Risk. After each sweep, loop back to verify previous sweeps weren't compromised by new edits." ;
    oc:hasRationale "Multiple focused passes catch issues that a single unfocused review misses, and looping back prevents cascading regressions across editing dimensions" ;
    oc:severityLevel "HIGH" .

oc:kn_713e47a2 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any copy editing session" ;
    oc:directiveContent "Check for product-marketing-context.md (.agents/ or .claude/) before editing. Read brand voice and customer language from that context to guide all edits." ;
    oc:hasRationale "Product marketing context ensures edits align with established brand voice, positioning, and customer language—preventing edits that contradict existing brand guidelines" ;
    oc:severityLevel "HIGH" .

oc:kn_c4ccf7cf a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When editing any existing marketing copy" ;
    oc:directiveContent "Never change the core message of the copy. Copy editing enhances and clarifies existing messaging—it does not rewrite from scratch. For new copy creation, defer to the copywriting skill." ;
    oc:hasRationale "The author's intent and core message must be preserved. Rewriting changes the nature of the task from editing to creation, which requires a different skill and process" ;
    oc:severityLevel "CRITICAL" .

