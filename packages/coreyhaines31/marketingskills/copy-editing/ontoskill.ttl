oc:kn_09cb0236 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying Prove It and Specificity sweeps" ;
    oc:directiveContent "Never fabricate specific numbers, statistics, or testimonials. If proof is missing, flag it and recommend adding real evidence or softening the claim. Do not invent data to make copy more specific." ;
    oc:hasRationale "Fabricated evidence destroys credibility and can create legal liability. Honest gaps are better than false claims." ;
    oc:severityLevel "CRITICAL" .

oc:kn_0a9bbf63 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any editing work" ;
    oc:directiveContent "Before editing: understand the goal of the copy, know the target audience, identify the desired action, and read through once without editing." ;
    oc:hasRationale "Context prevents misdirected edits—editing without understanding the purpose can break effective copy" ;
    oc:severityLevel "HIGH" .

oc:kn_1cee73a5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user asks to 'write' new copy without providing existing text" ;
    oc:directiveContent "Recognize when a request is for writing new copy from scratch rather than editing existing copy. In that case, defer to the copywriting skill. Copy-editing is specifically for improving existing copy." ;
    oc:hasRationale "Writing and editing are fundamentally different processes—editing assumes existing material to enhance" ;
    oc:severityLevel "HIGH" .

oc:kn_273ee36d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Sweep 3 (So What) and any feature-heavy copy" ;
    oc:directiveContent "For every claim in the copy, ask 'So what?' If the copy doesn't answer with a deeper benefit for the reader, it needs a benefit bridge. Features must connect to outcomes the reader cares about." ;
    oc:hasRationale "Features without benefits fail to motivate action because readers don't inherently care about capabilities—they care about results" ;
    oc:severityLevel "HIGH" .

oc:kn_5b89dae9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any editing pass" ;
    oc:directiveContent "If .agents/product-marketing-context.md (or .claude/product-marketing-context.md in older setups) exists, read it before editing. Use brand voice and customer language from that context to guide edits." ;
    oc:hasRationale "Product marketing context ensures edits align with established brand voice and customer terminology" ;
    oc:severityLevel "HIGH" .

oc:kn_5fb9d792 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Every copy editing task" ;
    oc:directiveContent "Good copy editing enhances, not rewrites. Don't change the core message—focus on improving clarity, specificity, and persuasion. Preserve the author's voice while making the copy more effective." ;
    oc:hasRationale "Rewriting from scratch violates the editing mandate and risks losing the original intent and brand voice" ;
    oc:severityLevel "CRITICAL" .

oc:kn_617a9ca4 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Full copy editing engagement" ;
    oc:directiveContent "Run seven sequential sweeps, each focusing on one dimension: 1-Clarity, 2-Voice & Tone, 3-So What, 4-Prove It, 5-Specificity, 6-Heightened Emotion, 7-Zero Risk. After each sweep, loop back to verify previous sweeps aren't compromised." ;
    oc:hasRationale "Multiple focused passes catch issues that get missed when trying to fix everything at once" ;
    oc:severityLevel "HIGH" .

oc:kn_fdc84afd a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Quick-pass editing and Sweep 5 (Specificity)" ;
    oc:directiveContent "Replace vague language with concrete specifics: use real numbers instead of 'many', specific timeframes instead of 'fast', quantified outcomes instead of 'improve'. Cut filler words (very, really, just, actually, basically) and corporate jargon (utilize, leverage, facilitate, seamless, robust)." ;
    oc:hasRationale "Concrete language is more believable and compelling than abstract claims. Readers distrust vague superlatives." ;
    oc:severityLevel "MEDIUM" .

oc:req_4bf5a09f a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of marketing copy principles and conversion copywriting" .

oc:req_605bb5a4 a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "Product marketing context file (.agents/product-marketing-context.md) for brand voice and customer language" .

