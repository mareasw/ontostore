            oc:hasStep _:ref_4f8c7552202e5037,
                _:ref_8eacaf88b10602d9,
                [ a oc:WorkflowStep ;
                    dcterms:description "One topic per paragraph. Short paragraphs (2-4 sentences for web). Strong opening sentences. Logical flow. White space for scannability." ;
                    oc:expectedOutcome "Paragraphs are focused and readable" ;
                    oc:stepDependsOn _:ref_4f8c7552202e5037 ;
                    oc:stepId "quick-paragraph-level" ] ;
            oc:workflowId "quick-pass-edit" ;
            oc:workflowName "Quick Pass Edit" ] ;
    oc:impartsKnowledge oc:kn_09cb0236,
        oc:kn_0a9bbf63,
        oc:kn_1cee73a5,
