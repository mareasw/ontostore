_:ref_8eacaf88b10602d9 a oc:WorkflowStep ;
    dcterms:description "Cut weak intensifiers (very, really), filler (just, actually, basically), vague words (things, stuff). Replace corporate jargon with plain English. Flag adverbs, passive voice, nominalizations." ;
    oc:expectedOutcome "Cleaner, more direct word choices" ;
    oc:stepId "quick-word-level" .

_:ref_94c14ea4b016218a a oc:WorkflowStep ;
    dcterms:description "Prove It sweep: Identify unsubstantiated claims. Flag missing social proof. Recommend adding evidence or softening claims. Return to So What, Voice & Tone, then Clarity." ;
    oc:expectedOutcome "All claims substantiated, no unearned superlatives" ;
    oc:stepDependsOn _:ref_72925bfed24f1398 ;
    oc:stepId "sweep-4-prove-it" .

