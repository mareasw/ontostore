    oc:stepId "sweep-2-voice-tone" .

_:ref_72925bfed24f1398 a oc:WorkflowStep ;
    dcterms:description "So What sweep: Ask 'so what?' for every claim. Add benefit bridges. Connect features to real reader desires. Return to Voice & Tone, then Clarity." ;
    oc:expectedOutcome "Every feature connects to a benefit, no impressive-but-empty statements" ;
    oc:stepDependsOn _:ref_5a3373e0c04e0a6e ;
    oc:stepId "sweep-3-so-what" .

