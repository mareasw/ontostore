    oc:dependsOnSkill oc:skill_ontoskills_product_marketing_context ;
    oc:differentia "applies seven sequential sweeps (Clarity, Voice & Tone, So What, Prove It, Specificity, Heightened Emotion, Zero Risk) to systematically improve existing marketing copy while preserving the core message" ;
    oc:handlesFailure oc:InvalidInput,
        oc:NoCopyProvided ;
    oc:hasArgumentHint "existing copy text to edit or review" ;
    oc:hasCategory "marketing" ;
    oc:hasDescription "When the user wants to edit, review, or improve existing marketing copy. Also use when the user mentions 'edit this copy,' 'review my copy,' 'copy feedback,' 'proofread,' 'polish this,' 'make this better,' 'copy sweep,' 'tighten this up,' 'this reads awkwardly,' 'clean up this text,' 'too wordy,' or 'sharpen the messaging.' Use this when the user already has copy and wants it improved rather than rewritten from scratch. For writing new copy, see copywriting." ;
    oc:hasName "copy-editing" ;
    oc:hasRequirement oc:req_4bf5a09f,
        oc:req_605bb5a4 ;
