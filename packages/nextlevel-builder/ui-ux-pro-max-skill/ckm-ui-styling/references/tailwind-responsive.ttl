oc:kn_24495adb a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When toggling visibility between mobile and desktop" ;
    oc:codeLanguage "html" ;
    oc:directiveContent """<div class="hidden lg:block">Desktop only</div>
<div class="block lg:hidden">Mobile only</div>""" .

oc:kn_2c3cc800 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing interactive elements for mobile viewports" ;
    oc:directiveContent "Touch targets must be minimum 44x44px on mobile. Ensure navigation works on mobile with hidden/shown patterns." ;
    oc:hasRationale "Accessibility standards require minimum touch target sizes; failing this creates unusable interfaces on touch devices." ;
    oc:severityLevel "CRITICAL" .

oc:kn_30fd7fef a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling any single element with responsive classes" ;
    oc:directiveContent "Avoid using more than 2-3 breakpoints per element. Do not use desktop-first thinking (e.g., text-xl lg:text-base)." ;
    oc:hasRationale "Too many breakpoints create maintenance burden and visual inconsistency. Desktop-first patterns fight against Tailwind's cascade model." ;
    oc:severityLevel "MEDIUM" .

oc:kn_42fadac9 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating reusable components that must respond to their container size" ;
    oc:codeLanguage "html" ;
    oc:directiveContent """<div class="@container">
  <div class="@md:grid-cols-2 @lg:grid-cols-3">
    <!-- Responds to parent width, not viewport -->
  </div>
</div>""" .

oc:kn_74b7b974 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After implementing responsive layouts" ;
    oc:directiveContent "Test at exact breakpoint boundary widths: 320px, 640px, 768px, 1024px, 1280px, 1536px. Also test landscape orientation and browser zoom." ;
    oc:hasRationale "Edge cases appear precisely at breakpoint boundaries; testing at these widths catches layout breaks early." ;
    oc:severityLevel "MEDIUM" .

oc:kn_aa9aa876 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating responsive card or content grids" ;
    oc:codeLanguage "html" ;
    oc:directiveContent """<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
  <!-- Items -->
</div>""" .

oc:kn_c1e654b1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building grouped responsive elements like card grids" ;
    oc:directiveContent "Use consistent breakpoints across related elements (e.g., grid and its gap should use the same breakpoint prefixes)." ;
    oc:hasRationale "Mismatched breakpoints cause visual misalignment where layout shifts before spacing adjusts or vice versa." ;
    oc:severityLevel "LOW" .

oc:kn_d1b98e10 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When architecting responsive page layouts" ;
    oc:directiveContent "Ensure core functionality and content works on mobile first, then progressively enhance with larger breakpoints. Use container queries (@container) for component-level responsiveness." ;
    oc:hasRationale "Progressive enhancement ensures no user is blocked; container queries decouple components from viewport-based breakpoints." ;
    oc:severityLevel "MEDIUM" .

oc:kn_eb3ba293 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any responsive Tailwind classes" ;
    oc:directiveContent "Always use mobile-first approach: write base styles for smallest screens, then add breakpoint prefixes (sm:, md:, lg:, xl:, 2xl:) to override at larger sizes." ;
    oc:hasRationale "Mobile-first produces smaller CSS, follows progressive enhancement, and matches how Tailwind's min-width media queries work." ;
    oc:severityLevel "HIGH" .

