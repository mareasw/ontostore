oc:kn_0cef4c3b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When incorporating design influences and references" ;
    oc:directiveContent "Embed conceptual DNA through subtle reference integration — niche references woven invisibly so those who know feel it intuitively while others experience masterful abstract composition." ;
    oc:hasRationale "Sophisticated design references enhance depth quietly, like a jazz musician quoting another song — never literal." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3ebb4d61 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating any canvas design output" ;
    oc:directiveContent "Avoid: cartoony aesthetics, text-heavy composition, random placement, overlapping elements, inconsistent spacing, obvious AI generation, and lack of refinement." ;
    oc:hasRationale "These patterns signal amateur execution and break the museum-quality standard." ;
    oc:severityLevel "HIGH" .

oc:kn_450502ad a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining color systems for canvas designs" ;
    oc:directiveContent "Use limited color palettes (2-5 colors) in oklch color space. Each shade must carry meaning through purposeful relationships." ;
    oc:hasRationale "Intentional color systems create cohesive, sophisticated compositions where color is an information system, not decoration." ;
    oc:severityLevel "HIGH" .

oc:kn_4e0ee8e7 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "After initial design creation" ;
    oc:directiveContent "Refinement is the critical second pass: don't add more graphics, refine what exists. Make it extremely crisp, respect minimalism, increase cohesion, make existing elements more artistic — polish rather than expand." ;
    oc:hasRationale "Adding more elements degrades quality; refinement of existing elements achieves museum-standard craftsmanship." ;
    oc:severityLevel "HIGH" .

oc:kn_4f548817 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """## Required outputs:
1. Design philosophy file (.md)
   - Movement name
   - 4-6 paragraph philosophy
   - Visual principles
   - Execution guidance
2. Visual expression file (.pdf or .png)
   - Visual interpretation of philosophy
   - Minimal text
   - Systematic composition
   - Expert-level execution""" ;
    oc:templateVariables "execution_guidance",
        "movement_name",
        "philosophy_paragraphs",
        "visual_principles" .

oc:kn_98bb9d51 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "All canvas design creation" ;
    oc:directiveContent "Design must be 90% visual, 10% text maximum. Text is a rare, powerful gesture — never paragraphs, only essential words integrated into visual architecture." ;
    oc:hasRationale "Information lives in design, not paragraphs. Visual communication is the primary information channel." ;
    oc:severityLevel "CRITICAL" .

oc:kn_aa24aa76 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before beginning canvas design execution" ;
    oc:directiveContent "Fonts must be sourced from ./canvas-fonts directory and downloaded as needed for typography integration onto canvas." .

oc:kn_be9924e0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "All canvas compositions" ;
    oc:directiveContent "Nothing falls off page, nothing overlaps, every element within canvas boundaries, proper margins are non-negotiable." ;
    oc:hasRationale "Professional execution requires contained, well-spaced compositions with breathing room and clear separation." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ccef042a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "All canvas design output" ;
    oc:directiveContent "Work must appear meticulously crafted, as if labored over for countless hours — museum-quality, top-of-field execution. Every alignment results from countless refinements." ;
    oc:hasRationale "The standard is not 'good enough' but 'could be displayed in a museum' — proof of undeniable expertise." ;
    oc:severityLevel "HIGH" .

oc:kn_e0aabd76 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining canvas color palettes using oklch color space" ;
    oc:codeLanguage "css" ;
    oc:directiveContent """--color-primary: oklch(0.55 0.22 264)
--color-accent: oklch(0.75 0.18 45)
--color-neutral: oklch(0.90 0.02 264)
--color-dark: oklch(0.25 0.15 264)""" .

oc:kn_e60ceb73 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating multi-page canvas design systems" ;
    oc:directiveContent "For multi-page systems: 1. Treat first page as single page in coffee table book → 2. Create additional pages along same philosophy → 3. Maintain shared palette, typography, compositional approach → 4. Give each page unique twist with different focal points and progressive visual narrative" ;
    oc:stepOrder 2 .

oc:kn_f31a1741 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any canvas design system" ;
    oc:directiveContent "1. Create design philosophy (4-6 paragraph manifesto covering space/form, color/material, scale/rhythm, composition/balance, visual hierarchy) → 2. Express philosophy through canvas artifacts (90% visual, 10% text) → 3. Refine: polish existing elements without adding more → 4. Verify against execution checklist before delivery" ;
    oc:hasRationale "The two-phase creation process ensures philosophical coherence before visual execution, and refinement prevents over-decoration." ;
    oc:stepOrder 1 .

