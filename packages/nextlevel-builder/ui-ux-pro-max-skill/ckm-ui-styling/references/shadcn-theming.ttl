oc:kn_09aae0ba a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining custom color variables" ;
    oc:directiveContent "Pair every color variable with an appropriate foreground variable to maintain contrast and readability" ;
    oc:hasRationale "Unpaired colors cause unreadable text when themes switch between light and dark modes" ;
    oc:severityLevel "HIGH" .

oc:kn_15d927e1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing component styles and variants" ;
    oc:directiveContent "Never use raw color names like 'red' or 'gray' in component code; always use semantic names like 'destructive' or 'muted'" ;
    oc:hasRationale "Semantic naming ensures colors adapt correctly across themes and maintain design system consistency" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3aea920c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining colors in globals.css" ;
    oc:directiveContent "CSS variable color values must use HSL format without the hsl() wrapper: 'H S L' not 'hsl(H, S%, L%)'" ;
    oc:hasRationale "Bare HSL values enable Tailwind to compose with opacity modifiers like hsl(var(--primary) / 0.5)" ;
    oc:severityLevel "CRITICAL" .

oc:kn_5372bdeb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up dark mode" ;
    oc:directiveContent "Use next-themes with attribute='class' for Next.js dark mode; use localStorage + classList.toggle for Vite/other frameworks" ;
    oc:hasRationale "next-themes handles SSR hydration correctly in Next.js; simpler solutions work for client-only frameworks" ;
    oc:severityLevel "MEDIUM" .

oc:kn_55735eb0 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "After modifying CSS variables or theme configuration" ;
    oc:directiveContent "Verify components render correctly in both light and dark modes after any theme change" ;
    oc:hasRationale "Dark mode often reveals contrast issues invisible in light mode testing" ;
    oc:severityLevel "HIGH" .

oc:kn_92c69e4b a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-applying theme configurations" ;
    oc:directiveContent "CSS variable updates are idempotent - applying the same variable values multiple times produces identical output" ;
    oc:hasRationale "Theme configuration is declarative and stateless, safe to re-apply" ;
    oc:severityLevel "LOW" .

oc:kn_b74fc093 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When configuring any shadcn/ui theme" ;
    oc:directiveContent "Use CSS variables for all theme colors to enable runtime theme switching without rebuilds" ;
    oc:hasRationale "CSS variables allow dynamic theme changes and dark mode toggling at runtime" ;
    oc:severityLevel "HIGH" .

oc:kn_df2883f3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When customizing component appearance" ;
    oc:directiveContent "Use className prop overrides for one-off customization; extract repeated patterns into custom variants via cva()" ;
    oc:hasRationale "Prevents style duplication and maintains consistency across the component library" ;
    oc:severityLevel "MEDIUM" .

