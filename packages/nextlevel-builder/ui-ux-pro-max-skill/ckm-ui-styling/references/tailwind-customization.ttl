oc:kn_0068a2de a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing CSS layers and creating reusable component classes" ;
    oc:directiveContent "Do not overuse @apply — extract components with it only for truly repeated patterns. Over-extraction reduces Tailwind's utility-first advantage." ;
    oc:hasRationale "Excessive @apply defeats the purpose of utility-first CSS and creates maintenance overhead" ;
    oc:severityLevel "MEDIUM" .

oc:kn_118d646d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding custom spacing values in @theme" ;
    oc:directiveContent "Custom spacing values using calc must reference var(--spacing) as the base unit: e.g., --spacing-18: calc(var(--spacing) * 18)." ;
    oc:hasRationale "Referencing the base spacing variable ensures custom values remain consistent with Tailwind's spacing scale" ;
    oc:severityLevel "MEDIUM" .

oc:kn_1396951e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing custom CSS alongside Tailwind" ;
    oc:directiveContent "Keep base styles, component classes, and utility extensions in separate @layer blocks (base, components, utilities) for correct CSS specificity ordering." ;
    oc:hasRationale "Layer ordering ensures utilities can always override components, and components override base styles" ;
    oc:severityLevel "MEDIUM" .

oc:kn_29e0a75d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining custom color palettes" ;
    oc:directiveContent "Use oklch() color space for custom color definitions for better perceptual uniformity across the color scale." ;
    oc:hasRationale "oklch provides perceptually even color steps, making 50-950 scales look more harmonious than hsl or hex" ;
    oc:severityLevel "LOW" .

oc:kn_461dbc9d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When configuring Tailwind for a project" ;
    oc:directiveContent "Ensure content paths in tailwind.config.js cover all files that use Tailwind classes, including components, pages, and app directories." ;
    oc:hasRationale "Missing content paths cause Tailwind to purge classes that appear to be unused, breaking styles at runtime" ;
    oc:severityLevel "CRITICAL" .

oc:kn_5b140fb6 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using dynamic or computed class names in templates" ;
    oc:directiveContent "Dynamically constructed class names (e.g., bg-${color}-500) will be purged. Use the safelist option to preserve them." ;
    oc:hasRationale "Tailwind's JIT engine only generates classes found as whole strings in content files" ;
    oc:severityLevel "HIGH" .

oc:kn_72247c15 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining custom color palettes and design tokens in @theme" ;
    oc:directiveContent "Use semantic naming for custom tokens (e.g., --color-primary, --color-success) rather than literal names (e.g., --color-blue)." ;
    oc:hasRationale "Semantic names support theming, dark mode, and brand changes without renaming throughout the codebase" ;
    oc:severityLevel "HIGH" .

oc:kn_b4b5639a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding custom colors, fonts, spacing, shadows, or breakpoints" ;
    oc:directiveContent "Prefer the CSS-based @theme directive over tailwind.config.js for simple customizations — it is the modern Tailwind v4 approach." ;
    oc:hasRationale "The @theme directive is the recommended modern approach and keeps customization co-located with your CSS" ;
    oc:severityLevel "MEDIUM" .

