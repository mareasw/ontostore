        oc:Prerequisite ;
    oc:appliesToContext "Before using any shadcn component" ;
    oc:directiveContent "Requires a Next.js or React project with Tailwind CSS configured and shadcn/ui initialized" .

oc:kn_7cf07e35 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When considering bundle size" ;
    oc:directiveContent "Components install as source code (not node_modules) — tree-shaking happens at build time; no runtime overhead from unused components" ;
    oc:hasRationale "shadcn copies component source into your project, so only imported components are bundled" .

oc:kn_8ed348aa a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when installing shadcn components" ;
    oc:directiveContent "Components install to `components/ui/` directory — this path is convention and should not be changed" ;
    oc:hasRationale "shadcn CLI expects this path structure; altering it breaks imports and future CLI operations" ;
    oc:severityLevel "HIGH" .

oc:kn_b851d592 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building complex UI layouts" ;
    oc:directiveContent "All components support composition: combine Card + Button + Badge, wrap Dialog triggers with `asChild`, use Popover for dropdown overlays" ;
    oc:hasRationale "shadcn/ui follows Radix UI's composable architecture — components are building blocks, not monoliths" .

oc:kn_b896ef18 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building form UIs" ;
    oc:directiveContent "Use Form + React Hook Form + Zod for any form with validation; use bare Input for simple unvalidated fields" ;
    oc:hasRationale "The Form component integrates with react-hook-form for state management and Zod for schema validation — essential for production forms" .

oc:kn_eb9f29c2 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When adding any shadcn/ui component" ;
    oc:directiveContent "1. Install component via `npx shadcn@latest add <component>` 2. Import from `@/components/ui/<component>` 3. Compose with Tailwind classes for layout 4. Use variant/size props for styling" ;
    oc:hasRationale "Ensures consistent installation path and import convention across all components" ;
    oc:stepOrder 1 .

oc:kn_f3c574bf a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling shadcn components" ;
    oc:directiveContent "Do not override shadcn component internals with custom Tailwind classes that conflict with design tokens — use variant props instead" ;
    oc:hasRationale "Direct class overrides break the design token system and create inconsistency with the rest of the UI" ;
    oc:severityLevel "MEDIUM" .

