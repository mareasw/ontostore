oc:kn_4c3cf062 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building forms and interactive elements" ;
    oc:directiveContent "Always label icon-only buttons with aria-label, provide sr-only text for screen readers, and use aria-describedby to link descriptions to inputs. Every form input must have an associated Label with matching htmlFor." ;
    oc:hasRationale "Without proper labeling, screen readers cannot communicate element purpose to users" ;
    oc:severityLevel "HIGH" .

oc:kn_69d72efb a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building any shadcn/ui component" ;
    oc:directiveContent "1. Use semantic HTML elements (button, nav, fieldset/legend) 2. Add aria-label to icon-only buttons 3. Link labels to inputs with htmlFor/id 4. Add aria-invalid and aria-describedby for form errors 5. Use sr-only for screen reader text 6. Add aria-live regions for dynamic content 7. Ensure focus-visible ring styles on all interactive elements 8. Test with keyboard-only navigation" ;
    oc:stepOrder 1 .

oc:kn_7f07907e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding animations or page layouts with navigation" ;
    oc:directiveContent "Respect prefers-reduced-motion by using motion-reduce:transition-none in Tailwind classes and adding CSS media queries that disable animations. Always include skip-to-content links." ;
    oc:hasRationale "Animations can cause vestibular disorders; skip links allow keyboard users to bypass repetitive navigation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9eb86d42 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When displaying dynamic content, notifications, or status updates" ;
    oc:directiveContent "Use aria-live='polite' for non-urgent dynamic updates and aria-live='assertive' for urgent errors. Toast notifications via useToast() are announced automatically." ;
    oc:hasRationale "Live regions ensure screen readers announce changes without requiring user focus to move" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ab5422f9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building interactive UI elements" ;
    oc:directiveContent "Never use div with onClick for interactive elements. Use semantic HTML elements like <button>, <nav>, <a> to ensure screen reader comprehension." ;
    oc:hasRationale "Div soup removes all built-in accessibility semantics, forcing screen readers to treat interactive elements as static content" ;
    oc:severityLevel "HIGH" .

oc:kn_cb8b3fc4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building accessible form fields with validation errors" ;
    oc:codeLanguage "tsx" ;
    oc:directiveContent """<FormField
  control={form.control}
  name="email"
  render={({ field, fieldState }) => (
    <FormItem>
      <FormLabel>Email</FormLabel>
      <FormControl><Input {...field} aria-invalid={!!fieldState.error} aria-describedby={fieldState.error ? "email-error" : undefined} /></FormControl>
      <FormMessage id="email-error" />
    </FormItem>
  )}
/>""" .

oc:kn_d658f463 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before shipping any shadcn/ui interface" ;
    oc:directiveContent "Verify all interactive elements are keyboard accessible, focus indicators visible, form errors announced with aria-invalid and aria-describedby, color contrast meets WCAG AA, skip links provided, and page works at 200% zoom." ;
    oc:hasRationale "Comprehensive accessibility testing catches issues that automated tools miss" ;
    oc:severityLevel "HIGH" .

oc:kn_d7f0cd66 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing text colors and foreground/background combinations" ;
    oc:directiveContent "Color contrast must meet WCAG AA minimum: 4.5:1 for normal text, 3:1 for large text. Use text-muted-foreground for secondary text and avoid low-contrast pairs like text-gray-400 on dark backgrounds." ;
    oc:hasRationale "Insufficient contrast makes text unreadable for users with low vision, failing WCAG 1.4.3" ;
    oc:severityLevel "HIGH" .

oc:kn_df75f12a a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up automated accessibility testing in a React/shadcn project" ;
    oc:directiveContent "npm install -D @axe-core/react" .

oc:kn_e020b4ba a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When performing accessibility review of shadcn/ui interfaces" ;
    oc:directiveContent """## Accessibility Testing Checklist
- [ ] All interactive elements keyboard accessible
- [ ] Focus indicators visible
- [ ] Screen reader announces all content correctly
- [ ] Form errors announced and associated
- [ ] Color contrast meets WCAG AA
- [ ] Semantic HTML used
- [ ] ARIA labels for icon-only buttons
- [ ] Modal/dialog focus trap works
- [ ] Dropdown/select keyboard navigable
- [ ] Live regions announce updates
- [ ] Respects reduced motion preference
- [ ] Works at 200% zoom
- [ ] Logical tab order
- [ ] Skip links provided""" .

oc:kn_f27b6677 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using accessibility patterns" ;
    oc:directiveContent "shadcn/ui components built on Radix UI primitives must be installed (npx shadcn-ui@latest init). Radix provides built-in keyboard navigation, focus management, and ARIA attributes automatically." .

oc:kn_fb9ae2db a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling interactive elements with Tailwind" ;
    oc:directiveContent "Never remove focus styles with focus:outline-none. Use focus-visible:ring-2 instead to preserve keyboard accessibility while avoiding mouse focus rings." ;
    oc:hasRationale "Removing focus indicators makes keyboard navigation invisible, violating WCAG 2.4.7 and blocking users who rely on keyboards" ;
    oc:severityLevel "CRITICAL" .

_:ref_0d90bf2ae51bbc93 a oc:WorkflowStep ;
    dcterms:description "Verify color contrast meets WCAG AA (4.5:1 normal text), add reduced motion support, verify 200% zoom" ;
    oc:expectedOutcome "Content readable at all zoom levels, animations respect preferences" ;
    oc:stepDependsOn _:ref_c2af6e8adc3f2603 ;
    oc:stepId "contrast-motion" .

_:ref_4337531f49dfa6fd a oc:WorkflowStep ;
    dcterms:description "Add aria-label to icon-only buttons, aria-describedby for descriptions, and sr-only text where needed" ;
    oc:expectedOutcome "All elements have accessible names and descriptions" ;
    oc:stepDependsOn _:ref_8062e1fbb7e4d13f ;
    oc:stepId "aria-labeling" .

_:ref_7d118dbf1105c532 a oc:WorkflowStep ;
    dcterms:description "Ensure all form inputs have Label with htmlFor, aria-invalid for errors, and required field indicators" ;
    oc:expectedOutcome "Forms are fully accessible with announced errors" ;
    oc:stepDependsOn _:ref_4337531f49dfa6fd ;
    oc:stepId "form-accessibility" .

_:ref_c2af6e8adc3f2603 a oc:WorkflowStep ;
    dcterms:description "Add focus-visible ring styles, skip-to-content links, and verify dialog/dropdown focus trapping" ;
    oc:expectedOutcome "Keyboard navigation works with visible focus indicators" ;
    oc:stepDependsOn _:ref_8062e1fbb7e4d13f ;
    oc:stepId "focus-management" .

_:ref_8062e1fbb7e4d13f a oc:WorkflowStep ;
    dcterms:description "Use semantic HTML elements (button, nav, fieldset) instead of divs for interactive elements" ;
    oc:expectedOutcome "All interactive elements use proper HTML semantics" ;
    oc:stepId "semantic-html" .

