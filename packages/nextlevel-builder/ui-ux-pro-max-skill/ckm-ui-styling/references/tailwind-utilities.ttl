oc:kn_17c0f4dc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying padding, margin, or gap values" ;
    oc:directiveContent "Use Tailwind's spacing scale (0-96) consistently rather than arbitrary pixel values. Standard increments: 1=4px, 2=8px, 4=16px, 8=32px." ;
    oc:hasRationale "Consistent spacing scale ensures visual rhythm and design system coherence across the UI" ;
    oc:severityLevel "MEDIUM" .

oc:kn_338a1c5d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying semi-transparent colors or colored shadows" ;
    oc:directiveContent "Use opacity modifiers with slash syntax: bg-black/75, text-blue-500/30, bg-purple-500/[0.87], border-red-600/50. Combined with shadow: shadow-lg shadow-blue-500/50" ;
    oc:hasRationale "Slash opacity modifiers are more concise and maintainable than separate opacity classes" .

oc:kn_5a9d08ab a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When Tailwind's default utility classes don't cover the needed value" ;
    oc:directiveContent "Use square bracket notation for values not in the default scale: p-[17px], bg-[#bada55], w-[500px], grid-cols-[1fr_500px_2fr], bg-[var(--brand-color)]" ;
    oc:hasRationale "Arbitrary values bridge the gap between Tailwind's conventions and project-specific design requirements" ;
    oc:severityLevel "MEDIUM" .

