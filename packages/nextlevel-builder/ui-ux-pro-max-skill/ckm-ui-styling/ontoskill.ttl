oc:kn_32304cd8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating responsive layouts" ;
    oc:directiveContent "Start with mobile styles as base, then layer responsive variants at sm/md/lg breakpoints. Use 2-3 breakpoints per element maximum." ;
    oc:hasRationale "Mobile-first is Tailwind's default approach and ensures progressive enhancement. Too many breakpoints create maintenance burden." ;
    oc:severityLevel "MEDIUM" .

oc:kn_416f6a92 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building any UI with shadcn/ui" ;
    oc:directiveContent "Build complex UIs from simple, composable primitives. Compose Card + CardHeader + CardContent rather than creating monolithic components." ;
    oc:hasRationale "Composable primitives enable reuse, reduce coupling, and allow flexible composition patterns that monolithic components cannot support." ;
    oc:severityLevel "HIGH" .

oc:kn_44f13117 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "Before running shadcn add commands" ;
    oc:directiveContent "shadcn/ui components must be initialized with 'npx shadcn@latest init' before adding components. Missing components.json causes all add operations to fail." ;
    oc:hasRationale "shadcn CLI requires components.json to know installation paths and framework configuration." ;
    oc:severityLevel "HIGH" .

oc:kn_5258d4be a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When styling any UI element" ;
    oc:directiveContent "Use utility-first styling: apply Tailwind classes directly in markup. Only extract to @apply or components when patterns are truly repeated across 3+ instances." ;
    oc:hasRationale "Premature extraction creates indirection and reduces readability. Utility classes co-locate styling with structure for better DX." ;
    oc:severityLevel "HIGH" .

oc:kn_580cd469 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling interactive elements" ;
    oc:directiveContent "Never remove focus indicators with focus:outline-none alone. Always pair with focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 for accessible focus states." ;
    oc:hasRationale "Removing focus styles breaks keyboard accessibility. focus-visible shows ring only during keyboard navigation, not mouse clicks." ;
    oc:severityLevel "CRITICAL" .

oc:kn_60278022 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing text and background color combinations" ;
    oc:directiveContent "Ensure WCAG AA color contrast: 4.5:1 for normal text, 3:1 for large text. Use semantic color names (text-muted-foreground, text-destructive) rather than arbitrary gray values." ;
    oc:hasRationale "Insufficient contrast excludes users with visual impairments. Semantic colors maintain contrast across light/dark themes." ;
    oc:severityLevel "CRITICAL" .

oc:kn_67606c7d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building dynamic class logic" ;
    oc:directiveContent "Avoid dynamic Tailwind class names (e.g., class string concatenation). Use complete class names or safelist patterns. Tailwind purges classes it cannot statically detect." ;
    oc:hasRationale "Tailwind's build-time dead code elimination cannot detect dynamically constructed class names, causing styles to be missing in production." ;
    oc:severityLevel "CRITICAL" .

oc:kn_99bdcc9c a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "On component installation failure" ;
    oc:directiveContent "If shadcn add fails, check: (1) components.json exists, (2) npx available, (3) Node.js 18+. Use --overwrite flag to reinstall corrupted components." ;
    oc:hasRationale "Most failures stem from missing initialization, outdated Node, or previously installed components blocking reinstallation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b4c79d4e a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When implementing dark mode support" ;
    oc:directiveContent "Apply dark: variants to ALL themed elements for consistent dark mode. Every bg-white needs dark:bg-gray-900, every text-gray-900 needs dark:text-white." ;
    oc:hasRationale "Partial dark mode coverage creates jarring inconsistencies where some elements appear broken in dark theme." ;
    oc:severityLevel "HIGH" .

oc:kn_e77e00dd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating canvas visual designs" ;
    oc:directiveContent "For canvas-based visual design: use 90% visual elements, 10% text maximum. Text should be rare labels integrated into visual architecture, never paragraphs." ;
    oc:hasRationale "Canvas design philosophy prioritizes visual communication over text-heavy layouts for maximum impact and sophistication." ;
    oc:severityLevel "MEDIUM" .

