oc:kn_12d383c8 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When designing banners" ;
    oc:directiveContent "1. Gather requirements via AskUserQuestion → 2. Research with ui-ux-pro-max, browse Pinterest → 3. Design HTML/CSS with frontend-design, generate visuals → 4. Screenshot to PNG at exact dimensions → 5. Present all options, iterate" ;
    oc:stepOrder 3 .

oc:kn_38f8bfaa a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When any Python script (logo, CIP, icon) fails during execution" ;
    oc:directiveContent "When scripts fail, try to fix them directly rather than falling back to manual generation" ;
    oc:hasRationale "Scripts contain domain-specific logic that manual generation cannot replicate; fixing is faster than rebuilding" ;
    oc:severityLevel "MEDIUM" .

oc:kn_45ff695c a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing logo, CIP, or icon generation" ;
    oc:directiveContent "Verify GEMINI_API_KEY is set and google-genai + pillow packages are installed before running any generation scripts" ;
    oc:hasRationale "Missing API key or dependencies cause immediate script failure with unclear errors" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4941e091 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating logos, CIP mockups, or icons" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """python3 ~/.claude/skills/design/scripts/logo/generate.py --brand "BrandName" --style minimalist --industry tech
python3 ~/.claude/skills/design/scripts/cip/generate.py --brand "Brand" --logo /path/to/logo.png --deliverable "business card" --industry "consulting"
python3 ~/.claude/skills/design/scripts/icon/generate.py --prompt "settings gear" --style outlined""" .

oc:kn_4add4a7d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing banners, social covers, or social photos" ;
    oc:directiveContent "Always keep critical content within the central 70-80% of any banner or social photo canvas to respect safe zones" ;
    oc:hasRationale "Platform UI chrome and crop variations clip content near edges" ;
    oc:severityLevel "MEDIUM" .

oc:kn_50d1b14d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When user requests a full brand identity package" ;
    oc:directiveContent "For complete brand packages, follow the sequence: Logo→CIP mockups→Presentation. Logo must exist before CIP generation" ;
    oc:hasRationale "CIP mockups require logo images; presentations showcase both, so this order avoids rework" ;
    oc:severityLevel "HIGH" .

oc:kn_6b3fe1c6 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating CIP deliverables" ;
    oc:directiveContent "1. Generate CIP brief via search.py --cip-brief → 2. Generate mockups with logo via generate.py --brand --logo --industry → 3. Render HTML presentation via render-html.py --brand --industry --images" ;
    oc:stepOrder 2 .

oc:kn_7348ce67 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any logo image" ;
    oc:directiveContent "Never generate logos without white background — always specify white background for output logo images" ;
    oc:hasRationale "White backgrounds ensure logos work universally across brand materials and mockups" ;
    oc:severityLevel "HIGH" .

oc:kn_74c94481 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When choosing generation model" ;
    oc:directiveContent "Gemini Flash model (default) is fast and cost-effective. Pro model provides higher quality with 4K text rendering but is slower. Icon generation uses Gemini 3.1 Pro Preview for text-only SVG output" ;
    oc:hasRationale "Model selection impacts both cost and output quality; choose based on deliverable requirements" ;
    oc:severityLevel "LOW" .

oc:kn_7cb1e1b1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any visual output" ;
    oc:directiveContent "Max 2 typefaces per design, minimum 16px body text, ≥32px headlines for digital; 300 DPI, CMYK, 3-5mm bleed for print" ;
    oc:hasRationale "Typography limits maintain visual coherence; print specs ensure physical output quality" ;
    oc:severityLevel "MEDIUM" .

oc:kn_894b7514 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When receiving any design request" ;
    oc:directiveContent "Route design tasks by type: brand identity→brand skill, tokens/specs→design-system, components→ui-styling, logo→built-in logo scripts, CIP→built-in CIP scripts, presentations→slides, banners→banner reference, icons→icon scripts" ;
    oc:hasRationale "Correct routing ensures the right tools and knowledge bases are activated for each design domain" ;
    oc:severityLevel "CRITICAL" .

oc:kn_8f7235ab a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing social media ad banners" ;
    oc:directiveContent "Never put more than 20% text on ad banners — Meta penalizes high text-to-image ratios" ;
    oc:hasRationale "Meta's algorithm demotes ads with excessive text overlay, reducing reach and CTR" ;
    oc:severityLevel "HIGH" .

oc:kn_aa3047b3 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """# Social Photos Design Report
## Overview
- Prompt/requirements: {input}
- Platforms: {platforms}
- Variations: {count}
- Style: {style}
## Ideas Generated
## Design Decisions (palette, typography, layout, brand alignment)
## Output Files (file, size, platform, preview)
## Why This Works
## Recommendations""" ;
    oc:templateVariables "count",
        "input",
        "platforms",
        "style" .

oc:kn_b27be06e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When designing logos" ;
    oc:directiveContent "1. Generate design brief via search.py --design-brief → 2. Generate logo/mockup variants via generate.py → 3. Ask user about HTML preview via AskUserQuestion → 4. If yes, invoke ui-ux-pro-max for gallery" ;
    oc:stepOrder 1 .

oc:kn_b5fc8e05 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When running any generate.py or render-html.py script" ;
    oc:directiveContent "All generation scripts create image files on disk (PNG/SVG). CIP render-html.py creates a single-file HTML presentation with base64-embedded images" ;
    oc:hasRationale "Understanding output artifacts helps manage disk space and file organization" ;
    oc:severityLevel "LOW" .

oc:kn_c4028547 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running any AI generation script" ;
    oc:directiveContent "Requires GEMINI_API_KEY environment variable (obtain from https://aistudio.google.com/apikey) and pip install google-genai pillow" .

oc:kn_e9e494e8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing banners and social photos" ;
    oc:directiveContent "Use the 3-zone visual hierarchy: top=logo/value prop, middle=supporting message+visuals, bottom=CTA. One CTA per banner, bottom-right, min 44px height" ;
    oc:hasRationale "Consistent visual hierarchy guides viewer eye flow and maximizes conversion" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f01b8c8b a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting any logo or CIP design project" ;
    oc:directiveContent """python3 ~/.claude/skills/design/scripts/logo/search.py "query" --design-brief -p "BrandName"
python3 ~/.claude/skills/design/scripts/cip/search.py "query" --cip-brief -b "BrandName\"""" .

oc:kn_f111799d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating social photos" ;
    oc:directiveContent "1. Orchestrate tasks via project-management → 2. Analyze requirements (subject, platforms, style, brand) → 3. Ideate 3-5 concepts, present for approval → 4. Design HTML per idea×size with brand+design-system+ui skills → 5. Export screenshots with 3-5s delay for fonts → 6. Verify visually, fix issues → 7. Generate report → 8. Organize outputs" ;
    oc:stepOrder 4 .

