    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:BrandIdentityDefined ;
    oc:resolvesIntent "create AI image generation prompts for brand collateral",
        "generate mockup prompts for corporate identity deliverables",
        "style corporate identity mockup photographs" ;
    oc:yieldsState oc:MockupPromptGenerated .

oc:kn_3a16bb9d a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Final assembled prompt output" ;
    oc:directiveContent "[Deliverable modifier], [Style modifier], [Lighting modifier], [Context modifier], photorealistic, professional photography, high quality, 8k resolution, detailed, sharp focus --negative blurry, low quality, distorted text, misspelled, amateur, clipart, cartoon, illustration, watermark" ;
    oc:hasRationale "Structured assembly ensures consistent, high-quality mockup generation across all deliverable types" .

oc:kn_9485c4fb a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When generating any CIP mockup prompt" ;
    oc:directiveContent "1. Identify deliverable type (business card, letterhead, signage, vehicle, apparel) 2. Fill base prompt template with brand parameters (name, colors, typography, placement) 3. Append deliverable-specific modifier 4. Select and apply style modifier 5. Choose lighting modifier (studio, natural, dramatic, warm) 6. Choose context modifier (marble desk, wooden table, office interior, flat lay, lifestyle) 7. Append quality modifiers 8. Add negative prompts to avoid artifacts" ;
    oc:stepOrder 1 .

oc:kn_9b39805b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting modifiers for specific CIP deliverables" ;
    oc:directiveContent "Match deliverable-specific modifiers to the physical context: business cards use marble surfaces at 45° angles, letterheads use flat lay with envelopes, signage uses 3D backlit LED in lobbies, vehicles use 3/4 front angle urban streets, apparel uses folded product photography" ;
    oc:hasRationale "Deliverable-appropriate staging creates believable mockups that stakeholders can visualize in real-world contexts" .

oc:kn_9bdea7c7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When determining the visual direction for a brand mockup" ;
    oc:directiveContent "Choose style modifier to match brand personality: Corporate Minimal (white space, matte), Luxury Premium (dark, gold accents, dramatic lighting), Modern Tech (gradients, geometric, futuristic), Warm Organic (natural materials, kraft, warm lighting)" ;
    oc:hasRationale "Style alignment with brand identity ensures mockups reinforce rather than contradict brand positioning" .

oc:kn_bc52f9a8 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any CIP mockup prompt" ;
    oc:directiveContent "Professional corporate identity mockup photograph showing [DELIVERABLE] for brand '[BRAND_NAME]', [STYLE] design style, using colors [COLORS], [TYPOGRAPHY] typography, logo placement: [PLACEMENT], [MATERIALS] materials with [FINISHES] finish, [CONTEXT] setting, [MOOD] mood, photorealistic product photography, soft natural lighting, high quality professional shot, 8k resolution detailed" ;
    oc:hasRationale "This base template ensures all brand identity parameters are captured in the AI image generation prompt" ;
    oc:templateVariables "BRAND_NAME",
        "COLORS",
        "CONTEXT",
        "DELIVERABLE",
        "FINISHES",
        "MATERIALS",
        "MOOD",
        "PLACEMENT",
        "STYLE",
        "TYPOGRAPHY" .

oc:kn_d05625d6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any CIP mockup image" ;
    oc:directiveContent "Always include negative prompts to avoid: blurry, low quality, distorted text, misspelled, amateur, clipart, cartoon, illustration, watermark" ;
    oc:hasRationale "Negative prompts prevent common AI image generation artifacts that undermine professional credibility of brand mockups" ;
    oc:severityLevel "HIGH" .

oc:kn_dfabb0b1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, when generating any mockup prompt" ;
    oc:directiveContent "Never omit quality modifiers (photorealistic, professional photography, high quality, 8k resolution, detailed, sharp focus) from any mockup prompt" ;
    oc:hasRationale "Without quality modifiers, AI generators produce low-fidelity or non-photorealistic results unsuitable for professional brand presentations" ;
    oc:severityLevel "HIGH" .

