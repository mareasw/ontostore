oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_cip_style_guide a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "cip-style-guide" ;
    skos:broader "Style guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-design" ;
    oc:contentHash "f3e15408cd981e93804440c1159c12e02d001bc37a3945f455b3fc13729ed4e1" ;
    oc:differentia "that defines corporate identity print design styles with color palettes, typography, materials, and finishes" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design ;
    oc:hasArgumentHint "industry or style name (e.g., \"finance\", \"tech\", \"luxury\")" ;
    oc:hasCategory "document" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Industries:** Fashion, Jewelry, Hotels, Fine Dining
**Colors:** Black (#1C1917), Gold (#D4AF37), White
**Typography:** Elegant serif (Playfair), thin sans
**Materials:** Heavy cotton paper, leather, metal
**Finishes:** Gold foil, emboss, deboss, soft-touch""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Luxury Premium" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Industries:** Sports, Entertainment, Gaming
**Colors:** Red (#DC2626), Orange (#F97316), Black
**Typography:** Bold condensed sans
**Materials:** High-contrast, metallic
**Finishes:** Gloss, vibrant colors""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Bold Dynamic" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 6 ;
                            oc:tableCaption "## Color Psychology" ;
                            oc:tableMarkdown """| Color | Meaning | Best Use |
|-------|---------|----------|
| Blue | Trust, stability | Finance, Tech, Healthcare |
| Green | Growth, nature | Eco, Wellness, Organic |
| Gold | Luxury, prestige | Premium, Jewelry |
| Red | Energy, passion | Food, Sports |
| Black | Sophistication | Luxury, Fashion |
| White | Clean, minimal | Tech, Healthcare |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 9 ;
                    oc:sectionTitle "Color Psychology" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Industries:** Law Firms, Heritage Brands, Finance
**Colors:** Navy, Burgundy, Gold
**Typography:** Traditional serif (Times, Garamond)
**Materials:** Quality laid paper, wood
**Finishes:** Letterpress, gold emboss""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Classic Traditional" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Industries:** Food, Organic, Wellness, Craft
**Colors:** Brown (#8B4513), Green (#228B22), Cream
**Typography:** Friendly serif, organic script
**Materials:** Kraft paper, recycled materials
**Finishes:** Uncoated, natural textures""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Warm Organic" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Industries:** Finance, Legal, Consulting, Tech
**Colors:** Navy (#0F172A), White (#FFFFFF), Blue accents
**Typography:** Clean sans-serif (Inter, Helvetica)
**Materials:** Premium matte paper, subtle textures
**Finishes:** Matte, spot UV on logo""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Corporate Minimal" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Industries:** Beauty, Wedding, Spa, Fashion
**Colors:** Pink (#F472B6), Gold, White
**Typography:** Elegant script, thin sans
**Materials:** Soft-touch, quality paper
**Finishes:** Rose gold foil, emboss""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Soft Elegant" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Industries:** Tech, SaaS, Startups, AI
**Colors:** Purple (#6366F1), Cyan (#0EA5E9), Green (#10B981)
**Typography:** Geometric sans (Outfit, Poppins)
**Materials:** Smooth surfaces, gradient prints
**Finishes:** Gloss, metallic accents""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Modern Tech" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Industries:** Healthcare, Wellness, Fintech
**Colors:** Mint (#10B981), Sky (#0EA5E9), White
**Typography:** Modern rounded sans
**Materials:** Light, clean surfaces
**Finishes:** Matte, clean minimal""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Fresh Modern" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "CIP Design Style Guide" ] ;
    oc:impartsKnowledge oc:kn_1bd8f8ba,
        oc:kn_34738e9b,
        oc:kn_aca9ad5d,
        oc:kn_db49975c,
        oc:kn_f04293aa ;
    oc:isUserInvocable true ;
    oc:nature "Reference" ;
    oc:resolvesIntent "apply color psychology to design decisions",
        "choose color palette by industry",
        "determine print materials and finishes by style",
        "match typography to brand personality",
        "select design style for corporate identity" .

oc:kn_1bd8f8ba a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assembling design specs for print or digital output" ;
    oc:directiveContent "Each style has a fixed color palette, typography family, material type, and finish set — do not mix elements across styles arbitrarily." ;
    oc:hasRationale "Cross-style mixing breaks visual coherence and dilutes brand identity" ;
    oc:severityLevel "HIGH" .

oc:kn_34738e9b a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a design style for any corporate identity project" ;
    oc:directiveContent "Match design style to industry: Corporate Minimal for Finance/Legal/Consulting, Modern Tech for SaaS/AI/Startups, Luxury Premium for Fashion/Jewelry/Hotels, Classic Traditional for Law/Heritage/Finance, Warm Organic for Food/Wellness/Craft, Bold Dynamic for Sports/Entertainment/Gaming, Fresh Modern for Healthcare/Fintech, Soft Elegant for Beauty/Wedding/Spa." ;
    oc:hasRationale "Industry alignment ensures visual communication resonates with target audience expectations and market positioning" .

oc:kn_aca9ad5d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing or justifying a primary color for a brand" ;
    oc:directiveContent "Use color psychology to guide palette selection: Blue = Trust (Finance, Tech), Green = Growth (Eco, Wellness), Gold = Luxury (Premium), Red = Energy (Food, Sports), Black = Sophistication (Luxury), White = Clean (Tech, Healthcare)." ;
    oc:hasRationale "Color psychology is empirically linked to audience perception and brand trust signals" .

oc:kn_db49975c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When mapping styles to industries" ;
    oc:directiveContent "Never use Warm Organic style (kraft paper, recycled materials, uncoated textures) for Luxury Premium industries (jewelry, fine dining) or vice versa." ;
    oc:hasRationale "Mismatched material and finish choices create dissonance between brand promise and visual delivery" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f04293aa a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining CSS or design token color variables for a CIP style" ;
    oc:codeLanguage "css" ;
    oc:directiveContent "Corporate Minimal: Navy #0F172A, White #FFFFFF, Blue accents. Modern Tech: Purple #6366F1, Cyan #0EA5E9, Green #10B981. Luxury Premium: Black #1C1917, Gold #D4AF37. Warm Organic: Brown #8B4513, Green #228B22. Bold Dynamic: Red #DC2626, Orange #F97316. Fresh Modern: Mint #10B981, Sky #0EA5E9. Soft Elegant: Pink #F472B6." ;
    oc:hasRationale "Exact hex values ensure color consistency across all outputs" .

