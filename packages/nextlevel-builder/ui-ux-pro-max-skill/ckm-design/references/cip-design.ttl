oc:kn_0be8c051 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When brand has no logo yet" ;
    oc:directiveContent "Do not generate mockups without a logo and then re-generate with a logo — if no logo exists, use Logo Design skill first" ;
    oc:hasRationale "Re-generating an entire CIP set wastes API credits and time; establishing the logo first ensures consistency" .

oc:kn_1be74afa a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When searching CIP domains for deliverables, styles, industries, or mockup contexts" ;
    oc:directiveContent "python3 ~/.claude/skills/design/scripts/cip/search.py \"{query}\" --domain deliverable|style|industry|mockup" .

oc:kn_239ca315 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any mockup generation" ;
    oc:directiveContent "Always generate a CIP brief first before creating mockups to establish consistent style and deliverable scope" ;
    oc:hasRationale "Briefing ensures coherent visual identity across all deliverables and avoids costly re-generation" .

oc:kn_26fca72a a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Standard CIP generation workflow" ;
    oc:directiveContent "1. Run search.py --cip-brief to create brief 2. Run generate.py --brand --logo --industry --set to generate mockups 3. Run render-html.py --brand --industry --images to create presentation" ;
    oc:stepOrder 1 .

oc:kn_5965c792 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating full CIP deliverable set" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "python3 ~/.claude/skills/design/scripts/cip/generate.py --brand \"{brand}\" --logo {logo_path} --industry \"{industry}\" --set" .

oc:kn_5bfd365d a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running any CIP script" ;
    oc:directiveContent "GEMINI_API_KEY must be set and google-genai + pillow Python packages installed" .

oc:kn_6592032e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Pre-flight check before execution" ;
    oc:directiveContent "GEMINI_API_KEY environment variable must be set and google-genai + pillow packages must be installed before any generation" ;
    oc:hasRationale "All mockup generation depends on Gemini API access and Pillow for image processing" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9c0005d8 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When selecting generation model" ;
    oc:directiveContent "Use flash model (default) for speed and cost; use pro model only for 4K text rendering quality requirements" ;
    oc:hasRationale "Flash is fast and cost-effective; Pro provides higher quality but at greater cost and latency" .

oc:kn_bd098127 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating a single deliverable mockup" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "python3 ~/.claude/skills/design/scripts/cip/generate.py --brand \"{brand}\" --logo {logo_path} --deliverable \"{deliverable}\" --industry \"{industry}\"" .

oc:kn_c252898d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating mockups" ;
    oc:directiveContent "Use --logo flag with an actual logo file for mockup generation whenever possible; only fall back to --no-logo-prompt when no logo exists" ;
    oc:hasRationale "Logo-based mockups use image editing for accurate brand placement, while no-logo mode relies on AI interpretation which may be inconsistent" .

