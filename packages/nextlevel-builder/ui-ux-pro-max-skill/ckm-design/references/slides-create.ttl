oc:kn_333228c4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding Chart.js visualizations to slides — supports bar, line, pie, doughnut, radar types" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """new Chart(document.getElementById('chartId'), {
  type: 'line',
  data: { labels: [...], datasets: [{ data: [...], borderColor: '#FF6B6B', fill: true, tension: 0.4 }] },
  options: { responsive: true, maintainAspectRatio: false }
});""" .

oc:kn_411f71ef a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting presentation strategy" ;
    oc:directiveContent "Match slide strategy to context: YC Seed/Series A for fundraising, Sales Pitch/Product Demo for selling, QBR/All-Hands for internal updates, Conference Talk for public speaking, Case Study for proving value" ;
    oc:hasRationale "Each strategy has a proven emotion arc and slide structure optimized for its audience and goal" .

oc:kn_619a79a3 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring any HTML slide — always wrap slide content in .slide-content for safe area constraints" ;
    oc:codeLanguage "html" ;
    oc:directiveContent """<div class="slide-deck">
  <div class="slide active">
    <div class="slide-content">
      <h1 class="slide-title">Title</h1>
      <p>Subtitle</p>
    </div>
  </div>
</div>""" .

oc:kn_6a9f71f9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing slide copy" ;
    oc:directiveContent "Apply copywriting formulas by slide type: PAS for problem slides, AIDA for CTAs, FAB for features, Cost of Inaction for urgency, Before-After-Bridge for transformation" ;
    oc:hasRationale "Formula-driven copy is more persuasive and matches the emotional arc of each slide position" .

oc:kn_b4029990 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any HTML slide presentation" ;
    oc:directiveContent "1. Parse presentation type from user request → 2. Load references/slides-create.md for creation guide → 3. Select layout patterns from references/slides-layout-patterns.md → 4. Apply copywriting formulas from references/slides-copywriting-formulas.md → 5. Use HTML template from references/slides-html-template.md → 6. Apply strategy from references/slides-strategies.md" ;
    oc:hasRationale "This 6-step workflow ensures strategic, well-structured presentations that leverage the full knowledge base" ;
    oc:stepOrder 1 .

oc:kn_edb7f7de a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when building the slide deck container" ;
    oc:directiveContent "Lock slide deck to 16:9 aspect ratio on desktop using max-width: calc(100vh * 16 / 9) and max-height: calc(100vw * 9 / 16) with letterboxing" ;
    oc:hasRationale "Maintaining 16:9 prevents layout distortion across different screen sizes" .

oc:kn_f23e860f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "Always when styling slides" ;
    oc:directiveContent "Use CSS variables (--color-primary, --color-background, --color-secondary, --primitive-gradient-primary, --typography-font-heading, --typography-font-body) for consistent theming across all slides" ;
    oc:hasRationale "Design tokens ensure brand consistency and enable easy theme changes" .

oc:kn_fbf6818e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing layouts for individual slides" ;
    oc:directiveContent "Use layout decision flow: slide goal → search layout-logic.csv, desired emotion → search color-logic.csv, content type → search typography.csv, pattern break at 1/3 and 2/3 positions → use full-bleed" ;
    oc:hasRationale "Systematic layout selection ensures visual variety and emotional progression through the deck" .

oc:kn_ffe57a63 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing the narrative arc of the deck" ;
    oc:directiveContent "Alternate between 'What Is' (current pain) and 'What Could Be' (better future) slides using the Duarte Sparkline pattern, with pattern breaks at 1/3 and 2/3 positions" ;
    oc:hasRationale "The Sparkline pattern creates engagement peaks and drives persuasion through contrast" .

_:ref_30755218baf036b8 a oc:WorkflowStep ;
    dcterms:description "Assemble HTML using template from references/slides-html-template.md with design tokens, layouts, copy, and Chart.js" ;
    oc:expectedOutcome "Complete HTML file with all slides, navigation, and interactivity" ;
    oc:stepDependsOn _:ref_db66f391c9eb32da,
        _:ref_fc345b9fd01ff363 ;
    oc:stepId "build-html" .

_:ref_60314e67433546c9 a oc:WorkflowStep ;
    dcterms:description "Parse user request to determine presentation type (pitch deck, sales, demo, etc.)" ;
    oc:expectedOutcome "Presentation type and strategy identified" ;
    oc:stepId "parse-request" .

_:ref_db66f391c9eb32da a oc:WorkflowStep ;
    dcterms:description "Load references/slides-layout-patterns.md and assign layout patterns to each slide" ;
    oc:expectedOutcome "Layout patterns assigned per slide with animation classes" ;
    oc:stepDependsOn _:ref_2372f8af9cd02299 ;
    oc:stepId "select-layouts" .

_:ref_fc345b9fd01ff363 a oc:WorkflowStep ;
    dcterms:description "Apply copywriting formulas from references/slides-copywriting-formulas.md to each slide's content" ;
    oc:expectedOutcome "Persuasive copy written for each slide using appropriate formula" ;
    oc:stepDependsOn _:ref_2372f8af9cd02299 ;
    oc:stepId "write-copy" .

_:ref_2372f8af9cd02299 a oc:WorkflowStep ;
    dcterms:description "Load references/slides-strategies.md and select appropriate deck structure and emotion arc" ;
    oc:expectedOutcome "Strategy selected with slide count and emotion arc defined" ;
    oc:stepDependsOn _:ref_60314e67433546c9 ;
    oc:stepId "select-strategy" .

