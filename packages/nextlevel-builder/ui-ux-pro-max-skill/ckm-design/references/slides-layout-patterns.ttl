oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_slides_layout_patterns a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "slides-layout-patterns" ;
    skos:broader "Layout pattern library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-design" ;
    oc:contentHash "0a967ca3bd829d3234e6f1802bade6c76447fabbaddbc8117c41adbae7dfb6df" ;
    oc:differentia "that provides 25 slide layout structures with CSS grids, responsive breakpoints, animation classes, component variants, and visual treatments for HTML presentations" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design ;
    oc:handlesFailure oc:InvalidBreakpoint,
        oc:LayoutNotFound ;
    oc:hasCategory "design" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "25 slide layouts with CSS structures and animation classes." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """.slide-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}
@media (max-width: 768px) {
    .slide-features { grid-template-columns: repeat(2, 1fr); gap: 16px; }
}
@media (max-width: 480px) {
    .slide-features { grid-template-columns: 1fr; }
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 51-63" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Feature Grid (3 columns)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """.slide-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
}
@media (max-width: 768px) {
    .slide-metrics { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
    .slide-metrics { grid-template-columns: 1fr; }
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 66-78" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Metrics Dashboard (4 columns)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """.slide-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
}
@media (max-width: 768px) {
    .slide-split { grid-template-columns: 1fr; gap: 24px; }
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 38-48" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Two Column Split" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """.slide-title {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 27-35" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Title Slide" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "CSS Structures" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """1. What's the slide goal?
   └─> Search layout-logic.csv

2. What emotion should it trigger?
   └─> Search color-logic.csv

3. What's the content type?
   └─> Search typography.csv

4. Should it break pattern?
   └─> Check position (1/3, 2/3) → Use full-bleed
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 125-137" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Layout Decision Flow" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 14 ;
                            oc:tableCaption "## Layout Selection by Use Case" ;
                            oc:tableMarkdown """| Layout | Use Case | Animation |
|--------|----------|-----------|
| Title Slide | Opening/first impression | `animate-fade-up` |
| Problem Statement | Establish pain point | `animate-stagger` |
| Solution Overview | Introduce solution | `animate-scale` |
| Feature Grid | Show capabilities (3-6 cards) | `animate-stagger` |
| Metrics Dashboard | Display KPIs (3-4 metrics) | `animate-stagger-scale` |
| Comparison Table | Compare options | `animate-fade-up` |
| Timeline Flow | Show progression | `animate-stagger` |
| Team Grid | Introduce people | `animate-stagger` |
| Quote Testimonial | Customer endorsement | `animate-fade-up` |
| Two Column Split | Compare/contrast | `animate-fade-up` |
| Big Number Hero | Single powerful metric | `animate-count` |
| Product Screenshot | Show product UI | `animate-scale` |
| Pricing Cards | Present tiers | `animate-stagger` |
| CTA Closing | Drive action | `animate-pulse` |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Layout Selection by Use Case" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Find layout for specific use
python .claude/skills/design-system/scripts/search-slides.py "metrics dashboard" -d layout

# Contextual recommendation
python .claude/skills/design-system/scripts/search-slides.py "traction slide" \\
  --context --position 4 --total 10
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 114-121" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Search Commands" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "### Card Styles" ;
                                    oc:tableMarkdown """| Style | CSS Class | Use For |
|-------|-----------|---------|
| Icon Left | `.card-icon-left` | Features with icons |
| Accent Bar | `.card-accent-bar` | Highlighted features |
| Metric Card | `.card-metric` | Numbers/stats |
| Avatar Card | `.card-avatar` | Team members |
| Pricing Card | `.card-pricing` | Price tiers |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Card Styles" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Metric Styles" ;
                                    oc:tableMarkdown """| Style | Effect |
|-------|--------|
| `gradient-number` | Gradient text on numbers |
| `oversized` | Extra large (120px+) |
| `sparkline` | Small inline chart |
| `funnel-numbers` | Conversion stages |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Metric Styles" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Component Variants" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 8 ;
                            oc:tableCaption "## Visual Treatments" ;
                            oc:tableMarkdown """| Treatment | When to Use |
|-----------|-------------|
| `gradient-glow` | Title slides, CTAs |
| `subtle-border` | Problem statements |
| `icon-top` | Feature grids |
| `screenshot-shadow` | Product screenshots |
| `popular-highlight` | Pricing (scale 1.05) |
| `bg-overlay` | Background images |
| `contrast-pair` | Before/after |
| `logo-grayscale` | Client logos |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Visual Treatments" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Layout Patterns" ] ;
    oc:impartsKnowledge oc:kn_2897a15a,
        oc:kn_2b1aaac8,
        oc:kn_3a508f3d,
        oc:kn_48d55de8,
        oc:kn_c3d13ae4,
        oc:kn_cbe53d92,
        oc:kn_e2d819ae,
        oc:kn_e7785121,
        oc:kn_e7f85539 ;
    oc:isUserInvocable false ;
    oc:nature "Reference" ;
    oc:requiresState oc:DesignTokensLoaded,
        oc:SlideContentDefined ;
    oc:resolvesIntent "apply CSS grid structures for responsive slides",
        "choose animation classes for slide transitions",
        "find visual treatments for specific slide types",
        "pick card and metric styles for slide components",
        "select slide layout for presentation content" ;
    oc:yieldsState oc:SlideCSSApplied,
        oc:SlideLayoutSelected .

oc:kn_2897a15a a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires design tokens to be loaded for consistent spacing, colors, and typography in slide layouts" .

oc:kn_2b1aaac8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building feature grid or metrics dashboard slides" ;
    oc:directiveContent "Do not use more than 6 cards in a feature grid or more than 4 metrics in a dashboard row." ;
    oc:hasRationale "Exceeding these limits causes cards/metrics to become too small and visually cluttered, reducing comprehension" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3a508f3d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a layout for any new slide" ;
    oc:directiveContent "Use the layout decision flow: 1) Identify slide goal → search layout-logic.csv, 2) Identify target emotion → search color-logic.csv, 3) Identify content type → search typography.csv, 4) Check position for pattern-breaking full-bleed at 1/3 or 2/3 marks." ;
    oc:hasRationale "Systematic lookup across the three logic CSVs ensures layout, color, and typography are coherently aligned to the slide's purpose" .

oc:kn_48d55de8 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating a feature grid slide with responsive breakpoints" ;
    oc:codeLanguage "css" ;
    oc:directiveContent """.slide-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}
@media (max-width: 768px) {
    .slide-features { grid-template-columns: repeat(2, 1fr); gap: 16px; }
}
@media (max-width: 480px) {
    .slide-features { grid-template-columns: 1fr; }
}""" .

oc:kn_c3d13ae4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any grid-based slide layout" ;
    oc:directiveContent "All grid layouts must include responsive breakpoints at 768px and 480px, reducing column counts progressively (3→2→1 or 4→2→1)." ;
    oc:hasRationale "Without responsive breakpoints, slide content overflows or becomes unreadable on smaller screens and projectors" ;
    oc:severityLevel "HIGH" .

oc:kn_cbe53d92 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When documenting or searching slide layouts" ;
    oc:directiveContent """| Layout | Use Case | Animation |
|--------|----------|-----------|
| {layout_name} | {use_case} | {animation_class} |""" ;
    oc:templateVariables "animation_class",
        "layout_name",
        "use_case" .

oc:kn_e2d819ae a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting animations for any slide" ;
    oc:directiveContent "Match animation class to slide purpose: animate-fade-up for informational, animate-stagger for lists/grids, animate-scale for reveals, animate-count for metrics, animate-pulse for CTAs." ;
    oc:hasRationale "Animation type reinforces the slide's communication goal — stagger draws attention to multiple items, scale creates emphasis, pulse drives urgency" .

oc:kn_e7785121 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building any presentation slide" ;
    oc:directiveContent "1. Identify slide goal and content type 2. Look up matching layout from layout-selection table 3. Apply corresponding CSS grid structure with responsive breakpoints 4. Select appropriate animation class 5. Choose card/metric style variant 6. Apply visual treatment matching slide position and purpose" ;
    oc:stepOrder 1 .

oc:kn_e7f85539 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when working with layout CSS" ;
    oc:directiveContent "CSS classes and layout patterns are pure definitions — applying the same class multiple times produces identical visual output with no side effects." ;
    oc:hasRationale "Layout patterns are stateless CSS rules; they can be freely reapplied or swapped without concern for accumulated state" .

