oc:kn_58e52cb3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting or recommending logo styles" ;
    oc:directiveContent "55+ styles available across 4 categories: General (Minimalist, Wordmark, Lettermark, etc.), Aesthetic (Vintage, Art Deco, Luxury, etc.), Modern (Gradient, Flat, 3D, etc.), Clever (Negative Space, Monoline, etc.)" ;
    oc:hasRationale "Broad style catalog enables matching any brand personality" .

oc:kn_76fd9a0b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating logos with generate.py" ;
    oc:directiveContent "ALWAYS use white background for output logos" ;
    oc:hasRationale "White backgrounds ensure logo visibility and compatibility across all use cases" ;
    oc:severityLevel "CRITICAL" .

