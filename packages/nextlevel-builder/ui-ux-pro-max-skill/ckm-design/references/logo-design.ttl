oc:kn_c06cf9d4 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every logo design request" ;
    oc:directiveContent "1. Generate design brief via `scripts/logo/search.py --design-brief` 2. Generate logo variations via `scripts/logo/generate.py --brand --style --industry` 3. Ask user if they want HTML preview 4. If yes, invoke `/ui-ux-pro-max` for HTML gallery" ;
    oc:stepOrder 1 .

oc:kn_e50cc38a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user has not specified a preferred style" ;
    oc:directiveContent "Match logo style to industry defaults: Tech→Minimalist/Abstract+blues/gradients, Healthcare→Professional/Line Art+blues/greens, Finance→Corporate/Emblem+navy/gold, Food→Vintage Badge/Mascot+warm reds, Fashion→Wordmark/Luxury+black/gold" ;
    oc:hasRationale "Industry conventions communicate professionalism and audience trust" .

