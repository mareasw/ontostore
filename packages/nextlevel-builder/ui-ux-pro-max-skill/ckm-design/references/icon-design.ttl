oc:kn_02016fcb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any SVG icon" ;
    oc:directiveContent "Use viewBox 0 0 24 24 (standard) or 0 0 16 16 (compact) for all SVG icons. Design at 24px and test at 16px and 48px for clarity." ;
    oc:hasRationale "Consistent viewBox ensures icons scale predictably across different UI contexts" ;
    oc:severityLevel "HIGH" .

oc:kn_1a0466ff a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before running any icon generation" ;
    oc:directiveContent "GEMINI_API_KEY must be set as environment variable and google-genai package installed (pip install google-genai)" ;
    oc:hasRationale "The script depends on the Gemini API for SVG generation and the google-genai Python client" .

oc:kn_25092412 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating SVG icon markup" ;
    oc:directiveContent "Never use hardcoded colors in SVG icons. Use currentColor for CSS inheritance and avoid embedded fonts or raster images." ;
    oc:hasRationale "currentColor enables theme integration and dynamic coloring; embedded assets bloat file size" ;
    oc:severityLevel "HIGH" .

oc:kn_385992cd a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After running icon generation" ;
    oc:directiveContent "A valid .svg file is written to the output directory with proper viewBox, currentColor usage, and <title> element" ;
    oc:hasRationale "These properties confirm the icon is production-ready and accessible" .

oc:kn_49c60127 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating outlined-style SVG icons" ;
    oc:directiveContent "Always include a <title> element in SVG output for accessibility. Use stroke-linecap=\"round\" and stroke-linejoin=\"round\" for outlined styles." ;
    oc:hasRationale "Accessibility compliance requires descriptive titles; rounded line caps/joins produce polished outlined icons" ;
    oc:severityLevel "MEDIUM" .

oc:kn_62567467 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing an AI model for icon generation" ;
    oc:directiveContent "Gemini 3.1 Pro Preview generates SVG as text output — no image generation API needed. This is token-efficient for structured XML output." ;
    oc:hasRationale "SVG is XML text, so text-only models can produce it directly without multimodal capabilities" .

oc:kn_64bb79f3 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When generating icons from scratch" ;
    oc:directiveContent "1. Describe icon with --prompt  2. Choose style with --style  3. Generate (script outputs .svg)  4. Optionally batch with --batch N for variations  5. Multi-size export with --sizes \"16,24,32,48\"" ;
    oc:hasRationale "This workflow ensures iterative refinement and produces all required size variants" ;
    oc:stepOrder 1 .

oc:kn_8c53a956 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting an icon style from the 15 available options" ;
    oc:directiveContent "Match icon style to use case: outlined for UI/web apps, filled for mobile/nav bars, duotone for marketing, thin for luxury/editorial, bold for headers/heroes." ;
    oc:hasRationale "Style-context alignment ensures visual coherence with the surrounding design language" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e186dff7 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating icons via CLI" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "python3 ~/.claude/skills/design/scripts/icon/generate.py --prompt \"{description}\" --style {style} --color \"{hex}\" --sizes \"16,24,32,48\" --output-dir ./icons" .

oc:payload_39281931d070918b a oc:ExecutionPayload ;
    oc:code "python3 ~/.claude/skills/design/scripts/icon/generate.py --prompt \"{prompt}\" --style {style} --output-dir {output_dir}" ;
    oc:executor "python" ;
    oc:timeout 60 .

