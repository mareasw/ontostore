    oc:yieldsState oc:DocumentCreated .

oc:kn_24814327 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any presentation structure" ;
    oc:directiveContent "Every effective deck follows an emotion arc that guides the audience through specific feeling states (e.g., curiosity→frustration→hope→confidence→urgency) to drive action." ;
    oc:hasRationale "Emotion arcs create psychological momentum that makes audiences receptive to the call-to-action." ;
    oc:severityLevel "HIGH" .

oc:kn_7d5a0e83 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building a deck for a specific strategy type" ;
    oc:directiveContent "Slide count matters per strategy: YC Seed = 10-12, Sales Pitch = 7-10, Product Demo = 5-8, Conference Talk = 15-25, Workshop = 20-40. Deviating significantly reduces effectiveness." ;
    oc:hasRationale "Each strategy's slide count is calibrated to the audience's attention span and the presentation's time constraints." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7d72ce7f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When selecting a slide strategy for a new presentation" ;
    oc:directiveContent "Match strategy to context: fundraising → YC Seed/Series A/Kawasaki; selling → Sales Pitch/Product Demo; internal → QBR/All-Hands/Board; public → Conference/Workshop; proving value → Case Study/Competitive Analysis; lead gen → Webinar." ;
    oc:hasRationale "Wrong strategy for the audience wastes slides and fails to achieve the presentation's goal." ;
    oc:severityLevel "HIGH" .

oc:kn_b4652f04 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any slide creation" ;
    oc:directiveContent "Never create a presentation without first identifying the target audience and selecting the matching strategy. A generic deck fails all audiences." ;
    oc:hasRationale "Audience misalignment is the primary cause of presentation failure — a board deck structure used for a sales pitch will not close deals." ;
    oc:severityLevel "CRITICAL" .

oc:kn_bfe52748 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the goal is to transform the audience's perspective or inspire change" ;
    oc:directiveContent "Use the Duarte Sparkline pattern to alternate between 'What Is' (current pain) and 'What Could Be' (better future), with pattern breaks at 1/3 and 2/3 positions to create engagement peaks." ;
    oc:hasRationale "Alternating pain/hope creates tension and release cycles that maintain audience engagement throughout the presentation." ;
    oc:severityLevel "MEDIUM" .

