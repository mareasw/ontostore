        oc:kn_b4652f04,
        oc:kn_bfe52748 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "build investor pitch deck",
        "create sales presentation",
        "design presentation emotion arc",
        "match presentation context to strategy",
