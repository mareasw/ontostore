oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_slides_strategies a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "slides-strategies" ;
    skos:broader "Presentation strategy framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-design" ;
    oc:contentHash "27ee3e53ffa0ea679ec83ebeacb0bcfbce498df57277e99f574b9c139dc44286" ;
    oc:differentia "provides 15 proven deck structures with emotion arcs for different audiences and goals" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "presentation context or goal (e.g., \"investor pitch\", \"sales demo\", \"conference talk\")" ;
    oc:hasCategory "document" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "15 proven deck structures with emotion arcs." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Find strategy by goal
python .claude/skills/design-system/scripts/search-slides.py "investor pitch" -d strategy

# Get emotion arc
python .claude/skills/design-system/scripts/search-slides.py "series a funding" -d strategy --json
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 77-83" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Search Commands" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 15 ;
                            oc:tableCaption "## Strategy Selection" ;
                            oc:tableMarkdown """| Strategy | Slides | Goal | Audience |
|----------|--------|------|----------|
| YC Seed Deck | 10-12 | Raise seed funding | VCs |
| Guy Kawasaki | 10 | Pitch in 20 min | Investors |
| Series A | 12-15 | Raise Series A | Growth VCs |
| Product Demo | 5-8 | Demonstrate value | Prospects |
| Sales Pitch | 7-10 | Close deal | Qualified leads |
| Nancy Duarte Sparkline | Varies | Transform perspective | Any |
| Problem-Solution-Benefit | 3-5 | Quick persuasion | Time-pressed |
| QBR | 10-15 | Update stakeholders | Leadership |
| Team All-Hands | 8-12 | Align team | Employees |
| Conference Talk | 15-25 | Thought leadership | Attendees |
| Workshop | 20-40 | Teach skills | Learners |
| Case Study | 8-12 | Prove value | Prospects |
| Competitive Analysis | 6-10 | Strategic decisions | Internal |
| Board Meeting | 15-20 | Update board | Directors |
| Webinar | 20-30 | Generate leads | Registrants |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Strategy Selection" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Pattern breaks at 1/3 and 2/3 positions create engagement peaks." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """What Is → What Could Be → What Is → What Could Be → New Bliss
(pain)     (hope)         (pain)     (hope)         (resolution)
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 68-71" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Alternate between \"What Is\" (current pain) and \"What Could Be\" (better future):" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Duarte Sparkline Pattern" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 6 ;
                            oc:tableCaption "## Matching Strategy to Context" ;
                            oc:tableMarkdown """| Context | Recommended Strategy |
|---------|---------------------|
| Raising money | YC Seed, Series A, Guy Kawasaki |
| Selling product | Sales Pitch, Product Demo |
| Internal update | QBR, All-Hands, Board Meeting |
| Public speaking | Conference Talk, Workshop |
| Proving value | Case Study, Competitive Analysis |
| Lead generation | Webinar |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Matching Strategy to Context" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Emotion arc:** curiosity→frustration→hope→confidence→urgency" ],
                                _:ref_e3d68f0ea8aac96d ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Product Demo (6 slides)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Emotion arc:** connection→frustration→fear→hope→trust→confidence→urgency" ],
                                _:ref_f4fdeae34d5fc9c5 ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Sales Pitch (9 slides)" ],
                        [ a oc:Section ;
                            oc:hasContent _:ref_90a0b382dbed85fd,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Emotion arc:** curiosity→frustration→hope→confidence→trust→urgency" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "YC Seed Deck (10 slides)" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Common Structures" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Slide Strategies" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Choose the right presentation strategy and build the deck structure with an appropriate emotion arc" ;
            oc:hasStep _:ref_2b65231ee66344b7,
                _:ref_736ca5d99114ccd6,
                _:ref_c57548812498ac7b,
                [ a oc:WorkflowStep ;
                    dcterms:description "Create the slide-by-slide outline following the strategy's prescribed structure and order" ;
                    oc:expectedOutcome "Complete slide outline with titles and content direction for each slide" ;
                    oc:stepDependsOn _:ref_2b65231ee66344b7,
                        _:ref_736ca5d99114ccd6 ;
                    oc:stepId "build-slide-outline" ] ;
            oc:workflowId "slides-strategy-selection" ;
            oc:workflowName "Select and Apply Slide Strategy" ],
        _:ref_90a0b382dbed85fd,
        _:ref_e3d68f0ea8aac96d,
        _:ref_f4fdeae34d5fc9c5 ;
    oc:impartsKnowledge oc:kn_24814327,
