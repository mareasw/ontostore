oc:kn_150b390c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a logo requires brand name text" ;
    oc:directiveContent "AI struggles with text generation in logos; generate the brand mark separately and add typography in post-production." ;
    oc:hasRationale "AI image generators frequently produce garbled, misspelled, or inconsistent text rendering." ;
    oc:severityLevel "HIGH" .

oc:kn_2e20059b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing any logo prompt" ;
    oc:directiveContent "Always specify background and aspect ratio explicitly: 'plain white background' and '1:1 square' or 'horizontal'." ;
    oc:hasRationale "Unclear backgrounds and wrong aspect ratios produce logos that cannot be used in standard placements." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2e6fad52 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always append negative prompts to every logo generation request" ;
    oc:directiveContent "Include negative prompts to exclude: photorealistic, 3D render, photograph, stock image, clip art, multiple logos, busy background, text watermarks, low quality, blurry, distorted, complex patterns." ;
    oc:hasRationale "Negative prompts dramatically reduce unwanted outputs and focus the AI on clean vector-style results." ;
    oc:severityLevel "HIGH" .

oc:kn_30c3bc1e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Identify industry and brand positioning 2. Select style keywords from appropriate category (minimalist, vintage, luxury, modern, playful, organic) 3. Choose color palette with emotional alignment 4. Add industry-specific prompt elements 5. Append technical requirements (scalability, versatility, quality) 6. Include negative prompts 7. Specify background and aspect ratio" ;
    oc:stepOrder 1 .

oc:kn_9bada0b5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When finalizing any logo brief" ;
    oc:directiveContent "Every logo prompt should specify three technical requirements: scalability (vector-style, works as favicon), versatility (works on light/dark backgrounds, single-color version), and quality (print-ready, crisp edges, balanced)." ;
    oc:hasRationale "Professional logos must function across all media sizes, backgrounds, and print/digital contexts." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a47844ba a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """Professional logo design for [brand name], a [industry] company.

Visual style: [style keywords]
Primary colors: [hex codes]
Mood: [emotional keywords]
Symbols: [iconography hints]

Technical: Vector-style illustration, scalable, works in single color,
centered on plain background, no text unless specified.""" ;
    oc:templateVariables "brand name",
        "emotional keywords",
        "hex codes",
        "iconography hints",
        "industry",
        "style keywords" .

oc:kn_b85c1bbd a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When constructing a logo generation prompt from scratch" ;
    oc:directiveContent """Professional logo design for [brand/industry]:
[Visual description]
Style: [style keywords]
Colors: [color palette]
Requirements: [technical specs]""" .

oc:kn_cd05ae65 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing logo prompts" ;
    oc:directiveContent "Avoid overly detailed prompts; AI generates complexity naturally, so explicitly request 'simple' and 'minimal' to get clean results." ;
    oc:hasRationale "Over-detailed prompts produce cluttered, busy logos that fail scalability and readability tests." ;
    oc:severityLevel "HIGH" .

oc:kn_eeb0b9c5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting any logo generation prompt" ;
    oc:directiveContent "Never request photorealistic or 3D-rendered logos; always specify 'illustration, vector-style, not photorealistic' to prevent unwanted outputs." ;
    oc:hasRationale "AI defaults to photorealistic rendering which produces unusable logos that cannot scale or function as brand marks." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fb2cfbc1 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When requesting logo variations or iterations" ;
    oc:directiveContent """Alternative version of [brand] logo:
Keep: [elements to preserve]
Change: [elements to modify]
Style direction: [new style keywords]""" .

