oc:kn_20d5faec a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When producing digital or environmental brand assets" ;
    oc:directiveContent "Digital assets require platform-specific dimensions (social media covers, email signatures max 600px), while environmental signage requires ADA compliance and material considerations (acrylic, metal, wood)." ;
    oc:hasRationale "Each medium has unique technical constraints; respecting them ensures professional output and regulatory compliance." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5e30f9e3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When preparing primary logo and logo variations" ;
    oc:directiveContent "Logo must be delivered in vector formats (SVG, AI, EPS) with multiple variations: horizontal, vertical, stacked, icon-only, and monochrome (black, white, reversed). It must scale from favicon to billboard." ;
    oc:hasRationale "Vector formats ensure lossless scaling; multiple variations ensure the logo works in any context or placement constraint." ;
    oc:severityLevel "CRITICAL" .

oc:kn_73b9d65c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting promotional merchandise" ;
    oc:directiveContent "Avoid promotional items that are low-quality or novelty-focused; prefer useful, durable items that prominently feature brand colors." ;
    oc:hasRationale "Low-quality promotional items reflect poorly on the brand and are quickly discarded, wasting budget and damaging perception." ;
    oc:severityLevel "MEDIUM" .

oc:kn_cd99475d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When producing any corporate identity deliverable" ;
    oc:directiveContent "Every CIP deliverable must maintain logo clear space, brand color fidelity, and consistent typography across all media types." ;
    oc:hasRationale "Visual consistency across all touchpoints is the primary purpose of a corporate identity program." ;
    oc:severityLevel "HIGH" .

oc:kn_f04190c0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing stationery set deliverables" ;
    oc:directiveContent "Business cards must follow standard dimensions (3.5×2 inches / 85×55mm), letterhead must match A4 or Letter size, and envelopes must use standard DL/C4/C5 sizes." ;
    oc:hasRationale "Non-standard dimensions increase printing costs and may not fit standard holders, wallets, or mailing systems." ;
    oc:severityLevel "HIGH" .

_:ref_36116654d5b9fd86 a oc:WorkflowStep ;
    dcterms:description "Define primary logo in vector format with all variations (horizontal, vertical, stacked, icon, monochrome)" ;
    oc:expectedOutcome "Complete logo suite with clear space rules and scalability verified" ;
    oc:stepId "s1-logo" .

