    oc:stepOrder 10 .

_:ref_db085bd63bf4415a a oc:WorkflowStep ;
    dcterms:description "**Gradient / Color Wash** — Smooth transitions, mesh gradients, chromatic blends" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_e6a196cb3086b5c6 a oc:WorkflowStep ;
    dcterms:description "**Flat / Solid Color** — Single background color, clean icons, no gradients" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_20" ;
    oc:stepOrder 20 .

