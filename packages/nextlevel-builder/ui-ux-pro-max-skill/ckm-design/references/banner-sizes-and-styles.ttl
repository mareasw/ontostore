oc:kn_0b0cacd2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any digital banner" ;
    oc:directiveContent "Critical content must stay within the central 70-80% of the canvas. Avoid text/CTA within 50-100px of edges." ;
    oc:hasRationale "Platform UI chrome and cropping during responsive display will clip edge content" ;
    oc:severityLevel "HIGH" .

oc:kn_5a163682 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any banner design" ;
    oc:directiveContent "Do not design banners without consulting the exact pixel dimensions for the target platform — sizes vary dramatically (e.g., LinkedIn company cover is 1128×191 vs YouTube channel art 2560×1440)." ;
    oc:hasRationale "Incorrect dimensions cause cropping, stretching, or rejection by platforms; each platform has unique requirements" ;
    oc:severityLevel "CRITICAL" .

oc:kn_8425875a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing YouTube or Meta/Instagram banners" ;
    oc:directiveContent "YouTube channel art has a safe area of 1546 × 423px inside a 2560 × 1440px canvas. Meta/Instagram: keep critical content in central 80%." ;
    oc:hasRationale "These platforms aggressively crop banners across devices; safe zones ensure visibility on all viewports" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a328f013 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing ads for Meta platforms or social covers" ;
    oc:directiveContent "Meta/Facebook ads: keep text under 20% of image area. Social covers: aim for 60/40 image-to-text ratio." ;
    oc:hasRationale "Meta penalizes ads with excessive text coverage; visual-heavy covers perform better on social feeds" ;
    oc:severityLevel "HIGH" .

oc:kn_b440b91b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When preparing print banner files (roll-up, step-and-repeat, vinyl, trade show)" ;
    oc:directiveContent "Print banners require 300 DPI minimum (150 DPI for large format), 3-5mm bleed all sides, CMYK color mode. Apply 1pt font size per foot of viewing distance." ;
    oc:hasRationale "Insufficient resolution, missing bleed, or RGB mode will cause print quality failures; viewing distance determines legible font sizes" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b49e2ec5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting typography on banners" ;
    oc:directiveContent "Max 2 typefaces per banner. Min 16px body text, ≥32px headline (digital). Min 4.5:1 contrast ratio. Max 7 words/line, 3 lines for ads." ;
    oc:hasRationale "Exceeding these limits reduces readability and ad performance; WCAG contrast requirements for accessibility" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e9ee7682 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When laying out any banner composition" ;
    oc:directiveContent "Apply the 3-Zone Rule: Top = logo/main value prop, Middle = supporting message + visuals, Bottom = CTA." ;
    oc:hasRationale "Follows natural scanning patterns (F-pattern/Z-pattern) and ensures information hierarchy is immediately clear" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ebf4e7a8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding calls-to-action to banners" ;
    oc:directiveContent "One CTA per banner, placed bottom-right with minimum 44px height for mobile tap targets. Use action verbs: Get, Start, Download, Claim." ;
    oc:hasRationale "Multiple CTAs dilute focus; bottom-right is the terminal reading area; 44px meets mobile accessibility standards" ;
    oc:severityLevel "HIGH" .

_:ref_0d8433f0f8922329 a oc:WorkflowStep ;
    dcterms:description "**Minimalist** — White space dominant, single focal element, 1-2 colors, clean sans-serif" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_1b19d04ae8ee4a34 a oc:WorkflowStep ;
    dcterms:description "**Digi-Cute / Kawaii** — Rounded shapes, pastel gradients, pixel art, playful characters" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_16" ;
    oc:stepOrder 16 .

_:ref_2a908d74aec25e52 a oc:WorkflowStep ;
    dcterms:description "**Motion-Ready / Kinetic** — Designed for animation; layered elements, loopable" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_22" ;
    oc:stepOrder 22 .

_:ref_2b97f0581ff3ae92 a oc:WorkflowStep ;
    dcterms:description "**Retro Futurism** — Space-age nostalgia, chrome, gradients, optimism" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_14" ;
    oc:stepOrder 14 .

_:ref_356fac5096281da9 a oc:WorkflowStep ;
    dcterms:description "**Collage / Mixed Media** — Cut-paper textures, photo cutouts, layered elements" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_13" ;
    oc:stepOrder 13 .

_:ref_4d0d3b2628651304 a oc:WorkflowStep ;
    dcterms:description "**Expressive / Anti-Design** — Chaotic layouts, mixed fonts, deliberate \"wrong\" composition" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_15" ;
    oc:stepOrder 15 .

_:ref_4f70e5c1063e3639 a oc:WorkflowStep ;
    dcterms:description "**Geometric / Abstract** — Shapes, lines, grids as primary visual elements" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_52922a3242d57657 a oc:WorkflowStep ;
    dcterms:description "**Data / Infographic** — Stats front-and-center, charts, numbers as heroes" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_18" ;
    oc:stepOrder 18 .

_:ref_63195c1296efba4a a oc:WorkflowStep ;
    dcterms:description "**Bold Typography** — Type IS the design; oversized, expressive letterforms fill canvas" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_66d075eedce92991 a oc:WorkflowStep ;
    dcterms:description "**Photo-Based** — Full-bleed photography with text overlay; hero lifestyle imagery" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_86acbce320b91163 a oc:WorkflowStep ;
    dcterms:description "**Glassmorphism** — Frosted glass panels, blur backdrop, subtle border glow" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_8" ;
    oc:stepOrder 8 .

_:ref_8b4e101c527347a8 a oc:WorkflowStep ;
    dcterms:description "**Illustrated / Hand-Drawn** — Custom illustrations, bespoke icons, artisan feel" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_8bd7094cecea37eb a oc:WorkflowStep ;
    dcterms:description "**Retro / Vintage** — Distressed textures, muted palettes, serif type, halftone dots" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_7" ;
    oc:stepOrder 7 .

_:ref_90eb77dd5b36a161 a oc:WorkflowStep ;
    dcterms:description "**Tactile / Sensory** — Puffy/squishy textures, hyper-real materials, embossed feel" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_17" ;
    oc:stepOrder 17 .

_:ref_91c026f348b32d95 a oc:WorkflowStep ;
    dcterms:description "**Duotone** — Two-color photo treatment; bold brand color overlay on image" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_11" ;
    oc:stepOrder 11 .

_:ref_a3a3d4d24a1b9c06 a oc:WorkflowStep ;
    dcterms:description "**Nature / Organic** — Earthy tones, botanical motifs, sustainable brand feel" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_21" ;
    oc:stepOrder 21 .

_:ref_b05fd5649d859e61 a oc:WorkflowStep ;
    dcterms:description "**Editorial / Magazine** — Grid-heavy layouts, pull quotes, journalistic composition" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_12" ;
    oc:stepOrder 12 .

_:ref_c44d6a88a4e0036a a oc:WorkflowStep ;
    dcterms:description "**3D / Sculptural** — Rendered objects, depth, shadows; product-centric" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_9" ;
    oc:stepOrder 9 .

_:ref_d6db3e1e7ad03598 a oc:WorkflowStep ;
    dcterms:description "**Dark Mode / Moody** — Near-black backgrounds, rich jewel tones, high contrast" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_19" ;
    oc:stepOrder 19 .

_:ref_d7e0a09d6ba0d252 a oc:WorkflowStep ;
    dcterms:description "**Neon / Cyberpunk** — Dark backgrounds, glowing neon accents, high contrast" ;
    oc:blockType "workflow_step" ;
