oc:kn_1f40be19 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any slide deck task" ;
    oc:directiveContent "Activate the parent 'design' skill before attempting slide creation — slides are invoked through the design skill, not standalone" ;
    oc:hasRationale "Slides depend on the design skill's token system and brand context" ;
    oc:severityLevel "CRITICAL" .

oc:kn_2b92f2dc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing slide copy for marketing, sales, or investor presentations" ;
    oc:directiveContent "Apply copywriting formulas (AIDA, PAS, FAB) to slide content to strengthen messaging and persuasion" ;
    oc:hasRationale "Structured copywriting formulas produce more compelling, conversion-oriented content" .

oc:kn_32884f77 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the final HTML output" ;
    oc:directiveContent "All presentations must be self-contained HTML files that work on both desktop and mobile without external build tools" ;
    oc:hasRationale "Portability and zero-dependency viewing are core to the HTML slide format" ;
    oc:severityLevel "HIGH" .

oc:kn_4d0cfa7f a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any slide presentation" ;
    oc:directiveContent "1. Parse presentation type from user request → 2. Load references/slides-create.md → 3. Select layout patterns from references/slides-layout-patterns.md → 4. Apply copywriting formulas from references/slides-copywriting-formulas.md → 5. Use HTML template from references/slides-html-template.md → 6. Apply strategy from references/slides-strategies.md" ;
    oc:hasRationale "Ensures consistent, strategic output by following the complete slide creation pipeline" ;
    oc:stepOrder 1 .

oc:kn_953fcd93 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When slides contain data or metrics" ;
    oc:codeLanguage "html" ;
    oc:directiveContent "Integrate Chart.js for data visualization: bar, line, pie, doughnut, and radar charts are supported. Embed chart configurations directly in the HTML template." ;
    oc:hasRationale "Chart.js provides responsive, professional data visualizations without external dependencies" .

oc:kn_b3573bdb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling any slide element" ;
    oc:directiveContent "Use design tokens for consistent spacing, colors, and typography across all slides rather than inline styles" ;
    oc:hasRationale "Design tokens ensure visual consistency and make global style changes possible" .

oc:kn_f494fb97 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When starting a new slide deck" ;
    oc:directiveContent "Match presentation type (marketing, pitch deck, investor, sales, team update) to the appropriate strategy from references/slides-strategies.md before selecting layouts or writing content" ;
    oc:hasRationale "Different presentation types have different audience expectations, narrative arcs, and visual requirements" .

