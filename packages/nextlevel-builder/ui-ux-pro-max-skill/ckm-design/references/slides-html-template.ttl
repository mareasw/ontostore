oc:kn_06ad8d42 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When programmatically navigating slides" ;
    oc:directiveContent "The showSlide(n) function clamps n to valid range [1, total], making repeated or out-of-range calls safe" ;
    oc:hasRationale "Prevents JavaScript errors from boundary navigation attempts" .

oc:kn_5841a38f a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When using .animate-stagger" ;
    oc:directiveContent "Limit stagger animations to 4 children or fewer; additional elements share the same 0.4s delay cap" ;
    oc:hasRationale "The CSS only defines delays for :nth-child(1) through (4); beyond that, children animate simultaneously" ;
    oc:severityLevel "LOW" .

oc:kn_5ddd923b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When authoring any slide" ;
    oc:directiveContent "Always wrap slide content in a .slide-content div to enforce safe area boundaries and prevent overflow" ;
    oc:hasRationale "The .slide class uses overflow:hidden and absolute positioning; without the inner wrapper, content can clip unpredictably" ;
    oc:severityLevel "HIGH" .

oc:kn_a15b0858 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When integrating Chart.js or any embedded visualization" ;
    oc:directiveContent "Do not use fixed pixel widths for chart containers; use min(), clamp(), or viewport-relative units instead" ;
    oc:hasRationale "Fixed dimensions break on tablet/mobile viewports and cause content overflow outside the slide safe area" ;
    oc:severityLevel "MEDIUM" .

oc:kn_bc6359e9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling any slide element" ;
    oc:directiveContent "Use CSS custom properties (variables) from the design token system for all colors, fonts, and gradients rather than hardcoded values" ;
    oc:hasRationale "Token-driven styling ensures brand consistency and enables theme changes from a single source of truth" ;
    oc:severityLevel "HIGH" .

oc:kn_be3f09b1 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before generating the final slide deck" ;
    oc:directiveContent "Verify Chart.js CDN is reachable and design tokens are injected into the :root CSS variables before generating the HTML file" ;
    oc:hasRationale "Missing tokens result in broken styling; unreachable CDN causes chart rendering failure" ;
    oc:severityLevel "CRITICAL" .

oc:kn_cffb82c4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting font-size on any text element" ;
    oc:directiveContent "Use clamp() for all typography sizes: clamp(min, preferred, max) with viewport-relative preferred values" ;
    oc:hasRationale "clamp() provides smooth scaling across breakpoints without requiring separate media queries for every element" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d394f55f a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding photographic or image backgrounds to slides" ;
    oc:directiveContent "For background image slides, use a .slide-with-bg div with inline background-image, an overlay div with a gradient for readability, and a content div at z-index:1" ;
    oc:hasRationale "The overlay ensures text legibility over any image; the z-index layering keeps content above the overlay" .

