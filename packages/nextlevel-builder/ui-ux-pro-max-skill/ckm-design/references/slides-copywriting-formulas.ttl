@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_slides_copywriting_formulas a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "slides-copywriting-formulas" ;
    skos:broader "Copywriting reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-design" ;
    oc:contentHash "03733d5916ab771834745550045b736deeb94a08226f2b200f7953009c35b219" ;
    oc:differentia "provides 25 persuasive formulas mapped to slide types for strategic presentations" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design ;
    oc:handlesFailure oc:NoMatchingFormula ;
    oc:hasArgumentHint "slide-type or emotional-goal (e.g., \"problem agitation\", \"urgency cta\")" ;
    oc:hasCategory "document" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "25 formulas for persuasive slide copy." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 6 ;
                            oc:tableCaption "## Quick Reference" ;
                            oc:tableMarkdown """| Need | Use Formula |
|------|------------|
| Create urgency | Cost of Inaction, Scarcity |
| Build trust | Social Proof, Testimonial |
| Show value | FAB, Value Stack |
| Drive action | AIDA, CTA |
| Tell story | BAB, Story Arc |
| Present data | Proof Stack |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Quick Reference" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """**Use:** Problem slides, pain points
**Components:** Problem → Agitate → Solution
**Template:** "[Pain point]? Every [time frame], [consequence]. [Solution] fixes this.\"""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "PAS (Problem-Agitate-Solution)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """**Use:** Agitation slides, urgency
**Components:** Status Quo → Loss → Time Decay
**Template:** "Without [solution], you're losing [amount] every [timeframe].\"""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Cost of Inaction" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """**Use:** Feature slides, product showcases
**Components:** Feature → Advantage → Benefit
**Template:** "[Feature] lets you [advantage], so you can [benefit].\"""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "FAB (Features-Advantages-Benefits)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """**Use:** CTAs, closing slides
**Components:** Attention → Interest → Desire → Action
**Template:** "[Bold statement]. [Benefit detail]. [Social proof]. [CTA].\"""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "AIDA (Attention-Interest-Desire-Action)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """**Use:** Transformation slides, case studies
**Components:** Before → After → Bridge
**Template:** "[Pain point before]. [Desired state after]. [Your solution] is the bridge.\"""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Before-After-Bridge" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Core Formulas" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Find formula for slide type
python .claude/skills/design-system/scripts/search-slides.py "problem agitation" -d copy

# Get emotion-appropriate formula
python .claude/skills/design-system/scripts/search-slides.py "urgency cta" -d copy
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 67-73" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Search Commands" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 9 ;
                            oc:tableCaption "## Formula-to-Slide Mapping" ;
                            oc:tableMarkdown """| Slide Type | Primary Formula | Emotion |
|------------|-----------------|---------|
| Title/Hook | AIDA, Hook | curiosity |
| Problem | PAS, Agitate | frustration |
| Cost/Risk | Cost of Inaction | fear |
| Solution | FAB, BAB | hope |
| Features | FAB | confidence |
| Traction | Proof Stack | trust |
| Social Proof | Testimonial | trust |
| Pricing | Value Stack | confidence |
| CTA | AIDA, Urgency | urgency |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Formula-to-Slide Mapping" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "\"[Number]+ [users/companies] trust [product]\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "\"Join [notable company] and [notable company]\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "\"As seen in [publication]\"" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Social Proof Patterns" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "\"The [adjective] way to [action]\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "\"Get [desired result] in [timeframe]\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "\"Why [audience] choose [product]\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "\"Stop [bad thing]\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "\"[Number] ways to [achieve goal]\"" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Power Words" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "\"Don't [bad action]. Instead, [good action].\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "\"From [pain point] to [benefit].\"" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "\"[Old way] is dead. Meet [new way].\"" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Contrast Patterns" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Headline Patterns" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Copywriting Formulas" ] ;
    oc:impartsKnowledge oc:kn_0ec31652,
        oc:kn_1b733093,
        oc:kn_2547eb54,
        oc:kn_3fb2d625,
        oc:kn_4468c4a4,
        oc:kn_622c25e2,
        oc:kn_7831f12d ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:SlideContextDefined ;
    oc:resolvesIntent "choose copywriting formula for slide type",
        "create compelling headlines and CTAs for presentations",
        "match emotion to slide type using formula mapping",
        "write persuasive slide copy" ;
    oc:yieldsState oc:CopyFormulaSelected,
        oc:SlideCopyGenerated .

oc:kn_0ec31652 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting tone and emotional register for any slide" ;
    oc:directiveContent "Match emotion to slide purpose: curiosity for hooks, frustration for problems, fear for cost/risk, hope for solutions, confidence for features and pricing, trust for social proof and traction, urgency for CTAs" ;
    oc:hasRationale "Emotional alignment increases persuasion by matching audience psychological state to slide content" .

oc:kn_1b733093 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing slide headlines and titles" ;
    oc:directiveContent "Use contrast patterns ('[Old way] is dead. Meet [new way].') and power words ('Stop [bad thing]', 'Get [result] in [timeframe]') to create memorable, action-oriented headlines" ;
    oc:hasRationale "Contrast and specificity in headlines dramatically increase audience engagement and recall" .

oc:kn_2547eb54 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When constructing slide copy from formulas" ;
    oc:directiveContent """[Pain point]? Every [time frame], [consequence]. [Solution] fixes this.

[Bold statement]. [Benefit detail]. [Social proof]. [CTA].

[Feature] lets you [advantage], so you can [benefit].

Without [solution], you're losing [amount] every [timeframe].

[Pain point before]. [Desired state after]. [Your solution] is the bridge.""" ;
    oc:templateVariables "Benefit detail",
        "Bold statement",
        "CTA",
        "Desired state after",
        "Feature",
        "Pain point",
        "Social proof",
        "Solution",
        "advantage",
        "amount",
        "benefit",
        "consequence",
        "time frame" .

oc:kn_3fb2d625 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When searching for a copywriting formula matching a slide type or emotional goal" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "python .claude/skills/design-system/scripts/search-slides.py \"<query>\" -d copy" .

oc:kn_4468c4a4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing problem or cost/risk slides" ;
    oc:directiveContent "Do not use FAB (feature-focused) formulas on problem or agitation slides—those require PAS or Cost of Inaction to amplify pain before presenting solutions" ;
    oc:hasRationale "Premature solution framing on problem slides undermines the emotional buildup needed for persuasion" ;
    oc:severityLevel "MEDIUM" .

oc:kn_622c25e2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any slide copy" ;
    oc:directiveContent "Every slide must use a defined formula—never write free-form copy without a rhetorical structure (PAS, AIDA, FAB, BAB, Cost of Inaction, or others from the 25-formula set)" ;
    oc:hasRationale "Structured formulas outperform unstructured copy because they encode proven persuasion patterns" ;
    oc:severityLevel "HIGH" .

oc:kn_7831f12d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When writing copy for any slide" ;
    oc:directiveContent "1. Identify slide type (title, problem, solution, features, pricing, CTA) 2. Look up primary formula from mapping table 3. Select matching emotion (curiosity, frustration, fear, hope, confidence, trust, urgency) 4. Apply formula components in sequence 5. Use headline power words or contrast patterns to sharpen copy" ;
    oc:hasRationale "Matching formula to slide type ensures the rhetorical structure aligns with the slide's persuasive purpose" ;
    oc:stepOrder 1 .

