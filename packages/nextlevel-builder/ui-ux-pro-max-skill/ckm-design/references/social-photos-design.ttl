oc:kn_0a8f08bf a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting typography in social photo designs" ;
    oc:directiveContent "Minimum typography sizes at 1080px width: Headline 48px, Subheadline 32px, Body 24px, Caption 18px, CTA 28px. Ensure WCAG AA 4.5:1 contrast ratio." ;
    oc:hasRationale "Text must be readable at thumbnail viewing sizes; low contrast fails accessibility standards" ;
    oc:severityLevel "HIGH" .

oc:kn_15c076e0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When laying out content in social photo HTML designs" ;
    oc:directiveContent "Keep critical content within the central 80% safe zone to avoid edge clipping on any platform." ;
    oc:hasRationale "Platforms may crop or overlay UI elements near edges; safe zones ensure visibility" ;
    oc:severityLevel "HIGH" .

oc:kn_334ffd64 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When activating design skills in Step 4" ;
    oc:directiveContent "Randomly invoke ONE of ui-ux-pro-max OR frontend-design per run to produce design variety across executions." ;
    oc:hasRationale "Varying the design skill source prevents repetitive, formulaic outputs across multiple runs" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3596e878 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "During Step 6 visual QA verification" ;
    oc:directiveContent "Common export issues to check: fonts falling back to system fonts, text overflow/clipping, elements outside safe zone, low contrast below WCAG AA, misaligned elements." ;
    oc:hasRationale "Catching these issues early prevents rework and ensures professional output quality" ;
    oc:severityLevel "MEDIUM" .

oc:kn_36bda1a4 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a screenshot export method" ;
    oc:directiveContent "Use Chrome headless CLI as the primary export method (zero dependencies). Fall back to chrome-devtools skill, Playwright, or Puppeteer if needed. Use deviceScaleFactor: 2 for retina output with Puppeteer." ;
    oc:hasRationale "Chrome headless CLI requires no npm dependencies and uses --virtual-time-budget for reliable asset loading" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3d35c321 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When exporting HTML to PNG screenshot" ;
    oc:directiveContent "Never screenshot before fonts and images are fully loaded. Always add a 3-5 second delay after page load before capture." ;
    oc:hasRationale "Premature capture produces images with missing fonts, broken layouts, or unloaded assets" ;
    oc:severityLevel "CRITICAL" .

oc:kn_52cf063b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating HTML for social photos" ;
    oc:directiveContent "Set exact viewport pixel dimensions matching target platform size. No scrolling allowed — everything must fit in one viewport." ;
    oc:hasRationale "Social platforms display images at fixed dimensions; overflow content is lost" ;
    oc:severityLevel "HIGH" .

oc:kn_6b8ad639 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoping user requests" ;
    oc:directiveContent "This skill does NOT handle video content, animation/motion graphics, print production (CMYK/bleed), direct social media posting, or AI image generation." ;
    oc:hasRationale "Prevents scope creep and sets correct expectations for what this pipeline produces" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9dddd454 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always — this skill writes files to disk" ;
    oc:directiveContent "Creates HTML files in output/social-photos/ and PNG exports in output/social-photos/exports/. Generates a summary report in plans/reports/." ;
    oc:hasRationale "Agents and users must be aware of output locations for downstream consumption" ;
    oc:severityLevel "LOW" .

oc:kn_ea8e8ced a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing HTML files for social photos" ;
    oc:directiveContent "All HTML files must be self-contained: inline all CSS, embed fonts via Google Fonts CDN, no external file dependencies." ;
    oc:hasRationale "Self-contained files ensure consistent rendering across different rendering contexts and avoid broken external references" ;
    oc:severityLevel "HIGH" .

