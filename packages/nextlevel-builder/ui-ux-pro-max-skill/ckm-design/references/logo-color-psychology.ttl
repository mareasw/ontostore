    oc:impartsKnowledge oc:kn_3b8fd74a,
        oc:kn_6ca0787b,
        oc:kn_a20d6de2,
        oc:kn_b6ae23da,
        oc:kn_ec8d10ed ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "choose logo colors by psychological meaning",
        "create accessible color palettes for logos",
        "find color combinations for brand identity",
        "select brand colors by industry" .

oc:kn_3b8fd74a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning primary brand colors to industry-specific logos" ;
    oc:directiveContent "Avoid red for healthcare (blood connotation), avoid blue for food (appetite suppressant), avoid brown/beige for tech, avoid neon for fashion unless intentional, avoid bright colors for finance." ;
    oc:hasRationale "Cultural and psychological associations of colors can create negative subconscious reactions in specific industry contexts" ;
    oc:severityLevel "HIGH" .

oc:kn_6ca0787b a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When selecting secondary or background colors" ;
    oc:directiveContent "White is a universal neutral that pairs with any color; use for backgrounds, negative space, and contrast. Black is best for high-end and luxury positioning." ;
    oc:hasRationale "These neutrals provide visual breathing room and can shift perceived brand tier" .

oc:kn_a20d6de2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting any logo color palette" ;
    oc:directiveContent "Minimum contrast ratio must be 4.5:1 (WCAG AA) for logo and brand text. Avoid red-green only indicators. Test in grayscale for clarity." ;
    oc:hasRationale "Approximately 8% of males are colorblind; WCAG compliance ensures brand accessibility" ;
    oc:severityLevel "HIGH" .

oc:kn_b6ae23da a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining brand personality through color" ;
    oc:directiveContent "Match primary color psychology to brand positioning: Blue→trust, Red→energy, Green→growth, Yellow→optimism, Purple→creativity, Orange→friendliness, Black→sophistication, White→simplicity." ;
    oc:hasRationale "Color psychology research shows consistent emotional associations across audiences; aligning color with brand values reinforces messaging" .

oc:kn_ec8d10ed a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When combining multiple colors in a logo design" ;
    oc:directiveContent "Use monochromatic (safe, cohesive), complementary (high contrast, vibrant), analogous (harmonious, natural), or triadic (balanced, dynamic) harmony types to build multi-color palettes." ;
    oc:hasRationale "Color harmony theory provides proven frameworks for visually pleasing and communicative palettes" .

_:ref_3549d705ca97b7f9 a oc:WorkflowStep ;
    dcterms:description "Apply a color harmony type (monochromatic, complementary, analogous, or triadic) to refine the palette" ;
    oc:expectedOutcome "Harmonious multi-color palette defined" ;
    oc:stepDependsOn _:ref_f717246434c28749 ;
    oc:stepId "choose-harmony" .

_:ref_7e845b4466d92d0d a oc:WorkflowStep ;
    dcterms:description "Map personality traits to primary color psychology (Blue=trust, Red=energy, Green=growth, etc.)" ;
    oc:expectedOutcome "Primary color candidate selected with psychological justification" ;
    oc:stepDependsOn _:ref_a87c6c9c56f08aab ;
    oc:stepId "match-psychology" .

_:ref_a87c6c9c56f08aab a oc:WorkflowStep ;
    dcterms:description "Identify the brand's core personality traits and desired emotional associations" ;
    oc:expectedOutcome "Clear list of 2-3 brand personality keywords" ;
    oc:stepId "define-brand" .

_:ref_f717246434c28749 a oc:WorkflowStep ;
    dcterms:description "Cross-reference with industry color combination table for recommended pairings and colors to avoid" ;
    oc:expectedOutcome "Primary, secondary, and accent color candidates identified; colors to avoid noted" ;
    oc:stepDependsOn _:ref_7e845b4466d92d0d ;
    oc:stepId "apply-industry-rules" .

