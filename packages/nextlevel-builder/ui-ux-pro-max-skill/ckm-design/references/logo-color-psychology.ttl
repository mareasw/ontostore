    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Process for selecting psychologically appropriate logo colors based on brand identity and industry" ;
            oc:hasStep _:ref_3549d705ca97b7f9,
                [ a oc:WorkflowStep ;
                    dcterms:description "Test palette for WCAG AA 4.5:1 contrast ratio, grayscale readability, and colorblind safety" ;
