    oc:impartsKnowledge oc:kn_0e67eccc,
        oc:kn_33f2dc6c,
        oc:kn_3dd9fbac,
        oc:kn_458906a9,
        oc:kn_50c7dcbb,
        oc:kn_d344a5ce ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignTokensReady ;
    oc:resolvesIntent "look up component sizing and spacing tokens",
        "reference interactive states and accessibility properties",
        "specify UI component variants and states",
        "understand component anatomy for layout" ;
    oc:yieldsState oc:ComponentSpecified .

oc:kn_0e67eccc a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reading or creating component specifications" ;
    oc:directiveContent "Each component follows the structure: Variants → Sizes → States → Anatomy → Spacing (where applicable). Anatomy uses ASCII box-drawing with labeled zones." ;
    oc:hasRationale "Consistent spec structure enables predictable lookup and reduces cognitive load" .

oc:kn_33f2dc6c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing components in code" ;
    oc:directiveContent "Do not hardcode component dimensions or colors — always reference the token names (primary, foreground, gray-300) shown in these specs so theme switching works." ;
    oc:hasRationale "Hardcoded values break theming, dark mode, and design token portability" ;
    oc:severityLevel "CRITICAL" .

oc:kn_3dd9fbac a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When implementing interactive states and scrollable containers" ;
    oc:directiveContent "Interactive Card variant transitions shadow from sm→md on hover. Dialog content area should scroll independently when content overflows. Table supports striped alternating rows for readability." ;
    oc:hasRationale "Constraining scroll to content area prevents layout shift and improves perceived performance" .

oc:kn_458906a9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying any new or existing component" ;
    oc:directiveContent "Every component must define variants (visual styles), sizes (dimensional tokens), states (interaction feedback), and anatomy (structural zones) to ensure consistency across the design system." ;
    oc:hasRationale "Incomplete component specs lead to visual inconsistency and developer guesswork" .

oc:kn_50c7dcbb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building Button components" ;
    oc:directiveContent "Button destructive variant must use red-600 background — never use red for non-destructive actions. Disabled state must use opacity 0.5 and cursor not-allowed." ;
    oc:hasRationale "Red signals danger/destruction; misusing it erodes user trust in destructive action warnings" ;
    oc:severityLevel "HIGH" .

oc:kn_d344a5ce a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sizing any component" ;
    oc:directiveContent "Use 4px grid alignment: sizes step at 32px/40px/48px for sm/default/lg across Button, Input, and other components. Compact/comfortable table row heights at 40px/48px/56px." ;
    oc:hasRationale "4px/8px grid ensures pixel-perfect vertical rhythm and alignment across all components" .

