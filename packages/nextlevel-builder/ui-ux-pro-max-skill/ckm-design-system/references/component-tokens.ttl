oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_system_component_tokens a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "component-tokens" ;
    skos:broader "Token specification" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-design-system" ;
    oc:contentHash "e27f8f5999badee425c98235eabbd2cb3ebe2a1a364766d5c7a6b3134ceaaec8" ;
    oc:differentia "that maps semantic design tokens to component-level CSS custom properties for UI elements like buttons, inputs, cards, badges, alerts, dialogs, and tables" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_system ;
    oc:handlesFailure oc:InvalidTokenReference ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Component-specific tokens referencing semantic layer." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Default */
  --alert-bg: var(--color-background);
  --alert-fg: var(--color-foreground);
  --alert-border: var(--color-border);

  /* Destructive */
  --alert-destructive-bg: var(--color-destructive);
  --alert-destructive-fg: var(--color-destructive-foreground);

  /* Spacing */
  --alert-padding: var(--space-4);
  --alert-radius: var(--radius-lg);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 134-149" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Alert Tokens" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Background & Border */
  --input-bg: var(--color-background);
  --input-border: var(--color-input);
  --input-fg: var(--color-foreground);

  /* Placeholder */
  --input-placeholder: var(--color-muted-foreground);

  /* Focus */
  --input-focus-border: var(--color-ring);
  --input-focus-ring: var(--color-ring);

  /* Error */
  --input-error-border: var(--color-error);
  --input-error-fg: var(--color-error);

  /* Disabled */
  --input-disabled-bg: var(--color-muted);
  --input-disabled-fg: var(--color-muted-foreground);

  /* Sizing */
  --input-padding-x: var(--space-3);
  --input-padding-y: var(--space-2);
  --input-radius: var(--radius-md);
  --input-font-size: var(--font-size-sm);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 51-79" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Input Tokens" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Header */
  --table-header-bg: var(--color-muted);
  --table-header-fg: var(--color-muted-foreground);

  /* Body */
  --table-row-bg: var(--color-background);
  --table-row-hover-bg: var(--color-muted);
  --table-row-fg: var(--color-foreground);

  /* Border */
  --table-border: var(--color-border);

  /* Spacing */
  --table-cell-padding-x: var(--space-4);
  --table-cell-padding-y: var(--space-3);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 173-191" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Table Tokens" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """.button {
  background: var(--button-bg);
  color: var(--button-fg);
  padding: var(--button-padding-y) var(--button-padding-x);
  border-radius: var(--button-radius);
  font-size: var(--button-font-size);
  font-weight: var(--button-font-weight);
  transition: background var(--duration-fast);
}

.button:hover {
  background: var(--button-hover-bg);
}

.button.secondary {
  background: var(--button-secondary-bg);
  color: var(--button-secondary-fg);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 195-214" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Usage Example" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Default (Primary) */
  --button-bg: var(--color-primary);
  --button-fg: var(--color-primary-foreground);
  --button-hover-bg: var(--color-primary-hover);
  --button-active-bg: var(--color-primary-active);

  /* Secondary */
  --button-secondary-bg: var(--color-secondary);
  --button-secondary-fg: var(--color-secondary-foreground);
  --button-secondary-hover-bg: var(--color-secondary-hover);

  /* Outline */
  --button-outline-border: var(--color-border);
  --button-outline-fg: var(--color-foreground);
  --button-outline-hover-bg: var(--color-accent);

  /* Ghost */
  --button-ghost-fg: var(--color-foreground);
  --button-ghost-hover-bg: var(--color-accent);

  /* Destructive */
  --button-destructive-bg: var(--color-destructive);
  --button-destructive-fg: var(--color-destructive-foreground);
  --button-destructive-hover-bg: var(--color-destructive-hover);

  /* Sizing */
  --button-padding-x: var(--space-4);
  --button-padding-y: var(--space-2);
  --button-padding-x-sm: var(--space-3);
  --button-padding-y-sm: var(--space-1-5);
  --button-padding-x-lg: var(--space-6);
  --button-padding-y-lg: var(--space-3);

  /* Shape */
  --button-radius: var(--radius-md);
  --button-font-size: var(--font-size-sm);
  --button-font-weight: var(--font-weight-medium);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 7-47" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Button Tokens" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Background & Border */
  --card-bg: var(--color-card);
  --card-fg: var(--color-card-foreground);
  --card-border: var(--color-border);

  /* Shadow */
  --card-shadow: var(--shadow-default);
  --card-shadow-hover: var(--shadow-md);

  /* Spacing */
  --card-padding: var(--space-6);
  --card-padding-sm: var(--space-4);
  --card-gap: var(--space-4);

  /* Shape */
  --card-radius: var(--radius-lg);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 83-102" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Card Tokens" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Default */
  --badge-bg: var(--color-primary);
  --badge-fg: var(--color-primary-foreground);

  /* Secondary */
  --badge-secondary-bg: var(--color-secondary);
  --badge-secondary-fg: var(--color-secondary-foreground);

  /* Outline */
  --badge-outline-border: var(--color-border);
  --badge-outline-fg: var(--color-foreground);

  /* Destructive */
  --badge-destructive-bg: var(--color-destructive);
  --badge-destructive-fg: var(--color-destructive-foreground);

  /* Sizing */
  --badge-padding-x: var(--space-2-5);
  --badge-padding-y: var(--space-0-5);
  --badge-radius: var(--radius-full);
  --badge-font-size: var(--font-size-xs);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 106-130" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Badge Tokens" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Overlay */
  --dialog-overlay-bg: rgb(0 0 0 / 0.5);

  /* Content */
  --dialog-bg: var(--color-background);
  --dialog-fg: var(--color-foreground);
  --dialog-border: var(--color-border);
  --dialog-shadow: var(--shadow-lg);

  /* Spacing */
  --dialog-padding: var(--space-6);
  --dialog-radius: var(--radius-lg);
  --dialog-max-width: 32rem;
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 153-169" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Dialog/Modal Tokens" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Component Tokens" ] ;
    oc:impartsKnowledge oc:kn_28a5a265,
        oc:kn_30b5e3d0,
        oc:kn_a20a3054,
        oc:kn_b90ec58e,
        oc:kn_db08c4cd,
        oc:kn_ef78c0fe ;
    oc:isUserInvocable true ;
    oc:nature "Reference" ;
    oc:requiresState oc:SemanticTokensDefined ;
    oc:resolvesIntent "apply semantic design tokens to components",
        "create consistent component styling with token variables",
        "define component tokens for UI elements",
        "implement themeable UI component styles" ;
    oc:yieldsState oc:ComponentTokensReady .

oc:kn_28a5a265 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining tokens for buttons, inputs, and other interactive elements" ;
    oc:directiveContent "Every interactive component must define variant tokens for default, hover, active, and disabled states at minimum." ;
    oc:hasRationale "Incomplete state coverage leads to inconsistent or broken interaction feedback." ;
    oc:severityLevel "HIGH" .

oc:kn_30b5e3d0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing component-level CSS custom properties" ;
    oc:directiveContent "Never hardcode color values, spacing, or radii in component tokens. Use var(--semantic-token) references exclusively." ;
    oc:hasRationale "Hardcoded values break theming, dark mode support, and the entire token cascade." ;
    oc:severityLevel "HIGH" .

oc:kn_a20a3054 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating new component token definitions following the established naming convention" ;
    oc:codeLanguage "css" ;
    oc:directiveContent """--{component}-{property}: var(--semantic-reference);
--{component}-{variant}-{property}: var(--semantic-reference);""" .

oc:kn_b90ec58e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining any component token" ;
    oc:directiveContent "Component tokens must always reference semantic layer tokens (var(--color-*), var(--space-*), var(--radius-*)), never primitive values directly." ;
    oc:hasRationale "Maintains the three-layer token hierarchy (primitive→semantic→component) ensuring theme changes propagate correctly through the system." ;
    oc:severityLevel "CRITICAL" .

oc:kn_db08c4cd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming any new component token" ;
    oc:directiveContent "Component tokens should follow the naming pattern: --{component}-{variant}-{property} (e.g., --button-secondary-hover-bg)." ;
    oc:hasRationale "Consistent naming enables predictable token lookup and auto-completion in tooling." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ef78c0fe a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining a full component token set" ;
    oc:directiveContent "Include sizing tokens (padding, radius, font-size) alongside color tokens for each component to ensure complete visual control." ;
    oc:hasRationale "Sizing tokens are essential for consistent spacing and typography within components across themes." ;
    oc:severityLevel "MEDIUM" .

