oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_system_primitive_tokens a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "primitive-tokens" ;
    skos:broader "Design token specification" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-design-system" ;
    oc:contentHash "91e6caa12646c08c8aadf8e09399aed65760a25c8d80595936d81a9131118fc3" ;
    oc:differentia "that defines raw primitive values (colors, spacing, typography, borders, shadows, motion, z-index) as CSS custom properties forming the foundational layer of a three-tier token system" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_system ;
    oc:hasCategory "design-system" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Raw design values - foundation of the design system." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  --duration-75:  75ms;
  --duration-100: 100ms;
  --duration-150: 150ms;
  --duration-200: 200ms;
  --duration-300: 300ms;
  --duration-500: 500ms;
  --duration-700: 700ms;
  --duration-1000: 1000ms;

  /* Semantic durations */
  --duration-fast:   var(--duration-150);
  --duration-normal: var(--duration-200);
  --duration-slow:   var(--duration-300);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 168-184" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Motion / Duration" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """:root {
  --color-blue-50:  #EFF6FF;
  --color-blue-100: #DBEAFE;
  --color-blue-200: #BFDBFE;
  --color-blue-300: #93C5FD;
  --color-blue-400: #60A5FA;
  --color-blue-500: #3B82F6;
  --color-blue-600: #2563EB;
  --color-blue-700: #1D4ED8;
  --color-blue-800: #1E40AF;
  --color-blue-900: #1E3A8A;
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 27-40" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Primary Colors (Blue)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """:root {
  /* Success - Green */
  --color-green-500: #22C55E;
  --color-green-600: #16A34A;

  /* Warning - Yellow */
  --color-yellow-500: #EAB308;
  --color-yellow-600: #CA8A04;

  /* Error - Red */
  --color-red-500: #EF4444;
  --color-red-600: #DC2626;

  /* Info - Blue */
  --color-info: var(--color-blue-500);
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 44-61" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Status Colors" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """:root {
  --color-gray-50:  #F9FAFB;
  --color-gray-100: #F3F4F6;
  --color-gray-200: #E5E7EB;
  --color-gray-300: #D1D5DB;
  --color-gray-400: #9CA3AF;
  --color-gray-500: #6B7280;
  --color-gray-600: #4B5563;
  --color-gray-700: #374151;
  --color-gray-800: #1F2937;
  --color-gray-900: #111827;
  --color-gray-950: #030712;
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 9-23" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Gray Scale" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Color Scales" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  --space-0:   0;
  --space-px:  1px;
  --space-0-5: 0.125rem;  /* 2px */
  --space-1:   0.25rem;   /* 4px */
  --space-1-5: 0.375rem;  /* 6px */
  --space-2:   0.5rem;    /* 8px */
  --space-2-5: 0.625rem;  /* 10px */
  --space-3:   0.75rem;   /* 12px */
  --space-3-5: 0.875rem;  /* 14px */
  --space-4:   1rem;      /* 16px */
  --space-5:   1.25rem;   /* 20px */
  --space-6:   1.5rem;    /* 24px */
  --space-7:   1.75rem;   /* 28px */
  --space-8:   2rem;      /* 32px */
  --space-9:   2.25rem;   /* 36px */
  --space-10:  2.5rem;    /* 40px */
  --space-12:  3rem;      /* 48px */
  --space-14:  3.5rem;    /* 56px */
  --space-16:  4rem;      /* 64px */
  --space-20:  5rem;      /* 80px */
  --space-24:  6rem;      /* 96px */
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 67-91" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "4px base unit system." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Spacing Scale" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  --shadow-none: none;
  --shadow-sm:   0 1px 2px 0 rgb(0 0 0 / 0.05);
  --shadow-default: 0 1px 3px 0 rgb(0 0 0 / 0.1),
                    0 1px 2px -1px rgb(0 0 0 / 0.1);
  --shadow-md:   0 4px 6px -1px rgb(0 0 0 / 0.1),
                 0 2px 4px -2px rgb(0 0 0 / 0.1);
  --shadow-lg:   0 10px 15px -3px rgb(0 0 0 / 0.1),
                 0 4px 6px -4px rgb(0 0 0 / 0.1);
  --shadow-xl:   0 20px 25px -5px rgb(0 0 0 / 0.1),
                 0 8px 10px -6px rgb(0 0 0 / 0.1);
  --shadow-2xl:  0 25px 50px -12px rgb(0 0 0 / 0.25);
  --shadow-inner: inset 0 2px 4px 0 rgb(0 0 0 / 0.05);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 149-164" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Shadows" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Font Sizes */
  --font-size-xs:   0.75rem;   /* 12px */
  --font-size-sm:   0.875rem;  /* 14px */
  --font-size-base: 1rem;      /* 16px */
  --font-size-lg:   1.125rem;  /* 18px */
  --font-size-xl:   1.25rem;   /* 20px */
  --font-size-2xl:  1.5rem;    /* 24px */
  --font-size-3xl:  1.875rem;  /* 30px */
  --font-size-4xl:  2.25rem;   /* 36px */
  --font-size-5xl:  3rem;      /* 48px */

  /* Line Heights */
  --leading-none:   1;
  --leading-tight:  1.25;
  --leading-snug:   1.375;
  --leading-normal: 1.5;
  --leading-relaxed: 1.625;
  --leading-loose:  2;

  /* Font Weights */
  --font-weight-normal:   400;
  --font-weight-medium:   500;
  --font-weight-semibold: 600;
  --font-weight-bold:     700;

  /* Letter Spacing */
  --tracking-tighter: -0.05em;
  --tracking-tight:   -0.025em;
  --tracking-normal:  0;
  --tracking-wide:    0.025em;
  --tracking-wider:   0.05em;
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 95-129" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Typography Scale" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  --z-auto:     auto;
  --z-0:        0;
  --z-10:       10;
  --z-20:       20;
  --z-30:       30;
  --z-40:       40;
  --z-50:       50;
  --z-dropdown: 1000;
  --z-sticky:   1100;
  --z-modal:    1200;
  --z-popover:  1300;
  --z-tooltip:  1400;
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 188-203" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Z-Index Scale" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  --radius-none:    0;
  --radius-sm:      0.125rem;  /* 2px */
  --radius-default: 0.25rem;   /* 4px */
  --radius-md:      0.375rem;  /* 6px */
  --radius-lg:      0.5rem;    /* 8px */
  --radius-xl:      0.75rem;   /* 12px */
  --radius-2xl:     1rem;      /* 16px */
  --radius-3xl:     1.5rem;    /* 24px */
  --radius-full:    9999px;
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 133-145" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Border Radius" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Primitive Tokens" ] ;
    oc:impartsKnowledge oc:kn_41ea3343,
        oc:kn_727889ff,
        oc:kn_a1d9d65f,
        oc:kn_e37b26e8,
        oc:kn_ec9b5e6e ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "define primitive design tokens",
        "establish color scales and spacing values",
        "look up raw design system values",
        "reference base typography and motion tokens" ;
    oc:yieldsState oc:DesignTokensDefined .

oc:kn_41ea3343 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When consuming design tokens in UI code" ;
    oc:directiveContent "Primitive tokens are raw, context-free values — they must never be applied directly in components. Always reference them through semantic or component-level tokens." ;
    oc:hasRationale "Direct primitive usage breaks the abstraction layer and makes theme changes impossible without touching every component" ;
    oc:severityLevel "HIGH" .

oc:kn_727889ff a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When choosing spacing values" ;
    oc:directiveContent "Spacing uses a 4px base unit system (0.25rem). All spacing tokens are multiples of this base unit." ;
    oc:hasRationale "A consistent base unit ensures visual rhythm and alignment across all layouts" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a1d9d65f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When layering UI elements" ;
    oc:directiveContent "Z-index semantic tokens (dropdown: 1000, sticky: 1100, modal: 1200, popover: 1300, tooltip: 1400) define a stacking convention. Use semantic z-index names, never raw numbers." ;
    oc:hasRationale "Arbitrary z-index values cause stacking context conflicts that are extremely difficult to debug" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e37b26e8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing CSS for design-system-backed projects" ;
    oc:directiveContent "Do not hardcode hex values or pixel measurements when primitive tokens exist for that purpose." ;
    oc:hasRationale "Hardcoded values bypass the token system, preventing global updates and theme switching" ;
    oc:severityLevel "HIGH" .

oc:kn_ec9b5e6e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting color values from scales" ;
    oc:directiveContent "Color scales follow a numeric progression (50–950 for grays, 50–900 for blues) where lower numbers are lighter and higher numbers are darker." ;
    oc:hasRationale "Consistent numbering enables predictable contrast ratios and accessible color pairings" ;
    oc:severityLevel "MEDIUM" .

