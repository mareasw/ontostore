oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_system_token_architecture a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "token-architecture" ;
    skos:broader "Design token system" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-design-system" ;
    oc:contentHash "925f4049c4c4313d9fd5df98cdfd52004112aca49fba1664ad85e76bc9dce4d3" ;
    oc:differentia "organizes tokens into three layers (primitive, semantic, component) for scalable themeable design systems" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_system ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Three-layer token system for scalable, themeable design systems." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Template ;
                            oc:blockType "template" ;
                            oc:contentOrder 1 ;
                            oc:templateContent """--{category}-{item}-{variant}-{state}

Examples:
--color-primary           # category-item
--color-primary-hover     # category-item-state
--button-bg-hover         # component-property-state
--space-section-sm        # category-semantic-variant
""" ;
                            oc:templateVariables "category",
                                "item",
                                "state",
                                "variant" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Naming Convention" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 3 ;
                            oc:tableCaption "## Why Three Layers?" ;
                            oc:tableMarkdown """| Layer | Purpose | When to Change |
|-------|---------|----------------|
| Primitive | Base values (colors, sizes) | Rarely - foundational |
| Semantic | Meaning assignment | Theme switching |
| Component | Component customization | Per-component needs |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Why Three Layers?" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Component-specific tokens referencing semantic layer." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Button */
  --button-bg: var(--color-primary);
  --button-fg: white;
  --button-hover-bg: var(--color-primary-hover);
  --button-padding-x: var(--space-4);
  --button-padding-y: var(--space-2);
  --button-radius: var(--radius-default);

  /* Input */
  --input-bg: var(--color-background);
  --input-border: var(--color-gray-300);
  --input-focus-ring: var(--color-primary);
  --input-padding: var(--space-2) var(--space-3);

  /* Card */
  --card-bg: var(--color-background);
  --card-border: var(--color-gray-200);
  --card-padding: var(--space-4);
  --card-radius: var(--radius-lg);
  --card-shadow: var(--shadow-default);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 98-121" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Layer 3: Component Tokens" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Before (flat):" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """--button-primary-bg: #2563EB;
--button-secondary-bg: #F3F4F6;
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 189-192" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/* Primitive */
--color-blue-600: #2563EB;
--color-gray-100: #F3F4F6;

/* Semantic */
--color-primary: var(--color-blue-600);
--color-secondary: var(--color-gray-100);

/* Component */
--button-bg: var(--color-primary);
--button-secondary-bg: var(--color-secondary);
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 4 ;
                            oc:sourceLocation "lines 195-207" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "After (three-layer):" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 10 ;
                    oc:sectionTitle "Migration from Flat Tokens" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 6 ;
                            oc:tableCaption "## Categories" ;
                            oc:tableMarkdown """| Category | Examples |
|----------|----------|
| color | primary, secondary, muted, destructive |
| space | 1, 2, 4, 8, section, component |
| font-size | xs, sm, base, lg, xl |
| radius | sm, default, lg, full |
| shadow | sm, default, lg |
| duration | fast, normal, slow |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Categories" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Or single file with layer comments:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/* === PRIMITIVES === */
:root { ... }

/* === SEMANTIC === */
:root { ... }

/* === COMPONENTS === */
:root { ... }

/* === DARK MODE === */
.dark { ... }
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 172-184" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """tokens/
├── primitives.css     # Raw values
├── semantic.css       # Purpose aliases
├── components.css     # Component tokens
└── index.css          # Imports all
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 162-168" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 9 ;
                    oc:sectionTitle "File Organization" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Token JSON format (W3C Design Tokens Community Group):" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """{
  "color": {
    "blue": {
      "600": {
        "$value": "#2563EB",
        "$type": "color"
      }
    }
  }
}
""" ;
                            oc:codeLanguage "json" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 213-224" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 11 ;
                    oc:sectionTitle "W3C DTCG Alignment" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """┌─────────────────────────────────────────┐
│  Component Tokens                       │  Per-component overrides
│  --button-bg, --card-padding            │
├─────────────────────────────────────────┤
│  Semantic Tokens                        │  Purpose-based aliases
│  --color-primary, --spacing-section     │
├─────────────────────────────────────────┤
│  Primitive Tokens                       │  Raw design values
│  --color-blue-600, --space-4            │
└─────────────────────────────────────────┘
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 7-18" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Layer Overview" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Override semantic tokens for dark theme:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """.dark {
  --color-background: var(--color-gray-900);
  --color-foreground: var(--color-gray-50);
  --color-muted: var(--color-gray-800);
  --color-muted-foreground: var(--color-gray-400);
  --color-secondary: var(--color-gray-800);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 127-135" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Dark Mode" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Purpose-based aliases that reference primitives." ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Background */
  --color-background: var(--color-gray-50);
  --color-foreground: var(--color-gray-900);

  /* Primary */
  --color-primary: var(--color-blue-600);
  --color-primary-hover: var(--color-blue-700);

  /* Secondary */
  --color-secondary: var(--color-gray-100);
  --color-secondary-foreground: var(--color-gray-900);

  /* Muted */
  --color-muted: var(--color-gray-100);
  --color-muted-foreground: var(--color-gray-500);

  /* Destructive */
  --color-destructive: var(--color-red-600);
  --color-destructive-foreground: white;

  /* Spacing */
  --spacing-component: var(--space-4);
  --spacing-section: var(--space-6);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 66-92" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Layer 2: Semantic Tokens" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Colors */
  --color-gray-50: #F9FAFB;
  --color-gray-900: #111827;
  --color-blue-500: #3B82F6;
  --color-blue-600: #2563EB;

  /* Spacing (4px base) */
  --space-1: 0.25rem;  /* 4px */
  --space-2: 0.5rem;   /* 8px */
  --space-4: 1rem;     /* 16px */
  --space-6: 1.5rem;   /* 24px */

  /* Typography */
  --font-size-sm: 0.875rem;
  --font-size-base: 1rem;
  --font-size-lg: 1.125rem;

  /* Radius */
  --radius-sm: 0.25rem;
  --radius-default: 0.5rem;
  --radius-lg: 0.75rem;

  /* Shadows */
  --shadow-sm: 0 1px 2px rgb(0 0 0 / 0.05);
  --shadow-default: 0 1px 3px rgb(0 0 0 / 0.1);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 32-60" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Raw design values without semantic meaning." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Layer 1: Primitive Tokens" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Token Architecture" ] ;
    oc:impartsKnowledge oc:kn_5144b5e8,
        oc:kn_5998f92d,
        oc:kn_8c945b05,
        oc:kn_8ec9aff7,
        oc:kn_e4c7c0e7,
        oc:kn_e98c7b78,
        oc:kn_ff53f15f ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DesignSystemInitialized ;
    oc:resolvesIntent "create design token architecture",
        "define CSS custom properties for design systems",
        "implement dark mode theming",
        "migrate flat tokens to three-layer system",
        "organize design tokens into layers" ;
    oc:yieldsState oc:TokenArchitectureDefined .

oc:kn_5144b5e8 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building a new token system from scratch" ;
    oc:directiveContent "1. Define raw primitives (colors, spacing, typography, radius, shadows) in :root. 2. Create semantic aliases mapping purpose to primitives. 3. Build component tokens referencing only semantic layer. 4. Add dark mode by overriding semantic tokens in .dark selector." ;
    oc:stepOrder 1 .

oc:kn_5998f92d a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When migrating an existing flat token system to three-layer architecture" ;
    oc:directiveContent "To migrate flat tokens: extract hardcoded values into primitives, create semantic aliases for purpose, then rewrite component tokens to reference semantics." ;
    oc:hasRationale "Incremental migration preserves existing styling while introducing layer separation." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8c945b05 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running or extending token definitions" ;
    oc:directiveContent "Token definitions are idempotent — re-declaring the same CSS custom property overwrites the previous value without side effects." ;
    oc:hasRationale "Safe to regenerate or append token files without corrupting existing state." .

oc:kn_8ec9aff7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which layer to modify" ;
    oc:directiveContent "Primitives change rarely (foundational palette), semantics change per theme, components change per-component customization needs." ;
    oc:hasRationale "Clear ownership boundaries prevent cascading changes and make the system predictable." ;
    oc:severityLevel "HIGH" .

oc:kn_e4c7c0e7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or migrating tokens" ;
    oc:directiveContent "Never hardcode raw values (e.g., #2563EB) in semantic or component token layers. Always reference the primitive layer." ;
    oc:hasRationale "Hardcoded values in upper layers break theming and create maintenance debt." ;
    oc:severityLevel "HIGH" .

oc:kn_e98c7b78 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming any new token" ;
    oc:directiveContent "Use the naming convention --{category}-{item}-{variant}-{state} consistently. Examples: --color-primary, --color-primary-hover, --button-bg-hover." ;
    oc:hasRationale "Consistent naming enables discoverability, autocompletion, and predictable token resolution." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ff53f15f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining any token at any layer" ;
    oc:directiveContent "Component tokens must only reference semantic tokens, semantic tokens must only reference primitive tokens. Never skip layers (e.g., component tokens referencing primitives directly)." ;
    oc:hasRationale "Layer separation ensures theme switching only requires overriding semantic tokens, not touching every component." ;
    oc:severityLevel "CRITICAL" .

