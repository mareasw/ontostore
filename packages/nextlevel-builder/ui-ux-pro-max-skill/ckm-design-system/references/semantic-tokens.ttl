    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-design-system" ;
    oc:contentHash "97e16d8061bbc22e82b51966a7015e3fc990932902e4647843506669a1cdebcc" ;
    oc:differentia "maps purpose-based semantic aliases to primitive tokens for colors, spacing, typography, and interactive states with dark mode support" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_design_system ;
    oc:handlesFailure oc:InvalidTokenReference ;
    oc:hasArgumentHint "component-name or token-category" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Purpose-based aliases referencing primitive tokens." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """// Toggle dark mode
document.documentElement.classList.toggle('dark');
""" ;
                                    oc:codeLanguage "js" ;
                                    oc:contentOrder 2 ;
                                    oc:sourceLocation "lines 212-215" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Semantic tokens enable instant theme switching:" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Theme Switching" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """/* Good - uses semantic tokens */
.card {
  background: var(--color-card);
  color: var(--color-card-foreground);
  border: 1px solid var(--color-border);
}

/* Bad - uses primitive tokens directly */
.card {
  background: var(--color-gray-50);
  color: var(--color-gray-900);
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 193-206" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Applying Semantic Tokens" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Usage Patterns" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Component internal spacing */
  --spacing-component-xs: var(--space-1);
  --spacing-component-sm: var(--space-2);
  --spacing-component: var(--space-3);
  --spacing-component-lg: var(--space-4);

  /* Section spacing */
  --spacing-section-sm: var(--space-8);
  --spacing-section: var(--space-12);
  --spacing-section-lg: var(--space-16);

  /* Page margins */
  --spacing-page-x: var(--space-4);
  --spacing-page-y: var(--space-6);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 104-121" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Spacing Semantics" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """:root {
  /* Page background */
  --color-background: var(--color-gray-50);
  --color-foreground: var(--color-gray-900);

  /* Card/surface background */
  --color-card: white;
  --color-card-foreground: var(--color-gray-900);

  /* Popover/dropdown */
  --color-popover: white;
  --color-popover-foreground: var(--color-gray-900);
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 9-23" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Background & Foreground" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """:root {
  --color-destructive: var(--color-red-600);
  --color-destructive-hover: var(--color-red-700);
  --color-destructive-foreground: white;
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 66-72" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "Destructive" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """:root {
  --color-muted: var(--color-gray-100);
  --color-muted-foreground: var(--color-gray-500);
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 48-53" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Muted" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """:root {
  --color-border: var(--color-gray-200);
  --color-input: var(--color-gray-200);
  --color-ring: var(--color-blue-500);
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 94-100" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 8 ;
                            oc:sectionTitle "Border & Ring" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """:root {
  --color-success: var(--color-green-600);
  --color-success-foreground: white;

  --color-warning: var(--color-yellow-500);
  --color-warning-foreground: var(--color-gray-900);

  --color-error: var(--color-red-600);
  --color-error-foreground: white;

  --color-info: var(--color-blue-500);
  --color-info-foreground: white;
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 76-90" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 7 ;
                            oc:sectionTitle "Status Colors" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """:root {
  --color-accent: var(--color-gray-100);
  --color-accent-foreground: var(--color-gray-900);
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 57-62" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "Accent" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """:root {
  --color-primary: var(--color-blue-600);
  --color-primary-hover: var(--color-blue-700);
  --color-primary-active: var(--color-blue-800);
  --color-primary-foreground: white;
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 27-34" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Primary" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """:root {
  --color-secondary: var(--color-gray-100);
  --color-secondary-hover: var(--color-gray-200);
  --color-secondary-foreground: var(--color-gray-900);
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 38-44" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Secondary" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Color Semantics" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Focus ring */
  --ring-width: 2px;
  --ring-offset: 2px;
  --ring-color: var(--color-ring);

  /* Opacity for disabled */
  --opacity-disabled: 0.5;

  /* Transitions */
  --transition-colors: color, background-color, border-color;
  --transition-transform: transform;
  --transition-all: all;
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 145-160" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Interactive States" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """.dark {
  --color-background: var(--color-gray-950);
  --color-foreground: var(--color-gray-50);

  --color-card: var(--color-gray-900);
  --color-card-foreground: var(--color-gray-50);

  --color-popover: var(--color-gray-900);
  --color-popover-foreground: var(--color-gray-50);

  --color-muted: var(--color-gray-800);
  --color-muted-foreground: var(--color-gray-400);

  --color-secondary: var(--color-gray-800);
  --color-secondary-foreground: var(--color-gray-50);

  --color-accent: var(--color-gray-800);
  --color-accent-foreground: var(--color-gray-50);

  --color-border: var(--color-gray-800);
  --color-input: var(--color-gray-800);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 164-187" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Dark Mode Overrides" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """:root {
  /* Headings */
  --font-heading: var(--font-size-2xl);
  --font-heading-lg: var(--font-size-3xl);
  --font-heading-xl: var(--font-size-4xl);

  /* Body */
  --font-body: var(--font-size-base);
  --font-body-sm: var(--font-size-sm);
  --font-body-lg: var(--font-size-lg);

  /* Labels & Captions */
  --font-label: var(--font-size-sm);
  --font-caption: var(--font-size-xs);
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 125-141" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Typography Semantics" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Semantic Tokens" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Define the complete semantic token layer for a design system" ;
            oc:hasStep _:ref_3fff5332edda09c1,
                [ a oc:WorkflowStep ;
                    dcterms:description "Add .dark class overrides for all color tokens that change in dark theme" ;
                    oc:expectedOutcome "Dark mode produces correct contrast and visual hierarchy" ;
                    oc:stepDependsOn _:ref_3fff5332edda09c1,
                        _:ref_8a1fc2b8683bae81,
                        _:ref_e7418c1f9fc98733,
                        _:ref_f30309b71c1313f7 ;
                    oc:stepId "define-dark-mode-overrides" ],
                _:ref_8a1fc2b8683bae81,
                _:ref_e7418c1f9fc98733,
                _:ref_f30309b71c1313f7 ;
            oc:workflowId "semantic-token-setup" ;
            oc:workflowName "Semantic Token Definition" ] ;
    oc:impartsKnowledge oc:kn_0149420e,
        oc:kn_20cba37e,
        oc:kn_5660ba37,
        oc:kn_5aeabbf4,
        oc:kn_652a7115,
        oc:kn_6a24d452,
        oc:kn_d3ba69ba ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:PrimitiveTokensDefined ;
    oc:resolvesIntent "apply semantic design tokens",
        "configure spacing and typography semantics",
        "define color semantics for UI components",
        "implement dark mode theme switching",
        "maintain theme-consistent styling across components" ;
    oc:yieldsState oc:SemanticTokensReady .

oc:kn_0149420e a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Define semantic color tokens (background, card, primary, secondary, muted, accent, destructive, status, border) 2. Define spacing tokens (component, section, page) 3. Define typography tokens (heading, body, label) 4. Define interactive state tokens (focus ring, opacity, transitions) 5. Add .dark class overrides for dark mode" ;
    oc:stepOrder 1 .

oc:kn_20cba37e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling any UI component" ;
    oc:directiveContent "Never use primitive tokens (e.g., var(--color-gray-50)) directly in component styles; always use semantic tokens (e.g., var(--color-card))." ;
    oc:hasRationale "Semantic tokens enable theme switching and design consistency — primitive tokens bypass the semantic layer and break theming." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5660ba37 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing dark mode" ;
    oc:directiveContent "Dark mode overrides only need to redefine semantic tokens that change — not primitive tokens. Toggle the .dark class on documentElement to switch themes." ;
    oc:hasRationale "Since semantic tokens are the consumption layer, overriding them in .dark is sufficient; primitive tokens remain unchanged." .

oc:kn_5aeabbf4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining or consuming design tokens" ;
    oc:directiveContent "Semantic tokens are purpose-based aliases (card, popover, primary, destructive) that reference primitive tokens, creating an indirection layer that enables theme switching." ;
    oc:hasRationale "This two-layer architecture separates meaning from value, allowing global theme changes by overriding only the semantic layer." .

oc:kn_652a7115 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling components with semantic tokens" ;
    oc:codeLanguage "css" ;
    oc:directiveContent """.card {
  background: var(--color-card);
  color: var(--color-card-foreground);
  border: 1px solid var(--color-border);
}""" .

oc:kn_6a24d452 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining new semantic color tokens" ;
    oc:directiveContent "Every semantic color token must have a matching foreground token (e.g., --color-primary requires --color-primary-foreground) to ensure readable text on any background." ;
    oc:hasRationale "Without paired foreground tokens, text contrast cannot be guaranteed across themes." ;
    oc:severityLevel "HIGH" .

oc:kn_d3ba69ba a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When switching themes programmatically" ;
    oc:directiveContent "Toggling dark mode via classList.toggle is idempotent — repeating the same toggle state produces the same result." .

_:ref_3fff5332edda09c1 a oc:WorkflowStep ;
    dcterms:description "Define focus ring, disabled opacity, and transition tokens" ;
    oc:expectedOutcome "Interactive state tokens are ready for component consumption" ;
    oc:stepDependsOn _:ref_e7418c1f9fc98733 ;
    oc:stepId "define-interactive-states" .

_:ref_8a1fc2b8683bae81 a oc:WorkflowStep ;
    dcterms:description "Define component, section, and page spacing tokens" ;
    oc:expectedOutcome "Spacing tokens reference valid primitive space tokens" ;
    oc:stepDependsOn _:ref_e7418c1f9fc98733 ;
    oc:stepId "define-spacing-semantics" .

_:ref_f30309b71c1313f7 a oc:WorkflowStep ;
    dcterms:description "Define heading, body, label, and caption typography tokens" ;
    oc:expectedOutcome "Typography tokens reference valid primitive font-size tokens" ;
    oc:stepDependsOn _:ref_e7418c1f9fc98733 ;
    oc:stepId "define-typography-semantics" .

_:ref_e7418c1f9fc98733 a oc:WorkflowStep ;
    dcterms:description "Define background, foreground, primary, secondary, muted, accent, destructive, status, border, and ring color tokens" ;
    oc:expectedOutcome "All color semantic tokens reference valid primitive tokens" ;
    oc:stepId "define-color-semantics" .

