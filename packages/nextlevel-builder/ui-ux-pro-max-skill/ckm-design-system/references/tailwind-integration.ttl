oc:kn_15755e88 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining color tokens in CSS variables for Tailwind" ;
    oc:directiveContent "Use HSL color values stored as space-separated numbers (without the hsl() function wrapper) in CSS variables so Tailwind's hsl(var(--token)) format enables opacity modifiers like bg-primary/50." ;
    oc:hasRationale "This pattern unlocks Tailwind's built-in opacity modifier syntax which requires the raw HSL channel values to be wrapped at usage time, not definition time." ;
    oc:severityLevel "CRITICAL" .

oc:kn_24332641 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-applying configuration to an existing project" ;
    oc:directiveContent "Re-running the CSS variable setup is safe as it overwrites identical values, but tailwind.config.ts changes are additive and should be merged carefully to avoid duplicating existing theme.extend keys." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2eda44c2 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When integrating design tokens into Tailwind" ;
    oc:directiveContent "1. Define CSS variables as space-separated HSL values in :root and .dark selectors 2. Configure tailwind.config.ts to reference variables via hsl(var(--name)) 3. Map borderRadius to var(--radius) and derivatives 4. Use @layer components for component-level classes with @apply 5. Verify dark mode toggle via classList.toggle('dark')" ;
    oc:stepOrder 1 .

oc:kn_37be142f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining color CSS variables for Tailwind" ;
    oc:directiveContent "Never wrap HSL values in the hsl() function inside CSS variable definitions (e.g., avoid --primary: hsl(217 91% 60%)). Use space-separated raw values instead." ;
    oc:hasRationale "Wrapping in hsl() at definition time prevents Tailwind's opacity modifier syntax from working, as it requires inserting the / opacity value inside the hsl() call." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e1667015 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming semantic color tokens" ;
    oc:directiveContent "CSS variable names must use the shadcn/ui naming convention (background, foreground, primary, secondary, muted, accent, destructive, border, input, ring, card) for compatibility with npx shadcn@latest add commands." ;
    oc:hasRationale "shadcn/ui components expect these exact variable names; deviation breaks automatic component styling." ;
    oc:severityLevel "HIGH" .

oc:kn_e1717938 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before starting Tailwind integration" ;
    oc:directiveContent "Tailwind CSS must be installed and configured in the project. For shadcn/ui compatibility, the project should be a Next.js, Vite, or Remix app with TypeScript." .

oc:kn_e4d07fce a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring borderRadius in tailwind.config.ts" ;
    oc:directiveContent "Derive border radius variants from a single --radius token using calc(): lg = var(--radius), md = calc(var(--radius) - 2px), sm = calc(var(--radius) - 4px)." ;
    oc:hasRationale "Single-source radius token ensures consistent scaling across all component variants with one change point." .

oc:kn_e9788d7e a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After completing Tailwind integration" ;
    oc:directiveContent "Integration is successful when: (1) bg-primary/50 produces 50% opacity output, (2) toggling .dark class switches all semantic colors, (3) shadcn/ui components render with correct tokens without overrides." ;
    oc:hasRationale "These three checks validate the core promises of the token-to-Tailwind bridge." .

