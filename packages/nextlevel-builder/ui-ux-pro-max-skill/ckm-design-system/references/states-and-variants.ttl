                                    oc:contentOrder 2 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "```" ;
                                    oc:tableMarkdown """| Element | Error Treatment |
|---------|-----------------|
| Input border | red-500 |
| Input focus ring | red/20% |
| Helper text | red-600 |
| Icon | red-500 |
""" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """.error {
  border-color: var(--color-error);
  color: var(--color-error);
}

.error:focus-visible {
  box-shadow: 0 0 0 2px var(--color-background),
              0 0 0 4px var(--color-error);
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 136-146" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Visual Indicators" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Include icon for accessibility" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Use error color" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Position below input" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Clear on valid input" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Error Messages" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Error States" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """/* Standard focus ring */
.focusable:focus-visible {
  outline: none;
  box-shadow: 0 0 0 var(--ring-offset) var(--color-background),
              0 0 0 calc(var(--ring-offset) + var(--ring-width)) var(--ring-color);
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 52-59" ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "```" ;
                                    oc:tableMarkdown """| Property | Value |
|----------|-------|
| Ring width | 2px |
| Ring offset | 2px |
| Ring color | primary (blue-500) |
| Offset color | background |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Focus Ring Spec" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """/* Container focus when child is focused */
.container:focus-within {
  border-color: var(--color-ring);
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 70-75" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Focus Within" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Focus States" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Use icons, text, or patterns" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Ensure focus is visible" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Provide loading announcements" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Never rely on color alone" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "State Indicators" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """<!-- Disabled -->
<button disabled aria-disabled="true">Submit</button>

<!-- Loading -->
<button aria-busy="true" aria-describedby="loading-text">
  <span id="loading-text" class="sr-only">Loading...</span>
</button>

<!-- Error -->
<input aria-invalid="true" aria-describedby="error-msg">
<span id="error-msg" role="alert">Error message</span>
""" ;
                                    oc:codeLanguage "html" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 229-241" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "ARIA States" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Color Contrast" ;
                                    oc:tableMarkdown """| Element | Minimum Ratio |
|---------|---------------|
| Normal text | 4.5:1 |
| Large text (18px+) | 3:1 |
| UI components | 3:1 |
| Focus indicator | 3:1 |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Color Contrast" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Accessibility Requirements" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """.disabled {
  opacity: var(--opacity-disabled); /* 0.5 */
  pointer-events: none;
  cursor: not-allowed;
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 81-87" ],
                                [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "```" ;
                                    oc:tableMarkdown """| Property | Disabled Value |
|----------|----------------|
| Opacity | 50% |
| Pointer events | none |
| Cursor | not-allowed |
| Background | muted |
| Color | muted-foreground |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Visual Treatment" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Use `aria-disabled=\"true\"` for semantic disabled" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Use `disabled` attribute for form elements" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Maintain sufficient contrast (3:1 minimum)" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Accessibility" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Disabled States" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """/* Pattern for size variants */
.component {
  --component-height: 40px;
  --component-padding: var(--space-4);
  --component-font: var(--font-size-sm);
}

.component.sm {
  --component-height: 32px;
  --component-padding: var(--space-3);
  --component-font: var(--font-size-xs);
}

.component.lg {
  --component-height: 48px;
  --component-padding: var(--space-6);
  --component-font: var(--font-size-base);
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 188-207" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Size Variants" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """/* Pattern for color variants */
.component {
  --component-bg: var(--color-primary);
  --component-fg: var(--color-primary-foreground);
  background: var(--component-bg);
  color: var(--component-fg);
}

.component.secondary {
  --component-bg: var(--color-secondary);
  --component-fg: var(--color-secondary-foreground);
}

.component.destructive {
  --component-bg: var(--color-destructive);
  --component-fg: var(--color-destructive-foreground);
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 166-184" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Color Variants" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Variant Patterns" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 2 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "```" ;
                                    oc:tableMarkdown """| Transition | Duration | Easing |
|------------|----------|--------|
| Color changes | 150ms | ease-in-out |
| Background | 150ms | ease-in-out |
| Transform | 200ms | ease-out |
| Opacity | 150ms | ease |
| Shadow | 200ms | ease-out |
""" ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """/* Standard transition for interactive elements */
.interactive {
  transition-property: color, background-color, border-color, box-shadow;
  transition-duration: var(--duration-fast);
  transition-timing-function: ease-in-out;
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 31-38" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "State Transitions" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 6 ;
                                    oc:tableCaption "### State Definitions" ;
                                    oc:tableMarkdown """| State | Trigger | Visual Change |
|-------|---------|---------------|
| default | None | Base appearance |
| hover | Mouse over | Slight color shift |
| focus | Tab/click | Focus ring |
| active | Mouse down | Darkest color |
| disabled | disabled attr | Reduced opacity |
| loading | Async action | Spinner + opacity |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "State Definitions" ],
                        [ a oc:Section ;
                            oc:hasContent _:ref_30b53ca4fc9784f5,
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "When multiple states apply, priority (highest to lowest):" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "State Priority" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Interactive States" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Spinner Placement" ;
                                    oc:tableMarkdown """| Component | Spinner Position |
|-----------|------------------|
| Button | Replace icon or center |
| Input | Trailing position |
| Card | Center overlay |
| Page | Center of viewport |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Spinner Placement" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """.loading {
  position: relative;
  pointer-events: none;
}

.loading::after {
  content: '';
  /* spinner styles */
}

.loading > * {
  opacity: 0.7;
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 116-130" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Loading Treatment" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Loading States" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "States and Variants" ] ;
    oc:hasWorkflow _:ref_30b53ca4fc9784f5,
        [ a oc:Workflow ;
            dcterms:description "Apply states in priority order when multiple states are active simultaneously" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Check if component is disabled — apply disabled treatment (opacity 0.5, pointer-events none)" ;
                    oc:expectedOutcome "Disabled state overrides all other visual states" ;
                    oc:stepId "step-1" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Check if component is active (mouse down) — apply darkest color treatment" ;
                    oc:expectedOutcome "Active state shows pressed/engaged visual" ;
                    oc:stepId "step-3" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Check if component is hovered — apply slight color shift" ;
                    oc:expectedOutcome "Hover state provides visual feedback on mouse-over" ;
                    oc:stepId "step-5" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Check if component is loading — apply loading treatment (spinner, pointer-events none)" ;
                    oc:expectedOutcome "Loading state overrides active, focus, hover, default" ;
                    oc:stepId "step-2" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Default state — base appearance with no additional treatment" ;
                    oc:expectedOutcome "Component renders at rest state" ;
                    oc:stepId "step-6" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Check if component has focus — apply focus ring (2px ring, 2px offset)" ;
                    oc:expectedOutcome "Focus ring visible for keyboard navigation" ;
                    oc:stepId "step-4" ] ;
            oc:workflowId "states-and-variants-priority" ;
            oc:workflowName "State Priority Resolution" ] ;
