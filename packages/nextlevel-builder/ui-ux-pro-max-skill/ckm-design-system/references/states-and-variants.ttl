oc:kn_1fceb61a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any visual state treatment" ;
    oc:directiveContent "Maintain minimum color contrast ratios: 4.5:1 for normal text, 3:1 for large text (18px+) and UI components, 3:1 for focus indicators" ;
    oc:hasRationale "WCAG accessibility compliance requires minimum contrast ratios for readability by users with visual impairments" ;
    oc:severityLevel "CRITICAL" .

oc:kn_2ab36315 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing interactive elements with overlapping states" ;
    oc:directiveContent "When multiple interactive states apply simultaneously, follow priority order: disabled > loading > active > focus > hover > default" ;
    oc:hasRationale "Prevents conflicting visual treatments and ensures the most important state is always communicated to the user" ;
    oc:severityLevel "HIGH" .

oc:kn_3555d2d8 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When implementing state visual indicators" ;
    oc:directiveContent "Never rely on color alone to indicate state; always combine with icons, text, patterns, or other non-color indicators" ;
    oc:hasRationale "Color-blind users cannot distinguish color-only state changes; redundant cues ensure universal accessibility" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c51cafcb a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating color or size variants for any component" ;
    oc:directiveContent "Use CSS custom properties pattern for variants: define --component-bg/fg at base, override in modifier classes (.secondary, .destructive, .sm, .lg)" ;
    oc:hasRationale "CSS custom property overrides provide a scalable, maintainable variant system without repetitive style declarations" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ca0d646c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing focus and disabled states" ;
    oc:directiveContent "Use focus-visible (not focus) for keyboard-only focus rings, and use aria-disabled for semantic disabled state alongside the HTML disabled attribute" ;
    oc:hasRationale "focus-visible prevents focus rings from appearing on mouse clicks (better UX), while aria-disabled ensures screen readers announce the disabled state" ;
    oc:severityLevel "HIGH" .

