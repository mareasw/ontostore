oc:kn_08d33414 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When fetching slide background images" ;
    oc:directiveContent "The fetch-background.py script requires Pexels/Unsplash API keys. Never commit API keys to token config files or slide HTML. Use environment variables." ;
    oc:hasRationale "Exposed API keys can be abused for unauthorized access to image services, leading to rate limiting or account suspension." ;
    oc:severityLevel "HIGH" .

oc:kn_20795ab2 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running build pipelines or CI checks" ;
    oc:directiveContent "Token generation is idempotent — running generate-tokens.cjs multiple times with the same config produces identical CSS output. Validation scripts are read-only and side-effect-free." ;
    oc:hasRationale "Idempotent generation ensures reproducible builds and safe re-runs in CI/CD pipelines." ;
    oc:severityLevel "LOW" .

oc:kn_541f5624 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any HTML slide/presentation" ;
    oc:directiveContent "All slides MUST: (1) import assets/design-tokens.css, (2) use CSS variables exclusively, (3) use Chart.js for charts not CSS-only bars, (4) include keyboard/click navigation with progress bar, (5) center-align content, (6) focus on persuasion/conversion." ;
    oc:hasRationale "These requirements ensure brand consistency, accessibility, and the strategic purpose of presentations is maintained." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5eadc829 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When implementing component state interactions" ;
    oc:directiveContent "State priority for interactive components: disabled > loading > active > focus > hover > default. When multiple states apply simultaneously, the highest-priority state wins." ;
    oc:hasRationale "Without defined priority, conflicting states produce unpredictable visual results and degrade accessibility." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6c27e9de a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or extending the design token system" ;
    oc:directiveContent "Follow the three-layer token cascade: Primitive (raw values like --color-blue-600) → Semantic (purpose aliases like --color-primary) → Component (component-specific like --button-bg). Each layer references the one below." ;
    oc:hasRationale "Three-layer separation enables theme switching at the semantic layer and per-component customization at the component layer without touching raw values." ;
    oc:severityLevel "HIGH" .

oc:kn_83c54308 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining color tokens in CSS or Tailwind config" ;
    oc:directiveContent "Use HSL format (space-separated: '37 99 235') for color tokens rather than hex, enabling Tailwind opacity modifiers like bg-primary/50 without additional CSS." ;
    oc:hasRationale "HSL space-separated format is the Tailwind/shadcn convention that unlocks opacity modifier syntax directly in utility classes." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d864b973 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After token generation or slide creation" ;
    oc:directiveContent "After generating any CSS or slides, run validate-tokens.cjs --dir src/ or slide-token-validator.py to verify no hardcoded values leaked into the output." ;
    oc:hasRationale "Automated validation catches token violations that manual review misses, especially in generated HTML slides." ;
    oc:severityLevel "MEDIUM" .

oc:kn_edeee53c a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When creating multi-slide presentations" ;
    oc:directiveContent "For slide generation, follow the contextual decision flow: parse goal → search slide-strategies.csv for strategy + emotion beats → for each slide query layout-logic, typography, color-logic, backgrounds → generate HTML with tokens → validate with slide-token-validator.py." ;
    oc:hasRationale "This CSV-driven decision system ensures consistent, strategic deck structures with proper emotion arcs (Duarte Sparkline pattern)." ;
    oc:severityLevel "HIGH" .

oc:kn_ef88e491 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing CSS, HTML, or slide markup that references design values" ;
    oc:directiveContent "Never use raw hex values or hardcoded colors in components — always reference tokens via CSS custom properties (var(--color-primary), var(--button-bg), etc.)." ;
    oc:hasRationale "Hardcoded values break theme switching, bypass the token layering system, and make maintenance catastrophic across large codebases." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ff35ae0d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running generate-tokens.cjs" ;
    oc:directiveContent "Before generating tokens, ensure the JSON config follows the three-layer structure with primitive, semantic, and component sections. Use templates/design-tokens-starter.json as the starting template." ;
    oc:hasRationale "Incorrect config structure produces invalid CSS output that breaks the entire design system cascade." ;
    oc:severityLevel "HIGH" .

oc:payload_b17ef19c5a3c53e5 a oc:ExecutionPayload ;
    oc:code "node scripts/generate-tokens.cjs --config {config_path} -o {output_path}" ;
    oc:executor "node" ;
    oc:timeout 30000 .

oc:req_21588ecf a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "Node.js (for generate-tokens.cjs, validate-tokens.cjs, embed-tokens.cjs)" .

