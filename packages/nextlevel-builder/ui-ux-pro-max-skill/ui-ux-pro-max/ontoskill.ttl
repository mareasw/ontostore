                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Search Reference" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Use `--design-system` first for full recommendations, then `--domain` to deep-dive any dimension you're unsure about" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Try different keywords for the same need: `\"playful neon\"` → `\"vibrant dark\"` → `\"content-first minimal\"`" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Use **multi-dimensional keywords** — combine product + industry + tone + density: `\"entertainment social vibrant content-dense\"` not just `\"app\"`" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Always add `--stack react-native` for implementation-specific guidance" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Query Strategy" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 7 ;
                                    oc:tableCaption "### Common Sticking Points" ;
                                    oc:tableMarkdown """| Problem | What to Do |
|---------|------------|
| Can't decide on style/color | Re-run `--design-system` with different keywords |
| Dark mode contrast issues | Quick Reference §6: `color-dark-mode` + `color-accessible-pairs` |
| Animations feel unnatural | Quick Reference §7: `spring-physics` + `easing` + `exit-faster-than-enter` |
| Form UX is poor | Quick Reference §8: `inline-validation` + `error-clarity` + `focus-management` |
| Navigation feels confusing | Quick Reference §9: `nav-hierarchy` + `bottom-nav-limit` + `back-behavior` |
| Layout breaks on small screens | Quick Reference §5: `mobile-first` + `breakpoint-consistency` |
| Performance / jank | Quick Reference §3: `virtualize-lists` + `main-thread-budget` + `debounce-throttle` |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Common Sticking Points" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "Confirm all touch targets ≥44pt and no content hidden behind safe areas" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Run `--domain ux \"animation accessibility z-index loading\"` as a UX validation pass before implementation" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Test on 375px (small phone) and landscape orientation" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Verify behavior with **reduced-motion** enabled and **Dynamic Type** at largest size" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "Check dark mode contrast independently (don't assume light mode values work)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Run through Quick Reference **§1–§3** (CRITICAL + HIGH) as a final review" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Pre-Delivery Checklist" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 10 ;
                    oc:sectionTitle "Tips for Better Results" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 13 ;
                                            oc:itemText "`state-preservation` - Navigating back must restore previous scroll position, filter state, and input (HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 10 ;
                                            oc:itemText "`modal-escape` - Modals and sheets must offer a clear close/dismiss affordance; swipe-down to dismiss on mobile (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 26 ;
                                            oc:itemText "`empty-nav-state` - When a nav destination is unavailable, explain why instead of silently hiding it (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 16 ;
                                            oc:itemText "`overflow-menu` - When actions exceed available space, use overflow/more menu instead of cramming (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 9 ;
                                            oc:itemText "`nav-hierarchy` - Primary nav (tabs/bottom bar) vs secondary nav (drawer/settings) must be clearly separated (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 15 ;
                                            oc:itemText "`tab-badge` - Use badges on nav items sparingly to indicate unread/pending; clear after user visits (HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`bottom-nav-limit` - Bottom navigation max 5 items; use labels with icons (Material Design)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 17 ;
                                            oc:itemText "`bottom-nav-top-level` - Bottom nav is for top-level screens only; never nest sub-navigation inside it (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 18 ;
                                            oc:itemText "`adaptive-navigation` - Large screens (≥1024px) prefer sidebar; small screens use bottom/top nav (Material Adaptive)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 24 ;
                                            oc:itemText "`persistent-nav` - Core navigation must remain reachable from deep pages; don't hide it entirely in sub-flows (HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 19 ;
                                            oc:itemText "`back-stack-integrity` - Never silently reset the navigation stack or unexpectedly jump to home (HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 21 ;
                                            oc:itemText "`avoid-mixed-patterns` - Don't mix Tab + Sidebar + Bottom Nav at the same hierarchy level" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "`top-app-bar-android` - Android: use Top App Bar with navigation icon for primary structure (Material Design)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 23 ;
                                            oc:itemText "`focus-on-route-change` - After page transition, move focus to main content region for screen reader users (WCAG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 8 ;
                                            oc:itemText "`nav-state-active` - Current location must be visually highlighted (color, weight, indicator) in navigation (HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "`deep-linking` - All key screens must be reachable via deep link / URL for sharing and notifications (Apple HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "`back-behavior` - Back navigation must be predictable and consistent; preserve scroll/state (Apple HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 12 ;
                                            oc:itemText "`breadcrumb-web` - Web: use breadcrumbs for 3+ level deep hierarchies to aid orientation (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "`tab-bar-ios` - iOS: use bottom Tab Bar for top-level navigation (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 11 ;
                                            oc:itemText "`search-accessible` - Search must be easily reachable (top bar or tab); provide recent/suggested queries (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "`nav-label-icon` - Navigation items must have both icon and text label; icon-only nav harms discoverability (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 14 ;
                                            oc:itemText "`gesture-nav-support` - Support system gesture navigation (iOS swipe-back, Android predictive back) without conflict (HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "`drawer-usage` - Use drawer/sidebar for secondary navigation, not primary actions (Material Design)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 20 ;
                                            oc:itemText "`navigation-consistency` - Navigation placement must stay the same across all pages; don't change by page type" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 25 ;
                                            oc:itemText "`destructive-nav-separation` - Dangerous actions (delete account, logout) must be visually and spatially separated from normal nav items (HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 22 ;
                                            oc:itemText "`modal-vs-navigation` - Modals must not be used for primary navigation flows; they break the user's path (HIG)" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 9 ;
                            oc:sectionTitle "9. Navigation Patterns (HIGH)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "`color-palette-from-product` - Choose palette from product/industry (search `--domain color`)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 12 ;
                                            oc:itemText "`blur-purpose` - Use blur to indicate background dismissal (modals, sheets), not as decoration (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 9 ;
                                            oc:itemText "`dark-mode-pairing` - Design light/dark variants together to keep brand, contrast, and style consistent" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "`no-emoji-icons` - Use SVG icons (Heroicons, Lucide), not emojis" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 8 ;
                                            oc:itemText "`elevation-consistent` - Use a consistent elevation/shadow scale for cards, sheets, modals; avoid random shadow values" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 10 ;
                                            oc:itemText "`icon-style-consistent` - Use one icon set/visual language (stroke width, corner radius) across the product" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 11 ;
                                            oc:itemText "`system-controls` - Prefer native/system controls over fully custom ones; only customize when branding requires it (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "`platform-adaptive` - Respect platform idioms (iOS HIG vs Material): navigation, controls, typography, motion" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "`effects-match-style` - Shadows, blur, radius aligned with chosen style (glass / flat / clay etc.)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "`state-clarity` - Make hover/pressed/disabled states visually distinct while staying on-style (Material state layers)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 13 ;
                                            oc:itemText "`primary-action` - Each screen should have only one primary CTA; secondary actions visually subordinate (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`style-match` - Match style to product type (use `--design-system` for recommendations)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "`consistency` - Use same style across all pages" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "4. Style Selection (HIGH)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 15 ;
                                            oc:itemText "`no-pie-overuse` - Avoid pie/donut for >5 categories; switch to bar chart for clarity" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`chart-type` - Match chart type to data type (trend → line, comparison → bar, proportion → pie/donut)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 8 ;
                                            oc:itemText "`responsive-chart` - Charts must reflow or simplify on small screens (e.g. horizontal bar instead of vertical, fewer ticks)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 9 ;
                                            oc:itemText "`empty-data-state` - Show meaningful empty state when no data exists (\"No data yet\" + guidance), not a blank chart (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 21 ;
                                            oc:itemText "`axis-readability` - Axis ticks must not be cramped; maintain readable spacing, auto-skip on small screens" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 18 ;
                                            oc:itemText "`direct-labeling` - For small datasets, label values directly on the chart to reduce eye travel" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 27 ;
                                            oc:itemText "`error-state-chart` - Data load failure must show error message with retry action, not a broken/empty chart" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 22 ;
                                            oc:itemText "`data-density` - Limit information density per chart to avoid cognitive overload; split into multiple charts if needed" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 12 ;
                                            oc:itemText "`large-dataset` - For 1000+ data points, aggregate or sample; provide drill-down for detail instead of rendering all (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 13 ;
                                            oc:itemText "`number-formatting` - Use locale-aware formatting for numbers, dates, currencies on axes and labels (HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 30 ;
                                            oc:itemText "`time-scale-clarity` - Time series charts must clearly label time granularity (day/week/month) and allow switching" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 23 ;
                                            oc:itemText "`trend-emphasis` - Emphasize data trends over decoration; avoid heavy gradients/shadows that obscure the data" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 28 ;
                                            oc:itemText "`export-option` - For data-heavy products, offer CSV/image export of chart data" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 11 ;
                                            oc:itemText "`animation-optional` - Chart entrance animations must respect prefers-reduced-motion; data should be readable immediately (HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 20 ;
                                            oc:itemText "`sortable-table` - Data tables must support sorting with aria-sort indicating current sort state (WCAG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "`color-guidance` - Use accessible color palettes; avoid red/green only pairs for colorblind users (WCAG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 26 ;
                                            oc:itemText "`screen-reader-summary` - Provide a text summary or aria-label describing the chart's key insight for screen readers (WCAG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 16 ;
                                            oc:itemText "`contrast-data` - Data lines/bars vs background ≥3:1; data text labels ≥4.5:1 (WCAG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 14 ;
                                            oc:itemText "`touch-target-chart` - Interactive chart elements (points, segments) must have ≥44pt tap area or expand on touch (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "`axis-labels` - Label axes with units and readable scale; avoid truncated or rotated labels on mobile" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 25 ;
                                            oc:itemText "`focusable-elements` - Interactive chart elements (points, bars, slices) must be keyboard-navigable (WCAG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "`legend-visible` - Always show legend; position near the chart, not detached below a scroll fold (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 29 ;
                                            oc:itemText "`drill-down-consistency` - Drill-down interactions must maintain a clear back-path and hierarchy breadcrumb" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 17 ;
                                            oc:itemText "`legend-interactive` - Legends should be clickable to toggle series visibility (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "`data-table` - Provide table alternative for accessibility; charts alone are not screen-reader friendly (WCAG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 24 ;
                                            oc:itemText "`gridline-subtle` - Grid lines should be low-contrast (e.g. gray-200) so they don't compete with data" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "`pattern-texture` - Supplement color with patterns, textures, or shapes so data is distinguishable without color (WCAG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 19 ;
                                            oc:itemText "`tooltip-keyboard` - Tooltip content must be keyboard-reachable and not rely on hover alone (WCAG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 10 ;
                                            oc:itemText "`loading-chart` - Use skeleton or shimmer placeholder while chart data loads; don't show an empty axis frame" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "`tooltip-on-interact` - Provide tooltips/data labels on hover (Web) or tap (mobile) showing exact values (HIG, MD)" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 10 ;
                            oc:sectionTitle "10. Charts & Data (LOW)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "`horizontal-scroll` - No horizontal scroll on mobile; ensure content fits viewport width" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "`mobile-first` - Design mobile-first, then scale up to tablet and desktop" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 14 ;
                                            oc:itemText "`orientation-support` - Keep layout readable and operable in landscape mode" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "`readable-font-size` - Minimum 16px body text on mobile (avoids iOS auto-zoom)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 13 ;
                                            oc:itemText "`viewport-units` - Prefer min-h-dvh over 100vh on mobile" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 15 ;
                                            oc:itemText "`content-priority` - Show core content first on mobile; fold or hide secondary content" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 9 ;
                                            oc:itemText "`container-width` - Consistent max-width on desktop (max-w-6xl / 7xl)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 11 ;
                                            oc:itemText "`fixed-element-offset` - Fixed navbar/bottom bar must reserve safe padding for underlying content" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 8 ;
                                            oc:itemText "`touch-density` - Keep component spacing comfortable for touch: not cramped, not causing mis-taps" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 12 ;
                                            oc:itemText "`scroll-behavior` - Avoid nested scroll regions that interfere with the main scroll experience" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 10 ;
                                            oc:itemText "`z-index-management` - Define layered z-index scale (e.g. 0 / 10 / 20 / 40 / 100 / 1000)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`viewport-meta` - width=device-width initial-scale=1 (never disable zoom)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 16 ;
                                            oc:itemText "`visual-hierarchy` - Establish hierarchy via size, spacing, contrast — not color alone" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "`spacing-scale` - Use 4pt/8dp incremental spacing system (Material Design)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "`breakpoint-consistency` - Use systematic breakpoints (e.g. 375 / 768 / 1024 / 1440)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "`line-length-control` - Mobile 35–60 chars per line; desktop 60–75 chars" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 5 ;
                            oc:sectionTitle "5. Layout & Responsive (HIGH)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "`error-feedback` - Clear error messages near problem" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 10 ;
                                            oc:itemText "`system-gestures` - Don't block system gestures (Control Center, back swipe, etc.) (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 11 ;
                                            oc:itemText "`press-feedback` - Visual feedback on press (ripple/highlight; MD state layers)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "`gesture-conflicts` - Avoid horizontal swipe on main content; prefer vertical scroll" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 13 ;
                                            oc:itemText "`gesture-alternative` - Don't rely on gesture-only interactions; always provide visible controls for critical actions" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "`loading-buttons` - Disable button during async operations; show spinner or progress" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "`cursor-pointer` - Add cursor-pointer to clickable elements (Web)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 16 ;
                                            oc:itemText "`swipe-clarity` - Swipe actions must show clear affordance or hint (chevron, label, tutorial)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 14 ;
                                            oc:itemText "`safe-area-awareness` - Keep primary touch targets away from notch, Dynamic Island, gesture bar and screen edges" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 8 ;
                                            oc:itemText "`tap-delay` - Use touch-action: manipulation to reduce 300ms delay (Web)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 17 ;
                                            oc:itemText "`drag-threshold` - Use a movement threshold before starting drag to avoid accidental drags" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 12 ;
                                            oc:itemText "`haptic-feedback` - Use haptic for confirmations and important actions; avoid overuse (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 9 ;
                                            oc:itemText "`standard-gestures` - Use platform standard gestures consistently; don't redefine (e.g. swipe-back, pinch-zoom) (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "`hover-vs-tap` - Use click/tap for primary interactions; don't rely on hover alone" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`touch-target-size` - Min 44×44pt (Apple) / 48×48dp (Material); extend hit area beyond visual bounds if needed" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 15 ;
                                            oc:itemText "`no-precision-required` - Avoid requiring pixel-perfect taps on small icons or thin edges" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "`touch-spacing` - Minimum 8px/8dp gap between touch targets (Apple HIG, MD)" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "2. Touch & Interaction (CRITICAL)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 10 ;
                                            oc:itemText "`spring-physics` - Prefer spring/physics-based curves over linear or cubic-bezier for natural feel (Apple HIG fluid animations)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 15 ;
                                            oc:itemText "`no-blocking-animation` - Never block user input during an animation; UI must stay interactive (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 14 ;
                                            oc:itemText "`interruptible` - Animations must be interruptible; user tap/gesture cancels in-progress animation immediately (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 24 ;
                                            oc:itemText "`layout-shift-avoid` - Animations must not cause layout reflow or CLS; use transform for position changes" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "`loading-states` - Show skeleton or progress indicator when loading exceeds 300ms" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 21 ;
                                            oc:itemText "`opacity-threshold` - Fading elements should not linger below opacity 0.2; either fade fully or remain visible" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 16 ;
                                            oc:itemText "`fade-crossfade` - Use crossfade for content replacement within the same container (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 17 ;
                                            oc:itemText "`scale-feedback` - Subtle scale (0.95–1.05) on press for tappable cards/buttons; restore on release (HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 11 ;
                                            oc:itemText "`exit-faster-than-enter` - Exit animations shorter than enter (~60–70% of enter duration) to feel responsive (MD motion)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 22 ;
                                            oc:itemText "`modal-motion` - Modals/sheets should animate from their trigger source (scale+fade or slide-in) for spatial context (HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 13 ;
                                            oc:itemText "`shared-element-transition` - Use shared element / hero transitions for visual continuity between screens (MD, HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`duration-timing` - Use 150–300ms for micro-interactions; complex transitions ≤400ms; avoid >500ms (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "`state-transition` - State changes (hover / active / expanded / collapsed / modal) should animate smoothly, not snap" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "`easing` - Use ease-out for entering, ease-in for exiting; avoid linear for UI transitions" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 20 ;
                                            oc:itemText "`motion-consistency` - Unify duration/easing tokens globally; all animations share the same rhythm and feel" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 23 ;
                                            oc:itemText "`navigation-direction` - Forward navigation animates left/up; backward animates right/down — keep direction logically consistent (HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "`motion-meaning` - Every animation must express a cause-effect relationship, not just be decorative (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "`excessive-motion` - Animate 1-2 key elements per view max" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 19 ;
                                            oc:itemText "`hierarchy-motion` - Use translate/scale direction to express hierarchy: enter from below = deeper, exit upward = back (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 8 ;
                                            oc:itemText "`continuity` - Page/screen transitions should maintain spatial continuity (shared element, directional slide) (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "`transform-performance` - Use transform/opacity only; avoid animating width/height/top/left" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 9 ;
                                            oc:itemText "`parallax-subtle` - Use parallax sparingly; must respect reduced-motion and not cause disorientation (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 18 ;
                                            oc:itemText "`gesture-feedback` - Drag, swipe, and pinch must provide real-time visual response tracking the finger (MD Motion)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 12 ;
                                            oc:itemText "`stagger-sequence` - Stagger list/grid item entrance by 30–50ms per item; avoid all-at-once or too-slow reveals (MD)" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 7 ;
                            oc:sectionTitle "7. Animation (MEDIUM)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 12 ;
                                            oc:itemText "`truncation-strategy` - Prefer wrapping over truncation; when truncating use ellipsis and provide full text via tooltip/expand (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "`line-length` - Limit to 65-75 characters per line" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "`weight-hierarchy` - Use font-weight to reinforce hierarchy: Bold headings (600–700), Regular body (400), Medium labels (500) (MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 10 ;
                                            oc:itemText "`color-accessible-pairs` - Foreground/background pairs must meet 4.5:1 (AA) or 7:1 (AAA); use tools to verify (WCAG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "`font-pairing` - Match heading/body font personalities" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 9 ;
                                            oc:itemText "`color-dark-mode` - Dark mode uses desaturated / lighter tonal variants, not inverted colors; test contrast separately (HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 11 ;
                                            oc:itemText "`color-not-decorative-only` - Functional color (error red, success green) must include icon/text; avoid color-only meaning (HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`line-height` - Use 1.5-1.75 for body text" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "`font-scale` - Consistent type scale (e.g. 12 14 16 18 24 32)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 8 ;
                                            oc:itemText "`color-semantic` - Define semantic color tokens (primary, secondary, error, surface, on-surface) not raw hex in components (Material color system)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 14 ;
                                            oc:itemText "`number-tabular` - Use tabular/monospaced figures for data columns, prices, and timers to prevent layout shift" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 15 ;
                                            oc:itemText "`whitespace-balance` - Use whitespace intentionally to group related items and separate sections; avoid visual clutter (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "`text-styles-system` - Use platform type system: iOS 11 Dynamic Type styles / Material 5 type roles (display, headline, title, body, label) (HIG, MD)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "`contrast-readability` - Darker text on light backgrounds (e.g. slate-900 on white)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 13 ;
                                            oc:itemText "`letter-spacing` - Respect default letter-spacing per platform; avoid tight tracking on body text (HIG, MD)" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 6 ;
                            oc:sectionTitle "6. Typography & Color (MEDIUM)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "`lazy-loading` - Lazy load non-hero components via dynamic import / route-level splitting" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 18 ;
                                            oc:itemText "`offline-support` - Provide offline state messaging and basic fallback (PWA / mobile)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 10 ;
                                            oc:itemText "`content-jumping` - Reserve space for async content to avoid layout jumps (Core Web Vitals: CLS)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 17 ;
                                            oc:itemText "`debounce-throttle` - Use debounce/throttle for high-frequency events (scroll, resize, input)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "`font-preload` - Preload only critical fonts; avoid overusing preload on every variant" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 12 ;
                                            oc:itemText "`virtualize-lists` - Virtualize lists with 50+ items to improve memory efficiency and scroll performance" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 7 ;
                                            oc:itemText "`bundle-splitting` - Split code by route/feature (React Suspense / Next.js dynamic) to reduce initial load and TTI" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "`image-dimension` - Declare width/height or use aspect-ratio to prevent layout shift (Core Web Vitals: CLS)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 11 ;
                                            oc:itemText "`lazy-load-below-fold` - Use loading=\"lazy\" for below-the-fold images and heavy media" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 15 ;
                                            oc:itemText "`input-latency` - Keep input latency under ~100ms for taps/scrolls (Material responsiveness standard)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText "`critical-css` - Prioritize above-the-fold CSS (inline critical CSS or early-loaded stylesheet)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 14 ;
                                            oc:itemText "`progressive-loading` - Use skeleton screens / shimmer instead of long blocking spinners for >1s operations (Apple HIG)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
