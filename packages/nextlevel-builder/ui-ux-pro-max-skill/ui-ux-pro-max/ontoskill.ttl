oc:kn_0727dab2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning any new UI project or page design" ;
    oc:directiveContent "Always start with --design-system to get comprehensive recommendations before deep-diving into individual domains. Use multi-dimensional keywords (product + industry + tone)." ;
    oc:hasRationale "The design system generator applies reasoning rules across product, style, color, typography, and landing domains simultaneously, producing coherent recommendations." ;
    oc:severityLevel "HIGH" .

oc:kn_32127299 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing colors for text, icons, and interactive elements" ;
    oc:directiveContent "Maintain minimum 4.5:1 contrast ratio for normal text (3:1 for large text). Test dark mode contrast independently." ;
    oc:hasRationale "WCAG AA compliance is critical for accessibility. Light mode contrast values do not transfer to dark mode." ;
    oc:severityLevel "CRITICAL" .

oc:kn_32e9635d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any UI with icons" ;
    oc:directiveContent "Never use emojis as structural icons in navigation, settings, or system controls. Use SVG icons (Heroicons, Lucide) instead." ;
    oc:hasRationale "Emojis are font-dependent, inconsistent across platforms, and cannot be controlled via design tokens." ;
    oc:severityLevel "HIGH" .

oc:kn_33568f5c a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any search or design-system command" ;
    oc:directiveContent "Verify python3 is installed before running search scripts. Check that data CSV files exist in the data/ directory." ;
    oc:hasRationale "The search engine requires Python 3 and the CSV data files to function." ;
    oc:severityLevel "MEDIUM" .

oc:kn_354a0443 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When persisting design systems for multi-page projects" ;
    oc:directiveContent "Use the Master + Overrides pattern for design system persistence: MASTER.md for global rules, pages/[page].md for page-specific overrides that take priority." ;
    oc:hasRationale "Hierarchical override pattern prevents repetition while allowing page-specific customization without polluting global rules." ;
    oc:severityLevel "MEDIUM" .

oc:kn_37d5695e a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When implementing any UI animation" ;
    oc:directiveContent "Animation timing: 150-300ms for micro-interactions, ≤400ms for complex transitions. Use ease-out for entering, ease-in for exiting. Always respect prefers-reduced-motion." ;
    oc:hasRationale "Consistent animation timing creates professional feel. Violating reduced-motion preference is an accessibility failure." ;
    oc:severityLevel "MEDIUM" .

oc:kn_61b27ce1 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When reviewing or building any UI" ;
    oc:directiveContent "Follow priority order: Accessibility (1) → Touch/Interaction (2) → Performance (3) → Style (4) → Layout (5) → Typography/Color (6) → Animation (7) → Forms (8) → Navigation (9) → Charts (10)." ;
    oc:hasRationale "Higher-priority categories have greater impact on user experience and carry more severe consequences if violated." ;
    oc:severityLevel "HIGH" .

oc:kn_65fec350 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any themed UI" ;
    oc:directiveContent "Use semantic color tokens (--color-primary, --color-surface, --color-destructive) instead of raw hex values in components. Map tokens per theme (light/dark)." ;
    oc:hasRationale "Semantic tokens enable consistent theming, dark mode support, and brand changes without touching component code." ;
    oc:severityLevel "HIGH" .

oc:kn_b35c4c08 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When implementing dark mode theming" ;
    oc:directiveContent "Dark mode cannot be inferred from light mode values. Borders, interaction states, and dividers often disappear in dark mode if only tested in light mode." ;
    oc:hasRationale "Many teams only test light mode, leading to invisible elements and broken interaction states in dark mode." ;
    oc:severityLevel "HIGH" .

oc:kn_b3870816 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "Before delivering any UI code" ;
    oc:directiveContent "Run pre-delivery checklist: no emoji icons, cursor-pointer on clickable elements, 4.5:1 contrast, focus states visible, reduced-motion respected, responsive at 375/768/1024/1440px." ;
    oc:hasRationale "Catches the most common unprofessional UI issues before they reach production." ;
    oc:severityLevel "HIGH" .

oc:kn_f0158fcd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing interactive elements for mobile apps" ;
    oc:directiveContent "Minimum touch target size 44×44pt (iOS) / 48×48dp (Android). Minimum 8px gap between touch targets." ;
    oc:hasRationale "Platform HIG standards require minimum touch targets for usability and accessibility compliance." ;
    oc:severityLevel "CRITICAL" .

