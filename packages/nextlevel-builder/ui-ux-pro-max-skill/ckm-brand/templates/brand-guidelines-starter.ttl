    oc:isUserInvocable true ;
    oc:nature "Template" ;
    oc:requiresState oc:BrandConceptDefined ;
    oc:resolvesIntent "configure design tokens for brand consistency",
        "create logo usage rules",
        "define brand visual identity",
        "establish brand color palette and typography",
        "set brand voice and tone guidelines" ;
    oc:yieldsState oc:BrandGuidelinesCreated .

oc:kn_2d8e402c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting or applying brand colors to any UI element" ;
    oc:directiveContent "All interactive elements must meet WCAG 2.1 AA contrast standards. Text on white requires 7.2:1 (AAA), Primary on white requires 4.6:1 (AA)." ;
    oc:hasRationale "Accessibility compliance ensures usability for all users and avoids legal/regulatory issues" ;
    oc:severityLevel "CRITICAL" .

oc:kn_2f07550b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any brand-facing copy" ;
    oc:directiveContent "Avoid prohibited terms: 'revolutionary', 'best-in-class', 'seamless', 'synergy', 'leverage' (use 'use' instead)." ;
    oc:hasRationale "Overused and vague terms undermine credibility and brand voice clarity" ;
    oc:severityLevel "MEDIUM" .

oc:kn_4379263a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When placing brand logo in layouts" ;
    oc:directiveContent "Minimum logo sizes: 120px digital full, 24px digital icon, 35mm print full, 10mm print icon. Minimum clear space = height of logo mark." ;
    oc:hasRationale "Ensures logo legibility and brand recognition at all sizes" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ad6ef410 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using brand logo in any context" ;
    oc:directiveContent "Never rotate, skew, recolor outside approved palette, add shadows/effects, crop, or modify logo proportions. Never place on busy backgrounds without sufficient contrast." ;
    oc:hasRationale "Logo misuse dilutes brand recognition and undermines visual identity consistency" ;
    oc:severityLevel "HIGH" .

oc:kn_fd1ca912 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating any brand copy or content" ;
    oc:directiveContent "Brand personality traits are Professional (expert yet approachable), Helpful (solution-focused), Clear (direct, jargon-free), Confident (assured without arrogance). Tone shifts by context: engaging for marketing, instructional for docs, calm for errors, brief for success." ;
    oc:hasRationale "Consistent voice and context-appropriate tone builds brand trust and recognition" ;
    oc:severityLevel "HIGH" .

