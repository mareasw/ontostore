                                    oc:contentOrder 1 ;
                                    oc:rowCount 2 ;
                                    oc:tableCaption "### Contrast Ratios (WCAG 2.1)" ;
                                    oc:tableMarkdown """| Level | Normal Text | Large Text | UI Components |
|-------|-------------|------------|---------------|
| AA | 4.5:1 | 3:1 | 3:1 |
| AAA | 7:1 | 4.5:1 | 4.5:1 |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Contrast Ratios (WCAG 2.1)" ] ;
