oc:kn_0f25031b a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When extracting color definitions from brand guidelines" ;
    oc:directiveContent "1. Parse markdown tables for hex values 2. Extract CSS variable definitions 3. Capture color names and usage descriptions" ;
    oc:stepOrder 2 .

oc:kn_13ae6681 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing text and semantic colors" ;
    oc:directiveContent "Never use pure black (#000) for text — use near-black like #111827 instead. Never rely solely on color to convey meaning — pair with icons or text." ;
    oc:hasRationale "Pure black creates excessive contrast causing eye strain; color-only cues exclude colorblind users" ;
    oc:severityLevel "HIGH" .

oc:kn_21beceb4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting or validating any text/background color combination" ;
    oc:directiveContent "WCAG 2.1 AA requires 4.5:1 contrast for normal text, 3:1 for large text and UI components. AAA requires 7:1 for normal text, 4.5:1 for large text." ;
    oc:hasRationale "Ensures readability and accessibility for users with visual impairments; legal requirement in many jurisdictions" ;
    oc:severityLevel "CRITICAL" .

oc:kn_5075ad00 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing colors in production UI" ;
    oc:directiveContent "Maintain consistent hover/active states. Document all color decisions. Test all color combinations for accessibility before shipping." ;
    oc:hasRationale "Consistent interactive states and documented decisions reduce regressions and team misalignment" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7d16935a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining a new brand color palette" ;
    oc:directiveContent "Use 1-2 primary colors, 2-3 secondary colors, 3-5 neutrals, and 4 semantic colors. Keep maximum 2-3 colors per single component." ;
    oc:hasRationale "Prevents visual overload and maintains cohesive brand identity across all touchpoints" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a3c53ab0 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating brand compliance validation output" ;
    oc:directiveContent "{\"compliance\": {score}, \"colors\": {\"brand\": [...hex], \"offBrand\": [...hex], \"dominant\": \"{hex}\"}, \"issues\": [\"{description}\"]}" ;
    oc:templateVariables "brand_colors",
        "dominant",
        "issues",
        "offBrand_colors",
        "score" .

oc:kn_abbcb8c8 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When programmatically checking WCAG contrast ratios between two colors" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """function luminance(r, g, b) {
  const [rs, gs, bs] = [r, g, b].map(v => {
    v /= 255;
    return v <= 0.03928 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4);
  });
  return 0.2126 * rs + 0.7152 * gs + 0.0722 * bs;
}
function contrastRatio(l1, l2) {
  const lighter = Math.max(l1, l2);
  const darker = Math.min(l1, l2);
  return (lighter + 0.05) / (darker + 0.05);
}""" ;
    oc:hasRationale "Implements the W3C relative luminance formula for accurate accessibility compliance checking" .

oc:kn_c38652c0 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining CSS custom properties for a brand color system" ;
    oc:codeLanguage "css" ;
    oc:directiveContent """:root {
  --color-primary: #2563EB;
  --color-primary-light: #3B82F6;
  --color-primary-dark: #1D4ED8;
  --color-secondary: #8B5CF6;
  --color-accent: #F59E0B;
  --color-background: #FFFFFF;
  --color-surface: #F9FAFB;
  --color-text-primary: #111827;
  --color-text-secondary: #6B7280;
  --color-border: #E5E7EB;
}""" ;
    oc:hasRationale "CSS variables enable consistent color usage across an entire codebase and simplify theming" .

oc:kn_d610e154 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating brand compliance" ;
    oc:directiveContent "Primary color must cover 60-70% of design, secondary 20-30%, accent 5-10%. Maximum 20% non-palette color tolerance." ;
    oc:hasRationale "Enforces visual consistency and brand recognition through controlled color distribution" ;
    oc:severityLevel "HIGH" .

oc:kn_f0b2fb0d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When extracting brand colors from images" ;
    oc:directiveContent "1. Load image file 2. Extract dominant colors using k-means clustering 3. Map to nearest brand colors 4. Report compliance percentage" ;
    oc:stepOrder 1 .

