oc:kn_168173cf a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When user provides a theme/preset name as argument" ;
    oc:directiveContent "If user specifies a recognized preset name (ocean-professional, electric-creative, forest-calm, midnight-purple, sunset-warm), apply the preset's predefined colors without asking for individual values" ;
    oc:hasRationale "Presets accelerate common brand changes and ensure well-tested color combinations" ;
    oc:severityLevel "MEDIUM" .

oc:kn_227d5d42 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing brand update" ;
    oc:directiveContent "1. Gather brand input (theme name, primary/secondary/accent colors with hex codes, brand mood keywords). 2. Edit docs/brand-guidelines.md (Quick Reference table, Brand Concept, Color Palette sections, AI Image Generation). 3. Run sync-brand-to-tokens.cjs to propagate to design-tokens.json and design-tokens.css. 4. Verify sync with inject-brand-context.cjs --json and grep on CSS. 5. Output summary report." ;
    oc:stepOrder 1 .

oc:kn_36649d91 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Final report after successful brand update" ;
    oc:directiveContent """- Theme: {name}
- Primary: {name} ({hex})
- Secondary: {name} ({hex})
- Accent: {name} ({hex})
- Files updated: brand-guidelines.md, design-tokens.json, design-tokens.css""" ;
    oc:templateVariables "hex",
        "name" .

oc:kn_402e703a a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing brand update workflow" ;
    oc:directiveContent "Run inject-brand-context.cjs --json after update to confirm extracted colors match what was written" ;
    oc:hasRationale "Verifies the round-trip: guidelines → extraction → tokens are consistent" ;
    oc:severityLevel "HIGH" .

oc:kn_41040a5f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After any brand color or style change" ;
    oc:directiveContent "Always sync all three files (brand-guidelines.md, design-tokens.json, design-tokens.css) — never update just brand-guidelines.md alone" ;
    oc:hasRationale "Partial updates break the design token pipeline and cause UI components to display outdated colors" ;
    oc:severityLevel "CRITICAL" .

oc:kn_501e6d32 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "After editing brand-guidelines.md to propagate changes to tokens and CSS" ;
    oc:directiveContent "node .claude/skills/brand/scripts/sync-brand-to-tokens.cjs" .

oc:kn_6ed808cf a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Quick verification that CSS variables were regenerated correctly" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "grep \"primary\" assets/design-tokens.css | head -5" .

oc:kn_e411f6dd a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Every execution" ;
    oc:directiveContent "Modifies docs/brand-guidelines.md, assets/design-tokens.json, and assets/design-tokens.css; regenerates CSS variables from token definitions" ;
    oc:hasRationale "Agents and users must be aware of which files are modified to avoid uncommitted changes conflicts" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fbd5f891 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "To verify brand context extraction after update" ;
    oc:directiveContent "node .claude/skills/brand/scripts/inject-brand-context.cjs --json | head -30" .

