oc:kn_1466873c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When drafting any brand message or positioning statement" ;
    oc:directiveContent "Never write messages that are jargon-heavy, unprovable, or indistinguishable from competitor messaging" ;
    oc:hasRationale "These are the three most common messaging failures that destroy credibility and differentiation" ;
    oc:severityLevel "CRITICAL" .

oc:kn_23a34eea a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When creating elevator pitches as part of messaging" ;
    oc:directiveContent "Always provide 3 elevator pitches at 10-second (one sentence), 30-second (problem + solution + differentiation), and 60-second (full pitch with proof points) lengths" ;
    oc:hasRationale "Different contexts require different levels of detail; having all three ready ensures readiness for any situation" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3f66c162 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When mapping messages to audience segments" ;
    oc:directiveContent """| Audience | Pain Point | Key Message | CTA |
|----------|------------|-------------|-----|
| [Segment] | [Pain] | [Message] | [Action] |""" ;
    oc:hasRationale "Every audience segment needs a tailored message tied to their specific pain point with a clear call to action" ;
    oc:templateVariables "Action",
        "Message",
        "Pain",
        "Segment" .

oc:kn_47a9b772 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When developing key supporting messages" ;
    oc:directiveContent "Supporting messages must be limited to 3-5, each addressing a different benefit or audience need with a corresponding proof point" ;
    oc:hasRationale "Too many messages dilute focus; too few leave gaps. 3-5 is the optimal range for clarity and coverage" ;
    oc:severityLevel "HIGH" .

oc:kn_8168951e a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing a value proposition" ;
    oc:directiveContent "For [target customer] who [need/problem], [Product/Brand] is a [category] that [key benefit]. Unlike [competitors], we [unique differentiator]." ;
    oc:hasRationale "This template ensures all critical elements—audience, need, category, benefit, and differentiation—are addressed in every value proposition" .

oc:kn_a1cb6893 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing a mission statement" ;
    oc:directiveContent "We [action] for [audience] by [method] so they can [outcome]." ;
    oc:hasRationale "Forces clarity on who, how, and why—eliminating vague aspirational language" .

oc:kn_a4bd5a5e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating any message or positioning statement" ;
    oc:directiveContent "Messages must pass 5 tests: Clear (no jargon), Differentiated (competitors can't say it), Credible (provable), Compelling (audience cares), Consistent (aligns with brand)" ;
    oc:hasRationale "Messages that fail any of these tests will lack impact or authenticity" .

oc:kn_ccd07766 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When building a messaging framework from scratch" ;
    oc:directiveContent "1. Define Mission (why we exist) → 2. Define Vision (where we're going) → 3. Craft Value Proposition (what we offer) → 4. Write Positioning Statement (how we're different) → 5. Develop Key Messages (what we say) → 6. Attach Proof Points (why to believe)" ;
    oc:hasRationale "Messaging must flow from purpose (mission) through differentiation (positioning) to tactical messages, ensuring hierarchical consistency" ;
    oc:stepOrder 1 .

_:ref_1c29505c8f4312b3 a oc:WorkflowStep ;
    dcterms:description "Is it differentiated? (Competitors can't say it)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_46e25b591f5c25fb a oc:WorkflowStep ;
    dcterms:description "Is it consistent? (Aligns with brand)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_5a4fdfb46a6716f9 a oc:WorkflowStep ;
    dcterms:description "Is it credible? (Can we prove it)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_8c780af7ffff9f1e a oc:WorkflowStep ;
    dcterms:description "Is it compelling? (Does audience care)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_de2af7021eeb37fe a oc:WorkflowStep ;
    dcterms:description "Is it clear? (No jargon)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_3146487fe941ddc0 a oc:WorkflowStep ;
    dcterms:description "Write Positioning Statement defining category, audience, outcome, and reason to believe" ;
    oc:expectedOutcome "Clear statement of how the brand is different in its category" ;
    oc:stepDependsOn _:ref_9aacadfe6ad934a4 ;
    oc:stepId "write-positioning" .

_:ref_34f67f1091f69db3 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_1c29505c8f4312b3,
        _:ref_46e25b591f5c25fb,
        _:ref_5a4fdfb46a6716f9,
        _:ref_8c780af7ffff9f1e,
        _:ref_de2af7021eeb37fe ;
    oc:workflowId "procedure_1" ;
    oc:workflowName "Ordered Procedure" .

_:ref_469f6d2490538675 a oc:WorkflowStep ;
    dcterms:description "Define Vision Statement expressing aspirational world-state" ;
    oc:expectedOutcome "Clear articulation of where the brand is going" ;
    oc:stepDependsOn _:ref_837413233a9b77ec ;
    oc:stepId "define-vision" .

_:ref_68e4e8c13632e91a a oc:WorkflowStep ;
    dcterms:description "Map tailored messages to each audience segment with pain points and CTAs" ;
    oc:expectedOutcome "Audience-specific message matrix ready for use" ;
    oc:stepDependsOn _:ref_049c62d6bbfb1b79 ;
    oc:stepId "map-audience-messages" .

_:ref_837413233a9b77ec a oc:WorkflowStep ;
    dcterms:description "Define Mission Statement using the action/audience/method/outcome template" ;
    oc:expectedOutcome "Clear articulation of why the brand exists" ;
    oc:stepId "define-mission" .

_:ref_9aacadfe6ad934a4 a oc:WorkflowStep ;
    dcterms:description "Craft Value Proposition using the target customer/need/category/benefit/differentiator template" ;
    oc:expectedOutcome "Compelling statement of what the brand offers and why it's unique" ;
    oc:stepDependsOn _:ref_469f6d2490538675 ;
    oc:stepId "craft-value-prop" .

_:ref_e81fa803c4a9311e a oc:WorkflowStep ;
    dcterms:description "Create 10-second, 30-second, and 60-second elevator pitches" ;
    oc:expectedOutcome "Three ready-to-use elevator pitches at different depths" ;
    oc:stepDependsOn _:ref_049c62d6bbfb1b79 ;
    oc:stepId "create-pitches" .

_:ref_049c62d6bbfb1b79 a oc:WorkflowStep ;
    dcterms:description "Develop primary message and 3-5 supporting messages mapped to audience needs with proof points" ;
    oc:expectedOutcome "Complete message architecture with evidence" ;
    oc:stepDependsOn _:ref_3146487fe941ddc0 ;
    oc:stepId "develop-key-messages" .

