                                    oc:blockType "code_block" ;
                                    oc:codeContent """Primary Colors (1-2)
├── Main brand color
└── Supporting primary

Secondary Colors (2-3)
├── Accent colors
└── Supporting visuals

Neutrals (3-4)
├── Text colors
├── Background colors
└── UI elements
""" ;
                                    oc:codeLanguage "" ;
