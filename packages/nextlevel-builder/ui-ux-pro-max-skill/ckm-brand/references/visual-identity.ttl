oc:kn_01b63eba a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating a visual identity style guide document" ;
    oc:directiveContent """## Logo Usage
- Correct usage guidelines
- Incorrect usage (no stretch, no recolor, no effects, no busy backgrounds)

## Color Specifications
### Primary Palette
| Color | Hex | RGB | Usage |
### Accessibility (4.5:1 contrast, WCAG AA)

## Imagery Style
### Photography (lighting, subject, composition, editing)
### Illustrations (style, color, complexity)
### Icons (style, stroke weight, corner radius)""" ;
    oc:templateVariables "Color",
        "Hex",
        "RGB",
        "Usage",
        "composition",
        "corner radius",
        "editing",
        "lighting",
        "stroke weight",
        "style",
        "subject" .

oc:kn_0dde2fbb a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating a visual identity system from scratch" ;
    oc:directiveContent "1. Define logo variants (primary, secondary, icon/mark) with clear space and minimum size rules. 2. Build color palette: 1-2 primary, 2-3 secondary, 3-4 neutrals with hex/RGB specs and usage guidance. 3. Set typography scale with usage-to-font-weight-size mapping. 4. Specify imagery style (photography, illustration, icon conventions). 5. Validate all elements against accessibility and quick-check criteria." ;
    oc:hasRationale "This sequence ensures foundational elements are defined before derived guidelines, and validated before use." ;
    oc:stepOrder 1 .

oc:kn_20bac087 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Whenever placing a logo on any material" ;
    oc:directiveContent "Never stretch, distort, recolor, add effects to, or place logos on busy backgrounds. Logo clear space and minimum size requirements must always be respected." ;
    oc:hasRationale "Logo misuse degrades brand recognition and can violate trademark protections." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3e620b1c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before delivering any branded output" ;
    oc:directiveContent "Use the Quick Checks checklist (logo correctness, color palette compliance, typography hierarchy) before finalizing any branded material." ;
    oc:hasRationale "Systematic checks catch common visual identity violations that erode brand consistency over time." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b25a1b5e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting colors for text and interactive elements" ;
    oc:directiveContent "Text contrast ratio must be at least 4.5:1 and buttons must be WCAG AA compliant." ;
    oc:hasRationale "Insufficient contrast excludes users with visual impairments and may violate accessibility regulations." ;
    oc:severityLevel "HIGH" .

oc:kn_bd632ee4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining or auditing any brand's visual identity" ;
    oc:directiveContent "A complete visual identity requires three core elements: logo system (primary/secondary/icon), color palette (primary 1-2, secondary 2-3, neutrals 3-4), and typography scale (H1 through caption with defined weights and sizes)." ;
    oc:hasRationale "These three elements form the minimum viable visual identity system; omitting any creates inconsistency across brand touchpoints." ;
    oc:severityLevel "HIGH" .

