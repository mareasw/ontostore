oc:kn_0013cc2b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing color compliance of any asset" ;
    oc:directiveContent "Primary/secondary color ratio must follow 60/30/10 distribution using brand palette colors only." ;
    oc:hasRationale "Maintains visual hierarchy and brand consistency across all marketing materials" ;
    oc:severityLevel "HIGH" .

oc:kn_05def2c2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning any asset review" ;
    oc:directiveContent "Run the quick review (purpose, audience, errors, campaign alignment) before detailed section-by-section review." ;
    oc:hasRationale "Catches fundamental misalignments early, saving time on detailed reviews of fundamentally flawed assets" .

oc:kn_50abdfca a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When auto-checking asset compliance for color palette, dimensions, format, size, naming, and metadata" ;
    oc:directiveContent "node .claude/skills/brand/scripts/validate-asset.cjs <asset-path>" .

oc:kn_55ee9944 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When beginning asset validation" ;
    oc:directiveContent "Before full manual review, run `node .claude/skills/brand/scripts/validate-asset.cjs <asset-path>` to auto-check color palette compliance, minimum dimensions, file format/size, naming convention, and basic metadata." ;
    oc:hasRationale "Automated pre-checks catch mechanical issues before human review focuses on subjective quality" .

oc:kn_855dade2 a oc:KnowledgeNode,
        oc:SecurityImplication ;
    oc:appliesToContext "When reviewing intellectual property compliance" ;
    oc:directiveContent "Verify stock images are licensed, music/audio is cleared, no trademark violations exist, user content is authorized, and credits are included where needed." ;
    oc:hasRationale "IP violations can result in legal liability, takedown demands, and reputational damage" ;
    oc:severityLevel "CRITICAL" .

oc:kn_94be876e a oc:KnowledgeNode,
