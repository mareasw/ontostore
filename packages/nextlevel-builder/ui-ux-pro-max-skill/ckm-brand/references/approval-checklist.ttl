| Copy/Content | {name} | {date} | Pass / Revisions |
| Brand Compliance | {name} | {date} | Pass / Revisions |
| Technical | {name} | {date} | Pass / Revisions |
| Legal | {name} | {date} | Pass / Revisions |

**Approved By:** {approver}
**Date:** {date}
**Version:** {version}""" ;
    oc:templateVariables "approver",
        "date",
        "name",
        "version" .

oc:kn_9b829cf2 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a review fails on specific criteria" ;
    oc:directiveContent "Common issues have prescribed fixes: logo too small → increase to minimum size; wrong font → replace with brand font; low contrast → adjust colors; off-brand color → replace with palette color; blurry image → use higher resolution source." ;
    oc:hasRationale "Standardized fixes ensure consistency and speed up revision cycles" .

oc:kn_cf075d6e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing or reviewing interactive elements and status indicators" ;
    oc:directiveContent "Never use color as the sole indicator of meaning; always provide a secondary visual cue." ;
    oc:hasRationale "Color-blind users cannot perceive information conveyed only through color" ;
    oc:severityLevel "HIGH" .

oc:kn_dd4e1d1e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When checking visual accessibility of any asset" ;
    oc:directiveContent "Text contrast ratio must be >= 4.5:1 (AA) for normal text and >= 3:1 for large text." ;
    oc:hasRationale "WCAG AA compliance ensures readability for users with visual impairments" ;
    oc:severityLevel "CRITICAL" .

oc:kn_df598fac a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When determining final approval readiness" ;
    oc:directiveContent "All five review areas (Visual Design, Copy/Content, Brand Compliance, Technical, Legal) must show 'Pass' status with reviewer sign-off." ;
    oc:hasRationale "Multi-dimensional sign-off prevents assets from going live with overlooked issues in any domain" .

oc:kn_e7ad74ea a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing a complete asset approval review" ;
    oc:directiveContent "1. Run quick review (purpose, audience, errors, campaign fit) 2. Check visual elements (logo, color, typography, imagery) 3. Verify accessibility (contrast, alt text, reading order) 4. Review content quality (brand voice, messaging, CTA) 5. Validate technical specs (format, resolution, platform requirements) 6. Confirm legal/compliance (IP, regulatory) 7. Obtain reviewer sign-off for each area 8. Run automation script 9. Archive approved asset" ;
    oc:stepOrder 1 .

oc:kn_f2bb4a16 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "When an asset passes all review areas" ;
    oc:directiveContent "After approval: update asset status in manifest.json, add approver and timestamp, move previous versions to archive, update campaign tracking, notify relevant teams." ;
    oc:hasRationale "Proper archival maintains audit trail, prevents use of outdated assets, and keeps teams synchronized" .

