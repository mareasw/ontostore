    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Full brand consistency audit covering visual identity, voice, and all channels" ;
            oc:hasStep _:ref_73ae37559e5f097b,
                _:ref_82de6d66742b8a58,
                _:ref_9aa86aaa0094ec5d,
                [ a oc:WorkflowStep ;
                    dcterms:description "Schedule next audit based on asset type frequency table" ;
