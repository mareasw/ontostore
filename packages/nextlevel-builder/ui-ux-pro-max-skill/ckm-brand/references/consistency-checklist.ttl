    oc:impartsKnowledge oc:kn_2a9f3d38,
        oc:kn_44ac8027,
        oc:kn_54f21f5b,
        oc:kn_62f49744,
        oc:kn_83fb363c,
        oc:kn_e017f0be,
        oc:kn_e3c20846 ;
    oc:isUserInvocable true ;
    oc:nature "Checklist" ;
    oc:requiresState oc:BrandStyleGuideAvailable ;
    oc:resolvesIntent "audit brand consistency",
        "check voice and messaging consistency",
        "identify brand inconsistency issues",
        "perform channel-level brand audit",
        "verify visual brand compliance" ;
    oc:yieldsState oc:BrandAuditComplete,
        oc:InconsistenciesDocumented .

oc:kn_2a9f3d38 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any brand consistency audit" ;
    oc:directiveContent "Verify that a current brand style guide (logo versions, color palette, typography specs, voice guidelines) is available before starting the audit" ;
    oc:hasRationale "Without an authoritative reference, the audit has no baseline to measure against" ;
    oc:severityLevel "CRITICAL" .

oc:kn_44ac8027 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing a full brand consistency audit" ;
    oc:directiveContent "1. Audit visual consistency (logo, colors, typography, imagery) 2. Audit voice consistency (tone, language, messaging) 3. Run channel audit (website, social, email, collateral) 4. Cross-reference issues against common fixes table 5. Schedule follow-up per audit frequency table" ;
    oc:hasRationale "Structured top-down audit ensures no brand touchpoint is overlooked" ;
    oc:stepOrder 1 .

oc:kn_54f21f5b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When auditing brand voice" ;
    oc:directiveContent "Tone, language, and messaging must be verified for consistency across all active channels simultaneously, not in isolation" ;
    oc:hasRationale "Voice inconsistency across channels creates disjointed customer experience" ;
    oc:severityLevel "HIGH" .

oc:kn_62f49744 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When validating any visual brand asset" ;
    oc:directiveContent "Logo, colors, typography, and imagery must each pass all sub-checks before any asset is considered brand-compliant" ;
    oc:hasRationale "A single visual inconsistency undermines overall brand perception" ;
    oc:severityLevel "HIGH" .

oc:kn_83fb363c a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When a brand consistency issue is identified" ;
    oc:directiveContent "For outdated logos → replace with current version; off-brand colors → update to palette; wrong fonts → replace with brand font; inconsistent voice → apply style guide; mixed messaging → align to framework" ;
    oc:hasRationale "Pre-mapped fixes enable rapid correction without revisiting brand guidelines from scratch" .

oc:kn_e017f0be a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing brand consistency fixes" ;
    oc:directiveContent "After audit, confirm all checklist items are resolved and re-check any assets that were modified during the audit" ;
    oc:hasRationale "Modifications can introduce new inconsistencies; re-validation ensures complete compliance" .

oc:kn_e3c20846 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scheduling brand consistency reviews" ;
    oc:directiveContent "Audit websites monthly, social profiles and email templates quarterly, and perform a full brand audit annually" ;
    oc:hasRationale "Higher-frequency audit for frequently changing assets prevents drift; annual full audit catches systemic issues" .

_:ref_73ae37559e5f097b a oc:WorkflowStep ;
    dcterms:description "Audit all channels: website, social media, email, and collateral for brand compliance" ;
    oc:expectedOutcome "Each channel passes all relevant checklist items" ;
    oc:stepDependsOn _:ref_82de6d66742b8a58,
        _:ref_9aa86aaa0094ec5d ;
    oc:stepId "channel-audit" .

_:ref_82de6d66742b8a58 a oc:WorkflowStep ;
    dcterms:description "Audit voice consistency: check tone alignment, language standards, and messaging coherence" ;
    oc:expectedOutcome "Voice and messaging confirmed consistent or issues documented" ;
    oc:stepId "voice-audit" .

_:ref_9aa86aaa0094ec5d a oc:WorkflowStep ;
    dcterms:description "Audit visual consistency: verify logo usage, color palette compliance, typography adherence, and imagery standards" ;
    oc:expectedOutcome "All visual elements confirmed brand-compliant or issues documented" ;
    oc:stepId "visual-audit" .

_:ref_eb03be3ff2a74705 a oc:WorkflowStep ;
    dcterms:description "Cross-reference identified issues against common fixes table and apply corrections" ;
    oc:expectedOutcome "All identified issues resolved with documented fixes" ;
    oc:stepDependsOn _:ref_73ae37559e5f097b ;
    oc:stepId "issue-resolution" .

