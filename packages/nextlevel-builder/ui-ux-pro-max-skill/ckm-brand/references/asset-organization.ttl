oc:kn_18b6ee38 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When cleaning up or reorganizing assets" ;
    oc:directiveContent "Never delete assets — always archive to archived/ with a date prefix. Never combine variants (e.g., dark/light) in a single file." ;
    oc:hasRationale "Deletion destroys audit history and makes rollback impossible; combined variants break automated workflows" ;
    oc:severityLevel "CRITICAL" .

oc:kn_2c6f0013 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When organizing any new or existing marketing asset" ;
    oc:directiveContent "1. One file per variant — separate dark/light modes into individual files. 2. Keep source files (.psd/.fig) in same directory structure. 3. Auto-organize AI-generated assets by generation date (YYYYMMDD). 4. Archive outdated assets to archived/ with date prefix instead of deleting. 5. Store videos >100MB via cloud storage links rather than locally." ;
    oc:hasRationale "Consistent file organization prevents asset loss, simplifies search, and keeps repositories clean" ;
    oc:stepOrder 1 .

oc:kn_40b34f18 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When tagging assets in manifest.json or tags.json" ;
    oc:directiveContent "Each asset must be tagged with at minimum: status + platform + content-type. Optional tags: format, source, campaign." ;
    oc:hasRationale "Minimum tag coverage ensures assets are discoverable via all primary dimensions" ;
    oc:severityLevel "HIGH" .

oc:kn_86e158db a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming any asset file" ;
    oc:directiveContent "Asset filename must follow format: {type}_{campaign}_{description}_{timestamp}_{variant}.{ext}. Use 'evergreen' as campaign for non-campaign assets." ;
    oc:hasRationale "Deterministic naming enables automated search and prevents filename collisions" ;
    oc:severityLevel "HIGH" .

oc:kn_9497339d a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When recording any asset in the system" ;
    oc:directiveContent "Store asset metadata centrally in .assets/manifest.json with full schema (id, name, type, path, dimensions, fileSize, mimeType, tags, status, source, version, createdBy, approvedBy, approvedAt). Track version history in .assets/versions/{asset-id}/v{n}.json." ;
    oc:hasRationale "Centralized metadata with versioning enables audit trails, deduplication, and programmatic asset queries" ;
    oc:severityLevel "MEDIUM" .

oc:kn_9a0d7502 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When running periodic asset cleanup" ;
    oc:directiveContent "1. Run extract-colors.cjs on new assets. 2. Validate against brand guidelines. 3. Update manifest.json with new entries. 4. Tag appropriately (status + platform + content-type required). 5. Remove duplicates/outdated versions." ;
    oc:hasRationale "Ensures assets remain brand-compliant and the manifest stays accurate" ;
    oc:stepOrder 2 .

oc:kn_a407b11e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up a new project's asset system" ;
    oc:directiveContent "Use a two-tier directory structure: .assets/ for Git-tracked metadata (manifest, tags, versions) and assets/ for raw files, organized by type then purpose." ;
    oc:hasRationale "Separating metadata from raw files allows Git to track changes efficiently without bloating the repository with large binaries" .

oc:kn_aab53772 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When searching for assets by status or other metadata fields" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent "jq '.assets[] | select(.status == \"approved\")' .assets/manifest.json" .

oc:kn_fbac85f4 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When naming any asset file" ;
    oc:directiveContent "{type}_{campaign}_{description}_{timestamp}_{variant}.{ext}" ;
    oc:templateVariables "campaign",
        "description",
        "ext",
        "timestamp",
        "type",
        "variant" .

