oc:kn_13413777 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying logo usage rules" ;
    oc:directiveContent "Never rotate, skew, recolor outside approved palette, add effects (shadows/gradients), crop, or modify logo proportions." ;
    oc:hasRationale "Logo misuse dilutes brand recognition and undermines visual identity consistency." ;
    oc:severityLevel "HIGH" .

oc:kn_37957ed0 a oc:DataProvenance,
        oc:KnowledgeNode ;
    oc:appliesToContext "When integrating brand guidelines with design systems or automated tooling" ;
    oc:directiveContent "Extractable fields include: colors.primary, colors.secondary, colors.neutral, typography.heading, typography.body, voice.traits, voice.prohibited, logo.variants, logo.minSize — these can be parsed programmatically from the filled template." ;
    oc:hasRationale "Machine-readable field names enable integration with design token pipelines and component libraries." .

oc:kn_6724e334 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When initiating a new brand guidelines document" ;
    oc:directiveContent "1. Copy the brand guidelines template. 2. Fill in brand-specific values for colors, fonts, voice traits, and logo specs. 3. Save as docs/brand-guidelines.md. 4. Reference in content workflows." ;
    oc:hasRationale "Following a repeatable process ensures consistency and discoverability of brand assets across projects." ;
    oc:stepOrder 1 .

oc:kn_88b57b0d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining the font stack for brand typography in CSS custom properties" ;
    oc:codeLanguage "css" ;
    oc:directiveContent """--font-heading: '{Font}', sans-serif;
--font-body: '{Font}', sans-serif;
--font-mono: '{Font}', monospace;""" .

oc:kn_98132308 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining color palettes and accessibility standards" ;
    oc:directiveContent "All interactive elements must meet WCAG 2.1 AA contrast ratios. Document text/background contrast and CTA contrast ratios explicitly." ;
    oc:hasRationale "Accessibility compliance is a legal requirement in many jurisdictions and ensures brand inclusivity." ;
    oc:severityLevel "CRITICAL" .

oc:kn_99b0f3ae a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When assembling the final brand guidelines document" ;
    oc:directiveContent "Brand guidelines should be structured as: 1) Quick Reference summary, 2) Color Palette (primary/secondary/neutral + accessibility), 3) Typography (font stack + type scale), 4) Logo Usage (variants/clear space/minimum size/don'ts), 5) Voice & Tone (personality/voice chart/tone by context/prohibited terms), 6) Imagery Guidelines (photography/illustrations/icons)." ;
    oc:hasRationale "This structure enables both quick reference and deep lookup, supporting designers and developers alike." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ae4afb24 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating any brand guidelines document" ;
    oc:directiveContent "Brand guidelines must cover five core sections: Color Palette, Typography, Logo Usage, Voice & Tone, and Imagery Guidelines to be considered comprehensive." ;
    oc:hasRationale "These five sections represent the minimum viable set of brand identity artifacts that ensure consistency across all touchpoints." ;
    oc:severityLevel "HIGH" .

oc:kn_be2a3768 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before using this template" ;
    oc:directiveContent "Brand identity decisions (primary/secondary colors, font selections, logo variants, voice traits) must be finalized before filling the template." ;
    oc:hasRationale "This template is a documentation scaffold, not a brand strategy tool. It captures decisions, it doesn't make them." .

oc:kn_dd6eeaad a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When establishing voice and tone guidelines" ;
    oc:directiveContent "Define brand voice with exactly 3 key traits, each with a 'We Are' and 'We Are Not' description, plus tone variations for at least 4 contexts (Marketing, Support, Error Messages, Success)." ;
    oc:hasRationale "A structured voice chart with positive/negative boundaries gives content creators clear guardrails while preserving brand flexibility." ;
    oc:severityLevel "MEDIUM" .

