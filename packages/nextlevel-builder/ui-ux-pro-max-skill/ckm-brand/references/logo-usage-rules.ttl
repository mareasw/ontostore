    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:BrandAssetsAvailable ;
    oc:resolvesIntent "apply logo correctly across materials",
        "ensure logo meets minimum size and clear space requirements",
        "implement co-branding layouts",
        "select appropriate logo variant for a context",
        "validate logo usage compliance" ;
    oc:yieldsState oc:LogoUsageValidated .

oc:kn_12088fc6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When sizing or positioning the logo in any layout" ;
    oc:directiveContent "Clear space around the logo must equal the height of the logo mark (icon portion) on all sides. Minimum sizes: Full Logo 120px digital / 35mm print; Icon Only 24px digital / 10mm print." ;
    oc:hasRationale "Insufficient clear space or undersized logos reduce legibility and brand recognition." ;
    oc:severityLevel "HIGH" .

oc:kn_7835fb4e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When placing any logo variant in any medium" ;
    oc:directiveContent "Never stretch, compress, rotate, add effects (shadows/gradients/transparency), use unapproved colors, add strokes/outlines, place on busy backgrounds, crop, rearrange elements, or add additional elements to the logo." ;
    oc:hasRationale "Any of these modifications compromise brand recognition and violate brand integrity standards." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8355d726 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When organizing or locating logo asset files" ;
    oc:directiveContent "assets/logos/ → full-horizontal/ (full-color.svg, full-color.png, reversed.svg, mono-dark.svg, mono-light.svg) → icon-only/ (full-color.svg, reversed.svg, favicon.ico) → monochrome/ (black.svg, white.svg)" ;
    oc:hasRationale "Consistent file naming and organization ensures correct variant selection across teams and tools." ;
    oc:severityLevel "MEDIUM" .

oc:kn_87845069 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When referencing, requesting, or generating logo files" ;
    oc:directiveContent "File naming convention: logo-{variant}-{color}.{ext} where variant=[full-horizontal|stacked|icon|wordmark] and color=[full-color|reversed|mono-dark|mono-light]. Formats: SVG (preferred web), PNG (fallback/documents), PDF/EPS (print)." ;
    oc:hasRationale "Standardized naming enables programmatic logo selection and prevents wrong-variant usage." .

oc:kn_89320425 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting logo color variant for a background" ;
    oc:directiveContent "Use Full Color on white/light backgrounds, Reversed (white) on dark/brand-primary backgrounds, Monochrome Dark on light when color unavailable, Monochrome Light on dark when color unavailable." ;
    oc:hasRationale "Correct color variant selection ensures sufficient contrast and brand consistency across all contexts." .

oc:kn_8a0f1ff6 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Before using any logo in production materials" ;
    oc:directiveContent "1. Verify you have the correct logo version 2. Check background compatibility 3. Ensure minimum size requirements 4. Confirm clear space allocation 5. Review against brand guidelines" ;
    oc:hasRationale "Systematic pre-flight validation prevents brand guideline violations before publication." ;
    oc:severityLevel "HIGH" ;
    oc:stepOrder 1 .

oc:kn_de0d2b11 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When placing partner logos alongside the brand logo" ;
    oc:directiveContent "For co-branding: equal visual weight (same height), adequate separation, optional divider line, both logos in approved colors, clear space applies to both." ;
    oc:hasRationale "Equal treatment maintains brand equity while respecting partner brands." ;
    oc:severityLevel "MEDIUM" .

