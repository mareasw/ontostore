oc:kn_0b772989 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing a design system's typography in code" ;
    oc:codeLanguage "css" ;
    oc:directiveContent "Define all typography tokens as CSS custom properties under :root (families, sizes, weights, line heights) and mirror them in Tailwind's theme config with fontSize entries that include lineHeight tuples." ;
    oc:hasRationale "Single-source token definitions ensure consistency across CSS and utility-class workflows" .

oc:kn_269c90a1 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When establishing a type scale or setting line heights" ;
    oc:directiveContent "Use a 1.25 Major Third scale ratio from a 16px (1rem) base. Headings use tighter line heights (1.1-1.3) for visual impact; body text uses 1.5-1.6 for optimal readability; long-form uses 1.6-1.75." ;
    oc:hasRationale "A consistent mathematical scale creates visual harmony and hierarchy across all text elements" .

oc:kn_5412baed a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting any font sizes or color combinations" ;
    oc:directiveContent "Body text minimum 16px, small text minimum 14px (not for long content), caption minimum 12px (use sparingly). Text-on-background contrast must be 4.5:1 (AA), large text (18px+) at least 3:1." ;
    oc:hasRationale "Ensures WCAG AA accessibility compliance and readability for all users" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9a6e5711 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling paragraph and body text content" ;
    oc:directiveContent "Do not use all caps for long text, avoid justified text (use left-align), do not use thin weights (<400) at small sizes, and limit body text to 65-75 characters per line (max-width: 65ch)." ;
    oc:hasRationale "These practices degrade readability and cause uneven spacing that fatigues readers" ;
    oc:severityLevel "HIGH" .

oc:kn_eb9f5603 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When fine-tuning letter spacing across different text treatments" ;
    oc:directiveContent "Use letter-spacing of -0.02em for display text, 0 for headings and body, 0.05em for all-caps text, and 0.1em for small-caps text." ;
    oc:hasRationale "Proper tracking compensates for optical spacing differences at various sizes and styles" .

