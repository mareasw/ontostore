oc:kn_0acc8318 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "After running brand update or sync operations" ;
    oc:directiveContent "After any brand update, run inject-brand-context.cjs --json to verify extraction works correctly. Check that primary, secondary, and accent colors all appear." ;
    oc:hasRationale "Silent sync failures can propagate stale values to design tokens and CSS variables, causing downstream visual inconsistencies." ;
    oc:severityLevel "HIGH" .

oc:kn_1249ccf7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When developing brand voice framework" ;
    oc:directiveContent "Define 3-5 brand personality traits with positive descriptors paired against what the brand is NOT (e.g., 'Confident, not arrogant'). Create a voice chart mapping each trait to Do/Don't examples." ;
    oc:hasRationale "Negative definitions prevent common tone drift and give writers clear boundaries for brand-appropriate copy." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1f240e6b a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When creating messaging framework for a brand" ;
    oc:directiveContent "The messaging framework flows from Mission → Vision → Value Proposition → Positioning → Key Messages → Proof Points. Each layer builds on the one above." ;
    oc:hasRationale "This hierarchical structure ensures messages are rooted in the brand's purpose and differentiated positioning, not just feature lists." ;
    oc:severityLevel "MEDIUM" .

oc:kn_66724d70 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When placing logos in any asset or design" ;
    oc:directiveContent "Never stretch, rotate, skew, recolor, add effects to, or crop the logo. Only use approved color variants on appropriate backgrounds." ;
    oc:hasRationale "Logo misuse undermines brand recognition and can violate legal trademark protections." ;
    oc:severityLevel "HIGH" .

oc:kn_77ccaa69 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When defining or validating color combinations for text, buttons, and interactive elements" ;
    oc:directiveContent "All text must meet WCAG 2.1 AA contrast ratios: 4.5:1 for normal text, 3:1 for large text and UI components." ;
    oc:hasRationale "Accessibility compliance is legally required in many jurisdictions and ensures usability for all users." ;
    oc:severityLevel "CRITICAL" .

oc:kn_858073ee a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After running sync-brand-to-tokens.cjs" ;
    oc:directiveContent "Brand sync is successful when: (1) brand-guidelines.md has updated colors/typography, (2) design-tokens.json contains matching values, (3) design-tokens.css has correct CSS variables, (4) inject-brand-context.cjs --json outputs all updated values." ;
    oc:hasRationale "Multi-file verification catches partial sync failures before they propagate to production UI." ;
    oc:severityLevel "HIGH" .

oc:kn_e43b47ae a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or validating any brand visual asset" ;
    oc:directiveContent "Primary colors should cover 60-70% of design, secondary 20-30%, and accent 5-10%. Maximum 20% tolerance for non-palette colors." ;
    oc:hasRationale "Consistent color ratios create visual coherence and reinforce brand identity across all touchpoints." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f72d971d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running the brand update workflow" ;
    oc:directiveContent "Always sync all three files (brand-guidelines.md, design-tokens.json, design-tokens.css) when updating brand identity. Never update brand-guidelines.md alone." ;
    oc:hasRationale "Partial updates cause drift between the human-readable guidelines and the token definitions used by UI components." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fc49cd2a a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When creating or organizing any brand asset file" ;
    oc:directiveContent "Asset naming convention: {type}_{campaign}_{description}_{timestamp}_{variant}.{ext}. Use 'evergreen' for non-campaign assets. Archive outdated versions instead of deleting." ;
    oc:hasRationale "Consistent naming enables automated search, validation, and lifecycle management of brand assets at scale." ;
    oc:severityLevel "LOW" .

