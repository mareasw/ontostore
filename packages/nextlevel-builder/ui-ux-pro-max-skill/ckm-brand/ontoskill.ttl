_:ref_6657577ed8c121a0 a oc:WorkflowStep ;
    dcterms:description "Collect brand input: theme name, primary/secondary/accent colors (name + hex), brand mood keywords" ;
    oc:expectedOutcome "All brand color and mood parameters collected from user" ;
    oc:stepId "gather-input" .

_:ref_6f7f5f6345c3bf16 a oc:WorkflowStep ;
    dcterms:description "Check logo usage (correct variant, clear space, size), color compliance (palette-only, ratios), typography (brand fonts, hierarchy)" ;
    oc:expectedOutcome "Visual elements scored against brand guidelines" ;
    oc:stepId "visual-audit" .

_:ref_8ca051ef2bf19349 a oc:WorkflowStep ;
    dcterms:description "Run sync-brand-to-tokens.cjs to propagate changes to design-tokens.json and design-tokens.css" ;
    oc:expectedOutcome "Token definitions and CSS variables regenerated from updated guidelines" ;
    oc:stepDependsOn _:ref_937228287691bea8 ;
    oc:stepId "sync-tokens" .

_:ref_937228287691bea8 a oc:WorkflowStep ;
    dcterms:description "Edit docs/brand-guidelines.md: update Quick Reference, Brand Concept, Color Palette, and AI Image Generation sections" ;
    oc:expectedOutcome "Human-readable brand documentation updated with new values" ;
    oc:stepDependsOn _:ref_6657577ed8c121a0 ;
    oc:stepId "update-guidelines" .

