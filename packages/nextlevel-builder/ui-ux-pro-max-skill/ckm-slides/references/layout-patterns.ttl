oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_slides_layout_patterns a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "layout-patterns" ;
    skos:broader "Layout pattern library" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/nextlevel-builder/ui-ux-pro-max-skill/ckm-slides" ;
    oc:contentHash "0a967ca3bd829d3234e6f1802bade6c76447fabbaddbc8117c41adbae7dfb6df" ;
    oc:differentia "Provides 25 slide layouts with CSS structures, responsive breakpoints, animation classes, and component variants for HTML presentations" ;
    oc:extends oc:skill_nextlevel_builder_ui_ux_pro_max_skill_ckm_slides ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "slide use case or content type (e.g., \"metrics dashboard\", \"feature grid\", \"pricing cards\")" ;
    oc:hasCategory "design" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "25 slide layouts with CSS structures and animation classes." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """.slide-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}
@media (max-width: 768px) {
    .slide-features { grid-template-columns: repeat(2, 1fr); gap: 16px; }
}
@media (max-width: 480px) {
    .slide-features { grid-template-columns: 1fr; }
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 51-63" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Feature Grid (3 columns)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """.slide-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
}
@media (max-width: 768px) {
    .slide-metrics { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
    .slide-metrics { grid-template-columns: 1fr; }
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 66-78" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 4 ;
                            oc:sectionTitle "Metrics Dashboard (4 columns)" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """.slide-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
}
@media (max-width: 768px) {
    .slide-split { grid-template-columns: 1fr; gap: 24px; }
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 38-48" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Two Column Split" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """.slide-title {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
}
""" ;
                                    oc:codeLanguage "css" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 27-35" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Title Slide" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "CSS Structures" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """1. What's the slide goal?
   └─> Search layout-logic.csv

2. What emotion should it trigger?
   └─> Search color-logic.csv

3. What's the content type?
   └─> Search typography.csv

4. Should it break pattern?
   └─> Check position (1/3, 2/3) → Use full-bleed
""" ;
                            oc:codeLanguage "" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 125-137" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Layout Decision Flow" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 14 ;
                            oc:tableCaption "## Layout Selection by Use Case" ;
                            oc:tableMarkdown """| Layout | Use Case | Animation |
|--------|----------|-----------|
| Title Slide | Opening/first impression | `animate-fade-up` |
| Problem Statement | Establish pain point | `animate-stagger` |
| Solution Overview | Introduce solution | `animate-scale` |
| Feature Grid | Show capabilities (3-6 cards) | `animate-stagger` |
| Metrics Dashboard | Display KPIs (3-4 metrics) | `animate-stagger-scale` |
| Comparison Table | Compare options | `animate-fade-up` |
| Timeline Flow | Show progression | `animate-stagger` |
| Team Grid | Introduce people | `animate-stagger` |
| Quote Testimonial | Customer endorsement | `animate-fade-up` |
| Two Column Split | Compare/contrast | `animate-fade-up` |
| Big Number Hero | Single powerful metric | `animate-count` |
| Product Screenshot | Show product UI | `animate-scale` |
| Pricing Cards | Present tiers | `animate-stagger` |
| CTA Closing | Drive action | `animate-pulse` |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Layout Selection by Use Case" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """# Find layout for specific use
python .claude/skills/design-system/scripts/search-slides.py "metrics dashboard" -d layout

# Contextual recommendation
python .claude/skills/design-system/scripts/search-slides.py "traction slide" \\
  --context --position 4 --total 10
""" ;
                            oc:codeLanguage "bash" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 114-121" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Search Commands" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 5 ;
                                    oc:tableCaption "### Card Styles" ;
                                    oc:tableMarkdown """| Style | CSS Class | Use For |
|-------|-----------|---------|
| Icon Left | `.card-icon-left` | Features with icons |
| Accent Bar | `.card-accent-bar` | Highlighted features |
| Metric Card | `.card-metric` | Numbers/stats |
| Avatar Card | `.card-avatar` | Team members |
| Pricing Card | `.card-pricing` | Price tiers |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Card Styles" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Metric Styles" ;
                                    oc:tableMarkdown """| Style | Effect |
|-------|--------|
| `gradient-number` | Gradient text on numbers |
| `oversized` | Extra large (120px+) |
| `sparkline` | Small inline chart |
| `funnel-numbers` | Conversion stages |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Metric Styles" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Component Variants" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 8 ;
                            oc:tableCaption "## Visual Treatments" ;
                            oc:tableMarkdown """| Treatment | When to Use |
|-----------|-------------|
| `gradient-glow` | Title slides, CTAs |
| `subtle-border` | Problem statements |
| `icon-top` | Feature grids |
| `screenshot-shadow` | Product screenshots |
| `popular-highlight` | Pricing (scale 1.05) |
| `bg-overlay` | Background images |
| `contrast-pair` | Before/after |
| `logo-grayscale` | Client logos |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Visual Treatments" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Layout Patterns" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Systematic process for selecting the right layout pattern for a given slide" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Select appropriate animation class based on layout type and emotional intent" ;
                    oc:expectedOutcome "Animation class assigned matching the layout's purpose" ;
                    oc:stepDependsOn _:ref_29c17d52f2b4b7a6 ;
                    oc:stepId "ls-3" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Apply responsive CSS breakpoints at 768px and 480px" ;
                    oc:expectedOutcome "Layout renders correctly on all screen sizes" ;
                    oc:stepDependsOn _:ref_29c17d52f2b4b7a6 ;
                    oc:stepId "ls-5" ],
                _:ref_29c17d52f2b4b7a6,
                [ a oc:WorkflowStep ;
                    dcterms:description "Choose card variant or visual treatment that matches content purpose" ;
                    oc:expectedOutcome "Component styles selected (card type, metric style, visual treatment)" ;
                    oc:stepDependsOn _:ref_29c17d52f2b4b7a6 ;
                    oc:stepId "ls-4" ],
                _:ref_739c163432f70f85 ;
            oc:workflowId "layout-selection" ;
            oc:workflowName "Slide Layout Selection" ] ;
    oc:impartsKnowledge oc:kn_16a1c9d0,
        oc:kn_6d05f1c8,
        oc:kn_7badcbb4,
        oc:kn_facf59ee,
        oc:kn_fb1421ef ;
    oc:isUserInvocable true ;
    oc:nature "Reference" ;
    oc:requiresState oc:DocumentCreated ;
    oc:resolvesIntent "apply responsive CSS grid patterns to slides",
        "choose animation classes for slide transitions",
        "find appropriate layout for a specific slide use case",
        "pick card styles and visual treatments for slide content",
        "select slide layout for presentation" ;
    oc:yieldsState oc:LayoutSelected,
        oc:ResponsiveCSSApplied .

oc:kn_16a1c9d0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding card components to any grid layout" ;
    oc:directiveContent "Use card variants that match content purpose: .card-metric for numbers/stats, .card-accent-bar for highlighted features, .card-avatar for team members, .card-pricing for tiers, .card-icon-left for feature lists." ;
    oc:hasRationale "Mismatched card styles confuse the visual hierarchy and dilute the slide's communicative intent." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6d05f1c8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding which layout pattern to use for a given slide" ;
    oc:directiveContent "Select layout by slide goal first (search layout-logic.csv), then match emotion (color-logic.csv), then content type (typography.csv). Break visual pattern at 1/3 and 2/3 positions with full-bleed layouts." ;
    oc:hasRationale "Systematic selection ensures layout, color, and typography work coherently together rather than being chosen independently." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7badcbb4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any grid-based slide layout (split, features, metrics)" ;
    oc:directiveContent "All grid layouts must include responsive breakpoints at 768px and 480px to maintain readability on mobile devices." ;
    oc:hasRationale "Without responsive breakpoints, multi-column layouts break on smaller screens and become unreadable." ;
    oc:severityLevel "HIGH" .

oc:kn_facf59ee a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building multi-slide presentations" ;
    oc:directiveContent "Do not use the same layout pattern for more than 2-3 consecutive slides; vary the rhythm to maintain audience engagement." ;
    oc:hasRationale "Repetitive layouts cause visual fatigue and reduce information retention." ;
    oc:severityLevel "LOW" .

oc:kn_fb1421ef a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assigning animation classes to slides" ;
    oc:directiveContent "Use `animate-stagger` for grid/card layouts, `animate-fade-up` for single-element slides, `animate-scale` for hero/product reveals, `animate-count` for big numbers, `animate-pulse` for CTAs." ;
    oc:hasRationale "Animation choice should match content density and emotional intent of the slide." ;
    oc:severityLevel "MEDIUM" .

_:ref_739c163432f70f85 a oc:WorkflowStep ;
    dcterms:description "Identify the slide's communication goal (e.g., show metrics, introduce team, present pricing)" ;
    oc:expectedOutcome "Clear understanding of what content the slide must convey" ;
    oc:stepId "ls-1" .

_:ref_29c17d52f2b4b7a6 a oc:WorkflowStep ;
    dcterms:description "Match goal to layout type using the Layout Selection table or layout-logic.csv" ;
    oc:expectedOutcome "Primary layout pattern identified" ;
    oc:stepDependsOn _:ref_739c163432f70f85 ;
    oc:stepId "ls-2" .

