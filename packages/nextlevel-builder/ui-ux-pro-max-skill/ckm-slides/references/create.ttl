    dcterms:description "For each slide: map to layout pattern, select copywriting formula, assign animation class and target emotion" ;
    oc:expectedOutcome "Slide-by-slide blueprint with layout, copy formula, animation, and emotion" ;
    oc:stepDependsOn _:ref_2372f8af9cd02299 ;
    oc:stepId "design-slides" .

_:ref_2372f8af9cd02299 a oc:WorkflowStep ;
