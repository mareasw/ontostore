    dcterms:description "Generate complete HTML file using base template, design tokens, layout CSS, Chart.js for data slides, and navigation JavaScript" ;
    oc:expectedOutcome "Self-contained HTML file with responsive slides and navigation" ;
    oc:stepDependsOn _:ref_0686b000d9d10f34 ;
    oc:stepId "generate-html" .

