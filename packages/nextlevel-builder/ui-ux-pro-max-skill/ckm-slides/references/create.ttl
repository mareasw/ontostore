oc:kn_3e18f95a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building slide HTML and CSS" ;
    oc:directiveContent "Always wrap slide content in .slide-content div for safe area constraints. Use overflow:hidden on .slide to prevent content overflow. Maintain 16:9 aspect ratio on desktop with letterboxing. Use clamp() for all font sizes to ensure responsive typography." ;
    oc:hasRationale "Prevents content overflow, ensures consistent aspect ratio, and maintains readability across devices" ;
    oc:severityLevel "HIGH" .

oc:kn_50ed8cbd a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding data visualization charts to slides" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent """new Chart(document.getElementById('{chartId}'), {
    type: '{line|bar|doughnut|radar}',
    data: { labels: [{labels}], datasets: [{ label: '{label}', data: [{values}], borderColor: '{color}', backgroundColor: 'rgba({r},{g},{b},0.1)', borderWidth: 3, fill: true, tension: 0.4 }] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#B8B8D0' } }, y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#B8B8D0' } } } }
});""" .

oc:kn_55d03000 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building responsive slide layouts for splits, features, and metrics" ;
    oc:codeLanguage "css" ;
    oc:directiveContent """.slide-split { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
.slide-features { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.slide-metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
@media (max-width: 768px) { .slide-split { grid-template-columns: 1fr; } .slide-features { grid-template-columns: repeat(2, 1fr); } .slide-metrics { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px) { .slide-features, .slide-metrics { grid-template-columns: 1fr; } }""" .

oc:kn_5bb68232 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Each slide in the deck follows this structure" ;
    oc:directiveContent """{slide_type}: {copywriting_formula}
  Layout: {layout_pattern}
  Animation: {animation_class}
  Emotion: {target_emotion}
  Content: {headline} | {body} | {visual_element}""" ;
    oc:templateVariables "animation_class",
        "body",
        "copywriting_formula",
        "headline",
        "layout_pattern",
        "slide_type",
        "target_emotion",
        "visual_element" .

oc:kn_6a27a4d8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When ordering slides within a deck" ;
    oc:directiveContent "Use emotion arcs to sequence slides: curiosity→frustration→hope→confidence→trust→urgency. Alternate between 'What Is' (pain) and 'What Could Be' (hope) using the Duarte Sparkline pattern. Break visual pattern at 1/3 and 2/3 positions for engagement peaks." ;
    oc:hasRationale "Strategic emotion sequencing drives audience engagement and persuasion effectiveness" .

oc:kn_9eb587f7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a deck strategy" ;
    oc:directiveContent "Match slide strategy to context: investor pitch → YC Seed/Series A, selling → Sales Pitch/Product Demo, internal → QBR/All-Hands/Board Meeting, public speaking → Conference Talk/Workshop, proving value → Case Study/Competitive Analysis, lead generation → Webinar" ;
    oc:hasRationale "Strategy mismatch leads to wrong audience expectations and poor persuasion outcomes" ;
    oc:severityLevel "HIGH" .

oc:kn_e1b6ad28 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any presentation" ;
    oc:directiveContent "1. Parse task arguments for topic and slide count. 2. Select slide strategy (YC Seed, Sales Pitch, Product Demo, etc.) based on goal and audience. 3. Map each slide to a layout pattern (Title, Problem, Feature Grid, Metrics, CTA, etc.). 4. Apply copywriting formula per slide type (PAS for problems, FAB for features, AIDA for CTAs). 5. Generate HTML using the base template with design tokens, Chart.js for data slides, and animation classes. 6. Wire up keyboard/click navigation and progress bar." ;
    oc:hasRationale "Ensures strategic coherence across strategy selection, layout, copy, and technical implementation" ;
    oc:stepOrder 1 .

oc:kn_e4d28b77 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Base template for all HTML slide decks" ;
    oc:codeLanguage "html" ;
    oc:directiveContent """<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{Presentation Title}</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <style>
        :root { --color-primary: {color}; --color-background: {bg}; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        .slide-deck { width: 100vw; height: 100vh; overflow: hidden; }
        .slide { position: absolute; width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 60px; opacity: 0; visibility: hidden; transition: opacity 0.4s; }
        .slide.active { opacity: 1; visibility: visible; }
    </style>
</head>
<body>
    <div class="progress-bar" id="progressBar"></div>
    <div class="slide-deck">{slides}</div>
    <div class="nav-controls">
        <button onclick="prevSlide()">←</button>
        <span class="slide-counter"><span id="current">1</span>/<span id="total">N</span></span>
        <button onclick="nextSlide()">→</button>
    </div>
    <script>{navigation + charts}</script>
</body>
</html>""" .

oc:kn_f63f46a6 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before generating slide HTML" ;
    oc:directiveContent "Chart.js 4.4.1 loaded via CDN (https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js). Design tokens must be available as CSS custom properties." .

