        oc:kn_63876048,
        oc:kn_697fd43a,
        oc:kn_e7391e31 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:PresentationContextDefined ;
    oc:resolvesIntent "build investor pitch deck",
        "choose emotion arc for slides",
        "create sales presentation",
        "match presentation context to deck format",
        "select slide strategy for presentation",
        "structure a pitch deck" ;
    oc:yieldsState oc:EmotionArcDefined,
        oc:SlideStrategySelected .

oc:kn_273e0aaf a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting any new presentation" ;
    oc:directiveContent "Never build a deck without first selecting the appropriate strategy and its corresponding slide count range —盲目 creating slides without structure leads to unfocused presentations." ;
    oc:hasRationale "Each strategy prescribes an optimal slide count and structure tested for its specific audience and goal" ;
    oc:severityLevel "MEDIUM" .

oc:kn_37ec5acd a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating transformative or persuasive presentations" ;
    oc:directiveContent "Use the Duarte Sparkline pattern to alternate between 'What Is' (current pain) and 'What Could Be' (better future), resolving at 'New Bliss'. Place pattern breaks at 1/3 and 2/3 positions for engagement peaks." ;
    oc:hasRationale "Alternating pain/hope creates tension and release that maintains audience attention throughout the presentation" .

oc:kn_63876048 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoping a presentation" ;
    oc:directiveContent "Slide count ranges are strategy-dependent: Product Demo (5-8), Problem-Solution-Benefit (3-5), Sales Pitch (7-10), YC Seed (10-12), Guy Kawasaki (10), Series A (12-15), Conference Talk (15-25), Workshop (20-40), Webinar (20-30)." ;
    oc:hasRationale "Deviating significantly from these ranges either overwhelms or underwhelms the target audience" ;
    oc:severityLevel "MEDIUM" .

oc:kn_697fd43a a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any multi-slide presentation" ;
    oc:directiveContent "Every deck must follow an explicit emotion arc that guides the audience through a psychological journey (e.g., curiosity→frustration→hope→confidence→urgency for YC Seed; connection→frustration→fear→hope→trust→confidence→urgency for Sales Pitch)." ;
    oc:hasRationale "Emotion arcs create narrative momentum that drives the audience toward the desired action" ;
    oc:severityLevel "HIGH" .

oc:kn_e7391e31 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting a slide strategy for a new presentation" ;
    oc:directiveContent "Match strategy to context: raising money → YC Seed/Series A/Guy Kawasaki; selling product → Sales Pitch/Product Demo; internal update → QBR/All-Hands/Board Meeting; public speaking → Conference Talk/Workshop; proving value → Case Study/Competitive Analysis; lead generation → Webinar." ;
    oc:hasRationale "Wrong strategy for the audience leads to disengagement and failed objectives" ;
    oc:severityLevel "HIGH" .

