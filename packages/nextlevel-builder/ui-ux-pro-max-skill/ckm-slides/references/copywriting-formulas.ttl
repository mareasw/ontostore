oc:kn_0c74bf06 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When composing slide copy from formulas" ;
    oc:directiveContent """PAS: "[Pain point]? Every [time frame], [consequence]. [Solution] fixes this."
AIDA: "[Bold statement]. [Benefit detail]. [Social proof]. [CTA]."
FAB: "[Feature] lets you [advantage], so you can [benefit]."
Cost of Inaction: "Without [solution], you're losing [amount] every [timeframe]."
BAB: "[Pain point before]. [Desired state after]. [Your solution] is the bridge.\"""" .

oc:kn_102842bc a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When mapping formulas to slide types" ;
    oc:directiveContent """| Slide Type | Primary Formula | Emotion |
| Title/Hook | AIDA, Hook | curiosity |
| Problem | PAS, Agitate | frustration |
| Cost/Risk | Cost of Inaction | fear |
| Solution | FAB, BAB | hope |
| Features | FAB | confidence |
| Traction | Proof Stack | trust |
| Social Proof | Testimonial | trust |
| Pricing | Value Stack | confidence |
| CTA | AIDA, Urgency | urgency |""" ;
    oc:templateVariables "Emotion",
        "Primary Formula",
        "Slide Type" .

oc:kn_2014dd05 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when applying formula templates" ;
    oc:directiveContent "Every formula must be filled with audience-specific, concrete details — generic placeholders weaken persuasion" ;
    oc:hasRationale "Abstract copy fails to trigger emotional response; specificity is what makes formulas work" ;
    oc:severityLevel "HIGH" .

oc:kn_450cf9a3 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When writing any slide copy" ;
    oc:directiveContent "1. Identify slide type (title, problem, solution, features, CTA) → 2. Match to primary formula from mapping table → 3. Select emotion target → 4. Fill template with audience-specific content → 5. Apply headline pattern for hook" ;
    oc:stepOrder 1 .

oc:kn_4538a826 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When looking up formulas programmatically" ;
    oc:codeLanguage "bash" ;
    oc:directiveContent """# Search for formula by slide context
python .claude/skills/design-system/scripts/search-slides.py "problem agitation" -d copy
# Get emotion-appropriate formula
python .claude/skills/design-system/scripts/search-slides.py "urgency cta" -d copy""" .

oc:kn_65ea4dbb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting which formula to use" ;
    oc:directiveContent "Match formula to desired audience emotion: curiosity→AIDA, frustration→PAS, fear→Cost of Inaction, hope→FAB/BAB, trust→Proof Stack/Testimonial, urgency→AIDA/Scarcity" ;
    oc:hasRationale "Emotion drives decision-making; aligning formula to target emotion maximizes persuasive impact" .

oc:kn_9fff5dde a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When crafting slide titles and headlines" ;
    oc:directiveContent "Use contrast patterns for headline hooks: '[Old way] is dead. Meet [new way].' or 'Don't [bad action]. Instead, [good action].' or 'From [pain point] to [benefit].'" .

oc:kn_ae0a9a66 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires search script at .claude/skills/design-system/scripts/search-slides.py for programmatic formula lookup" .

_:ref_4c9feeba74a467b8 a oc:WorkflowStep ;
    dcterms:description "Identify target emotion from the mapping (curiosity, frustration, fear, hope, trust, urgency)" ;
    oc:expectedOutcome "Emotion target set" ;
    oc:stepDependsOn _:ref_ac04d1ac8efca6bd ;
    oc:stepId "set-emotion" .

_:ref_5c3cbb08414bd539 a oc:WorkflowStep ;
    dcterms:description "Fill the formula template with audience-specific, concrete content" ;
    oc:expectedOutcome "Draft slide copy produced" ;
    oc:stepDependsOn _:ref_4c9feeba74a467b8 ;
    oc:stepId "fill-template" .

_:ref_ac04d1ac8efca6bd a oc:WorkflowStep ;
    dcterms:description "Map slide type to primary formula using the Formula-to-Slide Mapping table" ;
    oc:expectedOutcome "Primary formula selected" ;
    oc:stepDependsOn _:ref_f14ec62d625bbdcd ;
    oc:stepId "map-formula" .

_:ref_f14ec62d625bbdcd a oc:WorkflowStep ;
    dcterms:description "Identify the slide type (title, problem, solution, features, CTA, etc.)" ;
    oc:expectedOutcome "Slide type classified" ;
    oc:stepId "identify-slide" .

