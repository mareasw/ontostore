oc:kn_30c96709 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When designing transformational or persuasive presentations" ;
    oc:directiveContent "Use the Duarte Sparkline pattern for persuasive decks: alternate 'What Is' (current pain) and 'What Could Be' (better future) slides, with pattern breaks at 1/3 and 2/3 positions for engagement peaks, ending at 'New Bliss' resolution." ;
    oc:hasRationale "Pattern breaks at key positions prevent audience attention fatigue and create memorable engagement moments" .

oc:kn_389cd302 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When creating any presentation" ;
    oc:directiveContent "1. Parse subcommand from arguments (first word) 2. Load references/{subcommand}.md 3. Select slide strategy based on audience/goal 4. Load layout patterns and copywriting formulas from knowledge base 5. Generate complete HTML with design tokens, Chart.js, navigation, and animations 6. Ensure responsive breakpoints for all slides" ;
    oc:stepOrder 1 .

oc:kn_3a019050 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing slide CSS layouts" ;
    oc:directiveContent "Do not create slides without responsive breakpoints — every layout must include tablet (768px) and mobile (480px) media queries." ;
    oc:hasRationale "Presentations may be viewed on any device; missing breakpoints cause content overflow and broken layouts on smaller screens" ;
    oc:severityLevel "HIGH" .

oc:kn_67edd10b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting a new presentation" ;
    oc:directiveContent "Select slide strategy before designing individual slides: match the deck structure to the audience and goal (e.g., YC Seed for VCs, Sales Pitch for leads, Conference Talk for attendees)." ;
    oc:hasRationale "15 proven strategies exist with pre-defined slide sequences and emotion arcs; choosing wrong strategy misaligns content with audience expectations" ;
    oc:severityLevel "MEDIUM" .

oc:kn_8880e906 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When building any slide HTML" ;
    oc:directiveContent "Always wrap slide content in a .slide-content div inside the .slide container to ensure safe-area constraint and prevent content overflow." ;
    oc:hasRationale "The .slide-content wrapper provides overflow:hidden and flex layout that constrains content within the slide viewport" ;
    oc:severityLevel "HIGH" .

oc:kn_8e7da523 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any multi-slide deck" ;
    oc:directiveContent "Every slide must follow an emotion arc: map each slide to a specific emotion (curiosity→frustration→hope→confidence→trust→urgency) and select the matching copywriting formula and layout pattern." ;
    oc:hasRationale "Strategic emotion arcs create persuasive momentum and guide audience psychological journey through the presentation" ;
    oc:severityLevel "HIGH" .

oc:kn_c78945bf a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling slides" ;
    oc:directiveContent "Use CSS custom properties for design tokens: --color-primary, --color-background, --color-secondary, --primitive-gradient-primary, --typography-font-heading, --typography-font-body. Load from embed-tokens.cjs output." ;
    oc:hasRationale "Design tokens ensure visual consistency with the broader design system and enable theming" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d32a1793 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing slide deck interactivity" ;
    oc:codeLanguage "javascript" ;
    oc:directiveContent "Slide navigation: keyboard (ArrowRight/ArrowLeft/Space), click anywhere to advance, nav buttons with prev/next. Show progress bar at top. Track current/total slide count." .

oc:kn_da892b12 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating presentation HTML output" ;
    oc:directiveContent """<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <style>/* Design tokens + slide styles + responsive breakpoints */</style>
</head>
<body>
  <div class="progress-bar" id="progressBar"></div>
  <div class="slide-deck">
    <!-- {slides} wrapped in .slide > .slide-content -->
  </div>
  <div class="nav-controls"><!-- prev/counter/next --></div>
  <script>/* Navigation logic + Chart.js instances */</script>
</body>
</html>""" ;
    oc:templateVariables "slides",
        "title" .

oc:kn_df3c2b34 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing slide copy" ;
    oc:directiveContent "Match copywriting formula to slide type: PAS for problem slides, AIDA for CTAs, FAB for features, Cost of Inaction for urgency, BAB for transformations." ;
    oc:hasRationale "25 proven formulas exist with specific slide-type mappings; using the wrong formula weakens persuasive impact" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e2b08860 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "When creating slides with charts or graphs" ;
    oc:directiveContent "Chart.js 4.4.1 loaded via CDN (https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js) for data visualization slides" .

