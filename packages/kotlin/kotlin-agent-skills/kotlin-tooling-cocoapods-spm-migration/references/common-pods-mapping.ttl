Maven: `dev.gitlive:firebase-auth`, `dev.gitlive:firebase-firestore`, `dev.gitlive:firebase-storage`, etc.""" ],
                                _:ref_ce1fb80d634e106a ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "dev.gitlive/firebase-kotlin-sdk" ],
