oc:kn_01138574 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When migrating a pod not covered by this reference" ;
    oc:directiveContent "To find the correct Clang module name for an unknown pod: (1) keep `discoverModulesImplicitly = true`, (2) run `./gradlew build`, (3) check build errors for available class names, or inspect the library's `module.modulemap` file." ;
    oc:hasRationale "Build errors from implicit discovery reveal which Clang modules are available, providing the correct module names for explicit configuration." ;
    oc:severityLevel "MEDIUM" .

oc:kn_04db31dc a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring importedClangModules for Firebase products" ;
    oc:directiveContent "Several Firebase SPM products have Clang module names that differ from the product name: FirebaseDatabase → FirebaseDatabaseInternal, FirebaseFirestore → FirebaseFirestoreInternal, FirebaseRemoteConfig → FirebaseRemoteConfigInternal, FirebaseInAppMessaging-Beta → FirebaseInAppMessagingInternal. Use the Clang module name in `importedClangModules`, NOT the product name." ;
    oc:hasRationale "Some Firebase products ship as binary xcframeworks where the internal Clang module exposed to Objective-C has a different name than the SPM product. Without the correct module name, the KMP compiler cannot discover the ObjC headers." ;
    oc:severityLevel "HIGH" .

oc:kn_077c53eb a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When declaring a Firebase SPM product in build.gradle.kts" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """swiftPackage(
    url = url("https://github.com/firebase/firebase-ios-sdk.git"),
    version = from("12.6.0"),
    products = listOf(product("FirebaseAuth")),
    importedClangModules = listOf("FirebaseAuth"),
)""" .

oc:kn_18594ad6 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When declaring Google Maps SPM dependency" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """swiftPackage(
    url = url("https://github.com/googlemaps/ios-maps-sdk.git"),
    version = exact("10.6.0"),
    products = listOf(
        product("GoogleMaps", platforms = setOf(iOS()))
    ),
)""" .

oc:kn_5a0b73c9 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting any pod version constraint to SPM" ;
    oc:directiveContent "Preserve version constraint semantics from the CocoaPods block: `version = \"X.Y.Z\"` (without `~>`) is an exact pin → use `exact(\"X.Y.Z\")` in SPM. Only use `from()` when the CocoaPods spec used optimistic versioning (`~>`)." ;
    oc:hasRationale "Using `from()` for an exact pin can resolve to a newer version that breaks cinterop APIs if symbols were removed or renamed." ;
    oc:severityLevel "HIGH" .

oc:kn_614b3e02 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating any Firebase pod from CocoaPods to SPM" ;
    oc:directiveContent "Never mix Firebase products across CocoaPods and SPM — all Firebase pods must migrate to SPM at once. Shared transitive dependencies (gRPC, abseil, leveldb, BoringSSL, nanopb) get linked twice otherwise, causing dyld crashes like `Symbol not found: _OBJC_CLASS_$_FIRFirestore`." ;
    oc:hasRationale "Firebase products share a single repository and common transitive C/C++ dependencies; partial migration causes duplicate symbol linking with conflicting versions." ;
    oc:severityLevel "CRITICAL" .

oc:kn_7ed861f0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating projects that use KMP wrapper libraries with bundled cinterop" ;
    oc:directiveContent "When a KMP wrapper library (e.g., KMPNotifier, dev.gitlive) bundles pre-built cinterop klibs with `cocoapods.*` namespace, those imports must be preserved after migration. Do NOT replace `cocoapods.*` imports with `swiftPMImport.*` for those libraries." ;
    oc:hasRationale "Bundled klibs provide their own cinterop bindings. swiftPMDependencies detects existing bindings and skips regeneration, so the original `cocoapods.*` import paths remain valid and required." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9185236f a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When identifying bundled cinterop klibs in unknown KMP libraries" ;
    oc:directiveContent "1. Find klibs: `find ~/.gradle/caches -name \"*.klib\" -path \"*libraryName*\"`. 2. Dump signatures: `klib dump-metadata-signatures /path/to/library.klib | grep \"cocoapods\\.\"`. 3. If output shows cocoapods.* entries, preserve those imports after migration." ;
    oc:stepOrder 1 .

oc:kn_99caabdf a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When declaring GoogleMaps SwiftPM dependency" ;
    oc:directiveContent "Google Maps SPM requires `exact()` versioning, not `from()`. Using `from()` will fail to resolve the package." ;
    oc:hasRationale "The Google Maps SDK repository does not support semantic version range resolution via SPM." ;
    oc:severityLevel "HIGH" .

oc:kn_b9d8a573 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When researching a pod not covered by this reference" ;
    oc:directiveContent "1. Check GitHub repository for Package.swift file. 2. Check CocoaPods spec `source` field for Git URL. 3. Search Swift Package Index (swiftpackageindex.com). 4. Check library documentation for SPM installation instructions." ;
    oc:stepOrder 1 .

oc:kn_bd6bc42d a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When migrating Firebase from CocoaPods to SPM" ;
    oc:directiveContent "1. List all Firebase pods currently in the project. 2. Map each to its SPM product name (note `-Beta` suffixes and renames). 3. Declare all products in a single swiftPackage block. 4. Set `discoverModulesImplicitly = false`. 5. List all needed Clang modules in `importedClangModules` (using internal names where applicable). 6. Include Swift-only pods as products without importedClangModules. 7. Re-run `integrateLinkagePackage`." ;
    oc:stepOrder 1 .

oc:kn_d6d87433 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When the project uses dev.gitlive Firebase KMP libraries and migrates to SPM" ;
    oc:directiveContent "For dev.gitlive firebase-kotlin-sdk consumers, add per-product `-F` linkerOpts pointing to `$BUILT_PRODUCTS_DIR/<ProductName>` for each Firebase framework, and set `isStatic = true` on the framework to avoid dyld runtime crashes from missing dynamic framework loads." ;
    oc:hasRationale "dev.gitlive klibs have linker flags baked in from the CocoaPods era. SPM places Firebase frameworks in per-product subdirectories the K/N linker doesn't search. Dynamic linking fails because SPM Firebase products are static libraries not embedded in the app bundle." ;
    oc:severityLevel "HIGH" .

oc:kn_df606384 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When declaring Firebase SwiftPM dependencies in build.gradle.kts" ;
    oc:directiveContent "Use `discoverModulesImplicitly = false` for Firebase — its transitive C++ dependencies (gRPC, abseil, leveldb, BoringSSL) contain Clang modules that fail cinterop. Explicitly list only needed modules in `importedClangModules`." ;
    oc:hasRationale "Implicit discovery pulls in C++ modules that the Kotlin cinterop tool cannot process, causing build failures." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e6bb4ea1 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When declaring Firebase products with mismatched Clang module names" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """swiftPackage(
    url = url("https://github.com/firebase/firebase-ios-sdk.git"),
    version = from("12.6.0"),
    products = listOf(product("FirebaseFirestore")),
    importedClangModules = listOf("FirebaseFirestoreInternal"),
)""" .

