    oc:stepOrder 3 .

_:ref_c1a011ff1271874a a oc:WorkflowStep ;
    dcterms:description "**Must use `isStatic = true`.** With a dynamic framework, the K/N linker creates `@rpath/FirebaseCore.framework/FirebaseCore` load instructions. Firebase SPM products are static libraries — their `.framework` bundles are not embedded in the app bundle. At runtime, `dyld` crashes with `Library not loaded`. Switching to `isStatic = true` embeds all symbols and defers unresolved framework flags to the final Xcode link." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_cfdf2760dec5df8a a oc:WorkflowStep ;
    dcterms:description "Check the GitHub releases page for SPM-compatible versions" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_d3b6dc26284d2f2f a oc:WorkflowStep ;
    dcterms:description "**Preserve version constraint semantics from the `cocoapods {}` block.** CocoaPods `version = \"X.Y.Z\"` (without `~>`) is an exact pin — use `exact(\"X.Y.Z\")` in SPM, not `from()`. Using `from()` for an exact version can resolve to a newer version that breaks cinterop APIs if symbols were removed or renamed. Only use `from()` when the CocoaPods spec used optimistic versioning (`~>`)." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_f51b2496d13b8d75 a oc:WorkflowStep ;
    dcterms:description "**Check library documentation** - Many libraries document SPM installation" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

