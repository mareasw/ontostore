oc:kn_02685a5e a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When dev.gitlive:firebase-* causes 'framework not found' linker errors — add Gradle linkerOpts for Firebase SPM framework search paths" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """iosTarget.binaries.framework {
    val builtProductsDir = System.getenv("BUILT_PRODUCTS_DIR")
    if (builtProductsDir != null) {
        listOf("FirebaseCore", "FirebaseAuth", "FirebaseCoreExtension",
            "FirebaseCoreInternal", "FirebaseCrashlytics", "FirebaseFirestore",
            "FirebaseFirestoreInternal", "FirebaseInstallations", "FirebaseMessaging",
            "FirebaseStorage", "GoogleDataTransport", "GoogleUtilities",
            "GTMSessionFetcher", "AppCheckCore", "AppAuth", "GTMAppAuth",
        ).forEach { product ->
            linkerOpts("-F", "$builtProductsDir/$product")
        }
    }
}""" .

oc:kn_0e5a5e6b a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When checkSandboxAndWriteProtection fails — disable sandboxing via CLI" ;
    oc:directiveContent "sed -i '' 's/ENABLE_USER_SCRIPT_SANDBOXING = YES/ENABLE_USER_SCRIPT_SANDBOXING = NO/g' /path/to/iosApp/*.xcodeproj/project.pbxproj" .

oc:kn_0f63dacd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating Firebase dependencies" ;
    oc:directiveContent "All Firebase products must be migrated to SPM at once — do not split Firebase across CocoaPods and SPM. Shared transitive dependencies (gRPC, abseil, leveldb, BoringSSL) cause duplicate/conflicting symbols when both package managers link them." ;
    oc:hasRationale "All Firebase products share transitive dependencies that conflict when linked by both package managers, causing dyld symbol-not-found crashes." ;
    oc:severityLevel "HIGH" .

oc:kn_13fcb9a9 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "klib tool must be available (part of Kotlin/Native compiler distribution) for inspecting klib contents" .

oc:kn_285fa89f a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When troubleshooting Unresolved reference errors for migrated imports" ;
    oc:directiveContent "The swiftPMImport namespace follows the pattern: swiftPMImport.<group>.<module>.<ClassName>, where dashes in both group and module names become dots. Run ./gradlew build to see available classes in error messages if unsure of the exact path." ;
    oc:hasRationale "Correct import construction requires understanding the dash-to-dot transformation rule." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2bb2b0a2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using dev.gitlive:firebase-kotlin-sdk with SPM" ;
    oc:directiveContent "dev.gitlive:firebase-* requires isStatic = true for the KMP framework when using SwiftPM. Dynamic frameworks cause dyld runtime crashes because Firebase SPM products are static libraries whose .framework bundles are not embedded in the app." ;
    oc:hasRationale "Dynamic frameworks create LC_LOAD_DYLIB entries that dyld cannot resolve at runtime for static SPM products." ;
    oc:severityLevel "CRITICAL" .

oc:kn_2c3930e3 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When build fails after migration" ;
    oc:directiveContent "1. Read full error log and identify failure type (Gradle resolution / import not found / linker / Xcode build phase) 2. Re-check Phases 2-6 for common mistakes (missing repo, wrong import namespace, incomplete CocoaPods removal, wrong xcodeproj, missing isStatic, unrun integrateLinkagePackage, EmbedAndSign disabler, commented build phase, incorrectly replaced bundled klib imports) 3. Consult specific troubleshooting section for the error pattern 4. If unsure, present options to user" ;
    oc:stepOrder 1 .

oc:kn_87b2cbe2 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When integrateEmbedAndSign completes but Xcode project is not modified" ;
    oc:directiveContent "CocoaPods-era code that disables EmbedAndSign tasks (e.g., taskGraph.whenReady filters) inadvertently disables integrateEmbedAndSign. This code must be removed before running integration tasks. Also check if embedAndSignAppleFrameworkForXcode is commented out (prefixed with #) in project.pbxproj." ;
    oc:hasRationale "The disabler code was a CocoaPods workaround that breaks the new SPM integration tasks." ;
    oc:severityLevel "HIGH" .

oc:kn_a8e62da3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When build fails after migration" ;
    oc:directiveContent "Do NOT revert the migration as a first response to build failures. Instead, read the full error log, identify the failure type, re-check Phases 2-6, and consult specific error patterns in the troubleshooting guide." ;
    oc:hasRationale "Blind reversion wastes the migration work already completed; most failures are fixable with targeted diagnosis." ;
    oc:severityLevel "HIGH" .

oc:kn_b34ee62d a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When checkSandboxAndWriteProtection task fails during Xcode build" ;
    oc:directiveContent "Xcode 16+ enables User Script Sandboxing (ENABLE_USER_SCRIPT_SANDBOXING = YES) by default, which prevents the Gradle build phase from writing to the project directory. Must be set to NO and followed by ./gradlew --stop to restart the daemon." ;
    oc:hasRationale "The Gradle build phase script needs write access to the project directory, which sandboxing blocks." ;
    oc:severityLevel "HIGH" .

oc:kn_b86b97ff a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When all troubleshooting has failed and migration must be reverted" ;
    oc:directiveContent "Rollback is a last resort only if targeted fixes fail. Steps: 1) git checkout Podfile/Podfile.lock/podspec/build.gradle.kts/Kotlin sources, 2) Re-add kotlin(\"native.cocoapods\") plugin and cocoapods block, 3) Restore cocoapods.* imports, 4) Run pod install, 5) Open .xcworkspace in Xcode." ;
    oc:hasRationale "Provides a structured rollback path using git to restore pre-migration state." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b990303b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When cinterop fails on C++ transitive dependencies" ;
    oc:directiveContent "For Firebase cinterop failures on C++ modules (gRPC, abseil, leveldb, BoringSSL), set discoverModulesImplicitly = false and explicitly list only the needed Firebase Clang modules in importedClangModules. Several Firebase products use internal Clang module names that differ from SPM product names (e.g., FirebaseFirestore → FirebaseFirestoreInternal)." ;
    oc:hasRationale "The default discoverModulesImplicitly=true attempts cinterop on every Clang module including incompatible C++ modules; explicit listing avoids this." ;
    oc:severityLevel "HIGH" .

oc:kn_c120646a a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When missing symbols/linker errors occur — run this one-time task to generate the linkage Swift package" ;
    oc:directiveContent "./gradlew :moduleName:integrateLinkagePackage" .

oc:kn_d1979533 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When cocoapods.* imports fail after conversion to swiftPMImport.*" ;
    oc:directiveContent "Third-party KMP libraries (e.g., KMPNotifier) bundle pre-built cinterop klibs with cocoapods.* namespaces. The swiftPMDependencies cinterop generator skips generating bindings for those modules. Their cocoapods.* imports MUST be preserved — replacing them with swiftPMImport.* causes Unresolved reference errors." ;
    oc:hasRationale "The generator deliberately skips modules already provided by dependency klibs to avoid duplicate symbols, so swiftPMImport.* bindings for those classes simply don't exist." ;
    oc:severityLevel "CRITICAL" .

oc:kn_dd0aa463 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When verifying which classes are available in a klib (swiftPMImport vs bundled third-party klib)" ;
    oc:directiveContent "klib dump-metadata-signatures /path/to/library.klib | grep \"ClassName\"" .

oc:kn_efbcf14f a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When automatic integrateEmbedAndSign/integrateLinkagePackage fails" ;
    oc:directiveContent "1. Open .xcodeproj (or .xcworkspace if non-KMP CocoaPods remain) 2. Add 'Compile Kotlin' run script phase BEFORE 'Compile Sources': cd \"$SRCROOT/..\" && ./gradlew :moduleName:embedAndSignAppleFrameworkForXcode 3. Set ENABLE_USER_SCRIPT_SANDBOXING = NO 4. Run ./gradlew --stop 5. Add local package: ../moduleName/_internal_linkage_SwiftPMImport" ;
    oc:stepOrder 2 .

