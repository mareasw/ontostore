                                    oc:codeContent """buildscript {
    dependencies.constraints {
        "classpath"("org.jetbrains.kotlin:kotlin-gradle-plugin:<kotlin-version>!!")
    }
}
""" ;
                                    oc:codeLanguage "kotlin" ;
