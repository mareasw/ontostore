                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**Symptom:** Xcode build succeeds but produces no Kotlin framework. The app crashes at runtime with missing module errors." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
