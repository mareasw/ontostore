                            oc:sectionTitle "Import Not Found After Migration" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**Symptom:** Unresolved reference to `swiftPMDependencies` in build.gradle.kts" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
