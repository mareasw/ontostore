                            oc:sectionTitle "\"swiftPMDependencies not found\"" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**Symptom:** IDE fails to sync project after adding swiftPMDependencies" ],
                                _:ref_0f25659f7139460a,
                                [ a oc:Paragraph ;
