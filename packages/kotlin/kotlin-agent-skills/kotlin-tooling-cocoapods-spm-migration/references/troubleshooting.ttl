                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Solution:** Add buildscript constraint to root build.gradle.kts:" ] ;
                            oc:sectionLevel 3 ;
