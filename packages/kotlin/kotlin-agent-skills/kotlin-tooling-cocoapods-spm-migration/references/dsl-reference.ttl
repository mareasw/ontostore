oc:kn_0206364e a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When declaring a remote Swift package via Swift Package Registry" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """swiftPackage(
    repository = id("scope.package-name"),
    version = from("1.0.0"),
    products = listOf(product("ProductName")),
)""" .

oc:kn_04321ff8 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating a new local Swift package wrapper" ;
    oc:directiveContent "cd /path/to/shared && mkdir LocalPackage && cd LocalPackage && swift package init --type library --name LocalPackage" .

oc:kn_13c5d03c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring IDE integration with the KMP IntelliJ plugin" ;
    oc:directiveContent "xcodeProjectPathForKmpIJPlugin must point to the .xcodeproj file (not .xcworkspace) for KMP IntelliJ plugin IDE integration to work correctly." ;
    oc:hasRationale "The plugin resolves SwiftPM dependencies relative to the xcodeproj, not the workspace." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4094f063 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When declaring a remote Swift package dependency via Git URL" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """swiftPackage(
    url = url("https://github.com/owner/repo.git"),
    version = from("1.0.0"),
    products = listOf(product("ProductName")),
)""" .

oc:kn_4696683f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying package versions in swiftPackage()" ;
    oc:directiveContent "Use from() for most packages (minimum version, allows compatible updates), exact() for strict pinning (e.g., GoogleMaps), branch() for development, and revision() for pinning specific commits." ;
    oc:hasRationale "Matching the version strategy to the use case balances stability with flexibility — exact pins prevent unexpected breakage, while from() allows beneficial updates." .

oc:kn_59be20d3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring swiftPMDependencies with default auto-discovery" ;
    oc:directiveContent "Never use importedClangModules when discoverModulesImplicitly is true — the parameter is ignored and will mislead configuration." ;
    oc:hasRationale "Implicit discovery overrides explicit module lists, so specifying importedClangModules creates dead configuration that can cause confusion during debugging." ;
    oc:severityLevel "HIGH" .

oc:kn_5fef7d05 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When a Swift package has transitive dependencies" ;
    oc:directiveContent "SwiftPM transitive dependencies are resolved and provisioned automatically by the Kotlin Gradle Plugin during test execution or framework linking. Explicit declarations are only needed to pin specific transitive versions." ;
    oc:hasRationale "Understanding automatic transitive resolution prevents redundant explicit declarations while enabling version pinning when needed." .

oc:kn_699354f5 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When writing the full swiftPMDependencies DSL block" ;
    oc:directiveContent """swiftPMDependencies {
    iosDeploymentVersion.set("{ios_version}")
    macosDeploymentVersion.set("{macos_version}")
    xcodeProjectPathForKmpIJPlugin.set(layout.projectDirectory.file("{path_to_xcodeproj}"))
    discoverModulesImplicitly = {true|false}
    swiftPackage(url = url("{git_url}"), version = from("{version}"), products = listOf(product("{product}")))
    localSwiftPackage(directory = layout.projectDirectory.dir("{path}"), products = listOf("{product}"))
}""" ;
    oc:templateVariables "git_url",
        "ios_version",
        "macos_version",
        "path",
        "path_to_xcodeproj",
        "product",
        "version" .

oc:kn_7fa1aadf a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Always when configuring SwiftPM dependencies" ;
    oc:directiveContent "1. Declare swiftPMDependencies {} block inside kotlin {} block. 2. Set deployment versions (iosDeploymentVersion, etc.). 3. Set xcodeProjectPathForKmpIJPlugin if using KMP IntelliJ plugin. 4. Add swiftPackage() or localSwiftPackage() declarations with url/repository, version, and products. 5. Disable discoverModulesImplicitly and set importedClangModules for Firebase or packages with module name mismatches. 6. Add platform constraints via product(\"name\", platforms = setOf(...)) for platform-specific packages." ;
    oc:stepOrder 1 .

oc:kn_a904a4d5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When auto-discovery is disabled or product-to-module name mapping is non-trivial" ;
    oc:directiveContent "Use importedClangModules when the Clang module name differs from the product name (e.g., FirebaseFirestore product → FirebaseFirestoreInternal module), or when discoverModulesImplicitly is false." ;
    oc:hasRationale "Module name mismatches cause cinterop failures that are hard to diagnose without explicit module declarations." .

oc:kn_b5e4fc58 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When adding Firebase packages to swiftPMDependencies" ;
    oc:directiveContent "Firebase's transitive C++ dependencies (gRPC, abseil, leveldb, BoringSSL) contain Clang modules that fail cinterop generation. Set discoverModulesImplicitly = false and explicitly list only needed Firebase modules in importedClangModules." ;
    oc:hasRationale "Firebase is the primary known package where implicit discovery breaks due to its large transitive dependency tree containing incompatible C++ modules." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ba45f6a2 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When importing and using a SwiftPM module in Kotlin code" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """import swiftPMImport.<group>.<module>.HelloFromLocalPackage

@OptIn(kotlinx.cinterop.ExperimentalForeignApi::class)
fun useLocalPackage() {
    HelloFromLocalPackage().hello()
}""" .

oc:kn_c4b4bf02 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When declaring a local Swift package dependency" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """localSwiftPackage(
    directory = layout.projectDirectory.dir("../LocalPackage"),
    products = listOf("LocalPackage"),
)""" .

