                            oc:textContent "This enables the IDE to properly resolve SwiftPM dependencies and provide code completion. The path should point to the `.xcodeproj` file (not `.xcworkspace`)." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "If you are using the KMP IntelliJ plugin to build the iOS application, specify the path to the `.xcodeproj` that has the `embedAndSignAppleFrameworkForXcode` integration:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """kotlin {
    listOf(
        iosArm64(),
        iosSimulatorArm64(),
        iosX64(),
    ).forEach { iosTarget ->
        iosTarget.binaries.framework {
            baseName = "Shared"
            isStatic = true
        }
    }

    swiftPMDependencies {
        xcodeProjectPathForKmpIJPlugin.set(
            layout.projectDirectory.file("../iosApp/iosApp.xcodeproj")
        )
    }
}
""" ;
