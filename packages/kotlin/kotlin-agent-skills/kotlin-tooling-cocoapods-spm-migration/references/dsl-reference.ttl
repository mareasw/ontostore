oc:kn_1d50ebbd a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When adding Firebase packages to swiftPMDependencies" ;
    oc:directiveContent "Set discoverModulesImplicitly = false when using Firebase. Firebase's transitive C++ dependencies (gRPC, abseil, leveldb, BoringSSL) contain Clang modules that fail cinterop generation." ;
    oc:hasRationale "Implicit module discovery will attempt to import all transitive Clang modules from Firebase, causing cinterop failures on C++ dependencies that are not compatible with Kotlin/Native cinterop tooling" ;
    oc:severityLevel "CRITICAL" .

oc:kn_3421af71 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When configuring IDE integration in swiftPMDependencies" ;
    oc:directiveContent "The xcodeProjectPathForKmpIJPlugin should point to the .xcodeproj file (not .xcworkspace) for proper IDE integration with the KMP IntelliJ plugin." ;
    oc:hasRationale "The KMP IntelliJ plugin requires the .xcodeproj path specifically to resolve SwiftPM dependencies and provide code completion; pointing to .xcworkspace will not work" ;
    oc:severityLevel "MEDIUM" .

oc:kn_360d67be a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When integrating Swift-only libraries into a KMP project" ;
    oc:directiveContent "Use localSwiftPackage to create Swift/ObjC wrappers around Swift-only libraries that cannot be consumed directly by Kotlin/Native cinterop." ;
    oc:hasRationale "Kotlin/Native cinterop can only consume C/ObjC headers; Swift-only APIs need a local Swift package wrapper that exposes them via ObjC-compatible interfaces" ;
    oc:severityLevel "HIGH" .

oc:kn_89f157a8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring module imports in swiftPMDependencies" ;
    oc:directiveContent "When discoverModulesImplicitly = true, the importedClangModules parameter is ignored entirely. Only set importedClangModules when auto-discovery is disabled." ;
    oc:hasRationale "Prevents confusion about why explicit module lists are not taking effect during automatic discovery mode" ;
    oc:severityLevel "HIGH" .

oc:kn_c96d6b23 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a version specification strategy for SwiftPM packages" ;
    oc:directiveContent "Use from() for most packages (minimum version), exact() for strict pinning (e.g., GoogleMaps), branch() for development, and revision() for pinning specific commits." ;
    oc:hasRationale "Matching the version strategy to the use case ensures reproducible builds while allowing compatible updates for well-behaved packages" ;
    oc:severityLevel "MEDIUM" .

