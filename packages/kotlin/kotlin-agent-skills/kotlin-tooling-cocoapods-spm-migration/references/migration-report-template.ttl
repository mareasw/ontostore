@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_cocoapods_spm_migration_migration_report_template a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "migration-report-template" ;
    skos:broader "report template" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/kotlin/kotlin-agent-skills/kotlin-tooling-cocoapods-spm-migration" ;
    oc:contentHash "a728c8c9b79ad8fecde3902af6d1810dae2e142b50b486fd9c49e129b3bead70" ;
    oc:differentia "that documents a CocoaPods-to-SwiftPM migration with structured sections for each phase, errors, decisions, and file changes" ;
    oc:extends oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_cocoapods_spm_migration ;
    oc:handlesFailure oc:ReportGenerationFailed ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_30b4bd3b,
        oc:kn_7886b17e,
        oc:kn_9c72ba83,
        oc:kn_f8612f39,
        oc:kn_fcd70570 ;
    oc:isUserInvocable false ;
    oc:nature "Work" ;
    oc:requiresState oc:MigrationCompleted ;
    oc:resolvesIntent "create structured migration summary",
        "document migration outcome",
        "generate migration report" ;
    oc:yieldsState oc:MigrationReportCreated .

oc:kn_30b4bd3b a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When documenting errors in the Errors Encountered section" ;
    oc:directiveContent "Flag every error encountered as generalizable (Yes/No) to indicate whether it is likely to affect other projects." ;
    oc:hasRationale "Generalizable error patterns feed back into migration tooling improvements and help other projects anticipate the same issues." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7886b17e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When structuring the entire migration report" ;
    oc:directiveContent "Use consistent markdown headings, tables, and the Error #N format so the report is machine-parseable by AI agents." ;
    oc:hasRationale "Structured formatting enables automated extraction of migration patterns, common errors, and decision rationales for improving tooling." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9c72ba83 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any section of the migration report" ;
    oc:directiveContent "Every migration report must include actual file paths, class names, error messages, and before/after code snippets rather than vague descriptions." ;
    oc:hasRationale "Specific artifacts allow future readers and AI agents to trace exactly what changed and why, enabling reproducibility and debugging." ;
    oc:severityLevel "HIGH" .

oc:kn_f8612f39 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When deciding whether to write the report" ;
    oc:directiveContent "The report must be written regardless of migration success or failure — it documents the full journey including errors and incomplete states." ;
    oc:hasRationale "Failed migrations contain valuable diagnostic information; skipping the report on failure loses critical debugging context for humans and agents." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fcd70570 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When documenting Phase 4 import transformations" ;
    oc:directiveContent "Preserved cocoapods.* imports must be explicitly marked and explained with the library name that provides the bundled klib." ;
    oc:hasRationale "Preserved cocoapods imports are the most confusing aspect of the migration; explicit annotation prevents misinterpretation and regressions." ;
    oc:severityLevel "HIGH" .

