        oc:kn_4ec78556,
        oc:kn_a0d49318,
        oc:kn_e6845260,
        oc:kn_e9451ff6 ;
    oc:isUserInvocable true ;
    oc:nature "Template" ;
    oc:resolvesIntent "document migration outcome",
        "generate migration report",
        "record migration errors and decisions" .

oc:kn_082ee1e1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "when writing any section of the migration report" ;
    oc:directiveContent "Use consistent markdown headings, tables, and Error #N format so AI agents can extract structured data from the report." ;
    oc:hasRationale "Machine-parseable formatting enables tooling to aggregate migration reports across projects and improve the migration process." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4ec78556 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "always, after migration completes or fails" ;
    oc:directiveContent "Write MIGRATION_REPORT.md after every migration attempt — successful or failed — as both human-readable documentation and structured input for AI agents." ;
    oc:hasRationale "The report captures institutional knowledge about the migration that would otherwise be lost, and its structured format enables automated analysis." ;
    oc:severityLevel "HIGH" .

oc:kn_a0d49318 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "when documenting each error in the Errors Encountered section" ;
    oc:directiveContent "Flag every error as generalizable (Yes/No) to indicate whether it is likely to affect other projects and improve migration tooling." ;
    oc:hasRationale "Generalizable error patterns feed back into migration guide improvements and proactive detection." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e6845260 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "when documenting migration steps, errors, and file changes" ;
    oc:directiveContent "Include actual file paths, class names, and error messages. Avoid vague statements. Show before/after code snippets for non-trivial changes." ;
    oc:hasRationale "Specific artifacts enable future readers and agents to reproduce or understand the exact transformations performed." ;
    oc:severityLevel "HIGH" .

oc:kn_e9451ff6 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "when documenting import transformations in Phase 4" ;
    oc:directiveContent "Clearly mark preserved cocoapods.* imports and explain why each was kept and which library provides the bundled klib." ;
    oc:hasRationale "Preserved cocoapods imports are the most confusing aspect for future readers — explicit rationale prevents misdiagnosis." ;
    oc:severityLevel "HIGH" .

