    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:CocoaPodsConfigured,
        oc:ProjectCompiles ;
    oc:resolvesIntent "convert cocoapods imports to swiftPMImport",
        "deintegrate CocoaPods from KMP project",
        "migrate KMP from CocoaPods to SwiftPM",
        "reconfigure Xcode project for SwiftPM",
        "replace pod() with swiftPackage()" ;
    oc:yieldsState oc:CocoaPodsDeintegrated,
        oc:MigrationReportWritten,
        oc:SwiftPMConfigured .

oc:kn_0288679a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating library suites with shared transitive dependencies" ;
    oc:directiveContent "Do NOT mix the same library suite (e.g., all Firebase products) across CocoaPods and SPM. Move all pods from that suite to SPM at once, including Swift-only pods." ;
    oc:hasRationale "Libraries sharing a common repository have shared transitive dependencies. Having some linked via CocoaPods and others via SPM causes duplicate/conflicting symbols and dyld crashes at runtime." ;
    oc:severityLevel "CRITICAL" .

oc:kn_1a90c9ab a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding SwiftPM package declarations in build.gradle.kts" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """swiftPMDependencies {
    iosDeploymentVersion.set("16.0")
    swiftPackage(
        url = url("https://github.com/owner/repo.git"),
        version = from("1.0.0"),
        products = listOf(product("ProductName")),
        importedClangModules = listOf("ModuleName")
    )
}""" .

oc:kn_247a172a a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When transforming Kotlin source imports in Phase 4" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """// Import transformation formula:
// BEFORE: import cocoapods.FirebaseAnalytics.FIRAnalytics
// AFTER:  import swiftPMImport.org.example.myproject.shared.FIRAnalytics
// Where: dashes in group/module become dots, underscores preserved""" .

oc:kn_3f5c2650 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When automatic integration command discovery fails" ;
    oc:directiveContent "If xcodebuild approach fails in Phase 5.1, use the manual integration command discovery script: find iOS dir, locate .xcodeproj, find KMP module, then run integrateEmbedAndSign and integrateLinkagePackage directly with environment variables." ;
    oc:hasRationale "The xcodebuild approach depends on a specific error message format that may not appear in all project configurations. The manual script discovers paths independently." ;
    oc:severityLevel "MEDIUM" .

oc:kn_56796d95 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing bulk import replacement in Phase 4" ;
    oc:directiveContent "Never replace cocoapods.* imports that resolve to third-party KMP libraries' bundled cinterop klibs (e.g., KMPNotifier's cocoapods.FirebaseMessaging). These must remain as-is." ;
    oc:hasRationale "The swiftPMDependencies cinterop generator skips modules already provided by a dependency's klib, so swiftPMImport.* for those classes will fail with 'Unresolved reference'. The cocoapods prefix is the package namespace in the library's published klib, not an actual CocoaPods dependency." ;
    oc:severityLevel "CRITICAL" .

oc:kn_670a5aa0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When moving framework configuration from cocoapods block to binaries API (Phase 3.3)" ;
    oc:directiveContent "Use isStatic = true for the KMP framework. Dynamic frameworks have known edge cases with SwiftPM import that cause linker errors, dyld crashes, or duplicate class warnings. It is required when using dev.gitlive:firebase-*." ;
    oc:hasRationale "Static frameworks embed all symbols and avoid runtime dyld issues with SPM's static library products. Dynamic frameworks create LC_LOAD_DYLIB entries that fail at runtime when SPM frameworks aren't in the app bundle." ;
    oc:severityLevel "HIGH" .

oc:kn_831f7e24 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When specifying SPM package versions in Phase 3.2" ;
    oc:directiveContent "Match version constraint semantics from the cocoapods {} block. CocoaPods version='X.Y.Z' (exact) → exact('X.Y.Z') in SPM. CocoaPods version='~> X.Y' (optimistic) → from('X.Y.0') in SPM. Using from() for an exact pin can resolve to a newer version that breaks cinterop APIs." ;
    oc:hasRationale "Version semantics mismatch can silently upgrade dependencies, causing removed symbols or changed signatures that break cinterop at compile time." ;
    oc:severityLevel "MEDIUM" .

oc:kn_90452a4c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "After running integrateEmbedAndSign in Phase 5.1" ;
    oc:directiveContent "Disable User Script Sandboxing (ENABLE_USER_SCRIPT_SANDBOXING = NO) in the .xcodeproj. Xcode 16+ enables it by default, which prevents the Gradle build phase from writing to the project directory." ;
    oc:hasRationale "Without disabling sandboxing, the Gradle build phase script cannot write generated framework files, causing checkSandboxAndWriteProtection to fail." ;
    oc:severityLevel "HIGH" .

oc:kn_95ff8779 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When running integrateEmbedAndSign in Phase 5" ;
    oc:directiveContent "EmbedAndSign disablers (e.g., taskGraph.whenReady filters that disable tasks containing 'EmbedAndSign') break the migration because integrateEmbedAndSign gets disabled too. Remove them before Phase 5." ;
    oc:hasRationale "These disablers were CocoaPods-era workarounds that inadvertently prevent the new SwiftPM integration tasks from modifying the Xcode project." ;
    oc:severityLevel "HIGH" .

oc:kn_992fb1e6 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before Phase 1 migration begins" ;
    oc:directiveContent "Before starting migration: verify the module compiles with ./gradlew :moduleName:compileKotlinIosSimulatorArm64, confirm Kotlin version has Swift Import support, and check for EmbedAndSign disablers, deprecated gradle.properties, and bundled klib dependencies." ;
    oc:hasRationale "Pre-migration verification establishes a known-good baseline and identifies blockers that would cause silent failures later." ;
    oc:severityLevel "HIGH" .

oc:kn_aeab9eb7 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Full migration execution" ;
    oc:directiveContent "1. Pre-migration analysis (find pods, imports, blockers) → 2. Gradle config (repos, Kotlin version) → 3. Add swiftPMDependencies alongside cocoapods → 4. Transform imports cocoapods.* → swiftPMImport.* → 5. Reconfigure Xcode + deintegrate CocoaPods → 6. Remove CocoaPods plugin/block from Gradle → 7. Verify builds (iterate on failure) → 8. Write MIGRATION_REPORT.md" ;
    oc:stepOrder 1 .

oc:kn_b6c04768 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "Phase 7 verification" ;
    oc:directiveContent "After migration: run ./gradlew :moduleName:compileKotlinIosSimulatorArm64, then ./gradlew :moduleName:linkDebugFrameworkIosSimulatorArm64, then xcodebuild with the project. Do NOT write the migration report until the build succeeds." ;
    oc:hasRationale "Three-stage verification catches issues at each level: Kotlin source correctness, framework linking, and full Xcode integration." ;
    oc:severityLevel "HIGH" .

oc:kn_b7ab8878 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding swiftPMDependencies block during Phase 3" ;
    oc:directiveContent "Never remove the cocoapods {} block or kotlin('native.cocoapods') plugin until Phase 6. Add swiftPMDependencies {} alongside the existing CocoaPods setup first, reconfigure Xcode, and only then remove CocoaPods." ;
    oc:hasRationale "Premature removal of CocoaPods breaks the build before SwiftPM is fully configured and Xcode is reconfigured, leaving the project in a broken intermediate state." ;
    oc:severityLevel "CRITICAL" .

oc:kn_cb087891 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When adding group property in Phase 3.1" ;
    oc:directiveContent "The group property in build.gradle.kts is used both as the SwiftPM import namespace and as the Compose Multiplatform resources namespace. Adding or changing group may break existing Compose resource accessor call sites." ;
    oc:hasRationale "Compose resources use group as the namespace for generated resource accessors (Res.string.*, Res.drawable.*). Changing it requires updating all call sites." ;
    oc:severityLevel "HIGH" .

oc:kn_d0a8822c a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When writing MIGRATION_REPORT.md after successful migration" ;
    oc:directiveContent """# Migration Report: CocoaPods to SwiftPM Import
**Project:** {project_name}
**Module migrated:** {module_name}
**Date:** {date}
**Kotlin version:** {old_version} → {new_version}
**Status:** {status}

## Pre-Migration State | CocoaPods Dependencies | Framework Configuration | Kotlin Imports
## Migration Steps | Phase 2-6 changes with before/after
## Import Transformations | Table: File, Before, After, Source
## Errors Encountered | Error #N: Phase, Symptom, Root cause, Fix, Generalizable
## Non-Trivial Decisions | isStatic, preserved imports, search paths
## Files Changed | Grouped: Gradle, Kotlin, Xcode, Created, Deleted""" ;
    oc:templateVariables "date",
        "module_name",
        "new_version",
        "old_version",
        "project_name",
        "status" .

oc:kn_d2c5afe2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring Firebase swiftPackage() in swiftPMDependencies" ;
    oc:directiveContent "For Firebase, always set discoverModulesImplicitly = false and explicitly list only the needed Clang modules in importedClangModules. This prevents cinterop failures on C++ transitive dependencies (gRPC, abseil, leveldb, BoringSSL)." ;
    oc:hasRationale "Firebase's transitive C++ dependencies contain Clang modules that fail cinterop generation. Implicit discovery attempts to process all of them and fails." ;
    oc:severityLevel "HIGH" .

oc:kn_d4c4dd4a a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before starting migration" ;
    oc:directiveContent "Kotlin version with Swift Import support (2.4.0-Beta1 or later) and Xcode 16.4+ must be installed" .

oc:kn_dc845506 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Throughout the entire migration" ;
    oc:directiveContent "Do NOT upgrade Gradle wrapper version, update KSP, or update any other dependencies during this migration. Only change what is explicitly listed in the migration phases." ;
    oc:hasRationale "Introducing unrelated changes during migration makes it impossible to distinguish migration issues from version upgrade issues." ;
    oc:severityLevel "HIGH" .

oc:kn_e26265ba a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When Phase 7 verification fails" ;
    oc:directiveContent "Do NOT revert the migration as a first response to build failures. Read the error log, re-check Phases 2-6, and consult troubleshooting.md. Fix the issue and iterate." ;
    oc:hasRationale "Reverting discards all migration work. Most build failures have specific fixes (wrong import namespace, missing importedClangModules, sandboxing not disabled, etc.) that don't require a full rollback." ;
    oc:severityLevel "HIGH" .

