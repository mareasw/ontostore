oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_cocoapods_spm_migration a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "kotlin-tooling-cocoapods-spm-migration" ;
    skos:broader "Migration procedure" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/kotlin/kotlin-agent-skills/kotlin-tooling-cocoapods-spm-migration" ;
    oc:contentHash "5b651616cbac5afe234e2a6aa98e38f672aa7d7b05ac21b40ba6c2e8d76d3e4d" ;
    oc:differentia "that replaces Kotlin Multiplatform CocoaPods dependency management with Swift Package Manager (swiftPMDependencies DSL) through an 8-phase process covering Gradle reconfiguration, import transformation, Xcode project reconfiguration, and CocoaPods deintegration" ;
    oc:handlesFailure oc:BuildFailed,
        oc:CinteropGenerationFailed,
        oc:ImportResolutionFailed,
        oc:LinkerError,
        oc:SandboxingError ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "KMP project root directory with CocoaPods configuration" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Migrate KMP projects from CocoaPods (kotlin(\"native.cocoapods\")) to Swift Package Manager (swiftPMDependencies DSL) — replaces pod() with swiftPackage(), transforms cocoapods.* imports to swiftPMImport.*, and reconfigures the Xcode project." ;
    oc:hasName "kotlin-tooling-cocoapods-spm-migration" ;
    oc:hasRequirement oc:req_1261f9c0,
        oc:req_550c8ab9,
        oc:req_5f7fd453,
        oc:req_64bd7a34,
        oc:req_683cd05a,
        oc:req_71152954,
        oc:req_bb010bb0,
        oc:req_c55fd898 ;
    oc:impartsKnowledge oc:kn_54fd404a,
        oc:kn_665adb03,
        oc:kn_99a8bbc5,
        oc:kn_a09db9fb,
        oc:kn_b3fda703,
        oc:kn_b9c18a47,
        oc:kn_cbc1f8a8,
        oc:kn_e67f53e7,
        oc:kn_e7af5b18,
        oc:kn_ed8f712c,
        oc:kn_f5bc86f1,
        oc:kn_fd757eca ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:FileExists,
        oc:NetworkAvailable,
        oc:SystemAuthenticated ;
    oc:resolvesIntent "convert pod() declarations to swiftPackage() declarations",
        "deintegrate CocoaPods from KMP project",
        "migrate KMP project from CocoaPods to SwiftPM",
        "reconfigure Xcode project for SwiftPM integration",
        "replace cocoapods plugin with swiftPMDependencies",
        "transform cocoapods.* imports to swiftPMImport.*" ;
    oc:yieldsState oc:CocoaPodsDeintegrated,
        oc:MigrationReportWritten,
        oc:SwiftPMConfigured,
        oc:XcodeProjectReconfigured .

oc:kn_54fd404a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring binaries.framework {} after moving it out of the cocoapods block (Phase 3.3)" ;
    oc:directiveContent "Use isStatic = true for the KMP framework when migrating to SwiftPM, especially when using dev.gitlive:firebase-* or similar CocoaPods-era wrapper libraries. Dynamic frameworks have known edge cases causing linker errors, dyld crashes, or duplicate class warnings." ;
    oc:hasRationale "Firebase SPM products are static libraries — their .framework bundles are not embedded in the app bundle. Dynamic KMP frameworks create LC_LOAD_DYLIB entries that dyld cannot resolve at runtime." ;
    oc:severityLevel "HIGH" .

oc:kn_665adb03 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "Phase 7 verification when any build step fails" ;
    oc:directiveContent "Do NOT revert the migration as a first response to build failures. Read the error log, re-check Phases 2-6, consult troubleshooting reference, and iterate on fixes. Only roll back via git checkout as a last resort." ;
    oc:hasRationale "Reverting throws away all completed migration work. Most build failures are caused by small configuration issues (missing importedClangModules, wrong import paths, sandboxing not disabled) that can be fixed incrementally." ;
    oc:severityLevel "HIGH" .

oc:kn_99a8bbc5 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "Phase 8 — only after Phase 7 verification succeeds and the full application builds" ;
    oc:directiveContent "After migration, write a comprehensive MIGRATION_REPORT.md documenting pre-migration state, exact changes per phase, all import transformations (clearly marking preserved cocoapods.* imports), errors encountered with root causes, non-trivial decisions, and complete file change list." ;
    oc:hasRationale "The report serves as both human-readable documentation and structured input for future analysis. Preserved cocoapods.* imports are the most confusing aspect and must be clearly explained." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a09db9fb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring swiftPMDependencies for Firebase or other packages with C++ transitive dependencies" ;
    oc:directiveContent "Set discoverModulesImplicitly = false when using Firebase. Explicitly list only the needed Firebase Clang modules in importedClangModules to avoid cinterop failures on C++ transitive dependencies (gRPC, abseil, leveldb, BoringSSL)." ;
    oc:hasRationale "Firebase's transitive C++ dependencies contain Clang modules that are incompatible with cinterop generation, causing build failures when implicit discovery is enabled." ;
    oc:severityLevel "HIGH" .

oc:kn_b3fda703 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Phase 4 import transformations — always cross-reference with Phase 1 step 1.3 bundled klib detection" ;
    oc:directiveContent "Do NOT replace cocoapods.* imports that resolve to third-party KMP libraries' bundled cinterop klibs (e.g., KMPNotifier's cocoapods.FirebaseMessaging). These imports must remain as-is because swiftPMDependencies skips generating bindings for modules already provided by dependency klibs." ;
    oc:hasRationale "Replacing bundled klib imports with swiftPMImport.* causes 'Unresolved reference' errors because no swiftPMImport bindings are generated for those Clang modules — the third-party library's klib is the sole provider." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b9c18a47 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always during Phases 3-5 of migration" ;
    oc:directiveContent "Keep the cocoapods {} block and kotlin('native.cocoapods') plugin active until Phase 6. The migration adds swiftPMDependencies {} alongside the existing CocoaPods setup first, reconfigures Xcode, and only then removes CocoaPods." ;
    oc:hasRationale "Removing CocoaPods before the iOS project is fully reconfigured breaks the build — both systems must coexist temporarily to maintain a working state at each phase." ;
    oc:severityLevel "CRITICAL" .

oc:kn_cbc1f8a8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Phase 1 step 9 pre-migration analysis" ;
    oc:directiveContent "Cross-reference the Podfile against the Gradle cocoapods {} block to find Podfile-only dependencies. These were linked into the app by CocoaPods and must be migrated to swiftPMDependencies — dropping them silently causes obscure runtime linkage errors." ;
    oc:hasRationale "Some iOS-only dependencies may exist in the Podfile without corresponding Gradle pod() declarations, but they were still linked. Omitting them from swiftPMDependencies causes missing symbols at runtime that are hard to diagnose." ;
    oc:severityLevel "MEDIUM" .

oc:kn_e67f53e7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating any library family that shares a common repository and transitive dependencies (especially Firebase)" ;
    oc:directiveContent "Do not mix the same library suite (e.g., all Firebase products) across CocoaPods and SPM. Migrate all pods from that suite to SPM at once, including Swift-only pods that Kotlin doesn't use directly." ;
    oc:hasRationale "Libraries sharing a repository have shared transitive dependencies. Having some via CocoaPods and others via SPM causes duplicate/conflicting symbols and dyld crashes at runtime (e.g., 'Symbol not found: _OBJC_CLASS_$_FIRFirestore')." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e7af5b18 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Phase 1 pre-migration analysis — always before making any changes" ;
    oc:directiveContent "Before starting migration, verify the project builds: run ./gradlew :moduleName:compileKotlinIosSimulatorArm64 to confirm Kotlin code compiles, and optionally build the iOS app via xcodebuild." ;
    oc:hasRationale "Migrating a broken project makes it impossible to distinguish pre-existing issues from migration-caused errors, leading to wasted debugging effort." ;
    oc:severityLevel "HIGH" .

oc:kn_ed8f712c a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When specifying importedClangModules for Firebase products in swiftPMDependencies" ;
    oc:directiveContent "Several Firebase products expose ObjC headers through Clang modules whose names differ from the SPM product name: FirebaseDatabase→FirebaseDatabaseInternal, FirebaseFirestore→FirebaseFirestoreInternal, FirebaseRemoteConfig→FirebaseRemoteConfigInternal, FirebaseInAppMessaging→FirebaseInAppMessagingInternal." ;
    oc:hasRationale "Using the product name instead of the internal Clang module name causes 'Unresolved reference' errors because the KMP compiler cannot discover the Objective-C headers." ;
    oc:severityLevel "HIGH" .

oc:kn_f5bc86f1 a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "When adding the group property in Phase 3.1 for projects using Compose Multiplatform resources" ;
    oc:directiveContent "The group property in build.gradle.kts serves double duty: it defines the swiftPMImport namespace AND the Compose Multiplatform resources namespace (Res.string.*, Res.drawable.*). Adding or changing group may break existing Compose resource accessor call sites." ;
    oc:hasRationale "Compose resource accessors are generated based on the group property — changing it changes all generated accessor paths, requiring updates across the entire codebase." ;
    oc:severityLevel "HIGH" .

oc:kn_fd757eca a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When mapping pod version constraints to SPM version specifications in Phase 3.2" ;
    oc:directiveContent "Match version constraint semantics from the cocoapods {} block when creating swiftPackage() declarations: exact version ('1.2.3') → exact('1.2.3'), optimistic ('~> 1.2') → from('1.2.0'). Using from() for an exact CocoaPods version can resolve to a newer version that breaks cinterop APIs." ;
    oc:hasRationale "Version semantics mismatch can silently upgrade dependencies, introducing removed symbols or changed signatures that break cinterop bindings at compile time." ;
    oc:severityLevel "MEDIUM" .

