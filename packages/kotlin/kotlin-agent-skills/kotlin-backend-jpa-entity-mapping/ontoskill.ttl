oc:kn_5b1ca3e1 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When working with entity relationships, lazy loading, or batch operations" ;
    oc:directiveContent "Bidirectional associations must maintain both sides in domain methods. toString, debug logging, JSON serialization, and IDE inspection can all trigger lazy loads. Bulk updates/deletes bypass persistence context and lifecycle callbacks." ;
    oc:hasRationale "Half-updated bidirectional graphs cause subtle bugs; unintended lazy load triggers cause LazyInitializationException; bulk operations leave stale reads" ;
    oc:severityLevel "MEDIUM" .

oc:kn_630e007d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When investigating performance issues in JPA queries" ;
    oc:directiveContent "Diagnose N+1 by inspecting actual query count or SQL logs, not by guessing from annotations. Prefer targeted fetch solutions: @EntityGraph, JOIN FETCH, batch fetching, or DTO projection." ;
    oc:hasRationale "Guessing from annotations is unreliable; actual SQL observation is the only trustworthy diagnostic" ;
    oc:severityLevel "MEDIUM" .

oc:kn_a1295334 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When designing idempotent APIs or preventing duplicate records" ;
    oc:directiveContent "Enforce uniqueness at both database constraint and application check layers. Database constraint catches race conditions; application check provides clean error messages." ;
    oc:hasRationale "Application checks alone have race conditions; database constraints alone produce raw DataIntegrityViolationException. Both together cover the common case and the race." ;
    oc:severityLevel "HIGH" .

oc:kn_d224da19 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing equals/hashCode/toString on any JPA entity" ;
    oc:directiveContent "Entity equals must compare by ID only, hashCode must return a class-based constant, and toString must exclude lazy-loaded relations to prevent LazyInitializationException." ;
    oc:hasRationale "ID-based equality is stable under dirty tracking and proxy unwrapping; class-based hashCode avoids Set/Map corruption after persist" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d2c94442 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before applying any JPA entity patterns from this skill" ;
    oc:directiveContent "Project must use Spring Data JPA with Hibernate and have kotlin(\"plugin.jpa\") compiler plugin configured for no-arg constructor support." ;
    oc:hasRationale "JPA entities require no-arg constructors; Kotlin needs the JPA compiler plugin to generate them automatically" .

oc:kn_e389d24c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating or reviewing any JPA entity in Kotlin" ;
    oc:directiveContent "Never use Kotlin data class for JPA entities. Use regular class instead. Data class generates all-field equals/hashCode that corrupts Set/Map membership after state changes, and copy() creates detached duplicates of managed entities." ;
    oc:hasRationale "Hibernate relies on identity semantics that data class breaks; equals/hashCode over all fields causes hash instability and proxy incompatibility" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e8b2bd7f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When diagnosing lazy loading issues or designing API layers" ;
    oc:directiveContent "Do not recommend FetchType.EAGER everywhere to silence lazy loading symptoms. Do not expose entities directly through API responses by default." ;
    oc:hasRationale "Eager fetching masks the real problem and causes unnecessary data loading; exposing entities directly leaks persistence concerns into the API contract" ;
    oc:severityLevel "HIGH" .

oc:kn_f7cce0f6 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before creating JPA entities in a Kotlin project" ;
    oc:directiveContent "Verify kotlin(\"plugin.jpa\") or equivalent no-arg support when JPA entities exist. Verify classes and members are compatible with proxying where needed." ;
    oc:hasRationale "JPA requires no-arg constructors and proxyable classes; Kotlin classes are final by default and need compiler plugins" ;
    oc:severityLevel "HIGH" .

_:ref_0509f56b5cb5e51e a oc:WorkflowStep ;
    dcterms:description "Enable SQL logging and observe actual query count during the problematic operation" ;
    oc:expectedOutcome "Exact number and content of SQL queries is visible" ;
    oc:stepId "observe-queries" .

_:ref_53d1ddac5a915e2f a oc:WorkflowStep ;
    dcterms:description "Apply targeted fetch solution: @EntityGraph, JOIN FETCH, batch fetching, or DTO projection" ;
    oc:expectedOutcome "Query count reduced to expected number; explain how fetch plan changed" ;
    oc:stepDependsOn _:ref_e64ec0f701cb90e9 ;
    oc:stepId "apply-fetch-fix" .

_:ref_e64ec0f701cb90e9 a oc:WorkflowStep ;
    dcterms:description "Confirm N+1 pattern: one query for parent entities plus N queries for lazy-loaded associations" ;
    oc:expectedOutcome "Root cause association and access point identified" ;
    oc:stepDependsOn _:ref_0509f56b5cb5e51e ;
    oc:stepId "identify-n-plus-1" .

_:ref_f53b972cad0da5a9 a oc:WorkflowStep ;
    dcterms:description "Verify kotlin(\"plugin.jpa\") compiler plugin is configured in build.gradle.kts" ;
    oc:expectedOutcome "No-arg constructor generation is enabled for JPA entities" ;
    oc:stepId "verify-plugins" .

_:ref_48c808354ad99b14 a oc:WorkflowStep ;
    dcterms:description "Create regular (non-data) class with @Entity annotation, mutable constructor params for columns, and val id with @GeneratedValue default 0" ;
    oc:expectedOutcome "Entity class compiles and Hibernate can instantiate it" ;
    oc:stepDependsOn _:ref_f53b972cad0da5a9 ;
    oc:stepId "create-entity-class" .

