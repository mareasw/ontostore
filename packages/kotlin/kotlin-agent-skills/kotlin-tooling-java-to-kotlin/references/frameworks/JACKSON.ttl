    oc:requiresState oc:JavaSourceDetected ;
    oc:resolvesIntent "apply correct Kotlin use-site targets for Jackson annotations",
        "convert Jackson-annotated Java classes to Kotlin",
        "preserve Jackson serialization behavior during Java-to-Kotlin migration" ;
    oc:yieldsState oc:JacksonAnnotationsConverted .

oc:kn_58297cc6 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting Java classes with @JsonCreator factory methods or constructors" ;
    oc:directiveContent "Convert Java @JsonCreator static factories to Kotlin primary constructors annotated with @JsonCreator. Preserve the annotation even if the Jackson Kotlin module makes it technically unnecessary." ;
    oc:hasRationale "Preserving @JsonCreator ensures deserialization works without the Jackson Kotlin module present, maintaining backward compatibility." ;
    oc:severityLevel "HIGH" .

oc:kn_5b141f54 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Java builder-pattern classes annotated with @JsonPOJOBuilder" ;
    oc:directiveContent "If a Java class with @JsonPOJOBuilder is being converted to a Kotlin data class, replace the builder pattern with a primary constructor + @JsonCreator." ;
    oc:hasRationale "Kotlin data classes with primary constructors eliminate the need for builder patterns while maintaining immutability and Jackson compatibility." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5e9def42 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Java DTOs with multiple Jackson annotations on fields and getters" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """@JsonInclude(JsonInclude.Include.NON_NULL)
open class OrderSummaryDto(
    @field:JsonProperty("order_id")
    @get:JsonProperty("order_id")
    val orderId: String?,

    @field:JsonFormat(shape = JsonFormat.Shape.STRING, pattern = "yyyy-MM-dd")
    @get:JsonFormat(shape = JsonFormat.Shape.STRING, pattern = "yyyy-MM-dd")
    val createdDate: String?
)""" .

oc:kn_6a854395 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting any Jackson annotation beyond @JsonProperty" ;
    oc:directiveContent "Preserve @JsonIgnore, @JsonDeserialize, @JsonSerialize, @JsonInclude, and @JsonFormat with correct use-site targets matching the original Java annotation targets (field → @field:, getter → @get:)." ;
    oc:hasRationale "Each annotation's behavior depends on where it is placed; incorrect site targets can silently break serialization or deserialization." ;
    oc:severityLevel "HIGH" .

oc:kn_7973412b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When placing Jackson annotations on Kotlin properties" ;
    oc:directiveContent "Never apply Jackson annotations without use-site targets when the original Java had them on both field and getter. A single @JsonProperty on a Kotlin property annotates the constructor parameter, not the field or getter." ;
    oc:hasRationale "Without explicit site targets, Jackson annotations default to the constructor parameter in Kotlin, which may not match the original Java behavior and can break serialization." ;
    oc:severityLevel "CRITICAL" .

oc:kn_cf1249be a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Java classes with @JsonCreator factory methods to Kotlin data classes" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """data class ConfigEntry @JsonCreator constructor(
    @field:JsonProperty("key")
    @get:JsonProperty("key")
    val key: String?,

    @field:JsonProperty("value")
    @get:JsonProperty("value")
    val value: String?,

    @field:JsonProperty("enabled")
    @get:JsonProperty("enabled")
    val enabled: Boolean
)""" .

oc:kn_d3ad8946 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Jackson-annotated Java files to Kotlin" ;
    oc:directiveContent "Do NOT add jackson-module-kotlin during conversion. Only note its absence as a recommendation, since conversion must not alter project dependencies." ;
    oc:hasRationale "Conversion is a source-level transformation; adding dependencies is a separate project decision that may affect other modules." ;
    oc:severityLevel "HIGH" .

oc:kn_dbfeacea a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting Java classes with Jackson field + getter annotation pairs" ;
    oc:directiveContent "When a Java field and its getter both carry @JsonProperty, apply BOTH @field:JsonProperty and @get:JsonProperty on the corresponding Kotlin property." ;
    oc:hasRationale "Java annotates field and getter separately; Kotlin properties unify them, so both site targets are needed to preserve Jackson's dual-resolution behavior." ;
    oc:severityLevel "CRITICAL" .

oc:kn_e213f8f0 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing Java-to-Kotlin conversion on Jackson-annotated classes" ;
    oc:directiveContent "1. Detect Jackson imports (com.fasterxml.jackson.*) to activate this guide. 2. Map each Java annotation to its Kotlin use-site target based on whether it was on field, getter, or both. 3. Apply @field: and/or @get: prefixes to all Jackson annotations on Kotlin properties. 4. Convert @JsonCreator static factories to primary constructor annotations. 5. Preserve class-level annotations (e.g., @JsonInclude) without site targets. 6. Note if jackson-module-kotlin is missing." ;
    oc:stepOrder 1 .

_:ref_1748489446a77614 a oc:WorkflowStep ;
    dcterms:description "**Annotation site targets**:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 3 ;
                    oc:itemText """When converting to Kotlin properties, apply BOTH `@field:` and `@get:` targets to
match Java's dual annotation on field + getter.""" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "`@JsonProperty` on a Java field → `@field:JsonProperty` in Kotlin." ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "`@JsonProperty` on a Java getter → `@get:JsonProperty` in Kotlin." ] ] ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_786fb856dac039a1 a oc:WorkflowStep ;
    dcterms:description """**Builder pattern with @JsonPOJOBuilder**: Replace with primary constructor +
`@JsonCreator` if converting to data class. Otherwise preserve.""" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_8" ;
    oc:stepOrder 8 .

_:ref_999dcca52a592d83 a oc:WorkflowStep ;
    dcterms:description "**@JsonDeserialize / @JsonSerialize**: Preserve exactly with correct site targets." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_adda86e070de4f29 a oc:WorkflowStep ;
    dcterms:description """**@JsonIgnore**: Preserve exactly. Use `@get:JsonIgnore` or `@field:JsonIgnore`
depending on original target.""" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_b55db294e78fdbd0 a oc:WorkflowStep ;
    dcterms:description """**@JsonCreator**: Java's `@JsonCreator` static factory or constructor → Kotlin primary
constructor. The `@JsonCreator` annotation is often unnecessary on Kotlin's primary
constructor if using the Jackson Kotlin module, but preserve it for safety.""" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_cd835f1aafd77b4d a oc:WorkflowStep ;
    dcterms:description "**@JsonInclude**: Preserve on class or property level." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_e099bc0af821c9dc a oc:WorkflowStep ;
    dcterms:description """**Jackson Kotlin Module**: Note that projects using Jackson with Kotlin should add
`jackson-module-kotlin` for proper Kotlin support (data classes, default values,
nullable types). This is NOT something to add during conversion — just note it if
missing.""" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_7" ;
    oc:stepOrder 7 .

_:ref_e70e10942c3542a0 a oc:WorkflowStep ;
    dcterms:description "**@JsonFormat**: Preserve with `@field:JsonFormat` site target." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

