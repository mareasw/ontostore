                                    oc:itemOrder 2 ;
                                    oc:itemText "The class becomes a `data class` since it is immutable and value-oriented." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText """The Java `@JsonCreator` static factory is converted to a Kotlin primary constructor
with `@JsonCreator`. The companion object factory is preserved for backward
compatibility but the primary constructor handles deserialization.""" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Key points:**" ] ;
                    oc:hasSubsection [ a oc:Section ;
