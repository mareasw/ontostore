oc:kn_6a4b6012 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Converting Java test class visibility modifiers to Kotlin" ;
    oc:directiveContent "Test classes and methods do not need explicit public visibility; Kotlin's default is public which satisfies JUnit's requirements. Methods do not need open unless a framework subclasses the test." ;
    oc:hasRationale "Kotlin's default visibility is public, so adding explicit public is redundant noise" .

oc:kn_87a2d708 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Determining if this conversion guide applies" ;
    oc:directiveContent "Detected when imports match org.junit.* or org.testng.*" .

oc:kn_900fa8b9 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Naming test methods in Kotlin" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """@Test
fun `should return empty list when no users exist`() { ... }""" ;
    oc:hasRationale "Backtick-quoted method names produce readable test reports and serve as documentation" .

oc:kn_ab1d4b7a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Writing assertions in converted Kotlin test classes" ;
    oc:directiveContent "Do not use Assert.assertEquals(expected, actual) static imports; use kotlin.test top-level functions assertEquals(expected, actual) instead" ;
    oc:hasRationale "kotlin.test assertions delegate to the underlying framework at runtime, providing portability across test frameworks" ;
    oc:severityLevel "HIGH" .

oc:kn_baad5439 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Converting JUnit 4 rules to JUnit 5 extensions" ;
    oc:directiveContent "@Rule/@ClassRule from JUnit 4 should be replaced with @ExtendWith or @RegisterExtension in JUnit 5" ;
    oc:hasRationale "JUnit 5 replaced the rule mechanism with the more powerful Extension model" .

oc:kn_c065395a a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Converting static @BeforeClass methods to Kotlin" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """@BeforeAll
@JvmStatic
fun setupDatabase() { ... }""" ;
    oc:hasRationale "JUnit 5 requires @JvmStatic on @BeforeAll methods inside companion objects because JUnit calls them statically" .

oc:kn_d533a36e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Choosing assertion style for Kotlin tests" ;
    oc:directiveContent "Prefer kotlin.test assertions (assertEquals, assertTrue, assertNotNull, assertFailsWith) for portability across test frameworks" ;
    oc:hasRationale "kotlin.test provides a unified assertion API that works regardless of whether JUnit 5 or another framework is on the classpath" .

oc:kn_dd6ce31f a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Converting a JUnit 4 Java test class to Kotlin with JUnit 5" ;
    oc:directiveContent """1. Replace JUnit 4 annotations with JUnit 5 equivalents (@Before→@BeforeEach, @After→@AfterEach, @Ignore→@Disabled, @RunWith→@ExtendWith)
2. Move @BeforeClass/@AfterClass methods into companion object with @JvmStatic
3. Replace static Assert.* imports with kotlin.test top-level function imports
4. Replace @Test(expected=X.class) with assertFailsWith<X> { }
5. Rename test methods using backtick syntax for readability
6. Replace Java idioms with Kotlin equivalents (e.g., users.size() > 0 → users.isNotEmpty())
7. Use lateinit var for fields initialized in setup methods""" ;
    oc:stepOrder 1 .

oc:kn_e8668ca4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Replacing @Test(expected = X.class) with Kotlin reified generics" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """assertFailsWith<IllegalArgumentException> {
    userService.findById(-1L)
}""" ;
    oc:hasRationale "Kotlin's reified generics eliminate the need for .class literals; assertFailsWith is more idiomatic than JUnit's assertThrows" .

