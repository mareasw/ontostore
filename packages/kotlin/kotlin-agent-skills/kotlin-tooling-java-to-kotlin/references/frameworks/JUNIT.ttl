    oc:differentia "Converts JUnit 4 and TestNG test classes to idiomatic Kotlin with JUnit 5 and kotlin.test assertions" ;
    oc:extends oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_java_to_kotlin ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
