oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_java_to_kotlin_junit a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "junit" ;
    skos:broader "Testing framework conversion guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/kotlin/kotlin-agent-skills/kotlin-tooling-java-to-kotlin" ;
    oc:contentHash "58141f5f63afe96944366bcd2e4d462f6ba4d55e2cfe5e8fd29e77ff51604c78" ;
    oc:differentia "Maps JUnit 4/TestNG annotations and assertions to idiomatic Kotlin with JUnit 5 and kotlin.test, handling companion objects for static lifecycle methods and reified generics for exception assertions" ;
    oc:extends oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_java_to_kotlin ;
    oc:hasArgumentHint "Java test file using JUnit 4 or TestNG" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_0a927688,
        oc:kn_105156b3,
        oc:kn_3ccb18ca,
        oc:kn_5554d382,
        oc:kn_718764f5,
        oc:kn_96531b2c,
        oc:kn_a7657256,
        oc:kn_ca98a5eb ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:resolvesIntent "convert JUnit 4 tests to Kotlin with JUnit 5",
        "convert TestNG tests to Kotlin with JUnit 5",
        "migrate @BeforeClass/@AfterClass to companion objects with @JvmStatic",
        "modernize Java test assertions to kotlin.test idioms" .

oc:kn_0a927688 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting JUnit 4 expected-exception tests and test runners" ;
    oc:directiveContent "Convert @Test(expected = X.class) patterns to assertFailsWith<X> { } blocks wrapping the invocation, and @RunWith to @ExtendWith." ;
    oc:hasRationale "Kotlin's reified generics eliminate the need for .class literals, and JUnit 5 replaces @RunWith with the extensible @ExtendWith model. @Rule/@ClassRule should map to @ExtendWith or @RegisterExtension." ;
    oc:severityLevel "HIGH" .

oc:kn_105156b3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Kotlin test class declarations" ;
    oc:directiveContent "Test classes and methods do not need explicit `public` visibility, and test methods should not be `open` unless a framework subclasses the test (e.g., certain Spring test configurations)." ;
    oc:hasRationale "Kotlin's default visibility is public, satisfying JUnit's access requirements. Unnecessary `open` modifiers add confusion." ;
    oc:severityLevel "LOW" .

oc:kn_3ccb18ca a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting JUnit 4 @BeforeClass/@AfterClass or TestNG @BeforeClass/@AfterClass to Kotlin" ;
    oc:directiveContent "Always place @BeforeAll and @AfterAll methods inside a companion object annotated with @JvmStatic in Kotlin test classes." ;
    oc:hasRationale "JUnit 5 requires @BeforeAll/@AfterAll methods to be static; in Kotlin, companion object + @JvmStatic is the idiomatic way to achieve this." ;
    oc:severityLevel "CRITICAL" .

oc:kn_5554d382 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting TestNG data-driven tests to Kotlin" ;
    oc:directiveContent "Map TestNG @DataProvider to JUnit 5 @ParameterizedTest + @MethodSource." ;
    oc:hasRationale "JUnit 5's parameterized test extension is the standard replacement for TestNG's data provider pattern." ;
    oc:severityLevel "HIGH" .

oc:kn_718764f5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting JUnit 4 tests to Kotlin" ;
    oc:directiveContent "Do not keep JUnit 4 annotations (@Before, @After, @Ignore, @RunWith) in converted Kotlin test classes." ;
    oc:hasRationale "JUnit 4 annotations are deprecated in the Kotlin/JUnit 5 ecosystem and will cause runtime failures or misleading test lifecycle behavior." ;
    oc:severityLevel "CRITICAL" .

oc:kn_96531b2c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting any Java test assertion to Kotlin" ;
    oc:directiveContent "Prefer kotlin.test assertions (assertEquals, assertTrue, assertNotNull, assertFailsWith) over JUnit Assert static imports for portability across test frameworks." ;
    oc:hasRationale "kotlin.test assertions delegate to the underlying framework at runtime, making tests portable and eliminating .class suffix requirements for exception testing via reified generics." ;
    oc:severityLevel "HIGH" .

oc:kn_a7657256 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Java test bodies to Kotlin" ;
    oc:directiveContent "Replace Java collection idioms like `users.size() > 0` with Kotlin idioms like `users.isNotEmpty()` in test assertions." ;
    oc:hasRationale "Idiomatic Kotlin collection predicates are more readable and align with Kotlin conventions, making tests self-documenting." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ca98a5eb a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When naming Kotlin test methods" ;
    oc:directiveContent "Use backtick-quoted method names for test methods to produce human-readable test descriptions (e.g., `should return empty list when no users exist`)." ;
    oc:hasRationale "Kotlin allows backtick-quoted identifiers which produce readable test names in reports without requiring @DisplayName annotations." ;
    oc:severityLevel "MEDIUM" .

