                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 3 ;
                                    oc:textContent "**Kotlin:**" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Example 1: Micronaut Controller with Constructor Injection" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Examples" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Micronaut Conversion Guide" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Convert a Micronaut Java class to idiomatic Kotlin, handling DI, annotations, and AOP constraints." ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Preserve stereotype annotations (@Singleton, @Controller, @Client, @Repository) as-is. Escape $ in @Value as \\${...}." ;
                    oc:expectedOutcome "All annotations correctly preserved or escaped for Kotlin compilation." ;
                    oc:stepId "annotations" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "For @ConfigurationProperties: use lateinit var for required String properties, var with defaults for primitives." ;
                    oc:expectedOutcome "Configuration properties class has appropriate mutability for Micronaut's reflective binding." ;
                    oc:stepId "config-props" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Make return types nullable where Java methods may return null (e.g., single-entity lookups)." ;
                    oc:expectedOutcome "Kotlin null safety accurately reflects Java's potential null returns." ;
                    oc:stepId "nullability" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Detect Micronaut imports (io.micronaut.*) to confirm this guide applies." ;
                    oc:expectedOutcome "Micronaut framework confirmed; proceed with Micronaut-specific conversion rules." ;
                    oc:stepId "detect" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Convert @Inject constructor/field injection to Kotlin primary constructor parameters (private val). Remove @Inject and its import when only one constructor exists." ;
                    oc:expectedOutcome "Dependencies are immutable val properties in primary constructor; @Inject removed." ;
                    oc:stepId "inject" ],
                [ a oc:WorkflowStep ;
                    dcterms:description "Add 'open' modifier to classes using AOP annotations (@Around, @Introduction, @Cacheable), @Factory classes, and @ConfigurationProperties classes." ;
                    oc:expectedOutcome "All proxy-targeted classes are open for Micronaut compile-time subclassing." ;
                    oc:stepId "aop-open" ] ;
            oc:workflowId "micronaut-conversion" ;
            oc:workflowName "Micronaut Java-to-Kotlin Conversion" ] ;
