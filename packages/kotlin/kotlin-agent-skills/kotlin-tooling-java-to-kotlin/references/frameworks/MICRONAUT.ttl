oc:kn_16c041f8 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Micronaut controller methods that delegate to services returning single entities" ;
    oc:directiveContent "Make return types nullable (e.g., OrderDto → OrderDto?) where the Java service method may return null." ;
    oc:hasRationale "Kotlin enforces null safety; Java methods that can return null should be reflected as nullable Kotlin types." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4502fbad a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting any Micronaut stereotype-annotated class" ;
    oc:directiveContent "Preserve stereotype annotations (@Singleton, @Controller, @Client, @Repository) exactly as-is — no annotation site target needed." ;
    oc:hasRationale "These annotations target the class directly and do not require Kotlin annotation site targets like @field: or @get:." ;
    oc:severityLevel "LOW" .

oc:kn_5473927a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Micronaut @Inject field injection to Kotlin" ;
    oc:directiveContent "Do NOT use lateinit var for @Inject field-injected dependencies — convert them to constructor parameters with private val instead." ;
    oc:hasRationale "Constructor injection with val makes dependencies immutable and thread-safe, eliminating the need for lateinit var." ;
    oc:severityLevel "HIGH" .

oc:kn_96ea03a0 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting classes with Micronaut AOP/interceptor annotations" ;
    oc:directiveContent "Classes using Micronaut AOP annotations (@Around, @Introduction, @Cacheable) must be declared open in Kotlin." ;
    oc:hasRationale "Micronaut generates subclass proxies at compile time; Kotlin classes are final by default, which prevents proxy generation." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ac01e877 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Micronaut Java classes with a single @Inject-annotated constructor" ;
    oc:directiveContent "Remove @Inject when converting a Java class that has only one constructor — Micronaut auto-discovers the sole constructor for dependency injection." ;
    oc:hasRationale "Micronaut's compile-time DI resolves the single constructor automatically; keeping @Inject is redundant in Kotlin and adds unnecessary imports." ;
    oc:severityLevel "HIGH" .

oc:kn_c110b5a5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Micronaut @ConfigurationProperties to Kotlin" ;
    oc:directiveContent "For @ConfigurationProperties classes: use lateinit var for required String properties, var with defaults for primitives. The class must be open." ;
    oc:hasRationale "Micronaut sets properties via reflection at runtime; lateinit var handles required strings while var with defaults handles optional primitives." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d99aa065 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Micronaut bean factory classes" ;
    oc:directiveContent "@Factory classes and @Bean-annotated methods must be open so Micronaut can manage lifecycle through subclassing." ;
    oc:hasRationale "Micronaut subclasses factory beans for lifecycle management; closed classes/methods prevent this." ;
    oc:severityLevel "HIGH" .

oc:kn_fd85a981 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting @Value annotation property placeholders" ;
    oc:directiveContent "Escape $ in @Value annotations as \\${...} to prevent Kotlin string template interpretation." ;
    oc:hasRationale "Kotlin treats $ as string template prefix; unescaped $ causes compilation errors." ;
    oc:severityLevel "CRITICAL" .

