oc:kn_3c79b6b0 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When placing JPA annotations on entity properties" ;
    oc:directiveContent "Use @field: annotation site targets for JPA annotations like @Id, @Column, @GeneratedValue, @ManyToOne, @OneToMany, @JoinColumn in Kotlin. For example: @field:Id, @field:Column(name = \"username\"), @field:ManyToOne(fetch = FetchType.LAZY)." ;
    oc:hasRationale "Kotlin annotations default to targeting parameter sites, but Hibernate expects field-level annotations. Without @field: prefix, annotations are placed on constructor parameters instead of backing fields, causing Hibernate to ignore them." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4879ba8d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining entity property types and annotation array parameters" ;
    oc:directiveContent "Use `open var` for mutable entity properties and `open val` for immutable ones. Use MutableList for @OneToMany collections. Use Kotlin array syntax [CascadeType.ALL] instead of Java's {CascadeType.ALL}." ;
    oc:hasRationale "Properties must be open for proxy overriding. MutableList allows Hibernate to manage collection relationships. Kotlin uses [] for annotation arrays." .

oc:kn_58d3e26c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting any class annotated with @Entity" ;
    oc:directiveContent "Never use Kotlin data classes for JPA @Entity classes. Data classes generate equals/hashCode based on all properties, breaking Hibernate's identity semantics and proxy creation." ;
    oc:hasRationale "Hibernate uses identity-based equality for entities and creates runtime proxies via subclassing. Data class–generated equals/hashCode conflicts with both mechanisms." ;
    oc:severityLevel "CRITICAL" .

oc:kn_8f140287 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting entity classes that need proxy instantiation" ;
    oc:directiveContent "Provide a protected no-arg constructor that delegates to the primary constructor with default values. Alternatively, use default values for all primary constructor parameters." ;
    oc:hasRationale "Hibernate requires a no-argument constructor to instantiate proxy objects. Kotlin primary constructors with required parameters don't satisfy this requirement." .

oc:kn_97dc466f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting any @Entity class" ;
    oc:directiveContent "All JPA entity classes and their mutable properties must be declared `open`. Kotlin classes are final by default, but Hibernate requires subclassing for proxy creation." ;
    oc:hasRationale "Hibernate creates lazy-loading proxies by generating subclasses at runtime. Final classes prevent this, causing runtime errors." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ab260ad4 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When converting entity classes with generated IDs" ;
    oc:directiveContent "Declare @Id as a separate property inside the class body with `open var ... protected set` rather than in the primary constructor. Initialize it as nullable with null default." ;
    oc:hasRationale "This pattern keeps ID assignment controlled (protected setter) while allowing Hibernate to set it on persist, and avoids requiring ID in the primary constructor." .

oc:kn_d9e92c4a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting @Embeddable or @MappedSuperclass annotated classes" ;
    oc:directiveContent "@Embeddable classes CAN be data classes with default values for all constructor parameters. @MappedSuperclass must be declared as `open abstract class`." ;
    oc:hasRationale "@Embeddable classes are value objects not proxied by Hibernate, so data class semantics are safe. @MappedSuperclass is never instantiated directly." .

_:ref_0d6f2d83852d6c6e a oc:WorkflowStep ;
    dcterms:description "**Annotation site targets matter:**" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText """`@Id`, `@Column`, `@GeneratedValue` on fields → use `@field:Id`, `@field:Column`, etc.
in Kotlin, OR place annotations on constructor parameters with `@field:` site target.""" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "`@ManyToOne`, `@OneToMany`, `@JoinColumn` → same `@field:` targeting." ] ] ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_15b1a55cef8931ee a oc:WorkflowStep ;
    dcterms:description """**Lazy loading considerations:** `@ManyToOne(fetch = FetchType.LAZY)` requires the entity
class to be open for proxy creation. `@OneToMany` with lazy collections work with Kotlin's
`MutableList`.""" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_3efcb171157fa32c a oc:WorkflowStep ;
    dcterms:description """**Provide a no-argument constructor** if Hibernate requires one for proxy creation. Use a
secondary constructor or default values for all primary constructor parameters.""" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_5249b81a538d1cff a oc:WorkflowStep ;
    dcterms:description """**Do NOT use data classes for JPA entities.** Data classes generate `equals`/`hashCode`
based on all properties, which breaks Hibernate's identity semantics and proxy creation.""" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_554ecca960f7528b a oc:WorkflowStep ;
    dcterms:description "**`@Embeddable` classes**: Can be data classes (they don't need proxies)." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_7450ee86d6b5adb6 a oc:WorkflowStep ;
    dcterms:description "**`@MappedSuperclass`**: Must be `open abstract class` in Kotlin." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_7" ;
    oc:stepOrder 7 .

_:ref_8e0932b2bd6af091 a oc:WorkflowStep ;
    dcterms:description """**Keep entity classes `open`.** Hibernate creates proxies via subclassing. Kotlin classes
are `final` by default, so you must use `open` explicitly (or use the `allopen` compiler
plugin with JPA annotation support).""" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

