oc:kn_37eb532b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using @Named qualifier on constructor-injected parameters" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent "@param:Named(\"primary\") private val dataSource: DataSource" ;
    oc:hasRationale "Kotlin annotation site target @param: is required so @Named reaches the constructor parameter, not the backing field or property" .

oc:kn_40eb03b5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting @Named annotations on Guice-injected constructor parameters" ;
    oc:directiveContent "Do not use @field:Named or @property:Named on constructor parameters — use @param:Named" ;
    oc:hasRationale "Wrong site target causes Guice to fail at runtime because the qualifier annotation does not reach the injection point" ;
    oc:severityLevel "CRITICAL" .

oc:kn_50dff067 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing Guice binding DSL in Kotlin module configure()" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent "bind(Foo::class.java).to(FooImpl::class.java)" ;
    oc:hasRationale "Kotlin class references use ::class.java to produce the Java Class<?> that Guice's bind DSL expects" .

oc:kn_82a1e92e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When using .in(Singleton::class.java) in Guice module bindings in Kotlin" ;
    oc:directiveContent "Kotlin reserved keyword 'in' must be escaped with backticks when calling Guice's .in() scope method" ;
    oc:hasRationale "'in' is a reserved keyword in Kotlin; unescaped usage causes a compilation error" ;
    oc:severityLevel "HIGH" .

oc:kn_b36af7cb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Guice Provider<T> usage to Kotlin" ;
    oc:directiveContent "Where Provider<T> is used solely for deferred initialization outside Guice-managed contexts, Kotlin's lazy delegation can replace it" ;
    oc:hasRationale "Kotlin's built-in lazy {} is more idiomatic than Guice Provider for simple deferred init, but Provider must be kept when Guice scoping or injection chains are involved" .

oc:kn_c29253bb a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting @Inject-annotated Java constructors to Kotlin" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent "class Foo @Inject constructor(private val bar: Bar)" ;
    oc:hasRationale "Kotlin places @Inject before the constructor keyword in the primary constructor; constructor parameters become private val properties" .

oc:kn_ff4e2446 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting Guice scope annotations" ;
    oc:directiveContent "Preserve @Singleton exactly as-is; it can stay on class declarations or in module bindings via .in(Singleton::class.java)" ;
    oc:hasRationale "Guice scoping semantics are unchanged in Kotlin; @Singleton is a Java annotation that works without modification" .

