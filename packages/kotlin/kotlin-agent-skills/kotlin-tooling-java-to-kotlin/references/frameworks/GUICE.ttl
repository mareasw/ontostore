                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """Keep `@Provides` methods as regular functions. Guice modules extend `AbstractModule`,
so override `configure()` as usual.""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "2. @Provides methods in Modules" ],
