                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText """`.in(Singleton.class)` becomes `` .`in`(Singleton::class.java) `` — `in` is a
reserved keyword in Kotlin and must be escaped with backticks.""" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 6 ;
                                            oc:itemText "String concatenation `\"/orders/\" + id` becomes a string template `\"/orders/$id\"`." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "`@Inject` moves before the `constructor` keyword in the primary constructor." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 5 ;
                                            oc:itemText """The lambda in `getOrFetch` uses Kotlin's trailing lambda syntax instead of an
anonymous inner class.""" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Constructor parameters become `private val` in the primary constructor." ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText """`@Named("region")` uses `@param:Named` site target so the annotation reaches the
constructor parameter rather than the Kotlin property.""" ] ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Example 1: Guice Module with Bindings and an Injected Class" ] ;
                    oc:sectionLevel 2 ;
