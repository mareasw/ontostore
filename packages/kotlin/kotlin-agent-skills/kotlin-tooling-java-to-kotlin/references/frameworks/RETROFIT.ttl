    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:FileExists ;
    oc:resolvesIntent "convert Retrofit Java interfaces to Kotlin suspend functions",
        "migrate OkHttp client configuration from Java to Kotlin",
        "replace Call<T> with coroutine-based Retrofit patterns" ;
    oc:yieldsState oc:DocumentConverted .

oc:kn_05161d8c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting OkHttpClient.Builder Java chains to Kotlin" ;
    oc:directiveContent "Use .apply {} blocks on OkHttpClient.Builder to group related configuration instead of chaining individual calls." ;
    oc:hasRationale "apply blocks scope the builder receiver, making configuration grouping clearer and more Kotlin-idiomatic." ;
    oc:severityLevel "LOW" .

oc:kn_0bcd1515 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting any Retrofit service interface method" ;
    oc:directiveContent "Do not keep Call<T> return types in Kotlin Retrofit interfaces — replace them with suspend fun returning T directly, leveraging Retrofit 2.6.0+ built-in coroutine support." ;
    oc:hasRationale "Keeping Call<T> defeats Kotlin coroutine benefits and forces the caller to manage callback/callback hell patterns manually." ;
    oc:severityLevel "CRITICAL" .

oc:kn_225ede16 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding return type for suspend fun Retrofit methods" ;
    oc:directiveContent "For endpoints where HTTP status codes matter, keep Response<T> as the return type with suspend fun. For simple cases where only the body is needed, return T directly and let Retrofit throw on non-2xx responses." ;
    oc:hasRationale "Balancing convenience (direct T) against error-handling control (Response<T>) on a per-endpoint basis." ;
    oc:severityLevel "HIGH" .

oc:kn_475a9c99 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting OkHttp interceptor implementations" ;
    oc:directiveContent "Interceptor { chain -> chain.proceed(chain.request()) } — Java Interceptor anonymous classes become Kotlin SAM lambdas." ;
    oc:hasRationale "Kotlin SAM conversion eliminates verbose anonymous class boilerplate for single-abstract-method interfaces." ;
    oc:severityLevel "MEDIUM" .

oc:kn_9d2118d4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting DELETE or other void-returning endpoints where status verification matters" ;
    oc:directiveContent "Call<Void> must become Response<Unit>, not Unit directly, when HTTP status code checking is needed on void-returning endpoints." ;
    oc:hasRationale "Unit alone would swallow HTTP error information; Response<Unit> preserves status code access for error handling." ;
    oc:severityLevel "HIGH" .

oc:kn_aa75f554 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting any Retrofit-annotated method" ;
    oc:directiveContent "All Retrofit annotations (@GET, @POST, @Path, @Query, @Body, @Headers, etc.) transfer directly with zero changes — do not modify or 'Kotlin-ify' them." ;
    oc:hasRationale "Retrofit annotations are processed by the Java-based library at runtime and must remain in their original form." ;
    oc:severityLevel "CRITICAL" .

oc:kn_cb68ed43 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:directiveContent "1. Detect retrofit2.* or okhttp3.* imports → 2. Convert interface methods: replace Call<T> with suspend fun returning T → 3. Convert Call<Void> to Response<Unit> where status matters → 4. Preserve all Retrofit annotations unchanged → 5. Map Java primitives (int→Int, long→Long) → 6. Remove public modifier from interface → 7. Remove unused Call/Callback imports → 8. Convert OkHttpClient.Builder chains to .apply{} blocks → 9. Convert Interceptor anonymous classes to SAM lambdas → 10. Convert RequestBody.create() to .toRequestBody() extension" ;
    oc:stepOrder 1 .

oc:kn_fe2a850d a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting OkHttp request body creation code" ;
    oc:directiveContent "RequestBody.create(mediaType, content) → content.toRequestBody(mediaType) when using okhttp3-kotlin-extensions artifact." ;
    oc:hasRationale "Kotlin extension functions provide a more idiomatic API; the Java static method pattern is non-idiomatic in Kotlin." ;
    oc:severityLevel "MEDIUM" .

