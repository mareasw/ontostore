oc:kn_05e9e3cf a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting Dagger component or subcomponent interfaces" ;
    oc:directiveContent "Convert @Component and @Subcomponent interfaces directly to Kotlin interfaces; convert @Binds abstract methods in abstract classes directly with no special Kotlin considerations" ;
    oc:hasRationale "Dagger's annotation processing works identically with Kotlin interfaces via kapt or KSP" .

oc:kn_260d3a0e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting @Module classes" ;
    oc:directiveContent "Use Kotlin object for @Module classes that contain only static-like @Provides methods; keep @Provides methods open in abstract module classes when mixins or overriding is needed" ;
    oc:hasRationale "Kotlin object is the idiomatic equivalent of a Java class with only static methods, aligning with Dagger's expectation for stateless module providers" .

oc:kn_792a327c a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting @Module classes with @Provides methods" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """@Module
@InstallIn(SingletonComponent::class)
object NetworkModule {
    @Provides
    @Singleton
    fun provideOkHttpClient(): OkHttpClient = OkHttpClient.Builder().build()
}""" ;
    oc:hasRationale "Module classes containing only static-like provides methods should become Kotlin objects; use class reference syntax (::class) for annotations" .

oc:kn_9e88238c a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When converting any Hilt-annotated Android class" ;
    oc:directiveContent "Preserve Hilt Android annotations (@HiltAndroidApp, @AndroidEntryPoint, @HiltViewModel) exactly on their respective class types; preserve scoping annotations (@Singleton, @ActivityScoped, @ViewModelScoped, @FragmentScoped) without annotation site targets" ;
    oc:hasRationale "These annotations work identically in Kotlin and require no special transformation — incorrect modification would break Hilt's code generation" ;
    oc:severityLevel "HIGH" .

oc:kn_c29253bb a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting @Inject constructors from Java to Kotlin" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent "class Foo @Inject constructor(private val bar: Bar)" ;
    oc:hasRationale "Kotlin places @Inject before the constructor keyword in the primary constructor, unlike Java where it annotates the constructor method directly" .

oc:kn_c5db16db a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before applying any conversion rules" ;
    oc:directiveContent "This guide only applies when Java source contains imports matching dagger.* or dagger.hilt.* — it covers Dagger 2, Hilt for Android, and Hilt Jetpack integrations" ;
    oc:hasRationale "Applying Dagger/Hilt conversion rules to non-DI code would produce incorrect results" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e7d0b626 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting @AssistedInject / @AssistedFactory patterns" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """class PlayerViewModel @AssistedInject constructor(
    @Assisted private val playerId: String,
    private val repository: PlayerRepository
) : ViewModel()""" ;
    oc:hasRationale "@AssistedInject replaces @Inject on the constructor; @Assisted parameters appear alongside regular injected parameters in the primary constructor" .

oc:kn_fa1a882e a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When retrying or re-converting files" ;
    oc:directiveContent "Conversion is deterministic: the same Java input with the same Dagger/Hilt annotations will always produce the same Kotlin output" ;
    oc:hasRationale "Annotation mapping rules are unambiguous and do not depend on external state" .

