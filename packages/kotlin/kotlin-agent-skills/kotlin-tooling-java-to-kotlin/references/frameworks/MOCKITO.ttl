                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """While Mockito works in Kotlin, MockK is the idiomatic Kotlin mocking library. Convert
to MockK when the project already uses MockK or is doing a full Kotlin migration. If
the project wants to keep Mockito, convert only the Java syntax to Kotlin syntax using
the `mockito-kotlin` helper library.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Detected when imports match `org.mockito.*`." ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
