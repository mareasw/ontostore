oc:kn_135b0ca5 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When outputting converted Kotlin code" ;
    oc:directiveContent "{kotlin_class} with: all lombok imports removed, annotations replaced by kotlin language features, reference types nullable, primitive types with defaults, companion object for logging if @Slf4j" ;
    oc:templateVariables "kotlin_class" .

oc:kn_1c44e8f9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting @Builder annotations" ;
    oc:directiveContent "For @Builder, prefer default parameter values. Only create an explicit builder pattern if the Java code has complex builder logic beyond simple setters." ;
    oc:hasRationale "Kotlin named arguments and default values provide the same ergonomics as builders for most use cases, keeping code simpler" .

oc:kn_27da60fa a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting @Data @Builder classes to Kotlin" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """data class Order(
    val orderId: String?,
    val customerName: String?,
    val quantity: Int = 0,
    val expedited: Boolean = false
)""" .

oc:kn_29625e2a a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Java source must contain lombok.* imports to trigger this conversion guide" .

oc:kn_5c030181 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Always when performing Lombok-to-Kotlin conversion" ;
    oc:directiveContent "1. Detect lombok.* imports in Java source. 2. Map each Lombok annotation to its Kotlin equivalent using the conversion table. 3. Remove all Lombok imports. 4. Apply Kotlin idioms (data class, val/var properties, companion object logger, .use{} for @Cleanup, .copy() for @With, apply{} for chain accessors). 5. Verify nullability of reference types. 6. Ensure JPA entities use open class not data class." ;
    oc:stepOrder 1 .

oc:kn_5caa4a65 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting @Data on JPA entity classes" ;
    oc:directiveContent "Do NOT use data class for JPA entities. Use regular open class with properties instead. Data classes break Hibernate proxies." ;
    oc:hasRationale "Hibernate proxies require non-final classes and specific equals/hashCode behavior that data classes violate" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7349da74 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting service classes with @Slf4j and constructor injection annotations" ;
    oc:directiveContent "Convert @Slf4j to a companion object with LoggerFactory.getLogger(ClassName::class.java). Replace @RequiredArgsConstructor with primary constructor parameters." ;
    oc:hasRationale "Kotlin has no annotation-based logger injection; companion objects with LoggerFactory is the idiomatic pattern" .

oc:kn_777e936b a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting @Slf4j annotated classes" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """companion object {
    private val log = LoggerFactory.getLogger(MyClass::class.java)
}""" .

oc:kn_7e819627 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Java fields to Kotlin properties" ;
    oc:directiveContent "Reference types converted from Java should be nullable (e.g., String?) unless the original field has explicit nullability annotations or is proven non-null." ;
    oc:hasRationale "Java reference types default to null; assuming non-null without evidence causes NullPointerException at runtime" ;
    oc:severityLevel "HIGH" .

oc:kn_80308e2b a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When any lombok.* imports are detected in Java source" ;
    oc:directiveContent "Remove ALL Lombok annotations entirely. Do not convert Lombok to Lombok — convert to idiomatic Kotlin equivalents. Lombok has no place in Kotlin code." ;
    oc:hasRationale "Lombok exists to compensate for Java verbosity; Kotlin's language features make Lombok redundant" ;
    oc:severityLevel "CRITICAL" .

