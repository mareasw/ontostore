    oc:differentia "maps RxJava reactive types and operators to Kotlin coroutines and Flow during Java-to-Kotlin migration" ;
    oc:extends oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_java_to_kotlin ;
