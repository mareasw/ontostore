                                    oc:textContent "**Kotlin (mutable config with lateinit var):**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "**Java:**" ],
