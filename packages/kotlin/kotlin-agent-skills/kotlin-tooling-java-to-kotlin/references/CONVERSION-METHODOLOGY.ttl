                                    oc:textContent """**Step 2** — `id` is non-null by design (`Objects.requireNonNull` enforces it).
`nickname` is nullable (`@Nullable`). No val/var changes needed beyond what's already
done. Code unchanged.""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """**Step 1** — Faithful translation. Class is implicitly open → `open class`.
`@JsonProperty("id")` on the field → `@field:JsonProperty("id")`.
`@JsonProperty("id")` on the getter → `@get:JsonProperty("id")` when converted to
property later. Keep explicit getters/setters at this step for faithfulness.""" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 6 ;
                                    oc:textContent "**Step 3** — No collections. No changes." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 7 ;
                                    oc:textContent "Invariants check: All OK." ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Conversion Walkthrough" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Example 2: Domain Model with Annotations" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """Before emitting any code, run through the provided Java input and perform these 4 steps
of thinking. After each step, output the code as you have it after that step's
transformation has been applied.""" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText """If you see a logical assertion that a value is not null (e.g., `Objects.requireNonNull`),
this shows that the author has considered that the value can never be null. Use a
non-null type in this case, and remove the logical assertion.""" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText """In all other cases, preserve the fact that types can be null in Java by using the
Kotlin nullable version of that type.""" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Rules:**" ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """Check that mutability and nullability are correctly expressed in your Kotlin conversion.
Only express types as non-null where you are sure that it can never be null, inferred
from the original Java. Use `val` instead of `var` where you see variables that are
never modified.""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Step 2: Nullability & Mutability" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText """For Java collections like `List` that are mutable by default, always use the Kotlin
`MutableList`, unless you see explicitly that the Java code uses an immutable wrapper
(e.g., `Collections.unmodifiableList()`) — in this case, use the Kotlin `List` (and
so on for other collections like `Set`, `Map` etc.)""" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "Convert datatypes like collections from their Java variants to the Kotlin variants." ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Rules:**" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 3 ;
                            oc:sectionTitle "Step 3: Collection Type Conversion" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent """Convert the Java code 1 to 1 into Kotlin, prioritising faithfulness to the original
Java semantics, to replicate the Java code's functionality and logic exactly.""" ],
                                [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 3 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText """To convert Java constructors that inject into fields, use the Kotlin primary
constructor. Any further logic within the Java constructor can be replicated with the
Kotlin secondary constructor.""" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText """Java classes that are implicitly open MUST be converted as Kotlin classes that are
explicitly `open`, using the `open` keyword.""" ] ],
                                [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "**Rules:**" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Step 1: Faithful 1:1 Translation" ],
