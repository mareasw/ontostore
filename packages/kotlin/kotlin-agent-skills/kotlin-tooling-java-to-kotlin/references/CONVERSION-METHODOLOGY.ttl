oc:kn_30aea93a a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Converting Java static utility methods to idiomatic Kotlin" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """// Java static utility → Kotlin top-level function with Elvis operator
fun greet(name: String?) {
  println("Hello, ${name ?: "Guest"} - today is ${LocalDate.now()}")
}""" .

oc:kn_682debd3 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "After completing each conversion step" ;
    oc:directiveContent "After each of the 4 conversion steps, verify all 5 invariants hold. If any invariant is violated, revert to the previous step and recalculate." ;
    oc:hasRationale "The invariant check acts as a self-correcting mechanism, preventing compounding errors across steps." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6eb57d95 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Step 1: Faithful 1:1 Translation" ;
    oc:directiveContent "Java classes that are implicitly open MUST be converted as Kotlin classes that are explicitly `open`, using the `open` keyword, because Kotlin classes are final by default." ;
    oc:hasRationale "Kotlin's final-by-default classes would break subclassing that Java allows implicitly." ;
    oc:severityLevel "HIGH" .

oc:kn_73f20925 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Step 4: Idiomatic Transformations for annotated properties" ;
    oc:directiveContent "Convert Java getter/setter pairs into Kotlin properties. Apply both @field: and @get: annotation targets where the Java code annotated both the field and the getter." ;
    oc:hasRationale "Missing an annotation target when consolidating field+getter into a property breaks framework behavior." .

oc:kn_859fc7e6 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Outputting each conversion step" ;
    oc:directiveContent """## Step {N} — {Step Name}
{Description of transformation applied}

```kotlin
{transformed code}
```

Invariants check: {list violated invariants or "All OK"}""" ;
    oc:templateVariables "Description",
        "N",
        "Step Name",
        "transformed code",
        "violated invariants" .

oc:kn_a06828cb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Step 2: Nullability analysis" ;
    oc:directiveContent "When Objects.requireNonNull or similar null assertions appear, the author has considered the value non-null. Use a non-null Kotlin type and remove the assertion." ;
    oc:hasRationale "Redundant null checks in Kotlin clutter code; the type system enforces the contract." .

oc:kn_aa069ff4 a oc:KnowledgeNode,
        oc:RollbackProcedure ;
    oc:appliesToContext "Invariant verification failure at any step" ;
    oc:directiveContent "If any of the 5 invariants fails after a step, revert the code to the previous step's output and recalculate the transformation from there." ;
    oc:hasRationale "Prevents cascading errors where a bad transformation at step N corrupts all subsequent steps." ;
    oc:severityLevel "HIGH" .

oc:kn_ab8d0988 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every Java-to-Kotlin conversion" ;
    oc:directiveContent "1. Faithful 1:1 Translation — Convert Java to Kotlin preserving exact semantics; use `open` for implicitly open Java classes; use primary constructor for field injection, secondary constructor for additional logic. 2. Nullability & Mutability — Express nullable types where Java values can be null; use non-null only where null assertions exist (e.g., Objects.requireNonNull); prefer `val` over `var` for never-modified variables. 3. Collection Type Conversion — Use Kotlin `MutableList` for Java mutable collections; use Kotlin `List` only when Java uses immutable wrappers (e.g., Collections.unmodifiableList()). 4. Idiomatic Transformations — Replace getters/setters with Kotlin properties; use lambdas, string templates, Elvis operator, and top-level functions where appropriate." ;
    oc:hasRationale "The 4-step process ensures behavior preservation first, then progressive refinement toward idiomatic Kotlin without breaking semantics." ;
    oc:stepOrder 1 .

oc:kn_ba5d01e2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Every step of conversion" ;
    oc:directiveContent "No new side-effects or behaviour may be introduced during conversion. The Kotlin output must replicate the Java code's functionality and logic exactly." ;
    oc:hasRationale "Behavioral equivalence is the foundational contract of the conversion; any deviation makes the output unreliable." ;
    oc:severityLevel "CRITICAL" .

oc:kn_befa1ce3 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Converting annotated Java domain models to Kotlin" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """// Java getter/setter with annotations → Kotlin property
open class User(
  @field:JsonProperty("id")
  @get:JsonProperty("id")
  val id: String
) {
  @field:Nullable
  @get:Nullable
  var nickname: String? = null
}""" .

oc:kn_f1921395 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Package and import handling at every step" ;
    oc:directiveContent "Preserve the package declaration and all imports. Carry forwards every import; only remove imports that shadow Kotlin names (e.g., java.util.List → Kotlin's List). Add no new imports." ;
    oc:hasRationale "Import changes can introduce shadowing conflicts or break existing class resolution in large codebases." ;
    oc:severityLevel "HIGH" .

oc:kn_f2e9b5eb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting annotated Java members" ;
    oc:directiveContent "Preserve all annotations and their targets exactly. Annotations targeting Java fields must use Kotlin annotation site targets: `@field:`, `@get:`, `@set:`, `@param:`." ;
    oc:hasRationale "Annotation targeting errors break reflection-based frameworks (Jackson, Hibernate, Dagger, etc.) at runtime." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fab9ecfd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Comment handling at every step" ;
    oc:directiveContent "Preserve all Javadoc comments: convert to KDoc in step 1, then carry KDoc forward preserving information where structure changes." ;
    oc:hasRationale "Documentation loss degrades code maintainability and breaks API contract documentation." ;
    oc:severityLevel "MEDIUM" .

