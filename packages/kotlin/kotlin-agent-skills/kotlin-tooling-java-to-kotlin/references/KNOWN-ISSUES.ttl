        oc:kn_91c5086f,
        oc:kn_999465c1 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:resolvesIntent "apply jvm interop annotations for java-to-kotlin migration",
        "fix platform type null-safety issues in converted kotlin code",
        "handle kotlin keyword conflicts from java identifiers",
        "map java constructs to idiomatic kotlin equivalents",
        "resolve kotlin compilation errors after java conversion" .

oc:kn_0402a8b8 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When converting Java methods using wildcard or raw generic types" ;
    oc:directiveContent "For wildcard generics: map ? extends T to out T (covariance), ? super T to in T (contravariance), and raw types to the most specific explicit type parameter (not defaulting to Any?)." ;
    oc:hasRationale "Correct variance annotations preserve type safety; raw types defaulting to Any? lose all type information and enable unsafe casts." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3b277814 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When calling overloaded Java methods that accept different functional interface types" ;
    oc:directiveContent "Never use trailing lambda syntax with overloaded Java methods accepting different SAM interfaces — the compiler cannot resolve the ambiguity. Always use explicit SAM constructor calls like Runnable { } or Callable { }." ;
    oc:hasRationale "Kotlin's SAM conversion heuristic picks one overload arbitrarily or fails to compile when multiple SAM-typed overloads exist." ;
    oc:severityLevel "HIGH" .

oc:kn_4c9fba50 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting Java primitive arrays (int[], long[], double[], boolean[]) to Kotlin" ;
    oc:directiveContent "Use specialized primitive array types (IntArray, LongArray, DoubleArray, BooleanArray) instead of boxed Array<Int>, Array<Long>, etc. to avoid boxing overhead." ;
    oc:hasRationale "Using Array<Int> wraps each element in a java.lang.Integer object, causing significant memory and performance overhead for large arrays." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5bdec4cd a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When converting Java static methods, constants, and static initializer blocks" ;
    oc:directiveContent "Map Java statics to Kotlin: top-level functions for stateless utility methods, companion object for class-tied methods, const val for compile-time primitives, val for object constants, and companion object init {} for static initializers." ;
    oc:hasRationale "Kotlin has no static keyword; choosing the wrong idiom leads to unnecessary object allocation or inaccessible methods from Java." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7c70104a a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting common Java constructs to idiomatic Kotlin" ;
    oc:directiveContent "Convert Java try-with-resources to Kotlin .use {} extension: BufferedReader(FileReader(path)).use { reader -> ... }. Convert synchronized blocks to synchronized(lock) { } and synchronized methods to @Synchronized fun. Convert instanceof checks to is with smart casting. Convert ternary to if/else expressions." ;
    oc:hasRationale "These mappings produce idiomatic Kotlin that leverages the language's features (smart casts, expression-oriented, extension functions) rather than literal translations." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8d85c7cc a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When converting Java methods/fields whose names clash with Kotlin keywords" ;
    oc:directiveContent "Java identifiers that are Kotlin reserved keywords (when, in, is, object, fun, val, var, typealias, as) cause compilation errors after conversion. Backtick-escape them or rename to non-keyword alternatives for internal APIs." ;
    oc:hasRationale "Kotlin's keyword set is larger than Java's, so valid Java identifiers become syntax errors in Kotlin without escaping or renaming." ;
    oc:severityLevel "HIGH" .

oc:kn_91c5086f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converted Kotlin code must maintain a clean Java-callable API" ;
    oc:directiveContent "Use @JvmStatic for companion object methods, @JvmField for companion object properties, @JvmOverloads for functions with default parameters, and @Throws for functions throwing checked exceptions — whenever the Kotlin code is called from Java." ;
    oc:hasRationale "Without these annotations, Java callers face awkward Companion.getInstance() calls, missing overloads, and uncatchable checked exceptions." ;
    oc:severityLevel "HIGH" .

oc:kn_999465c1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Whenever consuming Java APIs without @Nullable/@NotNull annotations in converted Kotlin code" ;
    oc:directiveContent "Platform types (T!) from unannotated Java code bypass Kotlin's null-safety. Always add explicit type declarations (nullable or non-null) based on analysis of the Java source, documentation, and call sites." ;
    oc:hasRationale "Leaving platform types unchecked defers null errors to runtime, negating Kotlin's primary safety advantage." ;
    oc:severityLevel "CRITICAL" .

