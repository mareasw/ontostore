    oc:requiresState oc:FileConverted ;
    oc:resolvesIntent "check semantic equivalence after java-to-kotlin migration",
        "validate post-conversion quality",
        "verify kotlin conversion correctness" ;
    oc:yieldsState oc:ConversionVerified .

oc:kn_0dd1d174 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "Framework-specific code (Spring, JPA/Hibernate, Lombok, Mockito)" ;
    oc:directiveContent "Spring proxied classes must be open; JPA entities must be open (not data classes) with no-arg constructors; Lombok must be fully removed and replaced with Kotlin equivalents; Mockito `when` clashes with Kotlin keyword and needs escaping or MockK replacement" ;
    oc:hasRationale "Each framework has specific constraints that automated converters handle poorly or not at all" ;
    oc:severityLevel "HIGH" .

oc:kn_45f0c676 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Every converted file" ;
    oc:directiveContent "All public API signatures (method names, parameter types, return types) must be preserved exactly after conversion; exception behavior must remain unchanged" ;
    oc:hasRationale "API breakage causes compilation failures in downstream consumers and runtime behavioral changes" ;
    oc:severityLevel "CRITICAL" .

oc:kn_638fd4d6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting annotated Java classes (JPA entities, Jackson models, Spring beans)" ;
    oc:directiveContent "Do not drop annotations during conversion. Use correct Kotlin annotation site targets (@field:, @get:, @set:, @param:) to preserve annotation placement semantics" ;
    oc:hasRationale "Dropped or mis-targeted annotations cause silent runtime failures in framework-managed code" ;
    oc:severityLevel "HIGH" .

oc:kn_6c7b5b3c a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "Output of verification checklist per converted file" ;
    oc:directiveContent """## {FileName} Conversion Verification
- [ ] Compilation: zero errors, zero new warnings
- [ ] Tests: all pass
- [ ] API: signatures + exceptions preserved
- [ ] Annotations: all present, targets correct
- [ ] Package/Imports: match original
- [ ] KDoc: Javadoc converted ({@code}→backtick, {@link}→[...], <p>→blank line)
- [ ] Nullability: correct use of ? and non-null
- [ ] Mutability: val/var correct; collections typed correctly
- [ ] Idioms: properties, string templates, when, smart casts applied
- [ ] Framework: Spring open/Lombok removed/JPA open+no-arg/Jackson targets
- [ ] Git: mv (not delete+create), separate rename commit""" ;
    oc:templateVariables "FileName" .

oc:kn_71e6cc40 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When auditing nullability and mutability of converted code" ;
    oc:directiveContent "Prefer val over var; use MutableList/MutableSet/MutableMap for Java mutable collections; use List/Set/Map only where Java used immutable wrappers; mark nullable Java types with ?" ;
    oc:hasRationale "Kotlin's type system exposes mutability and nullability — incorrect choices undermine safety guarantees" .

oc:kn_73764be5 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When committing the renamed .kt file" ;
    oc:directiveContent "Do not delete+create files for rename; always use git mv to preserve history. Keep rename commit separate from content changes" ;
    oc:hasRationale "Delete+create destroys git blame history; combined commits make bisecting impossible" ;
    oc:severityLevel "HIGH" .

oc:kn_8148236c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "After each Java file is converted to Kotlin" ;
    oc:directiveContent """1. Compile the .kt file and verify zero errors
2. Run all existing tests — must pass
3. Check for new compiler warnings
4. Verify no new side-effects or behavioral changes
5. Confirm all public API signatures preserved (names, params, returns)
6. Validate exception behavior unchanged
7. Check annotations preserved with correct site targets
8. Verify package declaration and imports
9. Convert Javadoc → KDoc
10. Audit nullability (non-null vs nullable)
11. Audit mutability (val vs var)
12. Audit collections (mutable vs immutable)
13. Apply Kotlin idioms (properties, string templates, when, smart casts)
14. Apply framework-specific rules (Spring, Lombok, JPA, Jackson, RxJava, Mockito)
15. git mv for rename, separate commit from content change""" ;
    oc:hasRationale "Systematic verification prevents subtle regressions that automated converters often introduce" ;
    oc:stepOrder 1 .

_:ref_0e41719dee672ec0 a oc:WorkflowStep ;
    dcterms:description "Apply framework-specific rules: Spring open classes, Lombok removal, JPA entity rules, Jackson targets, RxJava→Coroutines, Mockito→MockK" ;
    oc:expectedOutcome "Framework compatibility maintained" ;
    oc:stepDependsOn _:ref_0a0d518fc4b90dcd,
        _:ref_d79e59a61df0cb5d ;
    oc:stepId "verify-framework" .

_:ref_cb0e487a9491da51 a oc:WorkflowStep ;
    dcterms:description "Apply Kotlin idioms: properties, string templates, when, smart casts, elvis operator" ;
    oc:expectedOutcome "Idiomatic Kotlin code" ;
    oc:stepDependsOn _:ref_0d7e3ea0b7dc746a ;
    oc:stepId "verify-idioms" .

_:ref_d79e59a61df0cb5d a oc:WorkflowStep ;
    dcterms:description "Confirm all annotations preserved with correct Kotlin site targets" ;
    oc:expectedOutcome "All annotations present and correctly targeted" ;
    oc:stepDependsOn _:ref_0d7e3ea0b7dc746a ;
    oc:stepId "verify-annotations" .

_:ref_0a0d518fc4b90dcd a oc:WorkflowStep ;
    dcterms:description "Verify no new side-effects, API signatures preserved, exception behavior unchanged" ;
    oc:expectedOutcome "Semantic equivalence confirmed" ;
    oc:stepDependsOn _:ref_0d7e3ea0b7dc746a ;
    oc:stepId "verify-semantics" .

_:ref_0d7e3ea0b7dc746a a oc:WorkflowStep ;
    dcterms:description "Compile the .kt file and verify zero errors and no new warnings" ;
    oc:expectedOutcome "Clean compilation with no errors or new warnings" ;
    oc:stepId "compile" .

