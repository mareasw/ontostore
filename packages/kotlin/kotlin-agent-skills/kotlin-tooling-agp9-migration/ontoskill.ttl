_:ref_52aac7882c812ac4 a oc:WorkflowStep ;
    dcterms:description "**AGP version** — update to 9.0.0+ and add the KMP library plugin." ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:CodeExample ;
            oc:blockType "code_block" ;
            oc:codeContent """plugins {
