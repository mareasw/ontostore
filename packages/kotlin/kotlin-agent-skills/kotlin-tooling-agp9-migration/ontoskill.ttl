oc:kn_0ff3da3c a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Migrating kotlinOptions to compilerOptions in pure Android (non-KMP) modules" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """// Old (AGP 8.x)
android {
    kotlinOptions {
        jvmTarget = "11"
        languageVersion = "2.0"
        freeCompilerArgs += listOf("-Xopt-in=kotlin.RequiresOptIn")
    }
}
// New (AGP 9.0)
kotlin {
    compilerOptions {
        jvmTarget.set(org.jetbrains.kotlin.gradle.dsl.JvmTarget.JVM_11)
        languageVersion.set(org.jetbrains.kotlin.gradle.dsl.KotlinVersion.KOTLIN_2_0)
        optIn.add("kotlin.RequiresOptIn")
    }
}""" .

oc:kn_111169a9 a oc:Command,
        oc:KnowledgeNode ;
    oc:appliesToContext "When Bash is available, run to get structured project analysis before migration" ;
    oc:directiveContent "bash scripts/analyze-project.sh [PROJECT_ROOT]" .

oc:kn_2ca31511 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating library modules that used build variants, flavors, or BuildConfig" ;
    oc:directiveContent "The KMP library plugin produces a single build variant. There are no build types or product flavors. BuildConfig is unavailable. Use localDependencySelection for dependency variant resolution." ;
    oc:hasRationale "This is a fundamental architectural change in the KMP library plugin" ;
    oc:severityLevel "HIGH" .

oc:kn_342a7a86 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any migration changes" ;
    oc:directiveContent "Always classify each module into one of four migration paths (A: library swap, B: Android app split, C: full restructure, or pure Android) before making changes. Path B is mandatory for KMP+app modules; Path C is recommended for monolithic multiplatform modules." ;
    oc:hasRationale "Correct path selection prevents unnecessary work and ensures the minimum required changes are made" .

oc:kn_4f121d4c a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When migrating KMP library modules that use Android or Compose resources" ;
    oc:directiveContent "Compose resources crash without explicit androidResources { enable = true } in the KMP library plugin. Android resources are NOT processed by default." ;
    oc:hasRationale "Silent failure — resources are simply ignored without error until referenced, causing runtime crashes" ;
    oc:severityLevel "HIGH" .

oc:kn_58b330b1 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When KMP library module depends on Android libraries with multiple build types or flavors" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """kotlin {
    android {
        localDependencySelection {
            selectBuildTypeFrom.set(listOf("debug", "release"))
            productFlavorDimension("tier") {
                selectFrom.set(listOf("free"))
            }
        }
    }
}""" .

oc:kn_6622e900 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before any AGP 9.0 migration" ;
    oc:directiveContent "Before migrating: (1) inventory all plugins and check compatibility with PLUGIN-COMPATIBILITY.md, (2) verify Gradle 9.1+, JDK 17+, SDK Build Tools 36.0.0, (3) read settings.gradle.kts, all build.gradle.kts files, gradle.properties, and gradle-wrapper.properties." ;
    oc:hasRationale "Missing prerequisites or incompatible plugins can completely block migration" .

oc:kn_7344a83e a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing migration changes" ;
    oc:directiveContent "After migration: run ./gradlew build, verify all platform targets build, run ./gradlew :shared:allTests and Android unit tests, confirm no com.android.library/com.android.application in KMP modules, no org.jetbrains.kotlin.android in AGP 9.0 modules, correct source set names." ;
    oc:hasRationale "Comprehensive verification catches silent migration failures like dropped ProGuard rules or misconfigured source sets" .

oc:kn_8194a60c a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When third-party plugins conflict with AGP 9.0 built-in Kotlin or new DSL" ;
    oc:directiveContent "If blocked by plugin incompatibilities, temporarily set android.builtInKotlin=false and/or android.newDsl=false in gradle.properties. Always ask the user before opting out and note these are temporary." ;
    oc:hasRationale "These flags will be removed in future AGP versions; they buy time but are not a solution" .

oc:kn_87a53073 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Full migration workflow" ;
    oc:directiveContent "1. Analyze project structure (settings.gradle.kts, build files, gradle.properties, wrapper props) 2. Classify each module (Path A/B/C/pure Android) 3. Ask user minimum (Path B) vs recommended (Path C) 4. Update versions (Gradle 9.1+, AGP 9.0.1+, JDK 17+, Build Tools 36.0.0) 5. Migrate each module per its path 6. Remove kotlin-android plugin globally 7. Migrate kapt to KSP/legacy-kapt 8. Update gradle.properties defaults 9. Verify build succeeds across all platforms" ;
    oc:stepOrder 1 .

oc:kn_b1a47db4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When a module uses annotation processing" ;
    oc:directiveContent "Do not apply org.jetbrains.kotlin.kapt with AGP 9.0 built-in Kotlin. Migrate to KSP (preferred) or use com.android.legacy-kapt as fallback." ;
    oc:hasRationale "kapt is incompatible with AGP 9.0's built-in Kotlin and will cause build failures" ;
    oc:severityLevel "HIGH" .

oc:kn_b7dbe2d7 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When module uses kotlin.multiplatform + com.android.application" ;
    oc:directiveContent "Path B (App Split): 1. Create androidApp module with com.android.application 2. Move Android entry point code (Activity, Manifest, resources) to androidApp 3. Add :androidApp to settings.gradle.kts 4. Add plugin declarations to root build 5. Convert original module via Path A 6. Ensure distinct namespaces 7. Remove applicationId/targetSdk/versionCode from shared 8. Update IDE run configurations" ;
    oc:stepOrder 3 .

oc:kn_c2870b84 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Minimal KMP library module build.gradle.kts after AGP 9.0 migration" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """plugins {
    alias(libs.plugins.kotlinMultiplatform)
    alias(libs.plugins.androidKmpLibrary)
}
kotlin {
    android {
        namespace = "com.example.lib"
        compileSdk = 35
        minSdk = 24
        compilerOptions {
            jvmTarget.set(org.jetbrains.kotlin.gradle.dsl.JvmTarget.JVM_11)
        }
    }
}""" .

oc:kn_c8e13047 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When a library module had consumerProguardFiles in old android { defaultConfig {} } block" ;
    oc:directiveContent "Consumer ProGuard rules are silently dropped if not migrated to consumerProguardFiles.add(file(...)) in the new DSL. No warning is emitted." ;
    oc:hasRationale "Can cause runtime crashes in release builds of consuming applications due to missing ProGuard rules" ;
    oc:severityLevel "HIGH" .

oc:kn_d39d574a a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When module uses kotlin.multiplatform + com.android.library" ;
    oc:directiveContent "Path A (Library): 1. Replace com.android.library → com.android.kotlin.multiplatform.library 2. Remove kotlin-android 3. Move android {} into kotlin { android {} } 4. Rename src/main→androidMain, src/test→androidHostTest, src/androidTest→androidDeviceTest 5. Move deps to sourceSets 6. Enable androidResources { enable = true } if needed 7. Add withJava() for .java sources 8. Configure withHostTest/withDeviceTest 9. Migrate debugImplementation→androidRuntimeClasspath 10. Migrate consumerProguardFiles" ;
    oc:stepOrder 2 .

oc:kn_dcd35960 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent """Project Analysis:
- Gradle version: {gradle_version}
- AGP version: {agp_version}
- Kotlin version: {kgp_version}
- Modules:
  - {module_name}: {plugins} → Path {A|B|C|none}
- Legacy flags: {flags}
- Status: {needs_migration|already_migrated}""" ;
    oc:templateVariables "agp_version",
        "flags",
        "gradle_version",
        "kgp_version",
        "module_name",
        "needs_migration",
        "plugins" .

oc:kn_de0e794b a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Version requirements before starting AGP 9.0 migration" ;
    oc:directiveContent "Gradle 9.1.0+, JDK 17+, Android SDK Build Tools 36.0.0, AGP 9.0.1+, KGP 2.0.0+ (2.3.0+ recommended), KSP 2.3.1+ if used" .

oc:kn_e0584bdb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "All modules using com.android.application or com.android.library with AGP 9.0" ;
    oc:directiveContent "Never apply org.jetbrains.kotlin.android plugin in AGP 9.0 modules. AGP 9.0 has built-in Kotlin support and the plugin will conflict." ;
    oc:hasRationale "The kotlin-android plugin conflicts with AGP 9.0's built-in Kotlin compilation, causing build failures" ;
    oc:severityLevel "CRITICAL" .

oc:kn_fd7be75e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When any module combines KMP with Android application plugin" ;
    oc:directiveContent "AGP 9.0 makes com.android.application and com.android.library incompatible with org.jetbrains.kotlin.multiplatform in the same module. KMP+Android app modules MUST be split into separate modules." ;
    oc:hasRationale "This is the fundamental breaking change in AGP 9.0 that necessitates all migration paths" ;
    oc:severityLevel "CRITICAL" .

