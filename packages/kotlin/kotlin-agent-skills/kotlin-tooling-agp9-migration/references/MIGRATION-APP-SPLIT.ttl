oc:kn_1c9f2340 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting namespace in both build.gradle.kts files" ;
    oc:directiveContent "The androidApp and shared modules must have different namespace values (e.g. com.example.app vs com.example.shared). Colliding namespaces produce duplicate R class errors at compile time." ;
    oc:hasRationale "Android resource generation requires unique namespace per module to generate distinct R classes" ;
    oc:severityLevel "HIGH" .

oc:kn_24360034 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the shared module's build.gradle.kts" ;
    oc:directiveContent "Use androidTarget {} → android {} as the DSL migration for the shared module's Kotlin block. The old androidTarget DSL is replaced with android inside kotlin {}." ;
    oc:hasRationale "AGP 9.0 KMP library plugin uses a new DSL shape for Android target configuration" ;
    oc:severityLevel "MEDIUM" .

oc:kn_47491b61 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating AGP 9.0 migration paths for any module applying both plugins" ;
    oc:directiveContent "AGP 9.0 does NOT support com.android.application combined with org.jetbrains.kotlin.multiplatform in the same module. The split is mandatory, not optional." ;
    oc:hasRationale "This is a hard incompatibility — the build will fail if both plugins remain in the same module" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4f0f2605 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating the shared/build.gradle.kts — uses com.android.kotlin.multiplatform.library, no applicationId/buildTypes" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """plugins {
    alias(libs.plugins.kotlinMultiplatform)
    alias(libs.plugins.androidKmpLibrary)
    alias(libs.plugins.composeMultiplatform)
    alias(libs.plugins.composeCompiler)
}
kotlin {
    android { namespace = "com.example.shared"; compileSdk = 35; minSdk = 24
        androidResources { enable = true } }
    sourceSets { commonMain.dependencies { /* shared deps */ } }
}""" .

oc:kn_52f305fa a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating the androidApp/build.gradle.kts — no kotlin-android plugin, no kotlin.multiplatform plugin" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """plugins {
    alias(libs.plugins.androidApplication)
    alias(libs.plugins.composeCompiler)
}
android {
    namespace = "com.example.app"
    compileSdk = 35
    defaultConfig { applicationId = "com.example.app"; minSdk = 24; targetSdk = 35 }
    buildFeatures { compose = true }
    kotlin { compilerOptions { jvmTarget.set(JvmTarget.JVM_11) } }
}
dependencies {
    implementation(project(":shared"))
}""" .

oc:kn_75f60ab0 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the relocated MainActivity in androidApp that delegates to shared Compose UI" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContent { App() }  // Shared composable from :shared
    }
}""" .

oc:kn_8d318ab9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring the new androidApp/build.gradle.kts" ;
    oc:directiveContent "Never apply org.jetbrains.kotlin.android to the androidApp module. AGP 9.0's com.android.application plugin has built-in Kotlin support; applying kotlin-android separately will cause a conflict error." ;
    oc:hasRationale "Double Kotlin compilation registration causes build failure" ;
    oc:severityLevel "CRITICAL" .

oc:kn_91666856 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When moving the manifest from composeApp/src/androidMain/ to androidApp/src/main/" ;
    oc:directiveContent "After moving AndroidManifest.xml to androidApp, the android:name attribute on <activity> must use the fully qualified class name. The old manifest may have relied on a default or short class name that no longer resolves." ;
    oc:hasRationale "The manifest merger needs the explicit class path because the activity class is now in a different module" ;
    oc:severityLevel "HIGH" .

oc:kn_97596d85 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When converting the original module to the shared KMP library" ;
    oc:directiveContent "The shared module must use com.android.kotlin.multiplatform.library, NOT com.android.library. Application-only concepts (applicationId, versionCode, versionName, targetSdk, buildTypes, productFlavors) must NOT appear in the shared module." ;
    oc:hasRationale "The KMP library plugin has a single-variant architecture and does not support application-specific configurations" ;
    oc:severityLevel "HIGH" .

oc:kn_d07090bc a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing all migration steps" ;
    oc:directiveContent "Run ./gradlew :androidApp:assembleDebug and ./gradlew :shared:assemble to verify both modules build independently. Check that namespaces are unique and no duplicate R class errors occur." ;
    oc:severityLevel "HIGH" .

oc:kn_d243fd35 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When the project has an iOS target and the module is renamed" ;
    oc:directiveContent "If iOS target exists and the module was renamed from composeApp to shared: update baseName in binaries.framework, update Xcode Run Script build phase from :composeApp: to :shared:, update all Swift import statements, and update framework search paths." ;
    oc:hasRationale "The iOS framework name and Gradle task paths are tied to the module name — mismatched references break the Xcode build" ;
    oc:severityLevel "HIGH" .

oc:kn_d4da3b27 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When executing the mandatory module split for AGP 9.0" ;
    oc:directiveContent "1. Create androidApp/ directory with build.gradle.kts (com.android.application only). 2. Move MainActivity, Application class, AndroidManifest.xml, app-level resources, ProGuard rules to androidApp/src/main/. 3. Convert original module to shared/ with kotlin.multiplatform + com.android.kotlin.multiplatform.library. 4. Remove application-only config from shared. 5. Add implementation(project(\":shared\")) to androidApp. 6. Update settings.gradle.kts includes. 7. Update root build.gradle.kts plugin declarations. 8. Ensure unique namespaces. 9. Update IDE run configs and Xcode project if applicable. 10. Verify with ./gradlew :androidApp:assembleDebug and ./gradlew :shared:assemble." ;
    oc:stepOrder 1 .

oc:kn_e2e4dd8b a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "The project must use AGP 9.0+ and Gradle 9.1.0+. The project must have been analyzed and the target module classified as requiring Path B (kotlin.multiplatform + com.android.application combined)." .

oc:kn_f1686238 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Always, before making any file changes" ;
    oc:directiveContent "Before starting: read settings.gradle.kts, the target module's build.gradle.kts, and verify the module applies both kotlin.multiplatform and com.android.application. Confirm no org.jetbrains.kotlin.android plugin is applied." .

