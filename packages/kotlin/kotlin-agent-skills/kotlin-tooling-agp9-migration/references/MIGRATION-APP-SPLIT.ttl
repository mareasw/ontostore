    oc:differentia "Splits a monolithic KMP + Android application module into separate androidApp and shared KMP library modules for AGP 9.0 compatibility" ;
    oc:extends oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_agp9_migration ;
    oc:handlesFailure oc:ManifestActivityNotFound,
        oc:NamespaceCollision,
        oc:PluginConflict ;
    oc:hasArgumentHint "module-name (e.g. composeApp)" ;
    oc:hasCategory "development" ;
    oc:hasPackageName "kotlin-tooling-agp9-migration" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "AGP 9.0 does not support `com.android.application` combined with `org.jetbrains.kotlin.multiplatform` in the same module. You must split the monolithic `composeApp` module into a pure Android application module and a KMP shared library module." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "After the split, the run configuration for the Android app must point to `:androidApp` instead of `:composeApp`:" ],
                                _:ref_c12ecf20192d0ca6 ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Android Studio" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 1 ;
                                    oc:textContent "If the shared module was renamed from `composeApp` to `shared`:" ],
                                _:ref_ca932b19a45ae57f ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "Xcode (iOS)" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 10 ;
                    oc:sectionTitle "Run Configuration Updates" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
