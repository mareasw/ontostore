oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_agp9_migration_plugin_compatibility a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "plugin-compatibility" ;
    skos:broader "Compatibility reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/kotlin/kotlin-agent-skills/kotlin-tooling-agp9-migration" ;
    oc:contentHash "ec47b996d9459c435fb2ca0588bb35189bc81370c533fee8f38cec93755e92a8" ;
    oc:differentia "that catalogs third-party plugin status against AGP 9.0 with minimum versions, opt-out flags, and known-broken entries" ;
    oc:extends oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_agp9_migration ;
    oc:handlesFailure oc:IncompatiblePluginDetected ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent """AGP 9.0 introduces breaking changes that affect many third-party plugins. **Before migrating, check
which plugins the project uses and whether they are compatible.**""" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 2 ;
                            oc:tableCaption "## Known Broken Plugins (No Workaround)" ;
                            oc:tableMarkdown """| Plugin                       | Status                    |
|------------------------------|---------------------------|
| `com.newrelic.agent.android` | Incompatible with AGP 9.0 |
| `com.huawei.agconnect.agcp`  | Incompatible with AGP 9.0 |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Known Broken Plugins (No Workaround)" ],
                [ a oc:Section ;
                    oc:hasContent _:ref_ec141ce2d67d19fb ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "What To Do" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 12 ;
                            oc:tableCaption "These work but require temporarily setting `android.newDsl=false` (or other flags)" ;
                            oc:tableMarkdown """| Plugin                                                  | Workaround                                                                                          |
|---------------------------------------------------------|-----------------------------------------------------------------------------------------------------|
| `androidx.baselineprofile` (< 1.5.0-alpha01)            | `android.newDsl=false`                                                                              |
| `de.mannodermaus.android-junit5` (< 1.13.4.0)           | `android.newDsl=false`                                                                              |
| `com.google.android.gms:oss-licenses-plugin` (< 0.10.8) | `android.newDsl=false`                                                                              |
| `com.apollographql.apollo` (< 4.4.0)                    | `android.newDsl=false`                                                                              |
| `org.gradle.android.cache-fix` (< 3.0.2)                | `android.newDsl=false`                                                                              |
| `com.github.triplet.play` (< 4.0.0)                     | `android.newDsl=false`                                                                              |
| `app.cash.sqldelight`                                   | `android.newDsl=false` + `android.disallowKotlinSourceSets=false`                                   |
| `com.google.protobuf`                                   | `android.newDsl=false`                                                                              |
| `app.cash.paparazzi`                                    | `android.newDsl=false`                                                                              |
| `io.gitlab.arturbosch.detekt` (< 2.0.0)                 | `android.newDsl=false` + `android.builtInKotlin=false`                                              |
| `org.jlleitschuh.gradle.ktlint`                         | `android.builtInKotlin=false`                                                                       |
| `dev.icerock.mobile.multiplatform-resources` (< 0.26.0) | `android.builtInKotlin=false` + `android.newDsl=false` + `android.sourceset.disallowProvider=false` |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "These work but require temporarily setting `android.newDsl=false` (or other flags):" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Plugins Requiring Opt-Out Flags" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 8 ;
                            oc:tableCaption "## Known Compatible Plugins (minimum version required)" ;
                            oc:tableMarkdown """| Plugin                              | Minimum Compatible Version | Notes                                                                                                                                |
|-------------------------------------|----------------------------|--------------------------------------------------------------------------------------------------------------------------------------|
| `com.google.devtools.ksp`           | 2.3.1 (2.3.3+ recommended) | 2.3.1 adds AGP 9.0 support; 2.3.3+ fixes deprecated compilerOptions KGP API usage. May need `android.disallowKotlinSourceSets=false` |
| `com.google.dagger.hilt.android`    | 2.59                       | —                                                                                                                                    |
| `com.google.firebase.firebase-perf` | 2.0.2                      | —                                                                                                                                    |
| `androidx.navigation.safeargs`      | 2.9.5                      | —                                                                                                                                    |
| `org.jetbrains.compose`             | 1.9.3                      | —                                                                                                                                    |
| `org.jetbrains.dokka`               | 2.2.0-Beta                 | —                                                                                                                                    |
| `app.cash.burst`                    | 2.10.0                     | —                                                                                                                                    |
| `com.google.firebase.testlab`       | 0.0.1-alpha11              | —                                                                                                                                    |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Known Compatible Plugins (minimum version required)" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Plugin Compatibility: AGP 9.0" ] ;
    oc:hasWorkflow _:ref_ec141ce2d67d19fb ;
