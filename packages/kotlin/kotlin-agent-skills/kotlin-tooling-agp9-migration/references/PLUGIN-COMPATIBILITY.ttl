@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_agp9_migration_plugin_compatibility a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "plugin-compatibility" ;
    skos:broader "Compatibility reference" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/kotlin/kotlin-agent-skills/kotlin-tooling-agp9-migration" ;
    oc:contentHash "ec47b996d9459c435fb2ca0588bb35189bc81370c533fee8f38cec93755e92a8" ;
    oc:differentia "Catalogs third-party plugin compatibility with AGP 9.0, including minimum versions, opt-out flags, and broken plugins" ;
    oc:extends oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_agp9_migration ;
    oc:handlesFailure oc:MissingOptOutFlag,
        oc:PluginIncompatible ;
    oc:hasAllowedTool "Glob",
        "Grep",
        "Read" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_35def7a2,
        oc:kn_4d801c17,
        oc:kn_959e0012,
        oc:kn_ac8baba4,
        oc:kn_f5acda5a ;
    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "check plugin compatibility with AGP 9.0",
        "determine which plugins need opt-out flags for AGP 9 migration",
        "identify incompatible plugins before AGP 9 migration",
        "update plugin versions for AGP 9.0 compatibility" ;
    oc:yieldsState oc:PluginCompatibilityVerified .

oc:kn_35def7a2 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When using KSP with AGP 9.0" ;
    oc:directiveContent "KSP versions 2.3.1–2.3.2 use a deprecated compilerOptions KGP API. Use KSP 2.3.3+ to avoid deprecation warnings and potential future breakage. KSP may also require android.disallowKotlinSourceSets=false." ;
    oc:hasRationale "The deprecated API usage in KSP 2.3.1–2.3.2 produces warnings that may become hard errors in future Kotlin/GP releases." ;
    oc:severityLevel "MEDIUM" .

oc:kn_4d801c17 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any AGP 9.0 migration" ;
    oc:directiveContent "Before starting AGP 9.0 migration, inventory all project plugins and verify each against the compatibility tables to avoid build failures mid-migration." ;
    oc:hasRationale "Discovering an incompatible plugin mid-migration can leave the project in a broken state that is costly to roll back." ;
    oc:severityLevel "CRITICAL" .

oc:kn_959e0012 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When plugins require opt-out flags to work with AGP 9.0" ;
    oc:directiveContent "For plugins that work with opt-out flags (android.newDsl=false, android.builtInKotlin=false, android.disallowKotlinSourceSets=false), add the required flags to gradle.properties as temporary workarounds and note them for future removal." ;
    oc:hasRationale "Opt-out flags disable new AGP 9.0 DSL features and should be removed once plugins release proper AGP 9.0 support, so tracking them is essential." ;
    oc:severityLevel "HIGH" .

oc:kn_ac8baba4 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When updating plugin versions for AGP 9.0 compatibility" ;
    oc:directiveContent "Always update plugins to their minimum AGP 9.0-compatible version before migration: KSP 2.3.1+ (2.3.3+ recommended), Hilt 2.59+, Firebase Perf 2.0.2+, Navigation SafeArgs 2.9.5+, Compose 1.9.3+, Dokka 2.2.0-Beta+." ;
    oc:hasRationale "Using the minimum compatible version ensures the plugin has the necessary AGP 9.0 support code and avoids cryptic build errors." ;
    oc:severityLevel "HIGH" .

oc:kn_f5acda5a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the project uses New Relic or Huawei AGConnect plugins" ;
    oc:directiveContent "Plugins com.newrelic.agent.android and com.huawei.agconnect.agcp have no workaround and are fundamentally incompatible with AGP 9.0. The user must remove them or delay migration." ;
    oc:hasRationale "These plugins cannot be made to work with AGP 9.0 under any configuration; proceeding will guarantee build failure." ;
    oc:severityLevel "CRITICAL" .

