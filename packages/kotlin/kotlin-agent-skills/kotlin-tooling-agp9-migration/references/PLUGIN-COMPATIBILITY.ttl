    oc:isUserInvocable false ;
    oc:nature "Concept" ;
    oc:requiresState oc:ProjectPluginsInventoried ;
    oc:resolvesIntent "check plugin compatibility with AGP 9.0",
        "determine if a plugin is broken on AGP 9.0",
        "find minimum compatible plugin versions for AGP 9.0",
        "identify plugins needing opt-out flags for AGP 9.0 migration" ;
    oc:yieldsState oc:PluginCompatibilityVerified .

oc:kn_15c727f0 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:directiveContent "Requires full list of project plugins from settings.gradle.kts and module-level build.gradle.kts files before compatibility can be assessed." .

oc:kn_3789d1f7 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing any AGP 9.0 migration path" ;
    oc:directiveContent "Verify each third-party plugin has a compatible version or a known opt-out workaround before beginning AGP 9.0 migration steps." ;
    oc:hasRationale "Plugin incompatibility is the most common cause of post-migration build failures." ;
    oc:severityLevel "CRITICAL" .

oc:kn_57acbe48 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding opt-out flags to gradle.properties for plugin compatibility" ;
    oc:directiveContent "Do not treat opt-out flags (android.newDsl=false, android.builtInKotlin=false, etc.) as permanent solutions. They are temporary workarounds that should be removed once plugin authors release compatible versions." ;
    oc:hasRationale "Opt-out flags disable new AGP 9.0 features and may themselves be deprecated in future releases." ;
    oc:severityLevel "HIGH" .

oc:kn_a7b99cfe a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "When performing plugin compatibility check for AGP 9.0 migration" ;
    oc:directiveContent "1. Inventory all plugins in the project (settings.gradle.kts and each module's build.gradle.kts). 2. Check each against the compatible-plugins table for minimum versions. 3. If a plugin is in the broken table with no workaround, inform user to remove or wait. 4. If a plugin needs opt-out flags, add them to gradle.properties as temporary workarounds. 5. Update all plugin versions to their AGP 9.0-compatible minimums before proceeding with migration." ;
    oc:stepOrder 1 .

oc:kn_c31d7774 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:directiveContent "Plugin compatibility report: For each plugin → Status: [compatible at version X / needs opt-out flags: Y / broken — no workaround]. Recommendation: [upgrade to X / add flag Y / remove or defer migration]." ;
    oc:templateVariables "plugin",
        "recommendation",
        "status" .

oc:kn_d75167e7 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the project uses either broken plugin" ;
    oc:directiveContent "com.newrelic.agent.android and com.huawei.agconnect.agcp are incompatible with AGP 9.0 with no workaround. The user must remove them or wait for upstream updates." ;
    oc:hasRationale "These plugins rely on removed AGP internal APIs and have no migration path yet." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d9370567 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the project uses com.google.devtools.ksp" ;
    oc:directiveContent "KSP requires version 2.3.1 minimum for AGP 9.0 compatibility; 2.3.3+ is recommended to fix deprecated compilerOptions KGP API usage. May need android.disallowKotlinSourceSets=false." ;
    oc:hasRationale "Older KSP versions will fail at build time with AGP 9.0 due to internal API changes." ;
    oc:severityLevel "CRITICAL" .

oc:kn_f3c555f3 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "At the start of any AGP 9.0 migration" ;
    oc:directiveContent "Before starting AGP 9.0 migration, inventory all project plugins and check each against the compatibility tables. If any plugin is broken without workaround, stop and inform the user before proceeding." ;
    oc:hasRationale "Discovering a blocking incompatibility mid-migration wastes effort and may leave the project in a broken state." ;
    oc:severityLevel "HIGH" .

_:ref_76a8cbc96356d3d9 a oc:WorkflowStep ;
    dcterms:description "**Inventory all plugins** used in the project" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_88c6ef3f1db884f7 a oc:WorkflowStep ;
    dcterms:description "**If any plugin is broken without workaround**, inform the user — they may need to wait for a plugin update or remove it" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_8fff85ff9a82f2d7 a oc:WorkflowStep ;
    dcterms:description "**If plugins need opt-out flags**, add them to `gradle.properties` and note them as temporary workarounds" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_9a53b9eb9c8c2c9f a oc:WorkflowStep ;
    dcterms:description "**Check each against the tables above**" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_eac46b377b2d90e3 a oc:WorkflowStep ;
    dcterms:description "**Update plugin versions** to their AGP 9.0-compatible versions before or during migration" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_ec141ce2d67d19fb a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 1 ;
    oc:hasStep _:ref_76a8cbc96356d3d9,
        _:ref_88c6ef3f1db884f7,
