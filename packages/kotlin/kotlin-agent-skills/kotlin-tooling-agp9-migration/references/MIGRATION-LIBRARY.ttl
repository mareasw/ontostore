oc:kn_29c9540f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating consumer ProGuard configuration" ;
    oc:directiveContent "Never leave consumer ProGuard rules in the old android { defaultConfig { consumerProguardFiles() } } block — it no longer exists and rules will be silently dropped." ;
    oc:hasRationale "The old android {} top-level block is removed; ProGuard rules must be moved to kotlin { android { consumerProguardFiles.add() } }" ;
    oc:severityLevel "CRITICAL" .

oc:kn_378e27df a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the module contains .java files in src/androidMain/java/" ;
    oc:directiveContent "Java source files in androidMain are ignored unless withJava() is explicitly called inside kotlin { android { } }." ;
    oc:hasRationale "Only Kotlin compilation is enabled by default; Java compilation must be opted into" ;
    oc:severityLevel "HIGH" .

oc:kn_7bf23d4e a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When migrating test configurations" ;
    oc:directiveContent "Test source sets must be explicitly opted into: withHostTest {} for JVM-based unit tests, withDeviceTest {} for instrumented tests. Without these, test source sets are not created." ;
    oc:hasRationale "Unlike the old plugin where test source sets existed by default, the new plugin requires explicit opt-in" ;
    oc:severityLevel "HIGH" .

oc:kn_80288df9 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any AGP 9 library migration" ;
    oc:directiveContent "Before starting migration, verify minimum versions: AGP 9.0.0+, Gradle 9.1.0+, KGP 2.0.0+ (2.3.0+ recommended)." ;
    oc:hasRationale "Older versions do not support the com.android.kotlin.multiplatform.library plugin ID" .

oc:kn_863850c2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When the module contains Android resources in src/androidMain/res/" ;
    oc:directiveContent "Android resources (res/) and R class generation are NOT processed by default with the new plugin. You must explicitly enable: androidResources { enable = true }." ;
    oc:hasRationale "Default-off behavior prevents unnecessary resource processing but breaks builds that assume R class availability" ;
    oc:severityLevel "HIGH" .

oc:kn_923001f2 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating dependency declarations" ;
    oc:directiveContent "Prefer putting dependencies inside kotlin { sourceSets { } } blocks rather than the top-level dependencies {} block. Top-level is only needed for special configurations like androidRuntimeClasspath." ;
    oc:hasRationale "Build variants (debug/release) are removed from the KMP library plugin, so variant-specific configurations like debugImplementation no longer exist" .

oc:kn_b929d2ea a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When dependency resolution fails due to missing variant matching" ;
    oc:directiveContent "If a legacy Android library dependency exposes multiple variants (debug/release or custom flavor dimensions), use localDependencySelection { selectBuildTypeFrom.set(); productFlavorDimension() { selectFrom.set() } } to explicitly resolve them." ;
    oc:hasRationale "The KMP library plugin has no build variants, so it cannot automatically match variant-specific dependencies" .

oc:kn_ce984d2f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring JVM target for Android compilation" ;
    oc:directiveContent "Do not use the old kotlinOptions { jvmTarget } DSL inside androidTarget { compilations.all { } } — it is removed in AGP 9.0." ;
    oc:hasRationale "The kotlinOptions DSL is deprecated and removed; use compilerOptions { jvmTarget.set() } instead" ;
    oc:severityLevel "CRITICAL" .

oc:kn_fdaffd2f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When restructuring build.gradle.kts for the new plugin" ;
    oc:directiveContent "All Android configuration moves from the top-level android {} block into kotlin { android {} }. The LibraryExtension class from AGP is no longer used — everything goes through KotlinMultiplatformExtension." ;
    oc:hasRationale "The new KMP-integrated plugin consolidates all configuration under the Kotlin extension, eliminating the separate Android extension" .

