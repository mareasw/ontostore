    oc:hasCategory "development" ;
    oc:hasRequirement oc:req_07187d77,
        oc:req_1a577469,
        oc:req_527ea598,
        oc:req_638fd8fd,
        oc:req_8030d78f,
        oc:req_f17f111a ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "This reference covers the full migration of a Kotlin Multiplatform library module from `com.android.library` (AGP 8.x) to `com.android.kotlin.multiplatform.library` (AGP 9.x)." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 4 ;
                            oc:tableCaption "The new KMP-integrated plugin does NOT change the expected source directory layout. The standard KMP source sets still apply" ;
                            oc:tableMarkdown """| Source Set              | Directory                 |
|-------------------------|---------------------------|
| `commonMain`            | `src/commonMain/kotlin/`  |
| `androidMain`           | `src/androidMain/kotlin/` |
| `androidMain` resources | `src/androidMain/res/`    |
| `iosMain`               | `src/iosMain/kotlin/`     |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The new KMP-integrated plugin does NOT change the expected source directory layout. The standard KMP source sets still apply:" ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 4 ;
                            oc:rowCount 5 ;
                            oc:tableCaption "**No renames are required** if you already use the standard KMP layout. If your module previously used the classic Android layout (`src/main/java/`, `src/main/res/`), you must migrate to the KMP layout" ;
                            oc:tableMarkdown """| Old (Android layout)           | New (KMP layout)                      |
|--------------------------------|---------------------------------------|
| `src/main/java/`               | `src/androidMain/kotlin/`             |
| `src/main/res/`                | `src/androidMain/res/`                |
| `src/main/AndroidManifest.xml` | `src/androidMain/AndroidManifest.xml` |
| `src/test/java/`               | `src/androidHostTest/kotlin/`         |
| `src/androidTest/java/`        | `src/androidDeviceTest/kotlin/`       |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**No renames are required** if you already use the standard KMP layout. If your module previously used the classic Android layout (`src/main/java/`, `src/main/res/`), you must migrate to the KMP layout:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 10 ;
                    oc:sectionTitle "Source Directory Renames" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "If you use convention plugins (build-logic), update them:" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Paragraph ;
                                    oc:blockType "paragraph" ;
                                    oc:contentOrder 2 ;
                                    oc:textContent "The `LibraryExtension` class from AGP is no longer used. All Android configuration goes through `KotlinMultiplatformExtension.android {}`." ],
                                [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """// build-logic/convention/src/main/kotlin/KmpLibraryConventionPlugin.kt
class KmpLibraryConventionPlugin : Plugin<Project> {
    override fun apply(target: Project) {
        with(target) {
            pluginManager.apply("org.jetbrains.kotlin.multiplatform")
            pluginManager.apply("com.android.kotlin.multiplatform.library")

            extensions.configure<KotlinMultiplatformExtension> {
                android {
                    namespace = // set per-module or pass as parameter
                    compileSdk = 35
                    minSdk = 24
                }
            }
        }
    }
}
""" ;
                                    oc:codeLanguage "kotlin" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 519-537" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 34 ;
                            oc:sectionTitle "After" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """// build-logic/convention/src/main/kotlin/KmpLibraryConventionPlugin.kt
class KmpLibraryConventionPlugin : Plugin<Project> {
    override fun apply(target: Project) {
        with(target) {
            pluginManager.apply("com.android.library")
            pluginManager.apply("org.jetbrains.kotlin.multiplatform")

            extensions.configure<LibraryExtension> {
                compileSdk = 34
                defaultConfig.minSdk = 24
            }
        }
    }
}
""" ;
                                    oc:codeLanguage "kotlin" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 500-515" ] ;
