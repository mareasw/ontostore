    oc:dependsOnSkill oc:skill_ontoskills_kotlin_tooling_agp9_migration ;
    oc:differentia "Migrates KMP library modules from com.android.library (AGP 8.x) to com.android.kotlin.multiplatform.library (AGP 9.x) with complete before/after examples" ;
