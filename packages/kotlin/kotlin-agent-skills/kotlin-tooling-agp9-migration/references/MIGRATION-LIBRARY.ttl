                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "If your module contains Java source files in `androidMain`, you must explicitly enable Java compilation:" ],
                        [ a oc:Paragraph ;
