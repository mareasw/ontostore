oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_agp9_migration_known_issues a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "known-issues" ;
    skos:broader "Reference guide" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/kotlin/kotlin-agent-skills/kotlin-tooling-agp9-migration" ;
    oc:contentHash "5b15e61f34e3821f40fb26d1a5a9cdce4c9cea1915b6be147df2d43ed883027f" ;
    oc:differentia "catalogs known issues, breaking changes, and workarounds for KMP AGP 9.0 library migration" ;
    oc:extends oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_agp9_migration ;
    oc:handlesFailure oc:BuildFailure,
        oc:ClassCastException,
        oc:ProGuardRuleDropped,
        oc:ResourceResolutionFailure ;
    oc:hasArgumentHint "issue-number or keyword (e.g., \"buildconfig\", \"proguard\", \"kapt\", \"ndk\")" ;
    oc:hasCategory "development" ;
    oc:impartsKnowledge oc:kn_336590d2,
        oc:kn_41261645,
        oc:kn_4f43845c,
        oc:kn_54177be8,
        oc:kn_5c197c9d,
        oc:kn_5f5e86d4,
        oc:kn_6f858883,
        oc:kn_919edb99,
        oc:kn_c0662e3b,
        oc:kn_ee4bcf8f ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:AGP9MigrationStarted ;
    oc:resolvesIntent "check breaking changes before migrating to AGP 9.0",
        "diagnose AGP 9.0 migration build failures",
        "find workarounds for KMP library plugin limitations",
        "fix convention plugin incompatibilities with AGP 9.0",
        "resolve BuildConfig removal in KMP library modules" ;
    oc:yieldsState oc:KnownIssuesReviewed,
        oc:WorkaroundApplied .

oc:kn_336590d2 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When configuring packaging exclusions in build scripts" ;
    oc:directiveContent "Packaging exclusions brace-expansion syntax (e.g., excludes += \"/META-INF/{AL2.0,LGPL2.1}\") may not work correctly in AGP 9.0. Use explicit individual entries with excludes.add() instead." ;
    oc:hasRationale "Subtle syntax change that can cause builds to fail or produce unexpected packaging results without a clear error message" ;
    oc:severityLevel "LOW" .

oc:kn_41261645 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When updating build-logic convention plugins for AGP 9.0 compatibility" ;
    oc:directiveContent "AGP 9.0 removes BaseExtension, AppExtension, LibraryExtension types. All build logic must use the new public DSL interfaces (CommonExtension, etc.). Convention plugins applying com.android.library must be rewritten to use org.jetbrains.kotlin.multiplatform + com.android.kotlin.multiplatform.library with KotlinMultiplatformExtension." ;
    oc:hasRationale "Casting to old extension types produces ClassCastException at runtime, and the old plugin IDs are no longer valid for KMP library modules" ;
    oc:severityLevel "HIGH" .

oc:kn_4f43845c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When configuring ProGuard consumer rules for KMP library modules" ;
    oc:directiveContent "Do not use consumerProguardFiles in the old android { defaultConfig {} } block — it is silently ignored in the new KMP library DSL. Move rules to kotlin { android { consumerProguardFiles.add(...) } }." ;
    oc:hasRationale "Silent dropping of consumer ProGuard rules can cause runtime crashes in release builds of consuming applications with no build-time warning" ;
    oc:severityLevel "CRITICAL" .

oc:kn_54177be8 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When migrating modules that rely on flavor-specific dependencies, resources, or source sets" ;
    oc:directiveContent "The KMP library plugin produces a single build variant with no debug/release build types or product flavors. Move all variant-dependent logic to the application module and use runtime configuration via DI or expect/actual." ;
    oc:hasRationale "Single variant architecture is a fundamental design constraint of the KMP library plugin that cannot be worked around within the library module itself" ;
    oc:severityLevel "HIGH" .

oc:kn_5c197c9d a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When migrating a library module that references BuildConfig fields" ;
    oc:directiveContent "BuildConfig is not generated for KMP library modules. Code referencing BuildConfig.DEBUG, BuildConfig.VERSION_NAME, or custom buildConfigField entries will fail to compile. Use the AppConfiguration DI pattern with expect/actual, or the BuildKonfig / gradle-buildconfig-plugin alternatives." ;
    oc:hasRationale "BuildConfig removal is one of the highest-impact breaking changes because many libraries use BuildConfig.DEBUG for logging gates and buildConfigField for compile-time constants" ;
    oc:severityLevel "HIGH" .

oc:kn_5f5e86d4 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When annotation processing or third-party plugins conflict with AGP 9.0 built-in Kotlin compilation" ;
    oc:directiveContent "If kapt conflicts with AGP 9.0's built-in Kotlin support, either migrate to KSP (preferred) or use com.android.legacy-kapt as a fallback. For other plugin conflicts, use android.builtInKotlin=false as a temporary opt-out." ;
    oc:hasRationale "kapt is incompatible with built-in Kotlin and causes hard build failures; KSP migration is the long-term solution but legacy-kapt provides a migration bridge" ;
    oc:severityLevel "HIGH" .

oc:kn_6f858883 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When organizing test source directories after migration" ;
    oc:directiveContent "Source set androidUnitTest is renamed to androidHostTest and androidInstrumentedTest to androidDeviceTest. Old names work as deprecated aliases. Rename directories and update CI scripts accordingly." ;
    oc:hasRationale "Deprecated aliases provide temporary compatibility but should be proactively renamed to avoid future breakage" ;
    oc:severityLevel "LOW" .

oc:kn_919edb99 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning and executing an AGP 9.0 migration" ;
    oc:directiveContent "For each AGP 9.0 migration, systematically check: (1) BuildConfig references, (2) consumer ProGuard rules, (3) convention plugins, (4) kapt usage, (5) NDK/JNI modules, (6) variant-dependent code, (7) resource enable flag, (8) third-party plugin versions. Address in this priority order." ;
    oc:hasRationale "Following a structured checklist prevents missing silent failures like dropped ProGuard rules or ignored resources that only manifest at runtime" .

oc:kn_c0662e3b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When setting up a KMP library module with the new plugin" ;
    oc:directiveContent "Before migrating, explicitly enable Android resources with kotlin { android { androidResources { enable = true } } }. Without this flag, resources are silently ignored (tracked as CMP-9547). Also verify IDE is Android Studio Otter 3+ — IntelliJ IDEA and older Android Studio versions do not support AGP 9.0." ;
    oc:hasRationale "Silent failure mode means resources are simply ignored without an error until referenced, making this easy to miss until runtime" ;
    oc:severityLevel "HIGH" .

oc:kn_ee4bcf8f a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When migrating modules that contain C/C++ native code via NDK" ;
    oc:directiveContent "The KMP library plugin does not support externalNativeBuild, ndkVersion, or JNI source compilation. Keep JNI modules as classic com.android.library and depend on them from the KMP module via a proxy interface pattern." ;
    oc:hasRationale "NDK/JNI is fundamentally incompatible with the KMP library plugin and requires architectural separation to maintain native code support" ;
    oc:severityLevel "MEDIUM" .

