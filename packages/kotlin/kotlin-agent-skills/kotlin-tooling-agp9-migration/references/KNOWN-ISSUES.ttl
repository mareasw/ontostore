                                    oc:itemText "For library-specific debug/release behavior, use the `AppConfiguration` pattern from issue 1." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Use `expect`/`actual` with different actual implementations selected by DI based on runtime config." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
