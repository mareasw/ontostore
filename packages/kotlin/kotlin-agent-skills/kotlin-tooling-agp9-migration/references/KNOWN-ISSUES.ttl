oc:kn_1e483bae a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When refactoring build-logic convention plugins for AGP 9.0 compatibility" ;
    oc:directiveContent "Convention plugins must switch from applying com.android.library + LibraryExtension to org.jetbrains.kotlin.multiplatform + com.android.kotlin.multiplatform.library + KotlinMultiplatformExtension." ;
    oc:hasRationale "The old plugin and extension types are removed; convention plugins that cast to LibraryExtension will throw ClassCastException" ;
    oc:severityLevel "HIGH" .

oc:kn_28f6bc41 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When migrating modules that use flavor-specific dependencies, resources, or source sets" ;
    oc:directiveContent "The KMP library plugin produces a single build variant — no debug/release build types, no product flavors. Move all variant-dependent logic to the application module or use runtime configuration via expect/actual + DI." ;
    oc:hasRationale "Variant removal is a fundamental architectural change that forces restructuring of build configuration" ;
    oc:severityLevel "HIGH" .

oc:kn_2fffd47b a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When migrating application modules with Java switch statements on R class fields" ;
    oc:directiveContent "R class fields are compile-time non-final in application modules by default. switch statements on R.id.* fields will fail to compile. Refactor to if/else." ;
    oc:hasRationale "AGP 9.0 defaults android.enableAppCompileTimeRClass=true, making R fields non-final" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3bef06d4 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When migrating modules that use org.jetbrains.kotlin.kapt" ;
    oc:directiveContent "kapt is incompatible with AGP 9.0's built-in Kotlin support. Migrate to KSP preferred, or use com.android.legacy-kapt as fallback." ;
    oc:hasRationale "Applying kapt alongside built-in Kotlin causes build failure; many projects still depend on kapt" ;
    oc:severityLevel "HIGH" .

oc:kn_648036a9 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When build logic or convention plugins cast to old AGP extension types" ;
    oc:directiveContent "BaseExtension, AppExtension, LibraryExtension types are removed. Use CommonExtension from com.android.build.api.dsl instead. Temporary opt-out: android.newDsl=false." ;
    oc:hasRationale "Casting to removed types causes ClassCastException at build time" ;
    oc:severityLevel "HIGH" .

oc:kn_64ed5651 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When migrating library modules that reference BuildConfig.DEBUG, BuildConfig.VERSION_NAME, or custom buildConfigField entries" ;
    oc:directiveContent "BuildConfig is not generated for KMP library modules. Use AppConfiguration expect/actual DI pattern, BuildKonfig plugin, or gradle-buildconfig-plugin as replacements." ;
    oc:hasRationale "Code referencing BuildConfig will fail to compile after migration; this is one of the highest-impact breaking changes" ;
    oc:severityLevel "HIGH" .

oc:kn_98a3e636 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When migrating modules with C/C++ native code via NDK" ;
    oc:directiveContent "The KMP library plugin does not support externalNativeBuild, ndkVersion, or JNI source compilation. Keep JNI modules as classic com.android.library and depend on them from the KMP module via a proxy interface." ;
    oc:hasRationale "NDK/JNI modules cannot be directly migrated; they must remain as separate Android library modules" ;
    oc:severityLevel "MEDIUM" .

oc:kn_af9d9da0 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating alternatives for BuildConfig removal" ;
    oc:directiveContent "Do not assume BuildKonfig or gradle-buildconfig-plugin fully replace Android build variants. They provide compile-time constants only — not variant-specific dependencies, resources, source sets, signing configs, or minification." ;
    oc:hasRationale "Overestimating plugin capabilities leads to missing variant-dependent configuration in production builds" ;
    oc:severityLevel "HIGH" .

oc:kn_b1cf3850 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When migrating application modules where targetSdk was intentionally unset" ;
    oc:directiveContent "targetSdk now defaults to compileSdk when not explicitly set (previously defaulted to minSdk). Explicitly set targetSdk in all application modules." ;
    oc:hasRationale "Silent behavioral change may trigger unexpected runtime behavior at higher API levels" ;
    oc:severityLevel "MEDIUM" .

oc:kn_bbb805e8 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When replacing BuildConfig.DEBUG or other build-time constants across KMP targets" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent "Use the AppConfiguration expect/actual DI pattern to replace BuildConfig: define expect class in commonMain with actual implementations in androidMain (using Context/ApplicationInfo) and iosMain (using Platform.isDebugBinary/NSBundle). Inject via DI framework." ;
    oc:hasRationale "This is the idiomatic KMP approach for cross-platform configuration without relying on Android-specific BuildConfig" .

oc:kn_bc5ae5ca a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When the KMP library module has Android resources that fail to resolve silently" ;
    oc:directiveContent "Android resources (res/) are not processed by default. Enable them with `kotlin { android { androidResources { enable = true } } }`. This is tracked as CMP-9547." ;
    oc:hasRationale "Silent failure — resources are simply ignored without an error until referenced, making this easy to miss" ;
    oc:severityLevel "HIGH" .

oc:kn_bd7b40c2 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When build scripts or third-party plugins use removed variant APIs" ;
    oc:directiveContent "applicationVariants, libraryVariants, testVariants, unitTestVariants, variantFilter APIs are removed. Replace with androidComponents.onVariants() and androidComponents.beforeVariants()." ;
    oc:hasRationale "These APIs were deprecated and are now removed; custom build logic must migrate to the new Variant API" ;
    oc:severityLevel "MEDIUM" .

oc:kn_c371d608 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When migrating modules that ship consumer ProGuard rules" ;
    oc:directiveContent "consumerProguardFiles must be migrated from android.defaultConfig to kotlin.android.consumerProguardFiles.add(). Old location is silently ignored with no warning." ;
    oc:hasRationale "Silently dropped rules can cause runtime crashes in release builds of consuming applications" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d58f4a26 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting up the development environment for AGP 9.0 migration" ;
    oc:directiveContent "IntelliJ IDEA does not support AGP 9.0 as of 2025.3. Use Android Studio Otter 3 (2025.2.3) or later for full AGP 9.0 + KMP library plugin support." ;
    oc:hasRationale "Using an unsupported IDE leads to project sync failures and incorrect code insight" ;
    oc:severityLevel "HIGH" .

oc:kn_edc1ea1c a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing a systematic migration audit of a module" ;
    oc:directiveContent "For each migrated module, check these in order: 1) BuildConfig usage 2) NDK/JNI 3) Build variants 4) Android resources 5) Consumer ProGuard rules 6) Convention plugins 7) kapt usage 8) R class switch statements 9) targetSdk default" ;
    oc:hasRationale "Prioritizing by impact (High→Medium→Low) ensures the most blocking issues are resolved first" .

oc:kn_ffa34573 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When plugin conflicts block migration and need an immediate workaround" ;
    oc:directiveContent "Use android.builtInKotlin=false in gradle.properties as a temporary opt-out when custom Kotlin compiler plugins or third-party plugins conflict with AGP 9.0's built-in Kotlin support. This flag will be removed in a future AGP version." ;
    oc:hasRationale "Provides a migration escape hatch while long-term fixes are developed" ;
    oc:severityLevel "MEDIUM" .

