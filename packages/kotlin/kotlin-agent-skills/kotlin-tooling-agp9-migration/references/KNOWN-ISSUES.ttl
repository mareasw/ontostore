                            oc:contentOrder 4 ;
                            oc:sourceLocation "lines 184-190" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Problem:** Android resources (`res/` directory) are not processed by default with the KMP library plugin. If you forget to enable them, resource references (`R.string.*`, `R.drawable.*`) will fail to resolve. This is tracked as CMP-9547." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
