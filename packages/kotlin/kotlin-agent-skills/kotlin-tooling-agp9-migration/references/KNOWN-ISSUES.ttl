                            oc:textContent "**Workaround -- Single Variant Architecture:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Impact:** High. Affects projects using flavor-specific dependencies, resources, or source sets." ],
                        [ a oc:BulletList ;
