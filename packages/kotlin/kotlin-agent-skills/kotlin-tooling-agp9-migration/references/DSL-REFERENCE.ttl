    oc:dependsOnSkill oc:skill_ontoskills_kotlin_tooling_agp9_migration ;
    oc:differentia "that provides side-by-side field-level migration from com.android.library (AGP 8.x) to com.android.kotlin.multiplatform.library (AGP 9.x) for every configuration block" ;
    oc:extends oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_agp9_migration ;
    oc:hasArgumentHint "AGP DSL element name or block (e.g. \"compileOptions\", \"buildFeatures\", \"testOptions\", \"lint\")" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Side-by-side mapping of every DSL element from the old `com.android.library` configuration to the new `com.android.kotlin.multiplatform.library` configuration." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 2 ;
                            oc:tableCaption "## Java Source Compilation" ;
                            oc:tableMarkdown """| Old                                                     | New                                 |
|---------------------------------------------------------|-------------------------------------|
| Java sources in `src/main/java/` compiled automatically | Must call `withJava()`              |
| `android { compileOptions { ... } }`                    | `kotlin { android { withJava() } }` |
""" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """kotlin {
    android {
        withJava()  // Required to compile .java files in androidMain
    }
}
""" ;
                            oc:codeLanguage "kotlin" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 240-246" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 14 ;
                    oc:sectionTitle "Java Source Compilation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 8 ;
                            oc:tableCaption "## Test Options" ;
                            oc:tableMarkdown """| Old                                                                  | New                                                                            |
|----------------------------------------------------------------------|--------------------------------------------------------------------------------|
| `android { testOptions { unitTests.isReturnDefaultValues = true } }` | `kotlin { android { withHostTest { } } }`                                      |
| `android { testOptions { animationsDisabled = true } }`              | `kotlin { android { withDeviceTest { } } }`                                    |
| Source set: `androidUnitTest`                                        | Source set: `androidHostTest` (alias: `androidUnitTest` still works)           |
| Source set: `androidInstrumentedTest`                                | Source set: `androidDeviceTest` (alias: `androidInstrumentedTest` still works) |
| `testImplementation(...)`                                            | `getByName("androidHostTest").dependencies { implementation(...) }`            |
| `androidTestImplementation(...)`                                     | `getByName("androidDeviceTest").dependencies { implementation(...) }`          |
| Source dir: `src/test/`                                              | Source dir: `src/androidHostTest/kotlin/`                                      |
| Source dir: `src/androidTest/`                                       | Source dir: `src/androidDeviceTest/kotlin/`                                    |
""" ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:CodeExample ;
                                    oc:blockType "code_block" ;
                                    oc:codeContent """// Old
android {
    testOptions {
        unitTests {
            isReturnDefaultValues = true
            isIncludeAndroidResources = true
        }
    }
}

// New
kotlin {
    android {
        withHostTest {
            // Host test specific configuration
            // returnDefaultValues and includeAndroidResources
            // are configured via gradle.properties or test runner
        }
        withDeviceTest {
            // Device test specific configuration
            instrumentationRunner = "androidx.test.runner.AndroidJUnitRunner"
        }
    }
}
""" ;
                                    oc:codeLanguage "kotlin" ;
                                    oc:contentOrder 1 ;
                                    oc:sourceLocation "lines 108-133" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Test Configuration Details" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Test Options" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """import org.jetbrains.kotlin.gradle.dsl.JvmTarget
""" ;
                            oc:codeLanguage "kotlin" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 64-66" ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 5 ;
                            oc:tableCaption "## Compile Options and Compiler Options" ;
                            oc:tableMarkdown """| Old                                                                           | New                                                                          |
|-------------------------------------------------------------------------------|------------------------------------------------------------------------------|
| `android { compileOptions { sourceCompatibility = JavaVersion.VERSION_11 } }` | `kotlin { android { compilerOptions { jvmTarget.set(JvmTarget.JVM_11) } } }` |
| `android { compileOptions { targetCompatibility = JavaVersion.VERSION_11 } }` | `kotlin { android { compilerOptions { jvmTarget.set(JvmTarget.JVM_11) } } }` |
| `kotlinOptions { jvmTarget = "11" }`                                          | `compilerOptions { jvmTarget.set(JvmTarget.JVM_11) }`                        |
| `kotlinOptions { freeCompilerArgs += listOf("-Xopt-in=...") }`                | `compilerOptions { optIn.add("...") }`                                       |
| `kotlinOptions { languageVersion = "1.9" }`                                   | `compilerOptions { languageVersion.set(KotlinVersion.KOTLIN_2_0) }`          |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Full JvmTarget import:" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Compile Options and Compiler Options" ],
                [ a oc:Section ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 4 ;
                                    oc:tableCaption "### Namespace and SDK Versions" ;
                                    oc:tableMarkdown """| Old (android {})                   | New (kotlin { android {} })                                             |
|------------------------------------|-------------------------------------------------------------------------|
| `namespace = "..."`                | `namespace = "..."`                                                     |
| `compileSdk = 35`                  | `compileSdk = 35` (same value, just moved into `kotlin { android {} }`) |
| `defaultConfig { minSdk = 24 }`    | `minSdk = 24`                                                           |
| `defaultConfig { targetSdk = 34 }` | N/A (application-only, not in library)                                  |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Namespace and SDK Versions" ],
                        [ a oc:Section ;
                            oc:hasContent [ a oc:Table ;
                                    oc:blockType "table" ;
                                    oc:contentOrder 1 ;
                                    oc:rowCount 7 ;
                                    oc:tableCaption "### defaultConfig Elements" ;
                                    oc:tableMarkdown """| Old (android { defaultConfig {} })         | New (kotlin { android {} })               |
|--------------------------------------------|-------------------------------------------|
| `minSdk = 24`                              | `minSdk = 24` (direct property)           |
| `testInstrumentationRunner = "..."`        | Set in `withDeviceTest { }` configuration |
| `consumerProguardFiles("...")`             | `consumerProguardFiles.add(file("..."))`  |
| `multiDexEnabled = true`                   | N/A (handled automatically)               |
| `vectorDrawables.useSupportLibrary = true` | N/A                                       |
| `buildConfigField(...)`                    | Removed (see KNOWN-ISSUES.md)             |
| `manifestPlaceholders[...]`                | N/A (use merged manifest in app module)   |
""" ] ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 2 ;
                            oc:sectionTitle "defaultConfig Elements" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "android {} Block Fields" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Note:** `useK2Uast` is deprecated. Remove it if present." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "The lint DSL is largely unchanged, it just moves inside `kotlin { android {} }`." ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 4 ;
                            oc:tableCaption "## Lint Configuration" ;
                            oc:tableMarkdown """| Old                                                         | New                                                                    |
|-------------------------------------------------------------|------------------------------------------------------------------------|
| `android { lint { abortOnError = false } }`                 | `kotlin { android { lint { abortOnError = false } } }`                 |
| `android { lint { checkReleaseBuilds = true } }`            | `kotlin { android { lint { checkReleaseBuilds = true } } }`            |
| `android { lint { disable += "SomeCheck" } }`               | `kotlin { android { lint { disable += "SomeCheck" } } }`               |
| `android { lint { baseline = file("lint-baseline.xml") } }` | `kotlin { android { lint { baseline = file("lint-baseline.xml") } } }` |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Lint Configuration" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 4 ;
                            oc:tableCaption "**Removed in KMP library plugin.** The `com.android.kotlin.multiplatform.library` plugin produces a single build variant." ;
                            oc:tableMarkdown """| Old                                               | New     | Notes                                               |
|---------------------------------------------------|---------|-----------------------------------------------------|
| `buildTypes { debug { ... } }`                    | Removed | Single variant only                                 |
| `buildTypes { release { minifyEnabled = true } }` | Removed | Minification is app-module concern                  |
| `productFlavors { ... }`                          | Removed | Use Gradle properties or expect/actual for variants |
| `flavorDimensions(...)`                           | Removed |                                                     |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Removed in KMP library plugin.** The `com.android.kotlin.multiplatform.library` plugin produces a single build variant." ] ;
                    oc:hasSubsection [ a oc:Section ;
                            oc:hasContent _:ref_0870983ed3b23c88 ;
                            oc:sectionLevel 3 ;
                            oc:sectionOrder 1 ;
                            oc:sectionTitle "Workarounds for Variant-Dependent Logic" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 12 ;
                    oc:sectionTitle "Build Types and Product Flavors" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 2 ;
                            oc:tableCaption "## Android Resources" ;
                            oc:tableMarkdown """| Old                                         | New                                                         |
|---------------------------------------------|-------------------------------------------------------------|
| Resources processed by default              | Must explicitly enable                                      |
| `android { ... }` (resources auto-included) | `kotlin { android { androidResources { enable = true } } }` |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Android Resources" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Note:** `android.enableLegacyVariantApi` is **removed** in AGP 9.0 and will cause an error if set. Code depending on legacy variant APIs must be migrated to `androidComponents` APIs." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "The `androidComponents` extension is significantly reduced in scope for KMP libraries because there is only a single variant. Most customization that relied on variant-aware APIs must be reworked." ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 3 ;
                            oc:tableCaption "## androidComponents Block" ;
                            oc:tableMarkdown """| Old                                            | New                                              |
|------------------------------------------------|--------------------------------------------------|
| `androidComponents { onVariants { ... } }`     | Limited support; most variant API is unavailable |
| `androidComponents { beforeVariants { ... } }` | Not available in KMP library                     |
| `androidComponents { finalizeDsl { ... } }`    | Not available in KMP library                     |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 13 ;
                    oc:sectionTitle "androidComponents Block" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Because the new KMP Android library plugin is strictly single-variant, you can no longer define fallback logic inside `buildTypes` or `defaultConfig`." ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 2 ;
                            oc:rowCount 2 ;
                            oc:tableCaption "Because the new KMP Android library plugin is strictly single-variant, you can no longer define fallback logic inside `buildTypes` or `defaultConfig`." ;
                            oc:tableMarkdown """| Old | New | Notes |
|---|---|---|
| `android { defaultConfig { missingDimensionStrategy("tier", "free") } }` | `kotlin { android { localDependencySelection { productFlavorDimension("tier") { selectFrom.set(listOf("free")) } } } }` | Configure dependency flavor fallbacks |
| `android { buildTypes { getByName("debug") { matchingFallbacks.add("release") } } }` | `kotlin { android { localDependencySelection { selectBuildTypeFrom.set(listOf("debug", "release")) } } }` | Configure dependency build type mapping |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 11 ;
                    oc:sectionTitle "Dependency Resolution" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 7 ;
                            oc:tableCaption "## Build Features" ;
                            oc:tableMarkdown """| Old (android { buildFeatures {} })      | New (kotlin { android {} })                                                  |
|-----------------------------------------|------------------------------------------------------------------------------|
| `buildFeatures { compose = true }`      | Applied via compose compiler plugin (no explicit flag needed in KMP library) |
| `buildFeatures { buildConfig = true }`  | Removed in KMP library (see KNOWN-ISSUES.md)                                 |
| `buildFeatures { viewBinding = true }`  | Not supported in KMP library                                                 |
| `buildFeatures { dataBinding = true }`  | Not supported in KMP library                                                 |
| `buildFeatures { aidl = true }`         | Not supported in KMP library                                                 |
| `buildFeatures { renderScript = true }` | Not supported                                                                |
| `buildFeatures { resValues = true }`    | Not supported in KMP library                                                 |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Build Features" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """// OLD
plugins {
    alias(libs.plugins.kotlinMultiplatform)
    alias(libs.plugins.androidLibrary)
}
kotlin {
    androidTarget { compilations.all { kotlinOptions { jvmTarget = "11" } } }
}
android {
    namespace = "com.example.lib"
    compileSdk = 35
    defaultConfig { minSdk = 24 }
    compileOptions {
        sourceCompatibility = JavaVersion.VERSION_11
        targetCompatibility = JavaVersion.VERSION_11
    }
}

// NEW
plugins {
    alias(libs.plugins.kotlinMultiplatform)
    alias(libs.plugins.androidKmpLibrary)
}
kotlin {
    android {
        namespace = "com.example.lib"
        compileSdk = 35
        minSdk = 24
        compilerOptions {
            jvmTarget.set(org.jetbrains.kotlin.gradle.dsl.JvmTarget.JVM_11)
        }
    }
}
""" ;
                            oc:codeLanguage "kotlin" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 252-286" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 15 ;
                    oc:sectionTitle "Quick Reference: Minimal Migration Template" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 2 ;
                            oc:tableCaption "## Top-Level Block Migration" ;
                            oc:tableMarkdown """| Old                                       | New                                 |
|-------------------------------------------|-------------------------------------|
| `android { ... }`                         | `kotlin { android { ... } }`        |
| `androidTarget { ... }` (in kotlin block) | `android { ... }` (in kotlin block) |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Top-Level Block Migration" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 5 ;
                            oc:tableCaption "## Plugin IDs" ;
                            oc:tableMarkdown """| Old (AGP 8.x)                        | New (AGP 9.x)                                                                                       |
|--------------------------------------|-----------------------------------------------------------------------------------------------------|
| `com.android.library`                | `com.android.kotlin.multiplatform.library`                                                          |
| `com.android.application`            | `com.android.application` (unchanged, but cannot combine with KMP)                                  |
| `org.jetbrains.kotlin.android`       | Built into `com.android.application` and `com.android.library` in AGP 9.0 (do not apply separately) |
| `org.jetbrains.kotlin.kapt`          | `com.android.legacy-kapt` (same version as AGP) or migrate to KSP                                   |
| `org.jetbrains.kotlin.multiplatform` | `org.jetbrains.kotlin.multiplatform` (unchanged)                                                    |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Plugin IDs" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 9 ;
                            oc:tableCaption "## Dependencies Configurations" ;
                            oc:tableMarkdown """| Old Configuration                | New Configuration                                                     | Notes                       |
|----------------------------------|-----------------------------------------------------------------------|-----------------------------|
| `implementation(...)`            | `androidMain.dependencies { implementation(...) }`                    | Move to source set          |
| `api(...)`                       | `androidMain.dependencies { api(...) }`                               | Move to source set          |
| `compileOnly(...)`               | `androidMain.dependencies { compileOnly(...) }`                       | Move to source set          |
| `debugImplementation(...)`       | `"androidRuntimeClasspath"(...)`                                      | No variant-specific configs |
| `releaseImplementation(...)`     | `androidMain.dependencies { implementation(...) }`                    | Single variant              |
| `testImplementation(...)`        | `getByName("androidHostTest").dependencies { implementation(...) }`   |                             |
| `androidTestImplementation(...)` | `getByName("androidDeviceTest").dependencies { implementation(...) }` |                             |
| `ksp(...)`                       | `add("ksp", ...)` or KSP Gradle plugin DSL                            | Check KSP compatibility     |
| `kapt(...)`                      | Migrate to KSP; kapt not supported                                    |                             |
""" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 10 ;
                    oc:sectionTitle "Dependencies Configurations" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 1 ;
                            oc:tableCaption "## Packaging / Resources Excludes" ;
                            oc:tableMarkdown """| Old                                                                               | New                                                                                          |
|-----------------------------------------------------------------------------------|----------------------------------------------------------------------------------------------|
| `android { packaging { resources { excludes += "/META-INF/{AL2.0,LGPL2.1}" } } }` | `kotlin { android { packaging { resources { excludes += "/META-INF/{AL2.0,LGPL2.1}" } } } }` |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "The DSL is the same, just nested under `kotlin { android {} }`." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Syntax note for AGP 9.0:**" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """// Old syntax (still works but deprecated)
resources.excludes += "/META-INF/{AL2.0,LGPL2.1}"

// Preferred AGP 9.0 syntax
resources {
    excludes.add("/META-INF/AL2.0")
    excludes.add("/META-INF/LGPL2.1")
}
""" ;
                            oc:codeLanguage "kotlin" ;
                            oc:contentOrder 4 ;
                            oc:sourceLocation "lines 161-170" ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 9 ;
                    oc:sectionTitle "Packaging / Resources Excludes" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "DSL Reference: AGP 8.x to AGP 9.x KMP Library Migration" ] ;
