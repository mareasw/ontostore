oc:kn_01ca5b50 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating buildFeatures block" ;
    oc:directiveContent "viewBinding, dataBinding, aidl, renderScript, and resValues build features are not supported in KMP library." ;
    oc:hasRationale "These features require Android-specific infrastructure that doesn't align with KMP library's multiplatform goals." ;
    oc:severityLevel "HIGH" .

oc:kn_01f31173 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating any dependency declaration" ;
    oc:directiveContent "Dependencies must be declared inside source set blocks (androidMain.dependencies {}, getByName(\"androidHostTest\").dependencies {}, etc.) rather than at the top-level configurations block." ;
    oc:hasRationale "KMP uses source-set-scoped dependencies to properly manage multiplatform dependency graphs." ;
    oc:severityLevel "HIGH" .

oc:kn_04ace20d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating variant-aware Android Gradle Plugin APIs" ;
    oc:directiveContent "androidComponents { beforeVariants {} } and androidComponents { finalizeDsl {} } are not available in the KMP library plugin. androidComponents { onVariants {} } has limited support." ;
    oc:hasRationale "Single-variant libraries don't need variant selection or DSL finalization hooks." ;
    oc:severityLevel "HIGH" .

oc:kn_1c655d45 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When auditing gradle.properties during migration" ;
    oc:directiveContent "android.enableLegacyVariantApi is removed in AGP 9.0 and will cause a build error if set in gradle.properties." ;
    oc:hasRationale "Legacy variant API was deprecated and is now fully removed." ;
    oc:severityLevel "CRITICAL" .

oc:kn_32095764 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating any variant-related configuration" ;
    oc:directiveContent "The KMP library plugin (com.android.kotlin.multiplatform.library) produces a single build variant — buildTypes, productFlavors, and flavorDimensions are all removed." ;
    oc:hasRationale "Multi-variant builds are an application-module concern; libraries use a single variant in KMP." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3b59fe67 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When buildConfigField or BuildConfig is referenced in old code" ;
    oc:directiveContent "BuildConfig generation is removed in the KMP library plugin. Use expect/actual or dependency injection instead." ;
    oc:hasRationale "BuildConfig was tied to the removed variant system; compile-time constants must be achieved differently." ;
    oc:severityLevel "HIGH" .

oc:kn_617615c3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating annotation processors" ;
    oc:directiveContent "kapt is not supported in KMP library. Use com.android.legacy-kapt as a stopgap or migrate to KSP." ;
    oc:hasRationale "kapt is deprecated; KSP is the forward-looking replacement for Kotlin annotation processing." ;
    oc:severityLevel "MEDIUM" .

oc:kn_72516826 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When the project contains .java files in androidMain" ;
    oc:directiveContent "Java sources require explicit withJava() call inside kotlin { android {} } to be compiled." ;
    oc:hasRationale "KMP libraries default to Kotlin-only; Java compilation is opt-in." ;
    oc:severityLevel "MEDIUM" .

oc:kn_93140f35 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When the library includes Android resources (layouts, drawables, etc.)" ;
    oc:directiveContent "Android resources are NOT processed by default. You must explicitly add androidResources { enable = true } inside kotlin { android {} }." ;
    oc:hasRationale "Explicit opt-in ensures KMP libraries that don't need Android resources aren't burdened with the processing overhead." ;
    oc:severityLevel "HIGH" .

oc:kn_d2270fe8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or migrating plugin declarations" ;
    oc:directiveContent "Do not apply org.jetbrains.kotlin.android separately — it is built into com.android.application and com.android.library in AGP 9.0." ;
    oc:hasRationale "Redundant plugin application causes configuration conflicts." ;
    oc:severityLevel "HIGH" .

oc:kn_db581cb9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When performing any AGP 8→9 DSL migration" ;
    oc:directiveContent "The android {} block moves from top-level to kotlin { android {} }. Inside the kotlin block, androidTarget {} becomes simply android {}." ;
    oc:hasRationale "This is the foundational structural change that all other migrations build upon." ;
    oc:severityLevel "CRITICAL" .

oc:kn_dee471a0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating namespace and SDK version fields" ;
    oc:directiveContent "Old defaultConfig properties become direct properties on the android {} block inside kotlin. E.g., defaultConfig { minSdk = 24 } becomes just minSdk = 24." ;
    oc:hasRationale "The defaultConfig wrapper is eliminated in the new DSL." ;
    oc:severityLevel "MEDIUM" .

