oc:kn_0a3c9365 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When migrating annotation processors" ;
    oc:directiveContent "Do not use org.jetbrains.kotlin.kapt with AGP 9.0 — it is incompatible. Use KSP or com.android.legacy-kapt instead." ;
    oc:hasRationale "kapt is fundamentally incompatible with AGP 9.0's built-in Kotlin compilation." ;
    oc:severityLevel "CRITICAL" .

oc:kn_264760da a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "After applying AGP 9.0" ;
    oc:directiveContent "AGP 9.0 auto-upgrades KGP to 2.2.10 if the project uses a lower version. Java source/target default changed from Java 8 to Java 11. targetSdk defaults to compileSdk instead of minSdk." ;
    oc:hasRationale "These implicit behavior changes can silently alter build output and must be accounted for." .

oc:kn_2bffcde0 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning AGP 9.0 migration" ;
    oc:directiveContent "Run `./gradlew --version` to verify Gradle 9.1.0+, check JDK is 17+, and run `./gradlew buildEnvironment` to confirm AGP and KGP versions before starting migration." ;
    oc:hasRationale "Catching version mismatches early avoids cryptic build failures later in the migration process." ;
    oc:severityLevel "HIGH" .

oc:kn_90fe64ca a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting recommended versions" ;
    oc:directiveContent "Use KGP 2.3.0+ and AGP 9.0.1+ for best compatibility. Compose Compiler Plugin version is automatically tied to KGP version via org.jetbrains.kotlin.plugin.compose." ;
    oc:hasRationale "KGP 2.3.0+ has best compatibility with KMP AGP 9.0 library plugin and improved diagnostics." .

oc:kn_a0550c9f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing an IDE for AGP 9.0 projects" ;
    oc:directiveContent "IntelliJ IDEA does not support AGP 9.0 as of 2026.1. Use Android Studio Otter 3+ for Android-targeted KMP development." ;
    oc:hasRationale "IntelliJ lacks the AGP 9.0 + KMP library plugin IDE support that Android Studio provides." ;
    oc:severityLevel "HIGH" .

oc:kn_a31470a3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When project uses KSP (required for Room KMP, etc.)" ;
    oc:directiveContent "KSP must be at least 2.3.1 for AGP 9.0 support. KSP 2.3.3+ avoids compatibility problems with other Gradle plugins due to migration away from deprecated compilerOptions KGP API." ;
    oc:hasRationale "Earlier KSP versions lack AGP 9.0 support and still use deprecated KGP APIs that conflict with AGP 9.0." ;
    oc:severityLevel "CRITICAL" .

oc:kn_ec649400 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any AGP 9.0 migration" ;
    oc:directiveContent "AGP 9.0 requires Gradle 9.1.0+, JDK 17+, SDK Build Tools 36.0.0, and KGP 2.0.0+ as hard minimums. Earlier versions of these tools will not work." ;
    oc:hasRationale "These are hard runtime dependencies enforced by AGP 9.0; missing any one causes build failures." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fe95ea8f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning the migration upgrade sequence from AGP 8.x + KGP 1.9.x" ;
    oc:directiveContent "Upgrade KGP to 2.0.0+ first while still on AGP 8.x, then upgrade Gradle to 9.1.0, then AGP to 9.0.1+, then migrate library plugins, and finally upgrade KGP to 2.3.0+ for best experience." ;
    oc:hasRationale "Staged upgrades reduce the blast radius of breaking changes and allow verification at each step." ;
    oc:severityLevel "HIGH" .

