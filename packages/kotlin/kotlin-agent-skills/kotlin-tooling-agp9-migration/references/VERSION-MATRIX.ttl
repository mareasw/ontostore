                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 15 ;
                                            oc:itemText "Removed: embedded Wear OS app support, density split APKs, legacy variant APIs." ],
