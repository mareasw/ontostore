oc:kn_23ddd862 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "After module rename" ;
    oc:directiveContent "After renaming composeApp to shared, the IDE caches the old module name. Delete .idea/ and re-import, or manually update .idea/modules.xml and related files." ;
    oc:hasRationale "IntelliJ/Android Studio caches module metadata and will show errors if the cache is stale." .

oc:kn_2512cac7 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing the target architecture" ;
    oc:directiveContent "The shared module should contain ONLY cross-platform library code. Each platform gets its own thin application module that depends on shared and provides only the platform entry point." ;
    oc:hasRationale "This separation is the new JetBrains default and prevents AGP 9.0 incompatibility by keeping application plugins out of KMP library modules." .

oc:kn_25b7dce3 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Creating webApp/build.gradle.kts" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """plugins {
    alias(libs.plugins.kotlinMultiplatform)
    alias(libs.plugins.composeMultiplatform)
    alias(libs.plugins.composeCompiler)
}
kotlin {
    wasmJs {
        browser { commonWebpackConfig { outputFileName = "app.js" } }
        binaries.executable()
    }
    sourceSets {
        wasmJsMain.dependencies {
            implementation(project(":shared"))
            implementation(compose.runtime)
            implementation(compose.foundation)
            implementation(compose.material3)
            implementation(compose.ui)
        }
    }
}""" .

oc:kn_a39e15c4 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "iOS Xcode project update" ;
    oc:directiveContent "When updating Xcode after rename: 1. Change Swift imports from ComposeApp to Shared (must match baseName). 2. Update Gradle task path to :shared:embedAndSignAppleFrameworkForXcode. 3. Rename @main struct if named after old module. 4. Update framework search paths. 5. Update CocoaPods spec name if used." ;
    oc:stepOrder 3 .

oc:kn_af9830c4 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Configuring iOS framework export in shared module" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """// iOS framework export stays in shared/build.gradle.kts
kotlin {
    listOf(iosX64(), iosArm64(), iosSimulatorArm64()).forEach {
        it.binaries.framework {
            baseName = "Shared"
            isStatic = true
        }
    }
}""" .

oc:kn_bc8a90e4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting desktop/web extraction" ;
    oc:directiveContent "Path B (Android app split) must be applied first before extracting other platform modules. The full restructure builds on top of the mandatory Android extraction." ;
    oc:hasRationale "The Android split is mandatory for AGP 9.0; other extractions are optional but recommended for clean architecture." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d04a4b94 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Native UI variant" ;
    oc:directiveContent "For projects where iOS uses SwiftUI natively (not Compose), split shared into sharedLogic (pure KMP, no Compose) and sharedUI (optional Compose UI) to minimize the shared surface area." ;
    oc:hasRationale "Reduces binary size and avoids pulling Compose dependencies into iOS when only business logic is needed." .

oc:kn_d415e600 a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Creating desktopApp/build.gradle.kts" ;
    oc:codeLanguage "kotlin" ;
    oc:directiveContent """plugins {
    alias(libs.plugins.kotlinJvm)
    alias(libs.plugins.composeMultiplatform)
    alias(libs.plugins.composeCompiler)
}
dependencies {
    implementation(project(":shared"))
    implementation(compose.desktop.currentOs)
    implementation(compose.runtime)
    implementation(compose.foundation)
    implementation(compose.material3)
}
compose.desktop {
    application {
        mainClass = "com.example.app.MainKt"
        nativeDistributions { /* platform configs */ }
    }
}""" .

oc:kn_dc7e1d36 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Full restructure execution" ;
    oc:directiveContent "1. Apply Path B (Android split) first. 2. Create desktopApp/ with compose desktop plugin + application block. 3. Create webApp/ with wasmJs target + binaries.executable(). 4. Move each platform's main() to its app module. 5. Move compose.desktop config to desktopApp. 6. Move wasmJs browser config to webApp. 7. Rename composeApp to shared. 8. Convert shared to KMP library plugin. 9. Remove platform app targets from shared. 10. Update settings.gradle.kts includes. 11. Update all project references. 12. Update Xcode project. 13. Verify each app module builds independently." ;
    oc:stepOrder 1 .

oc:kn_e5ff98b5 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Module rename phase" ;
    oc:directiveContent "When renaming composeApp to shared: 1. Rename directory (mv composeApp shared). 2. Update settings.gradle.kts includes. 3. Update all cross-module dependencies from :composeApp to :shared. 4. Delete .idea/ and re-import or update .idea/modules.xml." ;
    oc:stepOrder 2 .

oc:kn_f2ef628a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When removing desktop/web targets from shared module" ;
    oc:directiveContent "Never leave platform application targets (jvm(\"desktop\"), wasmJs with binaries.executable(), compose.desktop block) in the shared module after extraction. Only library targets belong in shared." ;
    oc:hasRationale "Leaving application targets in shared defeats the purpose of the restructure and creates circular dependencies." ;
    oc:severityLevel "HIGH" .

oc:kn_f447016e a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When shared JVM code exists between Android and Desktop" ;
    oc:directiveContent "If shared JVM code is needed by both Android and Desktop, either keep a jvm() target in shared (without application block) or put all shared code in commonMain and rely on JVM dependency from desktopApp." ;
    oc:hasRationale "Removing the desktop target from shared may break shared JVM source sets; these options preserve the shared code without keeping the application config." .

