oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_agp9_migration_checklist a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "checklist" ;
    skos:broader "Verification checklist" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/kotlin/kotlin-agent-skills/kotlin-tooling-agp9-migration" ;
    oc:contentHash "bccb1adb33a00368e09b94d4cce19b3f3b60da0dab6441664249c078d3dce31c" ;
    oc:differentia "that validates KMP AGP 9.0 migration completeness across plugin configuration, DSL, build logic, ProGuard, and multi-platform builds" ;
    oc:extends oc:skill_kotlin_kotlin_agent_skills_kotlin_tooling_agp9_migration ;
    oc:handlesFailure oc:BuildFailure,
        oc:ConfigurationError,
        oc:DeprecationWarning ;
    oc:hasArgumentHint "none (post-migration checklist)" ;
    oc:hasCategory "development" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Use this checklist after migration to verify everything is configured correctly." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 8 ;
                                    oc:itemText "[ ] No deprecation warnings about variant API or DSL" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "[ ] `xcodebuild -project iosApp/*.xcodeproj -scheme <scheme> -sdk iphonesimulator build` succeeds (if iOS app exists)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "[ ] Web/Wasm target compiles: `./gradlew :wasmJsApp:wasmJsBrowserDistribution` or equivalent (if web target exists)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "[ ] `./gradlew :androidApp:assembleDebug` succeeds (if app module exists)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "[ ] Desktop app compiles: `./gradlew :desktopApp:run` or equivalent (if desktop target exists)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "[ ] `./gradlew :shared:allTests` succeeds (or equivalent for KMP test tasks)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "[ ] `./gradlew :androidApp:testDebugUnitTest` succeeds (if app module exists)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "[ ] `./gradlew build` succeeds" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Build & Test Verification" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "[ ] Using `proguard-android-optimize.txt` (not `proguard-android.txt`)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "[ ] Consumer ProGuard rules migrated to `consumerProguardFiles.add(file(...))` in new DSL" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "[ ] No global options (`-dontobfuscate`, `-dontoptimize`) in library consumer rules" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "[ ] Keep rules updated for R8 strict full mode (explicit default constructor rules if needed)" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "ProGuard / R8" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "[ ] `androidResources { enable = true }` present if module uses Android or Compose Multiplatform resources" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "[ ] No `android {}` top-level block — use `androidLibrary {}` inside `kotlin {}` instead" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "[ ] Unique `namespace` for each library module (different from app module; `android.uniquePackageNames=true` is default in AGP 9.0)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:hasChild [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "app modules can still use `debugImplementation`" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "use `androidRuntimeClasspath` for tooling deps" ] ] ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "[ ] No `debugImplementation` or analogs in library modules" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "[ ] `withJava()` present if module has .java source files" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "[ ] Tests configured: `withHostTest {}`, `withDeviceTest {}`" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "[ ] Source sets renamed: `androidMain`, `androidHostTest`, `androidDeviceTest`" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "KMP Library Modules" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "[ ] Any opt-out flags (`android.newDsl=false`, `android.builtInKotlin=false`) documented with reason" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "[ ] `targetSdk` explicitly set in all app modules (defaults to `compileSdk` now, was `minSdk`)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:hasChild [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "`android.r8.integratedResourceShrinking`" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "`android.enableNewResourceShrinker.preciseShrinking`" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "`android.enableLegacyVariantApi`" ] ] ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "[ ] No removed properties in `gradle.properties` that cause errors:" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Gradle Properties & DSL" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "[ ] Using `CommonExtension` or specific new DSL types" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "[ ] No references to `BaseExtension`, `AppExtension`, `LibraryExtension` (removed in AGP 9.0)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "[ ] No use of removed APIs: `applicationVariants`, `libraryVariants`, `variantFilter`" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Build Logic / Convention Plugins" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "[ ] No `android.builtInKotlin=false` unless required by incompatible plugin (documented as temporary)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "[ ] `kotlin.sourceSets` migrated to `android.sourceSets` with `.kotlin` accessor (non-KMP modules)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 8 ;
                                    oc:itemText "[ ] Third-party plugins verified compatible" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "[ ] `org.jetbrains.kotlin.android` removed from all build files and version catalog (built-in Kotlin replaces it)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "[ ] No `com.android.library` or `com.android.application` in KMP modules' build.gradle.kts" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "[ ] `android.kotlinOptions {}` migrated to `kotlin { compilerOptions {} }` (non-KMP modules)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "[ ] `com.android.kotlin.multiplatform.library` plugin declared for KMP library modules" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "[ ] No `org.jetbrains.kotlin.kapt` plugin — migrated to KSP or `com.android.legacy-kapt`" ] ] ;
                    oc:sectionLevel 2 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Plugin Configuration" ] ;
            oc:sectionLevel 1 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "KMP AGP 9.0 Migration Verification Checklist" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Post-migration verification checklist to ensure all AGP 9.0 changes are correctly applied and builds pass." ;
            oc:hasStep _:ref_7fadffab825df200,
                _:ref_82bbe84631c07ecc,
                _:ref_b8ecf258b57b98d7,
                [ a oc:WorkflowStep ;
                    dcterms:description "Run full build, platform-specific builds (Android, iOS, Desktop, Wasm), and all test tasks. Verify no deprecation warnings." ;
                    oc:expectedOutcome "All builds and tests pass with no deprecation warnings" ;
                    oc:stepDependsOn _:ref_7fadffab825df200,
                        _:ref_b8ecf258b57b98d7,
                        _:ref_c9511b6cf4ebfe75 ;
                    oc:stepId "build-and-test" ],
                _:ref_c9511b6cf4ebfe75,
                _:ref_f8f9974f8e7042f1 ;
            oc:workflowId "agp9-verification" ;
            oc:workflowName "AGP 9.0 Migration Verification" ] ;
    oc:impartsKnowledge oc:kn_185e697e,
        oc:kn_3c8cb38a,
        oc:kn_4170a4f4,
        oc:kn_5aff0e4b,
        oc:kn_8842a2f3,
        oc:kn_afc4d020,
        oc:kn_bd079409,
        oc:kn_c688a8ca ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:MigrationCompleted ;
    oc:resolvesIntent "check post-migration configuration",
        "validate KMP migration correctness",
        "verify AGP 9.0 migration" ;
    oc:yieldsState oc:MigrationVerified .

oc:kn_185e697e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "KMP library module structure" ;
    oc:directiveContent "Source sets must be renamed to `androidMain`, `androidHostTest`, `androidDeviceTest`; use `androidLibrary {}` inside `kotlin {}` instead of top-level `android {}` block." ;
    oc:hasRationale "AGP 9.0 unified source set naming and DSL structure for KMP library modules." ;
    oc:severityLevel "HIGH" .

oc:kn_3c8cb38a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Plugin configuration verification" ;
    oc:directiveContent "No `com.android.library` or `com.android.application` in KMP modules' build.gradle.kts; they must use `com.android.kotlin.multiplatform.library`." ;
    oc:hasRationale "AGP 9.0 replaces the old Android plugins in KMP modules with the new multiplatform library plugin." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4170a4f4 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before running build verification" ;
    oc:directiveContent "Verify `org.jetbrains.kotlin.android` removed from all build files and version catalog; verify `org.jetbrains.kotlin.kapt` replaced with KSP or `com.android.legacy-kapt`." ;
    oc:hasRationale "Built-in Kotlin in AGP 9.0 replaces the separate Kotlin Android plugin; leftover references cause conflicts." ;
    oc:severityLevel "HIGH" .

oc:kn_5aff0e4b a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After build succeeds" ;
    oc:directiveContent "Confirm no deprecation warnings about variant API or DSL after successful build, and that `targetSdk` is explicitly set in all app modules (defaults changed to `compileSdk`)." ;
    oc:hasRationale "Deprecation warnings signal future breakage; the targetSdk default change can silently alter app behavior." ;
    oc:severityLevel "MEDIUM" .

oc:kn_8842a2f3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "KMP library module dependency configuration" ;
    oc:directiveContent "Do not use `debugImplementation` or analogs in KMP library modules; use `androidRuntimeClasspath` for tooling dependencies instead." ;
    oc:hasRationale "AGP 9.0 changed how Android dependencies work in KMP library modules; old configurations cause build errors or incorrect resolution." ;
    oc:severityLevel "HIGH" .

oc:kn_afc4d020 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Build logic and convention plugins" ;
    oc:directiveContent "No references to `BaseExtension`, `AppExtension`, `LibraryExtension`, `applicationVariants`, `libraryVariants`, or `variantFilter` — all removed in AGP 9.0." ;
    oc:hasRationale "These APIs were removed in AGP 9.0; using them causes compilation failures in build scripts." ;
    oc:severityLevel "CRITICAL" .

oc:kn_bd079409 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "Gradle properties cleanup" ;
    oc:directiveContent "Properties `android.enableLegacyVariantApi`, `android.r8.integratedResourceShrinking`, and `android.enableNewResourceShrinker.preciseShrinking` were removed and will cause errors if present in gradle.properties." ;
    oc:hasRationale "These removed properties cause build failures if left in gradle.properties after migration." ;
    oc:severityLevel "HIGH" .

oc:kn_c688a8ca a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Build & test verification order" ;
    oc:directiveContent "Run `./gradlew build` first, then verify each platform-specific build (Android, iOS, Desktop, Wasm), then run all test tasks." ;
    oc:hasRationale "Layered verification catches configuration issues early before platform-specific failures obscure root causes." .

_:ref_7fadffab825df200 a oc:WorkflowStep ;
    dcterms:description "Verify ProGuard/R8 rules: consumer rules migrated, using optimize config, no global options in library rules, R8 strict full mode compatible." ;
    oc:expectedOutcome "ProGuard/R8 configuration is AGP 9.0 compliant" ;
    oc:stepDependsOn _:ref_f8f9974f8e7042f1 ;
    oc:stepId "verify-proguard" .

_:ref_b8ecf258b57b98d7 a oc:WorkflowStep ;
    dcterms:description "Check gradle.properties for removed properties, verify targetSdk explicitly set, document any opt-out flags." ;
    oc:expectedOutcome "No removed properties present, targetSdk explicit" ;
    oc:stepDependsOn _:ref_82bbe84631c07ecc ;
    oc:stepId "verify-gradle-properties" .

_:ref_c9511b6cf4ebfe75 a oc:WorkflowStep ;
    dcterms:description "Verify KMP library modules: source sets renamed, androidLibrary DSL used, androidResources enabled, withJava/withHostTest/withDeviceTest configured, no debugImplementation in libs." ;
    oc:expectedOutcome "KMP module structure matches AGP 9.0 requirements" ;
    oc:stepDependsOn _:ref_82bbe84631c07ecc ;
    oc:stepId "verify-kmp-modules" .

_:ref_f8f9974f8e7042f1 a oc:WorkflowStep ;
    dcterms:description "Check convention plugins for removed API references (BaseExtension, AppExtension, LibraryExtension, variantFilter)." ;
    oc:expectedOutcome "Build logic uses only AGP 9.0 compatible APIs" ;
    oc:stepDependsOn _:ref_82bbe84631c07ecc ;
    oc:stepId "verify-build-logic" .

_:ref_82bbe84631c07ecc a oc:WorkflowStep ;
    dcterms:description "Verify plugin configuration: correct plugin IDs, removed old plugins, migrated kotlinOptions to compilerOptions, third-party compatibility." ;
    oc:expectedOutcome "All plugin declarations are AGP 9.0 compliant" ;
    oc:stepId "verify-plugins" .

