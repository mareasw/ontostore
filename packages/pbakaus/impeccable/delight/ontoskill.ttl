@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_delight a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "delight" ;
    skos:broader "UX Enhancement Skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/delight" ;
    oc:contentHash "5ade3a4fe9640a0235258062d778ae515ae1f6a433afbb1b035ae07f8fc3191a" ;
    oc:dependsOnSkill oc:skill_frontend_design ;
    oc:differentia "adds moments of joy, personality, micro-interactions, and unexpected touches that transform functional interfaces into memorable, emotionally engaging experiences" ;
    oc:extends oc:skill_polish ;
    oc:handlesFailure oc:AccessibilityViolation,
        oc:DelightOveruse,
        oc:PerformanceDegraded ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "design" ;
    oc:hasDescription "Add moments of joy, personality, and unexpected touches that make interfaces memorable and enjoyable to use. Elevates functional to delightful. Use when the user asks to add polish, personality, animations, micro-interactions, delight, or make an interface feel fun or memorable." ;
    oc:hasName "delight" ;
    oc:impartsKnowledge oc:kn_078d7fb4,
        oc:kn_09a70667,
        oc:kn_0fcb169a,
        oc:kn_5b789803,
        oc:kn_88cec908,
        oc:kn_97b86c5f,
        oc:kn_97de8a7c ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:CodebaseAccessible,
        oc:DesignContextLoaded ;
    oc:resolvesIntent "add delight and personality to interfaces",
        "add playful copy and visual personality",
        "create memorable micro-interactions",
        "design easter eggs and discovery rewards",
        "improve empty states, loading states, and success states" ;
    oc:yieldsState oc:DelightEnhanced,
        oc:MicroInteractionsAdded .

oc:kn_078d7fb4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing loading messages, empty states, or personality copy" ;
    oc:directiveContent "Never use cliched AI-generated loading messages like 'Herding pixels', 'Teaching robots to dance', or 'Consulting the magic 8-ball'. Write messages specific to what the product actually does." ;
    oc:hasRationale "Generic AI-slop copy is instantly recognizable as machine-generated and undermines the authenticity that delight is supposed to create." ;
    oc:severityLevel "HIGH" .

oc:kn_09a70667 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting delight techniques, copy tone, and animation style" ;
    oc:directiveContent "Match delight to brand personality and audience context. A banking app should not use the same playful tone as a gaming app. Banks can be warm but not wacky." ;
    oc:hasRationale "Inappropriate delight breaks trust and feels tone-deaf, especially in serious or high-stakes contexts." ;
    oc:severityLevel "HIGH" .

oc:kn_0fcb169a a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing delight strategies for frequently-used interfaces" ;
    oc:directiveContent "Delight should compound over time — vary responses so they remain fresh, reveal deeper layers with continued use, and don't repeat the same animation every time. Special moments should feel special because they are not constant." ;
    oc:hasRationale "Delight that is identical on every interaction becomes invisible and then annoying. Variation and progressive disclosure maintain the element of surprise." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5b789803 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any animation, sound, or visual delight element" ;
    oc:directiveContent "Animate responsibly: support prefers-reduced-motion, provide screen reader alternatives, and ensure delight features do not degrade performance. Lazy load delight features and compress assets." ;
    oc:hasRationale "Accessibility and performance are non-negotiable foundations. Delight that excludes users or causes jank is counterproductive." ;
    oc:severityLevel "CRITICAL" .

oc:kn_88cec908 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding any delight element to an interface" ;
    oc:directiveContent "Delight must amplify usability, never block it. Delight moments should be quick (< 1 second), never delay core functionality, and always be skippable or subtle." ;
    oc:hasRationale "If users notice the delight more than accomplishing their goal, the delight has failed its purpose and become a hindrance." ;
    oc:severityLevel "CRITICAL" .

oc:kn_97b86c5f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or implementing delight enhancements" ;
    oc:directiveContent "Never use delight to mask poor UX, force users through delightful moments, or sacrifice core usability for visual flair. Less is more." ;
    oc:hasRationale "Delight layered on top of broken flows is lipstick on a pig — it draws attention to the problem rather than solving it." ;
    oc:severityLevel "CRITICAL" .

oc:kn_97de8a7c a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding sound design or frequent micro-interactions" ;
    oc:directiveContent "Respect user's time and task focus. Sound fatigue is real — don't play sounds on every interaction. Keep volumes quiet and provide mute options." ;
    oc:hasRationale "Overstimulation creates the opposite of delight. Sound and animation frequency must be carefully throttled to remain pleasant." ;
    oc:severityLevel "MEDIUM" .

