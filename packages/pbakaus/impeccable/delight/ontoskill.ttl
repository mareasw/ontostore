oc:kn_05559075 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing delight techniques and copy tone" ;
    oc:directiveContent "Match delight to brand personality and context. Banks shouldn't be wacky, but they can be warm. Banking app ≠ gaming app." ;
    oc:hasRationale "Inappropriate delight erodes brand trust and confuses users about the product's identity" ;
    oc:severityLevel "CRITICAL" .

oc:kn_3bcaf2b3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding any delight element" ;
    oc:directiveContent "Delight moments must be quick (< 1 second). Never delay core functionality for delight. Make delight skippable or subtle." ;
    oc:hasRationale "Delight that blocks or slows users becomes an annoyance, defeating its purpose" ;
    oc:severityLevel "CRITICAL" .

oc:kn_56fc8921 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing delight strategy" ;
    oc:directiveContent "Never use delight to hide poor UX, force users through delightful moments, or make every interaction delightful. Special moments should be special." ;
    oc:hasRationale "Overuse of delight desensitizes users and devalues genuinely special moments" ;
    oc:severityLevel "HIGH" .

oc:kn_5859e338 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing loading messages or personality copy" ;
    oc:directiveContent "Never use cliched AI-slop loading messages like 'Herding pixels', 'Teaching robots to dance', 'Consulting the magic 8-ball'. Write messages specific to what the product actually does." ;
    oc:hasRationale "Generic AI-generated copy is instantly recognizable and breaks trust in the product's authenticity" ;
    oc:severityLevel "HIGH" .

oc:kn_906e2af4 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing delight implementations" ;
    oc:directiveContent "If users notice the delight more than accomplishing their goal, you've gone too far. Delight should enhance usability, never obscure it." ;
    oc:hasRationale "The primary purpose of any interface is utility; delight is a secondary quality that amplifies but never replaces good UX" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9f864481 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing repeated-use interactions" ;
    oc:directiveContent "Delight should compound over time: vary responses so they remain fresh, reveal deeper layers with continued use, and build anticipation through patterns." ;
    oc:hasRationale "Delight that repeats identically becomes invisible or annoying; novelty sustains engagement" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f9c8cb40 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing animations, sounds, or visual effects" ;
    oc:directiveContent "Respect accessibility: animate responsibly, provide alternatives for reduced motion, ensure screen reader compatibility, and always provide mute options for audio." ;
    oc:hasRationale "Delight that excludes users with disabilities is fundamentally broken" ;
    oc:severityLevel "CRITICAL" .

oc:kn_fb876a91 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When implementing any delight feature" ;
    oc:directiveContent "File size matters. Compress images, optimize animations, lazy load delight features. Never sacrifice performance for delight." ;
    oc:hasRationale "Slow interfaces destroy delight regardless of how charming the animations are" ;
    oc:severityLevel "HIGH" .

oc:kn_fbe07414 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any delight work" ;
    oc:directiveContent "Before adding delight, gather: brand personality (playful/professional/quirky/elegant), audience type, emotional context, and domain appropriateness." ;
    oc:hasRationale "Without understanding context, delight can be tone-deaf and counterproductive" ;
    oc:severityLevel "HIGH" .

