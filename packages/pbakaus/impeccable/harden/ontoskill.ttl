oc:skill_pbakaus_impeccable_harden a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "harden" ;
    skos:broader "UI quality improvement skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/harden" ;
    oc:contentHash "908e850238505c258c0ea270d2b20311d8c3f9f5b2695e45b3ffb3d3a221abf4" ;
    oc:differentia "systematically strengthens interfaces against edge cases, errors, internationalization issues, and real-world usage scenarios rather than visual styling" ;
    oc:extends oc:skill_audit ;
    oc:handlesFailure oc:InputValidationError,
        oc:LayoutBreaksDetected,
        oc:TextOverflowDetected ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Improve interface resilience through better error handling, i18n support, text overflow handling, and edge case management. Makes interfaces robust and production-ready. Use when the user asks to harden, make production-ready, handle edge cases, add error states, or fix overflow and i18n issues." ;
    oc:hasName "harden" ;
    oc:impartsKnowledge oc:kn_06f89c80,
        oc:kn_1df5b16f,
        oc:kn_768ef1d2,
        oc:kn_7fc726e9,
        oc:kn_90786965,
        oc:kn_a4ce3f2e,
        oc:kn_c2256022,
        oc:kn_d6d0220a,
        oc:kn_d6fa9cb8 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:ComponentRendered,
        oc:UIFeatureExists ;
    oc:resolvesIntent "add error states and recovery",
        "add internationalization support",
        "fix text overflow and wrapping issues",
        "handle edge cases in UI",
        "harden interface for production",
        "improve input validation and sanitization",
        "make interface resilient to real-world usage" ;
    oc:yieldsState oc:EdgeCasesHandled,
        oc:ProductionReady,
        oc:UIHardened .

oc:kn_06f89c80 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When implementing any event-driven or async UI pattern" ;
    oc:directiveContent "Use debounce for search input (~300ms) and throttle for scroll handlers (~100ms); always clean up event listeners, subscriptions, timers, and abort pending requests on unmount." ;
    oc:hasRationale "Unthrottled handlers cause excessive re-renders and API calls; uncleared subscriptions and timers cause memory leaks that degrade performance over time." ;
    oc:severityLevel "MEDIUM" .

oc:kn_1df5b16f a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When performing any hardening pass on a feature" ;
    oc:directiveContent "Harden systematically across six dimensions: text overflow, internationalization, error handling, edge cases/boundary conditions, input validation, and accessibility resilience." ;
    oc:hasRationale "Ad-hoc hardening misses entire categories of failure; systematic dimension-by-dimension coverage ensures comprehensive production readiness." ;
    oc:severityLevel "HIGH" .

oc:kn_768ef1d2 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing any CSS that involves directional spacing or borders" ;
    oc:directiveContent "Use logical CSS properties (margin-inline-start, padding-inline, border-inline-end) instead of physical directional properties to support RTL languages natively." ;
    oc:hasRationale "Physical properties (margin-left, padding-right) break in RTL layouts, requiring separate overrides; logical properties adapt automatically." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7fc726e9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When hardening any UI component" ;
    oc:directiveContent "Test with extreme inputs systematically: very long text (100+ chars), empty strings, emoji, RTL text, CJK characters, large numbers, and zero-item collections." ;
    oc:hasRationale "Edge cases with extreme inputs are the most common source of production UI failures that never appear in idealized development environments." ;
    oc:severityLevel "HIGH" .

oc:kn_90786965 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any form or data input flow" ;
    oc:directiveContent "Never trust client-side validation alone — always validate and sanitize on the server side." ;
    oc:hasRationale "Client-side validation can be bypassed, leading to injection attacks, data corruption, and security vulnerabilities." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a4ce3f2e a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When handling form submissions or any user-initiated async operation" ;
    oc:directiveContent "Prevent double-submission by disabling buttons during loading, and use optimistic updates with rollback for perceived performance." ;
    oc:hasRationale "Double-submission causes duplicate data and confusing states; optimistic updates with rollback provide responsiveness while maintaining data integrity on failure." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c2256022 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing any text-containing component" ;
    oc:directiveContent "Never use fixed widths for text containers or assume English-length text — translations can be 30-40% longer (e.g., German)." ;
    oc:hasRationale "Fixed-width text containers break when content expands due to translation, long user input, or special characters, causing overflow and layout destruction." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d6d0220a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When displaying any error state to users" ;
    oc:directiveContent "Never use generic error messages like 'Error occurred' — always show clear, specific messages with recovery actions." ;
    oc:hasRationale "Generic errors leave users confused and unable to recover, degrading trust and increasing support burden." ;
    oc:severityLevel "HIGH" .

oc:kn_d6fa9cb8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing CSS for flex or grid layouts" ;
    oc:directiveContent "All flex and grid items must have min-width: 0 to prevent content from overflowing their container." ;
    oc:hasRationale "Flex and grid items have an implicit minimum size equal to their content, which causes overflow when content is wider than the available space." ;
    oc:severityLevel "HIGH" .

