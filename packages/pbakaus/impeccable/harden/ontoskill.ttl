oc:kn_2b1b0eff a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling any text-containing element" ;
    oc:directiveContent "Never use fixed widths for text containers or assume English-length text. Add 30-40% space budget for translations and use content-adaptive layouts like flexbox/grid." ;
    oc:hasRationale "Translations (especially German) can be 30% longer than English, and CJK characters have different width characteristics" ;
    oc:severityLevel "HIGH" .

oc:kn_3ed6f5f8 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing error handling" ;
    oc:directiveContent "Never leave error messages generic ('Error occurred'), trust client-side validation alone, or block the entire interface when one component errors." ;
    oc:hasRationale "Generic errors frustrate users, client-side validation is bypassable, and cascading failures take down the whole UI" ;
    oc:severityLevel "CRITICAL" .

oc:kn_420d748f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assessing any interface for production readiness" ;
    oc:directiveContent "Designs that only work with perfect data aren't production-ready. Always validate: extreme inputs (long/short text, special chars, large numbers), error scenarios (network, API, validation), and i18n (RTL, CJK, date/number formats)." ;
    oc:hasRationale "Real users provide unexpected inputs, lose connections, and use the product in unanticipated ways" ;
    oc:severityLevel "CRITICAL" .

oc:kn_551baf07 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning a hardening pass" ;
    oc:directiveContent "Hardening is about expecting the unexpected. Systematically test each dimension: text overflow, i18n, error handling, edge cases (empty/loading/large data), input validation, accessibility, and performance." ;
    oc:hasRationale "A systematic dimension-by-dimension approach ensures no resilience gap is missed" .

oc:kn_90d9aaf1 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "When validating hardened interface" ;
    oc:directiveContent "Before considering hardening complete, verify with: 100+ character text, emoji in all fields, RTL languages, CJK characters, disabled network, 1000+ items, rapid repeated clicks, forced API errors, and empty data." ;
    oc:hasRationale "A comprehensive checklist ensures production resilience across all dimensions" .

oc:kn_d34b52c8 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When handling concurrent operations and performance-sensitive interactions" ;
    oc:directiveContent "Prevent double-submission by disabling buttons during loading, use pagination/virtual scrolling for large datasets, debounce search input (300ms), throttle scroll handlers (100ms), and clean up event listeners/subscriptions on unmount." ;
    oc:hasRationale "Uncontrolled concurrent operations and memory leaks degrade performance over time" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d88b4281 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing CSS for any layout" ;
    oc:directiveContent "Use logical CSS properties (margin-inline-start, padding-inline, border-inline-end) instead of physical properties (margin-left, padding-right) to support RTL languages without extra code." ;
    oc:hasRationale "Logical properties automatically adapt to RTL contexts, eliminating the need for separate RTL stylesheets" .

oc:kn_f80b3f49 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When implementing error handling for network/API calls" ;
    oc:directiveContent "For every error state, provide: a clear message explaining what happened, a retry/recovery action, and preservation of user input. Handle each API status code appropriately (400→validation, 401→login, 403→permissions, 404→not found, 429→rate limit, 500→generic with support)." ;
    oc:hasRationale "Actionable error states let users recover instead of abandoning the interface" .

oc:req_92d5d36f a oc:RequirementKnowledge ;
    oc:isOptional true ;
    oc:requirementValue "React error state patterns" .

oc:req_bc9a744b a oc:RequirementKnowledge ;
