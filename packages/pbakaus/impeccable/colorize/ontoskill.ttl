@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_colorize a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "colorize" ;
    skos:broader "UI design enhancement skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/colorize" ;
    oc:contentHash "3cdf30fefcfd687a79e22ba304c05c09b3b90a5dabc89f2369a00b2faee63dd3" ;
    oc:dependsOnSkill oc:skill_teach_impeccable ;
    oc:differentia "strategically introduces color to monochromatic or visually flat interfaces through semantic, hierarchical, and decorative color application while maintaining accessibility and cohesion" ;
    oc:extends oc:skill_frontend_design ;
    oc:handlesFailure oc:AccessibilityViolation,
        oc:DesignContextMissing,
        oc:InsufficientContext ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "design" ;
    oc:hasDescription "Add strategic color to features that are too monochromatic or lack visual interest, making interfaces more engaging and expressive. Use when the user mentions the design looking gray, dull, lacking warmth, needing more color, or wanting a more vibrant or expressive palette." ;
    oc:hasName "colorize" ;
    oc:impartsKnowledge oc:kn_1a119b1f,
        oc:kn_276e779d,
        oc:kn_4ee63be6,
        oc:kn_8bf1f3db,
        oc:kn_b8495c4b,
        oc:kn_d46d160f,
        oc:kn_e8f7a24f ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextEstablished,
        oc:ExistingCodebase ;
    oc:resolvesIntent "add color to interface",
        "create color palette for UI",
        "enhance visual hierarchy with color",
        "fix monochromatic design",
        "improve visual warmth",
        "make design more vibrant" ;
    oc:yieldsState oc:AccessibilityVerified,
        oc:ColorPaletteEstablished,
        oc:ColorStrategyApplied .

oc:kn_1a119b1f a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying any color to text, icons, or interactive elements" ;
    oc:directiveContent "All color combinations must meet WCAG contrast ratios: 4.5:1 for text, 3:1 for UI components. Never use color as the sole indicator of meaning." ;
    oc:hasRationale "Failing contrast requirements excludes users with visual impairments; relying only on color excludes colorblind users" ;
    oc:severityLevel "CRITICAL" .

oc:kn_276e779d a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After applying color changes to an interface" ;
    oc:directiveContent "Verify that color addition improved the experience: better hierarchy, clearer semantic meaning, warmer feel, WCAG compliance maintained, and color remains balanced rather than overwhelming." ;
    oc:hasRationale "Color must demonstrably improve the user experience; if it only adds visual noise, it should be refined or reduced" ;
    oc:severityLevel "MEDIUM" .

oc:kn_4ee63be6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning and balancing the overall color strategy" ;
    oc:directiveContent "Use the 60/30/10 color distribution rule: dominant color owns 60% of colored elements, secondary provides 30%, and accent provides 10% contrast for key moments." ;
    oc:hasRationale "Proportional color distribution creates visual harmony and prevents any single color from dominating unintentionally" ;
    oc:severityLevel "HIGH" .

oc:kn_8bf1f3db a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining any color value or palette" ;
    oc:directiveContent "Use OKLCH color space instead of hex or RGB. It is perceptually uniform, meaning equal steps in lightness look equal, making it ideal for generating harmonious color scales." ;
    oc:hasRationale "OKLCH produces more predictable and visually consistent results than sRGB-based hex values, especially for tints and shades" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b8495c4b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any color enhancement work" ;
    oc:directiveContent "Before colorizing, gather existing brand colors and ensure design context is established via /frontend-design and /teach-impeccable. Assess current color absence level and domain-appropriate tone." ;
    oc:hasRationale "Without understanding existing brand identity and context, color choices will feel disconnected and arbitrary" ;
    oc:severityLevel "HIGH" .

oc:kn_d46d160f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing background colors, gradients, and text colors" ;
    oc:directiveContent "Never default to purple-blue gradients (AI slop aesthetic), use pure gray (#f5f5f5) for neutrals, pure black (#000) or pure white (#fff) for large areas, or put gray text on colored backgrounds." ;
    oc:hasRationale "These choices signal AI-generated design and look unsophisticated; tinted neutrals and darker background-matched shades create more polished results" ;
    oc:severityLevel "HIGH" .

oc:kn_e8f7a24f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting and applying a color palette to any interface" ;
    oc:directiveContent "Never use every color in the rainbow — limit to 2-4 colors beyond neutrals. Every color choice must have semantic meaning and purpose." ;
    oc:hasRationale "Rainbow palettes create visual chaos and undermine the hierarchy that strategic color is meant to establish" ;
    oc:severityLevel "HIGH" .

