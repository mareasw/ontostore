@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_colorize a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "colorize" ;
    skos:broader "UI enhancement skill" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/colorize" ;
    oc:contentHash "3cdf30fefcfd687a79e22ba304c05c09b3b90a5dabc89f2369a00b2faee63dd3" ;
    oc:dependsOnSkill oc:skill_ontoskills_teach_impeccable ;
    oc:differentia "strategically introduces color to monochromatic or visually bland interfaces to improve engagement, hierarchy, and meaning" ;
    oc:extends oc:skill_ontoskills_frontend_design ;
    oc:handlesFailure oc:ColorOverload,
        oc:ContrastViolation,
        oc:InsufficientContext ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "design" ;
    oc:hasDescription "Add strategic color to features that are too monochromatic or lack visual interest, making interfaces more engaging and expressive. Use when the user mentions the design looking gray, dull, lacking warmth, needing more color, or wanting a more vibrant or expressive palette." ;
    oc:hasName "colorize" ;
    oc:hasRequirement oc:req_316de363,
        oc:req_6eac1487,
        oc:req_ed65a109 ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Strategically introduce color to designs that are too monochromatic, gray, or lacking in visual warmth and personality." ],
                [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: colorize
description: Add strategic color to features that are too monochromatic or lack visual interest, making interfaces more engaging and expressive. Use when the user mentions the design looking gray, dull, lacking warmth, needing more color, or wanting a more vibrant or expressive palette.
user-invocable: true
argument-hint: "[target]"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Clearer meaning**: Does color help users understand states/categories?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Better hierarchy**: Does color guide attention appropriately?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**More engaging**: Does the interface feel warmer and more inviting?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Still accessible**: Do all color combinations meet WCAG standards?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "**Not overwhelming**: Is color balanced and purposeful?" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Test that colorization improves the experience:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "Remember: Color is emotional and powerful. Use it to create warmth, guide attention, communicate meaning, and express personality. But restraint and strategy matter more than saturation and variety. Be colorful, but be intentional." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 6 ;
            oc:sectionTitle "Verify Color Addition" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Analyze the current state and identify opportunities:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**CRITICAL**: More color ≠ better. Strategic color beats rainbow vomit every time. Every color should have a purpose." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "If any of these are unclear from the codebase, ask the user directly to clarify what you cannot infer." ],
                _:ref_d23cc18c2c5f38e5 ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Assess Color Opportunity" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Add color systematically across these dimensions:" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Gradients**: Colorful gradient overlays or mesh backgrounds" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Shapes**: Geometric shapes in brand colors as background elements" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Illustrations**: Add colored illustrations or icons" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Blobs/organic shapes**: Soft colored shapes for visual interest" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Decorative Elements" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Use OKLCH for color**: It's perceptually uniform, meaning equal steps in lightness *look* equal. Great for generating harmonious scales." ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Cards & surfaces**: Tint cards or surfaces slightly for warmth" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Colored sections**: Use subtle background colors to separate areas" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Gradient backgrounds**: Add depth with subtle, intentional gradients (not generic purple-blue)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Tinted backgrounds**: Replace pure gray (`#f5f5f5`) with warm neutrals (`oklch(97% 0.01 60)`) or cool tints (`oklch(97% 0.01 250)`)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Background & Surfaces" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Charts & graphs**: Use color to encode categories or values" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Heatmaps**: Color intensity shows density or importance" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Comparison**: Color coding for different datasets or timeframes" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Data Visualization" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Icons**: Colorize key icons for recognition and personality" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Links**: Add color to clickable text (maintain accessibility)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Hover states**: Introduce color on interaction" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Primary actions**: Color the most important buttons/CTAs" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Headers/titles**: Add color to section headers or key labels" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Accent Color Application" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Highlight text**: Color for emphasis or categories" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Labels & tags**: Small colored labels for metadata or categories" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Colored headings**: Use brand colors for section headings (maintain contrast)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Typography Color" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:hasChild [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "Warning: Orange/amber tones" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Error: Red/pink tones (rose, crimson, coral)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Success: Green tones (emerald, forest, mint)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 4 ;
                                                    oc:itemText "Info: Blue tones (sky, ocean, indigo)" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 5 ;
                                                    oc:itemText "Neutral: Gray/slate for inactive states" ] ] ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**State indicators**:" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Status badges**: Colored backgrounds or borders for states (active, pending, completed, etc.)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Progress indicators**: Colored bars, rings, or charts showing completion or health" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Semantic Color" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Focus rings**: Colored focus indicators matching brand" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Accent borders**: Add colored left/top borders to cards or sections" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Underlines**: Color underlines for emphasis or active states" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Dividers**: Subtle colored dividers instead of gray lines" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Borders & Accents" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Introduce Color Strategically" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Create a purposeful color introduction plan:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**IMPORTANT**: Color should enhance hierarchy and meaning, not create chaos. Less is more when it matters more." ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Accent colors**: Which colors provide contrast and highlights? (30% and 10%)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Application strategy**: Where does each color appear and why?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Color palette**: What colors match the brand/context? (Choose 2-4 colors max beyond neutrals)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Dominant color**: Which color owns 60% of colored elements?" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Plan Color Strategy" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Invoke /frontend-design — it contains design principles, anti-patterns, and the **Context Gathering Protocol**. Follow the protocol before proceeding — if no design context exists yet, you MUST run /teach-impeccable first. Additionally gather: existing brand colors." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "MANDATORY PREPARATION" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Ensure color addition improves rather than overwhelms:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 3 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Use pure gray for neutrals—add subtle color tint (warm or cool) for sophistication" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Put gray text on colored backgrounds—it looks washed out; use a darker shade of the background color or transparency instead" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 8 ;
                            oc:itemText "Make everything colorful (defeats the purpose)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Apply color randomly without semantic meaning" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Use every color in the rainbow (choose 2-4 colors beyond neutrals)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 7 ;
                            oc:itemText "Use color as the only indicator (accessibility issue)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 9 ;
                            oc:itemText "Default to purple-blue gradients (AI slop aesthetic)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "Use pure black (`#000`) or pure white (`#fff`) for large areas" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 6 ;
                            oc:itemText "Violate WCAG contrast requirements" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**NEVER**:" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Consistent palette**: Use colors from defined palette, not arbitrary choices" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Systematic application**: Same color meanings throughout (green always = success)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Temperature consistency**: Warm palette stays warm, cool stays cool" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Cohesion" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Don't rely on color alone**: Use icons, labels, or patterns alongside color" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Test for color blindness**: Verify red/green combinations work for all users" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Contrast ratios**: Ensure WCAG compliance (4.5:1 for text, 3:1 for UI components)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Accessibility" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Accent color** (10%): High contrast for key moments" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Dominant color** (60%): Primary brand color or most used accent" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Neutrals** (remaining): Gray/black/white for structure" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Secondary color** (30%): Supporting color for variety" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Maintain Hierarchy" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 5 ;
            oc:sectionTitle "Balance & Refinement" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Complete workflow for adding purposeful color to monochromatic interfaces" ;
            oc:hasStep _:ref_0764aa7ea555ae3e,
                _:ref_11e7aba99948656d,
                [ a oc:WorkflowStep ;
                    dcterms:description "Verify WCAG contrast compliance, check 60-30-10 balance, ensure cohesion and temperature consistency, confirm color is purposeful not overwhelming." ;
                    oc:expectedOutcome "Colorized interface that is accessible, balanced, and improves user experience" ;
                    oc:stepDependsOn _:ref_f6b4dd9c0446e673 ;
                    oc:stepId "refine-verify" ],
                _:ref_f6b4dd9c0446e673,
                _:ref_fb53c486625553c8 ;
            oc:workflowId "colorize-workflow" ;
            oc:workflowName "Strategic Color Introduction" ],
        _:ref_d23cc18c2c5f38e5 ;
    oc:impartsKnowledge oc:kn_122157a8,
        oc:kn_327a96f2,
        oc:kn_372d0035,
        oc:kn_620d9395,
        oc:kn_a1ebbc27,
        oc:kn_c28c95c1,
        oc:kn_c77589e2,
        oc:kn_d38bbf8b ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:BrandColorsGathered,
        oc:DesignContextEstablished ;
    oc:resolvesIntent "add color to design",
        "apply semantic color coding",
        "create color palette",
        "fix dull or gray UI",
        "improve visual warmth",
        "make interface more vibrant" ;
    oc:yieldsState oc:AccessibleColorPalette,
        oc:ColorizedInterface .

oc:kn_122157a8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining any color value" ;
    oc:directiveContent "Use OKLCH for color definition — it's perceptually uniform, meaning equal steps in lightness look equal. Replace pure grays (#f5f5f5) with tinted neutrals like oklch(97% 0.01 60) for warmth or oklch(97% 0.01 250) for cool tones." ;
    oc:hasRationale "OKLCH produces harmonious, predictable color scales. Pure grays and pure black/white feel dead and unsophisticated; subtle tints add life." ;
    oc:severityLevel "HIGH" .

oc:kn_327a96f2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying any color to text or interactive elements" ;
    oc:directiveContent "Ensure WCAG compliance: 4.5:1 contrast ratio for text, 3:1 for UI components. Never rely on color alone — always pair with icons, labels, or patterns." ;
    oc:hasRationale "Accessibility violations exclude users with visual impairments and color blindness. Color-only indicators fail for ~8% of men." ;
    oc:severityLevel "CRITICAL" .

oc:kn_372d0035 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When defining and applying color palette" ;
    oc:directiveContent "Limit palette to 2-4 colors beyond neutrals. Maintain temperature consistency — warm palette stays warm, cool stays cool. Apply same color meanings throughout (green always = success)." ;
    oc:hasRationale "Palette discipline creates cohesion. Mixed temperatures feel disjointed; inconsistent color meanings confuse users." ;
    oc:severityLevel "HIGH" .

oc:kn_620d9395 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any colorization work" ;
    oc:directiveContent "Before colorizing: gather existing brand colors, invoke /frontend-design for design context, run /teach-impeccable if no design context exists yet. Ask user directly if brand colors or domain appropriateness are unclear." ;
    oc:hasRationale "Without brand alignment and design context, color choices will be arbitrary and likely clash with existing identity." ;
    oc:severityLevel "HIGH" .

oc:kn_a1ebbc27 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After applying color changes, verify these five criteria" ;
    oc:directiveContent "Colorization is successful when: color guides attention to important elements, states/categories are clearer, interface feels warmer and more inviting, all combinations meet WCAG, and color feels balanced not overwhelming." ;
    oc:hasRationale "These indicators confirm color added value rather than noise. If any criterion fails, the colorization needs revision." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c28c95c1 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning color strategy" ;
    oc:directiveContent "Follow the 60-30-10 rule: dominant color owns 60% of colored elements, secondary 30%, accent 10%. Every color should have a purpose — semantic meaning, hierarchy, categorization, wayfinding, or delight." ;
    oc:hasRationale "This ratio creates visual harmony and prevents color chaos. Purposeless color degrades rather than improves design." ;
    oc:severityLevel "HIGH" .

oc:kn_c77589e2 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding color to any interface" ;
    oc:directiveContent "Never use every color in the rainbow — choose 2-4 colors max beyond neutrals. Never apply color randomly without semantic meaning. Never default to purple-blue gradients (AI slop aesthetic)." ;
    oc:hasRationale "Strategic, restrained color use is more effective than saturation. Rainbow vomit and generic purple-blue gradients signal low design quality." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d38bbf8b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When styling text on colored surfaces or large background areas" ;
    oc:directiveContent "Never put gray text on colored backgrounds — it looks washed out. Use a darker shade of the background color or transparency instead. Never use pure black (#000) or pure white (#fff) for large areas." ;
    oc:hasRationale "Gray on color destroys readability and appears muddy. Pure black/white creates harsh, artificial contrast that strains the eyes." ;
    oc:severityLevel "MEDIUM" .

oc:req_316de363 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "WCAG contrast requirements (4.5:1 text, 3:1 UI components)" .

oc:req_6eac1487 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "OKLCH color space for perceptually uniform color generation" .

