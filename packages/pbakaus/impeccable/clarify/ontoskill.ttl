oc:skill_pbakaus_impeccable_clarify a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "clarify" ;
    skos:broader "UX writing skill" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/clarify" ;
    oc:contentHash "05338a7cc8864dc1236313b5c400c072c221ea039d0052de1a0f6e561bf31d3f" ;
    oc:dependsOnSkill oc:skill_ontoskills_teach_impeccable ;
    oc:differentia "identifies and improves unclear interface text including error messages, labels, microcopy, and instructions to make products easier to understand" ;
    oc:extends oc:skill_ontoskills_frontend_design ;
    oc:handlesFailure oc:DesignContextMissing,
        oc:InvalidInput ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "design" ;
    oc:hasDescription "Improve unclear UX copy, error messages, microcopy, labels, and instructions to make interfaces easier to understand. Use when the user mentions confusing text, unclear labels, bad error messages, hard-to-follow instructions, or wanting better UX writing." ;
    oc:hasName "clarify" ;
    oc:hasRequirement oc:req_a53625ec ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: clarify
description: Improve unclear UX copy, error messages, microcopy, labels, and instructions to make interfaces easier to understand. Use when the user mentions confusing text, unclear labels, bad error messages, hard-to-follow instructions, or wanting better UX writing.
user-invocable: true
argument-hint: "[target]"
""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Identify and improve unclear, confusing, or poorly written interface text to make the product easier to understand and use." ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Actionability**: Do users know what to do next?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Consistency**: Does it match terminology elsewhere?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Comprehension**: Can users understand without context?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "**Tone**: Is it appropriate for the situation?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Brevity**: Is it as short as possible while remaining clear?" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "Remember: You're a clarity expert with excellent communication skills. Write like you're explaining to a smart friend who's unfamiliar with the product. Be clear, be helpful, be human." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Test that copy improvements work:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 15 ;
            oc:sectionTitle "Verify Improvements" ],
        [ a oc:Section ;
            oc:hasContent _:ref_a21e5b527dda03a2,
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Identify what makes the text unclear or ineffective:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**CRITICAL**: Clear copy helps users succeed. Unclear copy creates frustration, errors, and support tickets." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Assess Current Copy" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Primary message**: What's the ONE thing users need to know?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Tone**: How should this feel? (Helpful? Apologetic? Encouraging?)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Action needed**: What should users do next (if anything)?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Constraints**: Length limits, brand voice, localization considerations" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**IMPORTANT**: Good UX writing is invisible. Users should understand immediately without noticing the words." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Create a strategy for clearer communication:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Plan Copy Improvements" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**NEVER**:" ],
                _:ref_52bd6ad31f821f6b,
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Every piece of copy should follow these rules:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 4 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "Write overly long explanations (be concise)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Be vague (\"Something went wrong\" without explanation)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 7 ;
                            oc:itemText "Assume technical knowledge" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 9 ;
                            oc:itemText "Repeat information (headers restating intros, redundant explanations)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Use passive voice unnecessarily" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 8 ;
                            oc:itemText "Vary terminology (pick one term and stick with it)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Use jargon without explanation" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Blame users (\"You made an error\" → \"This field is required\")" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 10 ;
                            oc:itemText "Use placeholders as the only labels (they disappear when users type)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 6 ;
                            oc:itemText "Use humor for errors (be empathetic instead)" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 14 ;
            oc:sectionTitle "Apply Clarity Principles" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Invoke /frontend-design — it contains design principles, anti-patterns, and the **Context Gathering Protocol**. Follow the protocol before proceeding — if no design context exists yet, you MUST run /teach-impeccable first. Additionally gather: audience technical level and users' mental state in context." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "MANDATORY PREPARATION" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Refine text across these common areas:" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Answer the implicit question (\"What is this?\" or \"Why do you need this?\")" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Link to detailed docs if needed" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Keep it brief but complete" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Add value (don't just repeat the label)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Bad**: "This is the username field"
**Good**: "Choose a username. You can change this later in Settings.\"""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Principles**:" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Help Text & Tooltips" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Bad**: Generic labels like "Items" | "Things" | "Stuff"
**Good**: Specific labels like "Your projects" | "Team members" | "Settings\"""" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Consider information scent (breadcrumbs, current location)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Be specific and descriptive" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Make hierarchy clear" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Use language users understand (not internal jargon)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Principles**:" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 13 ;
                    oc:sectionTitle "Navigation & Wayfinding" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Match user's mental model" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Use active voice (verb + noun)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Be specific (\"Save\" is better than \"OK\")" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Describe the action specifically" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Bad**: "Click here" | "Submit" | "OK"
**Good**: "Create account" | "Save changes" | "Got it, thanks\"""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Principles**:" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Button & CTA Text" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "State the specific action" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Use clear button labels (\"Delete project\" not \"Yes\")" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Explain consequences (especially for destructive actions)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Don't overuse confirmations (only for risky actions)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Bad**: "Are you sure?"
**Good**: "Delete 'Project Alpha'? This can't be undone.\"""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Principles**:" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 12 ;
                    oc:sectionTitle "Confirmation Dialogs" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Bad**: "DOB (MM/DD/YYYY)"
**Good**: "Date of birth" (with placeholder showing format)""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Principles**:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**Bad**: "Enter value here"
**Good**: "Your email address" or "Company name\"""" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Keep required field indicators clear" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Explain why you're asking (when not obvious)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Use clear, specific labels (not generic placeholders)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Put instructions before the field, not after" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Show format expectations with examples" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Form Labels & Instructions" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Bad**: "Error 403: Forbidden"
**Good**: "You don't have permission to view this page. Contact your admin for access.\"""" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Include examples when helpful" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Link to help/support if applicable" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Explain what went wrong in plain language" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Don't blame the user" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Suggest how to fix it" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Principles**:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**Bad**: "Invalid input"
**Good**: "Email addresses need an @ symbol. Try: name@example.com\"""" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Error Messages" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Principles**:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Show next action clearly" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Explain why it's empty (if not obvious)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Make it welcoming, not dead-end" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Bad**: "No items"
**Good**: "No projects yet. Create your first project to get started.\"""" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 9 ;
                    oc:sectionTitle "Empty States" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Principles**:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Bad**: "Loading..." (for 30+ seconds)
**Good**: "Analyzing your data... this usually takes 30-60 seconds\"""" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Set expectations (how long?)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Show progress when possible" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Offer escape hatch if appropriate (\"Cancel\")" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Explain what's happening (when it's not obvious)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 11 ;
                    oc:sectionTitle "Loading States" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Principles**:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Confirm what happened" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Explain what happens next (if relevant)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Be brief but complete" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Match the user's emotional moment (celebrate big wins)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**Bad**: "Success"
**Good**: "Settings saved! Your changes will take effect immediately.\"""" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 10 ;
                    oc:sectionTitle "Success Messages" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Improve Copy Systematically" ] ;
    oc:hasWorkflow _:ref_52bd6ad31f821f6b,
        _:ref_a21e5b527dda03a2,
        [ a oc:Workflow ;
            dcterms:description "Systematic workflow for identifying and improving unclear interface text" ;
            oc:hasStep _:ref_077bdb8b0a77df2a,
                _:ref_6735af95184d6dc9,
                _:ref_6c2e9ba395f68430,
                _:ref_86420c43be3eda25,
                [ a oc:WorkflowStep ;
                    dcterms:description "Verify improvements pass five quality checks: comprehension, actionability, brevity, consistency, tone" ;
                    oc:expectedOutcome "Verified copy that meets all quality criteria" ;
                    oc:stepDependsOn _:ref_6735af95184d6dc9 ;
                    oc:stepId "verify" ] ;
            oc:workflowId "clarify-main" ;
            oc:workflowName "Improve UX Copy Clarity" ] ;
    oc:impartsKnowledge oc:kn_02fd6d7b,
        oc:kn_2fd6a0da,
        oc:kn_79f9a5b2,
        oc:kn_80833dae,
        oc:kn_92c9ea3a,
        oc:kn_a6cdbcf6,
        oc:kn_d1f5fb88,
        oc:kn_d4c5e8cd ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:DesignContextAvailable,
        oc:EnvironmentReady ;
    oc:resolvesIntent "enhance interface text clarity",
        "fix bad error messages",
        "improve microcopy and instructions",
        "improve unclear UX copy",
        "rewrite confusing labels" ;
    oc:yieldsState oc:ClarityVerified,
        oc:CopyImproved .

oc:kn_02fd6d7b a oc:FallbackStrategy,
        oc:KnowledgeNode ;
    oc:appliesToContext "When facing conflicting constraints like character limits" ;
    oc:directiveContent "When copy cannot be made perfectly clear due to constraints, prioritize: actionability (what to do) over completeness (all details), then brevity, then tone matching." ;
    oc:hasRationale "If users know what to do, the copy has served its primary purpose even if some detail is sacrificed." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2fd6a0da a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or reviewing any UX copy" ;
    oc:directiveContent "Never blame users in error messages — write 'This field is required' not 'You made an error'. Never use jargon without explanation, passive voice unnecessarily, or humor in error states." ;
    oc:hasRationale "Blaming users creates frustration and support tickets. Jargon and passive voice reduce comprehension. Humor in error states feels dismissive." ;
    oc:severityLevel "CRITICAL" .

oc:kn_79f9a5b2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before writing or rewriting any interface text" ;
    oc:directiveContent "Always consider: audience technical level, user mental state (stressed during errors, confident during success), character/space limits, and brand voice constraints." ;
    oc:hasRationale "Context determines what clear means — the same message needs different treatment for a stressed user vs a confident one." ;
    oc:severityLevel "HIGH" .

oc:kn_80833dae a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning any copy improvement" ;
    oc:directiveContent "Good UX writing is invisible — users should understand immediately without noticing the words. Every piece of copy should be specific, concise, active, human, helpful, and consistent." ;
    oc:hasRationale "When users notice the words, the copy has failed. Invisible copy lets users complete tasks without cognitive friction." ;
    oc:severityLevel "HIGH" .

oc:kn_92c9ea3a a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When improving error messages" ;
    oc:directiveContent "Error messages must: explain what went wrong in plain language, suggest how to fix it, include examples when helpful, and link to help if applicable. Never use raw error codes alone." ;
    oc:hasRationale "Users encountering errors are already frustrated — clear, actionable messages reduce that frustration and prevent support requests." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a6cdbcf6 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any copy improvement work" ;
    oc:directiveContent "Must invoke /frontend-design first for design principles and Context Gathering Protocol. If no design context exists, must run /teach-impeccable first. Additionally gather audience technical level and user mental state." ;
    oc:hasRationale "Without project design context and audience understanding, copy improvements may be inconsistent with existing patterns." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d1f5fb88 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "After generating copy improvements" ;
    oc:directiveContent "Every piece of improved copy should pass five checks: comprehension (understandable without context), actionability (users know what to do next), brevity (short as possible while clear), consistency (matches terminology elsewhere), and tone (appropriate for situation)." ;
    oc:hasRationale "These five dimensions cover the essential quality criteria for effective UX writing." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d4c5e8cd a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing form labels, navigation, and page content" ;
    oc:directiveContent "Never use placeholders as the only labels (they disappear when users type), never vary terminology for variety (pick one term and stick with it), and never repeat information (headers restating intros)." ;
    oc:hasRationale "These patterns cause user confusion — disappearing labels hide context, varied terms create ambiguity, and repetition wastes space." ;
    oc:severityLevel "HIGH" .

oc:req_a53625ec a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "frontend-design skill for design principles and Context Gathering Protocol" .

_:ref_024eaeac71c3af01 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 5 ;
    oc:itemText "**Assumptions**: Assuming user knowledge they don't have" .

_:ref_107d81e0ad78496a a oc:WorkflowStep ;
    dcterms:description "**Be human**: \"Oops, something went wrong\" not \"System error encountered\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_126dff7e604decd7 a oc:WorkflowStep ;
    dcterms:description "**Be active**: \"Save changes\" not \"Changes will be saved\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_2cb46ee288e02c8d a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 4 ;
    oc:itemText "What's the constraint? (Character limits? Space limitations?)" .

_:ref_338339b33010ee02 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "What's the user's mental state? (Stressed during error? Confident during success?)" .

_:ref_41fe8a793d7cce94 a oc:WorkflowStep ;
    dcterms:description "**Find clarity problems**:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem _:ref_024eaeac71c3af01,
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "**Jargon**: Technical terms users won't understand" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "**Ambiguity**: Multiple interpretations possible" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 7 ;
                    oc:itemText "**Tone mismatch**: Too formal, too casual, or inappropriate for situation" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 6 ;
                    oc:itemText "**Missing context**: Users don't know what to do or why" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 4 ;
                    oc:itemText "**Length**: Too wordy or too terse" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 3 ;
                    oc:itemText "**Passive voice**: \"Your file has been uploaded\" vs \"We uploaded your file\"" ] ] ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_6471c8d51fceb968 a oc:WorkflowStep ;
    dcterms:description "**Be concise**: Cut unnecessary words (but don't sacrifice clarity)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_8ea04a2fca96cfc9 a oc:BulletList ;
