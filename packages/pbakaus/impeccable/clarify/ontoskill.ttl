@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_clarify a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "clarify" ;
    skos:broader "UX writing and microcopy refinement skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/clarify" ;
    oc:contentHash "05338a7cc8864dc1236313b5c400c072c221ea039d0052de1a0f6e561bf31d3f" ;
    oc:differentia "systematically identifies and improves unclear interface text — error messages, labels, buttons, help text, empty states, and instructions — by applying clarity principles, audience awareness, and plain language conventions" ;
    oc:extends oc:skill_frontend_design ;
    oc:handlesFailure oc:InvalidInput,
        oc:MissingDesignContext ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Improve unclear UX copy, error messages, microcopy, labels, and instructions to make interfaces easier to understand. Use when the user mentions confusing text, unclear labels, bad error messages, hard-to-follow instructions, or wanting better UX writing." ;
    oc:hasName "clarify" ;
    oc:impartsKnowledge oc:kn_0572af3f,
        oc:kn_444f27dc,
        oc:kn_4ade824e,
        oc:kn_708560fb,
        oc:kn_d4a42855,
        oc:kn_ffb2230b ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextGathered ;
    oc:resolvesIntent "clarify interface text and instructions",
        "fix bad labels and microcopy",
        "improve UX writing quality",
        "improve unclear UX copy",
        "rewrite confusing error messages" ;
    oc:yieldsState oc:CopyClarified,
        oc:UXWritingImproved .

oc:kn_0572af3f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or evaluating any interface text" ;
    oc:directiveContent "Good UX writing is invisible: users should understand immediately without noticing the words. Every piece of copy should be specific, concise, active, human, helpful, and consistent. Write like explaining to a smart friend unfamiliar with the product." ;
    oc:hasRationale "Invisible writing reduces cognitive load and lets users complete tasks without friction from poorly chosen words" .

oc:kn_444f27dc a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When auditing an entire interface's copy quality" ;
    oc:directiveContent "Systematically improve copy across 9 areas: error messages, form labels, button/CTA text, help text/tooltips, empty states, success messages, loading states, confirmation dialogs, and navigation. Each area has distinct principles — e.g., errors must explain the problem and suggest a fix; CTAs must use active verb+noun." ;
    oc:hasRationale "Copy problems cluster by UI area and each area has different user expectations — a one-size-fits-all approach misses critical context-specific improvements" ;
    oc:severityLevel "MEDIUM" .

oc:kn_4ade824e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing form designs and interactive elements" ;
    oc:directiveContent "Never use placeholders as the only labels for form fields — they disappear when users type. Never use generic button text like 'OK' or 'Submit' when a specific action label like 'Save changes' is possible. Never vary terminology for variety's sake." ;
    oc:hasRationale "Placeholders-as-labels destroy context once users begin typing; generic buttons force users to re-read surrounding context to understand what will happen" ;
    oc:severityLevel "HIGH" .

oc:kn_708560fb a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing or reviewing any UX copy, especially error messages and validation feedback" ;
    oc:directiveContent "Never blame the user in error messages. Say 'This field is required' not 'You made an error'. Never use jargon without explanation, vague messages like 'Something went wrong', or humor in error states." ;
    oc:hasRationale "Blame-oriented or vague copy creates frustration, increases support tickets, and erodes user trust" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d4a42855 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, before beginning any copy improvement work" ;
    oc:directiveContent "Before improving copy, you must gather audience technical level, users' mental state in context, and invoke the design context gathering protocol. If no design context exists, run teach-impeccable first." ;
    oc:hasRationale "Effective UX writing depends entirely on understanding who the readers are and what emotional state they're in — copy that works for a calm expert fails for a stressed novice" ;
    oc:severityLevel "HIGH" .

oc:kn_ffb2230b a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing copy improvements, before delivering final output" ;
    oc:directiveContent "After improving copy, verify against 5 criteria: comprehension (understandable without context?), actionability (users know what to do next?), brevity (as short as possible while clear?), consistency (matches terminology elsewhere?), and tone (appropriate for situation?)." ;
    oc:hasRationale "Systematic validation catches regressions where improvements in one dimension (e.g., brevity) undermine another (e.g., clarity or consistency)" .

