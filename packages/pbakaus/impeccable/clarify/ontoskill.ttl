            oc:itemText "What's the action? (What do we want users to do?)" ] .

_:ref_96aa9688e943f3a2 a oc:WorkflowStep ;
    dcterms:description "**Be helpful**: Tell users what to do, not just what happened" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_acaf05555863cd86 a oc:WorkflowStep ;
    dcterms:description "**Be consistent**: Use same terms throughout (don't vary for variety)" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_6" ;
    oc:stepOrder 6 .

_:ref_fb2aff5a7a5b5894 a oc:WorkflowStep ;
    dcterms:description "**Be specific**: \"Enter email\" not \"Enter value\"" ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

