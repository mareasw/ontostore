oc:skill_pbakaus_impeccable_animate a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "animate" ;
    skos:broader "UI enhancement skill" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/animate" ;
    oc:contentHash "d13506dc8484ff6997493b4dfe40ef2e675e93f84579bf52e450b3024cae1ffd" ;
    oc:differentia "that adds purposeful animations, micro-interactions, and motion effects to improve usability and delight" ;
    oc:extends oc:skill_ontoskills_frontend_design ;
    oc:handlesFailure oc:AccessibilityViolation,
        oc:PerformanceDegradation ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Review a feature and enhance it with purposeful animations, micro-interactions, and motion effects that improve usability and delight. Use when the user mentions adding animation, transitions, micro-interactions, motion design, hover effects, or making the UI feel more alive." ;
    oc:hasName "animate" ;
    oc:hasRequirement oc:req_5b29dd75,
        oc:req_92cf6329,
        oc:req_c71e598e ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Analyze where motion would improve the experience:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "If any of these are unclear from the codebase, ask the user directly to clarify what you cannot infer." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**CRITICAL**: Respect `prefers-reduced-motion`. Always provide non-animated alternatives for users who need them." ],
                _:ref_bc42fdb4be015f86 ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Assess Animation Opportunities" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Invoke /frontend-design — it contains design principles, anti-patterns, and the **Context Gathering Protocol**. Follow the protocol before proceeding — if no design context exists yet, you MUST run /teach-impeccable first. Additionally gather: performance constraints." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "MANDATORY PREPARATION" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Use appropriate techniques for each animation:" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/* Prefer for simple, declarative animations */
- transitions for state changes
- @keyframes for complex sequences
- transform + opacity only (GPU-accelerated)
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 122-127" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "CSS Animations" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/* Use for complex, interactive animations */
- Web Animations API for programmatic control
- Framer Motion for React
- GSAP for complex sequences
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 130-135" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "JavaScript Animation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """/* Recommended - natural deceleration */
--ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);    /* Smooth, refined */
--ease-out-quint: cubic-bezier(0.22, 1, 0.36, 1);   /* Slightly snappier */
--ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);     /* Confident, decisive */

/* AVOID - feel dated and tacky */
/* bounce: cubic-bezier(0.34, 1.56, 0.64, 1); */
/* elastic: cubic-bezier(0.68, -0.6, 0.32, 1.6); */
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 4 ;
                            oc:sourceLocation "lines 108-117" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Easing curves (use these, not CSS defaults):**" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**100-150ms**: Instant feedback (button press, toggle)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**300-500ms**: Layout changes (accordion, modal)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**500-800ms**: Entrance animations (page load)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**200-300ms**: State changes (hover, menu open)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Durations by purpose:**" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "**Exit animations are faster than entrances.** Use ~75% of enter duration." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Timing & Easing" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "Animate everything—animation fatigue makes interfaces feel exhausting" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Animate without purpose—every animation needs a reason" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Ignore `prefers-reduced-motion`—this is an accessibility violation" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Use durations over 500ms for feedback—it feels laggy" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Animate layout properties (width, height, top, left)—use transform instead" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Use bounce or elastic easing curves—they feel dated and draw attention to the animation itself" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "Block interaction during animations unless intentional" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**NEVER**:" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """@media (prefers-reduced-motion: reduce) {
  * {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 1 ;
                            oc:sourceLocation "lines 144-152" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Accessibility" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Reduce paint**: Minimize repaints, use `contain` where appropriate" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**GPU acceleration**: Use `transform` and `opacity`, avoid layout properties" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Monitor FPS**: Ensure 60fps on target devices" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**will-change**: Add sparingly for known expensive animations" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Performance" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 5 ;
            oc:sectionTitle "Technical Implementation" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Feedback layer**: Which interactions need acknowledgment?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Delight layer**: Where can we surprise and delight?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Transition layer**: Which state changes need smoothing?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Hero moment**: What's the ONE signature animation? (Page load? Hero section? Key interaction?)" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**IMPORTANT**: One well-orchestrated experience beats scattered animations everywhere. Focus on high-impact moments." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Create a purposeful animation plan:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Plan Animation Strategy" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: animate
description: Review a feature and enhance it with purposeful animations, micro-interactions, and motion effects that improve usability and delight. Use when the user mentions adding animation, transitions, micro-interactions, motion design, hover effects, or making the UI feel more alive.
user-invocable: true
argument-hint: "[target]"
""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Analyze a feature and strategically add animations and micro-interactions that enhance understanding, provide feedback, and create delight." ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Appropriate timing**: Not too fast (jarring) or too slow (laggy)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 6 ;
                            oc:itemText "**Adds value**: Makes interface clearer or more delightful" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "**Doesn't block**: Users can interact during/after animations" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Reduced motion works**: Animations disabled or simplified appropriately" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Smooth at 60fps**: No jank on target devices" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Feels natural**: Easing curves feel organic, not robotic" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "Remember: Motion should enhance understanding and provide feedback, not just add decoration. Animate with purpose, respect performance constraints, and always consider accessibility. Great animation is invisible - it just makes everything feel right." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Test animations thoroughly:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 6 ;
            oc:sectionTitle "Verify Quality" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Add motion systematically across these categories:" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Easter eggs**: Hidden interactions for discovery" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Completed actions**: Confetti, check mark flourish, success celebrations" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Empty states**: Subtle floating animations on illustrations" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Contextual animation**: Weather effects, time-of-day themes, seasonal touches" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Delight Moments" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Toggle switches**: Smooth slide + color transition (200-300ms)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:hasChild [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Validation: Shake on error, check mark on success, smooth color transitions" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Input focus: Border color transition, slight scale or glow" ] ] ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Form interactions**:" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Checkboxes/radio**: Check mark animation, ripple effect" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:hasChild [ a oc:BulletList ;
                                            oc:blockType "bullet_list" ;
                                            oc:contentOrder 1 ;
                                            oc:hasItem [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 2 ;
                                                    oc:itemText "Click: Quick scale down then up (0.95 → 1), ripple effect" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 1 ;
                                                    oc:itemText "Hover: Subtle scale (1.02-1.05), color shift, shadow increase" ],
                                                [ a oc:BulletItem ;
                                                    oc:blockType "bullet_item" ;
                                                    oc:itemOrder 3 ;
                                                    oc:itemText "Loading: Spinner or pulse state" ] ] ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Button feedback**:" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Like/favorite**: Scale + rotation, particle effects, color transition" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Micro-interactions" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Scroll effects**: Parallax layers, sticky headers with state changes, scroll progress indicators" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Page transitions**: Crossfade between routes, shared element transitions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Carousel/slider**: Smooth transforms, snap points, momentum" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Tab switching**: Slide indicator, content fade/slide" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Navigation & Flow" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Show/hide**: Fade + slide (not instant), appropriate timing (200-300ms)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Success/error**: Color transitions, icon animations, gentle scale pulse" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Enable/disable**: Opacity transitions, cursor changes" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Loading states**: Skeleton screen fades, spinner animations, progress bars" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Expand/collapse**: Height transition with overflow handling, icon rotation" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "State Transitions" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Copy/paste**: Brief highlight flash on paste, \"copied\" confirmation" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Focus flow**: Highlight path through form or workflow" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Drag & drop**: Lift effect (shadow + scale), drop zone highlights, smooth repositioning" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Hover hints**: Tooltip fade-ins, cursor changes, element highlights" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Feedback & Guidance" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Content reveals**: Scroll-triggered animations using intersection observer" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Page load choreography**: Stagger element reveals (100-150ms delays), fade + slide combinations" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Modal/drawer entry**: Smooth slide + fade, backdrop fade, focus management" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Hero section**: Dramatic entrance for primary content (scale, parallax, or creative effects)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Entrance Animations" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Implement Animations" ] ;
    oc:hasWorkflow _:ref_bc42fdb4be015f86,
        [ a oc:Workflow ;
            dcterms:description "Systematic workflow for analyzing a feature and adding meaningful animations and micro-interactions" ;
            oc:hasStep _:ref_02c8a1e024ae8312,
                _:ref_647ce76cc4d28c4b,
                [ a oc:WorkflowStep ;
                    dcterms:description "Test for 60fps smoothness, natural easing, appropriate timing, reduced motion support, non-blocking interaction, and added value." ;
                    oc:expectedOutcome "All animations verified as smooth, accessible, and purposeful" ;
                    oc:stepDependsOn _:ref_647ce76cc4d28c4b ;
                    oc:stepId "verify" ],
                _:ref_b1d260fdb46f7e81,
                _:ref_ba2aa7ac27a884b7 ;
            oc:workflowId "animate-main" ;
            oc:workflowName "Add Purposeful Animations" ] ;
    oc:impartsKnowledge oc:kn_33d244ac,
        oc:kn_471c1537,
        oc:kn_6d2d6234,
        oc:kn_76b7fcab,
        oc:kn_79af0707,
        oc:kn_b6d275f8,
        oc:kn_c3f63f0b,
        oc:kn_d4891c7d ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextEstablished,
        oc:EnvironmentReady ;
    oc:resolvesIntent "add animations to UI",
        "add transitions and motion effects",
        "enhance interface with micro-interactions",
        "improve UI feel with hover effects",
        "make UI feel alive with motion design" ;
    oc:yieldsState oc:AccessibilityVerified,
        oc:AnimationsImplemented .

oc:kn_33d244ac a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting easing curves for any animation" ;
    oc:directiveContent "Never use bounce or elastic easing curves — they feel dated and draw attention to the animation itself. Use natural deceleration curves instead (ease-out-quart, ease-out-quint, ease-out-expo)." ;
    oc:hasRationale "Bounce/elastic curves make animations feel gimmicky and distract from the content rather than enhancing it." ;
    oc:severityLevel "HIGH" .

oc:kn_471c1537 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding whether to add an animation" ;
    oc:directiveContent "Every animation needs a purpose — feedback, guidance, relationship clarification, or delight. Never animate just for decoration." ;
    oc:hasRationale "Purposeless animation clutters the interface and creates cognitive noise. Great animation is invisible — it just makes everything feel right." ;
    oc:severityLevel "HIGH" .

oc:kn_6d2d6234 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning animation strategy" ;
    oc:directiveContent "One well-orchestrated experience beats scattered animations everywhere. Focus on high-impact moments: one hero moment, feedback layer, transition layer, and delight layer." ;
    oc:hasRationale "Animation fatigue makes interfaces feel exhausting. Purposeful restraint creates better UX than blanket animation." ;
    oc:severityLevel "HIGH" .

oc:kn_76b7fcab a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing CSS animations or transitions" ;
    oc:directiveContent "Never animate layout properties (width, height, top, left). Use transform and opacity instead for GPU-accelerated performance." ;
    oc:hasRationale "Animating layout properties triggers reflows and repaints, causing jank and poor frame rates. Transform and opacity are GPU-composited." ;
    oc:severityLevel "HIGH" .

oc:kn_79af0707 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting timing for micro-interactions and feedback" ;
    oc:directiveContent "Never use durations over 500ms for feedback animations — they feel laggy and unresponsive." ;
    oc:hasRationale "Feedback must feel instantaneous. Delays over 500ms break the perceived connection between action and response." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b6d275f8 a oc:KnowledgeNode,
        oc:PerformanceProfile ;
    oc:appliesToContext "When implementing animations on complex pages or mobile devices" ;
    oc:directiveContent "Ensure 60fps on target devices. Use will-change sparingly, minimize repaints with contain, and monitor frame rates." ;
    oc:hasRationale "Dropped frames create jank that is more noticeable than no animation at all. Performance budget matters for animation." ;
    oc:severityLevel "HIGH" .

oc:kn_c3f63f0b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing enter/exit animation pairs" ;
    oc:directiveContent "Exit animations must be faster than entrances — use ~75% of the enter duration." ;
    oc:hasRationale "Users want to move forward quickly. Faster exits maintain perceived responsiveness while entrances set context." ;
    oc:severityLevel "MEDIUM" .

oc:kn_d4891c7d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any animation" ;
    oc:directiveContent "Always respect prefers-reduced-motion. Provide non-animated alternatives or reduced animations for users who need them." ;
    oc:hasRationale "Ignoring reduced motion preferences is an accessibility violation that can cause discomfort or motion sickness for sensitive users." ;
    oc:severityLevel "CRITICAL" .

oc:req_5b29dd75 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "prefers-reduced-motion accessibility media query" .

oc:req_92cf6329 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "CSS animations, transitions, and keyframes" .

oc:req_c71e598e a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "JavaScript animation libraries (Framer Motion, GSAP, Web Animations API)" .

_:ref_0c479ff7017096ad a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "What's the performance budget? (Mobile-first? Complex page?)" .

_:ref_1e3cccdbaa74f1a1 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 5 ;
    oc:itemText "**Missed guidance**: Opportunities to direct attention or explain behavior" .

_:ref_4a113d5a3792f101 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
    oc:itemText "**Missing feedback**: Actions without visual acknowledgment (button clicks, form submission, etc.)" .

_:ref_52868e333d38f00c a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 3 ;
    oc:itemText "Who's the audience? (Motion-sensitive users? Power users who want speed?)" .

_:ref_71531dfc4f5925fc a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem _:ref_0c479ff7017096ad,
        _:ref_52868e333d38f00c,
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 4 ;
            oc:itemText "What matters most? (One hero animation vs many micro-interactions?)" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 1 ;
            oc:itemText "What's the personality? (Playful vs serious, energetic vs calm)" ] .

_:ref_83121f94701ae8f1 a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem _:ref_1e3cccdbaa74f1a1,
        _:ref_4a113d5a3792f101,
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 2 ;
            oc:itemText "**Jarring transitions**: Instant state changes that feel abrupt (show/hide, page loads, route changes)" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 4 ;
            oc:itemText "**Lack of delight**: Functional but joyless interactions" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 3 ;
            oc:itemText "**Unclear relationships**: Spatial or hierarchical relationships that aren't obvious" ] .

