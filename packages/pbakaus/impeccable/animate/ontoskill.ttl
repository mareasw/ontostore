@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_animate a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "animate" ;
    skos:broader "UI Enhancement Skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/animate" ;
    oc:contentHash "d13506dc8484ff6997493b4dfe40ef2e675e93f84579bf52e450b3024cae1ffd" ;
    oc:differentia "Strategically adds purposeful animations, micro-interactions, and motion effects to frontend features to improve usability, feedback, and delight" ;
    oc:extends oc:skill_frontend_design ;
    oc:handlesFailure oc:PerformanceThresholdExceeded,
        oc:ReducedMotionViolation ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Review a feature and enhance it with purposeful animations, micro-interactions, and motion effects that improve usability and delight. Use when the user mentions adding animation, transitions, micro-interactions, motion design, hover effects, or making the UI feel more alive." ;
    oc:hasName "animate" ;
    oc:impartsKnowledge oc:kn_0922d251,
        oc:kn_184ed4f7,
        oc:kn_21ec0cbf,
        oc:kn_50c3bd3a,
        oc:kn_81e55c96,
        oc:kn_96fd085c,
        oc:kn_d8a65e8d ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextEstablished,
        oc:EnvironmentReady ;
    oc:resolvesIntent "add animations to UI",
        "add entrance animations and state transitions",
        "add hover effects and transitions",
        "create micro-interactions",
        "improve motion design",
        "make UI feel more alive" ;
    oc:yieldsState oc:AccessibilityCompliant,
        oc:AnimationsImplemented .

oc:kn_0922d251 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any animation" ;
    oc:directiveContent "Always respect prefers-reduced-motion media query and provide non-animated alternatives. Every animation must include a reduced-motion fallback that either disables or simplifies motion." ;
    oc:hasRationale "Ignoring reduced-motion preferences is an accessibility violation that can cause discomfort or motion sickness for sensitive users" ;
    oc:severityLevel "CRITICAL" .

oc:kn_184ed4f7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning animation strategy before implementation" ;
    oc:directiveContent "One well-orchestrated hero animation experience beats scattered animations everywhere. Focus on high-impact moments and use a layered strategy: hero moment, feedback layer, transition layer, and delight layer." ;
    oc:hasRationale "Animation fatigue makes interfaces feel exhausting; purposeful restraint creates better perceived quality than blanket animation coverage" ;
    oc:severityLevel "HIGH" .

oc:kn_21ec0cbf a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding what to animate" ;
    oc:directiveContent "Never animate without purpose—every animation needs a reason. Never animate everything across the entire interface. Never block user interaction during animations unless intentionally required." ;
    oc:hasRationale "Purposeless animation is decoration that distracts; animation fatigue from over-animation makes interfaces feel exhausting; blocking interaction frustrates users" ;
    oc:severityLevel "MEDIUM" .

oc:kn_50c3bd3a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting animation timing" ;
    oc:directiveContent "Use specific duration ranges by purpose: 100-150ms for instant feedback, 200-300ms for state changes, 300-500ms for layout changes, 500-800ms for entrance animations. Exit animations should use ~75% of entrance duration. Never exceed 500ms for feedback." ;
    oc:hasRationale "Correct timing feels natural; too fast is jarring, too slow feels laggy. These ranges match human perception thresholds for different interaction types" ;
    oc:severityLevel "MEDIUM" .

oc:kn_81e55c96 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any animation technically" ;
    oc:directiveContent "Use GPU-accelerated properties (transform and opacity) exclusively for animations. Add will-change sparingly only for known expensive animations. Monitor and ensure 60fps on target devices." ;
    oc:hasRationale "Non-GPU-accelerated animations trigger layout recalculations and repaints, causing jank and poor perceived performance" ;
    oc:severityLevel "HIGH" .

oc:kn_96fd085c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting easing curves and CSS properties for animation" ;
    oc:directiveContent "Never use bounce or elastic easing curves—they feel dated and draw attention to the animation itself rather than the content. Avoid animating layout properties (width, height, top, left); use transform and opacity instead." ;
    oc:hasRationale "Bounce/elastic easings feel unprofessional and layout property animations trigger expensive reflows instead of GPU-accelerated compositing" ;
    oc:severityLevel "HIGH" .

oc:kn_d8a65e8d a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning animation work on any feature" ;
    oc:directiveContent "Before implementing animations, gather: design context and principles via /frontend-design, performance constraints of the target, the personality of the product, the audience's motion sensitivity, and what matters most (hero animation vs many micro-interactions)." ;
    oc:hasRationale "Without understanding context, animations may clash with the product's personality, exceed performance budgets, or alienate motion-sensitive users" ;
    oc:severityLevel "HIGH" .

