@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_arrange a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "arrange" ;
    skos:broader "Layout refinement skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/arrange" ;
    oc:contentHash "c2d74da3c3e734d18913488d02ab3e93cbe1e06add7d7bbcbd822175d3d4d642" ;
    oc:dependsOnSkill oc:skill_teach_impeccable ;
    oc:differentia "Improves spacing, visual rhythm, and hierarchical composition in frontend interfaces by assessing current layout weaknesses and applying systematic spatial design principles" ;
    oc:extends oc:skill_frontend_design ;
    oc:handlesFailure oc:InvalidInput ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "frontend-design" ;
    oc:hasDescription "Improve layout, spacing, and visual rhythm. Fixes monotonous grids, inconsistent spacing, and weak visual hierarchy. Use when the user mentions layout feeling off, spacing issues, visual hierarchy, crowded UI, alignment problems, or wanting better composition." ;
    oc:hasName "arrange" ;
    oc:impartsKnowledge oc:kn_3887f450,
        oc:kn_3c2a9787,
        oc:kn_61316bab,
        oc:kn_6857cc04,
        oc:kn_6eb0b5cd,
        oc:kn_ffa58217 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "establish consistent spacing system",
        "fix alignment problems",
        "fix visual hierarchy",
        "improve composition and visual rhythm",
        "improve layout and spacing",
        "resolve crowded or monotonous UI" ;
    oc:yieldsState oc:LayoutOptimized .

oc:kn_3887f450 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After implementing layout improvements" ;
    oc:directiveContent "Apply the squint test (blur vision metaphorically) to verify that primary, secondary, and groupings remain identifiable. Check that hierarchy is obvious within 2 seconds, spacing is consistent, and layout adapts across screen sizes." ;
    oc:hasRationale "The squint test is the gold standard for verifying visual hierarchy — if structure survives blurring, the spatial design is sound." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3c2a9787 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing depth, elevation, and stacking contexts" ;
    oc:directiveContent "Build a semantic z-index scale (dropdown → sticky → modal-backdrop → modal → toast → tooltip) and a consistent shadow scale (sm → md → lg → xl). Never use arbitrary z-index values like 999 or 9999." ;
    oc:hasRationale "Arbitrary z-index values create impossible-to-debug stacking conflicts; semantic scales ensure predictable layering." ;
    oc:severityLevel "MEDIUM" .

oc:kn_61316bab a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning or refining spatial composition" ;
    oc:directiveContent "Create visual rhythm through alternating tight grouping (8-12px between siblings) and generous separation (48-96px between sections). Use the fewest dimensions needed for hierarchy — space and weight alone can suffice." ;
    oc:hasRationale "Rhythm transforms generic layouts into intentional designs; minimal hierarchy dimensions create sophistication without over-decoration." ;
    oc:severityLevel "HIGH" .

oc:kn_6857cc04 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When establishing or modifying any spacing system" ;
    oc:directiveContent "Never use arbitrary spacing values outside a defined scale, make all spacing equal, or wrap everything in cards — variety creates hierarchy and not everything needs a container." ;
    oc:hasRationale "Arbitrary spacing destroys visual rhythm; uniform spacing eliminates hierarchy; excessive card wrapping adds noise without structural benefit." ;
    oc:severityLevel "HIGH" .

oc:kn_6eb0b5cd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between CSS layout mechanisms" ;
    oc:directiveContent "Use Flexbox for 1D layouts (rows, nav bars, button groups) and Grid for 2D layouts (dashboards, data-dense interfaces). Default to the simplest tool for the job." ;
    oc:hasRationale "Over-engineering with Grid when Flexbox suffices creates unnecessary complexity; using Flexbox for 2D needs leads to fragile hacks." ;
    oc:severityLevel "MEDIUM" .

oc:kn_ffa58217 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any layout assessment or improvement" ;
    oc:directiveContent "Invoke frontend-design skill first to load design principles and the Context Gathering Protocol. If no design context exists, run teach-impeccable before proceeding." ;
    oc:hasRationale "Layout improvements must be grounded in the project's established design context and principles to be coherent." ;
    oc:severityLevel "CRITICAL" .

