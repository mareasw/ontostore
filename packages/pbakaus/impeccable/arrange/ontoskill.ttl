@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_arrange a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "arrange" ;
    skos:broader "UI design refinement skill" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/arrange" ;
    oc:contentHash "c2d74da3c3e734d18913488d02ab3e93cbe1e06add7d7bbcbd822175d3d4d642" ;
    oc:dependsOnSkill oc:skill_ontoskills_frontend_design ;
    oc:differentia "improves layout, spacing, visual rhythm, and composition by applying systematic spatial design principles" ;
    oc:handlesFailure oc:LayoutUnchanged,
        oc:NoDesignContext ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "design" ;
    oc:hasDescription "Improve layout, spacing, and visual rhythm. Fixes monotonous grids, inconsistent spacing, and weak visual hierarchy. Use when the user mentions layout feeling off, spacing issues, visual hierarchy, crowded UI, alignment problems, or wanting better composition." ;
    oc:hasName "arrange" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Remember: Space is the most underused design tool. A layout with the right rhythm and hierarchy can make even simple content feel polished and intentional." ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 1 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Rhythm**: Does the page have a satisfying beat of tight and generous spacing?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Breathing room**: Does the layout feel comfortable, not cramped or wasteful?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Squint test**: Can you identify primary, secondary, and groupings with blurred vision?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 6 ;
                            oc:itemText "**Responsiveness**: Does the layout adapt gracefully across screen sizes?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Hierarchy**: Is the most important content obvious within 2 seconds?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "**Consistency**: Is the spacing system applied uniformly?" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 5 ;
            oc:sectionTitle "Verify Layout Improvements" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Consult the [spatial design reference](reference/spatial-design.md) from the frontend-design skill for detailed guidance on grids, rhythm, and container queries." ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 3 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Spacing system**: Use a consistent scale — whether that's a framework's built-in scale (e.g., Tailwind), rem-based tokens, or a custom system. The specific values matter less than consistency." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Hierarchy strategy**: How will space communicate importance?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Layout approach**: What structure fits the content? Flex for 1D, Grid for 2D, named areas for complex page layouts." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Rhythm**: Where should spacing be tight vs generous?" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Create a systematic plan:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Plan Layout Improvements" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "**NEVER**:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 8 ;
                            oc:itemText "Default to CSS Grid when Flexbox would be simpler — use the simplest tool for the job" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Nest cards inside cards — use spacing and dividers for hierarchy within" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Wrap everything in cards — not everything needs a container" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "Use identical card grids everywhere (icon + heading + text, repeated)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 6 ;
                            oc:itemText "Center everything — left-aligned with asymmetry feels more designed" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Use arbitrary spacing values outside your scale" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 7 ;
                            oc:itemText "Default to the hero metric layout (big number, small label, stats, gradient) as a template. If showing real user data, a prominent metric can work — but it should display actual data, not decorative numbers." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 9 ;
                            oc:itemText "Use arbitrary z-index values (999, 9999) — build a semantic scale" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Make all spacing equal — variety creates hierarchy" ] ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Create a semantic z-index scale (dropdown → sticky → modal-backdrop → modal → toast → tooltip)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Use elevation to reinforce hierarchy, not as decoration" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Build a consistent shadow scale (sm → md → lg → xl) — shadows should be subtle" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Manage Depth & Elevation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Tight grouping** for related elements (8-12px between siblings)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Varied spacing** within sections — not every row needs the same gap" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Asymmetric compositions** — break the predictable centered-content pattern when it makes sense" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Generous separation** between distinct sections (48-96px)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Create Visual Rhythm" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "If an icon looks visually off-center despite being geometrically centered, nudge it — but only if you're confident it actually looks wrong. Don't adjust speculatively." ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Optical Adjustments" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Use `gap` for sibling spacing instead of margins — eliminates margin collapse hacks" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Name tokens semantically if using custom properties: `--space-xs` through `--space-xl`, not `--spacing-8`" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Use a consistent spacing scale — framework scales (Tailwind, etc.), rem-based tokens, or a custom scale all work. What matters is that values come from a defined set, not arbitrary numbers." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Apply `clamp()` for fluid spacing that breathes on larger screens" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Establish a Spacing System" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Use named grid areas (`grid-template-areas`) for complex page layouts — redefine at breakpoints." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Use `repeat(auto-fit, minmax(280px, 1fr))` for responsive grids without breakpoints." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Use Grid for 2D layouts**: Page-level structure, dashboards, data-dense interfaces, anything where rows AND columns need coordinated control." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Don't default to Grid** when Flexbox with `flex-wrap` would be simpler and more flexible." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Use Flexbox for 1D layouts**: Rows of items, nav bars, button groups, card contents, most component internals. Flex is simpler and more appropriate for the majority of layout tasks." ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Choose the Right Layout Tool" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Use the fewest dimensions needed for clear hierarchy. Space alone can be enough — generous whitespace around an element draws the eye. Some of the most sophisticated designs achieve rhythm with just space and weight. Add color or size contrast only when simpler means aren't sufficient." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Create clear content groupings through proximity and separation." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Be aware of reading flow — in LTR languages, the eye naturally scans top-left to bottom-right, but primary action placement depends on context (e.g., bottom-right in dialogs, top in navigation)." ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Strengthen Visual Hierarchy" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Vary card sizes, span columns, or mix cards with non-card content to break repetition" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Use cards only when content is truly distinct and actionable — never nest cards inside cards" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Don't default to card grids for everything — spacing and alignment create visual grouping naturally" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Break Card Grid Monotony" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Improve Layout Systematically" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Invoke /frontend-design — it contains design principles, anti-patterns, and the **Context Gathering Protocol**. Follow the protocol before proceeding — if no design context exists yet, you MUST run /teach-impeccable first." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "MANDATORY PREPARATION" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Assess and improve layout and spacing that feels monotonous, crowded, or structurally weak — turning generic arrangements into intentional, rhythmic compositions." ],
                [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: arrange
description: Improve layout, spacing, and visual rhythm. Fixes monotonous grids, inconsistent spacing, and weak visual hierarchy. Use when the user mentions layout feeling off, spacing issues, visual hierarchy, crowded UI, alignment problems, or wanting better composition.
user-invocable: true
argument-hint: "[target]"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**CRITICAL**: Layout problems are often the root cause of interfaces feeling \"off\" even when colors and fonts are fine. Space is a design material — use it with intention." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Analyze what's weak about the current spatial design:" ],
                _:ref_7ca5c385391d911e ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Assess Current Layout" ] ;
    oc:hasWorkflow _:ref_7ca5c385391d911e ;
    oc:impartsKnowledge oc:kn_02dfa69f,
        oc:kn_09c665b2,
        oc:kn_149207e5,
        oc:kn_3bc86da3,
        oc:kn_5de8285e,
        oc:kn_714496b2,
        oc:kn_8ea1cddb,
        oc:kn_91baeca3,
        oc:kn_da5e2298,
        oc:kn_f2179001,
        oc:kn_f77ae57b ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextReady ;
    oc:resolvesIntent "break monotonous grid patterns",
        "fix crowded or cramped UI",
        "fix visual hierarchy issues",
        "improve layout and spacing",
        "improve visual rhythm and composition",
        "resolve alignment problems" ;
    oc:yieldsState oc:LayoutImproved,
        oc:SpacingSystemEstablished .

oc:kn_02dfa69f a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When improving any layout" ;
    oc:directiveContent "Never use arbitrary spacing values outside a defined scale, make all spacing equal, or default to card grids for everything. Avoid nesting cards inside cards, centering everything, using identical card grids everywhere, and using arbitrary z-index values." ;
    oc:hasRationale "These patterns produce monotonous, generic-feeling interfaces that lack visual hierarchy and intentional rhythm" ;
    oc:severityLevel "HIGH" .

oc:kn_09c665b2 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Full arrange skill execution" ;
    oc:directiveContent "1. Invoke /frontend-design and follow Context Gathering Protocol (run /teach-impeccable if no context exists). 2. Assess current layout across 5 dimensions: spacing, visual hierarchy, grid/structure, rhythm/variety, density. 3. Plan improvements: define spacing scale, hierarchy strategy, layout approach (Flex vs Grid), rhythm pattern. 4. Implement: establish spacing tokens, create visual rhythm (tight 8-12px, generous 48-96px), choose layout tools, break card monotony, manage z-index/shadow scales. 5. Verify with squint test, rhythm check, hierarchy test, breathing room, consistency, and responsiveness." ;
    oc:stepOrder 1 .

oc:kn_149207e5 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing between CSS layout tools" ;
    oc:directiveContent "Use Flexbox for 1D layouts (rows, nav bars, button groups) and Grid for 2D layouts (page structure, dashboards). Don't default to Grid when Flexbox with flex-wrap would be simpler." ;
    oc:hasRationale "Using the simplest tool for the job keeps CSS maintainable and predictable" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3bc86da3 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when working with layout" ;
    oc:directiveContent "Space is a design material — layout problems are often the root cause of interfaces feeling 'off' even when colors and fonts are fine. Spacing values must come from a defined set, not arbitrary numbers." ;
    oc:hasRationale "Consistency in spacing is more important than the specific values chosen" ;
    oc:severityLevel "CRITICAL" .

oc:kn_5de8285e a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After making layout changes" ;
    oc:directiveContent "Verify improvements with: squint test (can you identify hierarchy with blurred vision?), 2-second rule (most important content obvious within 2 seconds), rhythm check (satisfying beat of tight/generous spacing), and graceful adaptation across screen sizes." ;
    oc:hasRationale "These quick checks catch the most common layout failures without requiring detailed visual review" ;
    oc:severityLevel "MEDIUM" .

oc:kn_714496b2 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When executing the arrange skill" ;
    oc:directiveContent "1. Assess current layout (spacing, hierarchy, grid, rhythm, density) → 2. Plan improvements (spacing system, hierarchy strategy, layout approach, rhythm) → 3. Improve systematically → 4. Verify with squint test and rhythm checks" ;
    oc:hasRationale "Systematic approach prevents random tweaks and ensures coherent, intentional layout improvements" .

oc:kn_8ea1cddb a oc:CodePattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing spacing systems" ;
    oc:codeLanguage "css" ;
    oc:directiveContent "Use `gap` for sibling spacing instead of margins. Apply `clamp()` for fluid spacing. Use `repeat(auto-fit, minmax(280px, 1fr))` for responsive grids without breakpoints. Name tokens semantically: `--space-xs` through `--space-xl`." ;
    oc:hasRationale "Modern CSS properties eliminate common hacks and produce more maintainable layout code" .

oc:kn_91baeca3 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When establishing visual hierarchy" ;
    oc:directiveContent "Use the fewest dimensions needed for clear hierarchy. Space alone can be enough — generous whitespace around an element draws the eye. Add color or size contrast only when simpler means aren't sufficient." ;
    oc:hasRationale "Sophisticated designs achieve rhythm with just space and weight; over-decorating signals weak spatial design" ;
    oc:severityLevel "HIGH" .

oc:kn_da5e2298 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When presenting layout analysis and changes to user" ;
    oc:directiveContent """## Layout Assessment
- **Spacing**: {consistent_or_arbitrary} — {observations}
- **Visual Hierarchy**: {clear_or_weak} — {observations}
- **Grid & Structure**: {structured_or_random} — {observations}
- **Rhythm & Variety**: {dynamic_or_monotonous} — {observations}
- **Density**: {appropriate_or_extreme} — {observations}

## Improvements Applied
- **Spacing System**: {scale_description}
- **Layout Approach**: {flex_or_grid_reasoning}
- **Hierarchy Strategy**: {how_space_communicates_importance}
- **Rhythm**: {tight_vs_generous_pattern}""" ;
    oc:templateVariables "appropriate_or_extreme",
        "clear_or_weak",
        "consistent_or_arbitrary",
        "dynamic_or_monotonous",
        "flex_or_grid_reasoning",
        "how_space_communicates_importance",
        "observations",
        "scale_description",
        "structured_or_random",
        "tight_vs_generous_pattern" .

oc:kn_f2179001 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When auditing spacing systems" ;
    oc:directiveContent "Equal spacing everywhere produces no visual rhythm — variety in spacing creates hierarchy. Tight grouping (8-12px) for related elements, generous separation (48-96px) between distinct sections." ;
    oc:hasRationale "Monotonous spacing is one of the most common layout problems and makes interfaces feel generic" ;
    oc:severityLevel "HIGH" .

oc:kn_f77ae57b a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before starting layout assessment" ;
    oc:directiveContent "Must invoke /frontend-design skill first for design principles and Context Gathering Protocol. If no design context exists, must run /teach-impeccable before proceeding." .

_:ref_1028fcff9ec21299 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "Is hierarchy achieved effectively? (Space and weight alone can be enough — but is the current approach working?)" .

_:ref_14dd84a84b4cdc7e a oc:WorkflowStep ;
    dcterms:description "**Rhythm & variety**:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "Does the layout have visual rhythm? (Alternating tight/generous spacing)" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 3 ;
                    oc:itemText "Are there intentional moments of surprise or emphasis?" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "Is every section structured the same way? (Monotonous repetition)" ] ] ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_1f24b3d739fe9d0e a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "Are identical card grids used everywhere? (Icon + heading + text, repeated endlessly)" .

_:ref_2706f9221002cb83 a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem _:ref_1f24b3d739fe9d0e,
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 3 ;
            oc:itemText "Is everything centered? (Left-aligned with asymmetric layouts feels more designed, but not a hard and fast rule)" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 1 ;
            oc:itemText "Is there a clear underlying structure, or does the layout feel random?" ] .

_:ref_363add5111e0f908 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
    oc:itemText "Is spacing consistent or arbitrary? (Random padding/margin values)" .

_:ref_45413d15c63e32fb a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "Is the layout too sparse? (Excessive whitespace without purpose)" .

_:ref_4a5fa67d93d51d1c a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 3 ;
    oc:itemText "Does whitespace guide the eye to what matters?" .

_:ref_553c2d8092983080 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 3 ;
    oc:itemText "Are related elements grouped tightly, with generous space between groups?" .

_:ref_5bbd090691298196 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "Is all spacing the same? (Equal padding everywhere = no rhythm)" .

_:ref_5c5a53f8104e63fe a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem _:ref_45413d15c63e32fb,
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 3 ;
            oc:itemText "Does density match the content type? (Data-dense UIs need tighter spacing; marketing pages need more air)" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 1 ;
            oc:itemText "Is the layout too cramped? (Not enough breathing room)" ] .

_:ref_5e80908da8770c52 a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem _:ref_363add5111e0f908,
