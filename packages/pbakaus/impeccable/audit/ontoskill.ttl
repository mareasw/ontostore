@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_audit a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "audit" ;
    skos:broader "Quality audit framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/audit" ;
    oc:contentHash "8aba3733c04570e3821aaccfd8942cdeb004fdf9df0f4e00e57dcf7c7821ea68" ;
    oc:dependsOnSkill oc:skill_frontend_design ;
    oc:differentia "Scores frontend code across 5 dimensions (accessibility, performance, theming, responsive design, anti-patterns) on a 0-20 scale with P0-P3 severity ratings and produces an actionable remediation plan" ;
    oc:handlesFailure oc:InsufficientCodeAccess,
        oc:MissingDesignContext ;
    oc:hasArgumentHint "[area (feature, page, component...)]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Run technical quality checks across accessibility, performance, theming, responsive design, and anti-patterns. Generates a scored report with P0-P3 severity ratings and actionable plan. Use when the user wants an accessibility check, performance audit, or technical quality review." ;
    oc:hasName "audit" ;
    oc:impartsKnowledge oc:kn_284edc40,
        oc:kn_396dc946,
        oc:kn_3b447caf,
        oc:kn_424be14f,
        oc:kn_aff1ee8e,
        oc:kn_f03a5cde,
        oc:kn_f043d047,
        oc:kn_f98a2fec ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:CodebaseAccessible,
        oc:DesignContextLoaded ;
    oc:resolvesIntent "assess responsive design quality",
        "audit accessibility of frontend code",
        "check for anti-patterns and AI slop in code",
        "generate scored quality report for frontend",
        "review technical quality of UI implementation",
        "run performance audit on web interface" ;
    oc:yieldsState oc:AuditReportGenerated,
        oc:QualityScoreCalculated .

oc:kn_284edc40 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Throughout the entire audit process" ;
    oc:directiveContent "This skill documents issues only — never fix them. Produce findings for other commands to address." ;
    oc:hasRationale "Maintaining separation between auditing and fixing ensures the report remains objective, complete, and unpolluted by partial fixes applied mid-analysis." ;
    oc:severityLevel "HIGH" .

oc:kn_396dc946 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning the report generation phase" ;
    oc:directiveContent "Start with the Anti-Patterns verdict — determine if the design looks AI-generated before diving into other dimensions. Be brutally honest about AI slop tells." ;
    oc:hasRationale "AI-generated design patterns (gradient text, glassmorphism, hero metrics, card grids) are a systemic quality problem that colors the interpretation of all other findings. Addressing this first sets the right context." ;
    oc:severityLevel "MEDIUM" .

oc:kn_3b447caf a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before every audit execution" ;
    oc:directiveContent "Before auditing, invoke /frontend-design to load design principles and anti-patterns. If no design context exists, run /teach-impeccable first to establish project design standards." ;
    oc:hasRationale "The audit must be calibrated against the project's established design system and principles to produce meaningful, contextual results rather than generic feedback." ;
    oc:severityLevel "CRITICAL" .

oc:kn_424be14f a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When documenting detailed findings" ;
    oc:directiveContent "Tag every issue with P0 (Blocking — prevents task completion), P1 (Major — WCAG AA violation or significant difficulty), P2 (Minor — annoyance with workaround), or P3 (Polish — nice-to-fix). Include location, category, impact, WCAG standard reference, recommendation, and suggested remediation command." ;
    oc:hasRationale "Structured, severity-tagged findings enable teams to triage effectively and route issues to the correct remediation skill without ambiguity." ;
    oc:severityLevel "MEDIUM" .

oc:kn_aff1ee8e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing audit findings and recommendations" ;
    oc:directiveContent "Never report issues without explaining impact, provide generic recommendations, skip positive findings, assign everything as P0, or report unverified false positives." ;
    oc:hasRationale "Audits without impact explanations are unactionable. Without positive findings, teams lose morale. Without severity discipline, nothing gets prioritized. Unverified false positives destroy trust in the audit process." ;
    oc:severityLevel "HIGH" .

oc:kn_f03a5cde a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When analyzing findings for the Patterns & Systemic Issues section" ;
    oc:directiveContent "Identify systemic recurring patterns (e.g., hard-coded colors across 15+ components, consistently undersized touch targets) rather than treating each issue in isolation." ;
    oc:hasRationale "Systemic issues reveal architectural gaps that, when fixed, resolve dozens of individual issues at once — far more impactful than fixing symptoms one at a time." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f043d047 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When generating the Recommended Actions section" ;
    oc:directiveContent "Map each finding to the most appropriate remediation command from the approved skill set, prioritize by severity (P0 first), and always end with /polish as the final recommended step if any fixes were suggested." ;
    oc:hasRationale "Providing specific command mappings creates a clear, executable remediation path rather than leaving the user to figure out what to do next." ;
    oc:severityLevel "MEDIUM" .

oc:kn_f98a2fec a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the Audit Health Score" ;
    oc:directiveContent "Score each of the 5 dimensions (Accessibility, Performance, Theming, Responsive Design, Anti-Patterns) on a 0-4 scale using the defined rubric criteria, yielding a total score out of 20 with rating bands." ;
    oc:hasRationale "A standardized 0-20 scoring system with defined rubrics ensures consistent, comparable results across audits and prevents subjective or inconsistent evaluations." ;
    oc:severityLevel "HIGH" .

