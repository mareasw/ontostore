@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_audit a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "audit" ;
    skos:broader "Quality audit framework" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/audit" ;
    oc:contentHash "8aba3733c04570e3821aaccfd8942cdeb004fdf9df0f4e00e57dcf7c7821ea68" ;
    oc:dependsOnSkill oc:skill_ontoskills_frontend_design ;
    oc:differentia "Scores frontend implementations across 5 measurable dimensions (Accessibility, Performance, Theming, Responsive Design, Anti-Patterns) on a 0-4 scale each, producing a P0-P3 severity-tagged report with actionable remediation commands" ;
    oc:handlesFailure oc:MissingDesignContext,
        oc:NoCodeToAudit ;
    oc:hasArgumentHint "[area (feature, page, component...)]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Run technical quality checks across accessibility, performance, theming, responsive design, and anti-patterns. Generates a scored report with P0-P3 severity ratings and actionable plan. Use when the user wants an accessibility check, performance audit, or technical quality review." ;
    oc:hasName "audit" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "List recommended commands in priority order (P0 first, then P1, then P2):" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent "**IMPORTANT**: Be thorough but actionable. Too many P3 issues creates noise. Focus on what actually matters." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 7 ;
                    oc:textContent "**NEVER**:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**Rules**: Only recommend commands from: /animate, /quieter, /optimize, /adapt, /clarify, /distill, /delight, /onboard, /normalize, /audit, /harden, /polish, /extract, /bolder, /arrange, /typeset, /critique, /colorize, /overdrive. Map findings to the most appropriate command. End with `/polish` as the final step if any fixes were recommended." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "After presenting the summary, tell the user:" ],
                _:ref_a44bc561be84e846,
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 9 ;
                    oc:textContent "Remember: You're a technical quality auditor. Document systematically, prioritize ruthlessly, cite specific code locations, and provide clear paths to improvement." ],
                [ a oc:BlockQuote ;
                    oc:blockType "blockquote" ;
                    oc:contentOrder 5 ;
                    oc:quoteContent """You can ask me to run these one at a time, all at once, or in any order you prefer.

Re-run `/audit` after fixes to see your score improve.""" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 8 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Report issues without explaining impact (why does this matter?)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "Report false positives without verification" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Skip positive findings (celebrate what works)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Provide generic recommendations (be specific and actionable)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Forget to prioritize (everything can't be P0)" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Recommended Actions" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "This is a code-level audit, not a design critique. Check what's measurable and verifiable in the implementation." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Invoke /frontend-design — it contains design principles, anti-patterns, and the **Context Gathering Protocol**. Follow the protocol before proceeding — if no design context exists yet, you MUST run /teach-impeccable first." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Run systematic **technical** quality checks and generate a comprehensive report. Don't fix issues — document them for other commands to address." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "MANDATORY PREPARATION" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: audit
description: Run technical quality checks across accessibility, performance, theming, responsive design, and anti-patterns. Generates a scored report with P0-P3 severity ratings and actionable plan. Use when the user wants an accessibility check, performance audit, or technical quality review.
user-invocable: true
argument-hint: "[area (feature, page, component...)]"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Run comprehensive checks across 5 dimensions. Score each dimension 0-4 using the criteria below." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Check for**:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Contrast issues**: Text contrast ratios < 4.5:1 (or 7:1 for AAA)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Keyboard navigation**: Missing focus indicators, illogical tab order, keyboard traps" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Missing ARIA**: Interactive elements without proper roles, labels, or states" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Form issues**: Inputs without labels, poor error messaging, missing required indicators" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Alt text**: Missing or poor image descriptions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Semantic HTML**: Improper heading hierarchy, missing landmarks, divs instead of buttons" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Score 0-4**: 0=Inaccessible (fails WCAG A), 1=Major gaps (few ARIA labels, no keyboard nav), 2=Partial (some a11y effort, significant gaps), 3=Good (WCAG AA mostly met, minor gaps), 4=Excellent (WCAG AA fully met, approaches AAA)" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "1. Accessibility (A11y)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Check for**:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Hard-coded colors**: Colors not using design tokens" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Theme switching issues**: Values that don't update on theme change" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Inconsistent tokens**: Using wrong tokens, mixing token types" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Broken dark mode**: Missing dark mode variants, poor contrast in dark theme" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Score 0-4**: 0=No theming (hard-coded everything), 1=Minimal tokens (mostly hard-coded), 2=Partial (tokens exist but inconsistently used), 3=Good (tokens used, minor hard-coded values), 4=Excellent (full token system, dark mode works perfectly)" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "3. Theming" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Score 0-4**: 0=Severe issues (layout thrash, unoptimized everything), 1=Major problems (no lazy loading, expensive animations), 2=Partial (some optimization, gaps remain), 3=Good (mostly optimized, minor improvements possible), 4=Excellent (fast, lean, well-optimized)" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Layout thrashing**: Reading/writing layout properties in loops" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Missing optimization**: Images without lazy loading, unoptimized assets, missing will-change" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Render performance**: Unnecessary re-renders, missing memoization" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Expensive animations**: Animating layout properties (width, height, top, left) instead of transform/opacity" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Bundle size**: Unnecessary imports, unused dependencies" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Check for**:" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "2. Performance" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Missing breakpoints**: No mobile/tablet variants" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Horizontal scroll**: Content overflow on narrow viewports" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Touch targets**: Interactive elements < 44x44px" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Fixed widths**: Hard-coded widths that break on mobile" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Text scaling**: Layouts that break when text size increases" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Score 0-4**: 0=Desktop-only (breaks on mobile), 1=Major issues (some breakpoints, many failures), 2=Partial (works on mobile, rough edges), 3=Good (responsive, minor touch target or overflow issues), 4=Excellent (fluid, all viewports, proper touch targets)" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Check for**:" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "4. Responsive Design" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Score 0-4**: 0=AI slop gallery (5+ tells), 1=Heavy AI aesthetic (3-4 tells), 2=Some tells (1-2 noticeable), 3=Mostly clean (subtle issues only), 4=No AI tells (distinctive, intentional design)" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Check against ALL the **DON'T** guidelines in the frontend-design skill. Look for AI slop tells (AI color palette, gradient text, glassmorphism, hero metrics, card grids, generic fonts) and general design anti-patterns (gray on color, nested cards, bounce easing, redundant copy)." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "5. Anti-Patterns (CRITICAL)" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Diagnostic Scan" ],
        [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "**Suggested command**: Which command to use (prefer: /animate, /quieter, /optimize, /adapt, /clarify, /distill, /delight, /onboard, /normalize, /audit, /harden, /polish, /extract, /bolder, /arrange, /typeset, /critique, /colorize, /overdrive)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Category**: Accessibility / Performance / Theming / Responsive / Anti-Pattern" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Location**: Component, file, line" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**WCAG/Standard**: Which standard it violates (if applicable)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**[P?] Issue name**" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Recommendation**: How to fix it" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Impact**: How it affects users" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "For each issue, document:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**P2 Minor**: Annoyance, workaround exists — fix in next pass" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**P0 Blocking**: Prevents task completion — fix immediately" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**P3 Polish**: Nice-to-fix, no real user impact — fix if time permits" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**P1 Major**: Significant difficulty or WCAG AA violation — fix before release" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Tag every issue with **P0-P3 severity**:" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Detailed Findings by Severity" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Start here.** Pass/fail: Does this look AI-generated? List specific tells. Be brutally honest." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Anti-Patterns Verdict" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Top 3-5 critical issues" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Recommended next steps" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Audit Health Score: **??/20** ([rating band])" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Total issues found (count by severity: P0/P1/P2/P3)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Executive Summary" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Note what's working well — good practices to maintain and replicate." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Positive Findings" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Identify recurring problems that indicate systemic gaps rather than one-off mistakes:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "\"Touch targets consistently too small (<44px) throughout mobile experience\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "\"Hard-coded colors appear in 15+ components, should use design tokens\"" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Patterns & Systemic Issues" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 1 ;
                            oc:rowCount 6 ;
                            oc:tableCaption "### Audit Health Score" ;
                            oc:tableMarkdown """| # | Dimension | Score | Key Finding |
|---|-----------|-------|-------------|
| 1 | Accessibility | ? | [most critical a11y issue or "--"] |
| 2 | Performance | ? | |
| 3 | Responsive Design | ? | |
| 4 | Theming | ? | |
| 5 | Anti-Patterns | ? | |
| **Total** | | **??/20** | **[Rating band]** |
""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Rating bands**: 18-20 Excellent (minor polish), 14-17 Good (address weak dimensions), 10-13 Acceptable (significant work needed), 6-9 Poor (major overhaul), 0-5 Critical (fundamental issues)" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Audit Health Score" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Generate Report" ] ;
    oc:hasWorkflow _:ref_a44bc561be84e846 ;
    oc:impartsKnowledge oc:kn_265713ba,
        oc:kn_4c10c397,
        oc:kn_524ca0e5,
        oc:kn_63944c78,
        oc:kn_aeb67267,
        oc:kn_c90bf156,
        oc:kn_c9845073,
        oc:kn_ce477bb5,
        oc:kn_d6457edd,
        oc:kn_dec57f83 ;
    oc:isUserInvocable true ;
    oc:nature "Tool" ;
    oc:requiresState oc:DesignContextLoaded ;
    oc:resolvesIntent "audit accessibility compliance",
        "check technical quality of UI",
        "check theming and design token usage",
        "generate scored quality report for frontend",
        "identify anti-patterns in frontend code",
        "review responsive design implementation",
        "run performance audit" ;
    oc:yieldsState oc:AuditReportGenerated .

oc:kn_265713ba a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When documenting detailed findings" ;
    oc:directiveContent "Tag every issue with P0-P3 severity: P0 Blocking (prevents task completion), P1 Major (significant difficulty or WCAG AA violation), P2 Minor (annoyance, workaround exists), P3 Polish (nice-to-fix). Too many P3 issues creates noise — focus on what matters." ;
    oc:hasRationale "Severity tagging enables prioritized remediation and prevents audit fatigue." .

oc:kn_4c10c397 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always during audit execution" ;
    oc:directiveContent "This is a code-level audit, not a design critique. Only check what is measurable and verifiable in the implementation. Do not fix issues — document them for other commands to address." ;
    oc:hasRationale "Audit scope must stay objective and technical; design opinions go to /critique, fixes go to specialized commands." ;
    oc:severityLevel "CRITICAL" .

oc:kn_524ca0e5 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before starting any audit" ;
    oc:directiveContent "Must invoke /frontend-design first to load design principles, anti-patterns, and the Context Gathering Protocol. If no design context exists, must run /teach-impeccable first." ;
    oc:hasRationale "Audit criteria reference the frontend-design skill's anti-patterns and design principles; without them, the audit lacks its evaluation framework." ;
    oc:severityLevel "CRITICAL" .

oc:kn_63944c78 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any audit" ;
    oc:directiveContent "Verify that frontend-design context (design principles and anti-patterns) is loaded. If missing, run /teach-impeccable to establish design context first." ;
    oc:hasRationale "The audit framework depends on the design principles and anti-patterns defined in /frontend-design." ;
    oc:severityLevel "CRITICAL" .

oc:kn_aeb67267 a oc:KnowledgeNode,
        oc:OutputFormat ;
    oc:appliesToContext "When generating the audit report" ;
    oc:directiveContent """## Audit Health Score
| # | Dimension | Score | Key Finding |
|---|-----------|-------|-------------|
| 1 | Accessibility | {a11y_score} | {a11y_finding} |
| 2 | Performance | {perf_score} | {perf_finding} |
| 3 | Responsive Design | {resp_score} | {resp_finding} |
| 4 | Theming | {theme_score} | {theme_finding} |
| 5 | Anti-Patterns | {anti_score} | {anti_finding} |
| **Total** | | **{total}/20** | **{rating_band}** |

## Anti-Patterns Verdict
## Executive Summary
## Detailed Findings by Severity (P0→P3)
## Patterns & Systemic Issues
## Positive Findings
## Recommended Actions""" ;
    oc:templateVariables "a11y_finding",
        "a11y_score",
        "anti_finding",
        "anti_score",
        "perf_finding",
        "perf_score",
        "rating_band",
        "resp_finding",
        "resp_score",
        "theme_finding",
        "theme_score",
        "total" .

oc:kn_c90bf156 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Every audit execution" ;
    oc:directiveContent "1. Load frontend-design context (run /teach-impeccable if none exists) 2. Run 5-dimension diagnostic scan (Accessibility, Performance, Theming, Responsive, Anti-Patterns) scoring each 0-4 3. Generate Anti-Patterns Verdict (pass/fail AI detection) 4. Compute total Audit Health Score /20 with rating band 5. Document findings by P0-P3 severity with location, category, impact, WCAG standard, recommendation, suggested command 6. Identify systemic patterns and positive findings 7. List recommended commands in priority order ending with /polish 8. Offer user choice of execution order" ;
    oc:stepOrder 1 .

oc:kn_c9845073 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always when documenting audit findings" ;
    oc:directiveContent "Never report issues without explaining impact, provide generic recommendations, skip positive findings, forget to prioritize (everything can't be P0), or report false positives without verification." ;
    oc:hasRationale "These anti-patterns produce low-value audits that overwhelm the reader with noise or erode trust." ;
    oc:severityLevel "HIGH" .

oc:kn_ce477bb5 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When generating the report, start with Anti-Patterns Verdict before the full score" ;
    oc:directiveContent "The Anti-Patterns dimension is the first verdict to present. Check for AI slop tells: AI color palette, gradient text, glassmorphism, hero metrics, card grids, generic fonts, gray on color, nested cards, bounce easing, redundant copy." ;
    oc:hasRationale "AI-generated designs have specific detectable patterns; catching them early frames the rest of the audit." ;
    oc:severityLevel "HIGH" .

oc:kn_d6457edd a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building the Recommended Actions section" ;
    oc:directiveContent "Map each finding to the most appropriate remediation command. End with /polish as the final step if any fixes were recommended. Only recommend from the approved command set." ;
    oc:hasRationale "Actionable command suggestions bridge the gap between diagnosis and treatment, giving the user a clear path forward." .

oc:kn_dec57f83 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When generating the Audit Health Score" ;
    oc:directiveContent "Score each of the 5 audit dimensions (Accessibility, Performance, Theming, Responsive Design, Anti-Patterns) on a 0-4 scale. Total score is out of 20. Rating bands: 18-20 Excellent, 14-17 Good, 10-13 Acceptable, 6-9 Poor, 0-5 Critical." ;
    oc:hasRationale "Consistent 0-4 scoring enables comparison across audits and tracking of improvement over time." .

