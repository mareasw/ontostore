        oc:kn_fc5dfed8 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextGathered,
        oc:FileExists ;
    oc:resolvesIntent "establish consistent type scale",
        "fix font choices and hierarchy",
        "improve text readability",
        "improve typography",
        "polish typography details" ;
    oc:yieldsState oc:HierarchyEstablished,
