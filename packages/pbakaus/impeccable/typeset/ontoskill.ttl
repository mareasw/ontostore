oc:kn_06ad9ce3 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building typographic hierarchy" ;
    oc:directiveContent "Combine size + weight + color + space for strong hierarchy — don't rely on size alone. Define clear roles for each weight and limit to 3-4 weights total." ;
    oc:hasRationale "Multi-dimensional contrast creates stronger visual signals than any single dimension" .

oc:kn_0d16bb14 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting fonts and establishing type scales" ;
    oc:directiveContent "Never default to Inter/Roboto/Open Sans when personality matters, pair fonts that are similar but not identical (e.g., two geometric sans-serifs), or pick sizes arbitrarily instead of committing to a modular scale." ;
    oc:hasRationale "Generic defaults strip personality; similar-yet-different pairings create subtle wrongness that users feel but can't articulate" ;
    oc:severityLevel "HIGH" .

oc:kn_1f868fe8 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing all typography improvements" ;
    oc:directiveContent "Verify: hierarchy is instantly distinguishable, body text is comfortable for long passages, same-role elements are identically styled, typography reflects brand, web fonts load without layout shift, text meets WCAG contrast ratios and is zoomable to 200%." ;
    oc:hasRationale "Comprehensive verification ensures no regressions and confirms accessibility compliance" .

oc:kn_25124d34 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When making any typography changes" ;
    oc:directiveContent "Never use more than 2-3 font families, set body text below 16px, use px for font sizes, or disable browser zoom. Always use rem units to respect user settings." ;
    oc:hasRationale "Excessive fonts create visual chaos; small text and px units harm accessibility and readability" ;
    oc:severityLevel "CRITICAL" .

oc:kn_70691e01 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assessing and improving any typography" ;
    oc:directiveContent "Typography improvements should make text clearer, more readable, and more intentional — not fancier. Good typography is invisible; bad typography is distracting." ;
    oc:hasRationale "Typography is the foundation of interface design and carries the majority of information — it's the highest-leverage improvement possible" ;
    oc:severityLevel "HIGH" .

oc:kn_98620b17 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Always, before beginning typography assessment" ;
    oc:directiveContent "Before proceeding, invoke /frontend-design for design principles and the Context Gathering Protocol. If no design context exists yet, run /teach-impeccable first." ;
    oc:hasRationale "Design context ensures typography decisions align with brand personality and established design system" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9fa46e42 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When establishing a type scale" ;
    oc:directiveContent "Use a modular type scale with a consistent ratio (1.25, 1.333, or 1.5) to create hierarchy. 5 sizes cover most needs: caption, secondary, body, subheading, heading." ;
    oc:hasRationale "A consistent ratio creates visual harmony and clear differentiation between levels" .

oc:kn_a3378dde a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When fixing readability" ;
    oc:directiveContent "Set max-width on text containers using ch units (max-width: 65ch). Adjust line-height per context: tighter for headings (1.1-1.2), looser for body (1.5-1.7). Increase line-height slightly for light-on-dark text." ;
    oc:hasRationale "Optimal line length (45-75 characters) and context-appropriate line-height are the two biggest readability levers" .

oc:kn_e109f3f9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing typography in CSS" ;
    oc:directiveContent "Use semantic token names (--text-body, --text-heading) not value names (--font-16). Load only the font weights actually used. Ensure web font loading uses font-display: swap and metric-matched fallbacks." ;
    oc:hasRationale "Semantic tokens enable theme changes; loading unused weights wastes bandwidth; unmanaged font loading causes layout shift" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fc5dfed8 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a sizing strategy" ;
    oc:directiveContent "Use fixed rem-based type scales for app UIs (fluid sizing undermines spatial predictability in dense layouts). Use fluid clamp() sizing for marketing/content page headings only. Keep body text fixed in all contexts." ;
    oc:hasRationale "Dense container-based layouts need spatial predictability; marketing pages benefit from responsive fluid sizing" ;
    oc:severityLevel "MEDIUM" .

_:ref_12db7daa08066b0e a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
    oc:itemText "Are line lengths comfortable? (45-75 characters ideal)" .

_:ref_19afee26289e4dd2 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 3 ;
    oc:itemText "Is there enough contrast between text and background?" .

_:ref_20b6694173be7a77 a oc:WorkflowStep ;
    dcterms:description "**Readability**:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem _:ref_12db7daa08066b0e,
