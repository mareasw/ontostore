@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_typeset a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "typeset" ;
    skos:broader "Typography improvement skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/typeset" ;
    oc:contentHash "87d8792bf21c934589168d2a9a6b28314053e1a143b0ba76ff5137475b9e94e8" ;
    oc:dependsOnSkill oc:skill_teach_impeccable ;
    oc:differentia "Fixes font choices, hierarchy, sizing, weight, and readability in frontend interfaces to produce intentional, well-crafted type systems" ;
    oc:extends oc:skill_frontend_design ;
    oc:handlesFailure oc:InvalidInput,
        oc:NoDesignContext ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Improves typography by fixing font choices, hierarchy, sizing, weight, and readability so text feels intentional. Use when the user mentions fonts, type, readability, text hierarchy, sizing looks off, or wants more polished, intentional typography." ;
    oc:hasName "typeset" ;
    oc:impartsKnowledge oc:kn_0a248489,
        oc:kn_0cb3713e,
        oc:kn_7d422347,
        oc:kn_d9984f43,
        oc:kn_dcce8cb1 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextAvailable ;
    oc:resolvesIntent "establish type hierarchy and scale",
        "fix font choices and pairings",
        "fix inconsistent typography",
        "improve text readability",
        "improve typography in a UI",
        "make text look intentional and polished" ;
    oc:yieldsState oc:TypeScaleEstablished,
        oc:TypographyImproved .

oc:kn_0a248489 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building or fixing a typography system" ;
    oc:directiveContent "Establish a modular type scale with a consistent ratio (1.25, 1.333, or 1.5) and combine size + weight + color + space for hierarchy — don't rely on size alone. 5 sizes (caption, secondary, body, subheading, heading) cover most needs." ;
    oc:hasRationale "A consistent type scale creates visual rhythm and clear information hierarchy. Combining multiple dimensions (size, weight, color, spacing) creates stronger differentiation than size alone." ;
    oc:severityLevel "HIGH" .

oc:kn_0cb3713e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing a sizing strategy for typography" ;
    oc:directiveContent "Use fixed rem-based type scales for app UIs (spatial predictability matters in dense layouts) and fluid clamp() sizing for marketing/content page headings. Keep body text fixed regardless of context." ;
    oc:hasRationale "Fluid sizing in app UIs undermines the spatial predictability that container-based layouts need, while marketing pages benefit from responsive, dramatic heading sizing." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7d422347 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting and sizing typography in any interface" ;
    oc:directiveContent "Never use more than 2-3 font families, pick sizes arbitrarily, set body text below 16px, use decorative fonts for body text, or use px for font sizes instead of rem." ;
    oc:hasRationale "These anti-patterns destroy readability, consistency, and accessibility. rem units respect user browser settings while px does not." ;
    oc:severityLevel "CRITICAL" .

oc:kn_d9984f43 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any typography assessment or improvement" ;
    oc:directiveContent "Before starting typography work, invoke the frontend-design skill for its design principles and Context Gathering Protocol. If no design context exists yet, run teach-impeccable first to establish project design context." ;
    oc:hasRationale "Typography improvements must be grounded in the project's established design context and brand personality to be coherent. Working without context leads to generic, misaligned results." ;
    oc:severityLevel "HIGH" .

oc:kn_dcce8cb1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When setting readability parameters for any text block" ;
    oc:directiveContent "Line lengths must stay in 45-75 character range (use max-width: 65ch), body text must be at least 16px/1rem, line-height should be tighter for headings (1.1-1.2) and looser for body (1.5-1.7), and text must meet WCAG contrast ratios." ;
    oc:hasRationale "These constraints ensure comfortable reading, accessibility compliance, and prevent eye strain. Deviating from them degrades the reading experience measurably." ;
    oc:severityLevel "HIGH" .

