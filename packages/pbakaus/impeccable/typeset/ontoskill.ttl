                    oc:itemOrder 2 ;
                    oc:itemText "Is line-height appropriate for the font and context?" ] ] ;
    oc:stepId "step_4" ;
    oc:stepOrder 4 .

_:ref_247490534f0ff923 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "Does the font match the brand personality? (A playful brand shouldn't use a corporate typeface)" .

_:ref_2737a770b9a19a3f a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
    oc:itemText "Are the same elements styled the same way throughout?" .

_:ref_2889f2e9041e94bd a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
    oc:itemText "Is there a consistent type scale, or are sizes arbitrary?" .

_:ref_2a6ef266ed4d8637 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 3 ;
    oc:itemText "Is the sizing strategy appropriate for the context? (Fixed `rem` scales for app UIs; fluid `clamp()` for marketing/content page headings)" .

_:ref_49bbb064dfb4ce01 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
    oc:itemText "Can you tell headings from body from captions at a glance?" .

_:ref_59bf7476e2ff2204 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 3 ;
    oc:itemText "Are weight contrasts strong enough? (Medium vs Regular is barely visible)" .

_:ref_67100761946fa789 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "Are font weights used consistently? (Not bold in one section, semibold in another for the same role)" .

_:ref_6eb71b57465c0408 a oc:WorkflowStep ;
    dcterms:description "**Consistency**:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem _:ref_2737a770b9a19a3f,
                _:ref_67100761946fa789,
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 3 ;
                    oc:itemText "Is letter-spacing intentional or default everywhere?" ] ] ;
    oc:stepId "step_5" ;
    oc:stepOrder 5 .

_:ref_7c8694674246da78 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 3 ;
    oc:itemText "Are there too many font families? (More than 2-3 is almost always a mess)" .

_:ref_7f349b7471c7c891 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
    oc:itemText "Are we using invisible defaults? (Inter, Roboto, Arial, Open Sans, system defaults)" .

_:ref_833a8389fd76db97 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "Are font sizes too close together? (14px, 15px, 16px = muddy hierarchy)" .

