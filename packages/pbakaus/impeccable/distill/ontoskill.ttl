@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_distill a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "distill" ;
    skos:broader "Design refinement skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/distill" ;
    oc:contentHash "df9f0e193ddcff291b283cd0f340e2404157ab04057a17c0a59150b07e28e831" ;
    oc:contradicts oc:skill_overdrive ;
    oc:dependsOnSkill oc:skill_frontend_design,
        oc:skill_teach_impeccable ;
    oc:differentia "Strips UI designs to their essential elements through systematic removal of unnecessary complexity across information architecture, visual, layout, interaction, content, and code dimensions" ;
    oc:handlesFailure oc:InvalidInput,
        oc:MissingDesignContext,
        oc:OverSimplification ;
    oc:hasAllowedTool "Edit",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "design" ;
    oc:hasDescription "Strip designs to their essence by removing unnecessary complexity. Great design is simple, powerful, and clean. Use when the user asks to simplify, declutter, reduce noise, remove elements, or make a UI cleaner and more focused." ;
    oc:hasName "distill" ;
    oc:impartsKnowledge oc:kn_2a87a727,
        oc:kn_796336bf,
        oc:kn_aea35e20,
        oc:kn_c3ccc470,
        oc:kn_c862011a,
        oc:kn_d0c2d80e,
        oc:kn_e0bdafc8 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextAvailable,
        oc:FileExists ;
    oc:resolvesIntent "declutter interface",
        "make design cleaner and more focused",
        "reduce visual noise",
        "remove unnecessary elements",
        "simplify UI design",
        "streamline user experience" ;
    oc:yieldsState oc:CodeCleaned,
        oc:DesignSimplified .

oc:kn_2a87a727 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning which elements to keep, remove, or hide" ;
    oc:directiveContent "Apply the 80/20 rule: identify the 20% of elements that deliver 80% of value. Use progressive disclosure to hide complexity behind clear entry points. Consolidate similar actions and content." ;
    oc:hasRationale "Progressive disclosure preserves full functionality while reducing cognitive load; consolidation reduces the paradox of choice" ;
    oc:severityLevel "MEDIUM" .

oc:kn_796336bf a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, as invariant constraints during any simplification pass" ;
    oc:directiveContent "Never sacrifice accessibility for simplicity — clear labels, ARIA attributes, and semantic structure must be preserved. Never oversimplify complex domains; match complexity to actual task complexity." ;
    oc:hasRationale "Accessible design is non-negotiable and oversimplification in complex domains creates mystery rather than clarity" ;
    oc:severityLevel "CRITICAL" .

oc:kn_aea35e20 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any simplification work" ;
    oc:directiveContent "Must invoke /frontend-design first for design principles and anti-patterns. If no design context exists, run /teach-impeccable to establish project context before proceeding." ;
    oc:hasRationale "Without established design context and principles, simplification decisions are arbitrary and may conflict with project standards" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c3ccc470 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing simplification changes" ;
    oc:directiveContent "After simplification, verify five outcomes: faster task completion, reduced cognitive load, feature completeness, clearer hierarchy, and better performance. Document all removed features and rationale." ;
    oc:hasRationale "Validation ensures simplification improved usability rather than degraded it; documentation prevents silent feature loss" ;
    oc:severityLevel "HIGH" .

oc:kn_c862011a a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When simplifying visual layout and structure" ;
    oc:directiveContent "Never nest cards inside cards, add unnecessary borders/shadows/backgrounds, or create complex multi-column layouts when simple vertical flow suffices." ;
    oc:hasRationale "Decorative containers and complex grids add visual noise without improving usability; spacing and alignment achieve the same grouping more cleanly" ;
    oc:severityLevel "HIGH" .

oc:kn_d0c2d80e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating any element for removal during simplification" ;
    oc:directiveContent "Simplicity is not about removing features — it is about removing obstacles between users and their goals. Every element must justify its existence." ;
    oc:hasRationale "Misguided simplification that removes functionality harms users; true simplicity preserves capability while reducing friction" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e0bdafc8 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When executing the simplification pass" ;
    oc:directiveContent "Systematically simplify across all six dimensions — information architecture, visuals, layout, interactions, content, and code — rather than cherry-picking one area." ;
    oc:hasRationale "Partial simplification creates inconsistency; holistic simplification across all dimensions produces coherent, clean results" ;
    oc:severityLevel "MEDIUM" .

