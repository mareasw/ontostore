@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_distill a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "distill" ;
    skos:broader "Design refinement skill" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/distill" ;
    oc:contentHash "df9f0e193ddcff291b283cd0f340e2404157ab04057a17c0a59150b07e28e831" ;
    oc:dependsOnSkill oc:skill_ontoskills_frontend_design,
        oc:skill_ontoskills_teach_impeccable ;
    oc:differentia "strips unnecessary complexity from UI designs through systematic simplification across information architecture, visual, layout, interaction, content, and code dimensions" ;
    oc:handlesFailure oc:InsufficientContext ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "document" ;
    oc:hasDescription "Strip designs to their essence by removing unnecessary complexity. Great design is simple, powerful, and clean. Use when the user asks to simplify, declutter, reduce noise, remove elements, or make a UI cleaner and more focused." ;
    oc:hasName "distill" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Still complete**: Are all necessary features still accessible?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Clearer hierarchy**: Is it obvious what matters most?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Reduced cognitive load**: Is it easier to understand what to do?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "**Better performance**: Does simpler design load faster?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Faster task completion**: Can users accomplish goals more quickly?" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Ensure simplification improves usability:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 5 ;
            oc:sectionTitle "Verify Simplification" ],
        [ a oc:Section ;
            oc:hasContent _:ref_0bbe0d049b54eb2e,
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**CRITICAL**: Simplicity is not about removing features - it's about removing obstacles between users and their goals. Every element should justify its existence." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "If any of these are unclear from the codebase, ask the user directly to clarify what you cannot infer." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Analyze what makes the design feel complex or cluttered:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Assess Current State" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Invoke /frontend-design — it contains design principles, anti-patterns, and the **Context Gathering Protocol**. Follow the protocol before proceeding — if no design context exists yet, you MUST run /teach-impeccable first." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "MANDATORY PREPARATION" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Document why they were removed" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Consider if they need alternative access points" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Note any user feedback to monitor" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "If you removed features or options:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "Remember: You have great taste and judgment. Simplification is an act of confidence - knowing what to keep and courage to remove the rest. As Antoine de Saint-Exupéry said: \"Perfection is achieved not when there is nothing more to add, but when there is nothing left to take away.\"" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 6 ;
            oc:sectionTitle "Document Removed Complexity" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: distill
description: Strip designs to their essence by removing unnecessary complexity. Great design is simple, powerful, and clean. Use when the user asks to simplify, declutter, reduce noise, remove elements, or make a UI cleaner and more focused.
user-invocable: true
argument-hint: "[target]"
""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Remove unnecessary complexity from designs, revealing the essential elements and creating clarity through ruthless simplification." ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Systematically remove complexity across these dimensions:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 3 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "Eliminate hierarchy completely (some things should stand out)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Sacrifice accessibility for simplicity (clear labels and ARIA still required)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Remove necessary functionality (simplicity ≠ feature-less)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Make things so simple they're unclear (mystery ≠ minimalism)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 6 ;
                            oc:itemText "Oversimplify complex domains (match complexity to actual task complexity)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Remove information users need to make decisions" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**NEVER**:" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Linear flow**: Replace complex grids with simple vertical flow where possible" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Remove sidebars**: Move secondary content inline or hide it" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Generous white space**: Let content breathe, don't pack everything tight" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Full-width**: Use available space generously instead of complex multi-column layouts" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Consistent alignment**: Pick left or center, stick with it" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Layout Simplification" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Reduce scope**: Remove secondary actions, optional features, redundant information" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Clear hierarchy**: ONE primary action, few secondary actions, everything else tertiary or hidden" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Combine related actions**: Merge similar buttons, consolidate forms, group related content" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Progressive disclosure**: Hide complexity behind clear entry points (accordions, modals, step-through flows)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Remove redundancy**: If it's said elsewhere, don't repeat it here" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Information Architecture" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Reduce color palette**: Use 1-2 colors plus neutrals, not 5-7 colors" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Limit typography**: One font family, 3-4 sizes maximum, 2-3 weights" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Flatten structure**: Reduce nesting, remove unnecessary containers—never nest cards inside cards" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Remove decorations**: Eliminate borders, shadows, backgrounds that don't serve hierarchy or function" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Consistent spacing**: Use one spacing scale, remove arbitrary gaps" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Remove unnecessary cards**: Cards aren't needed for basic layout; use spacing and alignment instead" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Visual Simplification" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Essential information only**: Remove marketing fluff, legalese, hedging" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Remove redundant copy**: No headers restating intros, no repeated explanations, say it once" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Remove jargon**: Plain language always wins" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Scannable structure**: Short paragraphs, bullet points, clear headings" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Active voice**: \"Save changes\" not \"Changes will be saved\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Shorter copy**: Cut every sentence in half, then do it again" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Content Simplification" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Reduce variants**: Does that component need 12 variations, or can 3 cover 90% of cases?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Flatten component trees**: Reduce nesting depth" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Remove unused code**: Dead CSS, unused components, orphaned files" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Consolidate styles**: Merge similar styles, use utilities consistently" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Code Simplification" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Smart defaults**: Make common choices automatic, only ask when necessary" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Clear CTAs**: ONE obvious next step, not five competing actions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Inline actions**: Replace modal flows with inline editing where possible" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Reduce choices**: Fewer buttons, fewer options, clearer path forward (paradox of choice is real)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Remove steps**: Can signup be one step instead of three? Can checkout be simplified?" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Interaction Simplification" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Simplify the Design" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Create a ruthless editing strategy:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**IMPORTANT**: Simplification is hard. It requires saying no to good ideas to make room for great execution. Be ruthless." ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Consolidation opportunities**: What can be combined or integrated?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Progressive disclosure**: What can be hidden until needed?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Core purpose**: What's the ONE thing this should accomplish?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Essential elements**: What's truly necessary to achieve that purpose?" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Plan Simplification" ] ;
    oc:hasWorkflow _:ref_0bbe0d049b54eb2e,
        [ a oc:Workflow ;
            dcterms:description "Systematic workflow for stripping unnecessary complexity from a UI design while preserving essential functionality." ;
            oc:hasStep _:ref_470c1b58b6bdcba9,
                [ a oc:WorkflowStep ;
                    dcterms:description "Document removed features/options: why removed, whether alternative access points are needed, user feedback to monitor." ;
                    oc:expectedOutcome "A record of what was removed and rationale, enabling informed decisions about future changes." ;
                    oc:stepDependsOn _:ref_6fbd7861f828695d ;
                    oc:stepId "document" ],
                _:ref_6fbd7861f828695d,
                _:ref_9d382b8c4128e9d4,
                _:ref_a7dc651af04155cb ;
            oc:workflowId "distill-simplify" ;
            oc:workflowName "Distill Design Simplification" ] ;
    oc:impartsKnowledge oc:kn_00fdf366,
        oc:kn_0dd8c12e,
        oc:kn_11a50c26,
        oc:kn_4f28896d,
        oc:kn_55267b41,
        oc:kn_6a725315,
        oc:kn_83158e87,
        oc:kn_83998fb6 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextAvailable ;
    oc:resolvesIntent "declutter interface",
        "make design cleaner and more focused",
        "reduce complexity",
        "remove visual noise",
        "simplify UI design" ;
    oc:yieldsState oc:DesignSimplified .

oc:kn_00fdf366 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When deciding what to do with secondary features and information" ;
    oc:directiveContent "Use progressive disclosure: hide complexity behind clear entry points like accordions, modals, and step-through flows rather than removing it entirely." ;
    oc:hasRationale "Progressive disclosure preserves functionality while reducing initial cognitive load." ;
    oc:severityLevel "MEDIUM" .

oc:kn_0dd8c12e a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When simplifying any design dimension" ;
    oc:directiveContent "NEVER remove necessary functionality, sacrifice accessibility for simplicity, make things so simple they're unclear, remove information users need to make decisions, eliminate hierarchy completely, or oversimplify complex domains." ;
    oc:hasRationale "These anti-patterns turn simplification into degradation, producing interfaces that are minimal but broken or confusing." ;
    oc:severityLevel "CRITICAL" .

oc:kn_11a50c26 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating any element for removal or retention" ;
    oc:directiveContent "Simplicity is not about removing features — it's about removing obstacles between users and their goals. Every element should justify its existence." ;
    oc:hasRationale "Mistaking feature removal for simplicity leads to unusable products; true simplicity preserves function while eliminating friction." ;
    oc:severityLevel "CRITICAL" .

oc:kn_4f28896d a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When simplifying content and copy" ;
    oc:directiveContent "For copy: cut every sentence in half, then do it again. Use active voice. Remove jargon. Say it once — no headers restating intros, no repeated explanations." ;
    oc:hasRationale "Concise writing reduces cognitive load and makes interfaces scannable and actionable." ;
    oc:severityLevel "MEDIUM" .

oc:kn_55267b41 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assessing current state and planning simplification" ;
    oc:directiveContent "Identify the 20% that delivers 80% of value. Find the ONE primary user goal and ruthlessly remove, hide, or combine everything else." ;
    oc:hasRationale "Pareto principle applied to UI design — most value comes from a small fraction of elements, so focus effort there." ;
    oc:severityLevel "HIGH" .

oc:kn_6a725315 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After completing simplification changes" ;
    oc:directiveContent "Verify simplification improved usability by checking: faster task completion, reduced cognitive load, all necessary features still accessible, clearer hierarchy, and better performance." ;
    oc:hasRationale "Simplification must measurably improve the user experience, not just reduce element count." ;
    oc:severityLevel "HIGH" .

oc:kn_83158e87 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any simplification work" ;
    oc:directiveContent "Design context must exist before proceeding. If no design context exists, run /teach-impeccable first. Invoke /frontend-design for design principles, anti-patterns, and the Context Gathering Protocol." ;
    oc:hasRationale "Without established design context, simplification decisions lack grounding and may conflict with project standards." ;
    oc:severityLevel "CRITICAL" .

oc:kn_83998fb6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When simplifying visual structure and layout" ;
    oc:directiveContent "Never nest cards inside cards. Cards aren't needed for basic layout — use spacing and alignment instead." ;
    oc:hasRationale "Nested cards create visual clutter and unnecessary depth without serving hierarchy or function." ;
    oc:severityLevel "MEDIUM" .

_:ref_03a6fb0d22f27dfe a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 4 ;
    oc:itemText "What's the 20% that delivers 80% of value?" .

_:ref_145b34884827c1f7 a oc:WorkflowStep ;
    dcterms:description "**Find the essence**:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem _:ref_03a6fb0d22f27dfe,
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "What's the primary user goal? (There should be ONE)" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 3 ;
                    oc:itemText "What can be removed, hidden, or combined?" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "What's actually necessary vs nice-to-have?" ] ] ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_475b0200f72407cf a oc:WorkflowStep ;
    dcterms:description "**Identify complexity sources**:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "**Excessive variation**: Too many colors, fonts, sizes, styles without purpose" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 4 ;
                    oc:itemText "**Visual noise**: Unnecessary borders, shadows, backgrounds, decorations" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 6 ;
                    oc:itemText "**Feature creep**: Too many options, actions, or paths forward" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 5 ;
                    oc:itemText "**Confusing hierarchy**: Unclear what matters most" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "**Too many elements**: Competing buttons, redundant information, visual clutter" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 3 ;
                    oc:itemText "**Information overload**: Everything visible at once, no progressive disclosure" ] ] ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_0bbe0d049b54eb2e a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_145b34884827c1f7,
        _:ref_475b0200f72407cf ;
    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_470c1b58b6bdcba9 a oc:WorkflowStep ;
    dcterms:description "Analyze current state: identify complexity sources (too many elements, excessive variation, information overload, visual noise, confusing hierarchy, feature creep) and find the essence (primary user goal, necessary vs nice-to-have, 20% delivering 80% value)." ;
    oc:expectedOutcome "Clear understanding of what makes the design complex and what its essential purpose is." ;
    oc:stepId "assess" .

_:ref_6fbd7861f828695d a oc:WorkflowStep ;
    dcterms:description "Verify simplification improved usability: faster task completion, reduced cognitive load, still feature-complete, clearer hierarchy, better performance." ;
    oc:expectedOutcome "Confirmed that simplification improved the design without breaking functionality." ;
    oc:stepDependsOn _:ref_9d382b8c4128e9d4 ;
    oc:stepId "verify" .

_:ref_9d382b8c4128e9d4 a oc:WorkflowStep ;
    dcterms:description "Systematically simplify across six dimensions: information architecture (reduce scope, progressive disclosure, clear hierarchy), visual (reduce palette, limit typography, remove decorations, flatten structure), layout (linear flow, remove sidebars, generous whitespace), interaction (fewer choices, smart defaults, remove steps), content (shorter copy, active voice, no jargon), and code (remove unused code, flatten components, consolidate styles)." ;
    oc:expectedOutcome "A cleaner, more focused design with all unnecessary complexity removed." ;
    oc:stepDependsOn _:ref_a7dc651af04155cb ;
    oc:stepId "simplify" .

