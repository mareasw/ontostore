oc:kn_21724708 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating performance targets" ;
    oc:directiveContent "Core Web Vitals thresholds: LCP < 2.5s, FID < 100ms / INP < 200ms, CLS < 0.1" ;
    oc:hasRationale "These are Google's established thresholds for good user experience and impact search ranking" ;
    oc:severityLevel "HIGH" .

oc:kn_432bfa4b a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any optimization work" ;
    oc:directiveContent "Never optimize without measuring first. Premature optimization wastes time — always identify and target the biggest bottleneck." ;
    oc:hasRationale "Without baseline measurements, you cannot verify improvements or know if you're optimizing the right thing" ;
    oc:severityLevel "CRITICAL" .

oc:kn_4720ecea a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying GPU acceleration hints" ;
    oc:directiveContent "Do not use will-change everywhere — it creates new compositor layers and consumes GPU memory." ;
    oc:hasRationale "Excessive layer creation degrades performance by increasing memory pressure and composite cost" ;
    oc:severityLevel "MEDIUM" .

oc:kn_49b36347 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After applying optimizations" ;
    oc:directiveContent "Compare before/after Lighthouse scores, test on low-end devices, throttle to 3G, verify no functional regressions, and assess perceived speed." ;
    oc:hasRationale "Lab conditions miss real-world variability — only cross-device, cross-network testing confirms genuine improvement" ;
    oc:severityLevel "HIGH" .

oc:kn_4a2482f2 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When running multiple optimization iterations" ;
    oc:directiveContent "Optimization passes are repeatable but each pass may produce different results as code evolves. Always re-measure after changes." ;
    oc:hasRationale "Code changes between passes mean bottlenecks shift — stale assumptions lead to wasted effort" ;
    oc:severityLevel "LOW" .

oc:kn_5369b74d a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When manipulating DOM dimensions or positions in JavaScript" ;
    oc:directiveContent "Batch DOM reads separately from DOM writes to avoid layout thrashing. Read all measurements first, then apply all mutations." ;
    oc:hasRationale "Alternating reads and writes forces synchronous layout recalculations (reflows) for each iteration" ;
    oc:severityLevel "HIGH" .

oc:kn_57e27a20 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying any optimization technique" ;
    oc:directiveContent "Never sacrifice accessibility for performance, break functionality while optimizing, or lazy load above-fold content." ;
    oc:hasRationale "Performance gains that break usability or accessibility create a worse overall user experience" ;
    oc:severityLevel "HIGH" .

oc:kn_bcd2871e a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting optimization work" ;
    oc:directiveContent "Establish baseline metrics (LCP, FID/INP, CLS, bundle size, frame rate) before making any changes." ;
    oc:hasRationale "Baseline measurements enable before/after comparison and prevent optimizing something that isn't actually a problem" ;
    oc:severityLevel "CRITICAL" .

oc:kn_e6df59e0 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When verifying performance improvements" ;
    oc:directiveContent "Measure on real devices with real network conditions. Desktop Chrome with fast connection isn't representative of actual user experience." ;
    oc:hasRationale "Most users are on mobile devices with slower CPUs and network connections — dev environment results are misleading" ;
    oc:severityLevel "MEDIUM" .

oc:kn_f3c34be0 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When optimizing animation performance" ;
    oc:directiveContent "Use transform and opacity for animations (GPU-accelerated) instead of layout properties (width, height, top, left). Target 16ms per frame for 60fps." ;
    oc:hasRationale "Transform and opacity animations bypass the main thread layout/paint pipeline and run on the compositor thread" ;
    oc:severityLevel "HIGH" .

