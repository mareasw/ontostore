    oc:contentHash "914899cdc370307efd1739481936cda856ab623ec7e5aec0b051717d2835fa31" ;
    oc:differentia "diagnoses and fixes UI performance across loading speed, rendering, animations, images, and bundle size for web frontend applications" ;
