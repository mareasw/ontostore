        oc:kn_f5a8a1ef ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:FileExists,
        oc:ProjectLoaded ;
    oc:resolvesIntent "diagnose performance issues",
        "fix animation jank",
        "improve Core Web Vitals",
        "improve rendering performance",
        "make UI faster and smoother",
        "optimize images",
        "optimize loading speed",
        "optimize network requests",
        "reduce bundle size",
