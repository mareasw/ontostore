@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_teach_impeccable a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "teach-impeccable" ;
    skos:broader "Setup workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/teach-impeccable" ;
    oc:contentHash "34e5b4f8dd63aae9952436ca0aeeb4eabc95eac50f51ffb53c65998de801580d" ;
    oc:differentia "that gathers design context from codebase exploration and user interview, then persists it as reusable guidelines for all future design sessions" ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasAllowedTool "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "none (runs against current project)" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "One-time setup that gathers design context for your project and saves it to your AI config file. Run once to establish persistent design guidelines." ;
    oc:hasName "teach-impeccable" ;
    oc:hasRequirement oc:req_445cacc2,
        oc:req_c30696a4,
        oc:req_e7b1bf3f ;
    oc:impartsKnowledge oc:kn_22cb5ee7,
        oc:kn_2d84d4c8,
        oc:kn_38950f1b,
        oc:kn_691762a0,
        oc:kn_7ad6a7ae,
        oc:kn_b67d6fce ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DirectoryWritable,
        oc:FileExists ;
    oc:resolvesIntent "create persistent design system configuration",
        "establish design guidelines",
        "gather design context",
        "onboard AI to project's design language" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_22cb5ee7 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When conducting the user interview in Step 2" ;
    oc:directiveContent "Structure the interview around four pillars: Users & Purpose, Brand & Personality, Aesthetic Preferences, and Accessibility & Inclusion — but adapt which questions to ask based on gaps found during exploration." ;
    oc:hasRationale "A structured yet adaptive interview framework ensures comprehensive coverage while avoiding unnecessary questions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2d84d4c8 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before executing the skill, during Step 1 exploration" ;
    oc:directiveContent "Before asking any questions, thoroughly scan the project to discover existing design context — README, docs, package.json, config files, components, brand assets, design tokens, CSS variables, and style guides." ;
    oc:hasRationale "Pre-exploration prevents asking the user questions they've already answered through their codebase, respecting their time and demonstrating competence." ;
    oc:severityLevel "HIGH" .

oc:kn_38950f1b a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always, when this skill is executed" ;
    oc:directiveContent "This skill creates or modifies .impeccable.md in the project root, and optionally modifies .github/copilot-instructions.md. These files persist across sessions and affect all future AI-assisted design work." ;
    oc:hasRationale "The persistent nature of these files means incorrect or incomplete design context will propagate to all future sessions. Getting it right matters." ;
    oc:severityLevel "HIGH" .

oc:kn_691762a0 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After Step 3, when the file has been written" ;
    oc:directiveContent "After writing the Design Context, confirm completion with the user and summarize the key design principles that will now guide all future work. Also ask whether to append to .github/copilot-instructions.md." ;
    oc:hasRationale "Explicit confirmation ensures the user can verify the synthesized principles match their intent, and the Copilot instructions option extends value to other AI tools." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7ad6a7ae a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When writing the Design Context to disk" ;
    oc:directiveContent "If .impeccable.md already exists, update the Design Context section in place rather than overwriting the entire file." ;
    oc:hasRationale "Preserving other content in .impeccable.md ensures idempotent re-runs don't destroy unrelated configuration." ;
    oc:severityLevel "MEDIUM" .

oc:kn_b67d6fce a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "During Step 2 user interview phase" ;
    oc:directiveContent "Only ask the user to clarify what cannot be inferred from the codebase. Skip questions where the answer is already clear from exploration." ;
    oc:hasRationale "Asking redundant questions wastes user time and signals that the agent hasn't done its homework. Focused questions build trust." ;
    oc:severityLevel "HIGH" .

oc:req_445cacc2 a oc:RequirementTool ;
    oc:isOptional false ;
    oc:requirementValue "File write access to .impeccable.md and optionally .github/copilot-instructions.md" .

oc:req_c30696a4 a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Understanding of UX design principles, brand personality, and aesthetic direction" .

oc:req_e7b1bf3f a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "Ability to read and analyze project codebase (README, package.json, components, CSS)" .

