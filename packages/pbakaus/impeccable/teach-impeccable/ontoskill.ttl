@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_teach_impeccable a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "teach-impeccable" ;
    skos:broader "Configuration setup ritual" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/teach-impeccable" ;
    oc:contentHash "34e5b4f8dd63aae9952436ca0aeeb4eabc95eac50f51ffb53c65998de801580d" ;
    oc:differentia "that explores a project's codebase, interviews the user about design preferences, and persists a structured Design Context document to guide all future design-related skill executions" ;
    oc:handlesFailure oc:InvalidInput,
        oc:PermissionDenied ;
    oc:hasArgumentHint "none (interactive setup)" ;
    oc:hasCategory "productivity" ;
    oc:hasDescription "One-time setup that gathers design context for your project and saves it to your AI config file. Run once to establish persistent design guidelines." ;
    oc:hasName "teach-impeccable" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Before asking questions, thoroughly scan the project to discover what you can:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Brand assets**: Logos, favicons, color values already defined" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 6 ;
                            oc:itemText "**Any style guides or brand documentation**" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**README and docs**: Project purpose, target audience, any stated goals" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "**Design tokens / CSS variables**: Existing color palettes, font stacks, spacing scales" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Existing components**: Current design patterns, spacing, typography in use" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Package.json / config files**: Tech stack, dependencies, existing design libraries" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "Note what you've learned and what remains unclear." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Step 1: Explore the Codebase" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Gather design context for this project, then persist it for all future sessions." ],
                [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: teach-impeccable
description: One-time setup that gathers design context for your project and saves it to your AI config file. Run once to establish persistent design guidelines.
user-invocable: true
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Skip questions where the answer is already clear from the codebase exploration." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "ask the user directly to clarify what you cannot infer. Focus only on what you couldn't infer from the codebase:" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Light mode, dark mode, or both?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Any colors that must be used or avoided?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Any strong preferences for visual direction? (minimal, bold, elegant, playful, technical, organic, etc.)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Aesthetic Preferences" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Specific accessibility requirements? (WCAG level, known user needs)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Considerations for reduced motion, color blindness, or other accommodations?" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Accessibility & Inclusion" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "What should this explicitly NOT look like? Any anti-references?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "How would you describe the brand personality in 3 words?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Any reference sites or apps that capture the right feel? What specifically about them?" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Brand & Personality" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Who uses this? What's their context when using it?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "What emotions should the interface evoke? (confidence, delight, calm, urgency, etc.)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "What job are they trying to get done?" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Users & Purpose" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Step 2: Ask UX-Focused Questions" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 5 ;
                    oc:textContent "Confirm completion and summarize the key design principles that will now guide all future work." ],
                [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """## Design Context

### Users
[Who they are, their context, the job to be done]

### Brand Personality
[Voice, tone, 3-word personality, emotional goals]

### Aesthetic Direction
[Visual tone, references, anti-references, theme]

### Design Principles
[3-5 principles derived from the conversation that should guide all design decisions]
""" ;
                    oc:codeLanguage "markdown" ;
                    oc:contentOrder 2 ;
                    oc:sourceLocation "lines 51-65" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Synthesize your findings and the user's answers into a `## Design Context` section:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "Write this section to `.impeccable.md` in the project root. If the file already exists, update the Design Context section in place." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "Then ask the user directly to clarify what you cannot infer. whether they'd also like the Design Context appended to .github/copilot-instructions.md. If yes, append or update the section there as well." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Step 3: Write Design Context" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Three-step workflow to explore the codebase, interview the user about design preferences, and persist a structured Design Context document." ;
            oc:hasStep _:ref_27c8538420005a06,
                _:ref_a53c8af46d97e7aa,
                [ a oc:WorkflowStep ;
                    dcterms:description "Synthesize codebase findings and user answers into a structured Design Context section and write it to .impeccable.md (and optionally .github/copilot-instructions.md)" ;
                    oc:expectedOutcome "A persisted .impeccable.md file with Design Context covering Users, Brand Personality, Aesthetic Direction, and Design Principles" ;
                    oc:stepDependsOn _:ref_27c8538420005a06 ;
                    oc:stepId "write-design-context" ] ;
            oc:workflowId "teach-impeccable-main" ;
            oc:workflowName "Gather and Persist Design Context" ] ;
    oc:impartsKnowledge oc:kn_682383fb,
        oc:kn_8f63a80e,
        oc:kn_b7c086fa,
        oc:kn_dd3f5d4a,
        oc:kn_e48aea7e ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DirectoryWritable ;
    oc:resolvesIntent "configure project design system",
        "create design guidelines",
        "establish design context",
        "gather design preferences",
        "persist design principles" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_682383fb a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, before asking any user questions" ;
    oc:directiveContent "Explore the codebase thoroughly before asking questions — infer as much as possible from existing files (README, package.json, components, design tokens, CSS variables, brand assets) so you only ask the user what cannot be inferred." ;
    oc:hasRationale "Minimizing user effort by maximizing codebase inference creates a better experience and demonstrates competence" ;
    oc:severityLevel "HIGH" .

oc:kn_8f63a80e a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When synthesizing findings into the Design Context document" ;
    oc:directiveContent "Design context must cover four domains: Users (who, context, job-to-be-done), Brand Personality (voice, tone, 3-word personality, emotional goals), Aesthetic Direction (visual tone, references, anti-references, theme), and Design Principles (3-5 guiding principles)." ;
    oc:hasRationale "These four domains provide comprehensive design guidance that covers user needs, brand identity, visual direction, and decision-making criteria" ;
    oc:severityLevel "CRITICAL" .

oc:kn_b7c086fa a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When persisting the design context" ;
    oc:directiveContent "Write the Design Context to .impeccable.md in the project root. If the file already exists, update the Design Context section in place without destroying other content." ;
    oc:hasRationale "Preserving existing file content while updating the relevant section prevents accidental data loss" ;
    oc:severityLevel "HIGH" .

oc:kn_dd3f5d4a a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When .impeccable.md already exists" ;
    oc:directiveContent "This skill is designed to be run once. If run again, it should update the existing Design Context section in place rather than create duplicates." ;
    oc:hasRationale "Repeated runs should refine the design context, not accumulate duplicate sections" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e48aea7e a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During the user interview phase (Step 2)" ;
    oc:directiveContent "Skip questions where the answer is already clear from the codebase exploration — only ask what you could not infer." ;
    oc:hasRationale "Respects the user's time and avoids redundant questions that waste cognitive effort" ;
    oc:severityLevel "MEDIUM" .

_:ref_27c8538420005a06 a oc:WorkflowStep ;
    dcterms:description "Ask the user targeted questions about Users & Purpose, Brand & Personality, Aesthetic Preferences, and Accessibility — only for things that couldn't be inferred from the codebase" ;
    oc:expectedOutcome "Clarified design preferences covering user context, brand voice, visual direction, and accessibility requirements" ;
    oc:stepDependsOn _:ref_a53c8af46d97e7aa ;
    oc:stepId "ask-ux-questions" .

_:ref_a53c8af46d97e7aa a oc:WorkflowStep ;
    dcterms:description "Thoroughly scan the project: README, docs, package.json, config files, existing components, brand assets, design tokens, CSS variables, style guides" ;
    oc:expectedOutcome "Comprehensive understanding of existing design patterns, tech stack, and brand identity" ;
    oc:stepId "explore-codebase" .

