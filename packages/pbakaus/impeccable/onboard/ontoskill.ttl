    dcterms:identifier "onboard" ;
    skos:broader "Frontend design skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/onboard" ;
    oc:contentHash "03956ec80338e3c646b6c9ca4ae74d96417af362ae72730c9da6653d35fc1916" ;
    oc:dependsOnSkill oc:skill_teach_impeccable ;
    oc:differentia "specializes in onboarding flows, empty states, and first-run experiences that accelerate user activation and time to value" ;
