                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Spotlight specific UI elements (dim rest of page)" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
