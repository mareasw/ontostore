                            oc:contentOrder 2 ;
                            oc:textContent "**Storage patterns**:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**IMPORTANT**: Don't show same onboarding twice (annoying). Track completion and respect dismissals." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Technical approaches:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 6 ;
            oc:sectionTitle "Implementation Patterns" ],
