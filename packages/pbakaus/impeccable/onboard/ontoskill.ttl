                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Force users through long onboarding before they can use product" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "Hide \"Skip\" or make it hard to find" ] ],
                        [ a oc:Paragraph ;
