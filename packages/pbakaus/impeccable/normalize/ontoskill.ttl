@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_normalize a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "normalize" ;
    skos:broader "UI normalization skill" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/normalize" ;
    oc:contentHash "811fd4533d311bc14bbff035655bd489022a869c45926205fc3792ce49b76f79" ;
    oc:dependsOnSkill oc:skill_ontoskills_frontend_design,
        oc:skill_ontoskills_teach_impeccable ;
    oc:differentia "that audits and realigns frontend features to match design system standards, tokens, and patterns" ;
    oc:handlesFailure oc:FileNotFound ;
    oc:hasAllowedTool "Edit",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "[feature (page, route, component...)]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Audits and realigns UI to match design system standards, spacing, tokens, and patterns. Use when the user mentions consistency, design drift, mismatched styles, tokens, or wants to bring a feature back in line with the system." ;
    oc:hasName "normalize" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Components**: Replace custom implementations with design system components. Ensure props and variants match established patterns." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Spacing & Layout**: Use spacing tokens (margins, padding, gaps). Align with grid systems and layout patterns used elsewhere." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 7 ;
                            oc:itemText "**Accessibility**: Verify contrast ratios, focus states, ARIA labels match design system requirements." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "**Motion & Interaction**: Match animation timing, easing, and interaction patterns to other features." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Color & Theme**: Apply design system color tokens. Remove one-off color choices that break the palette." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 6 ;
                            oc:itemText "**Responsive Behavior**: Ensure breakpoints and responsive patterns align with design system standards." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Typography**: Use design system fonts, sizes, weights, and line heights. Replace hard-coded values with typographic tokens or classes." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 8 ;
                            oc:itemText "**Progressive Disclosure**: Match information hierarchy and complexity management to established patterns." ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**NEVER**:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 5 ;
                    oc:textContent "This is not an exhaustive list—apply judgment to identify all areas needing normalization." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Systematically address all inconsistencies across these dimensions:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 4 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Hard-code values that should use design tokens" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Introduce new patterns that diverge from the design system" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Compromise accessibility for visual consistency" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Create new one-off components when design system equivalents exist" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Execute" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Before making changes, deeply understand the context:" ],
                _:ref_dedb2ccd7e4665ea ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Plan" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Invoke /frontend-design — it contains design principles, anti-patterns, and the **Context Gathering Protocol**. Follow the protocol before proceeding — if no design context exists yet, you MUST run /teach-impeccable first." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "MANDATORY PREPARATION" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "After normalization, ensure code quality:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Verify quality**: Lint, type-check, and test according to repository guidelines. Ensure normalization didn't introduce regressions." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Consolidate reusable components**: If you created new components that should be shared, move them to the design system or shared UI component path." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Remove orphaned code**: Delete unused implementations, styles, or files made obsolete by normalization." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Ensure DRYness**: Look for duplication introduced during refactoring and consolidate." ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "Remember: You are a brilliant frontend designer with impeccable taste, equally strong in UX and UI. Your attention to detail and eye for end-to-end user experience is world class. Execute with precision and thoroughness." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Clean Up" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Analyze and redesign the feature to perfectly match our design system standards, aesthetics, and established patterns." ],
                [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: normalize
description: Audits and realigns UI to match design system standards, spacing, tokens, and patterns. Use when the user mentions consistency, design drift, mismatched styles, tokens, or wants to bring a feature back in line with the system.
user-invocable: true
argument-hint: "[feature (page, route, component...)]"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Audit and realign a UI feature to match design system standards across all dimensions" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Consolidate reusable components, remove orphaned code, lint, type-check, test, ensure DRY." ;
                    oc:expectedOutcome "Clean codebase with no regressions" ;
                    oc:stepDependsOn _:ref_e692966e1aa4c084 ;
                    oc:stepId "cleanup" ],
                _:ref_26776e5a70cdeebb,
                _:ref_2b0fa6b9ee47c36c,
                _:ref_8d6c7ad622ed8e81,
                _:ref_d2eaa6a7895afe77,
                _:ref_e692966e1aa4c084 ;
            oc:workflowId "normalize-workflow" ;
            oc:workflowName "Normalize Feature to Design System" ],
        _:ref_dedb2ccd7e4665ea ;
    oc:impartsKnowledge oc:kn_06f1e78e,
        oc:kn_1e3a9183,
        oc:kn_2ed638de,
        oc:kn_3f6e1fc9,
        oc:kn_9c0d8429,
        oc:kn_d003ee8c,
        oc:kn_e3945052,
        oc:kn_e7873f02 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:EnvironmentReady ;
    oc:resolvesIntent "align components with design tokens and patterns",
        "audit UI for design system compliance",
        "fix design drift and inconsistent styles",
        "normalize UI to design system standards" ;
    oc:yieldsState oc:DocumentCreated .

oc:kn_06f1e78e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When discovering and interpreting design system documentation" ;
    oc:directiveContent "If something isn't clear about the design system, ask the user. Never guess at design system principles." ;
    oc:hasRationale "Incorrect assumptions about design system principles lead to misaligned normalization that creates more drift" ;
    oc:severityLevel "CRITICAL" .

oc:kn_1e3a9183 a oc:KnowledgeNode,
        oc:Prerequisite ;
    oc:appliesToContext "Before normalization begins" ;
    oc:directiveContent "Design context must exist — if not, run /teach-impeccable first to establish project design context." .

oc:kn_2ed638de a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "Post-normalization cleanup phase" ;
    oc:directiveContent "After normalization, consolidate reusable components into the design system, remove orphaned code, lint, type-check, test, and ensure no regressions were introduced." ;
    oc:hasRationale "Normalization refactoring can leave behind dead code, duplication, and regressions that undermine code quality" ;
    oc:severityLevel "MEDIUM" .

oc:kn_3f6e1fc9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating the normalization plan" ;
    oc:directiveContent "Prioritize UX consistency and usability over visual polish alone. Think through the best possible experience for the use case and personas first." ;
    oc:hasRationale "Visual consistency without UX alignment leads to superficial fixes that don't address root cause misalignment" ;
    oc:severityLevel "HIGH" .

oc:kn_9c0d8429 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "During normalization execution across all dimensions" ;
    oc:directiveContent "Never create new one-off components when design system equivalents exist, hard-code values that should use design tokens, introduce divergent patterns, or compromise accessibility for visual consistency." ;
    oc:hasRationale "These actions directly contradict the purpose of normalization and reintroduce the problems being solved" ;
    oc:severityLevel "CRITICAL" .

oc:kn_d003ee8c a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Execution phase of normalization" ;
    oc:directiveContent "Normalize across 8 dimensions: Typography (fonts/sizes/weights → tokens), Color & Theme (palette tokens), Spacing & Layout (margin/padding/gap tokens + grid), Components (system equivalents + matching props), Motion & Interaction (timing/easing patterns), Responsive Behavior (breakpoint alignment), Accessibility (contrast/focus/ARIA), Progressive Disclosure (hierarchy patterns)." ;
    oc:stepOrder 2 .

oc:kn_e3945052 a oc:KnowledgeNode,
        oc:Procedure ;
    oc:appliesToContext "Full normalization workflow" ;
    oc:directiveContent "1. Invoke /frontend-design for design principles and Context Gathering Protocol. 2. Discover design system (grep for docs, study tokens/patterns). 3. Analyze current feature for deviations. 4. Create normalization plan (component replacements, token usage, UX alignment). 5. Execute across dimensions (typography, color, spacing, components, motion, responsive, a11y). 6. Clean up (consolidate, remove orphans, lint, test, ensure DRY)." ;
    oc:stepOrder 1 .

oc:kn_e7873f02 a oc:AssumptionBoundary,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting normalization" ;
    oc:directiveContent "Assumes the project has an existing design system with defined tokens, components, and patterns. If no design context exists, teach-impeccable must be run first." ;
    oc:hasRationale "Normalization requires a reference standard; without design context, there is nothing to normalize against" ;
    oc:severityLevel "HIGH" .

_:ref_29a3229c311ee7a8 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 3 ;
    oc:itemText "Component patterns and conventions" .

_:ref_2a3a5cc22531a158 a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 2 ;
            oc:itemText "Which inconsistencies are cosmetic vs. functional?" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 3 ;
            oc:itemText "What's the root cause—missing tokens, one-off implementations, or conceptual misalignment?" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 1 ;
            oc:itemText "Where does it deviate from design system patterns?" ] .

_:ref_32291d694adafbf6 a oc:WorkflowStep ;
    dcterms:description "**Discover the design system**: Search for design system documentation, UI guidelines, component libraries, or style guides (grep for \"design system\", \"ui guide\", \"style guide\", etc.). Study it thoroughly until you understand:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:Paragraph ;
            oc:blockType "paragraph" ;
            oc:contentOrder 2 ;
            oc:textContent "**CRITICAL**: If something isn't clear, ask. Don't guess at design system principles." ],
        [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem _:ref_29a3229c311ee7a8,
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 2 ;
                    oc:itemText "Target audience and personas" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 4 ;
                    oc:itemText "Design tokens (colors, typography, spacing)" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 1 ;
                    oc:itemText "Core design principles and aesthetic direction" ] ] ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_69d4abfe146ea888 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "Which styles need to use design tokens instead of hard-coded values?" .

_:ref_a61c0dc87f00fb7b a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem _:ref_69d4abfe146ea888,
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 3 ;
            oc:itemText "How can UX patterns match established user flows?" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 1 ;
            oc:itemText "Which components can be replaced with design system equivalents?" ] .

_:ref_a7c1c4c4d7175d87 a oc:Paragraph ;
    oc:blockType "paragraph" ;
    oc:contentOrder 2 ;
    oc:textContent "**IMPORTANT**: Great design is effective design. Prioritize UX consistency and usability over visual polish alone. Think through the best possible experience for your use case and personas first." .

_:ref_c6e704cf48a81f83 a oc:WorkflowStep ;
    dcterms:description "**Create a normalization plan**: Define specific changes that will align the feature with the design system:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild _:ref_a61c0dc87f00fb7b,
        _:ref_a7c1c4c4d7175d87 ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_fca7f8874c3ec5c6 a oc:WorkflowStep ;
    dcterms:description "**Analyze the current feature**: Assess what works and what doesn't:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild _:ref_2a3a5cc22531a158 ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_26776e5a70cdeebb a oc:WorkflowStep ;
    dcterms:description "Define specific normalization changes: component replacements, token usage, UX pattern alignment." ;
    oc:expectedOutcome "Concrete normalization plan" ;
    oc:stepDependsOn _:ref_2b0fa6b9ee47c36c ;
    oc:stepId "create-plan" .

_:ref_2b0fa6b9ee47c36c a oc:WorkflowStep ;
    dcterms:description "Assess where the feature deviates from design system — cosmetic vs functional inconsistencies, root causes." ;
    oc:expectedOutcome "Gap analysis identifying all deviations" ;
    oc:stepDependsOn _:ref_d2eaa6a7895afe77 ;
    oc:stepId "analyze-current-feature" .

_:ref_8d6c7ad622ed8e81 a oc:WorkflowStep ;
    dcterms:description "Invoke /frontend-design for design principles, anti-patterns, and Context Gathering Protocol. Run /teach-impeccable if no design context exists." ;
    oc:expectedOutcome "Design context loaded and understood" ;
    oc:stepId "gather-context" .

_:ref_d2eaa6a7895afe77 a oc:WorkflowStep ;
    dcterms:description "Search for design system documentation, UI guidelines, component libraries. Study core principles, tokens, patterns." ;
    oc:expectedOutcome "Complete understanding of design system standards" ;
    oc:stepDependsOn _:ref_8d6c7ad622ed8e81 ;
    oc:stepId "discover-design-system" .

_:ref_dedb2ccd7e4665ea a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_32291d694adafbf6,
        _:ref_c6e704cf48a81f83,
        _:ref_fca7f8874c3ec5c6 ;
    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_e692966e1aa4c084 a oc:WorkflowStep ;
    dcterms:description "Systematically address typography, color, spacing, components, motion, responsive, a11y, and progressive disclosure." ;
    oc:expectedOutcome "Feature aligned with design system across all dimensions" ;
    oc:stepDependsOn _:ref_26776e5a70cdeebb ;
    oc:stepId "execute-normalization" .

