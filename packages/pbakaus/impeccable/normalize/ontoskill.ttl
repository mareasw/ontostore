@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_normalize a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "normalize" ;
    skos:broader "design system alignment skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/normalize" ;
    oc:contentHash "811fd4533d311bc14bbff035655bd489022a869c45926205fc3792ce49b76f79" ;
    oc:dependsOnSkill oc:skill_teach_impeccable ;
    oc:differentia "audits and realigns UI features to match established design system standards, tokens, and patterns, eliminating design drift and inconsistencies" ;
    oc:extends oc:skill_frontend_design ;
    oc:handlesFailure oc:DesignSystemNotFound,
        oc:InvalidInput,
        oc:RegressionDetected ;
    oc:hasArgumentHint "[feature (page, route, component...)]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Audits and realigns UI to match design system standards, spacing, tokens, and patterns. Use when the user mentions consistency, design drift, mismatched styles, tokens, or wants to bring a feature back in line with the system." ;
    oc:hasName "normalize" ;
    oc:impartsKnowledge oc:kn_3f6e1fc9,
        oc:kn_47b1ffb9,
        oc:kn_5e83c5d5,
        oc:kn_9c0d8429,
        oc:kn_fbe3f576 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextEstablished,
        oc:EnvironmentReady ;
    oc:resolvesIntent "align component styles with design tokens",
        "audit feature for design system compliance",
        "fix design drift and inconsistencies",
        "normalize UI to design system",
        "replace hard-coded styles with design tokens" ;
    oc:yieldsState oc:DesignSystemCompliant,
        oc:DesignTokensApplied .

oc:kn_3f6e1fc9 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When creating the normalization plan and executing changes" ;
    oc:directiveContent "Prioritize UX consistency and usability over visual polish alone. Think through the best possible experience for the use case and personas first." ;
    oc:hasRationale "Visual consistency without UX coherence leads to interfaces that look uniform but feel wrong. True normalization aligns interaction patterns, not just visual styles." ;
    oc:severityLevel "HIGH" .

oc:kn_47b1ffb9 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After all normalization changes are applied" ;
    oc:directiveContent "After normalization, consolidate reusable components into the design system path, remove orphaned code, lint/type-check/test for regressions, and ensure DRYness across the refactored code." ;
    oc:hasRationale "Normalization is incomplete if it leaves behind dead code, duplicated logic, or introduces regressions. The cleanup phase ensures the refactor is a net improvement." ;
    oc:severityLevel "MEDIUM" .

oc:kn_5e83c5d5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When encountering ambiguous or undocumented design system rules" ;
    oc:directiveContent "If design system principles are unclear, ask the user for clarification rather than guessing. Systematically normalize across typography, color, spacing, components, motion, responsiveness, accessibility, and progressive disclosure." ;
    oc:hasRationale "Guessing at design system principles leads to misaligned normalizations that may need to be undone, wasting effort and potentially introducing new inconsistencies." ;
    oc:severityLevel "HIGH" .

oc:kn_9c0d8429 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When normalizing any UI feature against a design system" ;
    oc:directiveContent "Never create new one-off components when design system equivalents exist, hard-code values that should use design tokens, introduce divergent patterns, or compromise accessibility for visual consistency." ;
    oc:hasRationale "These anti-patterns perpetuate the exact design drift the skill is meant to eliminate, creating new technical debt while fixing old debt." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fbe3f576 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Always, before beginning normalization work" ;
    oc:directiveContent "Before making any changes, discover and thoroughly study the design system documentation, component libraries, and style guides. If design context doesn't exist yet, run /teach-impeccable first." ;
    oc:hasRationale "Without a complete understanding of the design system's tokens, patterns, and principles, normalization will be based on guesses rather than authoritative standards." ;
    oc:severityLevel "HIGH" .

