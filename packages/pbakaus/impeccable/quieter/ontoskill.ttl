@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_quieter a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "quieter" ;
    skos:broader "Design refinement tool" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/quieter" ;
    oc:contentHash "88858dd13281faa3791ec3669bff2a069cb210ccc2568a8250624ce24c5d9ad4" ;
    oc:contradicts oc:skill_ontoskills_bolder ;
    oc:dependsOnSkill oc:skill_ontoskills_teach_impeccable ;
    oc:differentia "Reduces visual intensity and overstimulation in UI designs while preserving quality, functionality, and character through systematic desaturation, simplification, and restraint" ;
    oc:extends oc:skill_ontoskills_frontend_design ;
    oc:handlesFailure oc:InvalidInput,
        oc:NoDesignContext ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "design" ;
    oc:hasDescription "Tones down visually aggressive or overstimulating designs, reducing intensity while preserving quality. Use when the user mentions too bold, too loud, overwhelming, aggressive, garish, or wants a calmer, more refined aesthetic." ;
    oc:hasName "quieter" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: quieter
description: Tones down visually aggressive or overstimulating designs, reducing intensity while preserving quality. Use when the user mentions too bold, too loud, overwhelming, aggressive, garish, or wants a calmer, more refined aesthetic.
user-invocable: true
argument-hint: "[target]"
""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Reduce visual intensity in designs that are too bold, aggressive, or overstimulating, creating a more refined and approachable aesthetic without losing effectiveness." ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Ensure refinement maintains quality:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "Remember: Quiet design is confident design. It doesn't need to shout. Less is more, but less is also harder. Refine with precision and maintain intentionality." ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Sophistication**: Does it feel more refined and premium?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Better reading**: Is text easier to read for extended periods?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Still functional**: Can users still accomplish tasks easily?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Still distinctive**: Does it have character, or is it generic now?" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 5 ;
            oc:sectionTitle "Verify Quality" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "If any of these are unclear from the codebase, ask the user directly to clarify what you cannot infer." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**CRITICAL**: \"Quieter\" doesn't mean boring or generic. It means refined, sophisticated, and easier on the eyes. Think luxury, not laziness." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Analyze what makes the design feel too intense:" ],
                _:ref_7cfddc12922c801b ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Assess Current State" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Color approach**: Desaturate or shift to more sophisticated tones?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Sophistication approach**: How can we signal quality through restraint?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Hierarchy approach**: Which elements should stay bold (very few), which should recede?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Simplification approach**: What can be removed entirely?" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Create a strategy to reduce intensity while maintaining impact:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**IMPORTANT**: Great quiet design is harder than great bold design. Subtlety requires precision." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Plan Refinement" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 3 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Eliminate all personality (maintain character through refinement)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "Make everything small and light (some anchors needed)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Remove all color (quiet ≠ grayscale)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Make everything the same size/weight (hierarchy still matters)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Sacrifice usability for aesthetics (functional elements still need clear affordances)" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**NEVER**:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Systematically reduce intensity across these dimensions:" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Reduce saturation**: Shift from fully saturated to 70-85% saturation" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Soften palette**: Replace bright colors with muted, sophisticated tones" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "**Never gray on color**: If you have gray text on a colored background, use a darker shade of that color or transparency instead" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Reduce color variety**: Use fewer colors more thoughtfully" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Tinted grays**: Use warm or cool tinted grays instead of pure gray—adds sophistication without loudness" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Gentler contrasts**: High contrast only where it matters most" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Neutral dominance**: Let neutrals do more work, use color as accent (10% rule)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Color Refinement" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**White space**: Increase breathing room, reduce density" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Hierarchy through subtlety**: Use weight, size, and space instead of color and boldness" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Typography**: Reduce font weights (900 → 600, 700 → 500), decrease sizes where appropriate" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Borders & lines**: Reduce thickness, decrease opacity, or remove entirely" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Visual Weight Reduction" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Simplify shapes**: Reduce border radius extremes, simplify custom shapes" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Reduce layering**: Flatten visual hierarchy where possible" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Clean up effects**: Reduce or remove blur effects, glows, multiple shadows" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Remove decorative elements**: Gradients, shadows, patterns, textures that don't serve purpose" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Simplification" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Refined easing**: Use ease-out-quart for smooth, understated motion—never bounce or elastic" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Remove animations entirely** if they're not serving a clear purpose" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Remove decorative animations**: Keep functional motion, remove flourishes" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Subtle micro-interactions**: Replace dramatic effects with gentle feedback" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Reduce animation intensity**: Shorter distances (10-20px instead of 40px), gentler easing" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Motion Reduction" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Reduce scale jumps**: Smaller contrast between sizes creates calmer feeling" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Align to grid**: Bring rogue elements back into systematic alignment" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Even out spacing**: Replace extreme spacing variations with consistent rhythm" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Composition Refinement" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Refine the Design" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Invoke /frontend-design — it contains design principles, anti-patterns, and the **Context Gathering Protocol**. Follow the protocol before proceeding — if no design context exists yet, you MUST run /teach-impeccable first." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "MANDATORY PREPARATION" ] ;
    oc:hasWorkflow _:ref_7cfddc12922c801b,
        [ a oc:Workflow ;
            dcterms:description "Systematic process to reduce visual intensity while preserving quality and character" ;
            oc:hasStep _:ref_9d1c0e2e5ce62be2,
                [ a oc:WorkflowStep ;
                    dcterms:description "Validate that refinement maintains functionality, distinctiveness, readability, and sophistication." ;
                    oc:expectedOutcome "Confirmed quality — design is quieter but not degraded" ;
                    oc:stepDependsOn _:ref_d665c91a2db2cf1b ;
                    oc:stepId "verify" ],
                _:ref_c9f3463238746799,
                _:ref_d665c91a2db2cf1b,
                _:ref_f978a91ce633f728 ;
            oc:workflowId "quieter-refinement" ;
            oc:workflowName "Quieter Design Refinement" ] ;
    oc:impartsKnowledge oc:kn_6c39b8fc,
        oc:kn_778757c6,
        oc:kn_b1c8fd9a,
        oc:kn_e317ae3f,
        oc:kn_f7c39f66,
        oc:kn_fbf510a1,
        oc:kn_fc53b552,
        oc:kn_fdd80a92 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextEstablished,
        oc:SourceCodeAccessible ;
    oc:resolvesIntent "create calmer refined aesthetic",
        "desaturate overstimulating interfaces",
        "reduce visual intensity",
        "simplify overwhelming visual layouts",
        "tone down aggressive designs" ;
    oc:yieldsState oc:DesignRefined,
        oc:VisualIntensityReduced .

oc:kn_6c39b8fc a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When refining color palettes for quieter design" ;
    oc:directiveContent "Reduce saturation to 70-85%, let neutrals do more work, use color as accent (10% rule), and use tinted grays instead of pure gray." ;
    oc:hasRationale "Muted, sophisticated tones signal quality through restraint while maintaining visual interest." .

oc:kn_778757c6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reducing visual weight in typography and layout" ;
    oc:directiveContent "Reduce font weights systematically (900→600, 700→500), use weight/size/space for hierarchy instead of color and boldness, and increase white space to reduce density." ;
    oc:hasRationale "Subtle hierarchy through weight and spacing is more sophisticated than relying on color intensity or boldness." .

oc:kn_b1c8fd9a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reducing motion intensity" ;
    oc:directiveContent "Use ease-out-quart for smooth understated motion. Never use bounce or elastic easing. Reduce animation distances (10-20px instead of 40px). Remove animations entirely if they serve no clear purpose." ;
    oc:hasRationale "Dramatic easing functions undermine quiet aesthetic; gentle motion preserves feedback without visual aggression." ;
    oc:severityLevel "HIGH" .

oc:kn_e317ae3f a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing design refinement" ;
    oc:directiveContent "Verify refinement maintains: functionality (users can still accomplish tasks), distinctiveness (character is preserved), readability (text easier for extended periods), and sophistication (feels refined and premium)." ;
    oc:hasRationale "Quality validation ensures 'quieter' didn't become 'worse' — the refinement must improve the design, not degrade it." .

oc:kn_f7c39f66 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning and executing quiet refinement" ;
    oc:directiveContent "Great quiet design is harder than great bold design. Subtlety requires precision. Think luxury, not laziness." ;
    oc:hasRationale "With fewer dramatic elements, every remaining detail carries more weight and must be precisely intentional." .

oc:kn_fbf510a1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When refining designs to be quieter" ;
    oc:directiveContent "NEVER make everything the same size/weight, remove all color, eliminate all personality, sacrifice usability for aesthetics, or make everything small and light. Hierarchy, color, character, and functional affordances must be preserved." ;
    oc:hasRationale "'Quiet' means refined and sophisticated, not boring or generic. Removing all visual distinction defeats the purpose of design." ;
    oc:severityLevel "CRITICAL" .

oc:kn_fc53b552 a oc:KnowledgeNode,
        oc:RequiresHumanClarification ;
    oc:appliesToContext "During initial assessment of current design state" ;
    oc:directiveContent "If design purpose (marketing vs tool vs reading), audience expectations, what's working, or core message are unclear from the codebase, ask the user directly." ;
    oc:hasRationale "Context determines how aggressively to quiet the design; some contexts legitimately need energy." .

oc:kn_fdd80a92 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adjusting text colors during quiet refinement" ;
    oc:directiveContent "Never use gray text on a colored background — use a darker shade of that color or transparency instead." ;
    oc:hasRationale "Gray on color creates visual dissonance; tinted transparency maintains cohesion within the color system." ;
    oc:severityLevel "HIGH" .

_:ref_11f701df92d983b3 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "**Contrast extremes**: Too much high-contrast juxtaposition" .

_:ref_220eea282f812166 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
    oc:itemText "**Color saturation**: Overly bright or saturated colors" .

_:ref_236ba3c3289667d1 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 4 ;
    oc:itemText "What's the core message? (Preserve what matters)" .

_:ref_29e297d3cc1c2656 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
    oc:itemText "What's the purpose? (Marketing vs tool vs reading experience)" .

_:ref_5c3310ee36301461 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "Who's the audience? (Some contexts need energy)" .

_:ref_5c7d61889b2bb95e a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 5 ;
    oc:itemText "**Complexity**: Too many visual elements, patterns, or decorations" .

_:ref_6206499a2dcd151f a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 4 ;
    oc:itemText "**Animation excess**: Too much motion or overly dramatic effects" .

_:ref_65fa7e0b0baab2ba a oc:WorkflowStep ;
    dcterms:description "**Identify intensity sources**:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem _:ref_11f701df92d983b3,
                _:ref_220eea282f812166,
                _:ref_5c7d61889b2bb95e,
                _:ref_6206499a2dcd151f,
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 3 ;
                    oc:itemText "**Visual weight**: Too many bold, heavy elements competing" ],
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 6 ;
                    oc:itemText "**Scale**: Everything is large and loud with no hierarchy" ] ] ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_7f222b1cef5b4700 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 3 ;
    oc:itemText "What's working? (Don't throw away good ideas)" .

_:ref_cbc0796ec4dfabdc a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem _:ref_236ba3c3289667d1,
        _:ref_29e297d3cc1c2656,
        _:ref_5c3310ee36301461,
        _:ref_7f222b1cef5b4700 .

_:ref_d5ce6dd3e0a5b596 a oc:WorkflowStep ;
    dcterms:description "**Understand the context**:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild _:ref_cbc0796ec4dfabdc ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_7cfddc12922c801b a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_65fa7e0b0baab2ba,
        _:ref_d5ce6dd3e0a5b596 ;
    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_9d1c0e2e5ce62be2 a oc:WorkflowStep ;
    dcterms:description "Invoke /frontend-design and follow Context Gathering Protocol. Run /teach-impeccable if no design context exists." ;
    oc:expectedOutcome "Design context and principles are loaded" ;
    oc:stepId "prepare" .

_:ref_c9f3463238746799 a oc:WorkflowStep ;
    dcterms:description "Identify intensity sources (color saturation, contrast extremes, visual weight, animation excess, complexity, scale) and understand context (purpose, audience, what works, core message)." ;
    oc:expectedOutcome "Clear understanding of what makes the design feel too intense" ;
    oc:stepDependsOn _:ref_9d1c0e2e5ce62be2 ;
    oc:stepId "assess" .

_:ref_d665c91a2db2cf1b a oc:WorkflowStep ;
    dcterms:description "Systematically reduce intensity across color (saturation 70-85%, 10% accent rule, tinted grays), visual weight (reduce font weights, increase whitespace), simplification (remove decorative elements, flatten hierarchy), motion (shorter distances, ease-out-quart), and composition (reduce scale jumps, align grid, even spacing)." ;
    oc:expectedOutcome "Design code updated with reduced visual intensity" ;
    oc:stepDependsOn _:ref_f978a91ce633f728 ;
    oc:stepId "refine" .

_:ref_f978a91ce633f728 a oc:WorkflowStep ;
    dcterms:description "Create strategy across four dimensions: color approach (desaturate/shift tones), hierarchy approach (which elements recede), simplification approach (what to remove), sophistication approach (quality through restraint)." ;
    oc:expectedOutcome "Refinement strategy with specific decisions per dimension" ;
    oc:stepDependsOn _:ref_c9f3463238746799 ;
    oc:stepId "plan" .

