@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_quieter a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "quieter" ;
    skos:broader "Design refinement tool" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/quieter" ;
    oc:contentHash "88858dd13281faa3791ec3669bff2a069cb210ccc2568a8250624ce24c5d9ad4" ;
    oc:contradicts oc:skill_bolder ;
    oc:dependsOnSkill oc:skill_frontend_design ;
    oc:differentia "Reduces visual intensity in overstimulating designs by desaturating colors, simplifying elements, and reducing motion while preserving quality and functionality" ;
    oc:handlesFailure oc:DesignContextMissing,
        oc:OverSimplified ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "design" ;
    oc:hasDescription "Tones down visually aggressive or overstimulating designs, reducing intensity while preserving quality. Use when the user mentions too bold, too loud, overwhelming, aggressive, garish, or wants a calmer, more refined aesthetic." ;
    oc:hasName "quieter" ;
    oc:impartsKnowledge oc:kn_0aa60c7e,
        oc:kn_21a592c6,
        oc:kn_22ffc6e6,
        oc:kn_84aa1c1c,
        oc:kn_88df0df7,
        oc:kn_993f4ffe,
        oc:kn_d30d2f88 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextGathered ;
    oc:resolvesIntent "calm overstimulating interfaces",
        "make designs more sophisticated and approachable",
        "reduce visual intensity",
        "refine bold aesthetics",
        "tone down aggressive designs" ;
    oc:yieldsState oc:DesignRefined,
        oc:VisualIntensityReduced .

oc:kn_0aa60c7e a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing design refinement" ;
    oc:directiveContent "After refinement, verify the design is still functional, still distinctive (not generic), better for reading, and more sophisticated." ;
    oc:hasRationale "These four checks ensure the quieting process improved rather than degraded the design, catching over-simplification early." ;
    oc:severityLevel "HIGH" .

oc:kn_21a592c6 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reducing visual intensity in any design" ;
    oc:directiveContent "Quiet design does not mean boring or generic — it means refined, sophisticated, and easier on the eyes. Think luxury, not laziness." ;
    oc:hasRationale "The goal is sophistication through restraint, not removal of all personality. Misunderstanding this leads to bland, lifeless designs." ;
    oc:severityLevel "CRITICAL" .

oc:kn_22ffc6e6 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reducing visual weight and animation intensity" ;
    oc:directiveContent "Reduce font weights by one or two steps (900→600, 700→500), shorten animation distances (10-20px instead of 40px), and use ease-out-quart for motion — never bounce or elastic." ;
    oc:hasRationale "Systematic reduction of weight and motion creates a calmer feel while maintaining functional hierarchy. Bounce/elastic easing undermines the quiet aesthetic." ;
    oc:severityLevel "MEDIUM" .

oc:kn_84aa1c1c a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adjusting color contrast on colored backgrounds" ;
    oc:directiveContent "Never gray on color — if you have gray text on a colored background, use a darker shade of that color or transparency instead." ;
    oc:hasRationale "Using unrelated grays on colored backgrounds creates visual dissonance and looks unpolished. Tinted or related colors maintain cohesion." ;
    oc:severityLevel "HIGH" .

oc:kn_88df0df7 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When refining color palettes for quieter aesthetics" ;
    oc:directiveContent "Use tinted grays (warm or cool) instead of pure gray to add sophistication without loudness. Apply the 10% color rule — let neutrals dominate with color only as accent." ;
    oc:hasRationale "Pure grays feel lifeless; tinted grays add subtle warmth or coolness. Restricting color to accents creates a calm but intentional palette." ;
    oc:severityLevel "MEDIUM" .

oc:kn_993f4ffe a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any design refinement" ;
    oc:directiveContent "Before toning down, identify the core intensity sources (color saturation, contrast extremes, visual weight, animation excess, complexity, scale) and understand context (purpose, audience, what's working, core message)." ;
    oc:hasRationale "Without understanding what makes the design feel intense and why, refinement risks removing the wrong elements or losing what works." ;
    oc:severityLevel "HIGH" .

oc:kn_d30d2f88 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When simplifying or toning down any design element" ;
    oc:directiveContent "Never make everything the same size/weight, remove all color, eliminate all personality, sacrifice usability for aesthetics, or make everything small and light." ;
    oc:hasRationale "These mistakes destroy visual hierarchy, remove character, and degrade usability — the opposite of refined design." ;
    oc:severityLevel "CRITICAL" .

