    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/frontend-design" ;
    oc:contentHash "2ad4a7f0d48816cd042c273db387597100010f0016e75581359196b1366f2d65" ;
    oc:dependsOnSkill oc:skill_teach_impeccable ;
    oc:differentia "generates distinctive, production-grade UI code with exceptional aesthetic quality, deliberately avoiding generic AI-generated design patterns through bold aesthetic direction, modern CSS techniques, and comprehensive design reference knowledge" ;
