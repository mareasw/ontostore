@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_frontend_design a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "frontend-design" ;
    skos:broader "frontend interface generator" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/frontend-design" ;
    oc:contentHash "2ad4a7f0d48816cd042c273db387597100010f0016e75581359196b1366f2d65" ;
    oc:dependsOnSkill oc:skill_ontoskills_teach_impeccable ;
    oc:differentia "creates distinctive, production-grade UI code that avoids generic AI aesthetics through bold aesthetic direction and meticulous attention to design detail" ;
    oc:handlesFailure oc:AestheticDirectionUnclear,
        oc:DesignContextMissing ;
    oc:hasArgumentHint "description of the interface, component, or page to create" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Create distinctive, production-grade frontend interfaces with high design quality. Generates creative, polished code that avoids generic AI aesthetics. Use when the user asks to build web components, pages, artifacts, posters, or applications, or when any design skill requires project context." ;
    oc:hasName "frontend-design" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "Review the DON'T guidelines above—they are the fingerprints of AI-generated work from 2024-2025." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "**Critical quality check**: If you showed this interface to someone and said \"AI made this,\" would they believe you immediately? If yes, that's the problem." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "A distinctive interface should make someone ask \"how was this made?\" not \"which AI made this?\"" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 12 ;
            oc:sectionTitle "The AI Slop Test" ],
        [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Make interactions feel fast. Use optimistic UI—update immediately, sync later." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**DO**: Use progressive disclosure—start simple, reveal sophistication through interaction (basic options first, advanced behind expandable sections; hover states that reveal secondary actions)
**DO**: Design empty states that teach the interface, not just say "nothing here"
**DO**: Make every interactive surface feel intentional and responsive
**DON'T**: Repeat the same information—redundant headers, intros that restate the heading
**DON'T**: Make every button primary—use ghost buttons, text links, secondary styles; hierarchy matters""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "→ *Consult [interaction reference](reference/interaction-design.md) for forms, focus, and loading patterns.*" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 9 ;
                    oc:sectionTitle "Interaction" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Choose fonts that are beautiful, unique, and interesting. Pair a distinctive display font with a refined body font." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**DO**: Use a modular type scale with fluid sizing (clamp)
**DO**: Vary font weights and sizes to create clear visual hierarchy
**DON'T**: Use overused fonts—Inter, Roboto, Arial, Open Sans, system defaults
**DON'T**: Use monospace typography as lazy shorthand for "technical/developer" vibes
**DON'T**: Put large icons with rounded corners above every heading—they rarely add value and make sites look templated""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "→ *Consult [typography reference](reference/typography.md) for scales, pairing, and loading strategies.*" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Typography" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**DO**: Use container queries (@container) for component-level responsiveness
**DO**: Adapt the interface for different contexts—don't just shrink it
**DON'T**: Hide critical functionality on mobile—adapt the interface, don't amputate it""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "→ *Consult [responsive reference](reference/responsive-design.md) for mobile-first, fluid design, and container queries.*" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 10 ;
                    oc:sectionTitle "Responsive" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Focus on high-impact moments: one well-orchestrated page load with staggered reveals creates more delight than scattered micro-interactions." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "→ *Consult [motion reference](reference/motion-design.md) for timing, easing, and reduced motion.*" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**DO**: Use motion to convey state changes—entrances, exits, feedback
**DO**: Use exponential easing (ease-out-quart/quint/expo) for natural deceleration
**DO**: For height animations, use grid-template-rows transitions instead of animating height directly
**DON'T**: Animate layout properties (width, height, padding, margin)—use transform and opacity only
**DON'T**: Use bounce or elastic easing—they feel dated and tacky; real objects decelerate smoothly""" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "Motion" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**DO**: Create visual rhythm through varied spacing—tight groupings, generous separations
**DO**: Use fluid spacing with clamp() that breathes on larger screens
**DO**: Use asymmetry and unexpected compositions; break the grid intentionally for emphasis
**DON'T**: Wrap everything in cards—not everything needs a container
**DON'T**: Nest cards inside cards—visual noise, flatten the hierarchy
**DON'T**: Use identical card grids—same-sized cards with icon + heading + text, repeated endlessly
**DON'T**: Use the hero metric layout template—big number, small label, supporting stats, gradient accent
**DON'T**: Center everything—left-aligned text with asymmetric layouts feels more designed
**DON'T**: Use the same spacing everywhere—without rhythm, layouts feel monotonous""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Create visual rhythm through varied spacing—not the same padding everywhere. Embrace asymmetry and unexpected compositions. Break the grid intentionally for emphasis." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "→ *Consult [spatial reference](reference/spatial-design.md) for grids, rhythm, and container queries.*" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Layout & Space" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent """**DO**: Use modern CSS color functions (oklch, color-mix, light-dark) for perceptually uniform, maintainable palettes
**DO**: Tint your neutrals toward your brand hue—even a subtle hint creates subconscious cohesion
**DON'T**: Use gray text on colored backgrounds—it looks washed out; use a shade of the background color instead
**DON'T**: Use pure black (#000) or pure white (#fff)—always tint; pure black/white never appears in nature
**DON'T**: Use the AI color palette: cyan-on-dark, purple-to-blue gradients, neon accents on dark backgrounds
**DON'T**: Use gradient text for "impact"—especially on metrics or headings; it's decorative rather than meaningful
**DON'T**: Default to dark mode with glowing accents—it looks "cool" without requiring actual design decisions""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "→ *Consult [color reference](reference/color-and-contrast.md) for OKLCH, palettes, and dark mode.*" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Commit to a cohesive palette. Dominant colors with sharp accents outperform timid, evenly-distributed palettes." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Color & Theme" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "→ *Consult [ux-writing reference](reference/ux-writing.md) for labels, errors, and empty states.*" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent """**DO**: Make every word earn its place
**DON'T**: Repeat information users can already see""" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 11 ;
                    oc:sectionTitle "UX Writing" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent """**DO**: Use intentional, purposeful decorative elements that reinforce brand
**DON'T**: Use glassmorphism everywhere—blur effects, glass cards, glow borders used decoratively rather than purposefully
**DON'T**: Use rounded elements with thick colored border on one side—a lazy accent that almost never looks intentional
**DON'T**: Use sparklines as decoration—tiny charts that look sophisticated but convey nothing meaningful
**DON'T**: Use rounded rectangles with generic drop shadows—safe, forgettable, could be any AI output
**DON'T**: Use modals unless there's truly no better alternative—modals are lazy""" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "Visual Details" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Frontend Aesthetics Guidelines" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**CRITICAL**: Choose a clear conceptual direction and execute it with precision. Bold maximalism and refined minimalism both work—the key is intentionality, not intensity." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "Then implement working code that is:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Commit to a BOLD aesthetic direction:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Constraints**: Technical requirements (framework, performance, accessibility)." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Differentiation**: What makes this UNFORGETTABLE? What's the one thing someone will remember?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Tone**: Pick an extreme: brutally minimal, maximalist chaos, retro-futuristic, organic/natural, luxury/refined, playful/toy-like, editorial/magazine, brutalist/raw, art deco/geometric, soft/pastel, industrial/utilitarian, etc. There are so many flavors to choose from. Use these for inspiration but design one that is true to the aesthetic direction." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Purpose**: What problem does this interface solve? Who uses it?" ] ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 5 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Meticulously refined in every detail" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Visually striking and memorable" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Production-grade and functional" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Cohesive with a clear aesthetic point-of-view" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Design Direction" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**Required context** — every design skill needs at minimum:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 3 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Target audience**: Who uses this product and in what context?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Use cases**: What jobs are they trying to get done?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Brand personality/tone**: How should the interface feel?" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "Individual skills may require additional context — check the skill's preparation section for specifics." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 6 ;
                    oc:textContent "**Gathering order:**" ],
                _:ref_e7d1b8528523dbd6,
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 5 ;
                    oc:textContent "**CRITICAL**: You cannot infer this context by reading the codebase. Code tells you what was built, not who it's for or what it should feel like. Only the creator can provide this context." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Design skills produce generic output without project context. You MUST have confirmed design context before doing any design work." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Context Gathering Protocol" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "This skill guides creation of distinctive, production-grade frontend interfaces that avoid generic \"AI slop\" aesthetics. Implement real working code with exceptional attention to aesthetic details and creative choices." ],
                [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: frontend-design
description: Create distinctive, production-grade frontend interfaces with high design quality. Generates creative, polished code that avoids generic AI aesthetics. Use when the user asks to build web components, pages, artifacts, posters, or applications, or when any design skill requires project context.
license: Apache 2.0. Based on Anthropic's frontend-design skill. See NOTICE.md for attribution.
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Match implementation complexity to the aesthetic vision. Maximalist designs need elaborate code with extensive animations and effects. Minimalist or refined designs need restraint, precision, and careful attention to spacing, typography, and subtle details." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "Remember: the model is capable of extraordinary creative work. Don't hold back—show what can truly be created when thinking outside the box and committing fully to a distinctive vision." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Interpret creatively and make unexpected choices that feel genuinely designed for the context. No design should be the same. Vary between light and dark themes, different fonts, different aesthetics. NEVER converge on common choices across generations." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 13 ;
            oc:sectionTitle "Implementation Principles" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Complete workflow for creating a distinctive, production-grade frontend interface from request to delivery" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Apply the AI Slop Test: review the output against all DON'T guidelines to ensure the result doesn't look like generic AI-generated work" ;
                    oc:expectedOutcome "Interface passes the 'how was this made?' test rather than 'which AI made this?' test" ;
                    oc:stepDependsOn _:ref_2872b9d737b8143d ;
                    oc:stepId "ai-slop-test" ],
                _:ref_2872b9d737b8143d,
                _:ref_78e2af5d74254ad7,
                _:ref_ddc19f9ce1e1ee9a ;
            oc:workflowId "frontend-design-creation" ;
            oc:workflowName "Frontend Design Creation" ],
        _:ref_e7d1b8528523dbd6 ;
    oc:impartsKnowledge oc:kn_2b4963cd,
        oc:kn_33a61401,
        oc:kn_3f77d2f2,
        oc:kn_60de6f35,
        oc:kn_6f8db189,
        oc:kn_7bf53db9,
        oc:kn_9aefe2b6,
        oc:kn_a742cecf,
        oc:kn_ecd44005,
        oc:kn_fb5a40f5 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextAvailable ;
    oc:resolvesIntent "build web pages",
        "create distinctive web interfaces",
        "create frontend applications",
        "create web components",
        "design posters or visual artifacts",
        "generate production-grade UI code" ;
    oc:yieldsState oc:DesignDecisionMade,
        oc:FrontendCodeGenerated .

oc:kn_2b4963cd a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When selecting typography, colors, or spacing" ;
    oc:directiveContent "Never use overused fonts (Inter, Roboto, Arial, Open Sans, system defaults), pure black (#000) or pure white (#fff), or identical uniform spacing everywhere." ;
    oc:hasRationale "These choices signal lazy design and are hallmarks of AI-generated interfaces. Pure black/white don't exist in nature." ;
    oc:severityLevel "HIGH" .

oc:kn_33a61401 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any design task" ;
    oc:directiveContent "You MUST have confirmed design context (target audience, use cases, brand personality/tone) before doing any design work. Check instructions for Design Context section, then .impeccable.md, then run teach-impeccable if neither source has context." ;
    oc:hasRationale "Design skills produce generic output without project context. Code tells you what was built, not who it's for or what it should feel like." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3f77d2f2 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any motion or animation" ;
    oc:directiveContent "Always support prefers-reduced-motion: provide fade-in alternatives or disable animations entirely for users with vestibular disorders (~35% of adults over 40)." ;
    oc:hasRationale "Motion can cause nausea and disorientation for users with vestibular disorders. This is an accessibility requirement, not optional." ;
    oc:severityLevel "HIGH" .

oc:kn_60de6f35 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When starting any new design or interface creation" ;
    oc:directiveContent "Commit to a BOLD aesthetic direction with a clear purpose, extreme tone, defined constraints, and one UNFORGETTABLE differentiating element. Bold maximalism and refined minimalism both work—the key is intentionality, not intensity." ;
    oc:hasRationale "Generic, middle-of-the-road designs are instantly recognizable as AI output. Intentional extremes create memorable interfaces." ;
    oc:severityLevel "HIGH" .

oc:kn_6f8db189 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building color systems, responsive layouts, and spacing" ;
    oc:directiveContent "Use modern CSS: oklch/color-mix/light-dark for colors, container queries (@container) for component responsiveness, clamp() for fluid spacing, and tint neutrals toward the brand hue for subconscious cohesion." ;
    oc:hasRationale "Modern CSS features produce perceptually uniform palettes, component-level responsiveness, and visual cohesion that older methods cannot achieve." ;
    oc:severityLevel "MEDIUM" .

oc:kn_7bf53db9 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When designing layouts and component hierarchies" ;
    oc:directiveContent "Never wrap everything in cards, nest cards inside cards, use identical card grids (icon + heading + text repeated), use the hero metric layout template (big number + small label + gradient accent), or center everything." ;
    oc:hasRationale "These patterns are the most common AI-generated layout crutches that make designs look templated and indistinct." ;
    oc:severityLevel "HIGH" .

oc:kn_9aefe2b6 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing colors, visual elements, or theme direction" ;
    oc:directiveContent "Never use the AI slop palette: cyan-on-dark, purple-to-blue gradients, neon accents on dark backgrounds, glassmorphism everywhere, rounded rectangles with generic drop shadows, gradient text on headings, or dark mode with glowing accents as defaults." ;
    oc:hasRationale "These are the fingerprints of AI-generated work from 2024-2025 that make interfaces look generic and forgettable" ;
    oc:severityLevel "CRITICAL" .

oc:kn_a742cecf a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "During final design review before delivering code" ;
    oc:directiveContent "Apply the AI Slop Test: if you showed this interface to someone and said 'AI made this,' would they believe you immediately? If yes, the design fails. A distinctive interface should make someone ask 'how was this made?' not 'which AI made this?'" ;
    oc:hasRationale "The ultimate quality check for AI-generated design work—distinctiveness, not polish, is the primary success metric." ;
    oc:severityLevel "HIGH" .

oc:kn_ecd44005 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing the design in code" ;
    oc:directiveContent "Match implementation complexity to aesthetic vision: maximalist designs need elaborate animations and effects; minimalist designs need restraint, precision, and careful attention to spacing and typography subtleties. Never converge on common choices across generations." ;
    oc:hasRationale "Complexity mismatch between vision and implementation creates dissonance. Variation prevents convergence on a 'house style.'" ;
    oc:severityLevel "MEDIUM" .

oc:kn_fb5a40f5 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing CSS animations and transitions" ;
    oc:directiveContent "Animate only transform and opacity. For height animations, use grid-template-rows transitions instead of animating height directly. Use exponential easing (ease-out-quart/quint/expo), never bounce or elastic." ;
    oc:hasRationale "Animating layout properties causes expensive reflows. Exponential easing mimics natural physics; bounce/elastic feel dated." ;
    oc:severityLevel "MEDIUM" .

_:ref_0ff0f50b0e7cecd1 a oc:WorkflowStep ;
    dcterms:description "**Run teach-impeccable (REQUIRED)**: If neither source has context, you MUST run /teach-impeccable NOW before doing anything else. Do NOT skip this step. Do NOT attempt to infer context from the codebase instead." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_54c3cc8fb5724e9f a oc:WorkflowStep ;
    dcterms:description "**Check current instructions (instant)**: If your loaded instructions already contain a **Design Context** section, proceed immediately." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_9f994cb001d83560 a oc:WorkflowStep ;
    dcterms:description "**Check .impeccable.md (fast)**: If not in instructions, read `.impeccable.md` from the project root. If it exists and contains the required context, proceed." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_2872b9d737b8143d a oc:WorkflowStep ;
    dcterms:description "Implement production-grade, functional code applying typography, color (oklch), layout, motion, interaction, responsive, and UX writing guidelines while avoiding all AI slop patterns" ;
    oc:expectedOutcome "Working frontend code that is visually striking, cohesive, and meticulously refined" ;
    oc:stepDependsOn _:ref_78e2af5d74254ad7 ;
    oc:stepId "implement-code" .

_:ref_78e2af5d74254ad7 a oc:WorkflowStep ;
    dcterms:description "Commit to a BOLD aesthetic direction: define purpose, pick an extreme tone, identify constraints, and determine the one UNFORGETTABLE differentiating element" ;
    oc:expectedOutcome "Clear aesthetic direction with intentional tone and memorable differentiator" ;
    oc:stepDependsOn _:ref_ddc19f9ce1e1ee9a ;
    oc:stepId "commit-direction" .

_:ref_ddc19f9ce1e1ee9a a oc:WorkflowStep ;
    dcterms:description "Gather design context: check loaded instructions for Design Context section, then .impeccable.md, then run teach-impeccable if neither source has context" ;
    oc:expectedOutcome "Design context confirmed with target audience, use cases, and brand personality" ;
    oc:stepId "gather-context" .

_:ref_e7d1b8528523dbd6 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 7 ;
    oc:hasStep _:ref_0ff0f50b0e7cecd1,
        _:ref_54c3cc8fb5724e9f,
        _:ref_9f994cb001d83560 ;
    oc:workflowId "procedure_7" ;
    oc:workflowName "Ordered Procedure" .

