@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_adapt a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "adapt" ;
    skos:broader "Responsive design adapter" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/adapt" ;
    oc:contentHash "6c87d9864bc070fd2b0dbcb64acee9a8b9c822b457e62b070f47c28eaf6284ca" ;
    oc:dependsOnSkill oc:skill_frontend_design ;
    oc:differentia "Rethinks and implements designs for target contexts (mobile, tablet, desktop, print, email) using context-appropriate layout, interaction, content, and navigation strategies rather than mere scaling" ;
    oc:handlesFailure oc:AdaptationIncompatible,
        oc:ContextInsufficient ;
    oc:hasArgumentHint "[target] [context (mobile, tablet, print...)]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Adapt designs to work across different screen sizes, devices, contexts, or platforms. Implements breakpoints, fluid layouts, and touch targets. Use when the user mentions responsive design, mobile layouts, breakpoints, viewport adaptation, or cross-device compatibility." ;
    oc:hasName "adapt" ;
    oc:impartsKnowledge oc:kn_1b515f6f,
        oc:kn_1f587ce9,
        oc:kn_2a3ac246,
        oc:kn_33bcc022,
        oc:kn_6b55da8d,
        oc:kn_96653ccd,
        oc:kn_98b435ad,
        oc:kn_c40b9c6f ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextEstablished,
        oc:SourceDesignAvailable ;
    oc:resolvesIntent "adapt design for desktop",
        "adapt design for email",
        "adapt design for mobile",
        "adapt design for print",
        "adapt design for tablet",
        "add breakpoints to interface",
        "create viewport adaptation",
        "ensure cross-device compatibility",
        "implement touch-friendly design",
        "make responsive layout" ;
    oc:yieldsState oc:DesignAdaptedToContext,
        oc:ResponsiveBreakpointsImplemented .

oc:kn_1b515f6f a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing adaptations across multiple contexts" ;
    oc:directiveContent "Maintain consistent information architecture and brand identity across all contexts while using platform-native patterns for each target." ;
    oc:hasRationale "Different IA across contexts confuses users who switch devices; ignoring platform conventions breaks user expectations." ;
    oc:severityLevel "HIGH" .

oc:kn_1f587ce9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing responsive breakpoint values" ;
    oc:directiveContent "Prefer content-driven breakpoints over generic device breakpoints — set breakpoints where the design actually breaks, not at arbitrary pixel values." ;
    oc:hasRationale "Generic breakpoints may miss context-specific layout issues and create maintenance burden; content-driven breakpoints are more resilient to new device sizes." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2a3ac246 a oc:KnowledgeNode,
        oc:KnownIssue ;
    oc:appliesToContext "When making assumptions about device capabilities" ;
    oc:directiveContent "Do not assume desktop devices are always powerful — consider accessibility requirements and older machines, and do not ignore touch input on desktop (many desktop devices have touchscreens)." ;
    oc:hasRationale "Overgeneralizing device capabilities leads to broken experiences for users on hybrid or lower-powered devices." ;
    oc:severityLevel "MEDIUM" .

oc:kn_33bcc022 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning any cross-device adaptation" ;
    oc:directiveContent "Never treat adaptation as mere scaling — it requires rethinking the experience for each target context, including layout, interaction model, content hierarchy, and navigation patterns." ;
    oc:hasRationale "Simple scaling fails because different devices have fundamentally different input methods, screen constraints, user expectations, and usage contexts." ;
    oc:severityLevel "CRITICAL" .

oc:kn_6b55da8d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adapting any interface for touch-capable devices" ;
    oc:directiveContent "Touch targets must be minimum 44x44px and hover-dependent interactions must be replaced with touch-friendly alternatives on mobile/tablet." ;
    oc:hasRationale "Smaller touch targets cause mis-taps and frustration; hover states are inaccessible on touch devices." ;
    oc:severityLevel "HIGH" .

oc:kn_96653ccd a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any adaptation work" ;
    oc:directiveContent "Before adapting, identify the source context assumptions (screen size, input method, connection speed) and understand the target context's device, input method, screen constraints, connection, and user expectations." ;
    oc:hasRationale "Without understanding both source and target constraints, adaptations will be superficial and miss critical incompatibilities." ;
    oc:severityLevel "HIGH" .

oc:kn_98b435ad a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding what content to show or hide across breakpoints" ;
    oc:directiveContent "Never hide core functionality on mobile — if a feature matters, make it work in the mobile context rather than removing it." ;
    oc:hasRationale "Hiding features degrades the mobile experience and treats mobile users as second-class, violating the principle of content parity." ;
    oc:severityLevel "HIGH" .

oc:kn_c40b9c6f a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After implementing any responsive adaptation" ;
    oc:directiveContent "Test adaptations on real devices (not just browser DevTools emulation) across orientations, browsers, OS, input methods, screen sizes (320px to 4K), and network conditions." ;
    oc:hasRationale "Device emulation misses real-world rendering differences, touch behavior quirks, and performance characteristics of actual hardware." ;
    oc:severityLevel "MEDIUM" .

