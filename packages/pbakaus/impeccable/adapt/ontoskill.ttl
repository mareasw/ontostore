@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_adapt a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "adapt" ;
    skos:broader "responsive adaptation skill" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/adapt" ;
    oc:contentHash "6c87d9864bc070fd2b0dbcb64acee9a8b9c822b457e62b070f47c28eaf6284ca" ;
    oc:dependsOnSkill oc:skill_ontoskills_teach_impeccable ;
    oc:differentia "adapts UI designs across screen sizes, devices, and contexts through breakpoint-driven layout strategies, touch optimization, and context-specific interaction patterns" ;
    oc:extends oc:skill_ontoskills_frontend_design ;
    oc:handlesFailure oc:InvalidInput,
        oc:MissingDesignContext ;
    oc:hasArgumentHint "[target] [context (mobile, tablet, print...)]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Adapt designs to work across different screen sizes, devices, contexts, or platforms. Implements breakpoints, fluid layouts, and touch targets. Use when the user mentions responsive design, mobile layouts, breakpoints, viewport adaptation, or cross-device compatibility." ;
    oc:hasName "adapt" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent _:ref_d39f8d1e9de1dc9b,
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Understand what needs adaptation and why:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**CRITICAL**: Adaptation is not just scaling - it's rethinking the experience for the new context." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Assess Adaptation Challenge" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Adapt existing designs to work effectively across different contexts - different screen sizes, devices, platforms, or use cases." ],
                [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: adapt
description: Adapt designs to work across different screen sizes, devices, contexts, or platforms. Implements breakpoints, fluid layouts, and touch targets. Use when the user mentions responsive design, mobile layouts, breakpoints, viewport adaptation, or cross-device compatibility.
user-invocable: true
argument-hint: "[target] [context (mobile, tablet, print...)]"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Different browsers**: Safari, Chrome, Firefox, Edge" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "**Different input methods**: Touch, mouse, keyboard" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Different OS**: iOS, Android, Windows, macOS" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 7 ;
                            oc:itemText "**Slow connections**: Test on throttled network" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 6 ;
                            oc:itemText "**Edge cases**: Very small screens (320px), very large screens (4K)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Real devices**: Test on actual phones, tablets, desktops" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Different orientations**: Portrait and landscape" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "Remember: You're a cross-platform design expert. Make experiences that feel native to each context while maintaining brand and functionality consistency. Adapt intentionally, test thoroughly." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Test thoroughly across contexts:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 5 ;
            oc:sectionTitle "Verify Adaptations" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 4 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 6 ;
                            oc:itemText "Use generic breakpoints blindly (use content-driven breakpoints)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Assume desktop = powerful device (consider accessibility, older machines)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Hide core functionality on mobile (if it matters, make it work)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Use different information architecture across contexts (confusing)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Break user expectations for platform (mobile users expect mobile patterns)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "Forget landscape orientation on mobile/tablet" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 7 ;
                            oc:itemText "Ignore touch on desktop (many desktop devices have touch)" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Apply changes systematically:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**NEVER**:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**IMPORTANT**: Test on real devices, not just browser DevTools. Device emulation is helpful but not perfect." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**`clamp()`**: Fluid sizing between min and max" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Display properties**: Show/hide elements per context" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Container Queries**: Adapt based on container, not viewport" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Media queries**: Different styles for different contexts" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**CSS Grid/Flexbox**: Reflow layouts automatically" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Layout Adaptation Techniques" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Add more spacing between interactive elements" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Consider thumb zones (easier to reach bottom than top)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Increase touch target sizes (44x44px minimum)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Add touch feedback (ripples, highlights)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Remove hover-dependent interactions" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Touch Adaptation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Mobile: 320px-767px" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Tablet: 768px-1023px" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Desktop: 1024px+" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Or content-driven breakpoints (where design breaks)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Choose appropriate breakpoints:" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Responsive Breakpoints" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Lazy loading for off-screen content" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Progressive enhancement (core content first, enhancements on larger screens)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Responsive images (`srcset`, `picture` element)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Use `display: none` sparingly (still downloads)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Content Adaptation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Transform complex nav to hamburger/drawer on mobile" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Bottom nav bar for mobile apps" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Persistent side navigation on desktop" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Breadcrumbs on smaller screens for context" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Navigation Adaptation" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Implement Adaptations" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Invoke /frontend-design — it contains design principles, anti-patterns, and the **Context Gathering Protocol**. Follow the protocol before proceeding — if no design context exists yet, you MUST run /teach-impeccable first. Additionally gather: target platforms/devices and usage contexts." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "MANDATORY PREPARATION" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Create context-appropriate strategy:" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Interaction Strategy**:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Layout Strategy**:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Deep links to web app for complex interactions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Large, obvious CTAs (buttons not text links)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "No hover states (not reliable)" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Narrow width (600px max)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Single column only" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Inline CSS (no external stylesheets)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Table-based layouts (for email client compatibility)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Email Adaptation (Web → Email)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Black and white (or limited color)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Remove navigation, footer, interactive elements" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Page breaks at logical points" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Proper margins for binding" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Content Strategy**:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Layout Strategy**:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Include metadata (print date, page title)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Add page numbers, headers, footers" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Expand shortened content (show full URLs, hidden sections)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Convert charts to print-friendly versions" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Print Adaptation (Screen → Print)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Layout Strategy**:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "**Content Strategy**:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Thumbs-first design (controls within thumb reach)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Larger tap areas with more spacing" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Bottom sheets instead of dropdowns" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Swipe gestures where appropriate (lists, carousels)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Touch targets 44x44px minimum (not hover-dependent)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Interaction Strategy**:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 7 ;
                            oc:textContent "**Navigation Strategy**:" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 6 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Progressive disclosure (don't show everything at once)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Larger text (16px minimum)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Shorter text (more concise)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Prioritize primary content (secondary content in tabs/accordions)" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Vertical stacking instead of side-by-side" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Full-width components instead of fixed widths" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Bottom navigation instead of top/side navigation" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Single column instead of multi-column" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 8 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Back button in navigation flow" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Reduce navigation complexity" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Hamburger menu or bottom navigation" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Sticky headers for context" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Mobile Adaptation (Desktop → Mobile)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 6 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "More detailed descriptions" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Data tables with many columns" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Show more information upfront (less progressive disclosure)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Richer visualizations" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Fixed widths with max-width constraints (don't stretch to 4K)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Multiple information panels simultaneously" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Side navigation always visible" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Multi-column layouts (use horizontal space)" ] ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
