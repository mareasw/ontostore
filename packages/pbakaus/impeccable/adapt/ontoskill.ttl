                    dcterms:description "Test on real devices across orientations, browsers, OS, input methods, edge case screens (320px to 4K), and throttled networks." ;
                    oc:expectedOutcome "Verified working experience across all target contexts" ;
                    oc:stepDependsOn _:ref_38ad5f4373d2ce5a ;
                    oc:stepId "verify-adaptations" ],
                _:ref_c64aaf0142d691ea,
                _:ref_e1ee8d2fcc8f0288 ;
            oc:workflowId "adapt-design" ;
            oc:workflowName "Adapt Design Across Contexts" ] ;
    oc:impartsKnowledge oc:kn_452cfe31,
