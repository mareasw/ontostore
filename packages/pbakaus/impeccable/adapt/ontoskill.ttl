                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Side navigation drawers" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Touch targets 44x44px but allow denser layouts than phone" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Multi-column forms where appropriate" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Tablet Adaptation (Hybrid Approach)" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Plan Adaptation Strategy" ] ;
    oc:hasWorkflow _:ref_d39f8d1e9de1dc9b,
        [ a oc:Workflow ;
            dcterms:description "Full workflow for adapting an existing design to work across different screen sizes, devices, and contexts" ;
            oc:hasStep _:ref_38ad5f4373d2ce5a,
                _:ref_83962db6c27f851c,
