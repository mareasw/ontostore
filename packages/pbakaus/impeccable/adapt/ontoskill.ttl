oc:kn_452cfe31 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before planning any adaptation strategy" ;
    oc:directiveContent "Adaptation is not just scaling — it's rethinking the experience for the new context. Assess source context assumptions, target context constraints, and what won't fit, won't work, or is inappropriate." ;
    oc:hasRationale "Simply scaling a layout breaks usability; context-appropriate redesign preserves UX quality" ;
    oc:severityLevel "CRITICAL" .

oc:kn_afb1fd85 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning context-specific adaptation strategies" ;
    oc:directiveContent "Mobile → Desktop: use multi-column layouts, persistent side nav, hover states, keyboard shortcuts, show more info upfront. Desktop → Mobile: single column, bottom nav, progressive disclosure, thumbs-first design, larger text." ;
    oc:hasRationale "Each direction requires opposite strategies — expanding richness vs. simplifying for constraints" ;
    oc:severityLevel "HIGH" .

oc:kn_be8a1bff a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "After implementing adaptations — verification phase" ;
    oc:directiveContent "Test across real devices, orientations (portrait + landscape), browsers (Safari, Chrome, Firefox, Edge), OS (iOS, Android, Windows, macOS), input methods, edge case screens (320px and 4K), and throttled networks." ;
    oc:hasRationale "Emulators miss real device rendering differences, touch behavior quirks, and network handling" ;
    oc:severityLevel "HIGH" .

oc:kn_c445059b a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Always, before starting any adaptation work" ;
    oc:directiveContent "Before adapting: invoke /frontend-design for design principles and Context Gathering Protocol. If no design context exists, run /teach-impeccable first. Gather target platforms/devices and usage contexts." ;
    oc:hasRationale "Design context establishes shared principles and tokens; without it, adaptations will be inconsistent" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c73d67fa a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing responsive adaptations" ;
    oc:directiveContent "NEVER hide core functionality on mobile, use different information architecture across contexts, break platform user expectations, use generic breakpoints blindly, or ignore touch on desktop devices." ;
    oc:hasRationale "These patterns degrade user experience and violate platform conventions users rely on" ;
    oc:severityLevel "CRITICAL" .

oc:kn_cfd27882 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adapting for touch devices and email clients" ;
    oc:directiveContent "Touch targets must be 44x44px minimum. Text on mobile must be 16px minimum. Email layouts must be 600px max width with table-based layouts and inline CSS." ;
    oc:hasRationale "Below these thresholds, touch targets are inaccessible and text is unreadable; email clients reject non-inline CSS" ;
    oc:severityLevel "HIGH" .

oc:kn_f8de2871 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When choosing responsive breakpoints" ;
    oc:directiveContent "Prefer content-driven breakpoints over generic device breakpoints. Test on real devices, not just browser DevTools. Don't stretch layouts to 4K — use max-width constraints." ;
    oc:hasRationale "Content-driven breakpoints adapt where the design actually breaks; device emulation misses real device behaviors" ;
    oc:severityLevel "MEDIUM" .

