@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_bolder a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "bolder" ;
    skos:broader "Design amplification skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/bolder" ;
    oc:contentHash "f4c9baf584244770c6c84c3fde216029b793693cc42bfbd5297faf86fb7f8966" ;
    oc:differentia "that increases visual impact and personality of safe or generic designs across typography, color, space, effects, motion, and composition while maintaining usability and avoiding AI-generated clichés" ;
    oc:extends oc:skill_frontend_design ;
    oc:handlesFailure oc:AccessibilityViolation,
        oc:GenericAISlopDetected,
        oc:UsabilityDegraded ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "design" ;
    oc:hasDescription "Amplify safe or boring designs to make them more visually interesting and stimulating. Increases impact while maintaining usability. Use when the user says the design looks bland, generic, too safe, lacks personality, or wants more visual impact and character." ;
    oc:hasName "bolder" ;
    oc:impartsKnowledge oc:kn_18d5c318,
        oc:kn_3e3c31f4,
        oc:kn_48e7b042,
        oc:kn_7116109d,
        oc:kn_cb8291f7 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextLoaded,
        oc:ProjectContextEstablished ;
    oc:resolvesIntent "add personality to generic interface",
        "amplify boring design",
        "increase visual drama in bland layout",
        "make design more memorable and distinctive",
        "make design more visually impactful" ;
    oc:yieldsState oc:DesignAmplified,
        oc:VisualImpactIncreased .

oc:kn_18d5c318 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning design amplification strategy" ;
    oc:directiveContent "Choose ONE hero focal point and make it extraordinary rather than making everything slightly bolder — create dramatic scale jumps (3x-5x) and extreme weight contrast (900 vs 200)." ;
    oc:hasRationale "Bold design requires hierarchy amplification: contrast between elements creates visual drama. If everything is bold, nothing is bold." ;
    oc:severityLevel "HIGH" .

oc:kn_3e3c31f4 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding motion and animation effects" ;
    oc:directiveContent "Never use bounce or elastic easing curves for transitions — they cheapen the effect. Use ease-out-quart, ease-out-quint, or ease-out-expo for smooth, confident motion." ;
    oc:hasRationale "Playful easing curves undermine the confident, intentional quality that bold design requires. Smooth easing communicates sophistication." ;
    oc:severityLevel "MEDIUM" .

oc:kn_48e7b042 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During quality verification phase after amplification" ;
    oc:directiveContent "Use the 'AI slop test': if you showed this to someone and said 'AI made this bolder' and they'd believe it immediately, you've failed — bold means distinctive, not 'more effects'." ;
    oc:hasRationale "This litmus test catches the most common failure mode of AI-assisted design amplification: applying trendy effects mechanically rather than creating genuinely distinctive design." ;
    oc:severityLevel "HIGH" .

oc:kn_7116109d a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always, throughout all amplification work" ;
    oc:directiveContent "Bold design must still meet WCAG accessibility standards, maintain body text readability, and preserve functional usability — impact without function is just decoration." ;
    oc:hasRationale "Visual amplification that sacrifices accessibility or usability harms users and fails the core requirement that bold design remain functional." ;
    oc:severityLevel "CRITICAL" .

oc:kn_cb8291f7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Whenever amplifying visual design" ;
    oc:directiveContent "Never default to cyan/purple gradients, glassmorphism, neon accents on dark backgrounds, or gradient text on metrics — these are generic AI-generated clichés, not bold design." ;
    oc:hasRationale "AI models converge on the same visual patterns when asked to make things 'bolder', producing derivative work that is the opposite of distinctive." ;
    oc:severityLevel "CRITICAL" .

