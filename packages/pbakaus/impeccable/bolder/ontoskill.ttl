@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_bolder a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "bolder" ;
    skos:broader "Design enhancement skill" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/bolder" ;
    oc:contentHash "f4c9baf584244770c6c84c3fde216029b793693cc42bfbd5297faf86fb7f8966" ;
    oc:dependsOnSkill oc:skill_ontoskills_frontend_design,
        oc:skill_ontoskills_teach_impeccable ;
    oc:differentia "that amplifies visually safe or generic designs into distinctive, impactful experiences while maintaining usability and avoiding AI-generated clichés" ;
    oc:handlesFailure oc:AISlopDetected,
        oc:DesignContextMissing ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "design" ;
    oc:hasDescription "Amplify safe or boring designs to make them more visually interesting and stimulating. Increases impact while maintaining usability. Use when the user says the design looks bland, generic, too safe, lacks personality, or wants more visual impact and character." ;
    oc:hasName "bolder" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**CRITICAL**: \"Bolder\" doesn't mean chaotic or garish. It means distinctive, memorable, and confident. Think intentional drama, not random chaos." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "If any of these are unclear from the codebase, ask the user directly to clarify what you cannot infer." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 5 ;
                    oc:textContent "**WARNING - AI SLOP TRAP**: When making things \"bolder,\" AI defaults to the same tired tricks: cyan/purple gradients, glassmorphism, neon accents on dark backgrounds, gradient text on metrics. These are the OPPOSITE of bold—they're generic. Review ALL the DON'T guidelines in the frontend-design skill before proceeding. Bold means distinctive, not \"more effects.\"" ],
                _:ref_5ae491a45727a691,
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Analyze what makes the design feel too safe or boring:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Assess Current State" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**The test**: If you showed this to someone and said \"AI made this bolder,\" would they believe you immediately? If yes, you've failed. Bold means distinctive, not \"more AI effects.\"" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Ensure amplification maintains usability and coherence:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "Remember: Bold design is confident design. It takes risks, makes statements, and creates memorable experiences. But bold without strategy is just loud. Be intentional, be dramatic, be unforgettable." ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Memorable**: Will users remember this experience?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Still functional**: Can users accomplish tasks without distraction?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 6 ;
                            oc:itemText "**Accessible**: Does it still meet accessibility standards?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Coherent**: Does everything feel intentional and unified?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**NOT AI slop**: Does this look like every other AI-generated \"bold\" design? If yes, start over." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "**Performant**: Do all these effects run smoothly?" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 5 ;
            oc:sectionTitle "Verify Quality" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**IMPORTANT**: Bold design must still be usable. Impact without function is just decoration." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Create a strategy to increase impact while maintaining coherence:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Personality direction**: Maximalist chaos? Elegant drama? Playful energy? Dark moody? Choose a lane." ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Hierarchy amplification**: Make big things BIGGER, small things smaller (increase contrast)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Focal point**: What should be the hero moment? (Pick ONE, make it amazing)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Risk budget**: How experimental can we be? Push boundaries within constraints." ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Plan Amplification" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Invoke /frontend-design — it contains design principles, anti-patterns, and the **Context Gathering Protocol**. Follow the protocol before proceeding — if no design context exists yet, you MUST run /teach-impeccable first." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "MANDATORY PREPARATION" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: bolder
description: Amplify safe or boring designs to make them more visually interesting and stimulating. Increases impact while maintaining usability. Use when the user says the design looks bland, generic, too safe, lacks personality, or wants more visual impact and character.
user-invocable: true
argument-hint: "[target]"
""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Increase visual impact and personality in designs that are too safe, generic, or visually underwhelming, creating more engaging and memorable experiences." ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**NEVER**:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Systematically increase impact across these dimensions:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 3 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "Overwhelm with motion (animation fatigue is real)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 6 ;
                            oc:itemText "Copy trendy aesthetics blindly (bold means distinctive, not derivative)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Sacrifice readability for aesthetics (body text must be readable)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Add effects randomly without purpose (chaos ≠ bold)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Make everything bold (then nothing is bold - need contrast)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Ignore accessibility (bold design must still meet WCAG standards)" ] ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Transitions**: Smooth, noticeable transitions using ease-out-quart/quint/expo (not bounce or elastic—they cheapen the effect)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Micro-interactions**: Satisfying hover effects, click feedback, state changes" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Entrance choreography**: Staggered, dramatic page load animations with 50-100ms delays" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Scroll effects**: Parallax, reveal animations, scroll-triggered sequences" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "Motion & Animation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Diagonal flows**: Escape horizontal/vertical rigidity with diagonal arrangements" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Unexpected proportions**: Golden ratio? Throw it out. Try 70/30, 80/20 splits" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Hero moments**: Create clear focal points with dramatic treatment" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Full-bleed elements**: Use full viewport width/height for impact" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "Composition Boldness" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Replace generic fonts**: Swap system fonts for distinctive choices (see frontend-design skill for inspiration)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Weight contrast**: Pair 900 weights with 200 weights, not 600 with 400" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Extreme scale**: Create dramatic size jumps (3x-5x differences, not 1.5x)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Unexpected choices**: Variable fonts, display fonts for headlines, condensed/extended widths, monospace as intentional accent (not as lazy \"dev tool\" default)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 1 ;
                    oc:sectionTitle "Typography Amplification" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Texture & depth**: Grain, halftone, duotone, layered elements—NOT glassmorphism (it's overused AI slop)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Custom elements**: Illustrative elements, custom icons, decorative details that reinforce brand" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Dramatic shadows**: Large, soft shadows for elevation (but not generic drop shadows on rounded rectangles)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Background treatments**: Mesh patterns, noise textures, geometric patterns, intentional gradients (not purple-to-blue)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Borders & frames**: Thick borders, decorative frames, custom shapes (not rounded rectangles with colored border on one side)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "Visual Effects" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Rich gradients**: Intentional multi-stop gradients (not generic purple-to-blue)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Bold palette**: Introduce unexpected color combinations—avoid the purple-blue gradient AI slop" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Sharp accents**: High-contrast accent colors that pop" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Dominant color strategy**: Let one bold color own 60% of the design" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Increase saturation**: Shift to more vibrant, energetic colors (but not neon)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Tinted neutrals**: Replace pure grays with tinted grays that harmonize with your palette" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Color Intensification" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Generous space**: Use white space dramatically (100-200px gaps, not 20-40px)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Asymmetric layouts**: Replace centered, balanced layouts with tension-filled asymmetry" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Extreme scale jumps**: Make important elements 3-5x larger than surroundings" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Overlap**: Layer elements intentionally for depth" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Break the grid**: Let hero elements escape containers and cross boundaries" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Spatial Drama" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Amplify the Design" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Systematic workflow to amplify a safe/generic design into a bold, distinctive experience" ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Verify the amplified design is not AI slop, still functional, coherent, memorable, performant, and accessible" ;
                    oc:expectedOutcome "Bold design that passes all quality checks and feels intentionally crafted" ;
                    oc:stepDependsOn _:ref_c6b11b28a939e009 ;
                    oc:stepId "verify-quality" ],
                _:ref_3cde0eddb157022b,
                _:ref_a93215130de4a88f,
                _:ref_b4833c888b4f0d06,
                _:ref_c6b11b28a939e009 ;
            oc:workflowId "bolder-main" ;
            oc:workflowName "Design Amplification Workflow" ],
        _:ref_5ae491a45727a691 ;
    oc:impartsKnowledge oc:kn_0f5e87d9,
        oc:kn_1441652b,
        oc:kn_255c3a6d,
        oc:kn_525d1f4c,
        oc:kn_57ec365c,
        oc:kn_9a1171e7,
        oc:kn_9ec49c3d,
        oc:kn_a08ce20e ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DesignContextLoaded ;
    oc:resolvesIntent "add visual personality and impact",
        "amplify boring or safe designs",
        "increase design boldness while maintaining usability",
        "make design more visually interesting" ;
    oc:yieldsState oc:DesignAmplified,
        oc:VisualImpactIncreased .

oc:kn_0f5e87d9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Always — after any amplification" ;
    oc:directiveContent "Bold design must still meet WCAG accessibility standards, maintain readability for body text, and ensure users can accomplish tasks without distraction." ;
    oc:hasRationale "Impact without function is just decoration; usability is non-negotiable regardless of visual ambition" ;
    oc:severityLevel "CRITICAL" .

oc:kn_1441652b a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "During the Plan Amplification phase" ;
    oc:directiveContent "Choose a single personality direction (maximalist chaos, elegant drama, playful energy, or dark moody) and commit to it throughout the design." ;
    oc:hasRationale "Mixing personality directions creates visual confusion; coherence requires committing to one aesthetic lane" .

oc:kn_255c3a6d a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When amplifying any design dimension" ;
    oc:directiveContent "Never add effects randomly without purpose, sacrifice readability for aesthetics, make everything bold, ignore accessibility, overwhelm with motion, or copy trendy aesthetics blindly." ;
    oc:hasRationale "Chaos ≠ bold. Bold means one confident focal point with contrast, not everything turned to maximum" ;
    oc:severityLevel "HIGH" .

oc:kn_525d1f4c a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "After implementing all amplification changes" ;
    oc:directiveContent "Verify amplification with six checks: not AI slop, still functional, coherent, memorable, performant, and accessible." ;
    oc:hasRationale "Amplification can easily break usability, performance, or coherence — systematic verification prevents regression" .

oc:kn_57ec365c a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "During quality verification phase" ;
    oc:directiveContent "Test: if someone would immediately believe 'AI made this bolder,' you've failed. Start over with a more distinctive, less derivative approach." ;
    oc:hasRationale "The hallmark of failed boldness is predictability; truly bold design feels intentional and human-crafted" .

oc:kn_9a1171e7 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When amplifying any design" ;
    oc:directiveContent "Avoid AI slop defaults: cyan/purple gradients, glassmorphism, neon accents on dark backgrounds, gradient text on metrics. These are generic, not bold." ;
    oc:hasRationale "AI-generated 'bold' designs tend to converge on the same tired visual clichés that are the opposite of distinctive" ;
    oc:severityLevel "CRITICAL" .

oc:kn_9ec49c3d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning amplification strategy" ;
    oc:directiveContent "Bold design means distinctive, memorable, and confident — intentional drama, not random chaos. Pick ONE hero focal point and make it amazing." ;
    oc:hasRationale "Effective boldness requires a single strong statement supported by contrast, not uniform intensity across all elements" .

oc:kn_a08ce20e a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing typography, spatial drama, and composition boldness" ;
    oc:directiveContent "Create dramatic size jumps (3x-5x differences, not 1.5x). Pair 900 font weights with 200 weights. Use 100-200px gaps for white space. Try 70/30 or 80/20 layout splits instead of golden ratio." ;
    oc:hasRationale "Boring designs suffer from timid incremental differences; boldness requires exaggerated contrast ratios" .

_:ref_097a6fd4a7846cf0 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 3 ;
    oc:itemText "Who's the audience? (What will resonate?)" .

_:ref_4f1c27441f041357 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 5 ;
    oc:itemText "**Predictable**: Standard patterns with no surprises" .

_:ref_63f7fe4765c5d265 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "**Timid scale**: Everything is medium-sized with no drama" .

_:ref_7f8e750fd8b4743e a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 3 ;
    oc:itemText "**Low contrast**: Everything has similar visual weight" .

_:ref_8649a1d011c36b06 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 6 ;
    oc:itemText "**Flat hierarchy**: Nothing stands out or commands attention" .

_:ref_a3ab4a99cb969058 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "What's the purpose? (Marketing can be bolder than financial dashboards)" .

_:ref_ae464132e2069d5f a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 4 ;
    oc:itemText "What are the constraints? (Brand guidelines, accessibility, performance)" .

_:ref_b279de6697d61afc a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
    oc:itemText "**Generic choices**: System fonts, basic colors, standard layouts" .

_:ref_beef159da91ed9aa a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem _:ref_097a6fd4a7846cf0,
        _:ref_a3ab4a99cb969058,
        _:ref_ae464132e2069d5f,
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 1 ;
            oc:itemText "What's the brand personality? (How far can we push?)" ] .

_:ref_cb01ebb66d8f232a a oc:WorkflowStep ;
    dcterms:description "**Understand the context**:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild _:ref_beef159da91ed9aa ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_db07dbf7d20aa9bf a oc:WorkflowStep ;
    dcterms:description "**Identify weakness sources**:" ;
    oc:blockType "workflow_step" ;
    oc:hasChild [ a oc:BulletList ;
            oc:blockType "bullet_list" ;
            oc:contentOrder 1 ;
            oc:hasItem _:ref_4f1c27441f041357,
                _:ref_63f7fe4765c5d265,
                _:ref_7f8e750fd8b4743e,
                _:ref_8649a1d011c36b06,
                _:ref_b279de6697d61afc,
                [ a oc:BulletItem ;
                    oc:blockType "bullet_item" ;
                    oc:itemOrder 4 ;
                    oc:itemText "**Static**: No motion, no energy, no life" ] ] ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_3cde0eddb157022b a oc:WorkflowStep ;
    dcterms:description "Define focal point hero moment, choose personality direction, determine risk budget, and plan hierarchy amplification" ;
    oc:expectedOutcome "Amplification strategy with clear direction and constraints" ;
    oc:stepDependsOn _:ref_a93215130de4a88f ;
    oc:stepId "plan-amplification" .

_:ref_5ae491a45727a691 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_cb01ebb66d8f232a,
        _:ref_db07dbf7d20aa9bf ;
    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_a93215130de4a88f a oc:WorkflowStep ;
    dcterms:description "Identify weakness sources (generic choices, timid scale, low contrast, static feel, predictability, flat hierarchy) and understand brand context, purpose, audience, and constraints" ;
    oc:expectedOutcome "Clear diagnosis of what makes the design feel safe or boring" ;
    oc:stepDependsOn _:ref_b4833c888b4f0d06 ;
    oc:stepId "assess-current-state" .

_:ref_b4833c888b4f0d06 a oc:WorkflowStep ;
    dcterms:description "Invoke frontend-design skill and run Context Gathering Protocol; if no design context exists, run teach-impeccable first" ;
    oc:expectedOutcome "Design context and principles are loaded" ;
