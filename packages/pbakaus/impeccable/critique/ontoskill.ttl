@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_critique a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "critique" ;
    skos:broader "Design evaluation framework" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/critique" ;
    oc:contentHash "2db21108930bac8ae6ee28e5e47d3feff5b191b167f075e164ab6b6677808633" ;
    oc:dependsOnSkill oc:skill_frontend_design,
        oc:skill_teach_impeccable ;
    oc:differentia "conducts multi-dimensional UX critique with Nielsen heuristic scoring, persona-based testing, cognitive load assessment, and AI-generated anti-pattern detection to produce prioritized actionable feedback" ;
    oc:handlesFailure oc:DesignContextMissing,
        oc:InvalidInput ;
    oc:hasArgumentHint "[area (feature, page, component...)]" ;
    oc:hasCategory "research" ;
    oc:hasDescription "Evaluate design from a UX perspective, assessing visual hierarchy, information architecture, emotional resonance, cognitive load, and overall quality with quantitative scoring, persona-based testing, and actionable feedback. Use when the user asks to review, critique, evaluate, or give feedback on a design or component." ;
    oc:hasName "critique" ;
    oc:impartsKnowledge oc:kn_25de9164,
        oc:kn_3dbe0aea,
        oc:kn_3f249376,
        oc:kn_521c3a3f,
        oc:kn_66b75ba9,
        oc:kn_81fd9855,
        oc:kn_a86ede21 ;
    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DesignContextLoaded,
        oc:EnvironmentReady ;
    oc:resolvesIntent "assess UX quality",
        "critique a design",
        "evaluate a UI",
        "give design feedback",
        "review a design",
        "score design heuristics" ;
    oc:yieldsState oc:ActionPlanGenerated,
        oc:DesignCritiqued,
        oc:HeuristicScored .

oc:kn_25de9164 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When beginning any design critique evaluation" ;
    oc:directiveContent "Always check for AI-generated design tells first — gradient text, dark mode with glowing accents, glassmorphism, hero metric layouts, identical card grids, and the generic AI color palette are the highest-priority signals that the interface lacks originality." ;
    oc:hasRationale "AI slop is the most common and most damaging pattern in modern interface generation — it makes designs feel generic and undermines trust instantly." ;
    oc:severityLevel "CRITICAL" .

oc:kn_3dbe0aea a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "When evaluating persona-based usability" ;
    oc:directiveContent "Auto-select 2–3 personas from the 5 archetypes (Alex, Jordan, Sam, Riley, Casey) based on interface type using the selection table. Walk through the primary user action as each persona and report specific red flags — name exact elements that fail, not generic concerns." ;
    oc:hasRationale "Different user archetypes expose different failure modes that a single design director perspective would miss." ;
    oc:severityLevel "HIGH" .

oc:kn_3f249376 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When presenting all critique findings" ;
    oc:directiveContent "Feedback must be direct, specific, and concrete — reference 'the submit button' not 'some elements'. Say what's wrong AND why it matters to users. Give concrete suggestions. Prioritize ruthlessly — if everything is important, nothing is." ;
    oc:hasRationale "Vague feedback wastes time and fails to guide meaningful improvement. Developers need honest, specific feedback to ship great design." ;
    oc:severityLevel "HIGH" .

oc:kn_521c3a3f a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting Phase 1 of any critique" ;
    oc:directiveContent "Before critique begins, invoke frontend-design skill for design principles and anti-patterns. If no design context exists yet, teach-impeccable MUST run first. Also gather what the interface is trying to accomplish." ;
    oc:hasRationale "Without established design context and principles, critique has no grounded standard to evaluate against." ;
    oc:severityLevel "CRITICAL" .

oc:kn_66b75ba9 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When presenting findings and scoring design health" ;
    oc:directiveContent "Score each of Nielsen's 10 heuristics on a 0–4 scale honestly — a 4 means genuinely excellent. Most real interfaces score 20–32/40. Tag each issue P0–P3 based on whether a user would contact support about it." ;
    oc:hasRationale "Quantitative scoring enables tracking improvement over time and forces specificity over vague impressions." ;
    oc:severityLevel "MEDIUM" .

oc:kn_81fd9855 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When transitioning between findings and action plan" ;
    oc:directiveContent "If findings are straightforward (1–2 clear issues), skip Phase 3 questions and go directly to Phase 4 action recommendations. Otherwise limit to 2–4 targeted questions referencing specific findings with concrete options." ;
    oc:hasRationale "Respecting user time while gathering necessary direction prevents fatigue and keeps the critique workflow efficient." ;
    oc:severityLevel "MEDIUM" .

oc:kn_a86ede21 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When evaluating information architecture and cognitive load" ;
    oc:directiveContent "Count visible options at each decision point — if more than 4, flag it as cognitive overload. Score the 8-item cognitive load checklist: 0–1 failures = low, 2–3 = moderate, 4+ = critical." ;
    oc:hasRationale "Humans can hold ≤4 items in working memory (Cowan, 2001). Exceeding this causes mistakes, frustration, and abandonment." ;
    oc:severityLevel "HIGH" .

