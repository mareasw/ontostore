    oc:isUserInvocable true ;
    oc:nature "Concept" ;
    oc:requiresState oc:DesignContextAvailable,
        oc:EnvironmentReady ;
    oc:resolvesIntent "critique a design",
        "evaluate a UI",
        "give design feedback",
        "identify UX problems",
        "review a component",
        "score design quality" ;
    oc:yieldsState oc:ActionPlanGenerated,
