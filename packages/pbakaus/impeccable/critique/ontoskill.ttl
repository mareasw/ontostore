                _:ref_874a6f9d27be074f,
                _:ref_ad577f0ae55d62f9 ;
            oc:workflowId "critique-full" ;
            oc:workflowName "Full Design Critique" ],
        _:ref_af1d679aba37a6f0,
        _:ref_bcdecf8586d23e2f ;
    oc:impartsKnowledge oc:kn_06a24758,
        oc:kn_1b3b223b,
