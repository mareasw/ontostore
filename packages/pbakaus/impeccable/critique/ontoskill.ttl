@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_critique a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "critique" ;
    skos:broader "Design evaluation framework" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/critique" ;
    oc:contentHash "2db21108930bac8ae6ee28e5e47d3feff5b191b167f075e164ab6b6677808633" ;
    oc:dependsOnSkill oc:skill_ontoskills_frontend_design,
        oc:skill_ontoskills_teach_impeccable ;
    oc:differentia "provides holistic UX critique with Nielsen heuristic scoring, cognitive load assessment, persona-based testing, and actionable remediation recommendations" ;
    oc:handlesFailure oc:InvalidInput,
        oc:MissingDesignContext ;
    oc:hasArgumentHint "[area (feature, page, component...)]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Evaluate design from a UX perspective, assessing visual hierarchy, information architecture, emotional resonance, cognitive load, and overall quality with quantitative scoring, persona-based testing, and actionable feedback. Use when the user asks to review, critique, evaluate, or give feedback on a design or component." ;
    oc:hasName "critique" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Structure your feedback as a design director would:" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Score each of Nielsen's 10 heuristics 0–4. Present as a table:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "Be honest with scores. A 4 means genuinely excellent. Most real interfaces score 20–32." ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 1 ;
                            oc:quoteContent "*Consult [heuristics-scoring](reference/heuristics-scoring.md)*" ],
                        [ a oc:Table ;
                            oc:blockType "table" ;
                            oc:contentOrder 3 ;
                            oc:rowCount 11 ;
                            oc:tableCaption "Score each of Nielsen's 10 heuristics 0–4. Present as a table" ;
                            oc:tableMarkdown """| # | Heuristic | Score | Key Issue |
|---|-----------|-------|-----------|
| 1 | Visibility of System Status | ? | [specific finding or "—" if solid] |
| 2 | Match System / Real World | ? | |
| 3 | User Control and Freedom | ? | |
| 4 | Consistency and Standards | ? | |
| 5 | Error Prevention | ? | |
| 6 | Recognition Rather Than Recall | ? | |
| 7 | Flexibility and Efficiency | ? | |
| 8 | Aesthetic and Minimalist Design | ? | |
| 9 | Error Recovery | ? | |
| 10 | Help and Documentation | ? | |
| **Total** | | **??/40** | **[Rating band]** |
""" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 14 ;
                    oc:sectionTitle "Design Health Score" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Prioritize ruthlessly — if everything is important, nothing is" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Be specific — \"the submit button\" not \"some elements\"" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "Don't soften criticism — developers need honest feedback to ship great design" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Be direct — vague feedback wastes everyone's time" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Say what's wrong AND why it matters to users" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Give concrete suggestions, not just \"consider exploring...\"" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**Remember**:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Quick notes on smaller issues worth addressing." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 20 ;
                    oc:sectionTitle "Minor Observations" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**Start here.** Pass/fail: Does this look AI-generated? List specific tells from the skill's Anti-Patterns section. Be brutally honest." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 15 ;
                    oc:sectionTitle "Anti-Patterns Verdict" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Highlight 2–3 things done well. Be specific about why they work." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 17 ;
                    oc:sectionTitle "What's Working" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The 3–5 most impactful design problems, ordered by importance." ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**Suggested command**: Which command could address this (from: /animate, /quieter, /optimize, /adapt, /clarify, /distill, /delight, /onboard, /normalize, /audit, /harden, /polish, /extract, /bolder, /arrange, /typeset, /critique, /colorize, /overdrive)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Why it matters**: How this hurts users or undermines goals" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**[P?] What**: Name the problem clearly" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Fix**: What to do about it (be concrete)" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "For each issue, tag with **P0–P3 severity** (consult [heuristics-scoring](reference/heuristics-scoring.md) for severity definitions):" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 18 ;
                    oc:sectionTitle "Priority Issues" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "A brief gut reaction — what works, what doesn't, and the single biggest opportunity." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 16 ;
                    oc:sectionTitle "Overall Impression" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 6 ;
                            oc:textContent "Be specific — name the exact elements and interactions that fail each persona. Don't write generic persona descriptions; write what broke for them." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Auto-select 2–3 personas most relevant to this interface type (use the selection table in the reference). If `.github/copilot-instructions.md` contains a `## Design Context` section from `teach-impeccable`, also generate 1–2 project-specific personas from the audience/brand info." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "For each selected persona, walk through the primary user action and list specific red flags found:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 4 ;
                            oc:textContent "**Alex (Power User)**: No keyboard shortcuts detected. Form requires 8 clicks for primary action. Forced modal onboarding. ⚠️ High abandonment risk." ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 1 ;
                            oc:quoteContent "*Consult [personas](reference/personas.md)*" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "**Jordan (First-Timer)**: Icon-only nav in sidebar. Technical jargon in error messages (\"404 Not Found\"). No visible help. ⚠️ Will abandon at step 2." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 19 ;
                    oc:sectionTitle "Persona Red Flags" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 13 ;
            oc:sectionTitle "Phase 2: Present Findings" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: critique
description: Evaluate design from a UX perspective, assessing visual hierarchy, information architecture, emotional resonance, cognitive load, and overall quality with quantitative scoring, persona-based testing, and actionable feedback. Use when the user asks to review, critique, evaluate, or give feedback on a design or component.
user-invocable: true
argument-hint: "[area (feature, page, component...)]"
""" ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Ask questions along these lines (adapt to the specific findings — do NOT ask generic questions):" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 5 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Every question must reference specific findings from Phase 2 — never ask generic \"who is your audience?\" questions" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Keep it to 2–4 questions maximum — respect the user's time" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "If findings are straightforward (e.g., only 1–2 clear issues), skip questions and go directly to Phase 4" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Offer concrete options, not open-ended prompts" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "**After presenting findings**, use targeted questions based on what was actually found. ask the user directly to clarify what you cannot infer. These answers will shape the action plan." ],
                _:ref_af1d679aba37a6f0,
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "**Rules for questions**:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 21 ;
            oc:sectionTitle "Phase 3: Ask the User" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Evaluate the interface across these dimensions:" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Are hover/focus states providing useful feedback?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Are there hidden features that should be more visible?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Would a user know what to do without instructions?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Are interactive elements obviously interactive?" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "5. Discoverability & Affordance" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Peak-end rule**: Is the most intense moment positive? Does the experience end well (confirmation, celebration, clear next step)?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Emotional valleys**: Check for onboarding frustration, error cliffs, feature discovery gaps, or anxiety spikes at high-stakes moments (payment, delete, commit)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Would the target user feel \"this is for me\"?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "**Interventions at negative moments**: Are there design interventions where users are likely to feel frustrated or anxious? (progress indicators, reassurance copy, undo options, social proof)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Does it feel trustworthy, approachable, premium, playful — whatever it should feel?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "What emotion does this interface evoke? Is that intentional?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Does it match the brand personality?" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "4. Emotional Journey" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Are labels and buttons unambiguous?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Does it sound like a human (the right human for this brand)?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Does error copy help users fix the problem?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Is the writing clear and concise?" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 12 ;
                    oc:sectionTitle "10. Microcopy & Voice" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "**This is the most important check.** Does this look like every other AI-generated interface from 2024-2025?" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "Review the design against ALL the **DON'T** guidelines in the frontend-design skill — they are the fingerprints of AI-generated work. Check for the AI color palette, gradient text, dark mode with glowing accents, glassmorphism, hero metric layouts, identical card grids, generic fonts, and all other tells." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**The test**: If you showed this to someone and said \"AI made this,\" would they believe you immediately? If yes, that's the problem." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "1. AI Slop Detection (CRITICAL)" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Is whitespace used intentionally or just leftover?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Is there visual rhythm in spacing and repetition?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Does the layout feel balanced or uncomfortably weighted?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Does asymmetry feel designed or accidental?" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "6. Composition & Balance" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Are accent colors drawing attention to the right things?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Is color used to communicate, not just decorate?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Does the palette feel cohesive?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Does it work for colorblind users? (not just technically — does meaning still come through?)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 10 ;
                    oc:sectionTitle "8. Color with Purpose" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Error states: Are they helpful and non-blaming?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Empty states: Do they guide users toward action, or just say \"nothing here\"?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Success states: Do they confirm and guide next steps?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Loading states: Do they reduce perceived wait time?" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 11 ;
                    oc:sectionTitle "9. States & Edge Cases" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 1 ;
                            oc:quoteContent "*Consult [cognitive-load](reference/cognitive-load.md) for the working memory rule and 8-item checklist*" ],
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 2 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "**Run the 8-item cognitive load checklist** from the reference. Report failure count: 0–1 = low (good), 2–3 = moderate, 4+ = critical." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Are there too many choices at once? Count visible options at each decision point — if >4, flag it" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Is the structure intuitive? Would a new user understand the organization?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Is the navigation clear and predictable?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "**Progressive disclosure**: Is complexity revealed only when needed, or dumped on the user upfront?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Is related content grouped logically?" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "3. Information Architecture & Cognitive Load" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Does the type hierarchy clearly signal what to read first, second, third?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Is body text comfortable to read? (line length, spacing, size)" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Is there enough contrast between heading levels?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Do font choices reinforce the brand/tone?" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 9 ;
                    oc:sectionTitle "7. Typography as Communication" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Is there visual competition between elements that should have different weights?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Does the eye flow to the most important element first?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Do size, color, and position communicate importance correctly?" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Is there a clear primary action? Can you spot it in 2 seconds?" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 4 ;
                    oc:sectionTitle "2. Visual Hierarchy" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Phase 1: Design Critique" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Conduct a holistic design critique, evaluating whether the interface actually works — not just technically, but as a designed experience. Think like a design director giving feedback." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Invoke /frontend-design — it contains design principles, anti-patterns, and the **Context Gathering Protocol**. Follow the protocol before proceeding — if no design context exists yet, you MUST run /teach-impeccable first. Additionally gather: what the interface is trying to accomplish." ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "MANDATORY PREPARATION" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "**After receiving the user's answers**, present a prioritized action summary reflecting the user's priorities and scope from Phase 3." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "**Rules for recommendations**:" ],
                        [ a oc:BlockQuote ;
                            oc:blockType "blockquote" ;
                            oc:contentOrder 6 ;
                            oc:quoteContent """You can ask me to run these one at a time, all at once, or in any order you prefer.

Re-run `/critique` after fixes to see your score improve.""" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 5 ;
                            oc:textContent "After presenting the summary, tell the user:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "List recommended commands in priority order, based on the user's answers:" ],
                        _:ref_bcdecf8586d23e2f,
                        [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 4 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 7 ;
                                    oc:itemText "If the user marked areas as off-limits, exclude commands that would touch those areas" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Each item's description should carry enough context that the command knows what to focus on" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Only recommend commands from: /animate, /quieter, /optimize, /adapt, /clarify, /distill, /delight, /onboard, /normalize, /audit, /harden, /polish, /extract, /bolder, /arrange, /typeset, /critique, /colorize, /overdrive" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Map each Priority Issue to the appropriate command" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 8 ;
                                    oc:itemText "End with `/polish` as the final step if any fixes were recommended" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "If the user chose a limited scope, only include items within that scope" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Skip commands that would address zero issues" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Order by the user's stated priorities first, then by impact" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 23 ;
                    oc:sectionTitle "Action Summary" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 22 ;
            oc:sectionTitle "Phase 4: Recommended Actions" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Complete 4-phase design critique from evaluation through actionable recommendations" ;
            oc:hasStep _:ref_5aa82e2d6e94ef37,
                [ a oc:WorkflowStep ;
