@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_polish a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "polish" ;
    skos:broader "Quality assurance pass" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/polish" ;
    oc:contentHash "a47178eb54a519f71052157ed0f71c323f997508001e956b32b8582057e5c26f" ;
    oc:dependsOnSkill oc:skill_frontend_design,
        oc:skill_teach_impeccable ;
    oc:differentia "systematically fixes alignment, spacing, consistency, interaction states, typography, and micro-detail issues to elevate a functionally complete interface from good to production-ready" ;
    oc:handlesFailure oc:DesignSystemViolation,
        oc:IncompleteFeature,
        oc:InteractionStateMissing ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Performs a final quality pass fixing alignment, spacing, consistency, and micro-detail issues before shipping. Use when the user mentions polish, finishing touches, pre-launch review, something looks off, or wants to go from good to great." ;
    oc:hasName "polish" ;
    oc:impartsKnowledge oc:kn_20e1d114,
        oc:kn_4ae4778b,
        oc:kn_60d99e85,
        oc:kn_a342321a,
        oc:kn_a5211900,
        oc:kn_b2228e44,
        oc:kn_b890cd0d,
        oc:kn_d74e2189,
        oc:kn_f091bb00,
        oc:kn_fd63cc04 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextReady,
        oc:FeatureFunctionallyComplete ;
    oc:resolvesIntent "ensure visual consistency across a feature",
        "fix alignment and spacing issues",
        "fix micro-details like interaction states, typography, and edge cases",
        "go from good to great on a finished feature",
        "perform final pre-launch quality review",
        "polish an interface before shipping" ;
    oc:yieldsState oc:InterfacePolished,
        oc:ProductionReady .

oc:kn_20e1d114 a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When making any code change during polish" ;
    oc:directiveContent "Do not introduce bugs while polishing — test thoroughly after every change. If a polish change causes regression, revert immediately." ;
    oc:hasRationale "Polish changes are often small and subtle, making regressions hard to notice without deliberate testing." ;
    oc:severityLevel "HIGH" .

oc:kn_4ae4778b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When applying color and contrast adjustments" ;
    oc:directiveContent "Never put gray text on colored backgrounds — use a shade of that color or transparency instead. Never use pure gray or pure black — add subtle color tint (0.01 chroma)." ;
    oc:hasRationale "Tinted neutrals create visual harmony; gray-on-color creates visual dissonance that appears unintentional." ;
    oc:severityLevel "MEDIUM" .

oc:kn_60d99e85 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When discovering repeated inconsistencies during polish" ;
    oc:directiveContent "If spacing or alignment issues are systematic (everywhere), fix the underlying system rather than patching individual instances." ;
    oc:hasRationale "System-level fixes prevent recurrence and maintain consistency, while point fixes create fragile whack-a-mole patterns." ;
    oc:severityLevel "HIGH" .

oc:kn_a342321a a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any polish pass" ;
    oc:directiveContent "Before polishing, confirm: the feature is functionally complete, design context exists, and the quality bar (MVP vs flagship) is understood." ;
    oc:hasRationale "Starting without these preconditions leads to wasted effort and misaligned quality expectations." .

oc:kn_a5211900 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoping polish work" ;
    oc:directiveContent "Never spend hours on polish if the feature ships in 30 minutes. Triage polish effort against shipping timeline and quality bar (MVP vs flagship)." ;
    oc:hasRationale "Diminishing returns on polish time investment can delay shipping without proportional quality improvement." ;
    oc:severityLevel "HIGH" .

oc:kn_b2228e44 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before beginning any polish pass" ;
    oc:directiveContent "Never polish work that is not functionally complete. Polish is the last step, not the first." ;
    oc:hasRationale "Polishing incomplete work wastes effort on elements that may change, and risks introducing bugs into unfinished functionality." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b890cd0d a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing the polish pass" ;
    oc:directiveContent "After polishing, verify: all breakpoints tested, all interactive states work, no console errors, no layout shift, WCAG AA contrast met, keyboard navigation functional, and reduced-motion preference respected." ;
    oc:hasRationale "Systematic verification prevents regressions and ensures the polish actually achieved production readiness." .

oc:kn_d74e2189 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any animation or transition" ;
    oc:directiveContent "Only animate transform and opacity properties for 60fps performance. Keep transition durations between 150-300ms." ;
    oc:hasRationale "Transform and opacity are GPU-accelerated properties; animating layout properties causes repaints and jank." ;
    oc:severityLevel "HIGH" .

oc:kn_f091bb00 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing transitions and micro-interactions" ;
    oc:directiveContent "Never use bounce or elastic easing curves — they feel dated. Use ease-out-quart/quint/expo for natural deceleration instead." ;
    oc:hasRationale "Modern UI motion design favors smooth deceleration over playful bounciness, which feels unprofessional." ;
    oc:severityLevel "MEDIUM" .

oc:kn_fd63cc04 a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "When reviewing interaction completeness" ;
    oc:directiveContent "Every interactive element must implement all 8 states: default, hover, focus, active, disabled, loading, error, and success. Missing states create confusion and broken experiences." ;
    oc:hasRationale "Incomplete interaction states are a primary source of perceived low quality and usability problems." ;
    oc:severityLevel "HIGH" .

