oc:kn_0122b4ee a oc:KnowledgeNode,
        oc:SideEffect ;
    oc:appliesToContext "Always — polish touches multiple code layers" ;
    oc:directiveContent "Polish may modify CSS, HTML structure, animation code, image assets, and copy. May also reveal deeper design system issues requiring token/scale changes." ;
    oc:hasRationale "Understanding the blast radius of polish changes helps with version control and review." ;
    oc:severityLevel "MEDIUM" .

oc:kn_11cf1c79 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When re-running polish after changes" ;
    oc:directiveContent "Polish can be run multiple times safely, but each pass should verify previous fixes are intact and not regress." ;
    oc:hasRationale "Iteration is common during polish; ensuring no regressions maintains quality across passes." ;
    oc:severityLevel "LOW" .

oc:kn_12cdf44c a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When ship deadline is imminent (under 30 minutes)" ;
    oc:directiveContent "Never spend excessive time on polish when shipping under tight deadlines — triage polish scope to match available time." ;
    oc:hasRationale "Perfect polish on one thing while leaving others rough is worse than consistent moderate quality across everything." ;
    oc:severityLevel "HIGH" .

oc:kn_4382413a a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing micro-interactions and transitions" ;
    oc:directiveContent "Transitions must be 150-300ms using ease-out-quart/quint/expo. Never use bounce or elastic easing. Only animate transform and opacity for 60fps." ;
    oc:hasRationale "Consistent natural deceleration feels modern; bounce/elastic feels dated. Animating only transform/opacity ensures GPU-accelerated 60fps." ;
    oc:severityLevel "MEDIUM" .

oc:kn_6d2d1e3b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing color usage in CSS/styles" ;
    oc:directiveContent "Never use hard-coded colors — all colors must use design tokens. No pure gray or pure black; add subtle color tint (0.01 chroma). Never put gray text on colored backgrounds." ;
    oc:hasRationale "Design tokens ensure theme consistency and maintainability. Tinted neutrals feel more sophisticated. Gray on color backgrounds breaks visual harmony." ;
    oc:severityLevel "HIGH" .

oc:kn_850b9c53 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before starting any polish pass" ;
    oc:directiveContent "Never polish work that is not functionally complete. Polish is the last step, not the first." ;
    oc:hasRationale "Polishing incomplete work wastes effort and can introduce bugs that must be reworked when features are added." ;
    oc:severityLevel "CRITICAL" .

oc:kn_9be6b155 a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing the polish pass" ;
    oc:directiveContent "After polish: interact with the feature yourself, test on real devices, get fresh-eye review, compare to intended design, and check all states (not just happy path)." ;
    oc:hasRationale "Fresh perspective and real-device testing catch issues that focused polishing misses." ;
    oc:severityLevel "HIGH" .

oc:kn_a0ba663b a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When reviewing or implementing interactive elements" ;
    oc:directiveContent "All interactive elements must implement Default, Hover, Focus, Active, Disabled, Loading, Error, and Success states. Never remove focus indicators without replacement." ;
    oc:hasRationale "Missing interaction states create confusion and broken experiences, especially for keyboard and assistive technology users." ;
    oc:severityLevel "CRITICAL" .

oc:kn_a0f48062 a oc:KnowledgeNode,
        oc:SuccessIndicator ;
    oc:appliesToContext "When evaluating polish completeness" ;
    oc:directiveContent "Polish is complete when: alignment is pixel-perfect at all breakpoints, all spacing uses design tokens, all interactive states are implemented, transitions are 60fps, contrast meets WCAG AA, keyboard navigation works, no console errors, no layout shift, code is clean." ;
    oc:hasRationale "The checklist ensures objective verification rather than subjective 'looks fine' assessment." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c5e65160 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When discovering systematic issues during polish" ;
    oc:directiveContent "If spacing is off everywhere, fix the spacing system/tokens rather than individually correcting each instance. Maintain consistent quality level across all dimensions." ;
    oc:hasRationale "Systematic fixes are more efficient and prevent recurrence than point fixes, and ensure consistent quality." ;
    oc:severityLevel "MEDIUM" .

oc:kn_db31ff48 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When executing the polish pass" ;
    oc:directiveContent "Polish systematically across all dimensions — alignment, typography, color, interaction states, transitions, copy, icons, forms, edge cases, responsiveness, performance, and code quality — before marking complete." ;
    oc:hasRationale "Comprehensive systematic coverage prevents gaps and ensures no dimension is left rough." ;
    oc:severityLevel "HIGH" .

oc:kn_fda3a104 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before starting any polish work" ;
    oc:directiveContent "Before polishing: verify functional completeness, identify known issues to preserve (mark with TODOs), confirm quality bar (MVP vs flagship), and check ship timeline." ;
    oc:hasRationale "Understanding scope and constraints prevents wasted effort and ensures polish matches the project's quality bar." ;
    oc:severityLevel "HIGH" .

oc:req_463703ec a oc:RequirementTool ;
    oc:isOptional true ;
    oc:requirementValue "browser inspector / devtools for alignment verification" .

oc:req_7d2d8efa a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "design tokens and spacing scale from project's design system" .

oc:req_baa8230f a oc:RequirementKnowledge ;
    oc:isOptional false ;
    oc:requirementValue "WCAG AA contrast ratio requirements" .

