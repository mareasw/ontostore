                            oc:itemOrder 2 ;
                            oc:itemText "[ ] Spacing uses design tokens consistently" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Go through systematically:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
