@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_overdrive a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "overdrive" ;
    skos:broader "UI enhancement skill" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/overdrive" ;
    oc:contentHash "8c83d2dc506b76b5d58cd3d29f3093e2e5cb10be3009b835a32f8e849fb66c81" ;
    oc:dependsOnSkill oc:skill_ontoskills_frontend_design,
        oc:skill_ontoskills_teach_impeccable ;
    oc:differentia "pushes web interfaces past conventional limits using technically ambitious implementations like shaders, spring physics, scroll-driven reveals, and GPU-accelerated rendering to create extraordinary user experiences" ;
    oc:handlesFailure oc:BrowserCompatibilityIssue,
        oc:PerformanceBelowThreshold ;
    oc:hasAllowedTool "Bash",
        "Edit",
        "Glob",
        "Grep",
        "Read",
        "Write" ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Pushes interfaces past conventional limits with technically ambitious implementations — shaders, spring physics, scroll-driven reveals, 60fps animations. Use when the user wants to wow, impress, go all-out, or make something that feels extraordinary." ;
    oc:hasName "overdrive" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Organized by what you're trying to achieve, not by technology name." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Virtual scrolling** — render only visible rows for tables/lists with tens of thousands of items. No library required for simple cases; TanStack Virtual for complex ones." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Animated data transitions** — morph between chart states rather than replacing. D3's `transition()` or View Transitions for DOM-based charts." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**GPU-accelerated charts** — Canvas or WebGL-rendered data visualization for datasets too large for SVG/DOM. Libraries: deck.gl, regl-based custom renderers." ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 13 ;
                    oc:sectionTitle "Make data feel alive" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**WASM** — near-native performance for computation-heavy features. Image processing, physics simulations, codecs." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**OffscreenCanvas** — render in a Worker thread. The main thread stays free while complex visuals render in the background." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Web Workers** — move computation off the main thread. Heavy data processing, image manipulation, search indexing — anything that would cause jank." ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 15 ;
                    oc:sectionTitle "Push performance boundaries" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "**SVG filter chains** — displacement maps, turbulence, morphology for organic distortion effects. CSS-animatable." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**WebGL** (all browsers) — shader effects, post-processing, particle systems. Libraries: Three.js, OGL (lightweight), regl. Use for effects CSS can't express." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**WebGPU** (Chrome/Edge; Safari partial; Firefox: flag only) — next-gen GPU compute. More powerful than WebGL but limited browser support. Always fall back to WebGL2." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Canvas 2D / OffscreenCanvas** — custom rendering, pixel manipulation, or moving heavy rendering off the main thread entirely via Web Workers + OffscreenCanvas." ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 12 ;
                    oc:sectionTitle "Render beyond CSS" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Scroll-driven animations** (`animation-timeline: scroll()`) — CSS-only, no JS. Parallax, progress bars, reveal sequences all driven by scroll position. (Chrome/Edge/Safari; Firefox: flag only — always provide a static fallback)" ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 11 ;
                    oc:sectionTitle "Tie animation to scroll position" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**`@property`** (all browsers) — register custom CSS properties with types, enabling animation of gradients, colors, and complex values that CSS can't normally interpolate." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Web Animations API** (all browsers) — JavaScript-driven animations with the performance of CSS. Composable, cancellable, reversible. The foundation for complex choreography." ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 14 ;
                    oc:sectionTitle "Animate complex properties" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**View Transitions API** (same-document: all browsers; cross-document: no Firefox) — shared element morphing between states. A list item expanding into a detail page. A button morphing into a dialog. This is the closest thing to native FLIP animations." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**`@starting-style`** (all browsers) — animate elements from `display: none` to visible with CSS only, including entry keyframes" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "**Spring physics** — natural motion with mass, tension, and damping instead of cubic-bezier. Libraries: motion (formerly Framer Motion), GSAP, or roll your own spring solver." ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 10 ;
                    oc:sectionTitle "Make transitions feel cinematic" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "**Device APIs** — orientation, ambient light, geolocation. Use sparingly and always with user permission." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "**Web Audio API** — spatial audio, audio-reactive visualizations, sonic feedback. Requires user gesture to start." ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**NOTE**: This skill is about enhancing how an interface FEELS, not changing what a product DOES. Adding real-time collaboration, offline support, or new backend capabilities are product decisions, not UI enhancements. Focus on making existing features feel extraordinary." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 16 ;
                    oc:sectionTitle "Interact with the device" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 9 ;
            oc:sectionTitle "The Toolkit" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:CodeExample ;
                    oc:blockType "code_block" ;
                    oc:codeContent """──────────── ⚡ OVERDRIVE ─────────────
》》》 Entering overdrive mode...
""" ;
                    oc:codeLanguage "" ;
                    oc:contentOrder 3 ;
                    oc:sourceLocation "lines 10-13" ],
                [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: overdrive
description: Pushes interfaces past conventional limits with technically ambitious implementations — shaders, spring physics, scroll-driven reveals, 60fps animations. Use when the user wants to wow, impress, go all-out, or make something that feels extraordinary.
user-invocable: true
argument-hint: "[target]"
""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Start your response with:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 4 ;
                    oc:textContent "Push an interface past conventional limits. This isn't just about visual effects — it's about using the full power of the browser to make any part of an interface feel extraordinary: a table that handles a million rows, a dialog that morphs from its trigger, a form that validates in real-time with streaming feedback, a page transition that feels cinematic." ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "The right kind of technical ambition depends entirely on what you're working with. Before choosing a technique, ask: **what would make a user of THIS specific interface say \"wow, that's nice\"?**" ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Tables, forms, dialogs, navigation — the \"wow\" is in how it FEELS: a dialog that morphs from the button that triggered it via View Transitions, a data table that renders 100k rows at 60fps via virtual scrolling, a form with streaming validation that feels instant, drag-and-drop with spring physics." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 6 ;
                    oc:sectionTitle "For functional UI" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Pages, hero sections, landing pages, portfolios — the \"wow\" is often sensory: a scroll-driven reveal, a shader background, a cinematic page transition, generative art that responds to the cursor." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 5 ;
                    oc:sectionTitle "For visual/marketing surfaces" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Charts and dashboards — the \"wow\" is in fluidity: GPU-accelerated rendering via Canvas/WebGL for massive datasets, animated transitions between data states, force-directed graph layouts that settle naturally." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**The common thread**: something about the implementation goes beyond what users expect from a web interface. The technique serves the experience, not the other way around." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 8 ;
                    oc:sectionTitle "For data-heavy interfaces" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The \"wow\" is invisible but felt: a search that filters 50k items without a flicker, a complex form that never blocks the main thread, an image editor that processes in near-real-time. The interface just never hesitates." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 7 ;
                    oc:sectionTitle "For performance-critical UI" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Assess What \"Extraordinary\" Means Here" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Invoke /frontend-design — it contains design principles, anti-patterns, and the **Context Gathering Protocol**. Follow the protocol before proceeding — if no design context exists yet, you MUST run /teach-impeccable first." ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "**EXTRA IMPORTANT FOR THIS SKILL**: Context determines what \"extraordinary\" means. A particle system on a creative portfolio is impressive. The same particle system on a settings page is embarrassing. But a settings page with instant optimistic saves and animated state transitions? That's extraordinary too. Understand the project's personality and goals before deciding what's appropriate." ] ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Technically ambitious effects almost never work on the first try. You MUST actively use browser automation tools to preview your work, visually verify the result, and iterate. Do not assume the effect looks right — check it. Expect multiple rounds of refinement. The gap between \"technically works\" and \"looks extraordinary\" is closed through visual iteration, not code alone." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 3 ;
                    oc:sectionTitle "Iterate with Browser Automation" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "This skill has the highest potential to misfire. Do NOT jump straight into implementation. You MUST:" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 3 ;
                            oc:textContent "Skipping this step risks building something embarrassing that needs to be thrown away." ],
                        _:ref_9763bcced06a4755 ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 2 ;
                    oc:sectionTitle "Propose Before Building" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "MANDATORY PREPARATION" ],
        [ a oc:Section ;
            oc:hasSubsection [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 3 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Use bleeding-edge APIs without a functional fallback" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 6 ;
                                    oc:itemText "Layer multiple competing extraordinary moments — focus creates impact, excess creates noise" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Ship effects that cause jank on mid-range devices" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Use technical ambition to mask weak design fundamentals — fix those first with other skills" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Add sound without explicit user opt-in" ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Ignore `prefers-reduced-motion` — this is an accessibility requirement, not a suggestion" ] ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "The gap between \"cool\" and \"extraordinary\" is in the last 20% of refinement: the easing curve on a spring animation, the timing offset in a staggered reveal, the subtle secondary motion that makes a transition feel physical. Don't ship the first version that works — ship the version that feels inevitable." ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 2 ;
                            oc:textContent "**NEVER**:" ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 20 ;
                    oc:sectionTitle "Polish is the difference" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:BulletList ;
                            oc:blockType "bullet_list" ;
                            oc:contentOrder 1 ;
                            oc:hasItem [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 5 ;
                                    oc:itemText "Test on real mid-range devices, not just your development machine." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 2 ;
                                    oc:itemText "Respect `prefers-reduced-motion` — always. Provide a beautiful static alternative." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 1 ;
                                    oc:itemText "Target 60fps. If dropping below 50, simplify." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 4 ;
                                    oc:itemText "Pause off-screen rendering. Kill what you can't see." ],
                                [ a oc:BulletItem ;
                                    oc:blockType "bullet_item" ;
                                    oc:itemOrder 3 ;
                                    oc:itemText "Lazy-initialize heavy resources (WebGL contexts, WASM modules) only when near viewport." ] ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 19 ;
                    oc:sectionTitle "Performance rules" ],
                [ a oc:Section ;
                    oc:hasContent [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """if ('gpu' in navigator) { /* WebGPU */ }
else if (canvas.getContext('webgl2')) { /* WebGL2 fallback */ }
/* CSS-only fallback must still look good */
""" ;
                            oc:codeLanguage "javascript" ;
                            oc:contentOrder 3 ;
                            oc:sourceLocation "lines 107-111" ],
                        [ a oc:CodeExample ;
                            oc:blockType "code_block" ;
                            oc:codeContent """@supports (animation-timeline: scroll()) {
  .hero { animation-timeline: scroll(); }
}
""" ;
                            oc:codeLanguage "css" ;
                            oc:contentOrder 2 ;
                            oc:sourceLocation "lines 101-105" ],
                        [ a oc:Paragraph ;
                            oc:blockType "paragraph" ;
                            oc:contentOrder 1 ;
                            oc:textContent "Every technique must degrade gracefully. The experience without the enhancement must still be good." ] ;
                    oc:sectionLevel 3 ;
                    oc:sectionOrder 18 ;
                    oc:sectionTitle "Progressive enhancement is non-negotiable" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 17 ;
            oc:sectionTitle "Implement with Discipline" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Remember: \"Technically extraordinary\" isn't about using the newest API. It's about making an interface do something users didn't think a website could do." ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 1 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**The device test**: Run it on a phone, a tablet, a Chromebook. Still smooth?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**The removal test**: Take it away. Does the experience feel diminished, or does nobody notice?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**The wow test**: Show it to someone who hasn't seen it. Do they react?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**The accessibility test**: Enable reduced motion. Still beautiful?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "**The context test**: Does this make sense for THIS brand and audience?" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 21 ;
            oc:sectionTitle "Verify the Result" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Full workflow for creating technically ambitious UI enhancements that go beyond conventional limits" ;
            oc:hasStep _:ref_1ebc0a719fa63efc,
                _:ref_4734fffc9a803192,
                _:ref_5285b298d5c289c6,
                _:ref_58ba857bf9de6d6c,
                _:ref_a0f9ceed7e7570d6,
                [ a oc:WorkflowStep ;
                    dcterms:description "Run the five verification tests: wow test (fresh eyes react?), removal test (is it missed?), device test (smooth on phones/tablets?), accessibility test (beautiful with reduced motion?), context test (fits brand/audience?)." ;
                    oc:expectedOutcome "All five verification tests pass" ;
                    oc:stepDependsOn _:ref_5285b298d5c289c6 ;
                    oc:stepId "verify" ] ;
            oc:workflowId "overdrive-main" ;
            oc:workflowName "Overdrive Implementation Workflow" ],
        _:ref_9763bcced06a4755 ;
    oc:impartsKnowledge oc:kn_409af5fb,
        oc:kn_7cd2e9d9,
        oc:kn_7eb6a8be,
        oc:kn_895b65de,
        oc:kn_b0fb2fb5,
        oc:kn_b6ae62b1,
        oc:kn_c16bedad,
        oc:kn_d0c79b1d,
        oc:kn_e51d6b73 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextLoaded ;
    oc:resolvesIntent "add cinematic transitions and animations",
        "create extraordinary UI effects",
        "enhance interfaces with advanced browser APIs",
        "implement high-performance data rendering",
        "wow users with technically ambitious frontend implementations" ;
    oc:yieldsState oc:ExtraordinaryUIImplemented,
        oc:ProgressiveEnhancementVerified .

oc:kn_409af5fb a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoping what to implement" ;
    oc:directiveContent "This skill enhances how an interface FEELS, not what a product DOES. Do not add real-time collaboration, offline support, or new backend capabilities — those are product decisions." ;
    oc:hasRationale "Scope creep from UI enhancement to product feature leads to unfocused work" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7cd2e9d9 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When adding any animation or motion effect" ;
    oc:directiveContent "Always respect prefers-reduced-motion — provide a beautiful static alternative. This is an accessibility requirement, not a suggestion." ;
    oc:hasRationale "Motion sensitivity is a real accessibility concern; ignoring it excludes users" ;
    oc:severityLevel "CRITICAL" .

oc:kn_7eb6a8be a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "During and after implementation" ;
    oc:directiveContent "Target 60fps. If dropping below 50fps, simplify. Lazy-initialize heavy resources only when near viewport. Pause off-screen rendering. Test on real mid-range devices." ;
    oc:hasRationale "Performance regression turns extraordinary into frustrating" ;
    oc:severityLevel "HIGH" .

oc:kn_895b65de a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before choosing any implementation technique" ;
    oc:directiveContent "Context determines what 'extraordinary' means. A particle system on a creative portfolio is impressive; the same on a settings page is embarrassing. Match the technique to the interface type and brand personality." ;
    oc:hasRationale "Technical ambition that ignores context produces embarrassing results that must be thrown away" ;
    oc:severityLevel "HIGH" .

oc:kn_b0fb2fb5 a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "Before any implementation begins" ;
    oc:directiveContent "This skill has the highest potential to misfire. Always propose 2-3 different directions with trade-offs before building. Get user confirmation before implementing." ;
    oc:hasRationale "Skipping proposal risks building something embarrassing that must be thrown away" ;
    oc:severityLevel "HIGH" .

oc:kn_b6ae62b1 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any advanced browser API" ;
    oc:directiveContent "Every technique must degrade gracefully via progressive enhancement. The experience without the enhancement must still be good. Use @supports checks and feature detection." ;
    oc:hasRationale "Users on unsupported browsers must still have a functional, attractive experience" ;
    oc:severityLevel "CRITICAL" .

oc:kn_c16bedad a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "After initial implementation" ;
    oc:directiveContent "Technically ambitious effects almost never work on the first try. Use browser automation tools to visually verify and iterate. Expect multiple rounds of refinement." ;
    oc:hasRationale "The gap between technically works and looks extraordinary is closed through visual iteration, not code alone" ;
    oc:severityLevel "MEDIUM" .

oc:kn_d0c79b1d a oc:KnowledgeNode,
        oc:RecoveryTactic ;
    oc:appliesToContext "When using browser APIs with limited support" ;
    oc:directiveContent "For WebGPU, fall back to WebGL2. For scroll-driven animations (Firefox: flag only), provide a static fallback. For all bleeding-edge APIs, ensure CSS-only or basic JS fallbacks exist." ;
    oc:hasRationale "Browser fragmentation means cutting-edge features will fail for some users" ;
    oc:severityLevel "MEDIUM" .

oc:kn_e51d6b73 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning and implementing effects" ;
    oc:directiveContent "Never use technical ambition to mask weak design fundamentals — fix those first with other skills. Never layer multiple competing extraordinary moments — focus creates impact, excess creates noise." ;
    oc:hasRationale "A single extraordinary moment done well is more impactful than many competing effects" ;
    oc:severityLevel "HIGH" .

_:ref_2c8facc6afc8fb12 a oc:WorkflowStep ;
    dcterms:description "Only proceed with the direction the user confirms." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_3" ;
    oc:stepOrder 3 .

_:ref_9ccc56548408a814 a oc:WorkflowStep ;
    dcterms:description "**Think through 2-3 different directions** — consider different techniques, levels of ambition, and aesthetic approaches. For each direction, briefly describe what the result would look and feel like." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_1" ;
    oc:stepOrder 1 .

_:ref_e338a2075eea4777 a oc:WorkflowStep ;
    dcterms:description "**ask the user directly to clarify what you cannot infer.** to present these directions and get the user's pick before writing any code. Explain trade-offs (browser support, performance cost, complexity)." ;
    oc:blockType "workflow_step" ;
    oc:stepId "step_2" ;
    oc:stepOrder 2 .

_:ref_1ebc0a719fa63efc a oc:WorkflowStep ;
    dcterms:description "Think through 2-3 different directions with varying techniques, ambition levels, and aesthetic approaches. Describe look and feel for each. Present to user with trade-offs." ;
    oc:expectedOutcome "User selects one direction to proceed with" ;
    oc:stepDependsOn _:ref_a0f9ceed7e7570d6 ;
    oc:stepId "propose-directions" .

_:ref_4734fffc9a803192 a oc:WorkflowStep ;
    dcterms:description "Invoke /frontend-design for design principles and Context Gathering Protocol. Run /teach-impeccable if no design context exists yet." ;
    oc:expectedOutcome "Design context and project personality are loaded and understood" ;
    oc:stepId "gather-context" .

_:ref_5285b298d5c289c6 a oc:WorkflowStep ;
    dcterms:description "Use browser automation to visually verify the result. Refine easing curves, timing offsets, secondary motion. The last 20% of polish is the difference between cool and extraordinary." ;
    oc:expectedOutcome "Effect looks and feels extraordinary across devices" ;
    oc:stepDependsOn _:ref_58ba857bf9de6d6c ;
    oc:stepId "visual-iterate" .

_:ref_58ba857bf9de6d6c a oc:WorkflowStep ;
    dcterms:description "Build the selected direction with progressive enhancement (feature detection, @supports, fallbacks), 60fps target, prefers-reduced-motion support, and lazy initialization of heavy resources." ;
    oc:expectedOutcome "Working implementation with graceful degradation" ;
    oc:stepDependsOn _:ref_1ebc0a719fa63efc ;
    oc:stepId "implement" .

_:ref_9763bcced06a4755 a oc:Workflow ;
    oc:blockType "ordered_procedure" ;
    oc:contentOrder 2 ;
    oc:hasStep _:ref_2c8facc6afc8fb12,
        _:ref_9ccc56548408a814,
        _:ref_e338a2075eea4777 ;
    oc:workflowId "procedure_2" ;
    oc:workflowName "Ordered Procedure" .

_:ref_a0f9ceed7e7570d6 a oc:WorkflowStep ;
    dcterms:description "Assess what 'extraordinary' means for this specific interface. Determine if it's visual/marketing, functional UI, performance-critical, or data-heavy. Identify the right category of technique." ;
    oc:expectedOutcome "Clear understanding of which techniques match the interface type and brand" ;
    oc:stepDependsOn _:ref_4734fffc9a803192 ;
    oc:stepId "assess-extraordinary" .

