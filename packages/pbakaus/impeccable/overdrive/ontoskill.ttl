@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_overdrive a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "overdrive" ;
    skos:broader "UI enhancement skill" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/overdrive" ;
    oc:contentHash "8c83d2dc506b76b5d58cd3d29f3093e2e5cb10be3009b835a32f8e849fb66c81" ;
    oc:dependsOnSkill oc:skill_frontend_design,
        oc:skill_teach_impeccable ;
    oc:differentia "pushes browser interfaces past conventional limits using advanced rendering, animation physics, and GPU-accelerated techniques to create extraordinary user experiences" ;
    oc:handlesFailure oc:BrowserAPINotSupported,
        oc:DesignContextMismatch,
        oc:PerformanceThresholdExceeded,
        oc:ReducedMotionConstraint ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Pushes interfaces past conventional limits with technically ambitious implementations — shaders, spring physics, scroll-driven reveals, 60fps animations. Use when the user wants to wow, impress, go all-out, or make something that feels extraordinary." ;
    oc:hasName "overdrive" ;
    oc:impartsKnowledge oc:kn_14129704,
        oc:kn_15e61a24,
        oc:kn_2b591032,
        oc:kn_4c085221,
        oc:kn_53b9c8d1,
        oc:kn_b5baefb8,
        oc:kn_c923ea5a,
        oc:kn_ef173493 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:DesignContextLoaded,
        oc:FrontendDesignPrinciplesReady ;
    oc:resolvesIntent "add spring physics animations",
        "add wow-factor to an interface",
        "build high-performance data visualizations",
        "create cinematic page transitions",
        "create morphing dialog transitions",
        "implement scroll-driven animations",
        "implement shader effects or particle systems",
        "implement virtual scrolling for massive datasets",
        "optimize UI to 60fps" ;
    oc:yieldsState oc:ExtraordinaryUIImplemented,
        oc:PerformanceBudgetMet,
        oc:ProgressiveEnhancementVerified .

oc:kn_14129704 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any advanced browser API or effect" ;
    oc:directiveContent "Every technique must degrade gracefully via progressive enhancement. The experience without the enhancement must still be good. Always provide static fallbacks for scroll-driven animations, WebGPU/WebGL, and View Transitions." ;
    oc:hasRationale "Bleeding-edge APIs have inconsistent browser support. Firefox lacks cross-document View Transitions and only flags scroll-driven animations. Users on unsupported browsers must still have a functional, attractive experience." ;
    oc:severityLevel "CRITICAL" .

oc:kn_15e61a24 a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning which techniques to apply to a single interface" ;
    oc:directiveContent "Never layer multiple competing extraordinary moments. Focus creates impact; excess creates noise. One exceptional effect is better than five good ones." ;
    oc:hasRationale "Technical ambition that masks weak design fundamentals is counterproductive. Each 'wow' moment should be singular and purposeful." ;
    oc:severityLevel "MEDIUM" .

oc:kn_2b591032 a oc:Idempotency,
        oc:KnowledgeNode ;
    oc:appliesToContext "When managing WebGL, WebGPU, WASM, or Canvas rendering contexts" ;
    oc:directiveContent "Lazy-initialize heavy resources (WebGL contexts, WASM modules) only when near viewport. Pause off-screen rendering and clean up invisible effects. Heavy GPU resources should be created on demand, not at page load." ;
    oc:hasRationale "GPU contexts and WASM modules consume significant memory and compute. Initializing them eagerly wastes resources; leaving them active while off-screen causes unnecessary battery drain and performance degradation." ;
    oc:severityLevel "HIGH" .

oc:kn_4c085221 a oc:Heuristic,
        oc:KnowledgeNode ;
    oc:appliesToContext "When assessing which techniques to propose for a given interface" ;
    oc:directiveContent "Context determines what 'extraordinary' means. A particle system on a creative portfolio is impressive; the same on a settings page is embarrassing. Match the technique to the surface type: sensory wow for marketing pages, feel wow for functional UI, invisible wow for performance-critical UI, fluidity wow for data-heavy interfaces." ;
    oc:hasRationale "The technique must serve the experience, not the other way around. The right kind of ambition depends entirely on what you're working with." ;
    oc:severityLevel "HIGH" .

oc:kn_53b9c8d1 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "Before any code is written for overdrive enhancements" ;
    oc:directiveContent "Never jump straight into implementation without proposing 2-3 different directions and getting user confirmation. This skill has the highest potential to misfire and produce embarrassing results if context is misread." ;
    oc:hasRationale "Technically ambitious effects that don't match the project's personality waste effort and may need to be thrown away entirely." ;
    oc:severityLevel "CRITICAL" .

oc:kn_b5baefb8 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When scoping what overdrive should deliver" ;
    oc:directiveContent "This skill enhances how an interface FEELS, not what a product DOES. Adding real-time collaboration, offline support, or new backend capabilities are product decisions outside this skill's scope." ;
    oc:hasRationale "The boundary between UI enhancement and product feature is important. Overdrive focuses on making existing features feel extraordinary through rendering, animation, and performance techniques." ;
    oc:severityLevel "MEDIUM" .

oc:kn_c923ea5a a oc:KnowledgeNode,
        oc:WorkflowStrategy ;
    oc:appliesToContext "After initial implementation of any overdrive effect" ;
    oc:directiveContent "Technically ambitious effects almost never work on the first try. You MUST use browser automation tools to visually verify results and iterate through multiple refinement rounds. The gap between 'technically works' and 'looks extraordinary' is closed through visual iteration." ;
    oc:hasRationale "Complex animations, shaders, and transitions have subtle visual properties that cannot be reliably assessed from code alone. The last 20% of refinement—easing curves, timing offsets, secondary motion—is what separates 'cool' from 'extraordinary'." ;
    oc:severityLevel "HIGH" .

oc:kn_ef173493 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When implementing any animation or motion effect" ;
    oc:directiveContent "Always respect prefers-reduced-motion. This is an accessibility requirement, not a suggestion. Provide a beautiful static alternative. Target 60fps minimum; simplify if dropping below 50fps." ;
    oc:hasRationale "Ignoring reduced motion preferences excludes users with vestibular disorders. Performance jank on mid-range devices degrades everyone's experience." ;
    oc:severityLevel "CRITICAL" .

