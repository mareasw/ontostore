oc:skill_pbakaus_impeccable_extract a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "extract" ;
    skos:broader "Design system consolidation workflow" ;
    prov:wasDerivedFrom "../.agents/skills/pbakaus/impeccable/extract" ;
    oc:contentHash "ccdbbe16c9612d270dc90ab6cb33d9962a415c6198487e61bb7f0b6d5118b658" ;
    oc:differentia "that identifies reusable UI patterns, extracts them into shared components and design tokens, and migrates existing code to consume them" ;
    oc:handlesFailure oc:DesignSystemNotFound,
        oc:InvalidInput ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Extract and consolidate reusable components, design tokens, and patterns into your design system. Identifies opportunities for systematic reuse and enriches your component library. Use when the user asks to create components, refactor repeated UI patterns, build a design system, or extract tokens." ;
    oc:hasName "extract" ;
    oc:hasSection [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "Remember: A good design system is a living system. Extract patterns as they emerge, enrich them thoughtfully, and maintain them consistently." ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Add examples and guidelines" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Update any Storybook or component catalog" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Add new components to the component library" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Document token usage and values" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Update design system documentation:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 5 ;
            oc:sectionTitle "Document" ],
        [ a oc:Section ;
            oc:hasContent _:ref_3e3911002c7917a7,
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Analyze the target area to identify extraction opportunities:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 1 ;
            oc:sectionTitle "Discover" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Build improved, reusable versions:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**NEVER**:" ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:hasChild [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Documentation of when to use each token" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Proper hierarchy and organization" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Clear naming (primitive vs semantic)" ] ] ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Design tokens**: Create tokens with:" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:hasChild [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "Clear props API with sensible defaults" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 4 ;
                                            oc:itemText "Documentation and usage examples" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Accessibility built in (ARIA, keyboard navigation, focus management)" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Proper variants for different use cases" ] ] ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Components**: Create well-designed components with:" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:hasChild [ a oc:BulletList ;
                                    oc:blockType "bullet_list" ;
                                    oc:contentOrder 1 ;
                                    oc:hasItem [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 1 ;
                                            oc:itemText "When to use this pattern" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 3 ;
                                            oc:itemText "Variations and combinations" ],
                                        [ a oc:BulletItem ;
                                            oc:blockType "bullet_item" ;
                                            oc:itemOrder 2 ;
                                            oc:itemText "Code examples" ] ] ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Patterns**: Document patterns with:" ] ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 4 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "Create components so generic they're useless" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "Skip proper TypeScript types or prop documentation" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "Extract one-off, context-specific implementations without generalization" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "Create tokens for every single value (tokens should have semantic meaning)" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "Extract without considering existing design system conventions" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 3 ;
            oc:sectionTitle "Extract & Enrich" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:FrontmatterBlock ;
                    oc:blockType "frontmatter" ;
                    oc:contentOrder 1 ;
                    oc:rawYaml """name: extract
description: Extract and consolidate reusable components, design tokens, and patterns into your design system. Identifies opportunities for systematic reuse and enriches your component library. Use when the user asks to create components, refactor repeated UI patterns, build a design system, or extract tokens.
user-invocable: true
argument-hint: "[target]"
""" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 2 ;
                    oc:textContent "Identify reusable patterns, components, and design tokens, then extract and consolidate them into the design system for systematic reuse." ] ;
            oc:sectionLevel 0 ;
            oc:sectionOrder 0 ;
            oc:sectionTitle "" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Create a systematic extraction plan:" ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 3 ;
                    oc:textContent "**IMPORTANT**: Design systems grow incrementally. Extract what's clearly reusable now, not everything that might someday be reusable." ],
                [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 5 ;
                            oc:itemText "**Migration path**: How to refactor existing uses to consume the new shared versions" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Components to extract**: Which UI elements become reusable components?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Tokens to create**: Which hard-coded values become design tokens?" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Naming conventions**: Component names, token names, prop names that match existing patterns" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Variants to support**: What variations does each component need?" ] ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 2 ;
            oc:sectionTitle "Plan Extraction" ],
        [ a oc:Section ;
            oc:hasContent [ a oc:BulletList ;
                    oc:blockType "bullet_list" ;
                    oc:contentOrder 2 ;
                    oc:hasItem [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 1 ;
                            oc:itemText "**Find all instances**: Search for the patterns you've extracted" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 2 ;
                            oc:itemText "**Replace systematically**: Update each use to consume the shared version" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 4 ;
                            oc:itemText "**Delete dead code**: Remove the old implementations" ],
                        [ a oc:BulletItem ;
                            oc:blockType "bullet_item" ;
                            oc:itemOrder 3 ;
                            oc:itemText "**Test thoroughly**: Ensure visual and functional parity" ] ],
                [ a oc:Paragraph ;
                    oc:blockType "paragraph" ;
                    oc:contentOrder 1 ;
                    oc:textContent "Replace existing uses with the new shared versions:" ] ;
            oc:sectionLevel 2 ;
            oc:sectionOrder 4 ;
            oc:sectionTitle "Migrate" ] ;
    oc:hasWorkflow [ a oc:Workflow ;
            dcterms:description "Full workflow for identifying reusable UI patterns and consolidating them into a design system." ;
            oc:hasStep [ a oc:WorkflowStep ;
                    dcterms:description "Update design system docs, add to component library, document token usage, update Storybook or catalog" ;
