@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix oc: <https://ontoskills.sh/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oc:skill_pbakaus_impeccable_extract a oc:DeclarativeSkill,
        oc:Skill ;
    dcterms:identifier "extract" ;
    skos:broader "Design system refactoring workflow" ;
    prov:wasDerivedFrom "/home/marcello/Documenti/onto/ontoskills/.agents/skills/pbakaus/impeccable/extract" ;
    oc:contentHash "ccdbbe16c9612d270dc90ab6cb33d9962a415c6198487e61bb7f0b6d5118b658" ;
    oc:differentia "Identifies repeated UI patterns, hard-coded values, and inconsistent implementations across a codebase and consolidates them into reusable components, design tokens, and documented patterns for systematic reuse" ;
    oc:extends oc:skill_normalize ;
    oc:handlesFailure oc:ExtractionAmbiguous,
        oc:MigrationFailed,
        oc:NoDesignSystemFound ;
    oc:hasArgumentHint "[target]" ;
    oc:hasCategory "development" ;
    oc:hasDescription "Extract and consolidate reusable components, design tokens, and patterns into your design system. Identifies opportunities for systematic reuse and enriches your component library. Use when the user asks to create components, refactor repeated UI patterns, build a design system, or extract tokens." ;
    oc:hasName "extract" ;
    oc:impartsKnowledge oc:kn_04c0a32d,
        oc:kn_52c930ba,
        oc:kn_7b1333db,
        oc:kn_ad11c0d4,
        oc:kn_b8fc355e,
        oc:kn_c1cebfd3,
        oc:kn_d3de7b22 ;
    oc:isUserInvocable true ;
    oc:nature "Work" ;
    oc:requiresState oc:CodebaseAvailable ;
    oc:resolvesIntent "build or extend a design system",
        "consolidate inconsistent UI implementations",
        "extract design tokens from hard-coded values",
        "extract reusable components from existing UI",
        "refactor repeated UI patterns into shared components" ;
    oc:yieldsState oc:ComponentsExtracted,
        oc:DesignSystemUpdated,
        oc:DocumentationUpdated,
        oc:TokensCreated .

oc:kn_04c0a32d a oc:DesignPrinciple,
        oc:KnowledgeNode ;
    oc:appliesToContext "When planning which patterns to extract" ;
    oc:directiveContent "Design systems grow incrementally — extract what is clearly reusable now (used 3+ times or highly likely to be reused), not everything that might someday be reusable." ;
    oc:hasRationale "Premature abstraction creates maintenance burden and inflexible APIs that resist future change" ;
    oc:severityLevel "HIGH" .

oc:kn_52c930ba a oc:KnowledgeNode,
        oc:Standard ;
    oc:appliesToContext "During the migration phase of extraction" ;
    oc:directiveContent "After extraction, systematically find all instances of the old pattern, replace them with the new shared version, test for visual and functional parity, and delete dead code." ;
    oc:hasRationale "Incomplete migration leaves duplicated code and defeats the consistency goals of the design system" ;
    oc:severityLevel "MEDIUM" .

oc:kn_7b1333db a oc:KnowledgeNode,
        oc:PostFlightValidation ;
    oc:appliesToContext "After completing extraction and migration" ;
    oc:directiveContent "After extraction, update design system documentation: add new components to the library, document token usage and values, add examples and guidelines, and update Storybook or component catalogs." ;
    oc:hasRationale "Undiscovered components are unused components — documentation is essential for adoption and maintenance of the design system" ;
    oc:severityLevel "MEDIUM" .

oc:kn_ad11c0d4 a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When extracting design tokens from hard-coded values" ;
    oc:directiveContent "Design tokens must have semantic meaning — do not create a token for every single hard-coded value. Distinguish between primitive tokens (raw values) and semantic tokens (purpose-based)." ;
    oc:hasRationale "Token proliferation without semantic meaning makes the design system harder to understand and maintain than the original hard-coded values" ;
    oc:severityLevel "MEDIUM" .

oc:kn_b8fc355e a oc:Constraint,
        oc:KnowledgeNode ;
    oc:appliesToContext "When building extracted components" ;
    oc:directiveContent "Never skip proper TypeScript types, prop documentation, or accessibility (ARIA, keyboard navigation, focus management) when creating extracted components." ;
    oc:hasRationale "Undocumented or inaccessible shared components propagate low quality across the entire system" ;
    oc:severityLevel "HIGH" .

oc:kn_c1cebfd3 a oc:AntiPattern,
        oc:KnowledgeNode ;
    oc:appliesToContext "When deciding what to extract from the codebase" ;
    oc:directiveContent "Never extract one-off, context-specific implementations without generalization, and never create components so generic they become useless." ;
    oc:hasRationale "Over-extraction pollutes the design system with noise; under-generalization defeats the purpose of shared components" ;
    oc:severityLevel "HIGH" .

oc:kn_d3de7b22 a oc:KnowledgeNode,
        oc:PreFlightCheck ;
    oc:appliesToContext "Before beginning any extraction work" ;
    oc:directiveContent "Before extracting, locate the existing design system or component library. If no design system exists, ask the user before creating one — understand preferred location and structure first." ;
    oc:hasRationale "Creating a design system in the wrong location or structure creates technical debt and conflicts with team conventions" ;
    oc:severityLevel "CRITICAL" .

