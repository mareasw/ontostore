_:ref_2d08140ae250c105 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 2 ;
    oc:itemText "Would systematizing this improve consistency?" .

_:ref_39fc16c169af8f12 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 4 ;
    oc:itemText "**Reusable patterns**: Layout patterns, composition patterns, interaction patterns worth systematizing" .

_:ref_44841b776b92968d a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 1 ;
    oc:itemText "**Repeated components**: Similar UI patterns used multiple times (buttons, cards, inputs, etc.)" .

_:ref_4ae45f36be7e70b7 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 4 ;
    oc:itemText "What's the maintenance cost vs benefit?" .

_:ref_668ae063a6f6ef7a a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem _:ref_39fc16c169af8f12,
        _:ref_44841b776b92968d,
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 3 ;
            oc:itemText "**Inconsistent variations**: Multiple implementations of the same concept (3 different button styles)" ],
        [ a oc:BulletItem ;
            oc:blockType "bullet_item" ;
            oc:itemOrder 2 ;
            oc:itemText "**Hard-coded values**: Colors, spacing, typography, shadows that should be tokens" ] .

_:ref_867c45a09a025757 a oc:BulletItem ;
    oc:blockType "bullet_item" ;
    oc:itemOrder 3 ;
    oc:itemText "Is this a general pattern or context-specific?" .

_:ref_aa110373660f77b0 a oc:BulletList ;
    oc:blockType "bullet_list" ;
    oc:contentOrder 1 ;
    oc:hasItem _:ref_2d08140ae250c105,
